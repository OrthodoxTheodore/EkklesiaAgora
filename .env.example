# Ekklesia Agora — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ─── Firebase Client SDK (Public — safe to expose in browser) ───────────────
# Source: Firebase Console → Project Settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ─── Firebase Admin SDK (Server-only — NEVER prefix with NEXT_PUBLIC_) ──────
# Source: Firebase Console → Project Settings → Service accounts → Generate new private key
# FIREBASE_PROJECT_ID: same value as NEXT_PUBLIC_FIREBASE_PROJECT_ID
FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL: client_email field from downloaded service account JSON
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY: private_key field from downloaded JSON — wrap in double quotes
# The value must include the -----BEGIN PRIVATE KEY----- header and -----END PRIVATE KEY----- footer
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Session Cookie Signing Keys ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Use different values for current and previous (supports key rotation)
COOKIE_SECRET_CURRENT=generate-a-random-32-plus-character-string
COOKIE_SECRET_PREVIOUS=generate-another-random-32-plus-character-string

# ─── Super Admin Setup (one-time use, not required at runtime) ───────────────
# Email of the first super admin user. Run: npm run seed:admin
# The user must exist in Firebase Auth before running this script.
SUPER_ADMIN_EMAIL=your-admin-email@example.com
