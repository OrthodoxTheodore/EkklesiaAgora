rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Ekklesia Agora — Firestore Security Rules
//
// SECURITY PHILOSOPHY: Defense-in-depth.
// Middleware (next-firebase-auth-edge) handles routing but CAN be bypassed.
// Server Components call getTokens() for per-page auth checks.
// These Firestore rules are the REAL security layer — they enforce access
// control on every database read/write, regardless of how a request arrives.
//
// ROLE HIERARCHY (roleLevel custom claim on Firebase Auth tokens):
//   0 = guest (unauthenticated — no claim present)
//   1 = registered
//   2 = moderator
//   3 = admin
//   4 = superAdmin
//
// Custom claims are set via Firebase Admin SDK (server-only) and embedded
// in the JWT. They are available as request.auth.token.roleLevel in rules.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ───────────────────────────────────────────────────

    /// Returns the caller's roleLevel from their JWT custom claim.
    /// Falls back to 0 (guest) if the claim is absent.
    function roleLevel() {
      return request.auth != null
        ? (request.auth.token.get('roleLevel', 0))
        : 0;
    }

    /// True if caller is a registered user or higher (roleLevel >= 1).
    function isRegistered() {
      return request.auth != null && roleLevel() >= 1;
    }

    /// True if caller is a moderator or higher (roleLevel >= 2).
    function isModerator() {
      return request.auth != null && roleLevel() >= 2;
    }

    /// True if caller is an admin or higher (roleLevel >= 3).
    function isAdmin() {
      return request.auth != null && roleLevel() >= 3;
    }

    /// True if caller is a super admin (roleLevel == 4).
    function isSuperAdmin() {
      return request.auth != null && roleLevel() == 4;
    }

    /// True if the caller's UID matches the given uid (resource owner check).
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ─── /users/{uid} ───────────────────────────────────────────────────────
    // User profile documents.
    //   READ:  any authenticated user (for social features — display names, etc.)
    //   WRITE: the document owner OR admin+ (for role denormalization via Admin SDK)
    //          Note: roleLevel field is ALSO set by Admin SDK which bypasses rules.
    //          These write rules cover direct client writes (profile edits).

    match /users/{uid} {
      allow read: if request.auth != null;

      // Owner can update their own profile fields (not roleLevel — that's Admin SDK only).
      // Admin+ can update any user document (used for denormalized roleLevel sync).
      allow write: if isOwner(uid) || isAdmin();
    }

    // ─── /roleAuditLog/{entry} ──────────────────────────────────────────────
    // Role promotion audit trail.
    //   READ:  admin+ only (for audit review in admin panel)
    //   WRITE: false — Admin SDK bypasses rules; all writes come from claims.ts
    //          Blocking client writes here is intentional — this collection
    //          must only be writable by trusted server code.

    match /roleAuditLog/{entry} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ─── /userProfiles/{uid} ────────────────────────────────────────────────
    // Public user profiles for the social feed.
    //   READ:  anyone (profiles are public)
    //   WRITE: document owner only (Server Actions use Admin SDK for creation)

    match /userProfiles/{uid} {
      allow read: if true;
      allow write: if isOwner(uid);
    }

    // ─── /posts/{postId} ────────────────────────────────────────────────────
    // Social feed posts.
    //   READ:  anyone
    //   WRITE: false — Server Actions only via Admin SDK

    match /posts/{postId} {
      allow read: if true;
      allow write: if false;

      // /posts/{postId}/likes/{uid}
      //   READ:  anyone
      //   WRITE: the liking user (must be registered)
      match /likes/{uid} {
        allow read: if true;
        allow write: if isOwner(uid) && isRegistered();
      }

      // /posts/{postId}/comments/{commentId}
      //   READ:  anyone
      //   WRITE: false — Server Actions only
      match /comments/{commentId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ─── /follows/{followId} ────────────────────────────────────────────────
    // Follow relationships between users.
    //   READ:  authenticated users only
    //   WRITE: false — Server Actions only

    match /follows/{followId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── /users/{uid}/userFeed/{postId} ─────────────────────────────────────
    // Per-user fan-out feed (denormalized post copies).
    //   READ:  the feed owner only
    //   WRITE: false — Server Actions fan-out writes only

    match /users/{uid}/userFeed/{postId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // ─── /users/{uid}/notifications/{notificationId} ────────────────────────
    // Per-user notification inbox.
    //   READ:  the inbox owner only
    //   WRITE: false — Server Actions only

    match /users/{uid}/notifications/{notificationId} {
      allow read: if isOwner(uid);
      allow write: if false;
    }

    // ─── /userBlocks/{uid}/blocked/{blockedUid} ─────────────────────────────
    // Per-user block list.
    //   READ:  the list owner only
    //   WRITE: the list owner (must be registered)

    match /userBlocks/{uid}/blocked/{blockedUid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && isRegistered();
    }

    // ─── /userMutes/{uid}/muted/{mutedUid} ──────────────────────────────────
    // Per-user mute list.
    //   READ:  the list owner only
    //   WRITE: the list owner (must be registered)

    match /userMutes/{uid}/muted/{mutedUid} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && isRegistered();
    }

    // ─── Phase 3: Videos ────────────────────────────────────────────────────
    // /videos/{videoId}
    //   READ:  published videos to anyone; pending/rejected to owner or moderator+
    //   WRITE: false — Server Actions only via Admin SDK

    match /videos/{videoId} {
      allow read: if resource.data.status == 'published'
        || (request.auth != null && request.auth.uid == resource.data.uploaderUid)
        || isModerator();
      allow write: if false;

      // /videos/{videoId}/likes/{uid}
      //   READ:  anyone
      //   WRITE: the liking user (must be registered)
      match /likes/{uid} {
        allow read: if true;
        allow write: if isOwner(uid) && isRegistered();
      }

      // /videos/{videoId}/comments/{commentId}
      //   READ:  anyone
      //   WRITE: false — Server Actions only
      match /comments/{commentId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ─── Phase 3: Channels ──────────────────────────────────────────────────
    // /channels/{channelId}
    //   READ:  approved channels to anyone; pending/rejected to owner or moderator+
    //   WRITE: false — Server Actions only via Admin SDK

    match /channels/{channelId} {
      allow read: if resource.data.status == 'approved'
        || (request.auth != null && request.auth.uid == resource.data.ownerUid)
        || isModerator();
      allow write: if false;
    }

    // ─── Phase 3: Channel subscribes ────────────────────────────────────────
    // /channelSubscribes/{channelId}/subscribers/{uid}
    //   READ:  authenticated users
    //   WRITE: false — Server Actions only via Admin SDK

    match /channelSubscribes/{channelId}/subscribers/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ─── Phase 6: Patristic Library ─────────────────────────────────────────
    // /patristic_texts/{textId}
    //   READ:  anyone (public domain CCEL texts)
    //   WRITE: false — Admin SDK seed writes bypass rules

    match /patristic_texts/{textId} {
      allow read: if true;
      allow write: if false;
    }

    // /patristic_authors/{slug}
    //   READ:  anyone
    //   WRITE: false — Admin SDK seed writes bypass rules

    match /patristic_authors/{slug} {
      allow read: if true;
      allow write: if false;
    }

    // /study_guides/{guideId}
    //   READ:  anyone
    //   WRITE: false — Admin SDK seed writes bypass rules

    match /study_guides/{guideId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Conversations ─────────────────────────────────────────────────
    match /conversations/{conversationId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.participantUids;
      allow write: if false; // Server Actions only via Admin SDK

      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow write: if false; // Server Actions only via Admin SDK
      }
    }
  }
}
