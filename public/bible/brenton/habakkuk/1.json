[{"verseId":"brenton_habakkuk_1_1","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":1,"text":"burden which the prophet Ambacum saw.","searchKeywords":["burden","which","the","prophet","ambacum","saw"]},{"verseId":"brenton_habakkuk_1_2","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":2,"text":"How long, O Lord, shall I cry out, and thou wilt not hearken? shall I cry out to thee being injured, and thou wilt not save?","searchKeywords":["how","long","lord","shall","cry","out","and","thou","wilt","not","hearken","thee","being","injured","save"]},{"verseId":"brenton_habakkuk_1_3","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":3,"text":"Wherefore hast thou shewn me troubles and griefs to look upon, misery and ungodliness? judgment is before me, and the judge receives a reward.","searchKeywords":["wherefore","hast","thou","shewn","troubles","and","griefs","look","upon","misery","ungodliness","judgment","before","the","judge","receives","reward"]},{"verseId":"brenton_habakkuk_1_4","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":4,"text":"Therefore the law is frustrated, and judgment proceeds not effectually, for the ungodly prevails over the just; therefore perverse judgment will proceed.","searchKeywords":["therefore","the","law","frustrated","and","judgment","proceeds","not","effectually","for","ungodly","prevails","over","just","perverse","will","proceed"]},{"verseId":"brenton_habakkuk_1_5","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":5,"text":"Behold, ye despisers, and look, and wonder marvellously, and vanish: for I work a work in your days, which ye will in no wise believe, though a man declare .","searchKeywords":["behold","despisers","and","look","wonder","marvellously","vanish","for","work","your","days","which","will","wise","believe","though","man","declare"]},{"verseId":"brenton_habakkuk_1_6","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":6,"text":"Wherefore, behold, I stir up the Chaldeans, the bitter and hasty nation, that walks upon the breadth of the earth, to inherit tabernacles not his own.","searchKeywords":["wherefore","behold","stir","the","chaldeans","bitter","and","hasty","nation","that","walks","upon","breadth","earth","inherit","tabernacles","not","his","own"]},{"verseId":"brenton_habakkuk_1_7","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":7,"text":"He is terrible and famous; his judgment shall proceed of himself, and his dignity shall come out of himself.","searchKeywords":["terrible","and","famous","his","judgment","shall","proceed","himself","dignity","come","out"]},{"verseId":"brenton_habakkuk_1_8","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":8,"text":"And his horses shall bound than leopards, and fiercer than the wolves of Arabia: and his horsemen shall ride forth, and shall rush from far; and they shall fly as an eagle hasting to eat.","searchKeywords":["and","his","horses","shall","bound","than","leopards","fiercer","the","wolves","arabia","horsemen","ride","forth","rush","from","far","they","fly","eagle","hasting","eat"]},{"verseId":"brenton_habakkuk_1_9","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":9,"text":"Destruction shall come upon ungodly men, resisting with their adverse front, and he shall gather the captivity as the sand.","searchKeywords":["destruction","shall","come","upon","ungodly","men","resisting","with","their","adverse","front","and","gather","the","captivity","sand"]},{"verseId":"brenton_habakkuk_1_10","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":10,"text":"And he shall be at his ease with kings, and princes are his toys, and he shall mock at every strong-hold, and shall cast a mound, and take possession of it.","searchKeywords":["and","shall","his","ease","with","kings","princes","are","toys","mock","every","strong","hold","cast","mound","take","possession"]},{"verseId":"brenton_habakkuk_1_11","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":11,"text":"Then shall he change his spirit, and he shall pass through, and make an atonement, , This strength to my god.","searchKeywords":["then","shall","change","his","spirit","and","pass","through","make","atonement","this","strength","god"]},{"verseId":"brenton_habakkuk_1_12","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":12,"text":"not thou from the beginning, O Lord God, my Holy One? and surely we shall not die. O Lord, thou hast established it for judgment, and he has formed me to chasten his correction.","searchKeywords":["not","thou","from","the","beginning","lord","god","holy","one","and","surely","shall","die","hast","established","for","judgment","has","formed","chasten","his","correction"]},{"verseId":"brenton_habakkuk_1_13","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":13,"text":"eye is too pure to behold evil , and to look upon grievous afflictions: wherefore dost thou look upon despisers? wilt thou be silent when the ungodly swallows up the just?","searchKeywords":["eye","too","pure","behold","evil","and","look","upon","grievous","afflictions","wherefore","dost","thou","despisers","wilt","silent","when","the","ungodly","swallows","just"]},{"verseId":"brenton_habakkuk_1_14","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":14,"text":"And wilt thou make men as the fishes of the sea, and as the reptiles which have no guide?","searchKeywords":["and","wilt","thou","make","men","the","fishes","sea","reptiles","which","have","guide"]},{"verseId":"brenton_habakkuk_1_15","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":15,"text":"He has brought up destruction with a hook, and drawn one with a casting net, and caught another in his drags: therefore shall his heart rejoice and be glad.","searchKeywords":["has","brought","destruction","with","hook","and","drawn","one","casting","net","caught","another","his","drags","therefore","shall","heart","rejoice","glad"]},{"verseId":"brenton_habakkuk_1_16","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":16,"text":"Therefore will he sacrifice to his drag, and burn incense to his casting-net, because by them he has made his portion fat, and his meats choice.","searchKeywords":["therefore","will","sacrifice","his","drag","and","burn","incense","casting","net","because","them","has","made","portion","fat","meats","choice"]},{"verseId":"brenton_habakkuk_1_17","translationId":"brenton","testament":"OT","bookIndex":40,"bookName":"Habakkuk","bookAbbrev":"habakkuk","chapter":1,"verse":17,"text":"Therefore will he cast his net, and will not spare to slay the nations continually.","searchKeywords":["therefore","will","cast","his","net","and","not","spare","slay","the","nations","continually"]}]