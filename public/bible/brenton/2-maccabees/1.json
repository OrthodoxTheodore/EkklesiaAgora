[{"verseId":"brenton_2-maccabees_1_1","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":1,"text":"brethren, the Jews that be at Jerusalem and in the land of Judea, wish unto the brethren, the Jews that are throughout Egypt, health and peace:","searchKeywords":["brethren","the","jews","that","jerusalem","and","land","judea","wish","unto","are","throughout","egypt","health","peace"]},{"verseId":"brenton_2-maccabees_1_2","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":2,"text":"God be gracious unto you, and remember his covenant that he made with Abraham, Isaac, and Jacob, his faithful servants;","searchKeywords":["god","gracious","unto","you","and","remember","his","covenant","that","made","with","abraham","isaac","jacob","faithful","servants"]},{"verseId":"brenton_2-maccabees_1_3","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":3,"text":"and give you all an heart to serve him, and to do his will, with a good courage and a willing mind;","searchKeywords":["and","give","you","all","heart","serve","him","his","will","with","good","courage","willing","mind"]},{"verseId":"brenton_2-maccabees_1_4","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":4,"text":"and open your hearts in his law and commandments, and send you peace,","searchKeywords":["and","open","your","hearts","his","law","commandments","send","you","peace"]},{"verseId":"brenton_2-maccabees_1_5","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":5,"text":"and hear your prayers, and be at one with you, and never forsake you in time of trouble.","searchKeywords":["and","hear","your","prayers","one","with","you","never","forsake","time","trouble"]},{"verseId":"brenton_2-maccabees_1_6","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":6,"text":"And now we be here praying for you.","searchKeywords":["and","now","here","praying","for","you"]},{"verseId":"brenton_2-maccabees_1_7","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":7,"text":"What time as Demetrius reigned, in the hundred threescore and ninth year, we the Jews wrote unto you in the extremity of trouble that came upon us in those years, from the time that Jason and his company revolted from the holy land and kingdom,","searchKeywords":["what","time","demetrius","reigned","the","hundred","threescore","and","ninth","year","jews","wrote","unto","you","extremity","trouble","that","came","upon","those","years","from","jason","his","company","revolted","holy","land","kingdom"]},{"verseId":"brenton_2-maccabees_1_8","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":8,"text":"and burned the porch, and shed innocent blood: then we prayed unto the Lord, and were heard; we offered also sacrifices and fine flour, and lighted the lamps, and set forth the loaves.","searchKeywords":["and","burned","the","porch","shed","innocent","blood","then","prayed","unto","lord","were","heard","offered","also","sacrifices","fine","flour","lighted","lamps","set","forth","loaves"]},{"verseId":"brenton_2-maccabees_1_9","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":9,"text":"And now see that ye keep the feast of tabernacles in the month Casleu.","searchKeywords":["and","now","see","that","keep","the","feast","tabernacles","month","casleu"]},{"verseId":"brenton_2-maccabees_1_10","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":10,"text":"In the hundred fourscore and eighth year, the people that were at Jerusalem and in Judea, and the council, and Judas, sent greeting and health unto Aristobulus, king Ptolemeus' master, who was of the stock of the anointed priests, and to the Jews that were in Egypt:","searchKeywords":["the","hundred","fourscore","and","eighth","year","people","that","were","jerusalem","judea","council","judas","sent","greeting","health","unto","aristobulus","king","ptolemeus","master","who","was","stock","anointed","priests","jews","egypt"]},{"verseId":"brenton_2-maccabees_1_11","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":11,"text":"Insomuch as God hath delivered us from great perils, we thank him highly, as having been in battle against a king.","searchKeywords":["insomuch","god","hath","delivered","from","great","perils","thank","him","highly","having","been","battle","against","king"]},{"verseId":"brenton_2-maccabees_1_12","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":12,"text":"For he cast them out that fought within the holy city.","searchKeywords":["for","cast","them","out","that","fought","within","the","holy","city"]},{"verseId":"brenton_2-maccabees_1_13","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":13,"text":"For when the leader was come into Persia, and the army with him that seemed invincible, they were slain in the temple of Nanea by the deceit of Nanea's priests.","searchKeywords":["for","when","the","leader","was","come","into","persia","and","army","with","him","that","seemed","invincible","they","were","slain","temple","nanea","deceit","priests"]},{"verseId":"brenton_2-maccabees_1_14","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":14,"text":"For Antiochus, as though he would marry her, came into the place, and his friends that were with him, to receive money in name of a dowry.","searchKeywords":["for","antiochus","though","would","marry","her","came","into","the","place","and","his","friends","that","were","with","him","receive","money","name","dowry"]},{"verseId":"brenton_2-maccabees_1_15","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":15,"text":"Which when the priests of Nanea had set forth, and he was entered with a small company into the compass of the temple, they shut the temple as soon as Antiochus was come in:","searchKeywords":["which","when","the","priests","nanea","had","set","forth","and","was","entered","with","small","company","into","compass","temple","they","shut","soon","antiochus","come"]},{"verseId":"brenton_2-maccabees_1_16","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":16,"text":"and opening a privy door of the roof, they threw stones like thunderbolts, and struck down the captain, hewed them in pieces, smote off their heads, and cast them to those that were without.","searchKeywords":["and","opening","privy","door","the","roof","they","threw","stones","like","thunderbolts","struck","down","captain","hewed","them","pieces","smote","off","their","heads","cast","those","that","were","without"]},{"verseId":"brenton_2-maccabees_1_17","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":17,"text":"Blessed be our God in all things, who hath delivered up the ungodly.","searchKeywords":["blessed","our","god","all","things","who","hath","delivered","the","ungodly"]},{"verseId":"brenton_2-maccabees_1_18","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":18,"text":"Therefore whereas we are now purposed to keep the purification of the temple upon the five and twentieth day of Casleu, we thought it necessary to certify you thereof, that ye also might keep of the tabernacles, and of the fire, when Neemias offered sacrifice, after that he had builded the temple and the altar.","searchKeywords":["therefore","whereas","are","now","purposed","keep","the","purification","temple","upon","five","and","twentieth","day","casleu","thought","necessary","certify","you","thereof","that","also","might","tabernacles","fire","when","neemias","offered","sacrifice","after","had","builded","altar"]},{"verseId":"brenton_2-maccabees_1_19","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":19,"text":"For when our fathers were led into Persia, the priests that were then devout took the fire of the altar privily, and hid it in an hollow place of a pit without water, where they kept sure, so that the place was unknown to all men.","searchKeywords":["for","when","our","fathers","were","led","into","persia","the","priests","that","then","devout","took","fire","altar","privily","and","hid","hollow","place","pit","without","water","where","they","kept","sure","was","unknown","all","men"]},{"verseId":"brenton_2-maccabees_1_20","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":20,"text":"Now after many years, when it pleased God, Neemias, being sent from the king of Persia, did send of the posterity of those priests that had hid it to the fire: but when they told us they found no fire, but thick water;","searchKeywords":["now","after","many","years","when","pleased","god","neemias","being","sent","from","the","king","persia","did","send","posterity","those","priests","that","had","hid","fire","but","they","told","found","thick","water"]},{"verseId":"brenton_2-maccabees_1_21","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":21,"text":"then commanded he them to draw it up, and to bring it; and when the sacrifices were laid on, Neemias commanded the priests to sprinkle the wood and the things laid thereupon with the water.","searchKeywords":["then","commanded","them","draw","and","bring","when","the","sacrifices","were","laid","neemias","priests","sprinkle","wood","things","thereupon","with","water"]},{"verseId":"brenton_2-maccabees_1_22","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":22,"text":"When this was done, and the time came that the sun shone, which afore was hid in the cloud, there was a great fire kindled, so that every man marvelled.","searchKeywords":["when","this","was","done","and","the","time","came","that","sun","shone","which","afore","hid","cloud","there","great","fire","kindled","every","man","marvelled"]},{"verseId":"brenton_2-maccabees_1_23","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":23,"text":"And the priests made a prayer whilst the sacrifice was consuming, , both the priests, and all , Jonathan beginning, and the rest answering thereunto, as Neemias did.","searchKeywords":["and","the","priests","made","prayer","whilst","sacrifice","was","consuming","both","all","jonathan","beginning","rest","answering","thereunto","neemias","did"]},{"verseId":"brenton_2-maccabees_1_24","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":24,"text":"And the prayer was after this manner: O Lord, Lord God, Creator of all things, who art fearful and strong, and righteous, and merciful, and the only and gracious King,","searchKeywords":["and","the","prayer","was","after","this","manner","lord","god","creator","all","things","who","art","fearful","strong","righteous","merciful","only","gracious","king"]},{"verseId":"brenton_2-maccabees_1_25","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":25,"text":"the only giver of all things, the only just, almighty, and everlasting, thou that deliverest Israel from all trouble, and didst choose the fathers, and sanctify them:","searchKeywords":["the","only","giver","all","things","just","almighty","and","everlasting","thou","that","deliverest","israel","from","trouble","didst","choose","fathers","sanctify","them"]},{"verseId":"brenton_2-maccabees_1_26","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":26,"text":"receive the sacrifice for thy whole people Israel, and preserve thine own portion, and sanctify it.","searchKeywords":["receive","the","sacrifice","for","thy","whole","people","israel","and","preserve","thine","own","portion","sanctify"]},{"verseId":"brenton_2-maccabees_1_27","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":27,"text":"Gather those together that are scattered from us, deliver them that serve among the heathen, look upon them that are despised and abhorred, and let the heathen know that thou art our God.","searchKeywords":["gather","those","together","that","are","scattered","from","deliver","them","serve","among","the","heathen","look","upon","despised","and","abhorred","let","know","thou","art","our","god"]},{"verseId":"brenton_2-maccabees_1_28","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":28,"text":"Punish them that oppress us, and with pride do us wrong.","searchKeywords":["punish","them","that","oppress","and","with","pride","wrong"]},{"verseId":"brenton_2-maccabees_1_29","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":29,"text":"Plant thy people again in thy holy place, as Moses hath spoken.","searchKeywords":["plant","thy","people","again","holy","place","moses","hath","spoken"]},{"verseId":"brenton_2-maccabees_1_30","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":30,"text":"And the priests sung psalms of thanksgiving.","searchKeywords":["and","the","priests","sung","psalms","thanksgiving"]},{"verseId":"brenton_2-maccabees_1_31","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":31,"text":"Now when the sacrifice was consumed, Neemias commanded the water that was left to be poured on the great stones.","searchKeywords":["now","when","the","sacrifice","was","consumed","neemias","commanded","water","that","left","poured","great","stones"]},{"verseId":"brenton_2-maccabees_1_32","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":32,"text":"When this was done, there was kindled a flame: but it was consumed by the light that shined from the altar.","searchKeywords":["when","this","was","done","there","kindled","flame","but","consumed","the","light","that","shined","from","altar"]},{"verseId":"brenton_2-maccabees_1_33","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":33,"text":"So when this matter was known, it was told the king of Persia, that in the place, where the priests that were led away had hid the fire, there appeared water, and that Neemias had purified the sacrifices therewith.","searchKeywords":["when","this","matter","was","known","told","the","king","persia","that","place","where","priests","were","led","away","had","hid","fire","there","appeared","water","and","neemias","purified","sacrifices","therewith"]},{"verseId":"brenton_2-maccabees_1_34","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":34,"text":"Then the king, inclosing the place, made it holy, after he had tried the matter.","searchKeywords":["then","the","king","inclosing","place","made","holy","after","had","tried","matter"]},{"verseId":"brenton_2-maccabees_1_35","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":35,"text":"And the king took many gifts, and bestowed thereof on those whom he would gratify.","searchKeywords":["and","the","king","took","many","gifts","bestowed","thereof","those","whom","would","gratify"]},{"verseId":"brenton_2-maccabees_1_36","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":1,"verse":36,"text":"And Neemias called this thing Naphthar, which is as much as to say, a cleansing: but many men call it Nephi.","searchKeywords":["and","neemias","called","this","thing","naphthar","which","much","say","cleansing","but","many","men","call","nephi"]}]