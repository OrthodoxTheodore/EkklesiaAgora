[{"verseId":"brenton_2-maccabees_11_1","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":1,"text":"Not long after this, Lysias the king's protector and cousin, who also managed the affairs, took sore displeasure for the things that were done.","searchKeywords":["not","long","after","this","lysias","the","king","protector","and","cousin","who","also","managed","affairs","took","sore","displeasure","for","things","that","were","done"]},{"verseId":"brenton_2-maccabees_11_2","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":2,"text":"And when he had gathered about fourscore thousand with all the horsemen, he came against the Jews, thinking to make the city an habitation of the Gentiles,","searchKeywords":["and","when","had","gathered","about","fourscore","thousand","with","all","the","horsemen","came","against","jews","thinking","make","city","habitation","gentiles"]},{"verseId":"brenton_2-maccabees_11_3","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":3,"text":"and to make a gain of the temple, as of the other chapels of the heathen, and to set the high priesthood to sale every year:","searchKeywords":["and","make","gain","the","temple","other","chapels","heathen","set","high","priesthood","sale","every","year"]},{"verseId":"brenton_2-maccabees_11_4","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":4,"text":"not at all considering the power of God, but puffed up with his ten thousands of footmen, and his thousands of horsemen, and his fourscore elephants.","searchKeywords":["not","all","considering","the","power","god","but","puffed","with","his","ten","thousands","footmen","and","horsemen","fourscore","elephants"]},{"verseId":"brenton_2-maccabees_11_5","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":5,"text":"So he came to Judea, and drew near to Bethsura, which was a strong town, but distant from Jerusalem about five furlongs, and he laid sore siege unto it.","searchKeywords":["came","judea","and","drew","near","bethsura","which","was","strong","town","but","distant","from","jerusalem","about","five","furlongs","laid","sore","siege","unto"]},{"verseId":"brenton_2-maccabees_11_6","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":6,"text":"Now when they that were with Maccabeus heard that he besieged the holds, they and all the people with lamentation and tears besought the Lord that he would send a good angel to deliver Israel.","searchKeywords":["now","when","they","that","were","with","maccabeus","heard","besieged","the","holds","and","all","people","lamentation","tears","besought","lord","would","send","good","angel","deliver","israel"]},{"verseId":"brenton_2-maccabees_11_7","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":7,"text":"Then Maccabeus himself first of all took weapons, exhorting the other that they would jeopard themselves together with him to help their brethren: so they went forth together with a willing mind.","searchKeywords":["then","maccabeus","himself","first","all","took","weapons","exhorting","the","other","that","they","would","jeopard","themselves","together","with","him","help","their","brethren","went","forth","willing","mind"]},{"verseId":"brenton_2-maccabees_11_8","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":8,"text":"And as they were at Jerusalem, there appeared before them on horseback one in white clothing, shaking his armour of gold.","searchKeywords":["and","they","were","jerusalem","there","appeared","before","them","horseback","one","white","clothing","shaking","his","armour","gold"]},{"verseId":"brenton_2-maccabees_11_9","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":9,"text":"Then they praised the merciful God all together, and took heart, insomuch that they were ready not only to fight with men, but with most cruel beasts, and to pierce through walls of iron.","searchKeywords":["then","they","praised","the","merciful","god","all","together","and","took","heart","insomuch","that","were","ready","not","only","fight","with","men","but","most","cruel","beasts","pierce","through","walls","iron"]},{"verseId":"brenton_2-maccabees_11_10","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":10,"text":"Thus they marched forward in their armour, having an helper from heaven: for the Lord was merciful unto them.","searchKeywords":["thus","they","marched","forward","their","armour","having","helper","from","heaven","for","the","lord","was","merciful","unto","them"]},{"verseId":"brenton_2-maccabees_11_11","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":11,"text":"And giving a charge upon their enemies like lions, they slew eleven thousand , and sixteen hundred horsemen, and put all the other to flight.","searchKeywords":["and","giving","charge","upon","their","enemies","like","lions","they","slew","eleven","thousand","sixteen","hundred","horsemen","put","all","the","other","flight"]},{"verseId":"brenton_2-maccabees_11_12","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":12,"text":"Many of them also being wounded escaped naked; and Lysias himself fled away shamefully, and so escaped.","searchKeywords":["many","them","also","being","wounded","escaped","naked","and","lysias","himself","fled","away","shamefully"]},{"verseId":"brenton_2-maccabees_11_13","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":13,"text":"Who, as he was a man of understanding, casting with himself what loss he had had, and considering that the Hebrews could not be overcome, because the Almighty God helped them, he sent unto them,","searchKeywords":["who","was","man","understanding","casting","with","himself","what","loss","had","and","considering","that","the","hebrews","could","not","overcome","because","almighty","god","helped","them","sent","unto"]},{"verseId":"brenton_2-maccabees_11_14","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":14,"text":"and persuaded them to agree to all reasonable , and that he would persuade the king that he must needs be a friend unto them.","searchKeywords":["and","persuaded","them","agree","all","reasonable","that","would","persuade","the","king","must","needs","friend","unto"]},{"verseId":"brenton_2-maccabees_11_15","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":15,"text":"Then Maccabeus consented to all that Lysias desired, being careful of the common good; and whatsoever Maccabeus wrote unto Lysias concerning the Jews, the king granted it.","searchKeywords":["then","maccabeus","consented","all","that","lysias","desired","being","careful","the","common","good","and","whatsoever","wrote","unto","concerning","jews","king","granted"]},{"verseId":"brenton_2-maccabees_11_16","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":16,"text":"For there were letters written unto the Jews from Lysias to this effect: Lysias unto the people of the Jews greeting:","searchKeywords":["for","there","were","letters","written","unto","the","jews","from","lysias","this","effect","people","greeting"]},{"verseId":"brenton_2-maccabees_11_17","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":17,"text":"John and Absalon, who were sent from you, delivered me the petition subscribed, and made request for the performance of the contents thereof.","searchKeywords":["john","and","absalon","who","were","sent","from","you","delivered","the","petition","subscribed","made","request","for","performance","contents","thereof"]},{"verseId":"brenton_2-maccabees_11_18","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":18,"text":"Therefore what things soever were meet to be reported to the king, I have declared them, and he hath granted as much as might be.","searchKeywords":["therefore","what","things","soever","were","meet","reported","the","king","have","declared","them","and","hath","granted","much","might"]},{"verseId":"brenton_2-maccabees_11_19","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":19,"text":"If then ye will keep yourselves loyal to the state, hereafter also will I endeavour to be a means of your good.","searchKeywords":["then","will","keep","yourselves","loyal","the","state","hereafter","also","endeavour","means","your","good"]},{"verseId":"brenton_2-maccabees_11_20","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":20,"text":"But of the particulars I have given order both to these, and the other that came from me, to commune with you.","searchKeywords":["but","the","particulars","have","given","order","both","these","and","other","that","came","from","commune","with","you"]},{"verseId":"brenton_2-maccabees_11_21","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":21,"text":"Fare ye well. The hundred and eight and fortieth year, the four and twentieth day of Dioscorinthius.","searchKeywords":["fare","well","the","hundred","and","eight","fortieth","year","four","twentieth","day","dioscorinthius"]},{"verseId":"brenton_2-maccabees_11_22","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":22,"text":"Now the king's letter contained these words: King Antiochus unto his brother Lysias greeting:","searchKeywords":["now","the","king","letter","contained","these","words","antiochus","unto","his","brother","lysias","greeting"]},{"verseId":"brenton_2-maccabees_11_23","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":23,"text":"since our father is translated unto the gods, our will is, that they that are in our realm live quietly, that every one may attend upon his own affairs.","searchKeywords":["since","our","father","translated","unto","the","gods","will","that","they","are","realm","live","quietly","every","one","may","attend","upon","his","own","affairs"]},{"verseId":"brenton_2-maccabees_11_24","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":24,"text":"We understand also that the Jews would not consent to our father, for to be brought unto the customs of the Gentiles, but had rather keep their own manner of living: for the which cause they require of us, that we should suffer them to live after their own laws.","searchKeywords":["understand","also","that","the","jews","would","not","consent","our","father","for","brought","unto","customs","gentiles","but","had","rather","keep","their","own","manner","living","which","cause","they","require","should","suffer","them","live","after","laws"]},{"verseId":"brenton_2-maccabees_11_25","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":25,"text":"Wherefore our mind is, that this nation shall be in rest, and we have determined to restore them their temple, that they may live according to the customs of their forefathers.","searchKeywords":["wherefore","our","mind","that","this","nation","shall","rest","and","have","determined","restore","them","their","temple","they","may","live","according","the","customs","forefathers"]},{"verseId":"brenton_2-maccabees_11_26","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":26,"text":"Thou shalt do well therefore to send unto them, and grant them peace, that when they are certified of our mind, they may be of good comfort, and ever go cheerfully about their own affairs.","searchKeywords":["thou","shalt","well","therefore","send","unto","them","and","grant","peace","that","when","they","are","certified","our","mind","may","good","comfort","ever","cheerfully","about","their","own","affairs"]},{"verseId":"brenton_2-maccabees_11_27","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":27,"text":"And the letter of the king unto the nation of the Jews was after this manner: King Antiochus greeting unto the council, and the rest of the Jews;","searchKeywords":["and","the","letter","king","unto","nation","jews","was","after","this","manner","antiochus","greeting","council","rest"]},{"verseId":"brenton_2-maccabees_11_28","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":28,"text":"If ye fare well, we have our desire; we are also in good health.","searchKeywords":["fare","well","have","our","desire","are","also","good","health"]},{"verseId":"brenton_2-maccabees_11_29","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":29,"text":"Menelaus declared unto us, that your desire was to return home, and to follow your own business:","searchKeywords":["menelaus","declared","unto","that","your","desire","was","return","home","and","follow","own","business"]},{"verseId":"brenton_2-maccabees_11_30","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":30,"text":"wherefore they that will depart shall have safe conduct till the thirtieth day of Xanthicus with security.","searchKeywords":["wherefore","they","that","will","depart","shall","have","safe","conduct","till","the","thirtieth","day","xanthicus","with","security"]},{"verseId":"brenton_2-maccabees_11_31","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":31,"text":"And the Jews shall use their own kind of meats and laws, as before: and none of them any manner of ways shall be molested for things ignorantly done.","searchKeywords":["and","the","jews","shall","use","their","own","kind","meats","laws","before","none","them","any","manner","ways","molested","for","things","ignorantly","done"]},{"verseId":"brenton_2-maccabees_11_32","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":32,"text":"I have sent also Menelaus, that he may comfort you.","searchKeywords":["have","sent","also","menelaus","that","may","comfort","you"]},{"verseId":"brenton_2-maccabees_11_33","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":33,"text":"Fare ye well. In the hundred forty and eighth year, the fifteenth of Xanthicus.","searchKeywords":["fare","well","the","hundred","forty","and","eighth","year","fifteenth","xanthicus"]},{"verseId":"brenton_2-maccabees_11_34","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":34,"text":"The Romans also sent unto them a letter containing these words: Quintus Memmius and Titus Manlius, ambassadors of the Romans, greeting unto the people of the Jews.","searchKeywords":["the","romans","also","sent","unto","them","letter","containing","these","words","quintus","memmius","and","titus","manlius","ambassadors","greeting","people","jews"]},{"verseId":"brenton_2-maccabees_11_35","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":35,"text":"Whatsoever Lysias the king's cousin hath granted, therewith we also are well pleased.","searchKeywords":["whatsoever","lysias","the","king","cousin","hath","granted","therewith","also","are","well","pleased"]},{"verseId":"brenton_2-maccabees_11_36","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":36,"text":"But touching such things as he judged to be referred to the king, after ye have advised thereof, send one forthwith, that we may declare as it is convenient for you: for we are now going to Antioch.","searchKeywords":["but","touching","such","things","judged","referred","the","king","after","have","advised","thereof","send","one","forthwith","that","may","declare","convenient","for","you","are","now","going","antioch"]},{"verseId":"brenton_2-maccabees_11_37","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":37,"text":"Therefore send some with speed, that we may know what is your mind.","searchKeywords":["therefore","send","some","with","speed","that","may","know","what","your","mind"]},{"verseId":"brenton_2-maccabees_11_38","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":11,"verse":38,"text":"Farewell. This hundred and eight and fortieth year, the fifteenth day of Xanthicus.","searchKeywords":["farewell","this","hundred","and","eight","fortieth","year","the","fifteenth","day","xanthicus"]}]