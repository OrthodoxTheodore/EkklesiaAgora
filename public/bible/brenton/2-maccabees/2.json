[{"verseId":"brenton_2-maccabees_2_1","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":1,"text":"It is also found in the records, that Jeremy the prophet commanded them that were carried away to take of the fire, as it hath been signified:","searchKeywords":["also","found","the","records","that","jeremy","prophet","commanded","them","were","carried","away","take","fire","hath","been","signified"]},{"verseId":"brenton_2-maccabees_2_2","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":2,"text":"and how that the prophet, having given them the law, charged them not to forget the commandments of the Lord, and that they should not err in their minds, when they see images of silver and gold, with their ornaments.","searchKeywords":["and","how","that","the","prophet","having","given","them","law","charged","not","forget","commandments","lord","they","should","err","their","minds","when","see","images","silver","gold","with","ornaments"]},{"verseId":"brenton_2-maccabees_2_3","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":3,"text":"And with other such speeches exhorted he them, that the law should not depart from their hearts.","searchKeywords":["and","with","other","such","speeches","exhorted","them","that","the","law","should","not","depart","from","their","hearts"]},{"verseId":"brenton_2-maccabees_2_4","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":4,"text":"It was also contained in the same writing, that the prophet, being warned of God, commanded the tabernacle and the ark to go with him, as he went forth into the mountain, where Moses climbed up, and saw the heritage of God.","searchKeywords":["was","also","contained","the","same","writing","that","prophet","being","warned","god","commanded","tabernacle","and","ark","with","him","went","forth","into","mountain","where","moses","climbed","saw","heritage"]},{"verseId":"brenton_2-maccabees_2_5","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":5,"text":"And when Jeremy came thither, he found an hollow cave, wherein he laid the tabernacle, and the ark, and the altar of incense, and so stopped the door.","searchKeywords":["and","when","jeremy","came","thither","found","hollow","cave","wherein","laid","the","tabernacle","ark","altar","incense","stopped","door"]},{"verseId":"brenton_2-maccabees_2_6","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":6,"text":"And some of those that followed him came to mark the way, but they could not find it.","searchKeywords":["and","some","those","that","followed","him","came","mark","the","way","but","they","could","not","find"]},{"verseId":"brenton_2-maccabees_2_7","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":7,"text":"Which when Jeremy perceived, he blamed them, saying, As for that place, it shall be unknown until the time that God gather his people again together, and receive them unto mercy.","searchKeywords":["which","when","jeremy","perceived","blamed","them","saying","for","that","place","shall","unknown","until","the","time","god","gather","his","people","again","together","and","receive","unto","mercy"]},{"verseId":"brenton_2-maccabees_2_8","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":8,"text":"Then shall the Lord shew them these things, and the glory of the Lord shall appear, and the cloud also, as it was shewed under Moses, and as when Solomon desired that the place might be honourably sanctified.","searchKeywords":["then","shall","the","lord","shew","them","these","things","and","glory","appear","cloud","also","was","shewed","under","moses","when","solomon","desired","that","place","might","honourably","sanctified"]},{"verseId":"brenton_2-maccabees_2_9","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":9,"text":"It was also declared, that he being wise offered the sacrifice of dedication, and of the finishing of the temple.","searchKeywords":["was","also","declared","that","being","wise","offered","the","sacrifice","dedication","and","finishing","temple"]},{"verseId":"brenton_2-maccabees_2_10","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":10,"text":"And as when Moses prayed unto the Lord, the fire came down from heaven, and consumed the sacrifices: even so prayed Solomon also, and the fire came down from heaven, and consumed the burnt offerings.","searchKeywords":["and","when","moses","prayed","unto","the","lord","fire","came","down","from","heaven","consumed","sacrifices","even","solomon","also","burnt","offerings"]},{"verseId":"brenton_2-maccabees_2_11","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":11,"text":"And Moses said, Because the sin offering was not to be eaten, it was consumed.","searchKeywords":["and","moses","said","because","the","sin","offering","was","not","eaten","consumed"]},{"verseId":"brenton_2-maccabees_2_12","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":12,"text":"So Solomon kept those eight days.","searchKeywords":["solomon","kept","those","eight","days"]},{"verseId":"brenton_2-maccabees_2_13","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":13,"text":"The same things also were reported in the writings and commentaries of Neemias; and how he founding a library gathered together the acts of the kings, and the prophets, and of David, and the epistles of the kings concerning the holy gifts.","searchKeywords":["the","same","things","also","were","reported","writings","and","commentaries","neemias","how","founding","library","gathered","together","acts","kings","prophets","david","epistles","concerning","holy","gifts"]},{"verseId":"brenton_2-maccabees_2_14","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":14,"text":"In like manner also Judas gathered together all those things that were lost by reason of the war we had, and they remain with us.","searchKeywords":["like","manner","also","judas","gathered","together","all","those","things","that","were","lost","reason","the","war","had","and","they","remain","with"]},{"verseId":"brenton_2-maccabees_2_15","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":15,"text":"Wherefore if ye have need thereof, send some to fetch them unto you.","searchKeywords":["wherefore","have","need","thereof","send","some","fetch","them","unto","you"]},{"verseId":"brenton_2-maccabees_2_16","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":16,"text":"Whereas we then are about to celebrate the purification, we have written unto you, and ye shall do well, if ye keep the same days.","searchKeywords":["whereas","then","are","about","celebrate","the","purification","have","written","unto","you","and","shall","well","keep","same","days"]},{"verseId":"brenton_2-maccabees_2_17","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":17,"text":"We hope also, that the God, that delivered all his people, and gave them all an heritage, and the kingdom, and the priesthood, and the sanctuary,","searchKeywords":["hope","also","that","the","god","delivered","all","his","people","and","gave","them","heritage","kingdom","priesthood","sanctuary"]},{"verseId":"brenton_2-maccabees_2_18","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":18,"text":"as he promised in the law, will shortly have mercy upon us, and gather us together out of every land under heaven into the holy place: for he hath delivered us out of great troubles, and hath purified the place.","searchKeywords":["promised","the","law","will","shortly","have","mercy","upon","and","gather","together","out","every","land","under","heaven","into","holy","place","for","hath","delivered","great","troubles","purified"]},{"verseId":"brenton_2-maccabees_2_19","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":19,"text":"Now as concerning Judas Maccabeus, and his brethren, and the purification of the great temple, and the dedication of the altar,","searchKeywords":["now","concerning","judas","maccabeus","and","his","brethren","the","purification","great","temple","dedication","altar"]},{"verseId":"brenton_2-maccabees_2_20","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":20,"text":"and the wars against Antiochus Epiphanes, and Eupator his son,","searchKeywords":["and","the","wars","against","antiochus","epiphanes","eupator","his","son"]},{"verseId":"brenton_2-maccabees_2_21","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":21,"text":"and the manifest signs that came from heaven unto those that behaved themselves manfully to their honour for Judaism: so that, being but a few, they overcame the whole country, and chased barbarous multitudes,","searchKeywords":["and","the","manifest","signs","that","came","from","heaven","unto","those","behaved","themselves","manfully","their","honour","for","judaism","being","but","few","they","overcame","whole","country","chased","barbarous","multitudes"]},{"verseId":"brenton_2-maccabees_2_22","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":22,"text":"and recovered again the temple renowned all the world over, and freed the city, and upheld the laws which were going down, the Lord being gracious unto them with all favour:","searchKeywords":["and","recovered","again","the","temple","renowned","all","world","over","freed","city","upheld","laws","which","were","going","down","lord","being","gracious","unto","them","with","favour"]},{"verseId":"brenton_2-maccabees_2_23","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":23,"text":", being declared by Jason of Cyrene in five books, we will assay to abridge in one volume.","searchKeywords":["being","declared","jason","cyrene","five","books","will","assay","abridge","one","volume"]},{"verseId":"brenton_2-maccabees_2_24","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":24,"text":"For considering the infinite number, and the difficulty which they find that desire to look into the narrations of the story, for the variety of the matter,","searchKeywords":["for","considering","the","infinite","number","and","difficulty","which","they","find","that","desire","look","into","narrations","story","variety","matter"]},{"verseId":"brenton_2-maccabees_2_25","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":25,"text":"we have been careful, that they that will read may have delight, and that they that are desirous to commit to memory might have ease, and that all into whose hands it comes might have profit.","searchKeywords":["have","been","careful","that","they","will","read","may","delight","and","are","desirous","commit","memory","might","ease","all","into","whose","hands","comes","profit"]},{"verseId":"brenton_2-maccabees_2_26","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":26,"text":"Therefore to us, that have taken upon us this painful labour of abridging, it was not easy, but a matter of sweat and watching;","searchKeywords":["therefore","that","have","taken","upon","this","painful","labour","abridging","was","not","easy","but","matter","sweat","and","watching"]},{"verseId":"brenton_2-maccabees_2_27","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":27,"text":"even as it is no ease unto him that prepareth a banquet, and seeketh the benefit of others: yet for the pleasuring of many we will undertake gladly this great pains;","searchKeywords":["even","ease","unto","him","that","prepareth","banquet","and","seeketh","the","benefit","others","yet","for","pleasuring","many","will","undertake","gladly","this","great","pains"]},{"verseId":"brenton_2-maccabees_2_28","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":28,"text":"leaving to the author the exact handling of every particular, and labouring to follow the rules of an abridgement.","searchKeywords":["leaving","the","author","exact","handling","every","particular","and","labouring","follow","rules","abridgement"]},{"verseId":"brenton_2-maccabees_2_29","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":29,"text":"For as the master builder of a new house must care for the whole building: but he that undertaketh to set it out, and paint it, must seek out fit things for the adorning thereof: even so I think it is with us.","searchKeywords":["for","the","master","builder","new","house","must","care","whole","building","but","that","undertaketh","set","out","and","paint","seek","fit","things","adorning","thereof","even","think","with"]},{"verseId":"brenton_2-maccabees_2_30","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":30,"text":"To stand upon every point, and go over things at large, and to be curious in particulars, belongeth to the first author of the story:","searchKeywords":["stand","upon","every","point","and","over","things","large","curious","particulars","belongeth","the","first","author","story"]},{"verseId":"brenton_2-maccabees_2_31","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":31,"text":"but to use brevity, and avoid much labouring of the work, is to be granted to him that will make an abridgement.","searchKeywords":["but","use","brevity","and","avoid","much","labouring","the","work","granted","him","that","will","make","abridgement"]},{"verseId":"brenton_2-maccabees_2_32","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":2,"verse":32,"text":"Here then will we begin the story: only adding thus much to that which hath been said, that it is a foolish thing to make a long prologue, and to be short in the story itself.","searchKeywords":["here","then","will","begin","the","story","only","adding","thus","much","that","which","hath","been","said","foolish","thing","make","long","prologue","and","short","itself"]}]