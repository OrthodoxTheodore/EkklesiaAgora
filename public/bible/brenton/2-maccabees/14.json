[{"verseId":"brenton_2-maccabees_14_1","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":1,"text":"After three years was Judas informed, that Demetrius the of Seleucus, having entered by the haven of Tripolis with a great power and navy,","searchKeywords":["after","three","years","was","judas","informed","that","demetrius","the","seleucus","having","entered","haven","tripolis","with","great","power","and","navy"]},{"verseId":"brenton_2-maccabees_14_2","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":2,"text":"had taken the country, and killed Antiochus, and Lysias his protector.","searchKeywords":["had","taken","the","country","and","killed","antiochus","lysias","his","protector"]},{"verseId":"brenton_2-maccabees_14_3","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":3,"text":"Now one Alcimus, who had been high priest, and had defiled himself wilfully in the times of their mingling , seeing that by no means he could save himself, nor have any more access to the holy altar,","searchKeywords":["now","one","alcimus","who","had","been","high","priest","and","defiled","himself","wilfully","the","times","their","mingling","seeing","that","means","could","save","nor","have","any","more","access","holy","altar"]},{"verseId":"brenton_2-maccabees_14_4","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":4,"text":"came to king Demetrius in the hundred and one and fiftieth year, presenting unto him a crown of gold, and a palm, and also of the boughs which were used solemnly in the temple: and so that day he held his peace.","searchKeywords":["came","king","demetrius","the","hundred","and","one","fiftieth","year","presenting","unto","him","crown","gold","palm","also","boughs","which","were","used","solemnly","temple","that","day","held","his","peace"]},{"verseId":"brenton_2-maccabees_14_5","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":5,"text":"Howbeit, having gotten opportunity to further his foolish enterprise, being called into council by Demetrius, and asked how the Jews stood affected, and what they intended, he answered thereunto:","searchKeywords":["howbeit","having","gotten","opportunity","further","his","foolish","enterprise","being","called","into","council","demetrius","and","asked","how","the","jews","stood","affected","what","they","intended","answered","thereunto"]},{"verseId":"brenton_2-maccabees_14_6","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":6,"text":"Those of the Jews that be called Assideans, whose captain is Judas Maccabeus, nourish war, and are seditious, and will not let the realm be in peace.","searchKeywords":["those","the","jews","that","called","assideans","whose","captain","judas","maccabeus","nourish","war","and","are","seditious","will","not","let","realm","peace"]},{"verseId":"brenton_2-maccabees_14_7","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":7,"text":"Therefore I, being deprived of mine ancestors' honour, I mean the high priesthood, am now come hither:","searchKeywords":["therefore","being","deprived","mine","ancestors","honour","mean","the","high","priesthood","now","come","hither"]},{"verseId":"brenton_2-maccabees_14_8","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":8,"text":"first, verily for the unfeigned care I have of things pertaining to the king; and secondly, even for that I intend the good of mine own citizens: for all our nation is in no small misery through the unadvised dealing of them aforesaid.","searchKeywords":["first","verily","for","the","unfeigned","care","have","things","pertaining","king","and","secondly","even","that","intend","good","mine","own","citizens","all","our","nation","small","misery","through","unadvised","dealing","them","aforesaid"]},{"verseId":"brenton_2-maccabees_14_9","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":9,"text":"Wherefore, O king, seeing thou knowest all these things, be careful for the country, and our nation, which is pressed on every side, according to the clemency that thou readily shewest unto all.","searchKeywords":["wherefore","king","seeing","thou","knowest","all","these","things","careful","for","the","country","and","our","nation","which","pressed","every","side","according","clemency","that","readily","shewest","unto"]},{"verseId":"brenton_2-maccabees_14_10","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":10,"text":"For as long as Judas liveth, it is not possible that the state should be quiet.","searchKeywords":["for","long","judas","liveth","not","possible","that","the","state","should","quiet"]},{"verseId":"brenton_2-maccabees_14_11","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":11,"text":"This was no sooner spoken of him, but others of the king's friends, being maliciously set against Judas, did more incense Demetrius.","searchKeywords":["this","was","sooner","spoken","him","but","others","the","king","friends","being","maliciously","set","against","judas","did","more","incense","demetrius"]},{"verseId":"brenton_2-maccabees_14_12","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":12,"text":"And forthwith calling Nicanor, who had been master of the elephants, and making him governor over Judea, he sent him forth,","searchKeywords":["and","forthwith","calling","nicanor","who","had","been","master","the","elephants","making","him","governor","over","judea","sent","forth"]},{"verseId":"brenton_2-maccabees_14_13","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":13,"text":"commanding him to slay Judas, and to scatter them that were with him, and to make Alcimus high priest of the great temple.","searchKeywords":["commanding","him","slay","judas","and","scatter","them","that","were","with","make","alcimus","high","priest","the","great","temple"]},{"verseId":"brenton_2-maccabees_14_14","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":14,"text":"Then the heathen, that had fled out of Judea from Judas, came to Nicanor by flocks, thinking the harm and calamities of the Jews to be their welfare.","searchKeywords":["then","the","heathen","that","had","fled","out","judea","from","judas","came","nicanor","flocks","thinking","harm","and","calamities","jews","their","welfare"]},{"verseId":"brenton_2-maccabees_14_15","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":15,"text":"Now when the Jews heard of Nicanor's coming, and that the heathen were up against them, they cast earth upon their heads, and made supplication to him that had established his people for ever, and who always helpeth his portion with manifestation of his presence.","searchKeywords":["now","when","the","jews","heard","nicanor","coming","and","that","heathen","were","against","them","they","cast","earth","upon","their","heads","made","supplication","him","had","established","his","people","for","ever","who","always","helpeth","portion","with","manifestation","presence"]},{"verseId":"brenton_2-maccabees_14_16","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":16,"text":"So at the commandment of the captain they removed straightways from thence, and came near unto them at the town of Dessau.","searchKeywords":["the","commandment","captain","they","removed","straightways","from","thence","and","came","near","unto","them","town","dessau"]},{"verseId":"brenton_2-maccabees_14_17","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":17,"text":"Now Simon, Judas' brother, had joined battle with Nicanor, but was somewhat discomfited through the sudden silence of his enemies.","searchKeywords":["now","simon","judas","brother","had","joined","battle","with","nicanor","but","was","somewhat","discomfited","through","the","sudden","silence","his","enemies"]},{"verseId":"brenton_2-maccabees_14_18","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":18,"text":"Nevertheless Nicanor, hearing of the manliness of them that were with Judas, and the courageousness that they had to fight for their country, durst not try the matter by the sword.","searchKeywords":["nevertheless","nicanor","hearing","the","manliness","them","that","were","with","judas","and","courageousness","they","had","fight","for","their","country","durst","not","try","matter","sword"]},{"verseId":"brenton_2-maccabees_14_19","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":19,"text":"Wherefore he sent Posidonius, and Theodotus, and Mattathias, to make peace.","searchKeywords":["wherefore","sent","posidonius","and","theodotus","mattathias","make","peace"]},{"verseId":"brenton_2-maccabees_14_20","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":20,"text":"So when they had taken long advisement thereupon, and the captain had made the multitude acquainted therewith, and it appeared that they were all of one mind, they consented to the covenants,","searchKeywords":["when","they","had","taken","long","advisement","thereupon","and","the","captain","made","multitude","acquainted","therewith","appeared","that","were","all","one","mind","consented","covenants"]},{"verseId":"brenton_2-maccabees_14_21","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":21,"text":"and appointed a day to meet in together by themselves: and when the day came, and stools were set for either of them,","searchKeywords":["and","appointed","day","meet","together","themselves","when","the","came","stools","were","set","for","either","them"]},{"verseId":"brenton_2-maccabees_14_22","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":22,"text":"Judas placed armed men ready in convenient places, lest some treachery should be suddenly practised by the enemies: so they made a peaceable conference.","searchKeywords":["judas","placed","armed","men","ready","convenient","places","lest","some","treachery","should","suddenly","practised","the","enemies","they","made","peaceable","conference"]},{"verseId":"brenton_2-maccabees_14_23","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":23,"text":"Now Nicanor abode in Jerusalem, and did no hurt, but sent away the people that came flocking unto him.","searchKeywords":["now","nicanor","abode","jerusalem","and","did","hurt","but","sent","away","the","people","that","came","flocking","unto","him"]},{"verseId":"brenton_2-maccabees_14_24","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":24,"text":"And he would not willingly have Judas out of his sight: for he loved the man from his heart.","searchKeywords":["and","would","not","willingly","have","judas","out","his","sight","for","loved","the","man","from","heart"]},{"verseId":"brenton_2-maccabees_14_25","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":25,"text":"He prayed him also to take a wife, and to beget children: so he married, was quiet, and took part of this life.","searchKeywords":["prayed","him","also","take","wife","and","beget","children","married","was","quiet","took","part","this","life"]},{"verseId":"brenton_2-maccabees_14_26","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":26,"text":"But Alcimus, perceiving the love that was betwixt them, and considering the covenants that were made, came to Demetrius, and told him that Nicanor was not well affected toward the state: for that he had ordained Judas, a traitor to his realm, to be the king's successor.","searchKeywords":["but","alcimus","perceiving","the","love","that","was","betwixt","them","and","considering","covenants","were","made","came","demetrius","told","him","nicanor","not","well","affected","toward","state","for","had","ordained","judas","traitor","his","realm","king","successor"]},{"verseId":"brenton_2-maccabees_14_27","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":27,"text":"Then the king being in a rage, and provoked with the accusations of the most wicked man, wrote to Nicanor, signifying that he was much displeased with the covenants, and commanding him that he should send Maccabeus prisoner in all haste unto Antioch.","searchKeywords":["then","the","king","being","rage","and","provoked","with","accusations","most","wicked","man","wrote","nicanor","signifying","that","was","much","displeased","covenants","commanding","him","should","send","maccabeus","prisoner","all","haste","unto","antioch"]},{"verseId":"brenton_2-maccabees_14_28","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":28,"text":"When this came to Nicanor's hearing, he was much confounded in himself, and took it grievously that he should make void the articles which were agreed upon, the man being in no fault.","searchKeywords":["when","this","came","nicanor","hearing","was","much","confounded","himself","and","took","grievously","that","should","make","void","the","articles","which","were","agreed","upon","man","being","fault"]},{"verseId":"brenton_2-maccabees_14_29","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":29,"text":"But because there was no dealing against the king, he watched his time to accomplish this thing by policy.","searchKeywords":["but","because","there","was","dealing","against","the","king","watched","his","time","accomplish","this","thing","policy"]},{"verseId":"brenton_2-maccabees_14_30","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":30,"text":"Notwithstanding, when Maccabeus saw that Nicanor began to be churlish unto him, and that he entreated him more roughly than he was wont, perceiving that such sour behaviour came not of good, he gathered together not a few of his men, and withdrew himself from Nicanor.","searchKeywords":["notwithstanding","when","maccabeus","saw","that","nicanor","began","churlish","unto","him","and","entreated","more","roughly","than","was","wont","perceiving","such","sour","behaviour","came","not","good","gathered","together","few","his","men","withdrew","himself","from"]},{"verseId":"brenton_2-maccabees_14_31","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":31,"text":"But the other, knowing that he was notably prevented by Judas' policy, came into the great and holy temple, and commanded the priests, that were offering their usual sacrifices, to deliver him the man.","searchKeywords":["but","the","other","knowing","that","was","notably","prevented","judas","policy","came","into","great","and","holy","temple","commanded","priests","were","offering","their","usual","sacrifices","deliver","him","man"]},{"verseId":"brenton_2-maccabees_14_32","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":32,"text":"And when they sware that they could not tell where the man was whom he sought,","searchKeywords":["and","when","they","sware","that","could","not","tell","where","the","man","was","whom","sought"]},{"verseId":"brenton_2-maccabees_14_33","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":33,"text":"he stretched out his right hand toward the temple, and made an oath in this manner: If ye will not deliver me Judas as a prisoner, I will lay this temple of God even with the ground, and I will break down the altar, and erect a notable temple unto Bacchus.","searchKeywords":["stretched","out","his","right","hand","toward","the","temple","and","made","oath","this","manner","will","not","deliver","judas","prisoner","lay","god","even","with","ground","break","down","altar","erect","notable","unto","bacchus"]},{"verseId":"brenton_2-maccabees_14_34","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":34,"text":"After these words, he departed. Then the priests lifted up their hands toward heaven, and besought him that was ever a defender of their nation, saying in this manner;","searchKeywords":["after","these","words","departed","then","the","priests","lifted","their","hands","toward","heaven","and","besought","him","that","was","ever","defender","nation","saying","this","manner"]},{"verseId":"brenton_2-maccabees_14_35","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":35,"text":"Thou, O Lord of all things, who hast need of nothing, wast pleased that the temple of thine habitation should be among us:","searchKeywords":["thou","lord","all","things","who","hast","need","nothing","wast","pleased","that","the","temple","thine","habitation","should","among"]},{"verseId":"brenton_2-maccabees_14_36","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":36,"text":"therefore now, O holy Lord of all holiness, keep this house ever undefiled, which lately was cleansed, and stop every unrighteous mouth.","searchKeywords":["therefore","now","holy","lord","all","holiness","keep","this","house","ever","undefiled","which","lately","was","cleansed","and","stop","every","unrighteous","mouth"]},{"verseId":"brenton_2-maccabees_14_37","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":37,"text":"Now was there accused unto Nicanor one Razis, one of the elders of Jerusalem, a lover of his countrymen, and a man of very good report, who for his kindness was called a father of the Jews.","searchKeywords":["now","was","there","accused","unto","nicanor","one","razis","the","elders","jerusalem","lover","his","countrymen","and","man","very","good","report","who","for","kindness","called","father","jews"]},{"verseId":"brenton_2-maccabees_14_38","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":38,"text":"For in the former times, when they mingled not themselves with the Gentiles, he had been accused of Judaism, and did boldly jeopard his body and life with all vehemency for the religion of the Jews.","searchKeywords":["for","the","former","times","when","they","mingled","not","themselves","with","gentiles","had","been","accused","judaism","and","did","boldly","jeopard","his","body","life","all","vehemency","religion","jews"]},{"verseId":"brenton_2-maccabees_14_39","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":39,"text":"So Nicanor, willing to declare the hate that he bare unto the Jews, sent above five hundred men of war to take him:","searchKeywords":["nicanor","willing","declare","the","hate","that","bare","unto","jews","sent","above","five","hundred","men","war","take","him"]},{"verseId":"brenton_2-maccabees_14_40","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":40,"text":"for he thought by taking him to do the Jews much hurt.","searchKeywords":["for","thought","taking","him","the","jews","much","hurt"]},{"verseId":"brenton_2-maccabees_14_41","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":41,"text":"Now when the multitude would have taken the tower, and violently broken into the outer door, and bade that fire should be brought to burn it, he being ready to be taken on every side fell upon his sword;","searchKeywords":["now","when","the","multitude","would","have","taken","tower","and","violently","broken","into","outer","door","bade","that","fire","should","brought","burn","being","ready","every","side","fell","upon","his","sword"]},{"verseId":"brenton_2-maccabees_14_42","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":42,"text":"choosing rather to die manfully, than to come into the hands of the wicked, to be abused otherwise than beseemed his noble birth:","searchKeywords":["choosing","rather","die","manfully","than","come","into","the","hands","wicked","abused","otherwise","beseemed","his","noble","birth"]},{"verseId":"brenton_2-maccabees_14_43","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":43,"text":"but missing his stroke through haste, the multitude also rushing within the doors, he ran boldly up to the wall, and cast himself down manfully among the thickest of them.","searchKeywords":["but","missing","his","stroke","through","haste","the","multitude","also","rushing","within","doors","ran","boldly","wall","and","cast","himself","down","manfully","among","thickest","them"]},{"verseId":"brenton_2-maccabees_14_44","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":44,"text":"But they quickly giving back, and a space being made, he fell down into the midst of the void place.","searchKeywords":["but","they","quickly","giving","back","and","space","being","made","fell","down","into","the","midst","void","place"]},{"verseId":"brenton_2-maccabees_14_45","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":45,"text":"Nevertheless, while there was yet breath within him, being inflamed with anger, he rose up; and though his blood gushed out like spouts of water, and his wounds were grievous, yet he ran through the midst of the throng; and standing upon a steep rock,","searchKeywords":["nevertheless","while","there","was","yet","breath","within","him","being","inflamed","with","anger","rose","and","though","his","blood","gushed","out","like","spouts","water","wounds","were","grievous","ran","through","the","midst","throng","standing","upon","steep","rock"]},{"verseId":"brenton_2-maccabees_14_46","translationId":"brenton","testament":"OT","bookIndex":22,"bookName":"2 Maccabees","bookAbbrev":"2-maccabees","chapter":14,"verse":46,"text":"when as his blood was now quite gone, he plucked out his bowels, and taking them in both his hands, he cast them upon the throng, and calling upon the Lord of life and spirit to restore him those again, he thus died.","searchKeywords":["when","his","blood","was","now","quite","gone","plucked","out","bowels","and","taking","them","both","hands","cast","upon","the","throng","calling","lord","life","spirit","restore","him","those","again","thus","died"]}]