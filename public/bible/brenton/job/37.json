[{"verseId":"brenton_job_37_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":1,"text":"At this also my heart is troubled, and moved out of its place.","searchKeywords":["this","also","heart","troubled","and","moved","out","its","place"]},{"verseId":"brenton_job_37_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":2,"text":"Hear thou a report by the anger of the Lord's wrath, and a discourse shall come out of his mouth.","searchKeywords":["hear","thou","report","the","anger","lord","wrath","and","discourse","shall","come","out","his","mouth"]},{"verseId":"brenton_job_37_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":3,"text":"His dominion is under the whole heaven, and his light is at the extremities of the earth.","searchKeywords":["his","dominion","under","the","whole","heaven","and","light","extremities","earth"]},{"verseId":"brenton_job_37_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":4,"text":"After him shall be a cry with a voice; he shall thunder with the voice of his excellency, yet he shall not cause men to pass away, for one shall hear his voice.","searchKeywords":["after","him","shall","cry","with","voice","thunder","the","his","excellency","yet","not","cause","men","pass","away","for","one","hear"]},{"verseId":"brenton_job_37_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":5,"text":"The Mighty One shall thunder wonderfully with his voice: for he has done great things which we knew not;","searchKeywords":["the","mighty","one","shall","thunder","wonderfully","with","his","voice","for","has","done","great","things","which","knew","not"]},{"verseId":"brenton_job_37_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":6,"text":"commanding the snow, Be thou upon the earth, and the stormy rain, and the storm of the showers of his might.","searchKeywords":["commanding","the","snow","thou","upon","earth","and","stormy","rain","storm","showers","his","might"]},{"verseId":"brenton_job_37_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":7,"text":"He seals up the hand of every man, that every man may know his own weakness.","searchKeywords":["seals","the","hand","every","man","that","may","know","his","own","weakness"]},{"verseId":"brenton_job_37_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":8,"text":"And the wild beasts come in under the covert, and rest in lair.","searchKeywords":["and","the","wild","beasts","come","under","covert","rest","lair"]},{"verseId":"brenton_job_37_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":9,"text":"Troubles come on out of the secret chambers, and cold from the mountain-tops.","searchKeywords":["troubles","come","out","the","secret","chambers","and","cold","from","mountain","tops"]},{"verseId":"brenton_job_37_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":10,"text":"And from the breath of the Mighty One he will send frost; and he guides the water in whatever way he pleases.","searchKeywords":["and","from","the","breath","mighty","one","will","send","frost","guides","water","whatever","way","pleases"]},{"verseId":"brenton_job_37_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":11,"text":"And a cloud obscures precious , his light will disperse the cloud.","searchKeywords":["and","cloud","obscures","precious","his","light","will","disperse","the"]},{"verseId":"brenton_job_37_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":12,"text":"And he will carry round the encircling by his governance, to their works: whatsoever he shall command them,","searchKeywords":["and","will","carry","round","the","encircling","his","governance","their","works","whatsoever","shall","command","them"]},{"verseId":"brenton_job_37_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":13,"text":"this has been appointed by him on the earth, whether for correction, for his land, or if he shall find him for mercy.","searchKeywords":["this","has","been","appointed","him","the","earth","whether","for","correction","his","land","shall","find","mercy"]},{"verseId":"brenton_job_37_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":14,"text":"Hearken to this, O Job: stand still, and be admonished of the power of the Lord.","searchKeywords":["hearken","this","job","stand","still","and","admonished","the","power","lord"]},{"verseId":"brenton_job_37_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":15,"text":"We know that God has disposed his works, having made light out of darkness.","searchKeywords":["know","that","god","has","disposed","his","works","having","made","light","out","darkness"]},{"verseId":"brenton_job_37_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":16,"text":"And he knows the divisions of the clouds, and the signal overthrows of the ungodly.","searchKeywords":["and","knows","the","divisions","clouds","signal","overthrows","ungodly"]},{"verseId":"brenton_job_37_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":17,"text":"But thy robe is warm, and there is quiet upon the land.","searchKeywords":["but","thy","robe","warm","and","there","quiet","upon","the","land"]},{"verseId":"brenton_job_37_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":18,"text":"Wilt thou establish with him for the ancient strong as a molten mirror.","searchKeywords":["wilt","thou","establish","with","him","for","the","ancient","strong","molten","mirror"]},{"verseId":"brenton_job_37_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":19,"text":"Wherefore teach me, what shall we say to him? and let us cease from saying much.","searchKeywords":["wherefore","teach","what","shall","say","him","and","let","cease","from","saying","much"]},{"verseId":"brenton_job_37_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":20,"text":"Have I a book or a scribe by me, that I may stand and put man to silence?","searchKeywords":["have","book","scribe","that","may","stand","and","put","man","silence"]},{"verseId":"brenton_job_37_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":21,"text":"But the light is not visible to all: it shines afar off in the heavens, as that which is from him in the clouds.","searchKeywords":["but","the","light","not","visible","all","shines","afar","off","heavens","that","which","from","him","clouds"]},{"verseId":"brenton_job_37_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":22,"text":"From the north the clouds shining like gold: in these great are the glory and honour of the Almighty;","searchKeywords":["from","the","north","clouds","shining","like","gold","these","great","are","glory","and","honour","almighty"]},{"verseId":"brenton_job_37_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":23,"text":"and we do not find another his equal in strength: him that judges justly, dost thou not think that he listens?","searchKeywords":["and","not","find","another","his","equal","strength","him","that","judges","justly","dost","thou","think","listens"]},{"verseId":"brenton_job_37_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":37,"verse":24,"text":"Wherefore men shall fear him; and the wise also in heart shall fear him.","searchKeywords":["wherefore","men","shall","fear","him","and","the","wise","also","heart"]}]