[{"verseId":"brenton_job_20_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":1,"text":"Then Sophar the Minæan answered and said,","searchKeywords":["then","sophar","the","min","answered","and","said"]},{"verseId":"brenton_job_20_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":2,"text":"I did not suppose that thou wouldest answer thus: neither do ye understand more than I.","searchKeywords":["did","not","suppose","that","thou","wouldest","answer","thus","neither","understand","more","than"]},{"verseId":"brenton_job_20_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":3,"text":"I will hear my shameful reproach; and the spirit of my understanding answers me.","searchKeywords":["will","hear","shameful","reproach","and","the","spirit","understanding","answers"]},{"verseId":"brenton_job_20_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":4,"text":"Hast thou known these things of old, from the time that man was set upon the earth?","searchKeywords":["hast","thou","known","these","things","old","from","the","time","that","man","was","set","upon","earth"]},{"verseId":"brenton_job_20_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":5,"text":"But the mirth of the ungodly is a signal downfall, and the joy of transgressors is destruction:","searchKeywords":["but","the","mirth","ungodly","signal","downfall","and","joy","transgressors","destruction"]},{"verseId":"brenton_job_20_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":6,"text":"although his gifts should go up to heaven, and his sacrifice reach the clouds.","searchKeywords":["although","his","gifts","should","heaven","and","sacrifice","reach","the","clouds"]},{"verseId":"brenton_job_20_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":7,"text":"For when he shall seem to be now established, then he shall utterly perish: and they that knew him shall say, Where is he?","searchKeywords":["for","when","shall","seem","now","established","then","utterly","perish","and","they","that","knew","him","say","where"]},{"verseId":"brenton_job_20_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":8,"text":"Like a dream that has fled away, he shall not be found; and he has fled like a vision of the night.","searchKeywords":["like","dream","that","has","fled","away","shall","not","found","and","vision","the","night"]},{"verseId":"brenton_job_20_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":9,"text":"The eye has looked upon him, but shall not again; and his place shall no longer perceive him.","searchKeywords":["the","eye","has","looked","upon","him","but","shall","not","again","and","his","place","longer","perceive"]},{"verseId":"brenton_job_20_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":10,"text":"Let inferiors destroy his children, and let his hands kindle the fire of sorrow.","searchKeywords":["let","inferiors","destroy","his","children","and","hands","kindle","the","fire","sorrow"]},{"verseId":"brenton_job_20_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":11,"text":"His bones have been filled with his youth, and it shall lie down with him in the dust.","searchKeywords":["his","bones","have","been","filled","with","youth","and","shall","lie","down","him","the","dust"]},{"verseId":"brenton_job_20_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":12,"text":"Though evil be sweet in his mouth, he will hide it under his tongue;","searchKeywords":["though","evil","sweet","his","mouth","will","hide","under","tongue"]},{"verseId":"brenton_job_20_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":13,"text":"though he will not spare it, and will not leave it, but will keep it in the midst of his throat:","searchKeywords":["though","will","not","spare","and","leave","but","keep","the","midst","his","throat"]},{"verseId":"brenton_job_20_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":14,"text":"yet he shall not at all be able to help himself; the gall of an asp is in his belly.","searchKeywords":["yet","shall","not","all","able","help","himself","the","gall","asp","his","belly"]},{"verseId":"brenton_job_20_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":15,"text":"wealth unjustly collected shall be vomited up; a messenger shall drag him out of his house.","searchKeywords":["wealth","unjustly","collected","shall","vomited","messenger","drag","him","out","his","house"]},{"verseId":"brenton_job_20_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":16,"text":"And let him suck the poison of serpents, and let the serpent's tongue slay him.","searchKeywords":["and","let","him","suck","the","poison","serpents","serpent","tongue","slay"]},{"verseId":"brenton_job_20_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":17,"text":"Let him not see the milk of the pastures, nor the supplies of honey and butter.","searchKeywords":["let","him","not","see","the","milk","pastures","nor","supplies","honey","and","butter"]},{"verseId":"brenton_job_20_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":18,"text":"He has laboured unprofitably and in vain, wealth of which he shall not taste: as a lean thing, unfit for food, which he cannot swallow.","searchKeywords":["has","laboured","unprofitably","and","vain","wealth","which","shall","not","taste","lean","thing","unfit","for","food","cannot","swallow"]},{"verseId":"brenton_job_20_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":19,"text":"For he has broken down the houses of many mighty men: and he has plundered an habitation, though he built not.","searchKeywords":["for","has","broken","down","the","houses","many","mighty","men","and","plundered","habitation","though","built","not"]},{"verseId":"brenton_job_20_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":20,"text":"There is no security to his possessions; he shall not be saved by his desire.","searchKeywords":["there","security","his","possessions","shall","not","saved","desire"]},{"verseId":"brenton_job_20_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":21,"text":"There is nothing remaining of his provisions; therefore his goods shall not flourish.","searchKeywords":["there","nothing","remaining","his","provisions","therefore","goods","shall","not","flourish"]},{"verseId":"brenton_job_20_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":22,"text":"But when he shall seem to be just satisfied, he shall be straitened; and all distress shall come upon him.","searchKeywords":["but","when","shall","seem","just","satisfied","straitened","and","all","distress","come","upon","him"]},{"verseId":"brenton_job_20_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":23,"text":"If by any means he would fill his belly, let send upon him the fury of wrath; let him bring a torrent of pains upon him.","searchKeywords":["any","means","would","fill","his","belly","let","send","upon","him","the","fury","wrath","bring","torrent","pains"]},{"verseId":"brenton_job_20_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":24,"text":"And he shall by no means escape from the power of the sword; let the brazen bow wound him.","searchKeywords":["and","shall","means","escape","from","the","power","sword","let","brazen","bow","wound","him"]},{"verseId":"brenton_job_20_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":25,"text":"And let the arrow pierce through his body; and let the stars be against his dwelling-place: let terrors come upon him.","searchKeywords":["and","let","the","arrow","pierce","through","his","body","stars","against","dwelling","place","terrors","come","upon","him"]},{"verseId":"brenton_job_20_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":26,"text":"And let all darkness wait for him: a fire that burns not out shall consume him; and let a stranger plague his house.","searchKeywords":["and","let","all","darkness","wait","for","him","fire","that","burns","not","out","shall","consume","stranger","plague","his","house"]},{"verseId":"brenton_job_20_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":27,"text":"And let the heaven reveal his iniquities, and the earth rise up against him.","searchKeywords":["and","let","the","heaven","reveal","his","iniquities","earth","rise","against","him"]},{"verseId":"brenton_job_20_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":28,"text":"Let destruction bring his house to an end; let a day of wrath come upon him.","searchKeywords":["let","destruction","bring","his","house","end","day","wrath","come","upon","him"]},{"verseId":"brenton_job_20_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":20,"verse":29,"text":"This is the portion of an ungodly man from the Lord, and the possession of his goods by the all-seeing .","searchKeywords":["this","the","portion","ungodly","man","from","lord","and","possession","his","goods","all","seeing"]}]