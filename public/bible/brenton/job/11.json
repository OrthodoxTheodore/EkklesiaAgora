[{"verseId":"brenton_job_11_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":1,"text":"Then Sophar the Minæan answered and said,","searchKeywords":["then","sophar","the","min","answered","and","said"]},{"verseId":"brenton_job_11_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":2,"text":"He that speaks much, should also hear on the other side: or does the fluent speaker think himself to be righteous? blessed the short-lived offspring of woman.","searchKeywords":["that","speaks","much","should","also","hear","the","other","side","does","fluent","speaker","think","himself","righteous","blessed","short","lived","offspring","woman"]},{"verseId":"brenton_job_11_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":3,"text":"Be not a speaker of many words; for is there none to answer thee?","searchKeywords":["not","speaker","many","words","for","there","none","answer","thee"]},{"verseId":"brenton_job_11_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":4,"text":"For say not, I am pure in my works, and blameless before him.","searchKeywords":["for","say","not","pure","works","and","blameless","before","him"]},{"verseId":"brenton_job_11_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":5,"text":"But oh that the Lord would speak to thee, and open his lips with thee!","searchKeywords":["but","that","the","lord","would","speak","thee","and","open","his","lips","with"]},{"verseId":"brenton_job_11_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":6,"text":"Then shall he declare to thee the power of wisdom; for it shall be double of that which is with thee: and then shalt thou know, that a just recompence of thy sins has come to thee from the Lord.","searchKeywords":["then","shall","declare","thee","the","power","wisdom","for","double","that","which","with","and","shalt","thou","know","just","recompence","thy","sins","has","come","from","lord"]},{"verseId":"brenton_job_11_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":7,"text":"Wilt thou find out the traces of the Lord? or hast thou come to the end which the Almighty has made?","searchKeywords":["wilt","thou","find","out","the","traces","lord","hast","come","end","which","almighty","has","made"]},{"verseId":"brenton_job_11_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":8,"text":"Heaven high; and what wilt thou do? and there are deeper things than those in hell; what dost thou know?","searchKeywords":["heaven","high","and","what","wilt","thou","there","are","deeper","things","than","those","hell","dost","know"]},{"verseId":"brenton_job_11_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":9,"text":"Or longer than the measure of the earth, or the breadth of the sea.","searchKeywords":["longer","than","the","measure","earth","breadth","sea"]},{"verseId":"brenton_job_11_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":10,"text":"And if he should overthrow all things, who will say to him, What hast thou done?","searchKeywords":["and","should","overthrow","all","things","who","will","say","him","what","hast","thou","done"]},{"verseId":"brenton_job_11_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":11,"text":"For he knows the works of transgressors; and when he sees wickedness, he will not overlook .","searchKeywords":["for","knows","the","works","transgressors","and","when","sees","wickedness","will","not","overlook"]},{"verseId":"brenton_job_11_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":12,"text":"But man vainly buoys himself up with words; and a mortal born of woman like an ass of the desert.","searchKeywords":["but","man","vainly","buoys","himself","with","words","and","mortal","born","woman","like","ass","the","desert"]},{"verseId":"brenton_job_11_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":13,"text":"For if thou hast made thine heart pure, and liftest up hands towards him;","searchKeywords":["for","thou","hast","made","thine","heart","pure","and","liftest","hands","towards","him"]},{"verseId":"brenton_job_11_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":14,"text":"if there is any iniquity in thy hands, put it far from thee, and let not unrighteousness lodge in thy habitation.","searchKeywords":["there","any","iniquity","thy","hands","put","far","from","thee","and","let","not","unrighteousness","lodge","habitation"]},{"verseId":"brenton_job_11_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":15,"text":"For thus shall thy countenance shine again, as pure water; and thou shalt divest thyself of uncleanness, and shalt not fear.","searchKeywords":["for","thus","shall","thy","countenance","shine","again","pure","water","and","thou","shalt","divest","thyself","uncleanness","not","fear"]},{"verseId":"brenton_job_11_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":16,"text":"And thou shalt forget trouble, as a wave that has passed by; and thou shalt not be scared.","searchKeywords":["and","thou","shalt","forget","trouble","wave","that","has","passed","not","scared"]},{"verseId":"brenton_job_11_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":17,"text":"And thy prayer as the morning star, and life shall arise to thee from the noon-day.","searchKeywords":["and","thy","prayer","the","morning","star","life","shall","arise","thee","from","noon","day"]},{"verseId":"brenton_job_11_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":18,"text":"And thou shalt be confident, because thou hast hope; and peace shall dawn to thee from out of anxiety and care.","searchKeywords":["and","thou","shalt","confident","because","hast","hope","peace","shall","dawn","thee","from","out","anxiety","care"]},{"verseId":"brenton_job_11_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":19,"text":"For thou shalt be at ease, and there shall be no one to fight against thee; and many shall charge, and make supplication to thee.","searchKeywords":["for","thou","shalt","ease","and","there","shall","one","fight","against","thee","many","charge","make","supplication"]},{"verseId":"brenton_job_11_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":11,"verse":20,"text":"But safety shall fail them; for their hope is destruction, and the eyes of the ungodly shall waste away.","searchKeywords":["but","safety","shall","fail","them","for","their","hope","destruction","and","the","eyes","ungodly","waste","away"]}]