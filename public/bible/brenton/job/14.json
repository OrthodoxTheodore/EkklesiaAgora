[{"verseId":"brenton_job_14_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":1,"text":"For a mortal born of a woman short-lived, and full of wrath.","searchKeywords":["for","mortal","born","woman","short","lived","and","full","wrath"]},{"verseId":"brenton_job_14_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":2,"text":"Or he falls like a flower that has bloomed; and he departs like a shadow, and cannot continue.","searchKeywords":["falls","like","flower","that","has","bloomed","and","departs","shadow","cannot","continue"]},{"verseId":"brenton_job_14_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":3,"text":"Hast thou not taken account even of him, and caused him to enter into judgment before thee?","searchKeywords":["hast","thou","not","taken","account","even","him","and","caused","enter","into","judgment","before","thee"]},{"verseId":"brenton_job_14_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":4,"text":"For who shall be pure from uncleanness? not even one;","searchKeywords":["for","who","shall","pure","from","uncleanness","not","even","one"]},{"verseId":"brenton_job_14_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":5,"text":"if even his life should be one day upon the earth: and his months are numbered by him: thou hast appointed for a time, and he shall by no means exceed .","searchKeywords":["even","his","life","should","one","day","upon","the","earth","and","months","are","numbered","him","thou","hast","appointed","for","time","shall","means","exceed"]},{"verseId":"brenton_job_14_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":6,"text":"Depart from him, that he may be quiet, and take pleasure in his life, as a hireling.","searchKeywords":["depart","from","him","that","may","quiet","and","take","pleasure","his","life","hireling"]},{"verseId":"brenton_job_14_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":7,"text":"For there is hope for a tree, even if it should be cut down, it shall blossom again, and its branch shall not fail.","searchKeywords":["for","there","hope","tree","even","should","cut","down","shall","blossom","again","and","its","branch","not","fail"]},{"verseId":"brenton_job_14_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":8,"text":"For though its root should grow old in the earth, and its stem die in the rock;","searchKeywords":["for","though","its","root","should","grow","old","the","earth","and","stem","die","rock"]},{"verseId":"brenton_job_14_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":9,"text":"it will blossom from the scent of water, and will produce a crop, as one newly planted.","searchKeywords":["will","blossom","from","the","scent","water","and","produce","crop","one","newly","planted"]},{"verseId":"brenton_job_14_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":10,"text":"But a man that has died is utterly gone; and when a mortal has fallen, he is no more.","searchKeywords":["but","man","that","has","died","utterly","gone","and","when","mortal","fallen","more"]},{"verseId":"brenton_job_14_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":11,"text":"For the sea wastes in time, and a river fails and is dried up.","searchKeywords":["for","the","sea","wastes","time","and","river","fails","dried"]},{"verseId":"brenton_job_14_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":12,"text":"And man that has lain down shall certainly not rise again till the heaven be dissolved, and they shall not awake from their sleep.","searchKeywords":["and","man","that","has","lain","down","shall","certainly","not","rise","again","till","the","heaven","dissolved","they","awake","from","their","sleep"]},{"verseId":"brenton_job_14_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":13,"text":"For oh that thou hadst kept me in the grave, and hadst hidden me until thy wrath should cease, and thou shouldest set me a time in which thou wouldest remember me!","searchKeywords":["for","that","thou","hadst","kept","the","grave","and","hidden","until","thy","wrath","should","cease","shouldest","set","time","which","wouldest","remember"]},{"verseId":"brenton_job_14_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":14,"text":"For if a man should die, shall he live , having accomplished the days of his life? I will wait till I exist again?","searchKeywords":["for","man","should","die","shall","live","having","accomplished","the","days","his","life","will","wait","till","exist","again"]},{"verseId":"brenton_job_14_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":15,"text":"Then shalt thou call, and I will hearken to thee: but do not thou reject the work of thine hands.","searchKeywords":["then","shalt","thou","call","and","will","hearken","thee","but","not","reject","the","work","thine","hands"]},{"verseId":"brenton_job_14_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":16,"text":"But thou hast numbered my devices: and not one of my sins shall escape thee?","searchKeywords":["but","thou","hast","numbered","devices","and","not","one","sins","shall","escape","thee"]},{"verseId":"brenton_job_14_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":17,"text":"And thou hast sealed up my transgressions in a bag, and marked if I have been guilty of any transgression unawares.","searchKeywords":["and","thou","hast","sealed","transgressions","bag","marked","have","been","guilty","any","transgression","unawares"]},{"verseId":"brenton_job_14_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":18,"text":"And verily a mountain falling will utterly be destroyed, and a rock shall be worn out of its place.","searchKeywords":["and","verily","mountain","falling","will","utterly","destroyed","rock","shall","worn","out","its","place"]},{"verseId":"brenton_job_14_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":19,"text":"The waters wear the stones, and waters falling headlong a heap of the earth: and thou destroyest the hope of man.","searchKeywords":["the","waters","wear","stones","and","falling","headlong","heap","earth","thou","destroyest","hope","man"]},{"verseId":"brenton_job_14_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":20,"text":"Thou drivest him to an end, and he is gone: thou settest thy face against him, and sendest him away;","searchKeywords":["thou","drivest","him","end","and","gone","settest","thy","face","against","sendest","away"]},{"verseId":"brenton_job_14_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":21,"text":"and though his children be multiplied, he knows not; and if they be few, he is not aware.","searchKeywords":["and","though","his","children","multiplied","knows","not","they","few","aware"]},{"verseId":"brenton_job_14_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":14,"verse":22,"text":"But his flesh is in pain, and his soul mourns.","searchKeywords":["but","his","flesh","pain","and","soul","mourns"]}]