[{"verseId":"brenton_job_22_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":1,"text":"Then Eliphaz the Thæmanite answered and said,","searchKeywords":["then","eliphaz","the","manite","answered","and","said"]},{"verseId":"brenton_job_22_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":2,"text":"Is it not the Lord that teaches understanding and knowledge?","searchKeywords":["not","the","lord","that","teaches","understanding","and","knowledge"]},{"verseId":"brenton_job_22_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":3,"text":"For what matters it to the Lord, if thou wert blameless in works? or is it profitable that thou shouldest perfect thy way?","searchKeywords":["for","what","matters","the","lord","thou","wert","blameless","works","profitable","that","shouldest","perfect","thy","way"]},{"verseId":"brenton_job_22_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":4,"text":"Wilt thou maintain and plead thine own cause? and will he enter into judgment with thee?","searchKeywords":["wilt","thou","maintain","and","plead","thine","own","cause","will","enter","into","judgment","with","thee"]},{"verseId":"brenton_job_22_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":5,"text":"Is not thy wickedness abundant, and thy sins innumerable?","searchKeywords":["not","thy","wickedness","abundant","and","sins","innumerable"]},{"verseId":"brenton_job_22_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":6,"text":"And thou hast taken security of thy brethren for nothing, and hast taken away the clothing of the naked.","searchKeywords":["and","thou","hast","taken","security","thy","brethren","for","nothing","away","the","clothing","naked"]},{"verseId":"brenton_job_22_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":7,"text":"Neither hast thou given water to the thirsty to drink, but hast taken away the morsel of the hungry.","searchKeywords":["neither","hast","thou","given","water","the","thirsty","drink","but","taken","away","morsel","hungry"]},{"verseId":"brenton_job_22_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":8,"text":"And thou hast accepted the persons of some; and thou hast established those on the earth.","searchKeywords":["and","thou","hast","accepted","the","persons","some","established","those","earth"]},{"verseId":"brenton_job_22_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":9,"text":"But thou hast sent widows away empty, and hast afflicted orphans.","searchKeywords":["but","thou","hast","sent","widows","away","empty","and","afflicted","orphans"]},{"verseId":"brenton_job_22_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":10,"text":"Therefore snares have compassed thee, and disastrous war has troubled thee.","searchKeywords":["therefore","snares","have","compassed","thee","and","disastrous","war","has","troubled"]},{"verseId":"brenton_job_22_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":11,"text":"The light has proved darkness to thee, and water has covered thee on thy lying down.","searchKeywords":["the","light","has","proved","darkness","thee","and","water","covered","thy","lying","down"]},{"verseId":"brenton_job_22_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":12,"text":"Does not he that dwells in the high places observe? and has he not brought down the proud?","searchKeywords":["does","not","that","dwells","the","high","places","observe","and","has","brought","down","proud"]},{"verseId":"brenton_job_22_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":13,"text":"And thou hast said, What does the Mighty One know? does he judge in the dark?","searchKeywords":["and","thou","hast","said","what","does","the","mighty","one","know","judge","dark"]},{"verseId":"brenton_job_22_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":14,"text":"A cloud is his hiding-place, and he shall not be seen; and he passes through the circle of heaven.","searchKeywords":["cloud","his","hiding","place","and","shall","not","seen","passes","through","the","circle","heaven"]},{"verseId":"brenton_job_22_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":15,"text":"Wilt thou mark the old way, which righteous men have trodden?","searchKeywords":["wilt","thou","mark","the","old","way","which","righteous","men","have","trodden"]},{"verseId":"brenton_job_22_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":16,"text":"who were seized before their time: their foundations an overflowing stream.","searchKeywords":["who","were","seized","before","their","time","foundations","overflowing","stream"]},{"verseId":"brenton_job_22_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":17,"text":"Who say, What will the Lord do to us? or what will the Almighty bring upon us?","searchKeywords":["who","say","what","will","the","lord","almighty","bring","upon"]},{"verseId":"brenton_job_22_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":18,"text":"Yet he filled their houses with good things: but the counsel of the wicked is far from him.","searchKeywords":["yet","filled","their","houses","with","good","things","but","the","counsel","wicked","far","from","him"]},{"verseId":"brenton_job_22_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":19,"text":"The righteous have seen , and laughed, and the blameless one has derided .","searchKeywords":["the","righteous","have","seen","and","laughed","blameless","one","has","derided"]},{"verseId":"brenton_job_22_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":20,"text":"Verily their substance has been utterly destroyed, and the fire shall devour what is left of their .","searchKeywords":["verily","their","substance","has","been","utterly","destroyed","and","the","fire","shall","devour","what","left"]},{"verseId":"brenton_job_22_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":21,"text":"Be firm, I pray thee, if thou canst endure; then thy fruit shall prosper.","searchKeywords":["firm","pray","thee","thou","canst","endure","then","thy","fruit","shall","prosper"]},{"verseId":"brenton_job_22_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":22,"text":"And receive a declaration from his mouth, and lay up his words in thine heart.","searchKeywords":["and","receive","declaration","from","his","mouth","lay","words","thine","heart"]},{"verseId":"brenton_job_22_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":23,"text":"And if thou shalt turn and humble thyself before the Lord, thou hast removed unrighteousness far from thy habitation.","searchKeywords":["and","thou","shalt","turn","humble","thyself","before","the","lord","hast","removed","unrighteousness","far","from","thy","habitation"]},{"verseId":"brenton_job_22_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":24,"text":"Thou shalt lay up for thyself in a heap on the rock; and Sophir as the rock of the torrent.","searchKeywords":["thou","shalt","lay","for","thyself","heap","the","rock","and","sophir","torrent"]},{"verseId":"brenton_job_22_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":25,"text":"So the Almighty shall be thy helper from enemies, and he shall bring thee forth pure as silver that has been tried by fire.","searchKeywords":["the","almighty","shall","thy","helper","from","enemies","and","bring","thee","forth","pure","silver","that","has","been","tried","fire"]},{"verseId":"brenton_job_22_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":26,"text":"Then shalt thou have boldness before the Lord, looking up cheerfully to heaven.","searchKeywords":["then","shalt","thou","have","boldness","before","the","lord","looking","cheerfully","heaven"]},{"verseId":"brenton_job_22_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":27,"text":"And he shall hear thee when thou prayest to him, and he shall grant thee to pay thy vows.","searchKeywords":["and","shall","hear","thee","when","thou","prayest","him","grant","pay","thy","vows"]},{"verseId":"brenton_job_22_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":28,"text":"And he shall establish to thee again a habitation of righteousness and there shall be light upon thy paths.","searchKeywords":["and","shall","establish","thee","again","habitation","righteousness","there","light","upon","thy","paths"]},{"verseId":"brenton_job_22_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":29,"text":"Because thou hast humbled thyself; and thou shalt say, has behaved proudly, but he shall save him that is of lowly eyes.","searchKeywords":["because","thou","hast","humbled","thyself","and","shalt","say","has","behaved","proudly","but","shall","save","him","that","lowly","eyes"]},{"verseId":"brenton_job_22_30","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":22,"verse":30,"text":"He shall deliver the innocent, and do thou save thyself by thy pure hands.","searchKeywords":["shall","deliver","the","innocent","and","thou","save","thyself","thy","pure","hands"]}]