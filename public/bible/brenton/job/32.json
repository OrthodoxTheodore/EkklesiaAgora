[{"verseId":"brenton_job_32_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":1,"text":"And his three friends also ceased any longer to answer Job: for Job was righteous before them.","searchKeywords":["and","his","three","friends","also","ceased","any","longer","answer","job","for","was","righteous","before","them"]},{"verseId":"brenton_job_32_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":2,"text":"Then Elius the son of Barachiel, the Buzite, of the kindred of Ram, of the country of Ausis, was angered: and he was very angry with Job, because he justified himself before the Lord.","searchKeywords":["then","elius","the","son","barachiel","buzite","kindred","ram","country","ausis","was","angered","and","very","angry","with","job","because","justified","himself","before","lord"]},{"verseId":"brenton_job_32_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":3,"text":"And he was also very angry with three friends, because they were not able to return answers to Job, yet set him down for an ungodly man.","searchKeywords":["and","was","also","very","angry","with","three","friends","because","they","were","not","able","return","answers","job","yet","set","him","down","for","ungodly","man"]},{"verseId":"brenton_job_32_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":4,"text":"But Elius had forborne to give an answer to Job, because they were older than he.","searchKeywords":["but","elius","had","forborne","give","answer","job","because","they","were","older","than"]},{"verseId":"brenton_job_32_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":5,"text":"And Elius saw that there was no answer in the mouth of the three men; and he was angered in his wrath.","searchKeywords":["and","elius","saw","that","there","was","answer","the","mouth","three","men","angered","his","wrath"]},{"verseId":"brenton_job_32_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":6,"text":"And Elius the Buzite the son of Barachiel answered and said,","searchKeywords":["and","elius","the","buzite","son","barachiel","answered","said"]},{"verseId":"brenton_job_32_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":7,"text":"And I said, It is not time that speaks, though in many years know wisdom:","searchKeywords":["and","said","not","time","that","speaks","though","many","years","know","wisdom"]},{"verseId":"brenton_job_32_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":8,"text":"but there is a spirit in mortals; and the inspiration of the Almighty is that which teaches.","searchKeywords":["but","there","spirit","mortals","and","the","inspiration","almighty","that","which","teaches"]},{"verseId":"brenton_job_32_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":9,"text":"The long-lived are not wise ; neither do the aged know judgment.","searchKeywords":["the","long","lived","are","not","wise","neither","aged","know","judgment"]},{"verseId":"brenton_job_32_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":10,"text":"Wherefore I said, Hear me, and I will tell you what I know.","searchKeywords":["wherefore","said","hear","and","will","tell","you","what","know"]},{"verseId":"brenton_job_32_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":11,"text":"Hearken to my words; for I will speak in your hearing, until ye shall have tried with words:","searchKeywords":["hearken","words","for","will","speak","your","hearing","until","shall","have","tried","with"]},{"verseId":"brenton_job_32_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":12,"text":"and I shall understand as far as you; and, behold, there was no one of you that answered Job his words in argument,","searchKeywords":["and","shall","understand","far","you","behold","there","was","one","that","answered","job","his","words","argument"]},{"verseId":"brenton_job_32_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":13,"text":"lest ye should say, We have found that we have added wisdom to the Lord.","searchKeywords":["lest","should","say","have","found","that","added","wisdom","the","lord"]},{"verseId":"brenton_job_32_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":14,"text":"And ye have commissioned a man to speak such words.","searchKeywords":["and","have","commissioned","man","speak","such","words"]},{"verseId":"brenton_job_32_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":15,"text":"They were afraid, they answered no longer; they gave up their speaking.","searchKeywords":["they","were","afraid","answered","longer","gave","their","speaking"]},{"verseId":"brenton_job_32_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":16,"text":"I waited, (for I had not spoken,) because they stood still, they answered not.","searchKeywords":["waited","for","had","not","spoken","because","they","stood","still","answered"]},{"verseId":"brenton_job_32_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":17,"text":"And Elius continued, and said, I will again speak,","searchKeywords":["and","elius","continued","said","will","again","speak"]},{"verseId":"brenton_job_32_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":18,"text":"for I am full of words, for the spirit of my belly destroys me.","searchKeywords":["for","full","words","the","spirit","belly","destroys"]},{"verseId":"brenton_job_32_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":19,"text":"And my belly is as a skin of sweet wine bound up ready to burst; or as a brazier's labouring bellows.","searchKeywords":["and","belly","skin","sweet","wine","bound","ready","burst","brazier","labouring","bellows"]},{"verseId":"brenton_job_32_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":20,"text":"I will speak, that I may open my lips and relieve myself.","searchKeywords":["will","speak","that","may","open","lips","and","relieve","myself"]},{"verseId":"brenton_job_32_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":21,"text":"For truly I will not be awed because of man, nor indeed will I be confounded before a mortal.","searchKeywords":["for","truly","will","not","awed","because","man","nor","indeed","confounded","before","mortal"]},{"verseId":"brenton_job_32_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":32,"verse":22,"text":"For I know not how to respect persons: and if otherwise, even the moths would eat me.","searchKeywords":["for","know","not","how","respect","persons","and","otherwise","even","the","moths","would","eat"]}]