[{"verseId":"brenton_job_34_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":1,"text":"And Elius continued, and said,","searchKeywords":["and","elius","continued","said"]},{"verseId":"brenton_job_34_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":2,"text":"Hear me, ye wise men; hearken, ye that have knowledge.","searchKeywords":["hear","wise","men","hearken","that","have","knowledge"]},{"verseId":"brenton_job_34_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":3,"text":"For the ear tries words, and the mouth tastes meat.","searchKeywords":["for","the","ear","tries","words","and","mouth","tastes","meat"]},{"verseId":"brenton_job_34_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":4,"text":"Let us choose judgment to ourselves: let us know among ourselves what is right.","searchKeywords":["let","choose","judgment","ourselves","know","among","what","right"]},{"verseId":"brenton_job_34_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":5,"text":"For Job has said, I am righteous: the Lord has removed my judgment.","searchKeywords":["for","job","has","said","righteous","the","lord","removed","judgment"]},{"verseId":"brenton_job_34_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":6,"text":"And he has erred in my judgment: my wound is severe without unrighteousness .","searchKeywords":["and","has","erred","judgment","wound","severe","without","unrighteousness"]},{"verseId":"brenton_job_34_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":7,"text":"What man is as Job, drinking scorning like water?","searchKeywords":["what","man","job","drinking","scorning","like","water"]},{"verseId":"brenton_job_34_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":8,"text":", I have not sinned, nor committed ungodliness, nor had fellowship with workers of iniquity, to go with the ungodly.","searchKeywords":["have","not","sinned","nor","committed","ungodliness","had","fellowship","with","workers","iniquity","the","ungodly"]},{"verseId":"brenton_job_34_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":9,"text":"For thou shouldest not say, There shall be no visitation of a man, whereas a visitation on him from the Lord.","searchKeywords":["for","thou","shouldest","not","say","there","shall","visitation","man","whereas","him","from","the","lord"]},{"verseId":"brenton_job_34_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":10,"text":"Wherefore hear me, ye that are wise in heart: far be it from me to sin before the Lord, and to pervert righteousness before the Almighty.","searchKeywords":["wherefore","hear","that","are","wise","heart","far","from","sin","before","the","lord","and","pervert","righteousness","almighty"]},{"verseId":"brenton_job_34_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":11,"text":"Yea, he renders to a man accordingly as each of them does, and in a man's path he will find him.","searchKeywords":["yea","renders","man","accordingly","each","them","does","and","path","will","find","him"]},{"verseId":"brenton_job_34_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":12,"text":"And thinkest thou that the Lord will do wrong, or will the Almighty who made the earth wrest judgment?","searchKeywords":["and","thinkest","thou","that","the","lord","will","wrong","almighty","who","made","earth","wrest","judgment"]},{"verseId":"brenton_job_34_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":13,"text":"And who is he that made under heaven, and all things therein?","searchKeywords":["and","who","that","made","under","heaven","all","things","therein"]},{"verseId":"brenton_job_34_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":14,"text":"For if he would confine, and restrain his spirit with himself;","searchKeywords":["for","would","confine","and","restrain","his","spirit","with","himself"]},{"verseId":"brenton_job_34_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":15,"text":"all flesh would die together, and every mortal would return to the earth, whence also he was formed.","searchKeywords":["all","flesh","would","die","together","and","every","mortal","return","the","earth","whence","also","was","formed"]},{"verseId":"brenton_job_34_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":16,"text":"Take heed lest he rebuke : hear this, hearken to the voice of words.","searchKeywords":["take","heed","lest","rebuke","hear","this","hearken","the","voice","words"]},{"verseId":"brenton_job_34_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":17,"text":"Behold then the one that hates iniquities, and that destroys the wicked, who is for ever just.","searchKeywords":["behold","then","the","one","that","hates","iniquities","and","destroys","wicked","who","for","ever","just"]},{"verseId":"brenton_job_34_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":18,"text":"ungodly that says to a king, Thou art a transgressor, to princes, O most ungodly one.","searchKeywords":["ungodly","that","says","king","thou","art","transgressor","princes","most","one"]},{"verseId":"brenton_job_34_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":19,"text":"as would not reverence the face of an honourable man, neither knows how to give honour to the great, so as that their persons should be respected.","searchKeywords":["would","not","reverence","the","face","honourable","man","neither","knows","how","give","honour","great","that","their","persons","should","respected"]},{"verseId":"brenton_job_34_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":20,"text":"But it shall turn out vanity to them, to cry and beseech a man; for they dealt unlawfully, the poor being turned aside .","searchKeywords":["but","shall","turn","out","vanity","them","cry","and","beseech","man","for","they","dealt","unlawfully","the","poor","being","turned","aside"]},{"verseId":"brenton_job_34_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":21,"text":"For he surveys the works of men, and nothing of what they do has escaped him.","searchKeywords":["for","surveys","the","works","men","and","nothing","what","they","has","escaped","him"]},{"verseId":"brenton_job_34_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":22,"text":"Neither shall there be a place for the workers of iniquity to hide themselves.","searchKeywords":["neither","shall","there","place","for","the","workers","iniquity","hide","themselves"]},{"verseId":"brenton_job_34_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":23,"text":"For he will not lay upon a man more .","searchKeywords":["for","will","not","lay","upon","man","more"]},{"verseId":"brenton_job_34_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":24,"text":"For the Lord looks down upon all men, who comprehends unsearchable things, glorious also and excellent things without number.","searchKeywords":["for","the","lord","looks","down","upon","all","men","who","comprehends","unsearchable","things","glorious","also","and","excellent","without","number"]},{"verseId":"brenton_job_34_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":25,"text":"Who discovers their works, and will bring night about , and they shall be brought low.","searchKeywords":["who","discovers","their","works","and","will","bring","night","about","they","shall","brought","low"]},{"verseId":"brenton_job_34_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":26,"text":"And he quite destroys the ungodly, for they are seen before him.","searchKeywords":["and","quite","destroys","the","ungodly","for","they","are","seen","before","him"]},{"verseId":"brenton_job_34_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":27,"text":"Because they turned aside from the law of God, and did not regard his ordinances,","searchKeywords":["because","they","turned","aside","from","the","law","god","and","did","not","regard","his","ordinances"]},{"verseId":"brenton_job_34_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":28,"text":"so as to bring before him the cry of the needy; for he will hear the cry of the poor.","searchKeywords":["bring","before","him","the","cry","needy","for","will","hear","poor"]},{"verseId":"brenton_job_34_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":29,"text":"And he will give quiet, and who will condemn? and he will hide his face, and who shall see him? whether against a nation, or against a man also:","searchKeywords":["and","will","give","quiet","who","condemn","hide","his","face","shall","see","him","whether","against","nation","man","also"]},{"verseId":"brenton_job_34_30","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":30,"text":"causing a hypocrite to be king, because of the waywardness of the people.","searchKeywords":["causing","hypocrite","king","because","the","waywardness","people"]},{"verseId":"brenton_job_34_31","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":31,"text":"For one that says to the Mighty One, I have received ; I will not take a pledge:","searchKeywords":["for","one","that","says","the","mighty","have","received","will","not","take","pledge"]},{"verseId":"brenton_job_34_32","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":32,"text":"I will see apart from myself: do thou shew me if I have done unrighteousness; I will not do any more.","searchKeywords":["will","see","apart","from","myself","thou","shew","have","done","unrighteousness","not","any","more"]},{"verseId":"brenton_job_34_33","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":33,"text":"Will he take vengeance for it on thee, whereas thou wilt put far ? for thou shalt choose, and not I; and what thou knowest, speak thou.","searchKeywords":["will","take","vengeance","for","thee","whereas","thou","wilt","put","far","shalt","choose","and","not","what","knowest","speak"]},{"verseId":"brenton_job_34_34","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":34,"text":"Because the wise in heart shall say this, and a wise man listens to my word.","searchKeywords":["because","the","wise","heart","shall","say","this","and","man","listens","word"]},{"verseId":"brenton_job_34_35","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":35,"text":"But Job has not spoken with understanding, his words are not with knowledge.","searchKeywords":["but","job","has","not","spoken","with","understanding","his","words","are","knowledge"]},{"verseId":"brenton_job_34_36","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":36,"text":"Howbeit do thou learn, Job: no longer make answer as the foolish:","searchKeywords":["howbeit","thou","learn","job","longer","make","answer","the","foolish"]},{"verseId":"brenton_job_34_37","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":34,"verse":37,"text":"that we add not to our sins: for iniquity will be reckoned against us, if speak many words before the Lord.","searchKeywords":["that","add","not","our","sins","for","iniquity","will","reckoned","against","speak","many","words","before","the","lord"]}]