[{"verseId":"brenton_job_33_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":1,"text":"Howbeit hear, Job, my words, and hearken to my speech.","searchKeywords":["howbeit","hear","job","words","and","hearken","speech"]},{"verseId":"brenton_job_33_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":2,"text":"For behold, I have opened my mouth, and my tongue has spoken.","searchKeywords":["for","behold","have","opened","mouth","and","tongue","has","spoken"]},{"verseId":"brenton_job_33_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":3,"text":"My heart pure by words; and the understanding of my lips shall meditate purity.","searchKeywords":["heart","pure","words","and","the","understanding","lips","shall","meditate","purity"]},{"verseId":"brenton_job_33_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":4,"text":"The Divine Spirit is that which formed me, and the breath of the Almighty that which teaches me.","searchKeywords":["the","divine","spirit","that","which","formed","and","breath","almighty","teaches"]},{"verseId":"brenton_job_33_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":5,"text":"If thou canst, give me an answer: wait therefore; stand against me, and I against thee.","searchKeywords":["thou","canst","give","answer","wait","therefore","stand","against","and","thee"]},{"verseId":"brenton_job_33_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":6,"text":"Thou art formed out of the clay as also I: we have been formed out of the same .","searchKeywords":["thou","art","formed","out","the","clay","also","have","been","same"]},{"verseId":"brenton_job_33_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":7,"text":"My fear shall not terrify thee, neither shall my hand be heavy upon thee.","searchKeywords":["fear","shall","not","terrify","thee","neither","hand","heavy","upon"]},{"verseId":"brenton_job_33_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":8,"text":"But thou hast said in mine ears, (I have heard the voice of thy words;) because thou sayest, I am pure, not having sinned;","searchKeywords":["but","thou","hast","said","mine","ears","have","heard","the","voice","thy","words","because","sayest","pure","not","having","sinned"]},{"verseId":"brenton_job_33_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":9,"text":"I am blameless, for I have not transgressed.","searchKeywords":["blameless","for","have","not","transgressed"]},{"verseId":"brenton_job_33_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":10,"text":"Yet he has discovered a charge against me, and he has reckoned me as an adversary.","searchKeywords":["yet","has","discovered","charge","against","and","reckoned","adversary"]},{"verseId":"brenton_job_33_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":11,"text":"And he has put my foot in the stocks, and has watched all my ways.","searchKeywords":["and","has","put","foot","the","stocks","watched","all","ways"]},{"verseId":"brenton_job_33_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":12,"text":"For how sayest thou, I am righteous, yet he has not hearkened to me? for he that is above mortals is eternal.","searchKeywords":["for","how","sayest","thou","righteous","yet","has","not","hearkened","that","above","mortals","eternal"]},{"verseId":"brenton_job_33_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":13,"text":"But thou sayest, Why has he not heard every word of my cause?","searchKeywords":["but","thou","sayest","why","has","not","heard","every","word","cause"]},{"verseId":"brenton_job_33_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":14,"text":"For when the Lord speaks once, or a second time,","searchKeywords":["for","when","the","lord","speaks","once","second","time"]},{"verseId":"brenton_job_33_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":15,"text":"a dream, or in the meditation of the night; (as when a dreadful alarm happens to fall upon men, in slumberings on the bed:)","searchKeywords":["dream","the","meditation","night","when","dreadful","alarm","happens","fall","upon","men","slumberings","bed"]},{"verseId":"brenton_job_33_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":16,"text":"then opens he the understanding of men: he scares them with such fearful visions:","searchKeywords":["then","opens","the","understanding","men","scares","them","with","such","fearful","visions"]},{"verseId":"brenton_job_33_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":17,"text":"to turn a man from unrighteousness, and he delivers his body from a fall.","searchKeywords":["turn","man","from","unrighteousness","and","delivers","his","body","fall"]},{"verseId":"brenton_job_33_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":18,"text":"He spares also his soul from death, and him not to fall in war.","searchKeywords":["spares","also","his","soul","from","death","and","him","not","fall","war"]},{"verseId":"brenton_job_33_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":19,"text":"And again, he chastens him with sickness on his bed, and the multitude of his bones is benumbed.","searchKeywords":["and","again","chastens","him","with","sickness","his","bed","the","multitude","bones","benumbed"]},{"verseId":"brenton_job_33_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":20,"text":"And he shall not be able to take any food, though his soul shall desire meat;","searchKeywords":["and","shall","not","able","take","any","food","though","his","soul","desire","meat"]},{"verseId":"brenton_job_33_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":21,"text":"until his flesh shall be consumed, and he shall shew his bones bare.","searchKeywords":["until","his","flesh","shall","consumed","and","shew","bones","bare"]},{"verseId":"brenton_job_33_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":22,"text":"His soul also draws nigh to death, and his life is in Hades.","searchKeywords":["his","soul","also","draws","nigh","death","and","life","hades"]},{"verseId":"brenton_job_33_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":23,"text":"Though there should be a thousand messengers of death, not one of them shall wound him: if he should purpose in his heart to turn to the Lord, and declare to man his fault, and shew his folly;","searchKeywords":["though","there","should","thousand","messengers","death","not","one","them","shall","wound","him","purpose","his","heart","turn","the","lord","and","declare","man","fault","shew","folly"]},{"verseId":"brenton_job_33_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":24,"text":"he will support him, that he should not perish, and will restore his body as plaster upon a wall; and he will fill his bones with marrow.","searchKeywords":["will","support","him","that","should","not","perish","and","restore","his","body","plaster","upon","wall","fill","bones","with","marrow"]},{"verseId":"brenton_job_33_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":25,"text":"And he will make his flesh tender as that of a babe, and he will restore him among men in full strength.","searchKeywords":["and","will","make","his","flesh","tender","that","babe","restore","him","among","men","full","strength"]},{"verseId":"brenton_job_33_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":26,"text":"And he shall pray to the Lord, and his prayer shall be accepted of him; he shall enter with a cheerful countenance, with a full expression : for he will render to men due.","searchKeywords":["and","shall","pray","the","lord","his","prayer","accepted","him","enter","with","cheerful","countenance","full","expression","for","will","render","men","due"]},{"verseId":"brenton_job_33_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":27,"text":"Even then a man shall blame himself, saying, What kind of things have I done? and he has not punished me according to the full amount of my sins.","searchKeywords":["even","then","man","shall","blame","himself","saying","what","kind","things","have","done","and","has","not","punished","according","the","full","amount","sins"]},{"verseId":"brenton_job_33_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":28,"text":"Deliver my soul, that it may not go to destruction, and my life shall see the light.","searchKeywords":["deliver","soul","that","may","not","destruction","and","life","shall","see","the","light"]},{"verseId":"brenton_job_33_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":29,"text":"Behold, all these things the Mighty One works in a threefold manner with a man.","searchKeywords":["behold","all","these","things","the","mighty","one","works","threefold","manner","with","man"]},{"verseId":"brenton_job_33_30","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":30,"text":"And he has delivered my soul from death, that my life may praise him in the light.","searchKeywords":["and","has","delivered","soul","from","death","that","life","may","praise","him","the","light"]},{"verseId":"brenton_job_33_31","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":31,"text":"Hearken, Job, and hear me: be silent, and I will speak.","searchKeywords":["hearken","job","and","hear","silent","will","speak"]},{"verseId":"brenton_job_33_32","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":32,"text":"If thou hast words, answer me: speak, for I desire thee to be justified.","searchKeywords":["thou","hast","words","answer","speak","for","desire","thee","justified"]},{"verseId":"brenton_job_33_33","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":33,"verse":33,"text":"If not, do thou hear me: be silent, and I will teach thee.","searchKeywords":["not","thou","hear","silent","and","will","teach","thee"]}]