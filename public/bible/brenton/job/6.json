[{"verseId":"brenton_job_6_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":1,"text":"But Job answered and said,","searchKeywords":["but","job","answered","and","said"]},{"verseId":"brenton_job_6_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":2,"text":"Oh that one would indeed weigh the wrath that is upon me, and take up my griefs in a balance together!","searchKeywords":["that","one","would","indeed","weigh","the","wrath","upon","and","take","griefs","balance","together"]},{"verseId":"brenton_job_6_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":3,"text":"And verily they would be heavier than the sand by the seashore: but, as it seems, my words are vain.","searchKeywords":["and","verily","they","would","heavier","than","the","sand","seashore","but","seems","words","are","vain"]},{"verseId":"brenton_job_6_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":4,"text":"For the arrows of the Lord are in my body, whose violence drinks up my blood: whenever I am going to speak, they pierce me.","searchKeywords":["for","the","arrows","lord","are","body","whose","violence","drinks","blood","whenever","going","speak","they","pierce"]},{"verseId":"brenton_job_6_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":5,"text":"What then? will the wild ass bray for nothing, if he is not seeking food? or again, will the ox low at the manger, when he has fodder?","searchKeywords":["what","then","will","the","wild","ass","bray","for","nothing","not","seeking","food","again","low","manger","when","has","fodder"]},{"verseId":"brenton_job_6_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":6,"text":"Shall bread be eaten without salt? or again, is there taste in empty words?","searchKeywords":["shall","bread","eaten","without","salt","again","there","taste","empty","words"]},{"verseId":"brenton_job_6_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":7,"text":"For my wrath cannot cease; for I perceive my food as the smell of a lion loathsome.","searchKeywords":["for","wrath","cannot","cease","perceive","food","the","smell","lion","loathsome"]},{"verseId":"brenton_job_6_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":8,"text":"For oh that he would grant , and my petition might come, and the Lord would grant my hope!","searchKeywords":["for","that","would","grant","and","petition","might","come","the","lord","hope"]},{"verseId":"brenton_job_6_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":9,"text":"Let the Lord begin and wound me, but let him not utterly destroy me.","searchKeywords":["let","the","lord","begin","and","wound","but","him","not","utterly","destroy"]},{"verseId":"brenton_job_6_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":10,"text":"Let the grave be my city, upon the walls of which I have leaped: I will not shrink from it; for I have not denied the holy words of my God.","searchKeywords":["let","the","grave","city","upon","walls","which","have","leaped","will","not","shrink","from","for","denied","holy","words","god"]},{"verseId":"brenton_job_6_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":11,"text":"For what is my strength, that I continue? what is my time, that my soul endures?","searchKeywords":["for","what","strength","that","continue","time","soul","endures"]},{"verseId":"brenton_job_6_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":12,"text":"Is my strength the strength of stones? or is my flesh of brass?","searchKeywords":["strength","the","stones","flesh","brass"]},{"verseId":"brenton_job_6_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":13,"text":"Or have I not trusted in him? but help is from me.","searchKeywords":["have","not","trusted","him","but","help","from"]},{"verseId":"brenton_job_6_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":14,"text":"Mercy has rejected me; and the visitation of the Lord has disregarded me.","searchKeywords":["mercy","has","rejected","and","the","visitation","lord","disregarded"]},{"verseId":"brenton_job_6_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":15,"text":"My nearest relations have not regarded me; they have passed me by like a failing brook, or like a wave.","searchKeywords":["nearest","relations","have","not","regarded","they","passed","like","failing","brook","wave"]},{"verseId":"brenton_job_6_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":16,"text":"They who used to reverence me, now have come against me like snow or congealed ice.","searchKeywords":["they","who","used","reverence","now","have","come","against","like","snow","congealed","ice"]},{"verseId":"brenton_job_6_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":17,"text":"When it has melted at the approach of heat, it is not known what it was.","searchKeywords":["when","has","melted","the","approach","heat","not","known","what","was"]},{"verseId":"brenton_job_6_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":18,"text":"Thus I also have been deserted of all; and I am ruined, and become an outcast.","searchKeywords":["thus","also","have","been","deserted","all","and","ruined","become","outcast"]},{"verseId":"brenton_job_6_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":19,"text":"Behold the ways of the Thæmanites, ye that mark the paths of the Sabæans.","searchKeywords":["behold","the","ways","manites","that","mark","paths","sab","ans"]},{"verseId":"brenton_job_6_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":20,"text":"They too that trust in cities and riches shall come to shame.","searchKeywords":["they","too","that","trust","cities","and","riches","shall","come","shame"]},{"verseId":"brenton_job_6_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":21,"text":"But ye also have come to me without pity; so that beholding my wound ye are afraid.","searchKeywords":["but","also","have","come","without","pity","that","beholding","wound","are","afraid"]},{"verseId":"brenton_job_6_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":22,"text":"What? have I made any demand of you? or do I ask for strength from you,","searchKeywords":["what","have","made","any","demand","you","ask","for","strength","from"]},{"verseId":"brenton_job_6_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":23,"text":"to deliver me from enemies, or to rescue me from the hand of the mighty ones?","searchKeywords":["deliver","from","enemies","rescue","the","hand","mighty","ones"]},{"verseId":"brenton_job_6_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":24,"text":"Teach ye me, and I will be silent: if in anything I have erred, tell me.","searchKeywords":["teach","and","will","silent","anything","have","erred","tell"]},{"verseId":"brenton_job_6_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":25,"text":"But as it seems, the words of a true man are vain, because I do not ask strength of you.","searchKeywords":["but","seems","the","words","true","man","are","vain","because","not","ask","strength","you"]},{"verseId":"brenton_job_6_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":26,"text":"Neither will your reproof cause me to cease my words, for neither will I endure the sound of your speech.","searchKeywords":["neither","will","your","reproof","cause","cease","words","for","endure","the","sound","speech"]},{"verseId":"brenton_job_6_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":27,"text":"Even because ye attack the fatherless, and insult your friend.","searchKeywords":["even","because","attack","the","fatherless","and","insult","your","friend"]},{"verseId":"brenton_job_6_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":28,"text":"But now, having looked upon your countenances, I will not lie.","searchKeywords":["but","now","having","looked","upon","your","countenances","will","not","lie"]},{"verseId":"brenton_job_6_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":29,"text":"Sit down now, and let there not be unrighteousness; and unite again with the just.","searchKeywords":["sit","down","now","and","let","there","not","unrighteousness","unite","again","with","the","just"]},{"verseId":"brenton_job_6_30","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":6,"verse":30,"text":"For there is no injustice in my tongue; and does not my throat meditate understanding?","searchKeywords":["for","there","injustice","tongue","and","does","not","throat","meditate","understanding"]}]