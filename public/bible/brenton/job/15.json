[{"verseId":"brenton_job_15_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":1,"text":"Then Eliphaz the Thæmanite answered and said,","searchKeywords":["then","eliphaz","the","manite","answered","and","said"]},{"verseId":"brenton_job_15_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":2,"text":"Will a wise man give for answer a breath of wisdom? and does he fill up the pain of his belly,","searchKeywords":["will","wise","man","give","for","answer","breath","wisdom","and","does","fill","the","pain","his","belly"]},{"verseId":"brenton_job_15_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":3,"text":"reasoning with improper sayings, and with words wherein is no profit?","searchKeywords":["reasoning","with","improper","sayings","and","words","wherein","profit"]},{"verseId":"brenton_job_15_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":4,"text":"Hast not thou moreover cast off fear, and accomplished such words before the Lord?","searchKeywords":["hast","not","thou","moreover","cast","off","fear","and","accomplished","such","words","before","the","lord"]},{"verseId":"brenton_job_15_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":5,"text":"Thou art guilty by the words of thy mouth, neither hast thou discerned the words of the mighty.","searchKeywords":["thou","art","guilty","the","words","thy","mouth","neither","hast","discerned","mighty"]},{"verseId":"brenton_job_15_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":6,"text":"Let thine own mouth, and not me, reprove thee: and thy lips shall testify against thee.","searchKeywords":["let","thine","own","mouth","and","not","reprove","thee","thy","lips","shall","testify","against"]},{"verseId":"brenton_job_15_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":7,"text":"What! art thou the first man that was born? or wert thou established before the hills?","searchKeywords":["what","art","thou","the","first","man","that","was","born","wert","established","before","hills"]},{"verseId":"brenton_job_15_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":8,"text":"Or hast thou heard the ordinance of the Lord? or has God used thee as counsellor? and has wisdom come to thee?","searchKeywords":["hast","thou","heard","the","ordinance","lord","has","god","used","thee","counsellor","and","wisdom","come"]},{"verseId":"brenton_job_15_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":9,"text":"For what knowest thou, that we know not? or what understandest thou, which we do not also?","searchKeywords":["for","what","knowest","thou","that","know","not","understandest","which","also"]},{"verseId":"brenton_job_15_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":10,"text":"Truly among us both the old and very aged man, more advanced in days than thy father.","searchKeywords":["truly","among","both","the","old","and","very","aged","man","more","advanced","days","than","thy","father"]},{"verseId":"brenton_job_15_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":11,"text":"Thou hast been scourged for few of thy sins: thou hast spoken haughtily extravagantly.","searchKeywords":["thou","hast","been","scourged","for","few","thy","sins","spoken","haughtily","extravagantly"]},{"verseId":"brenton_job_15_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":12,"text":"What has thine heart dared? or what have thine eyes ,","searchKeywords":["what","has","thine","heart","dared","have","eyes"]},{"verseId":"brenton_job_15_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":13,"text":"that thou hast vented rage before the Lord, and delivered such words from mouth?","searchKeywords":["that","thou","hast","vented","rage","before","the","lord","and","delivered","such","words","from","mouth"]},{"verseId":"brenton_job_15_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":14,"text":"For who, being a mortal, that he shall be blameless? or, born of a woman, that he should be just?","searchKeywords":["for","who","being","mortal","that","shall","blameless","born","woman","should","just"]},{"verseId":"brenton_job_15_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":15,"text":"Forasmuch as he trusts not his saints; and the heaven is not pure before him.","searchKeywords":["forasmuch","trusts","not","his","saints","and","the","heaven","pure","before","him"]},{"verseId":"brenton_job_15_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":16,"text":"Alas then, abominable and unclean is man, drinking unrighteousness as a draught.","searchKeywords":["alas","then","abominable","and","unclean","man","drinking","unrighteousness","draught"]},{"verseId":"brenton_job_15_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":17,"text":"But I will tell thee, hearken to me; I will tell thee now what I have seen;","searchKeywords":["but","will","tell","thee","hearken","now","what","have","seen"]},{"verseId":"brenton_job_15_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":18,"text":"things wise men say, and their fathers have not hidden.","searchKeywords":["things","wise","men","say","and","their","fathers","have","not","hidden"]},{"verseId":"brenton_job_15_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":19,"text":"To them alone the earth was given, and no stranger came upon them.","searchKeywords":["them","alone","the","earth","was","given","and","stranger","came","upon"]},{"verseId":"brenton_job_15_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":20,"text":"All the life of the ungodly in care, and the years granted to the oppressor are numbered.","searchKeywords":["all","the","life","ungodly","care","and","years","granted","oppressor","are","numbered"]},{"verseId":"brenton_job_15_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":21,"text":"And his terror is in his ears: just when he seems to be at peace, his overthrow will come.","searchKeywords":["and","his","terror","ears","just","when","seems","peace","overthrow","will","come"]},{"verseId":"brenton_job_15_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":22,"text":"Let him not trust that he shall return from darkness, for he has been already made over to the power of the sword.","searchKeywords":["let","him","not","trust","that","shall","return","from","darkness","for","has","been","already","made","over","the","power","sword"]},{"verseId":"brenton_job_15_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":23,"text":"And he has been appointed to be food for vultures; and he knows within himself that he is doomed to be a carcase: and a dark day shall carry him away as with a whirlwind.","searchKeywords":["and","has","been","appointed","food","for","vultures","knows","within","himself","that","doomed","carcase","dark","day","shall","carry","him","away","with","whirlwind"]},{"verseId":"brenton_job_15_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":24,"text":"Distress also and anguish shall come upon him: he shall fall as a captain in the first rank.","searchKeywords":["distress","also","and","anguish","shall","come","upon","him","fall","captain","the","first","rank"]},{"verseId":"brenton_job_15_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":25,"text":"For he has lifted his hands against the Lord, and he has hardened his neck against the Almighty Lord.","searchKeywords":["for","has","lifted","his","hands","against","the","lord","and","hardened","neck","almighty"]},{"verseId":"brenton_job_15_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":26,"text":"And he has run against him with insolence, on the thickness of the back of his shield.","searchKeywords":["and","has","run","against","him","with","insolence","the","thickness","back","his","shield"]},{"verseId":"brenton_job_15_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":27,"text":"For he has covered his face with his fat, and made layers of fat upon his thighs.","searchKeywords":["for","has","covered","his","face","with","fat","and","made","layers","upon","thighs"]},{"verseId":"brenton_job_15_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":28,"text":"And let him lodge in desolate cities, and enter into houses without inhabitant: and what they have prepared, others shall carry away.","searchKeywords":["and","let","him","lodge","desolate","cities","enter","into","houses","without","inhabitant","what","they","have","prepared","others","shall","carry","away"]},{"verseId":"brenton_job_15_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":29,"text":"Neither shall he at all grow rich, nor shall his substance remain: he shall not cast a shadow upon the earth.","searchKeywords":["neither","shall","all","grow","rich","nor","his","substance","remain","not","cast","shadow","upon","the","earth"]},{"verseId":"brenton_job_15_30","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":30,"text":"Neither shall he in any wise escape the darkness: let the wind blast his blossom, and let his flower fall off.","searchKeywords":["neither","shall","any","wise","escape","the","darkness","let","wind","blast","his","blossom","and","flower","fall","off"]},{"verseId":"brenton_job_15_31","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":31,"text":"Let him not think that he shall endure; for his end shall be vanity.","searchKeywords":["let","him","not","think","that","shall","endure","for","his","end","vanity"]},{"verseId":"brenton_job_15_32","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":32,"text":"His harvest shall perish before the time, and his branch shall not flourish.","searchKeywords":["his","harvest","shall","perish","before","the","time","and","branch","not","flourish"]},{"verseId":"brenton_job_15_33","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":33,"text":"And let him be gathered as the unripe grape before the time, and let him fall as the blossom of the olive.","searchKeywords":["and","let","him","gathered","the","unripe","grape","before","time","fall","blossom","olive"]},{"verseId":"brenton_job_15_34","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":34,"text":"For death is the witness of an ungodly man, and fire shall burn the houses of them that receive gifts.","searchKeywords":["for","death","the","witness","ungodly","man","and","fire","shall","burn","houses","them","that","receive","gifts"]},{"verseId":"brenton_job_15_35","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":15,"verse":35,"text":"And he shall conceive sorrows, and his end shall be vanity, and his belly shall bear deceit.","searchKeywords":["and","shall","conceive","sorrows","his","end","vanity","belly","bear","deceit"]}]