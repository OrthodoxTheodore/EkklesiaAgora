[{"verseId":"brenton_job_10_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":1,"text":"Weary in my soul, I will pour my words with groans upon him: I will speak being straitened in the bitterness of my soul.","searchKeywords":["weary","soul","will","pour","words","with","groans","upon","him","speak","being","straitened","the","bitterness"]},{"verseId":"brenton_job_10_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":2,"text":"And I will say to the Lord, Do not teach me to be impious; and wherefore hast thou thus judged me?","searchKeywords":["and","will","say","the","lord","not","teach","impious","wherefore","hast","thou","thus","judged"]},{"verseId":"brenton_job_10_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":3,"text":"Is it good before thee if I be unrighteous? for thou hast disowned the work of thy hands, and attended to the counsel of the ungodly.","searchKeywords":["good","before","thee","unrighteous","for","thou","hast","disowned","the","work","thy","hands","and","attended","counsel","ungodly"]},{"verseId":"brenton_job_10_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":4,"text":"Or dost thou see as a mortal sees? or wilt thou look as a man sees?","searchKeywords":["dost","thou","see","mortal","sees","wilt","look","man"]},{"verseId":"brenton_job_10_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":5,"text":"Or is thy life human, or thy years of a man,","searchKeywords":["thy","life","human","years","man"]},{"verseId":"brenton_job_10_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":6,"text":"that thou hast enquired into mine iniquity, and searched out my sins?","searchKeywords":["that","thou","hast","enquired","into","mine","iniquity","and","searched","out","sins"]},{"verseId":"brenton_job_10_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":7,"text":"For thou knowest that I have not committed iniquity: but who is he that can deliver out of thy hands?","searchKeywords":["for","thou","knowest","that","have","not","committed","iniquity","but","who","can","deliver","out","thy","hands"]},{"verseId":"brenton_job_10_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":8,"text":"Thy hands have formed me and made me; afterwards thou didst change , and smite me.","searchKeywords":["thy","hands","have","formed","and","made","afterwards","thou","didst","change","smite"]},{"verseId":"brenton_job_10_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":9,"text":"Remember that thou hast made me clay, and thou dost turn me again to earth.","searchKeywords":["remember","that","thou","hast","made","clay","and","dost","turn","again","earth"]},{"verseId":"brenton_job_10_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":10,"text":"Hast thou not poured me out like milk, and curdled me like cheese?","searchKeywords":["hast","thou","not","poured","out","like","milk","and","curdled","cheese"]},{"verseId":"brenton_job_10_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":11,"text":"And thou didst clothe me with skin and flesh, and frame me with bones and sinews.","searchKeywords":["and","thou","didst","clothe","with","skin","flesh","frame","bones","sinews"]},{"verseId":"brenton_job_10_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":12,"text":"And thou didst bestow upon me life and mercy, and thy oversight has preserved my spirit.","searchKeywords":["and","thou","didst","bestow","upon","life","mercy","thy","oversight","has","preserved","spirit"]},{"verseId":"brenton_job_10_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":13,"text":"Having these things in thyself, I know that thou canst do all things; for nothing is impossible with thee.","searchKeywords":["having","these","things","thyself","know","that","thou","canst","all","for","nothing","impossible","with","thee"]},{"verseId":"brenton_job_10_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":14,"text":"And if I should sin, thou watchest me; and thou hast not cleared me from iniquity.","searchKeywords":["and","should","sin","thou","watchest","hast","not","cleared","from","iniquity"]},{"verseId":"brenton_job_10_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":15,"text":"Or if I should be ungodly, woe is me: and if I should be righteous, I cannot lift myself up, for I am full of dishonour.","searchKeywords":["should","ungodly","woe","and","righteous","cannot","lift","myself","for","full","dishonour"]},{"verseId":"brenton_job_10_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":16,"text":"For I am hunted like a lion for slaughter; for again thou hast changed and art terribly destroying me;","searchKeywords":["for","hunted","like","lion","slaughter","again","thou","hast","changed","and","art","terribly","destroying"]},{"verseId":"brenton_job_10_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":17,"text":"renewing against me my torture: and thou hast dealt with me in great anger, and thou hast brought trials upon me.","searchKeywords":["renewing","against","torture","and","thou","hast","dealt","with","great","anger","brought","trials","upon"]},{"verseId":"brenton_job_10_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":18,"text":"Why then didst thou bring me out of the womb? and why did I not die, and no eye see me,","searchKeywords":["why","then","didst","thou","bring","out","the","womb","and","did","not","die","eye","see"]},{"verseId":"brenton_job_10_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":19,"text":"and I become as if I had not been? for why was I not carried from the womb to the grave?","searchKeywords":["and","become","had","not","been","for","why","was","carried","from","the","womb","grave"]},{"verseId":"brenton_job_10_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":20,"text":"Is not the time of my life short? suffer me to rest a little,","searchKeywords":["not","the","time","life","short","suffer","rest","little"]},{"verseId":"brenton_job_10_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":21,"text":"before I go whence I shall not return, to a land of darkness and gloominess;","searchKeywords":["before","whence","shall","not","return","land","darkness","and","gloominess"]},{"verseId":"brenton_job_10_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":10,"verse":22,"text":"to a land of perpetual darkness, where there is no light, neither see the life of mortals.","searchKeywords":["land","perpetual","darkness","where","there","light","neither","see","the","life","mortals"]}]