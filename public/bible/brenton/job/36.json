[{"verseId":"brenton_job_36_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":1,"text":"And Elius further continued, and said,","searchKeywords":["and","elius","further","continued","said"]},{"verseId":"brenton_job_36_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":2,"text":"Wait for me yet a little while, that I may teach thee: for there is yet speech in me.","searchKeywords":["wait","for","yet","little","while","that","may","teach","thee","there","speech"]},{"verseId":"brenton_job_36_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":3,"text":"Having fetched my knowledge from afar, and according to my works,","searchKeywords":["having","fetched","knowledge","from","afar","and","according","works"]},{"verseId":"brenton_job_36_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":4,"text":"I will speak just things truly, and thou shalt not unjustly receive unjust words.","searchKeywords":["will","speak","just","things","truly","and","thou","shalt","not","unjustly","receive","unjust","words"]},{"verseId":"brenton_job_36_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":5,"text":"But know that the Lord will not cast off an innocent man: being mighty in strength of wisdom,","searchKeywords":["but","know","that","the","lord","will","not","cast","off","innocent","man","being","mighty","strength","wisdom"]},{"verseId":"brenton_job_36_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":6,"text":"he will not by any means save alive the ungodly: and he will grant the judgment of the poor.","searchKeywords":["will","not","any","means","save","alive","the","ungodly","and","grant","judgment","poor"]},{"verseId":"brenton_job_36_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":7,"text":"He will not turn away his eyes from the righteous, but with kings on the throne: and he will establish them in triumph, and they shall be exalted.","searchKeywords":["will","not","turn","away","his","eyes","from","the","righteous","but","with","kings","throne","and","establish","them","triumph","they","shall","exalted"]},{"verseId":"brenton_job_36_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":8,"text":"But they that are bound in fetters shall be holden in cords of poverty.","searchKeywords":["but","they","that","are","bound","fetters","shall","holden","cords","poverty"]},{"verseId":"brenton_job_36_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":9,"text":"And he shall recount to them their works, and their transgressions, for such will act with violence.","searchKeywords":["and","shall","recount","them","their","works","transgressions","for","such","will","act","with","violence"]},{"verseId":"brenton_job_36_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":10,"text":"But he will hearken to the righteous: and he has said that they shall turn from unrighteousness.","searchKeywords":["but","will","hearken","the","righteous","and","has","said","that","they","shall","turn","from","unrighteousness"]},{"verseId":"brenton_job_36_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":11,"text":"If they should hear and serve , they shall spend their days in prosperity, and their years in honour.","searchKeywords":["they","should","hear","and","serve","shall","spend","their","days","prosperity","years","honour"]},{"verseId":"brenton_job_36_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":12,"text":"But he preserves not the ungodly; because they are not willing to know the Lord, and because when reproved they were disobedient.","searchKeywords":["but","preserves","not","the","ungodly","because","they","are","willing","know","lord","and","when","reproved","were","disobedient"]},{"verseId":"brenton_job_36_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":13,"text":"And the hypocrites in heart will array wrath ; they will not cry, because he has bound them.","searchKeywords":["and","the","hypocrites","heart","will","array","wrath","they","not","cry","because","has","bound","them"]},{"verseId":"brenton_job_36_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":14,"text":"Therefore let their soul die in youth, and their life be wounded by messengers .","searchKeywords":["therefore","let","their","soul","die","youth","and","life","wounded","messengers"]},{"verseId":"brenton_job_36_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":15,"text":"Because they afflicted the weak and helpless: and he will vindicate the judgment of the meek.","searchKeywords":["because","they","afflicted","the","weak","and","helpless","will","vindicate","judgment","meek"]},{"verseId":"brenton_job_36_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":16,"text":"And he has also enticed thee out of the mouth of the enemy:","searchKeywords":["and","has","also","enticed","thee","out","the","mouth","enemy"]},{"verseId":"brenton_job_36_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":17,"text":"a deep gulf a rushing stream beneath it, and thy table came down full of fatness. Judgment shall not fail from the righteous;","searchKeywords":["deep","gulf","rushing","stream","beneath","and","thy","table","came","down","full","fatness","judgment","shall","not","fail","from","the","righteous"]},{"verseId":"brenton_job_36_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":18,"text":"but there shall be wrath upon the ungodly, by reason of the ungodliness of the bribes which they received for iniquities.","searchKeywords":["but","there","shall","wrath","upon","the","ungodly","reason","ungodliness","bribes","which","they","received","for","iniquities"]},{"verseId":"brenton_job_36_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":19,"text":"Let not mind willingly turn thee aside from the petition of the feeble that are in distress.","searchKeywords":["let","not","mind","willingly","turn","thee","aside","from","the","petition","feeble","that","are","distress"]},{"verseId":"brenton_job_36_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":20,"text":"And draw not forth all the mighty by night, so that the people should go up instead of them.","searchKeywords":["and","draw","not","forth","all","the","mighty","night","that","people","should","instead","them"]},{"verseId":"brenton_job_36_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":21,"text":"But take heed lest thou do that which is wrong: for of this thou hast made choice because of poverty.","searchKeywords":["but","take","heed","lest","thou","that","which","wrong","for","this","hast","made","choice","because","poverty"]},{"verseId":"brenton_job_36_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":22,"text":"Behold, the Mighty One shall prevail by his strength: for who is powerful as he is?","searchKeywords":["behold","the","mighty","one","shall","prevail","his","strength","for","who","powerful"]},{"verseId":"brenton_job_36_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":23,"text":"And who is he that examines his works? or who can say, He has wrought injustice?","searchKeywords":["and","who","that","examines","his","works","can","say","has","wrought","injustice"]},{"verseId":"brenton_job_36_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":24,"text":"Remember that his works are great those which men have attempted.","searchKeywords":["remember","that","his","works","are","great","those","which","men","have","attempted"]},{"verseId":"brenton_job_36_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":25,"text":"Every man has seen in himself, how many mortals are wounded.","searchKeywords":["every","man","has","seen","himself","how","many","mortals","are","wounded"]},{"verseId":"brenton_job_36_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":26,"text":"Behold, the Mighty One is great, and we shall not know : the number of his years is even infinite.","searchKeywords":["behold","the","mighty","one","great","and","shall","not","know","number","his","years","even","infinite"]},{"verseId":"brenton_job_36_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":27,"text":"And the drops of rain are numbered by him, and shall be poured out in rain to form a cloud.","searchKeywords":["and","the","drops","rain","are","numbered","him","shall","poured","out","form","cloud"]},{"verseId":"brenton_job_36_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":28,"text":"The ancient shall flow, and the clouds overshadow innumerable mortals: by all these things thy understanding is not astonished, neither is thy mind disturbed in body.","searchKeywords":["the","ancient","shall","flow","and","clouds","overshadow","innumerable","mortals","all","these","things","thy","understanding","not","astonished","neither","mind","disturbed","body"]},{"verseId":"brenton_job_36_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":29,"text":"the measure of his tabernacle;","searchKeywords":["the","measure","his","tabernacle"]},{"verseId":"brenton_job_36_32","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":32,"text":"hands, and given charge concerning it to the interposing .","searchKeywords":["hands","and","given","charge","concerning","the","interposing"]},{"verseId":"brenton_job_36_33","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":36,"verse":33,"text":"his friend: a portion also for unrighteousness.","searchKeywords":["his","friend","portion","also","for","unrighteousness"]}]