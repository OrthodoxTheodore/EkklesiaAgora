[{"verseId":"brenton_job_27_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":1,"text":"And Job further continued and said in his parable,","searchKeywords":["and","job","further","continued","said","his","parable"]},{"verseId":"brenton_job_27_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":2,"text":"God lives, who has thus judged me; and the Almighty, who has embittered my soul;","searchKeywords":["god","lives","who","has","thus","judged","and","the","almighty","embittered","soul"]},{"verseId":"brenton_job_27_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":3,"text":"verily, while my breath is yet in , and the breath of God which remains to me is in my nostrils,","searchKeywords":["verily","while","breath","yet","and","the","god","which","remains","nostrils"]},{"verseId":"brenton_job_27_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":4,"text":"my lips shall not speak evil words, neither shall my soul meditate unrighteous thoughts.","searchKeywords":["lips","shall","not","speak","evil","words","neither","soul","meditate","unrighteous","thoughts"]},{"verseId":"brenton_job_27_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":5,"text":"Far be it from me that I should justify you till I die; for I will not let go my innocence,","searchKeywords":["far","from","that","should","justify","you","till","die","for","will","not","let","innocence"]},{"verseId":"brenton_job_27_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":6,"text":"but keeping fast to righteousness I will by no means let it go: for I am not conscious to myself of having done any thing amiss.","searchKeywords":["but","keeping","fast","righteousness","will","means","let","for","not","conscious","myself","having","done","any","thing","amiss"]},{"verseId":"brenton_job_27_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":7,"text":"Nay rather, but let mine enemies be as the overthrow of the ungodly, and they that rise up against me, as the destruction of transgressors.","searchKeywords":["nay","rather","but","let","mine","enemies","the","overthrow","ungodly","and","they","that","rise","against","destruction","transgressors"]},{"verseId":"brenton_job_27_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":8,"text":"For what is the hope of the ungodly, that he holds to it? will he indeed trust in the Lord be saved?","searchKeywords":["for","what","the","hope","ungodly","that","holds","will","indeed","trust","lord","saved"]},{"verseId":"brenton_job_27_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":9,"text":"Will God hear his prayer? or, when distress has come upon him,","searchKeywords":["will","god","hear","his","prayer","when","distress","has","come","upon","him"]},{"verseId":"brenton_job_27_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":10,"text":"has he any confidence before him? or will hear him as he calls upon him?","searchKeywords":["has","any","confidence","before","him","will","hear","calls","upon"]},{"verseId":"brenton_job_27_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":11,"text":"Yet now I will tell you what is in the hand of the Lord: I will not lie concerning the things which are with the Almighty.","searchKeywords":["yet","now","will","tell","you","what","the","hand","lord","not","lie","concerning","things","which","are","with","almighty"]},{"verseId":"brenton_job_27_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":12,"text":"Behold, ye all know that ye are adding vanity to vanity.","searchKeywords":["behold","all","know","that","are","adding","vanity"]},{"verseId":"brenton_job_27_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":13,"text":"This is the portion of an ungodly man from the Lord, and the possession of oppressors shall come upon them from the Almighty.","searchKeywords":["this","the","portion","ungodly","man","from","lord","and","possession","oppressors","shall","come","upon","them","almighty"]},{"verseId":"brenton_job_27_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":14,"text":"And if their children be many, they shall be for slaughter: and if they grow up, they shall beg.","searchKeywords":["and","their","children","many","they","shall","for","slaughter","grow","beg"]},{"verseId":"brenton_job_27_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":15,"text":"And they that survive of him shall utterly perish, and no one shall pity their widows.","searchKeywords":["and","they","that","survive","him","shall","utterly","perish","one","pity","their","widows"]},{"verseId":"brenton_job_27_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":16,"text":"Even if he should gather silver as earth, and prepare gold as clay;","searchKeywords":["even","should","gather","silver","earth","and","prepare","gold","clay"]},{"verseId":"brenton_job_27_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":17,"text":"all these things shall the righteous gain, and the truehearted shall possess his wealth.","searchKeywords":["all","these","things","shall","the","righteous","gain","and","truehearted","possess","his","wealth"]},{"verseId":"brenton_job_27_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":18,"text":"And his house is gone like moths, and like a spider's web.","searchKeywords":["and","his","house","gone","like","moths","spider","web"]},{"verseId":"brenton_job_27_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":19,"text":"The rich man shall lie down, and shall not continue: he has opened his eyes, and he is not.","searchKeywords":["the","rich","man","shall","lie","down","and","not","continue","has","opened","his","eyes"]},{"verseId":"brenton_job_27_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":20,"text":"Pains have come upon him as water, and darkness has carried him away by night.","searchKeywords":["pains","have","come","upon","him","water","and","darkness","has","carried","away","night"]},{"verseId":"brenton_job_27_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":21,"text":"And a burning wind shall catch him, and he shall depart, and it shall utterly drive him out of his place.","searchKeywords":["and","burning","wind","shall","catch","him","depart","utterly","drive","out","his","place"]},{"verseId":"brenton_job_27_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":22,"text":"And shall cast upon him, and not spare: he would fain flee out of his hand.","searchKeywords":["and","shall","cast","upon","him","not","spare","would","fain","flee","out","his","hand"]},{"verseId":"brenton_job_27_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":27,"verse":23,"text":"He shall cause to clap their hands against them, and shall hiss him out of his place.","searchKeywords":["shall","cause","clap","their","hands","against","them","and","hiss","him","out","his","place"]}]