[{"verseId":"brenton_job_23_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":1,"text":"Then Job answered and said,","searchKeywords":["then","job","answered","and","said"]},{"verseId":"brenton_job_23_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":2,"text":"Yea, I know that pleading is out of my reach; and his hand has been made heavy upon my groaning.","searchKeywords":["yea","know","that","pleading","out","reach","and","his","hand","has","been","made","heavy","upon","groaning"]},{"verseId":"brenton_job_23_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":3,"text":"Who would then know that I might find him, and come to an end ?","searchKeywords":["who","would","then","know","that","might","find","him","and","come","end"]},{"verseId":"brenton_job_23_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":4,"text":"And I would plead my own cause, and he would fill my mouth with arguments.","searchKeywords":["and","would","plead","own","cause","fill","mouth","with","arguments"]},{"verseId":"brenton_job_23_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":5,"text":"And I would know the remedies which he would speak to me, and I would perceive what he would tell me.","searchKeywords":["and","would","know","the","remedies","which","speak","perceive","what","tell"]},{"verseId":"brenton_job_23_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":6,"text":"Though he should come on me in great strength, then he would not threaten me;","searchKeywords":["though","should","come","great","strength","then","would","not","threaten"]},{"verseId":"brenton_job_23_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":7,"text":"for truth and reproof are from him; and he would bring forth my judgment to an end.","searchKeywords":["for","truth","and","reproof","are","from","him","would","bring","forth","judgment","end"]},{"verseId":"brenton_job_23_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":8,"text":"For if I shall go first, and exist no longer, still what do I know the latter end?","searchKeywords":["for","shall","first","and","exist","longer","still","what","know","the","latter","end"]},{"verseId":"brenton_job_23_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":9,"text":"When he wrought on the left hand, then I observed not: his right hand shall encompass me but I shall not see .","searchKeywords":["when","wrought","the","left","hand","then","observed","not","his","right","shall","encompass","but","see"]},{"verseId":"brenton_job_23_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":10,"text":"For he knows already my way; and he has tried me as gold.","searchKeywords":["for","knows","already","way","and","has","tried","gold"]},{"verseId":"brenton_job_23_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":11,"text":"And I will go forth according to his commandments, for I have kept his ways; and I shall not turn aside from his commandments,","searchKeywords":["and","will","forth","according","his","commandments","for","have","kept","ways","shall","not","turn","aside","from"]},{"verseId":"brenton_job_23_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":12,"text":"neither shall I transgress; but I have hid his words in my bosom.","searchKeywords":["neither","shall","transgress","but","have","hid","his","words","bosom"]},{"verseId":"brenton_job_23_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":13,"text":"And if too he has thus judged, who is he that has contradicted, for he has both willed and done it.","searchKeywords":["and","too","has","thus","judged","who","that","contradicted","for","both","willed","done"]},{"verseId":"brenton_job_23_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":15,"text":"Therefore am I troubled at him; and when I was reproved, I thought of him.","searchKeywords":["therefore","troubled","him","and","when","was","reproved","thought"]},{"verseId":"brenton_job_23_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":23,"verse":17,"text":"before my face.","searchKeywords":["before","face"]}]