[{"verseId":"brenton_job_40_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":1,"text":"And the Lord God answered Job, and said,","searchKeywords":["and","the","lord","god","answered","job","said"]},{"verseId":"brenton_job_40_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":2,"text":"Will pervert judgment with the Mighty One? and he that reproves God, let him return it for answer.","searchKeywords":["will","pervert","judgment","with","the","mighty","one","and","that","reproves","god","let","him","return","for","answer"]},{"verseId":"brenton_job_40_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":3,"text":"And Job answered and said to the Lord,","searchKeywords":["and","job","answered","said","the","lord"]},{"verseId":"brenton_job_40_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":4,"text":"Why do I yet plead? being rebuked even while reproving the Lord: hearing such things, whereas I am nothing: and what shall I answer to these ? I will lay my hand upon my mouth.","searchKeywords":["why","yet","plead","being","rebuked","even","while","reproving","the","lord","hearing","such","things","whereas","nothing","and","what","shall","answer","these","will","lay","hand","upon","mouth"]},{"verseId":"brenton_job_40_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":5,"text":"I have spoken once; but I will not do so a second time.","searchKeywords":["have","spoken","once","but","will","not","second","time"]},{"verseId":"brenton_job_40_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":6,"text":"And the Lord yet again answered and spoke to Job out of the cloud, ,","searchKeywords":["and","the","lord","yet","again","answered","spoke","job","out","cloud"]},{"verseId":"brenton_job_40_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":7,"text":"Nay, gird up now thy loins like a man; and I will ask thee, and do thou answer me.","searchKeywords":["nay","gird","now","thy","loins","like","man","and","will","ask","thee","thou","answer"]},{"verseId":"brenton_job_40_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":8,"text":"Do not set aside my judgment: and dost thou think that I have dealt with thee in any other way, than that thou mightest appear to be righteous?","searchKeywords":["not","set","aside","judgment","and","dost","thou","think","that","have","dealt","with","thee","any","other","way","than","mightest","appear","righteous"]},{"verseId":"brenton_job_40_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":9,"text":"Hast thou an arm like the Lord's? or dost thou thunder with a voice like his?","searchKeywords":["hast","thou","arm","like","the","lord","dost","thunder","with","voice","his"]},{"verseId":"brenton_job_40_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":10,"text":"Assume now a lofty bearing and power; and clothe thyself with glory and honour.","searchKeywords":["assume","now","lofty","bearing","and","power","clothe","thyself","with","glory","honour"]},{"verseId":"brenton_job_40_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":11,"text":"And send forth messengers with wrath; and lay low every haughty one.","searchKeywords":["and","send","forth","messengers","with","wrath","lay","low","every","haughty","one"]},{"verseId":"brenton_job_40_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":12,"text":"Bring down also the proud man; and consume at once the ungodly.","searchKeywords":["bring","down","also","the","proud","man","and","consume","once","ungodly"]},{"verseId":"brenton_job_40_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":13,"text":"And hide them together in the earth; and fill their faces with shame.","searchKeywords":["and","hide","them","together","the","earth","fill","their","faces","with","shame"]},{"verseId":"brenton_job_40_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":14,"text":"will I confess that thy right hand can save .","searchKeywords":["will","confess","that","thy","right","hand","can","save"]},{"verseId":"brenton_job_40_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":15,"text":"But now look at the wild beasts with thee; they eat grass like oxen.","searchKeywords":["but","now","look","the","wild","beasts","with","thee","they","eat","grass","like","oxen"]},{"verseId":"brenton_job_40_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":16,"text":"Behold now, his strength is in his loins, and his force is in the navel of his belly.","searchKeywords":["behold","now","his","strength","loins","and","force","the","navel","belly"]},{"verseId":"brenton_job_40_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":17,"text":"He sets up his tail like a cypress; and his nerves are wrapped together.","searchKeywords":["sets","his","tail","like","cypress","and","nerves","are","wrapped","together"]},{"verseId":"brenton_job_40_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":18,"text":"His sides are sides of brass; and his backbone is cast iron.","searchKeywords":["his","sides","are","brass","and","backbone","cast","iron"]},{"verseId":"brenton_job_40_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":19,"text":"This is the chief of the creation of the Lord; made to be played with by his angels.","searchKeywords":["this","the","chief","creation","lord","made","played","with","his","angels"]},{"verseId":"brenton_job_40_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":20,"text":"And when he has gone up to a steep mountain, he causes joy to the quadrupeds in the deep.","searchKeywords":["and","when","has","gone","steep","mountain","causes","joy","the","quadrupeds","deep"]},{"verseId":"brenton_job_40_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":21,"text":"He lies under trees of every kind, by the papyrus, and reed, and bulrush.","searchKeywords":["lies","under","trees","every","kind","the","papyrus","and","reed","bulrush"]},{"verseId":"brenton_job_40_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":22,"text":"And the great trees make a shadow over him with their branches, and the bushes of the field.","searchKeywords":["and","the","great","trees","make","shadow","over","him","with","their","branches","bushes","field"]},{"verseId":"brenton_job_40_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":23,"text":"If there should be a flood, he will not perceive it; he trusts that Jordan will rush up into his mouth.","searchKeywords":["there","should","flood","will","not","perceive","trusts","that","jordan","rush","into","his","mouth"]},{"verseId":"brenton_job_40_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":24,"text":"shall take him in his sight; shall catch with a cord, and pierce his nose.","searchKeywords":["shall","take","him","his","sight","catch","with","cord","and","pierce","nose"]},{"verseId":"brenton_job_40_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":25,"text":"But wilt thou catch the serpent with a hook, and put a halter about his nose?","searchKeywords":["but","wilt","thou","catch","the","serpent","with","hook","and","put","halter","about","his","nose"]},{"verseId":"brenton_job_40_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":26,"text":"Or wilt thou fasten a ring in his nostril, and bore his lip with a clasp?","searchKeywords":["wilt","thou","fasten","ring","his","nostril","and","bore","lip","with","clasp"]},{"verseId":"brenton_job_40_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":27,"text":"Will he address thee with a petition? softly, with the voice of a suppliant?","searchKeywords":["will","address","thee","with","petition","softly","the","voice","suppliant"]},{"verseId":"brenton_job_40_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":28,"text":"And will he make a covenant with thee? and wilt thou take him for a perpetual servant?","searchKeywords":["and","will","make","covenant","with","thee","wilt","thou","take","him","for","perpetual","servant"]},{"verseId":"brenton_job_40_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":29,"text":"And wilt thou play with him as with a bird? or bind him as a sparrow for a child?","searchKeywords":["and","wilt","thou","play","with","him","bird","bind","sparrow","for","child"]},{"verseId":"brenton_job_40_30","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":30,"text":"And do the nations feed upon him, and the nations of the Phœnicians share him?","searchKeywords":["and","the","nations","feed","upon","him","nicians","share"]},{"verseId":"brenton_job_40_31","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":31,"text":"And all the ships come together would not be able to bear the mere skin of his tail; neither his head in fishing-vessels.","searchKeywords":["and","all","the","ships","come","together","would","not","able","bear","mere","skin","his","tail","neither","head","fishing","vessels"]},{"verseId":"brenton_job_40_32","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":40,"verse":32,"text":"But thou shalt lay thy hand upon him , remembering the war that is waged by his mouth; and let it not be done any more.","searchKeywords":["but","thou","shalt","lay","thy","hand","upon","him","remembering","the","war","that","waged","his","mouth","and","let","not","done","any","more"]}]