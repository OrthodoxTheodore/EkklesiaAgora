[{"verseId":"brenton_job_8_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":1,"text":"Then Baldad the Sauchite answered, and said,","searchKeywords":["then","baldad","the","sauchite","answered","and","said"]},{"verseId":"brenton_job_8_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":2,"text":"How long wilt thou speak these things, the breath of thy mouth abundant in words?","searchKeywords":["how","long","wilt","thou","speak","these","things","the","breath","thy","mouth","abundant","words"]},{"verseId":"brenton_job_8_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":3,"text":"Will the Lord be unjust when he judges; or will he that has made all things pervert justice?","searchKeywords":["will","the","lord","unjust","when","judges","that","has","made","all","things","pervert","justice"]},{"verseId":"brenton_job_8_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":4,"text":"If thy sons have sinned before him, he has cast them away because of their transgression.","searchKeywords":["thy","sons","have","sinned","before","him","has","cast","them","away","because","their","transgression"]},{"verseId":"brenton_job_8_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":5,"text":"But be thou early in prayer to the Lord Almighty.","searchKeywords":["but","thou","early","prayer","the","lord","almighty"]},{"verseId":"brenton_job_8_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":6,"text":"If thou art pure and true, he will hearken to thy supplication, and will restore to thee the habitation of righteousness.","searchKeywords":["thou","art","pure","and","true","will","hearken","thy","supplication","restore","thee","the","habitation","righteousness"]},{"verseId":"brenton_job_8_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":7,"text":"Though then thy beginning should be small, yet thy end should be unspeakably great.","searchKeywords":["though","then","thy","beginning","should","small","yet","end","unspeakably","great"]},{"verseId":"brenton_job_8_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":8,"text":"For ask of the former generation, and search diligently among the race of fathers:","searchKeywords":["for","ask","the","former","generation","and","search","diligently","among","race","fathers"]},{"verseId":"brenton_job_8_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":9,"text":"(for we are of yesterday, and know nothing; for our life upon the earth is a shadow:)","searchKeywords":["for","are","yesterday","and","know","nothing","our","life","upon","the","earth","shadow"]},{"verseId":"brenton_job_8_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":10,"text":"shall not these teach thee, and report , and bring out words from heart?","searchKeywords":["shall","not","these","teach","thee","and","report","bring","out","words","from","heart"]},{"verseId":"brenton_job_8_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":11,"text":"Does the rush flourish without water, or shall the flag grow up without moisture?","searchKeywords":["does","the","rush","flourish","without","water","shall","flag","grow","moisture"]},{"verseId":"brenton_job_8_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":12,"text":"When it is yet on the root, and it has not been cut down, does not any herb wither before it has received moisture?","searchKeywords":["when","yet","the","root","and","has","not","been","cut","down","does","any","herb","wither","before","received","moisture"]},{"verseId":"brenton_job_8_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":13,"text":"Thus then shall be the end of all that forget the Lord: for the hope of the ungodly shall perish.","searchKeywords":["thus","then","shall","the","end","all","that","forget","lord","for","hope","ungodly","perish"]},{"verseId":"brenton_job_8_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":14,"text":"For his house shall be without inhabitants, and his tent shall prove a spider's web.","searchKeywords":["for","his","house","shall","without","inhabitants","and","tent","prove","spider","web"]},{"verseId":"brenton_job_8_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":15,"text":"If he should prop up his house, it shall not stand: and when he has taken hold of it, it shall not remain.","searchKeywords":["should","prop","his","house","shall","not","stand","and","when","has","taken","hold","remain"]},{"verseId":"brenton_job_8_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":16,"text":"For it is moist under the sun, and his branch shall come forth out of his dung-heap.","searchKeywords":["for","moist","under","the","sun","and","his","branch","shall","come","forth","out","dung","heap"]},{"verseId":"brenton_job_8_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":17,"text":"He lies down upon a gathering of stones, and shall live in the midst of flints.","searchKeywords":["lies","down","upon","gathering","stones","and","shall","live","the","midst","flints"]},{"verseId":"brenton_job_8_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":18,"text":"If should destroy , his place shall deny him. Hast thou not seen such things,","searchKeywords":["should","destroy","his","place","shall","deny","him","hast","thou","not","seen","such","things"]},{"verseId":"brenton_job_8_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":19,"text":"that such is the overthrow of the ungodly? and out of the earth another shall grow.","searchKeywords":["that","such","the","overthrow","ungodly","and","out","earth","another","shall","grow"]},{"verseId":"brenton_job_8_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":20,"text":"For the Lord will by no means reject the harmless man; but he will not receive any gift of the ungodly.","searchKeywords":["for","the","lord","will","means","reject","harmless","man","but","not","receive","any","gift","ungodly"]},{"verseId":"brenton_job_8_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":21,"text":"But he will fill with laughter the mouth of the sincere, and their lips with thanksgiving.","searchKeywords":["but","will","fill","with","laughter","the","mouth","sincere","and","their","lips","thanksgiving"]},{"verseId":"brenton_job_8_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":8,"verse":22,"text":"But their adversaries shall clothe themselves with shame; and the habitation of the ungodly shall perish.","searchKeywords":["but","their","adversaries","shall","clothe","themselves","with","shame","and","the","habitation","ungodly","perish"]}]