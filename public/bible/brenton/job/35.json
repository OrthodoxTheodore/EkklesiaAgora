rseId":"brenton_job_35_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":35,"verse":8,"text":"Thy ungodliness a man who is like to thee; or thy righteousness a son of man.","searchKeywords":["thy","ungodliness","man","who","like","thee","righteousness","son"]},{"verseId":"brenton_job_35_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":35,"verse":9,"text":"They that are oppressed of a multitude will be ready to cry out; they will call for help because of the arm of many.","searchKeywords":["they","that","are","oppressed","multitude","will","ready","cry","out","call","for","help","because","the","arm","many"]},{"verseId":"brenton_job_35_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":35,"verse":10,"text":"But none said, Where is God that made me, who appoints the night-watches;","searchKeywords":["but","none","said","where","god","that","made","who","appoints","the","night","watches"]},{"verseId":"brenton_job_35_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":35,"verse":11,"text":"who makes me to differ from the four-footed beasts of the earth, and from the birds of the sky?","searchKeywords":["who","makes","differ","from","the","four","footed","beasts","earth","and","birds","sky"]},{"verseId":"brenton_job_35_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":35,"verse":12,"text":"There they shall cry, and none shall hearken, even because of the insolence of wicked men.","searchKeywords":["there","they","shall","cry","and","none","hearken","even","because","the","insolence","wicked","men"]},{"verseId":"brenton_job_35_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":35,"verse":13,"text":"For the Lord desires not to look on error, for he is the Almighty One.","searchKeywords":["for","the","lord","desires","not","look","error","almighty","one"]},{"verseId":"brenton_job_35_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":35,"verse":14,"text":"He beholds them that perform lawless deeds, and he will save me: and do thou plead before him, if thou canst praise him, as it is even now.","searchKeywords":["beholds","them","that","perform","lawless","deeds","and","will","save","thou","plead","before","him","canst","praise","even","now"]},{"verseId":"brenton_job_35_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":35,"verse":15,"text":"For he is not regarding his wrath, nor has he noticed severely any trespass.","searchKeywords":["for","not","regarding","his","wrath","nor","has","noticed","severely","any","trespass"]},{"verseId":"brenton_job_35_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":35,"verse":16,"text":"Yet Job vainly opens his mouth, in ignorance he multiplies words.","searchKeywords":["yet","job","vainly","opens","his","mouth","ignorance","multiplies","words"]}]