[{"verseId":"brenton_job_9_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":1,"text":"Then Job answered and said,","searchKeywords":["then","job","answered","and","said"]},{"verseId":"brenton_job_9_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":2,"text":"I know of a truth that it is so: for how shall a mortal man be just before the Lord?","searchKeywords":["know","truth","that","for","how","shall","mortal","man","just","before","the","lord"]},{"verseId":"brenton_job_9_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":3,"text":"For if he would enter into judgment with him, would not hearken to him, so that he should answer to one of his charges of a thousand.","searchKeywords":["for","would","enter","into","judgment","with","him","not","hearken","that","should","answer","one","his","charges","thousand"]},{"verseId":"brenton_job_9_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":4,"text":"For he is wise in mind, and mighty, and great: who has hardened himself against him and endured?","searchKeywords":["for","wise","mind","and","mighty","great","who","has","hardened","himself","against","him","endured"]},{"verseId":"brenton_job_9_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":5,"text":"Who wears out the mountains, and know it not: who overturns them in anger.","searchKeywords":["who","wears","out","the","mountains","and","know","not","overturns","them","anger"]},{"verseId":"brenton_job_9_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":6,"text":"Who shakes the under heaven from its foundations, and its pillars totter.","searchKeywords":["who","shakes","the","under","heaven","from","its","foundations","and","pillars","totter"]},{"verseId":"brenton_job_9_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":7,"text":"Who commands the sun, and it rises not; and he seals up the stars.","searchKeywords":["who","commands","the","sun","and","rises","not","seals","stars"]},{"verseId":"brenton_job_9_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":8,"text":"Who alone has stretched out the heavens, and walks on the sea as on firm ground.","searchKeywords":["who","alone","has","stretched","out","the","heavens","and","walks","sea","firm","ground"]},{"verseId":"brenton_job_9_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":9,"text":"Who makes Pleias, and Hesperus, and Arcturus, and the chambers of the south.","searchKeywords":["who","makes","pleias","and","hesperus","arcturus","the","chambers","south"]},{"verseId":"brenton_job_9_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":10,"text":"Who does great and unsearchable things; glorious also and excellent things, innumerable.","searchKeywords":["who","does","great","and","unsearchable","things","glorious","also","excellent","innumerable"]},{"verseId":"brenton_job_9_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":11,"text":"If ever he should go beyond me, I shall not see him: if he should pass by me, neither thus have I known .","searchKeywords":["ever","should","beyond","shall","not","see","him","pass","neither","thus","have","known"]},{"verseId":"brenton_job_9_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":12,"text":"If he would take away, who shall turn him back? or who shall say to him, What hast thou done?","searchKeywords":["would","take","away","who","shall","turn","him","back","say","what","hast","thou","done"]},{"verseId":"brenton_job_9_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":13,"text":"For he has turned away anger, the whales under heaven have stooped under him.","searchKeywords":["for","has","turned","away","anger","the","whales","under","heaven","have","stooped","him"]},{"verseId":"brenton_job_9_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":14,"text":"Oh then that he would hearken to me, or judge my cause.","searchKeywords":["then","that","would","hearken","judge","cause"]},{"verseId":"brenton_job_9_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":15,"text":"For though I be righteous, he will not hearken to me: I will intreat his judgment.","searchKeywords":["for","though","righteous","will","not","hearken","intreat","his","judgment"]},{"verseId":"brenton_job_9_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":16,"text":"And if I should call and he should not hearken, I cannot believe that he has listened to my voice.","searchKeywords":["and","should","call","not","hearken","cannot","believe","that","has","listened","voice"]},{"verseId":"brenton_job_9_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":17,"text":"Let him not crush me with a dark storm: but he has made my bruises many without cause.","searchKeywords":["let","him","not","crush","with","dark","storm","but","has","made","bruises","many","without","cause"]},{"verseId":"brenton_job_9_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":18,"text":"For he suffers me not to take breath, but he has filled me with bitterness.","searchKeywords":["for","suffers","not","take","breath","but","has","filled","with","bitterness"]},{"verseId":"brenton_job_9_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":19,"text":"For indeed he is strong in power: who then shall resist his judgment?","searchKeywords":["for","indeed","strong","power","who","then","shall","resist","his","judgment"]},{"verseId":"brenton_job_9_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":20,"text":"For though I should seem righteous, my mouth will be profane: and though I should seem blameless, I shall be proved perverse.","searchKeywords":["for","though","should","seem","righteous","mouth","will","profane","and","blameless","shall","proved","perverse"]},{"verseId":"brenton_job_9_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":21,"text":"For even if I have sinned, I know it not my soul: but my life is taken away.","searchKeywords":["for","even","have","sinned","know","not","soul","but","life","taken","away"]},{"verseId":"brenton_job_9_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":22,"text":"Wherefore I said, Wrath slays the great and mighty man.","searchKeywords":["wherefore","said","wrath","slays","the","great","and","mighty","man"]},{"verseId":"brenton_job_9_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":23,"text":"For the worthless die, but the righteous are laughed to scorn.","searchKeywords":["for","the","worthless","die","but","righteous","are","laughed","scorn"]},{"verseId":"brenton_job_9_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":24,"text":"For they are delivered into the hands of the unrighteous : he covers the faces of the judges : but if it be not he, who is it?","searchKeywords":["for","they","are","delivered","into","the","hands","unrighteous","covers","faces","judges","but","not","who"]},{"verseId":"brenton_job_9_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":25,"text":"But my life is swifter than a post: have fled away, and they knew it not.","searchKeywords":["but","life","swifter","than","post","have","fled","away","and","they","knew","not"]},{"verseId":"brenton_job_9_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":26,"text":"Or again, is there a trace of path by ships? or is there one of the flying eagle as it seeks prey?","searchKeywords":["again","there","trace","path","ships","one","the","flying","eagle","seeks","prey"]},{"verseId":"brenton_job_9_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":27,"text":"And if I should say, I will forget to speak, I will bow down my face and groan;","searchKeywords":["and","should","say","will","forget","speak","bow","down","face","groan"]},{"verseId":"brenton_job_9_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":28,"text":"I quake in all my limbs, for I know that thou wilt not leave me alone innocent.","searchKeywords":["quake","all","limbs","for","know","that","thou","wilt","not","leave","alone","innocent"]},{"verseId":"brenton_job_9_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":29,"text":"But since I am ungodly, why have I not died?","searchKeywords":["but","since","ungodly","why","have","not","died"]},{"verseId":"brenton_job_9_30","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":30,"text":"For if I should wash myself with snow, and purge myself with pure hands,","searchKeywords":["for","should","wash","myself","with","snow","and","purge","pure","hands"]},{"verseId":"brenton_job_9_31","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":31,"text":"thou hadst thoroughly plunged me in filth, and my garment had abhorred me.","searchKeywords":["thou","hadst","thoroughly","plunged","filth","and","garment","had","abhorred"]},{"verseId":"brenton_job_9_32","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":32,"text":"For thou art not man like me, with whom I could contend, that we might come together to judgment.","searchKeywords":["for","thou","art","not","man","like","with","whom","could","contend","that","might","come","together","judgment"]},{"verseId":"brenton_job_9_33","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":33,"text":"Would that our mediator were , and a reprover, and one who should hear between both.","searchKeywords":["would","that","our","mediator","were","and","reprover","one","who","should","hear","between","both"]},{"verseId":"brenton_job_9_34","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":34,"text":"Let him remove rod from me, and let not his fear terrify me:","searchKeywords":["let","him","remove","rod","from","and","not","his","fear","terrify"]},{"verseId":"brenton_job_9_35","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":9,"verse":35,"text":"so shall I not be afraid, but I will speak: for I am not thus conscious .","searchKeywords":["shall","not","afraid","but","will","speak","for","thus","conscious"]}]