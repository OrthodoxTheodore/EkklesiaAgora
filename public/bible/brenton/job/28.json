[{"verseId":"brenton_job_28_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":1,"text":"For there is a place for the silver, whence it comes, and a place for the gold, whence it is refined.","searchKeywords":["for","there","place","the","silver","whence","comes","and","gold","refined"]},{"verseId":"brenton_job_28_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":2,"text":"For iron comes out of the earth, and brass is hewn out like stone.","searchKeywords":["for","iron","comes","out","the","earth","and","brass","hewn","like","stone"]},{"verseId":"brenton_job_28_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":3,"text":"He has set a bound to darkness, and he searches out every limit: a stone darkness, and the shadow of death.","searchKeywords":["has","set","bound","darkness","and","searches","out","every","limit","stone","the","shadow","death"]},{"verseId":"brenton_job_28_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":4,"text":"There is a cutting off of the torrent by reason of dust: so they that forget the right way are weakened; they are removed from men.","searchKeywords":["there","cutting","off","the","torrent","reason","dust","they","that","forget","right","way","are","weakened","removed","from","men"]},{"verseId":"brenton_job_28_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":5,"text":"the earth, out of it shall come bread: under it has been turned up as it were fire.","searchKeywords":["the","earth","out","shall","come","bread","under","has","been","turned","were","fire"]},{"verseId":"brenton_job_28_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":6,"text":"Her stones are the place of the sapphire: and dust man with gold.","searchKeywords":["her","stones","are","the","place","sapphire","and","dust","man","with","gold"]},{"verseId":"brenton_job_28_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":7,"text":"a path, the fowl has not known it, neither has the eye of the vulture seen it:","searchKeywords":["path","the","fowl","has","not","known","neither","eye","vulture","seen"]},{"verseId":"brenton_job_28_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":8,"text":"neither have the sons of the proud trodden it, a lion has not passed upon it.","searchKeywords":["neither","have","the","sons","proud","trodden","lion","has","not","passed","upon"]},{"verseId":"brenton_job_28_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":9,"text":"He has stretched forth his hand on the sharp , and turned up mountains by the roots:","searchKeywords":["has","stretched","forth","his","hand","the","sharp","and","turned","mountains","roots"]},{"verseId":"brenton_job_28_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":10,"text":"and he has interrupted the whirlpools of rivers, and mine eye has seen every precious thing.","searchKeywords":["and","has","interrupted","the","whirlpools","rivers","mine","eye","seen","every","precious","thing"]},{"verseId":"brenton_job_28_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":11,"text":"And he has laid bare the depths of rivers, and has brought his power to light.","searchKeywords":["and","has","laid","bare","the","depths","rivers","brought","his","power","light"]},{"verseId":"brenton_job_28_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":12,"text":"But whence has wisdom been discovered? and what is the place of knowledge?","searchKeywords":["but","whence","has","wisdom","been","discovered","and","what","the","place","knowledge"]},{"verseId":"brenton_job_28_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":13,"text":"A mortal has not known its way, neither indeed has it been discovered among men.","searchKeywords":["mortal","has","not","known","its","way","neither","indeed","been","discovered","among","men"]},{"verseId":"brenton_job_28_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":14,"text":"The depth said, It is not in me: and the sea said, It is not with me.","searchKeywords":["the","depth","said","not","and","sea","with"]},{"verseId":"brenton_job_28_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":15,"text":"One shall not give fine gold instead of it, neither shall silver be weighed in exchange for it.","searchKeywords":["one","shall","not","give","fine","gold","instead","neither","silver","weighed","exchange","for"]},{"verseId":"brenton_job_28_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":16,"text":"Neither shall it be compared with gold of Sophir, with the precious onyx and sapphire.","searchKeywords":["neither","shall","compared","with","gold","sophir","the","precious","onyx","and","sapphire"]},{"verseId":"brenton_job_28_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":17,"text":"Gold and crystal shall not be equalled to it, neither shall vessels of gold be its exchange.","searchKeywords":["gold","and","crystal","shall","not","equalled","neither","vessels","its","exchange"]},{"verseId":"brenton_job_28_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":18,"text":"Coral and fine pearl shall not be mentioned: but do thou esteem wisdom above the most precious things.","searchKeywords":["coral","and","fine","pearl","shall","not","mentioned","but","thou","esteem","wisdom","above","the","most","precious","things"]},{"verseId":"brenton_job_28_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":19,"text":"The topaz of Ethiopia shall not be equalled to it; it shall not be compared with pure gold.","searchKeywords":["the","topaz","ethiopia","shall","not","equalled","compared","with","pure","gold"]},{"verseId":"brenton_job_28_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":20,"text":"Whence then is wisdom found? and of what kind is the place of understanding?","searchKeywords":["whence","then","wisdom","found","and","what","kind","the","place","understanding"]},{"verseId":"brenton_job_28_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":21,"text":"It has escaped the notice of every man, and has been hidden from the birds of the sky.","searchKeywords":["has","escaped","the","notice","every","man","and","been","hidden","from","birds","sky"]},{"verseId":"brenton_job_28_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":22,"text":"Destruction and Death said, We have heard the report of it.","searchKeywords":["destruction","and","death","said","have","heard","the","report"]},{"verseId":"brenton_job_28_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":23,"text":"God has well ordered the way of it, and he knows the place of it.","searchKeywords":["god","has","well","ordered","the","way","and","knows","place"]},{"verseId":"brenton_job_28_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":24,"text":"For he surveys the whole under heaven, knowing the things in the earth:","searchKeywords":["for","surveys","the","whole","under","heaven","knowing","things","earth"]},{"verseId":"brenton_job_28_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":25,"text":"all that he has made; the weight of the winds, the measures of the water.","searchKeywords":["all","that","has","made","the","weight","winds","measures","water"]},{"verseId":"brenton_job_28_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":26,"text":"When he made , thus he saw and numbered them, and made a way for the pealing of the thunder.","searchKeywords":["when","made","thus","saw","and","numbered","them","way","for","the","pealing","thunder"]},{"verseId":"brenton_job_28_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":27,"text":"Then he saw it, and declared it: he prepared it traced it out.","searchKeywords":["then","saw","and","declared","prepared","traced","out"]},{"verseId":"brenton_job_28_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":28,"verse":28,"text":"And he said to man, Behold, godliness is wisdom; and to abstain from evil is understanding.","searchKeywords":["and","said","man","behold","godliness","wisdom","abstain","from","evil","understanding"]}]