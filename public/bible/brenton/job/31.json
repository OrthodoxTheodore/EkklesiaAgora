[{"verseId":"brenton_job_31_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":1,"text":"I made a covenant with mine eyes, and I will not think upon a virgin.","searchKeywords":["made","covenant","with","mine","eyes","and","will","not","think","upon","virgin"]},{"verseId":"brenton_job_31_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":2,"text":"Now what portion has God given from above? and is there an inheritance of the Mighty One from the highest?","searchKeywords":["now","what","portion","has","god","given","from","above","and","there","inheritance","the","mighty","one","highest"]},{"verseId":"brenton_job_31_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":3,"text":"Alas! destruction to the unrighteous, and rejection to them that do iniquity.","searchKeywords":["alas","destruction","the","unrighteous","and","rejection","them","that","iniquity"]},{"verseId":"brenton_job_31_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":4,"text":"Will he not see my way, and number all my steps?","searchKeywords":["will","not","see","way","and","number","all","steps"]},{"verseId":"brenton_job_31_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":5,"text":"But if I had gone with scorners, and if too my foot has hasted to deceit:","searchKeywords":["but","had","gone","with","scorners","and","too","foot","has","hasted","deceit"]},{"verseId":"brenton_job_31_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":6,"text":"(for I am weighed in a just balance, and the Lord knows my innocence:)","searchKeywords":["for","weighed","just","balance","and","the","lord","knows","innocence"]},{"verseId":"brenton_job_31_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":7,"text":"if my foot has turned aside out of the way, or if mine heart has followed mine eye, and if too I have touched gifts with my hands;","searchKeywords":["foot","has","turned","aside","out","the","way","mine","heart","followed","eye","and","too","have","touched","gifts","with","hands"]},{"verseId":"brenton_job_31_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":8,"text":"then let me sow, and let others eat; and let me be uprooted on the earth.","searchKeywords":["then","let","sow","and","others","eat","uprooted","the","earth"]},{"verseId":"brenton_job_31_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":9,"text":"If my heart has gone forth after another man's wife, and if I laid wait at her doors;","searchKeywords":["heart","has","gone","forth","after","another","man","wife","and","laid","wait","her","doors"]},{"verseId":"brenton_job_31_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":10,"text":"then let my wife also please another, and let my children be brought low.","searchKeywords":["then","let","wife","also","please","another","and","children","brought","low"]},{"verseId":"brenton_job_31_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":11,"text":"For the rage of anger is not to be controlled, of defiling man's wife.","searchKeywords":["for","the","rage","anger","not","controlled","defiling","man","wife"]},{"verseId":"brenton_job_31_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":12,"text":"For it is a fire burning on every side, and whomsoever it attacks, it utterly destroys.","searchKeywords":["for","fire","burning","every","side","and","whomsoever","attacks","utterly","destroys"]},{"verseId":"brenton_job_31_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":13,"text":"And if too I despised the judgment of my servant or handmaid, when they pleaded with me;","searchKeywords":["and","too","despised","the","judgment","servant","handmaid","when","they","pleaded","with"]},{"verseId":"brenton_job_31_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":14,"text":"what then shall I do if the Lord should try me? and if also he should at all visit me, can I make an answer?","searchKeywords":["what","then","shall","the","lord","should","try","and","also","all","visit","can","make","answer"]},{"verseId":"brenton_job_31_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":15,"text":"Were not they too formed as I also was formed in the womb? yea, we were formed in the same womb.","searchKeywords":["were","not","they","too","formed","also","was","the","womb","yea","same"]},{"verseId":"brenton_job_31_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":16,"text":"But the helpless missed not whatever need they had, and I did not cause the eye of the widow to fail.","searchKeywords":["but","the","helpless","missed","not","whatever","need","they","had","and","did","cause","eye","widow","fail"]},{"verseId":"brenton_job_31_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":17,"text":"And if too I ate my morsel alone, and did not impart to the orphan;","searchKeywords":["and","too","ate","morsel","alone","did","not","impart","the","orphan"]},{"verseId":"brenton_job_31_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":18,"text":"(for I nourished as a father from my youth, and guided from my mother's womb.)","searchKeywords":["for","nourished","father","from","youth","and","guided","mother","womb"]},{"verseId":"brenton_job_31_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":19,"text":"And if too I overlooked the naked as he was perishing, and did not clothe him;","searchKeywords":["and","too","overlooked","the","naked","was","perishing","did","not","clothe","him"]},{"verseId":"brenton_job_31_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":20,"text":"and if the poor did not bless me, and their shoulders were warmed with the fleece of my lambs;","searchKeywords":["and","the","poor","did","not","bless","their","shoulders","were","warmed","with","fleece","lambs"]},{"verseId":"brenton_job_31_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":21,"text":"if I lifted my hand against an orphan, trusting that my strength was far superior :","searchKeywords":["lifted","hand","against","orphan","trusting","that","strength","was","far","superior"]},{"verseId":"brenton_job_31_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":22,"text":"let then my shoulder start from the blade-bone, and my arm be crushed off from the elbow.","searchKeywords":["let","then","shoulder","start","from","the","blade","bone","and","arm","crushed","off","elbow"]},{"verseId":"brenton_job_31_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":23,"text":"For the fear of the Lord constrained me, and I cannot bear up by reason of his burden.","searchKeywords":["for","the","fear","lord","constrained","and","cannot","bear","reason","his","burden"]},{"verseId":"brenton_job_31_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":24,"text":"If I made gold my treasure, and if too I trusted the precious stone;","searchKeywords":["made","gold","treasure","and","too","trusted","the","precious","stone"]},{"verseId":"brenton_job_31_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":25,"text":"and if too I rejoiced when my wealth was abundant, and if too I laid my hand on innumerable :","searchKeywords":["and","too","rejoiced","when","wealth","was","abundant","laid","hand","innumerable"]},{"verseId":"brenton_job_31_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":26,"text":"(do we not see the shining sun eclipsed, and the moon waning? for they have not :)","searchKeywords":["not","see","the","shining","sun","eclipsed","and","moon","waning","for","they","have"]},{"verseId":"brenton_job_31_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":27,"text":"and if my heart was secretly deceived, and if I have laid my hand upon my mouth and kissed it:","searchKeywords":["and","heart","was","secretly","deceived","have","laid","hand","upon","mouth","kissed"]},{"verseId":"brenton_job_31_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":28,"text":"let this also then be reckoned to me as the greatest iniquity: for I have lied against the Lord Most High.","searchKeywords":["let","this","also","then","reckoned","the","greatest","iniquity","for","have","lied","against","lord","most","high"]},{"verseId":"brenton_job_31_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":29,"text":"And if too I was glad at the fall of mine enemies, and mine heart said, Aha!","searchKeywords":["and","too","was","glad","the","fall","mine","enemies","heart","said","aha"]},{"verseId":"brenton_job_31_30","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":30,"text":"let then mine ear hear my curse, and let me be a by-word among my people in my affliction.","searchKeywords":["let","then","mine","ear","hear","curse","and","word","among","people","affliction"]},{"verseId":"brenton_job_31_31","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":31,"text":"And if too my handmaids have often said, Oh that we might be satisfied with his flesh; (whereas I was very kind:","searchKeywords":["and","too","handmaids","have","often","said","that","might","satisfied","with","his","flesh","whereas","was","very","kind"]},{"verseId":"brenton_job_31_32","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":32,"text":"for the stranger did not lodge without, and my door was opened to every one that came:)","searchKeywords":["for","the","stranger","did","not","lodge","without","and","door","was","opened","every","one","that","came"]},{"verseId":"brenton_job_31_33","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":33,"text":"or if too having sinned unintentionally, I hid my sin;","searchKeywords":["too","having","sinned","unintentionally","hid","sin"]},{"verseId":"brenton_job_31_34","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":34,"text":"(for I did not stand in awe of a great multitude, so as not to declare boldly before them:) and if too I permitted a poor man to go out of my door with an empty bosom:","searchKeywords":["for","did","not","stand","awe","great","multitude","declare","boldly","before","them","and","too","permitted","poor","man","out","door","with","empty","bosom"]},{"verseId":"brenton_job_31_35","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":35,"text":"(Oh that I had a hearer,) and if I had not feared the hand of the Lord; and the written charge which I had against any one,","searchKeywords":["that","had","hearer","and","not","feared","the","hand","lord","written","charge","which","against","any","one"]},{"verseId":"brenton_job_31_36","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":36,"text":"I would place as a chaplet on my shoulders, and read it.","searchKeywords":["would","place","chaplet","shoulders","and","read"]},{"verseId":"brenton_job_31_37","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":37,"text":"And if I did not read it and return it, having taken nothing from the debtor:","searchKeywords":["and","did","not","read","return","having","taken","nothing","from","the","debtor"]},{"verseId":"brenton_job_31_38","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":38,"text":"If at any time the land groaned against me, and if its furrows mourned together;","searchKeywords":["any","time","the","land","groaned","against","and","its","furrows","mourned","together"]},{"verseId":"brenton_job_31_39","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":39,"text":"and if I ate its strength alone without price, and if too I grieved the heart of the owner of the soil, by taking from :","searchKeywords":["and","ate","its","strength","alone","without","price","too","grieved","the","heart","owner","soil","taking","from"]},{"verseId":"brenton_job_31_40","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":31,"verse":40,"text":"then let the nettle come up to me instead of wheat, and a bramble instead of barley. And Job ceased speaking.","searchKeywords":["then","let","the","nettle","come","instead","wheat","and","bramble","barley","job","ceased","speaking"]}]