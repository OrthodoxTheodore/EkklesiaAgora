[{"verseId":"brenton_job_39_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":1,"text":"if thou knowest the time of the bringing forth of the wild goats of the rock, and thou hast marked the calving of the hinds:","searchKeywords":["thou","knowest","the","time","bringing","forth","wild","goats","rock","and","hast","marked","calving","hinds"]},{"verseId":"brenton_job_39_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":2,"text":"and thou hast numbered the full months of their being with young, and thou hast relieved their pangs:","searchKeywords":["and","thou","hast","numbered","the","full","months","their","being","with","young","relieved","pangs"]},{"verseId":"brenton_job_39_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":3,"text":"and hast reared their young without fear; and wilt thou loosen their pangs?","searchKeywords":["and","hast","reared","their","young","without","fear","wilt","thou","loosen","pangs"]},{"verseId":"brenton_job_39_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":4,"text":"Their young will break forth; they will be multiplied with offspring: will go forth, and will not return to them.","searchKeywords":["their","young","will","break","forth","they","multiplied","with","offspring","and","not","return","them"]},{"verseId":"brenton_job_39_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":5,"text":"And who is he that sent forth the wild ass free? and who loosed his bands?","searchKeywords":["and","who","that","sent","forth","the","wild","ass","free","loosed","his","bands"]},{"verseId":"brenton_job_39_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":6,"text":"whereas I made his habitation the wilderness, and the salt land his coverts.","searchKeywords":["whereas","made","his","habitation","the","wilderness","and","salt","land","coverts"]},{"verseId":"brenton_job_39_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":7,"text":"He laughs to scorn the multitude of the city, and hears not the chiding of the tax-gatherer.","searchKeywords":["laughs","scorn","the","multitude","city","and","hears","not","chiding","tax","gatherer"]},{"verseId":"brenton_job_39_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":8,"text":"He will survey the mountains his pasture, and he seeks after every green thing.","searchKeywords":["will","survey","the","mountains","his","pasture","and","seeks","after","every","green","thing"]},{"verseId":"brenton_job_39_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":9,"text":"And will the unicorn be willing to serve thee, or to lie down at thy manger?","searchKeywords":["and","will","the","unicorn","willing","serve","thee","lie","down","thy","manger"]},{"verseId":"brenton_job_39_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":10,"text":"And wilt thou bind his yoke with thongs, or will he plough furrows for thee in the plain?","searchKeywords":["and","wilt","thou","bind","his","yoke","with","thongs","will","plough","furrows","for","thee","the","plain"]},{"verseId":"brenton_job_39_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":11,"text":"And dost thou trust him, because his strength is great? and wilt thou commit thy works to him?","searchKeywords":["and","dost","thou","trust","him","because","his","strength","great","wilt","commit","thy","works"]},{"verseId":"brenton_job_39_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":12,"text":"And wilt thou believe that he will return to thee thy seed, and bring in thy threshing-floor?","searchKeywords":["and","wilt","thou","believe","that","will","return","thee","thy","seed","bring","threshing","floor"]},{"verseId":"brenton_job_39_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":13,"text":"The peacock has a beautiful wing: if the stork and the ostrich conceive, ,","searchKeywords":["the","peacock","has","beautiful","wing","stork","and","ostrich","conceive"]},{"verseId":"brenton_job_39_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":14,"text":"for will leave her eggs in the ground, and warm them on the dust,","searchKeywords":["for","will","leave","her","eggs","the","ground","and","warm","them","dust"]},{"verseId":"brenton_job_39_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":15,"text":"and has forgotten that the foot will scatter them, and the wild beasts of the field trample them.","searchKeywords":["and","has","forgotten","that","the","foot","will","scatter","them","wild","beasts","field","trample"]},{"verseId":"brenton_job_39_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":16,"text":"She has hardened against her young ones, as though not herself: she labours in vain without fear.","searchKeywords":["she","has","hardened","against","her","young","ones","though","not","herself","labours","vain","without","fear"]},{"verseId":"brenton_job_39_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":17,"text":"For God has withholden wisdom from her, and not given her a portion in understanding.","searchKeywords":["for","god","has","withholden","wisdom","from","her","and","not","given","portion","understanding"]},{"verseId":"brenton_job_39_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":18,"text":"In her season she will lift herself on high; she will scorn the horse and his rider.","searchKeywords":["her","season","she","will","lift","herself","high","scorn","the","horse","and","his","rider"]},{"verseId":"brenton_job_39_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":19,"text":"Hast thou invested the horse with strength, and clothed his neck with terror?","searchKeywords":["hast","thou","invested","the","horse","with","strength","and","clothed","his","neck","terror"]},{"verseId":"brenton_job_39_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":20,"text":"And hast thou clad him in perfect armour, and made his breast glorious with courage?","searchKeywords":["and","hast","thou","clad","him","perfect","armour","made","his","breast","glorious","with","courage"]},{"verseId":"brenton_job_39_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":21,"text":"He paws exulting in the plain, and goes forth in strength into the plain.","searchKeywords":["paws","exulting","the","plain","and","goes","forth","strength","into"]},{"verseId":"brenton_job_39_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":22,"text":"He laughs to scorn a king as he meets him, and will by no means turn back from the sword.","searchKeywords":["laughs","scorn","king","meets","him","and","will","means","turn","back","from","the","sword"]},{"verseId":"brenton_job_39_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":23,"text":"The bow and sword resound against him; and rage will swallow up the ground:","searchKeywords":["the","bow","and","sword","resound","against","him","rage","will","swallow","ground"]},{"verseId":"brenton_job_39_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":24,"text":"and he will not believe until the trumpet sounds.","searchKeywords":["and","will","not","believe","until","the","trumpet","sounds"]},{"verseId":"brenton_job_39_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":25,"text":"And when the trumpet sounds, he says, Aha! and afar off he smells the war with prancing and neighing.","searchKeywords":["and","when","the","trumpet","sounds","says","aha","afar","off","smells","war","with","prancing","neighing"]},{"verseId":"brenton_job_39_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":26,"text":"And does the hawk remain steady by thy wisdom, having spread out her wings unmoved, looking toward the region of the south?","searchKeywords":["and","does","the","hawk","remain","steady","thy","wisdom","having","spread","out","her","wings","unmoved","looking","toward","region","south"]},{"verseId":"brenton_job_39_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":27,"text":"And does the eagle rise at thy command, and the vulture remain sitting over his nest,","searchKeywords":["and","does","the","eagle","rise","thy","command","vulture","remain","sitting","over","his","nest"]},{"verseId":"brenton_job_39_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":28,"text":"on a crag of a rock, and in a secret ?","searchKeywords":["crag","rock","and","secret"]},{"verseId":"brenton_job_39_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":29,"text":"Thence he seeks food, his eyes observe from far.","searchKeywords":["thence","seeks","food","his","eyes","observe","from","far"]},{"verseId":"brenton_job_39_30","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":39,"verse":30,"text":"And his young ones roll themselves in blood, and wherever the carcases may be, immediately they are found.","searchKeywords":["and","his","young","ones","roll","themselves","blood","wherever","the","carcases","may","immediately","they","are","found"]}]