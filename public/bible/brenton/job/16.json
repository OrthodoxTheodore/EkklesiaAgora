[{"verseId":"brenton_job_16_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":1,"text":"But Job answered and said,","searchKeywords":["but","job","answered","and","said"]},{"verseId":"brenton_job_16_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":2,"text":"I have heard many such things: poor comforters are ye all.","searchKeywords":["have","heard","many","such","things","poor","comforters","are","all"]},{"verseId":"brenton_job_16_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":3,"text":"What! is there any reason in vain words? or what will hinder thee from answering?","searchKeywords":["what","there","any","reason","vain","words","will","hinder","thee","from","answering"]},{"verseId":"brenton_job_16_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":4,"text":"I also will speak as ye : if indeed your soul were in my stead, then would I insult you with words, and I would shake my head at you.","searchKeywords":["also","will","speak","indeed","your","soul","were","stead","then","would","insult","you","with","words","and","shake","head"]},{"verseId":"brenton_job_16_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":5,"text":"And would there were strength in my mouth, and I would not spare the movement of my lips.","searchKeywords":["and","would","there","were","strength","mouth","not","spare","the","movement","lips"]},{"verseId":"brenton_job_16_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":6,"text":"For if I should speak, I shall not feel the pain of my wound: and if I should be silent, how shall I be wounded the less?","searchKeywords":["for","should","speak","shall","not","feel","the","pain","wound","and","silent","how","wounded","less"]},{"verseId":"brenton_job_16_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":7,"text":"But now he has made me weary, and a worn-out fool; and thou hast laid hold of me.","searchKeywords":["but","now","has","made","weary","and","worn","out","fool","thou","hast","laid","hold"]},{"verseId":"brenton_job_16_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":8,"text":"My falsehood has become a testimony, and has risen up against me: it has confronted me to my face.","searchKeywords":["falsehood","has","become","testimony","and","risen","against","confronted","face"]},{"verseId":"brenton_job_16_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":9,"text":"In his anger he has cast me down; he has gnashed his teeth upon me: the weapons of his robbers have fallen upon me.","searchKeywords":["his","anger","has","cast","down","gnashed","teeth","upon","the","weapons","robbers","have","fallen"]},{"verseId":"brenton_job_16_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":10,"text":"He has attacked me with the keen glances of his eyes; with his sharp he has smitten me upon my knees; and they have run upon me with one accord.","searchKeywords":["has","attacked","with","the","keen","glances","his","eyes","sharp","smitten","upon","knees","and","they","have","run","one","accord"]},{"verseId":"brenton_job_16_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":11,"text":"For the Lord has delivered me into the hands of unrighteous men, and thrown me upon the ungodly.","searchKeywords":["for","the","lord","has","delivered","into","hands","unrighteous","men","and","thrown","upon","ungodly"]},{"verseId":"brenton_job_16_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":12,"text":"When I was at peace he distracted me: he took me by the hair of the head, and plucked it out: he set me up as a mark.","searchKeywords":["when","was","peace","distracted","took","the","hair","head","and","plucked","out","set","mark"]},{"verseId":"brenton_job_16_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":13,"text":"They surrounded me with spears, aiming at my reins: without sparing they poured out my gall upon the ground.","searchKeywords":["they","surrounded","with","spears","aiming","reins","without","sparing","poured","out","gall","upon","the","ground"]},{"verseId":"brenton_job_16_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":14,"text":"They overthrew me with fall upon fall: they ran upon me in might.","searchKeywords":["they","overthrew","with","fall","upon","ran","might"]},{"verseId":"brenton_job_16_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":15,"text":"They sewed sackcloth upon my skin, and my strength has been spent on the ground.","searchKeywords":["they","sewed","sackcloth","upon","skin","and","strength","has","been","spent","the","ground"]},{"verseId":"brenton_job_16_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":16,"text":"My belly has been parched with wailing, and darkness is on my eyelids.","searchKeywords":["belly","has","been","parched","with","wailing","and","darkness","eyelids"]},{"verseId":"brenton_job_16_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":17,"text":"Yet there was no injustice in my hands, and my prayer is pure.","searchKeywords":["yet","there","was","injustice","hands","and","prayer","pure"]},{"verseId":"brenton_job_16_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":18,"text":"Earth, cover not over the blood of my flesh, and let my cry have no place.","searchKeywords":["earth","cover","not","over","the","blood","flesh","and","let","cry","have","place"]},{"verseId":"brenton_job_16_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":19,"text":"And now, behold, my witness is in heaven, and my advocate is on high.","searchKeywords":["and","now","behold","witness","heaven","advocate","high"]},{"verseId":"brenton_job_16_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":20,"text":"Let my supplication come to the Lord, and let mine eye weep before him.","searchKeywords":["let","supplication","come","the","lord","and","mine","eye","weep","before","him"]},{"verseId":"brenton_job_16_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":21,"text":"Oh that a man might plead before the Lord, even the son of man with his neighbour!","searchKeywords":["that","man","might","plead","before","the","lord","even","son","with","his","neighbour"]},{"verseId":"brenton_job_16_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":16,"verse":22,"text":"But my years are numbered and come, and I shall go by the way by which I shall not return.","searchKeywords":["but","years","are","numbered","and","come","shall","the","way","which","not","return"]}]