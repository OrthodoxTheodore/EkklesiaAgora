[{"verseId":"brenton_job_5_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":1,"text":"But call, if any one will hearken to thee, or if thou shalt see any of the holy angels.","searchKeywords":["but","call","any","one","will","hearken","thee","thou","shalt","see","the","holy","angels"]},{"verseId":"brenton_job_5_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":2,"text":"For wrath destroys the foolish one, and envy slays him that has gone astray.","searchKeywords":["for","wrath","destroys","the","foolish","one","and","envy","slays","him","that","has","gone","astray"]},{"verseId":"brenton_job_5_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":3,"text":"And I have seen foolish ones taking root: but suddenly their habitation was devoured.","searchKeywords":["and","have","seen","foolish","ones","taking","root","but","suddenly","their","habitation","was","devoured"]},{"verseId":"brenton_job_5_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":4,"text":"Let their children be far from safety, and let them be crushed at the doors of vile men, and let there be no deliverer.","searchKeywords":["let","their","children","far","from","safety","and","them","crushed","the","doors","vile","men","there","deliverer"]},{"verseId":"brenton_job_5_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":5,"text":"For what they have collected, the just shall eat; but they shall not be delivered out of calamities: let their strength be utterly exhausted.","searchKeywords":["for","what","they","have","collected","the","just","shall","eat","but","not","delivered","out","calamities","let","their","strength","utterly","exhausted"]},{"verseId":"brenton_job_5_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":6,"text":"For labour cannot by any means come out of the earth, nor shall trouble spring out of the mountains:","searchKeywords":["for","labour","cannot","any","means","come","out","the","earth","nor","shall","trouble","spring","mountains"]},{"verseId":"brenton_job_5_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":7,"text":"yet man is born to labour, and the vulture's young seek the high places.","searchKeywords":["yet","man","born","labour","and","the","vulture","young","seek","high","places"]},{"verseId":"brenton_job_5_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":8,"text":"Nevertheless I will beseech the Lord, and will call upon the Lord, the sovereign of all;","searchKeywords":["nevertheless","will","beseech","the","lord","and","call","upon","sovereign","all"]},{"verseId":"brenton_job_5_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":9,"text":"who does great things and untraceable, glorious things also, and marvellous, of which there is no number:","searchKeywords":["who","does","great","things","and","untraceable","glorious","also","marvellous","which","there","number"]},{"verseId":"brenton_job_5_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":10,"text":"who gives rain upon the earth, sending water on the earth:","searchKeywords":["who","gives","rain","upon","the","earth","sending","water"]},{"verseId":"brenton_job_5_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":11,"text":"who exalts the lowly, and raises up them that are lost:","searchKeywords":["who","exalts","the","lowly","and","raises","them","that","are","lost"]},{"verseId":"brenton_job_5_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":12,"text":"frustrating the counsels of the crafty, and their hands shall not perform the truth:","searchKeywords":["frustrating","the","counsels","crafty","and","their","hands","shall","not","perform","truth"]},{"verseId":"brenton_job_5_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":13,"text":"who takes the wise in their wisdom, and subverts the counsel of the crafty.","searchKeywords":["who","takes","the","wise","their","wisdom","and","subverts","counsel","crafty"]},{"verseId":"brenton_job_5_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":14,"text":"In the day darkness shall come upon them, and let them grope in the noon-day even as in the night:","searchKeywords":["the","day","darkness","shall","come","upon","them","and","let","grope","noon","even","night"]},{"verseId":"brenton_job_5_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":15,"text":"and let them perish in war, and let the weak escape from the hand of the mighty.","searchKeywords":["and","let","them","perish","war","the","weak","escape","from","hand","mighty"]},{"verseId":"brenton_job_5_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":16,"text":"And let the weak have hope, but the mouth of the unjust be stopped.","searchKeywords":["and","let","the","weak","have","hope","but","mouth","unjust","stopped"]},{"verseId":"brenton_job_5_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":17,"text":"But blessed the man whom the Lord has reproved; and reject not thou the chastening of the Almighty.","searchKeywords":["but","blessed","the","man","whom","lord","has","reproved","and","reject","not","thou","chastening","almighty"]},{"verseId":"brenton_job_5_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":18,"text":"For he causes to be in pain, and restores again: he smites, and his hands heal.","searchKeywords":["for","causes","pain","and","restores","again","smites","his","hands","heal"]},{"verseId":"brenton_job_5_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":19,"text":"Six times he shall deliver thee out of distresses: and in the seventh harm shall not touch thee.","searchKeywords":["six","times","shall","deliver","thee","out","distresses","and","the","seventh","harm","not","touch"]},{"verseId":"brenton_job_5_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":20,"text":"In famine he shall deliver thee from death: and in war he shall free thee from the power of the sword.","searchKeywords":["famine","shall","deliver","thee","from","death","and","war","free","the","power","sword"]},{"verseId":"brenton_job_5_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":21,"text":"He shall hide thee from the scourge of the tongue: and thou shalt not be afraid of coming evils.","searchKeywords":["shall","hide","thee","from","the","scourge","tongue","and","thou","shalt","not","afraid","coming","evils"]},{"verseId":"brenton_job_5_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":22,"text":"Thou shalt laugh at the unrighteous and the lawless: and thou shalt not be afraid of wild beasts.","searchKeywords":["thou","shalt","laugh","the","unrighteous","and","lawless","not","afraid","wild","beasts"]},{"verseId":"brenton_job_5_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":23,"text":"For the wild beasts of the field shall be at peace with thee.","searchKeywords":["for","the","wild","beasts","field","shall","peace","with","thee"]},{"verseId":"brenton_job_5_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":24,"text":"Then shalt thou know that thy house shall be at peace, and the provision for thy tabernacle shall not fail.","searchKeywords":["then","shalt","thou","know","that","thy","house","shall","peace","and","the","provision","for","tabernacle","not","fail"]},{"verseId":"brenton_job_5_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":25,"text":"And thou shalt know that thy seed abundant; and thy children shall be like the herbage of the field.","searchKeywords":["and","thou","shalt","know","that","thy","seed","abundant","children","shall","like","the","herbage","field"]},{"verseId":"brenton_job_5_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":26,"text":"And thou shalt come to the grave like ripe corn reaped in its season, or as a heap of the corn-flour collected in proper time.","searchKeywords":["and","thou","shalt","come","the","grave","like","ripe","corn","reaped","its","season","heap","flour","collected","proper","time"]},{"verseId":"brenton_job_5_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":5,"verse":27,"text":"Behold, we have thus sought out these matters; these are what we have heard: but do thou reflect with thyself, if thou hast done anything .","searchKeywords":["behold","have","thus","sought","out","these","matters","are","what","heard","but","thou","reflect","with","thyself","hast","done","anything"]}]