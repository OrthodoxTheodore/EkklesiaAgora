[{"verseId":"brenton_job_4_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":1,"text":"Then Eliphaz the Thæmanite answered and said,","searchKeywords":["then","eliphaz","the","manite","answered","and","said"]},{"verseId":"brenton_job_4_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":2,"text":"Hast thou been often spoken to in distress? but who shall endure the force of thy words?","searchKeywords":["hast","thou","been","often","spoken","distress","but","who","shall","endure","the","force","thy","words"]},{"verseId":"brenton_job_4_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":3,"text":"For whereas thou hast instructed many, and hast strengthened the hands of the weak one,","searchKeywords":["for","whereas","thou","hast","instructed","many","and","strengthened","the","hands","weak","one"]},{"verseId":"brenton_job_4_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":4,"text":"and hast supported the failing with words, and hast imparted courage to feeble knees.","searchKeywords":["and","hast","supported","the","failing","with","words","imparted","courage","feeble","knees"]},{"verseId":"brenton_job_4_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":5,"text":"Yet now pain has come upon thee, and touched thee, thou art troubled.","searchKeywords":["yet","now","pain","has","come","upon","thee","and","touched","thou","art","troubled"]},{"verseId":"brenton_job_4_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":6,"text":"Is not thy fear in folly, thy hope also, and the mischief of thy way?","searchKeywords":["not","thy","fear","folly","hope","also","and","the","mischief","way"]},{"verseId":"brenton_job_4_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":7,"text":"Remember then who has perished, being pure? or when were the true-hearted utterly destroyed?","searchKeywords":["remember","then","who","has","perished","being","pure","when","were","the","true","hearted","utterly","destroyed"]},{"verseId":"brenton_job_4_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":8,"text":"Accordingly as I have seen men ploughing barren places, and they that sow them will reap sorrows for themselves.","searchKeywords":["accordingly","have","seen","men","ploughing","barren","places","and","they","that","sow","them","will","reap","sorrows","for","themselves"]},{"verseId":"brenton_job_4_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":9,"text":"They shall perish by the command of the Lord, and shall be utterly consumed by the breath of his wrath.","searchKeywords":["they","shall","perish","the","command","lord","and","utterly","consumed","breath","his","wrath"]},{"verseId":"brenton_job_4_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":10,"text":"The strength of the lion, and the voice of the lioness, and the exulting cry of serpents are quenched.","searchKeywords":["the","strength","lion","and","voice","lioness","exulting","cry","serpents","are","quenched"]},{"verseId":"brenton_job_4_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":11,"text":"The old lion has perished for want of food, and the lions' whelps have forsaken one another.","searchKeywords":["the","old","lion","has","perished","for","want","food","and","lions","whelps","have","forsaken","one","another"]},{"verseId":"brenton_job_4_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":12,"text":"But if there had been any truth in thy words, none of these evils would have befallen thee. Shall not mine ear receive excellent from him?","searchKeywords":["but","there","had","been","any","truth","thy","words","none","these","evils","would","have","befallen","thee","shall","not","mine","ear","receive","excellent","from","him"]},{"verseId":"brenton_job_4_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":13,"text":"But terror falls upon men, with dread and a sound in the night,","searchKeywords":["but","terror","falls","upon","men","with","dread","and","sound","the","night"]},{"verseId":"brenton_job_4_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":14,"text":"horror and trembling seized me, and caused all my bones greatly to shake.","searchKeywords":["horror","and","trembling","seized","caused","all","bones","greatly","shake"]},{"verseId":"brenton_job_4_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":15,"text":"And a spirit came before my face; and my hair and flesh quivered.","searchKeywords":["and","spirit","came","before","face","hair","flesh","quivered"]},{"verseId":"brenton_job_4_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":16,"text":"I arose and perceived it not: I looked, and there was no form before my eyes: but I only heard a breath and a voice, ,","searchKeywords":["arose","and","perceived","not","looked","there","was","form","before","eyes","but","only","heard","breath","voice"]},{"verseId":"brenton_job_4_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":17,"text":"What, shall a mortal be pure before the Lord? or a man be blameless in regard to his works?","searchKeywords":["what","shall","mortal","pure","before","the","lord","man","blameless","regard","his","works"]},{"verseId":"brenton_job_4_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":18,"text":"Whereas he trusts not in his servants, and perceives perverseness in his angels.","searchKeywords":["whereas","trusts","not","his","servants","and","perceives","perverseness","angels"]},{"verseId":"brenton_job_4_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":19,"text":"But them that dwell in houses of clay, of whom we also are formed of the same clay, he smites them like a moth.","searchKeywords":["but","them","that","dwell","houses","clay","whom","also","are","formed","the","same","smites","like","moth"]},{"verseId":"brenton_job_4_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":20,"text":"And from morning to evening they no longer exist: they have perished, because they cannot help themselves.","searchKeywords":["and","from","morning","evening","they","longer","exist","have","perished","because","cannot","help","themselves"]},{"verseId":"brenton_job_4_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":4,"verse":21,"text":"For he blows upon them, and they are withered: they have perished for lack of wisdom.","searchKeywords":["for","blows","upon","them","and","they","are","withered","have","perished","lack","wisdom"]}]