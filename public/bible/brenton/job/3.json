[{"verseId":"brenton_job_3_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":1,"text":"After this Job opened his mouth, and cursed his day,","searchKeywords":["after","this","job","opened","his","mouth","and","cursed","day"]},{"verseId":"brenton_job_3_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":2,"text":"saying,","searchKeywords":["saying"]},{"verseId":"brenton_job_3_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":3,"text":"Let the day perish in which I was born, and that night in which they said, Behold a man-child!","searchKeywords":["let","the","day","perish","which","was","born","and","that","night","they","said","behold","man","child"]},{"verseId":"brenton_job_3_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":4,"text":"Let that night be darkness, and let not the Lord regard it from above, neither let light come upon it.","searchKeywords":["let","that","night","darkness","and","not","the","lord","regard","from","above","neither","light","come","upon"]},{"verseId":"brenton_job_3_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":5,"text":"But let darkness and the shadow of death seize it; let blackness come upon it;","searchKeywords":["but","let","darkness","and","the","shadow","death","seize","blackness","come","upon"]},{"verseId":"brenton_job_3_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":6,"text":"let that day and night be cursed, let darkness carry them away; let it not come into the days of the year, neither let it be numbered with the days of the months.","searchKeywords":["let","that","day","and","night","cursed","darkness","carry","them","away","not","come","into","the","days","year","neither","numbered","with","months"]},{"verseId":"brenton_job_3_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":7,"text":"But let that night be pain, and let not mirth come upon it, nor joy.","searchKeywords":["but","let","that","night","pain","and","not","mirth","come","upon","nor","joy"]},{"verseId":"brenton_job_3_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":8,"text":"But let him that curses that day curse it, he that is ready to attack the great whale.","searchKeywords":["but","let","him","that","curses","day","curse","ready","attack","the","great","whale"]},{"verseId":"brenton_job_3_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":9,"text":"Let the stars of that night be darkened; let it remain , and not come into light; and let it not see the morning star arise:","searchKeywords":["let","the","stars","that","night","darkened","remain","and","not","come","into","light","see","morning","star","arise"]},{"verseId":"brenton_job_3_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":10,"text":"because it shut not up the gates of my mother's womb, for it would have removed sorrow from my eyes.","searchKeywords":["because","shut","not","the","gates","mother","womb","for","would","have","removed","sorrow","from","eyes"]},{"verseId":"brenton_job_3_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":11,"text":"For why died I not in the belly? and did I not come forth from the womb and die immediately?","searchKeywords":["for","why","died","not","the","belly","and","did","come","forth","from","womb","die","immediately"]},{"verseId":"brenton_job_3_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":12,"text":"And why did the knees support me? and why did I suck the breasts?","searchKeywords":["and","why","did","the","knees","support","suck","breasts"]},{"verseId":"brenton_job_3_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":13,"text":"Now I should have lain down and been quiet, I should have slept and been at rest,","searchKeywords":["now","should","have","lain","down","and","been","quiet","slept","rest"]},{"verseId":"brenton_job_3_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":14,"text":"with kings councillors of the earth, who gloried in swords;","searchKeywords":["with","kings","councillors","the","earth","who","gloried","swords"]},{"verseId":"brenton_job_3_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":15,"text":"or with rulers, whose gold was abundant, who filled their houses with silver:","searchKeywords":["with","rulers","whose","gold","was","abundant","who","filled","their","houses","silver"]},{"verseId":"brenton_job_3_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":16,"text":"or as an untimely birth proceeding from his mother's womb, or as infants who never saw light.","searchKeywords":["untimely","birth","proceeding","from","his","mother","womb","infants","who","never","saw","light"]},{"verseId":"brenton_job_3_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":17,"text":"There the ungodly have burnt out the fury of rage; there the wearied in body rest.","searchKeywords":["there","the","ungodly","have","burnt","out","fury","rage","wearied","body","rest"]},{"verseId":"brenton_job_3_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":18,"text":"And the men of old time have together ceased to hear the exactor's voice.","searchKeywords":["and","the","men","old","time","have","together","ceased","hear","exactor","voice"]},{"verseId":"brenton_job_3_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":19,"text":"The small and great are there, and the servant that feared his lord.","searchKeywords":["the","small","and","great","are","there","servant","that","feared","his","lord"]},{"verseId":"brenton_job_3_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":20,"text":"For why is light given to those who are in bitterness, and life to the souls which are in griefs?","searchKeywords":["for","why","light","given","those","who","are","bitterness","and","life","the","souls","which","griefs"]},{"verseId":"brenton_job_3_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":21,"text":"who desire death, and obtain it not, digging as treasures;","searchKeywords":["who","desire","death","and","obtain","not","digging","treasures"]},{"verseId":"brenton_job_3_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":22,"text":"and would be very joyful if they should gain it?","searchKeywords":["and","would","very","joyful","they","should","gain"]},{"verseId":"brenton_job_3_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":23,"text":"Death rest to a man, for God has hedged him in.","searchKeywords":["death","rest","man","for","god","has","hedged","him"]},{"verseId":"brenton_job_3_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":24,"text":"For my groaning comes before my food, and I weep being beset with terror.","searchKeywords":["for","groaning","comes","before","food","and","weep","being","beset","with","terror"]},{"verseId":"brenton_job_3_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":25,"text":"For the terror of which I meditated has come upon me, and that which I had feared has befallen me.","searchKeywords":["for","the","terror","which","meditated","has","come","upon","and","that","had","feared","befallen"]},{"verseId":"brenton_job_3_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":3,"verse":26,"text":"I was not at peace, nor quiet, nor had I rest; yet wrath came upon me.","searchKeywords":["was","not","peace","nor","quiet","had","rest","yet","wrath","came","upon"]}]