[{"verseId":"brenton_job_24_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":1,"text":"But why have the seasons been hidden from the Lord,","searchKeywords":["but","why","have","the","seasons","been","hidden","from","lord"]},{"verseId":"brenton_job_24_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":2,"text":"while the ungodly have passed over the bound, carrying off the flock with the shepherd?","searchKeywords":["while","the","ungodly","have","passed","over","bound","carrying","off","flock","with","shepherd"]},{"verseId":"brenton_job_24_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":3,"text":"They have led away the ass of the fatherless, and taken the widow's ox for a pledge.","searchKeywords":["they","have","led","away","the","ass","fatherless","and","taken","widow","for","pledge"]},{"verseId":"brenton_job_24_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":4,"text":"They have turned aside the weak from the right way: and the meek of the earth have hidden themselves together.","searchKeywords":["they","have","turned","aside","the","weak","from","right","way","and","meek","earth","hidden","themselves","together"]},{"verseId":"brenton_job_24_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":5,"text":"And they have departed like asses in the field, having gone forth on my account according to their own order: his bread is sweet to little ones.","searchKeywords":["and","they","have","departed","like","asses","the","field","having","gone","forth","account","according","their","own","order","his","bread","sweet","little","ones"]},{"verseId":"brenton_job_24_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":6,"text":"They have reaped a field that was not their own before the time: the poor have laboured in the vineyards of the ungodly without pay and without food.","searchKeywords":["they","have","reaped","field","that","was","not","their","own","before","the","time","poor","laboured","vineyards","ungodly","without","pay","and","food"]},{"verseId":"brenton_job_24_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":7,"text":"They have caused many naked to sleep without clothes, and they have taken away the covering of their body.","searchKeywords":["they","have","caused","many","naked","sleep","without","clothes","and","taken","away","the","covering","their","body"]},{"verseId":"brenton_job_24_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":8,"text":"They are wet with the drops of the mountains: they have embraced the rock, because they had no shelter.","searchKeywords":["they","are","wet","with","the","drops","mountains","have","embraced","rock","because","had","shelter"]},{"verseId":"brenton_job_24_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":9,"text":"They have snatched the fatherless from the breast, and have afflicted the outcast.","searchKeywords":["they","have","snatched","the","fatherless","from","breast","and","afflicted","outcast"]},{"verseId":"brenton_job_24_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":10,"text":"And they have wrongfully caused to sleep without clothing, and taken away the morsel of the hungry.","searchKeywords":["and","they","have","wrongfully","caused","sleep","without","clothing","taken","away","the","morsel","hungry"]},{"verseId":"brenton_job_24_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":11,"text":"They have unrighteously laid wait in narrow places, and have not known the righteous way.","searchKeywords":["they","have","unrighteously","laid","wait","narrow","places","and","not","known","the","righteous","way"]},{"verseId":"brenton_job_24_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":12,"text":"Who have cast forth poor from the city and their own houses, and the soul of the children has groaned aloud.","searchKeywords":["who","have","cast","forth","poor","from","the","city","and","their","own","houses","soul","children","has","groaned","aloud"]},{"verseId":"brenton_job_24_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":13,"text":"Why then has he not visited these? forasmuch as they were upon the earth, and took no notice, and they knew not the way of righteousness, neither have they walked in their paths?","searchKeywords":["why","then","has","not","visited","these","forasmuch","they","were","upon","the","earth","and","took","notice","knew","way","righteousness","neither","have","walked","their","paths"]},{"verseId":"brenton_job_24_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":14,"text":"But having known their works, he delivered them into darkness: and in the night one will be as a thief:","searchKeywords":["but","having","known","their","works","delivered","them","into","darkness","and","the","night","one","will","thief"]},{"verseId":"brenton_job_24_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":15,"text":"and the eye of the adulterer has watched the darkness, saying, Eye shall not perceive me, and he puts a covering on his face.","searchKeywords":["and","the","eye","adulterer","has","watched","darkness","saying","shall","not","perceive","puts","covering","his","face"]},{"verseId":"brenton_job_24_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":16,"text":"In darkness he digs through houses: by day they conceal themselves securely: they know not the light.","searchKeywords":["darkness","digs","through","houses","day","they","conceal","themselves","securely","know","not","the","light"]},{"verseId":"brenton_job_24_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":17,"text":"For the morning is to them all the shadow of death, for will be conscious of the terror of the shadow of death.","searchKeywords":["for","the","morning","them","all","shadow","death","will","conscious","terror"]},{"verseId":"brenton_job_24_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":18,"text":"He is swift on the face of the water: let his portion be cursed on the earth; and let their plants be laid bare.","searchKeywords":["swift","the","face","water","let","his","portion","cursed","earth","and","their","plants","laid","bare"]},{"verseId":"brenton_job_24_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":19,"text":"withered upon the earth; for they have plundered the sheaves of the fatherless.","searchKeywords":["withered","upon","the","earth","for","they","have","plundered","sheaves","fatherless"]},{"verseId":"brenton_job_24_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":20,"text":"Then is his sin brought to remembrance, and he vanishes like a vapour of dew: but let what he has done be recompensed to him, and let every unrighteous one be crushed like rotten wood.","searchKeywords":["then","his","sin","brought","remembrance","and","vanishes","like","vapour","dew","but","let","what","has","done","recompensed","him","every","unrighteous","one","crushed","rotten","wood"]},{"verseId":"brenton_job_24_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":21,"text":"For he has not treated the barren woman well, and has had no pity on a feeble woman.","searchKeywords":["for","has","not","treated","the","barren","woman","well","and","had","pity","feeble"]},{"verseId":"brenton_job_24_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":22,"text":"And in wrath he has overthrown the helpless: therefore when he has arisen, will not feel secure of his own life.","searchKeywords":["and","wrath","has","overthrown","the","helpless","therefore","when","arisen","will","not","feel","secure","his","own","life"]},{"verseId":"brenton_job_24_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":23,"text":"When he has fallen sick, let him not hope to recover: but let him perish by disease.","searchKeywords":["when","has","fallen","sick","let","him","not","hope","recover","but","perish","disease"]},{"verseId":"brenton_job_24_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":24,"text":"For his exaltation has hurt many; but he has withered as mallows in the heat, or as an ear of corn falling off of itself from the stalk.","searchKeywords":["for","his","exaltation","has","hurt","many","but","withered","mallows","the","heat","ear","corn","falling","off","itself","from","stalk"]},{"verseId":"brenton_job_24_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":24,"verse":25,"text":"But if not, who is he that says I speak falsely, and will make my words of no account?","searchKeywords":["but","not","who","that","says","speak","falsely","and","will","make","words","account"]}]