[{"verseId":"brenton_job_7_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":1,"text":"Is not the life of man upon earth a state of trial? and his existence as that of a hireling by the day?","searchKeywords":["not","the","life","man","upon","earth","state","trial","and","his","existence","that","hireling","day"]},{"verseId":"brenton_job_7_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":2,"text":"Or as a servant that fears his master, and one who has grasped a shadow? or as a hireling waiting for his pay?","searchKeywords":["servant","that","fears","his","master","and","one","who","has","grasped","shadow","hireling","waiting","for","pay"]},{"verseId":"brenton_job_7_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":3,"text":"So have I also endured months of vanity, and nights of pain have been appointed me.","searchKeywords":["have","also","endured","months","vanity","and","nights","pain","been","appointed"]},{"verseId":"brenton_job_7_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":4,"text":"Whenever I lie down, I say, When day? and whenever I rise up, again when evening? and I am full of pains from evening to morning.","searchKeywords":["whenever","lie","down","say","when","day","and","rise","again","evening","full","pains","from","morning"]},{"verseId":"brenton_job_7_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":5,"text":"And my body is covered with loathsome worms; and I waste away, scraping off clods of dust from my eruption.","searchKeywords":["and","body","covered","with","loathsome","worms","waste","away","scraping","off","clods","dust","from","eruption"]},{"verseId":"brenton_job_7_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":6,"text":"And my life is lighter than a word, and has perished in vain hope.","searchKeywords":["and","life","lighter","than","word","has","perished","vain","hope"]},{"verseId":"brenton_job_7_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":7,"text":"Remember then that my life is breath, and mine eye shall not yet again see good.","searchKeywords":["remember","then","that","life","breath","and","mine","eye","shall","not","yet","again","see","good"]},{"verseId":"brenton_job_7_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":8,"text":"The eye of him that sees me shall not see me : thine eyes are upon me, and I am no more.","searchKeywords":["the","eye","him","that","sees","shall","not","see","thine","eyes","are","upon","and","more"]},{"verseId":"brenton_job_7_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":9,"text":"as a cloud that is cleared away from the sky: for if a man go down to the grave, he shall not come up again:","searchKeywords":["cloud","that","cleared","away","from","the","sky","for","man","down","grave","shall","not","come","again"]},{"verseId":"brenton_job_7_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":10,"text":"and he shall surely not return to his own house, neither shall his place know him any more.","searchKeywords":["and","shall","surely","not","return","his","own","house","neither","place","know","him","any","more"]},{"verseId":"brenton_job_7_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":11,"text":"Then neither will I refrain my mouth: I will speak being in distress; being in anguish I will disclose the bitterness of my soul.","searchKeywords":["then","neither","will","refrain","mouth","speak","being","distress","anguish","disclose","the","bitterness","soul"]},{"verseId":"brenton_job_7_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":12,"text":"Am I a sea, or a serpent, that thou hast set a watch over me?","searchKeywords":["sea","serpent","that","thou","hast","set","watch","over"]},{"verseId":"brenton_job_7_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":13,"text":"I said that my bed should comfort me, and I would privately counsel with myself on my couch.","searchKeywords":["said","that","bed","should","comfort","and","would","privately","counsel","with","myself","couch"]},{"verseId":"brenton_job_7_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":14,"text":"Thou scarest me with dreams, and dost terrify me with visions.","searchKeywords":["thou","scarest","with","dreams","and","dost","terrify","visions"]},{"verseId":"brenton_job_7_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":15,"text":"Thou wilt separate life from my spirit; and yet my bones from death.","searchKeywords":["thou","wilt","separate","life","from","spirit","and","yet","bones","death"]},{"verseId":"brenton_job_7_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":16,"text":"For I shall not live for ever, that I should patiently endure: depart from me, for my life vain.","searchKeywords":["for","shall","not","live","ever","that","should","patiently","endure","depart","from","life","vain"]},{"verseId":"brenton_job_7_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":17,"text":"For what is man, that thou hast magnified him? or that thou givest heed to him?","searchKeywords":["for","what","man","that","thou","hast","magnified","him","givest","heed"]},{"verseId":"brenton_job_7_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":18,"text":"Wilt thou visit him till the morning, and judge him till rest?","searchKeywords":["wilt","thou","visit","him","till","the","morning","and","judge","rest"]},{"verseId":"brenton_job_7_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":19,"text":"How long dost thou not let me alone, nor let me go, until I shall swallow down my spittle?","searchKeywords":["how","long","dost","thou","not","let","alone","nor","until","shall","swallow","down","spittle"]},{"verseId":"brenton_job_7_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":20,"text":"If I have sinned, what shall I be able to do, O thou that understandest the mind of men? why hast thou made me as thine accuser, and am I a burden to thee?","searchKeywords":["have","sinned","what","shall","able","thou","that","understandest","the","mind","men","why","hast","made","thine","accuser","and","burden","thee"]},{"verseId":"brenton_job_7_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":7,"verse":21,"text":"Why hast thou not forgotten my iniquity, and purged my sin? but now I shall depart to the earth; and in the morning, I am no more.","searchKeywords":["why","hast","thou","not","forgotten","iniquity","and","purged","sin","but","now","shall","depart","the","earth","morning","more"]}]