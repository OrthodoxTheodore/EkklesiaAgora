[{"verseId":"brenton_job_21_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":1,"text":"But Job answered and said,","searchKeywords":["but","job","answered","and","said"]},{"verseId":"brenton_job_21_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":2,"text":"Hear ye, hear ye my words, that I may not have this consolation from you.","searchKeywords":["hear","words","that","may","not","have","this","consolation","from","you"]},{"verseId":"brenton_job_21_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":3,"text":"Raise me, and I will speak; then ye shall not laugh me to scorn.","searchKeywords":["raise","and","will","speak","then","shall","not","laugh","scorn"]},{"verseId":"brenton_job_21_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":4,"text":"What! is my reproof of man? and why should I not be angry?","searchKeywords":["what","reproof","man","and","why","should","not","angry"]},{"verseId":"brenton_job_21_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":5,"text":"Look upon me, and wonder, laying your hand upon your cheek.","searchKeywords":["look","upon","and","wonder","laying","your","hand","cheek"]},{"verseId":"brenton_job_21_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":6,"text":"For even when I remember, I am alarmed, and pains seize my flesh.","searchKeywords":["for","even","when","remember","alarmed","and","pains","seize","flesh"]},{"verseId":"brenton_job_21_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":7,"text":"Wherefore do the ungodly live, and grow old even in wealth?","searchKeywords":["wherefore","the","ungodly","live","and","grow","old","even","wealth"]},{"verseId":"brenton_job_21_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":8,"text":"Their seed is according to desire, and their children are in sight.","searchKeywords":["their","seed","according","desire","and","children","are","sight"]},{"verseId":"brenton_job_21_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":9,"text":"Their houses are prosperous, neither any where fear, neither is there a scourge from the Lord upon them.","searchKeywords":["their","houses","are","prosperous","neither","any","where","fear","there","scourge","from","the","lord","upon","them"]},{"verseId":"brenton_job_21_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":10,"text":"Their cow does not cast her calf, and their with young is safe, and does not miscarry.","searchKeywords":["their","cow","does","not","cast","her","calf","and","with","young","safe","miscarry"]},{"verseId":"brenton_job_21_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":11,"text":"And they remain as an unfailing flock, and their children play before , taking up the psaltery and harp;","searchKeywords":["and","they","remain","unfailing","flock","their","children","play","before","taking","the","psaltery","harp"]},{"verseId":"brenton_job_21_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":12,"text":"and they rejoice at the voice of a song.","searchKeywords":["and","they","rejoice","the","voice","song"]},{"verseId":"brenton_job_21_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":13,"text":"And they spend their days in wealth, and fall asleep in the rest of the grave.","searchKeywords":["and","they","spend","their","days","wealth","fall","asleep","the","rest","grave"]},{"verseId":"brenton_job_21_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":14,"text":"Yet says to the Lord, Depart from me; I desire not to know thy ways.","searchKeywords":["yet","says","the","lord","depart","from","desire","not","know","thy","ways"]},{"verseId":"brenton_job_21_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":15,"text":"What is the Mighty One, that we should serve him? and what profit is there that we should approach him?","searchKeywords":["what","the","mighty","one","that","should","serve","him","and","profit","there","approach"]},{"verseId":"brenton_job_21_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":16,"text":"For their good things were in hands, but he regards not the works of the ungodly.","searchKeywords":["for","their","good","things","were","hands","but","regards","not","the","works","ungodly"]},{"verseId":"brenton_job_21_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":17,"text":"Nevertheless, the lamp of the ungodly also shall be put out, and destruction shall come upon them, and pangs of vengeance shall seize them.","searchKeywords":["nevertheless","the","lamp","ungodly","also","shall","put","out","and","destruction","come","upon","them","pangs","vengeance","seize"]},{"verseId":"brenton_job_21_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":18,"text":"And they shall be as chaff before the wind, or as dust which the storm has taken up.","searchKeywords":["and","they","shall","chaff","before","the","wind","dust","which","storm","has","taken"]},{"verseId":"brenton_job_21_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":19,"text":"Let his substance fail his children: shall recompense him, and he shall know it.","searchKeywords":["let","his","substance","fail","children","shall","recompense","him","and","know"]},{"verseId":"brenton_job_21_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":20,"text":"Let his eyes see his own destruction, and let him not be saved by the Lord.","searchKeywords":["let","his","eyes","see","own","destruction","and","him","not","saved","the","lord"]},{"verseId":"brenton_job_21_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":21,"text":"For his desire is in his house with him, and the number of his months has been suddenly cut off.","searchKeywords":["for","his","desire","house","with","him","and","the","number","months","has","been","suddenly","cut","off"]},{"verseId":"brenton_job_21_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":22,"text":"Is it not the Lord who teaches understanding and knowledge? and does not he judge murders?","searchKeywords":["not","the","lord","who","teaches","understanding","and","knowledge","does","judge","murders"]},{"verseId":"brenton_job_21_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":23,"text":"One shall die in his perfect strength, and wholly at ease and prosperous;","searchKeywords":["one","shall","die","his","perfect","strength","and","wholly","ease","prosperous"]},{"verseId":"brenton_job_21_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":24,"text":"and his inwards are full of fat, and his marrow is diffused .","searchKeywords":["and","his","inwards","are","full","fat","marrow","diffused"]},{"verseId":"brenton_job_21_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":25,"text":"And another dies in bitterness of soul, not eating any good thing.","searchKeywords":["and","another","dies","bitterness","soul","not","eating","any","good","thing"]},{"verseId":"brenton_job_21_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":26,"text":"But they lie down in the earth together, and corruption covers them.","searchKeywords":["but","they","lie","down","the","earth","together","and","corruption","covers","them"]},{"verseId":"brenton_job_21_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":27,"text":"So I know you, that ye presumptuously attack me:","searchKeywords":["know","you","that","presumptuously","attack"]},{"verseId":"brenton_job_21_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":28,"text":"so that ye will say, Where is the house of the prince? and where is the covering of the tabernacles of the ungodly?","searchKeywords":["that","will","say","where","the","house","prince","and","covering","tabernacles","ungodly"]},{"verseId":"brenton_job_21_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":29,"text":"Ask those that go by the way, and do not disown their tokens.","searchKeywords":["ask","those","that","the","way","and","not","disown","their","tokens"]},{"verseId":"brenton_job_21_30","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":30,"text":"For the wicked hastens to the day of destruction: they shall be led away for the day of his vengeance.","searchKeywords":["for","the","wicked","hastens","day","destruction","they","shall","led","away","his","vengeance"]},{"verseId":"brenton_job_21_31","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":31,"text":"Who will tell him his way to his face, whereas he has done ? who shall recompense him?","searchKeywords":["who","will","tell","him","his","way","face","whereas","has","done","shall","recompense"]},{"verseId":"brenton_job_21_32","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":32,"text":"And he has been led away to the tombs, and he has watched over the heaps.","searchKeywords":["and","has","been","led","away","the","tombs","watched","over","heaps"]},{"verseId":"brenton_job_21_33","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":33,"text":"The stones of the valley have been sweet to him, and every man shall depart after him, and innumerable before him.","searchKeywords":["the","stones","valley","have","been","sweet","him","and","every","man","shall","depart","after","innumerable","before"]},{"verseId":"brenton_job_21_34","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":21,"verse":34,"text":"How then do ye comfort me in vain? whereas I have no rest from your molestation.","searchKeywords":["how","then","comfort","vain","whereas","have","rest","from","your","molestation"]}]