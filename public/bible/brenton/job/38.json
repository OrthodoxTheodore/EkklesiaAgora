[{"verseId":"brenton_job_38_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":1,"text":"And after Elius had ceased from speaking, the Lord spoke to Job through the whirlwind and clouds, ,","searchKeywords":["and","after","elius","had","ceased","from","speaking","the","lord","spoke","job","through","whirlwind","clouds"]},{"verseId":"brenton_job_38_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":2,"text":"Who is this that hides counsel from me, and confines words in heart, and thinks to conceal from me?","searchKeywords":["who","this","that","hides","counsel","from","and","confines","words","heart","thinks","conceal"]},{"verseId":"brenton_job_38_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":3,"text":"Gird thy loins like a man; and I will ask thee, and do thou answer me.","searchKeywords":["gird","thy","loins","like","man","and","will","ask","thee","thou","answer"]},{"verseId":"brenton_job_38_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":4,"text":"Where wast thou when I founded the earth? tell me now, if thou hast knowledge,","searchKeywords":["where","wast","thou","when","founded","the","earth","tell","now","hast","knowledge"]},{"verseId":"brenton_job_38_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":5,"text":"who set the measures of it, if thou knowest? or who stretched a line upon it?","searchKeywords":["who","set","the","measures","thou","knowest","stretched","line","upon"]},{"verseId":"brenton_job_38_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":6,"text":"On what are its rings fastened? and who is he that laid the corner-stone upon it?","searchKeywords":["what","are","its","rings","fastened","and","who","that","laid","the","corner","stone","upon"]},{"verseId":"brenton_job_38_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":7,"text":"When the stars were made, all my angels praised me with a loud voice.","searchKeywords":["when","the","stars","were","made","all","angels","praised","with","loud","voice"]},{"verseId":"brenton_job_38_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":8,"text":"And I shut up the sea with gates, when it rushed out, coming forth out of its mother's womb.","searchKeywords":["and","shut","the","sea","with","gates","when","rushed","out","coming","forth","its","mother","womb"]},{"verseId":"brenton_job_38_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":9,"text":"And I made a cloud its clothing, and swathed it in mist.","searchKeywords":["and","made","cloud","its","clothing","swathed","mist"]},{"verseId":"brenton_job_38_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":10,"text":"And I set bounds to it, surrounding it with bars and gates.","searchKeywords":["and","set","bounds","surrounding","with","bars","gates"]},{"verseId":"brenton_job_38_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":11,"text":"And I said to it, Hitherto shalt thou come, but thou shalt not go beyond, but thy waves shall be confined within thee.","searchKeywords":["and","said","hitherto","shalt","thou","come","but","not","beyond","thy","waves","shall","confined","within","thee"]},{"verseId":"brenton_job_38_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":12,"text":"Or did I order the morning light in thy time; and the morning star see his appointed place;","searchKeywords":["did","order","the","morning","light","thy","time","and","star","see","his","appointed","place"]},{"verseId":"brenton_job_38_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":13,"text":"to lay hold of the extremities of the earth, to cast out the ungodly out of it?","searchKeywords":["lay","hold","the","extremities","earth","cast","out","ungodly"]},{"verseId":"brenton_job_38_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":14,"text":"Or didst thou take clay of the ground, and form a living creature, and set it with the power of speech upon the earth?","searchKeywords":["didst","thou","take","clay","the","ground","and","form","living","creature","set","with","power","speech","upon","earth"]},{"verseId":"brenton_job_38_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":15,"text":"And hast thou removed light from the ungodly, and crushed the arm of the proud?","searchKeywords":["and","hast","thou","removed","light","from","the","ungodly","crushed","arm","proud"]},{"verseId":"brenton_job_38_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":16,"text":"Or hast thou gone to the source of the sea, and walked in the tracks of the deep?","searchKeywords":["hast","thou","gone","the","source","sea","and","walked","tracks","deep"]},{"verseId":"brenton_job_38_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":17,"text":"And do the gates of death open to thee for fear; and did the porters of hell quake when they saw thee?","searchKeywords":["and","the","gates","death","open","thee","for","fear","did","porters","hell","quake","when","they","saw"]},{"verseId":"brenton_job_38_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":18,"text":"And hast thou been instructed in the breadth of the under heaven? tell me now, what is the extent of it?","searchKeywords":["and","hast","thou","been","instructed","the","breadth","under","heaven","tell","now","what","extent"]},{"verseId":"brenton_job_38_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":19,"text":"And in what kind of a land does the light dwell? and of what kind is the place of darkness?","searchKeywords":["and","what","kind","land","does","the","light","dwell","place","darkness"]},{"verseId":"brenton_job_38_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":20,"text":"If thou couldest bring me to their boundaries, and if also thou knowest their paths;","searchKeywords":["thou","couldest","bring","their","boundaries","and","also","knowest","paths"]},{"verseId":"brenton_job_38_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":21,"text":"I know then that thou wert born at that time, and the number of thy years is great.","searchKeywords":["know","then","that","thou","wert","born","time","and","the","number","thy","years","great"]},{"verseId":"brenton_job_38_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":22,"text":"But hast thou gone to the treasures of snow? and hast thou seen the treasures of hail?","searchKeywords":["but","hast","thou","gone","the","treasures","snow","and","seen","hail"]},{"verseId":"brenton_job_38_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":23,"text":"And is there a store , for thee against the time of enemies, for the day of wars and battle?","searchKeywords":["and","there","store","for","thee","against","the","time","enemies","day","wars","battle"]},{"verseId":"brenton_job_38_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":24,"text":"And whence proceeds the frost? or is the south wind dispersed over the under heaven?","searchKeywords":["and","whence","proceeds","the","frost","south","wind","dispersed","over","under","heaven"]},{"verseId":"brenton_job_38_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":25,"text":"And who prepared a course for the violent rain, and a way for the thunders;","searchKeywords":["and","who","prepared","course","for","the","violent","rain","way","thunders"]},{"verseId":"brenton_job_38_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":26,"text":"to rain upon the land where no man, the wilderness, where there is not a man in it; so as to feed the untrodden and uninhabited ,","searchKeywords":["rain","upon","the","land","where","man","wilderness","there","not","feed","untrodden","and","uninhabited"]},{"verseId":"brenton_job_38_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":27,"text":"and cause it to send forth a crop of green herbs?","searchKeywords":["and","cause","send","forth","crop","green","herbs"]},{"verseId":"brenton_job_38_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":28,"text":"Who is the rain's father? and who has generated the drops of dew?","searchKeywords":["who","the","rain","father","and","has","generated","drops","dew"]},{"verseId":"brenton_job_38_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":29,"text":"And out of whose womb comes the ice? and who has produced the frost in the sky,","searchKeywords":["and","out","whose","womb","comes","the","ice","who","has","produced","frost","sky"]},{"verseId":"brenton_job_38_30","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":30,"text":"which descends like flowing water? who has terrified the face of the ungodly?","searchKeywords":["which","descends","like","flowing","water","who","has","terrified","the","face","ungodly"]},{"verseId":"brenton_job_38_31","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":31,"text":"And dost thou understand the band of Pleias, and hast thou opened the barrier of Orion?","searchKeywords":["and","dost","thou","understand","the","band","pleias","hast","opened","barrier","orion"]},{"verseId":"brenton_job_38_32","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":32,"text":"Or wilt thou reveal Mazuroth in his season, and the evening star with his rays? Wilt thou guide them?","searchKeywords":["wilt","thou","reveal","mazuroth","his","season","and","the","evening","star","with","rays","guide","them"]},{"verseId":"brenton_job_38_33","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":33,"text":"And knowest thou the changes of heaven, or the events which take place together under heaven?","searchKeywords":["and","knowest","thou","the","changes","heaven","events","which","take","place","together","under"]},{"verseId":"brenton_job_38_34","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":34,"text":"And wilt thou call a cloud with thy voice, and will it obey thee with a violent shower of much rain?","searchKeywords":["and","wilt","thou","call","cloud","with","thy","voice","will","obey","thee","violent","shower","much","rain"]},{"verseId":"brenton_job_38_35","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":35,"text":"And wilt thou send lightnings, and they shall go? and shall they say to thee, What is ?","searchKeywords":["and","wilt","thou","send","lightnings","they","shall","say","thee","what"]},{"verseId":"brenton_job_38_36","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":36,"text":"And who has given to women skill in weaving, or knowledge of embroidery?","searchKeywords":["and","who","has","given","women","skill","weaving","knowledge","embroidery"]},{"verseId":"brenton_job_38_37","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":37,"text":"And who is he that numbers the clouds in wisdom, and has bowed the heaven to the earth?","searchKeywords":["and","who","that","numbers","the","clouds","wisdom","has","bowed","heaven","earth"]},{"verseId":"brenton_job_38_38","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":38,"text":"For it is spread out as dusty earth, and I have cemented it as one hewn stone to another.","searchKeywords":["for","spread","out","dusty","earth","and","have","cemented","one","hewn","stone","another"]},{"verseId":"brenton_job_38_39","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":39,"text":"And wilt thou hunt a prey for the lions? and satisfy the desires of the serpents?","searchKeywords":["and","wilt","thou","hunt","prey","for","the","lions","satisfy","desires","serpents"]},{"verseId":"brenton_job_38_40","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":40,"text":"For they fear in their lairs, and lying in wait couch in the woods.","searchKeywords":["for","they","fear","their","lairs","and","lying","wait","couch","the","woods"]},{"verseId":"brenton_job_38_41","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":38,"verse":41,"text":"And who has prepared food for the raven? for its young ones wander and cry to the Lord, in search of food.","searchKeywords":["and","who","has","prepared","food","for","the","raven","its","young","ones","wander","cry","lord","search"]}]