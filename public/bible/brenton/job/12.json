[{"verseId":"brenton_job_12_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":1,"text":"And Job answered and said,","searchKeywords":["and","job","answered","said"]},{"verseId":"brenton_job_12_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":2,"text":"So then ye are men, and wisdom shall die with you?","searchKeywords":["then","are","men","and","wisdom","shall","die","with","you"]},{"verseId":"brenton_job_12_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":3,"text":"I also have a heart as well as you.","searchKeywords":["also","have","heart","well","you"]},{"verseId":"brenton_job_12_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":4,"text":"For a righteous and blameless man has become a subject for mockery.","searchKeywords":["for","righteous","and","blameless","man","has","become","subject","mockery"]},{"verseId":"brenton_job_12_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":5,"text":"For it had been ordained that he should fall under others at the appointed time, and that his houses should be spoiled by transgressors: let not however any one trust that, being evil, he shall be guiltless,","searchKeywords":["for","had","been","ordained","that","should","fall","under","others","the","appointed","time","and","his","houses","spoiled","transgressors","let","not","however","any","one","trust","being","evil","shall","guiltless"]},{"verseId":"brenton_job_12_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":6,"text":"even as many as provoke the Lord, as if there were indeed to be no inquisition of them.","searchKeywords":["even","many","provoke","the","lord","there","were","indeed","inquisition","them"]},{"verseId":"brenton_job_12_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":7,"text":"But ask now the beasts, if they may speak to thee; and the birds of the air, if they may declare to thee.","searchKeywords":["but","ask","now","the","beasts","they","may","speak","thee","and","birds","air","declare"]},{"verseId":"brenton_job_12_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":8,"text":"Tell the earth, if it may speak to thee: and the fishes of the sea shall explain to thee.","searchKeywords":["tell","the","earth","may","speak","thee","and","fishes","sea","shall","explain"]},{"verseId":"brenton_job_12_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":9,"text":"Who then has not known in all these things, that the hand of the Lord has made them?","searchKeywords":["who","then","has","not","known","all","these","things","that","the","hand","lord","made","them"]},{"verseId":"brenton_job_12_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":10,"text":"Whereas the life of all living things is in his hand, and the breath of every man.","searchKeywords":["whereas","the","life","all","living","things","his","hand","and","breath","every","man"]},{"verseId":"brenton_job_12_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":11,"text":"For the ear tries words, and the palate tastes meats.","searchKeywords":["for","the","ear","tries","words","and","palate","tastes","meats"]},{"verseId":"brenton_job_12_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":12,"text":"In length of time is wisdom, and in long life knowledge.","searchKeywords":["length","time","wisdom","and","long","life","knowledge"]},{"verseId":"brenton_job_12_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":13,"text":"With him are wisdom and power, with him counsel and understanding.","searchKeywords":["with","him","are","wisdom","and","power","counsel","understanding"]},{"verseId":"brenton_job_12_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":14,"text":"If he should cast down, who will build up? if he should shut up against men, who shall open?","searchKeywords":["should","cast","down","who","will","build","shut","against","men","shall","open"]},{"verseId":"brenton_job_12_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":15,"text":"If he should withhold the water, he will dry the earth: and if he should let it loose, he overthrows and destroys it.","searchKeywords":["should","withhold","the","water","will","dry","earth","and","let","loose","overthrows","destroys"]},{"verseId":"brenton_job_12_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":16,"text":"With him are strength and power: he has knowledge and understanding.","searchKeywords":["with","him","are","strength","and","power","has","knowledge","understanding"]},{"verseId":"brenton_job_12_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":17,"text":"He leads counsellors away captive, and maddens the judges of the earth.","searchKeywords":["leads","counsellors","away","captive","and","maddens","the","judges","earth"]},{"verseId":"brenton_job_12_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":18,"text":"He seats kings upon thrones, and girds their loins with a girdle.","searchKeywords":["seats","kings","upon","thrones","and","girds","their","loins","with","girdle"]},{"verseId":"brenton_job_12_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":19,"text":"He sends away priests into captivity, and overthrows the mighty ones of the earth.","searchKeywords":["sends","away","priests","into","captivity","and","overthrows","the","mighty","ones","earth"]},{"verseId":"brenton_job_12_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":20,"text":"He changes the lips of the trusty, and he knows the understanding of the elders.","searchKeywords":["changes","the","lips","trusty","and","knows","understanding","elders"]},{"verseId":"brenton_job_12_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":21,"text":"He pours dishonour upon princes, and heals the lowly.","searchKeywords":["pours","dishonour","upon","princes","and","heals","the","lowly"]},{"verseId":"brenton_job_12_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":22,"text":"Revealing deep things out of darkness: and he has brought into light the shadow of death.","searchKeywords":["revealing","deep","things","out","darkness","and","has","brought","into","light","the","shadow","death"]},{"verseId":"brenton_job_12_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":23,"text":"Causing the nations to wander, and destroying them: overthrowing the nations, and leading them .","searchKeywords":["causing","the","nations","wander","and","destroying","them","overthrowing","leading"]},{"verseId":"brenton_job_12_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":24,"text":"Perplexing the minds of the princes of the earth: and he causes them to wander in a way they have not known, ,","searchKeywords":["perplexing","the","minds","princes","earth","and","causes","them","wander","way","they","have","not","known"]},{"verseId":"brenton_job_12_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":12,"verse":25,"text":"Let them grope darkness, and no light, and let them wander as a drunken man.","searchKeywords":["let","them","grope","darkness","and","light","wander","drunken","man"]}]