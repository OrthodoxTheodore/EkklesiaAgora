[{"verseId":"brenton_job_30_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":1,"text":"But now the youngest have laughed me to scorn, now they reprove me in turn, whose fathers I set at nought; whom I did not deem worthy my shepherd dogs.","searchKeywords":["but","now","the","youngest","have","laughed","scorn","they","reprove","turn","whose","fathers","set","nought","whom","did","not","deem","worthy","shepherd","dogs"]},{"verseId":"brenton_job_30_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":2,"text":"Yea, why had I the strength of their hands? for them the full term was lost.","searchKeywords":["yea","why","had","the","strength","their","hands","for","them","full","term","was","lost"]},{"verseId":"brenton_job_30_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":3,"text":"childless in want and famine, they that fled but lately the distress and misery of drought.","searchKeywords":["childless","want","and","famine","they","that","fled","but","lately","the","distress","misery","drought"]},{"verseId":"brenton_job_30_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":4,"text":"Who compass the salt places on the sounding , who had salt for their food, and were dishonourable and of no repute, in want of every good thing; who also ate roots of trees by reason of great hunger.","searchKeywords":["who","compass","the","salt","places","sounding","had","for","their","food","and","were","dishonourable","repute","want","every","good","thing","also","ate","roots","trees","reason","great","hunger"]},{"verseId":"brenton_job_30_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":5,"text":"Thieves have risen up against me,","searchKeywords":["thieves","have","risen","against"]},{"verseId":"brenton_job_30_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":6,"text":"whose houses were the caves of the rocks, who lived under the wild shrubs.","searchKeywords":["whose","houses","were","the","caves","rocks","who","lived","under","wild","shrubs"]},{"verseId":"brenton_job_30_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":7,"text":"They will cry out among the rustling .","searchKeywords":["they","will","cry","out","among","the","rustling"]},{"verseId":"brenton_job_30_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":8,"text":"sons of fools and vile men, name and glory quenched from off the earth.","searchKeywords":["sons","fools","and","vile","men","name","glory","quenched","from","off","the","earth"]},{"verseId":"brenton_job_30_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":9,"text":"But now I am their music, and they have me for a by-word.","searchKeywords":["but","now","their","music","and","they","have","for","word"]},{"verseId":"brenton_job_30_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":10,"text":"And they stood aloof and abhorred me, and spared not to spit in my face.","searchKeywords":["and","they","stood","aloof","abhorred","spared","not","spit","face"]},{"verseId":"brenton_job_30_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":11,"text":"For he has opened his quiver and afflicted me: they also have cast off the restraint of my presence.","searchKeywords":["for","has","opened","his","quiver","and","afflicted","they","also","have","cast","off","the","restraint","presence"]},{"verseId":"brenton_job_30_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":12,"text":"They have risen up against on the right hand of offspring; they have stretched out their foot, and directed against me the ways of their destruction.","searchKeywords":["they","have","risen","against","the","right","hand","offspring","stretched","out","their","foot","and","directed","ways","destruction"]},{"verseId":"brenton_job_30_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":13,"text":"My paths are ruined; for they have stripped off my raiment: he has shot at me with his weapons.","searchKeywords":["paths","are","ruined","for","they","have","stripped","off","raiment","has","shot","with","his","weapons"]},{"verseId":"brenton_job_30_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":14,"text":"And he has pleaded against me as he will: I am overwhelmed with pains.","searchKeywords":["and","has","pleaded","against","will","overwhelmed","with","pains"]},{"verseId":"brenton_job_30_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":15,"text":"My pains return upon ; my hope is gone like the wind, and my safety as a cloud.","searchKeywords":["pains","return","upon","hope","gone","like","the","wind","and","safety","cloud"]},{"verseId":"brenton_job_30_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":16,"text":"Even now my life shall be poured forth upon me; and days of anguish seize me.","searchKeywords":["even","now","life","shall","poured","forth","upon","and","days","anguish","seize"]},{"verseId":"brenton_job_30_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":17,"text":"And by night my bones are confounded; and my sinews are relaxed.","searchKeywords":["and","night","bones","are","confounded","sinews","relaxed"]},{"verseId":"brenton_job_30_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":18,"text":"With great force has taken hold of my garment: it has compassed me as the collar of my coat.","searchKeywords":["with","great","force","has","taken","hold","garment","compassed","the","collar","coat"]},{"verseId":"brenton_job_30_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":19,"text":"And thou hast counted me as clay; my portion is in dust and ashes.","searchKeywords":["and","thou","hast","counted","clay","portion","dust","ashes"]},{"verseId":"brenton_job_30_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":20,"text":"And I have cried to thee, but thou hearest me not: but they stood still, and observed me.","searchKeywords":["and","have","cried","thee","but","thou","hearest","not","they","stood","still","observed"]},{"verseId":"brenton_job_30_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":21,"text":"They attacked me also without mercy: thou hast scourged me with a strong hand.","searchKeywords":["they","attacked","also","without","mercy","thou","hast","scourged","with","strong","hand"]},{"verseId":"brenton_job_30_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":22,"text":"And thou hast put me to grief, and hast cast me away from safety.","searchKeywords":["and","thou","hast","put","grief","cast","away","from","safety"]},{"verseId":"brenton_job_30_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":23,"text":"For I know that death will destroy me: for the earth is the house for every mortal.","searchKeywords":["for","know","that","death","will","destroy","the","earth","house","every","mortal"]},{"verseId":"brenton_job_30_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":24,"text":"Oh then that I might lay hands upon myself, or at least ask another, and he should do this for me.","searchKeywords":["then","that","might","lay","hands","upon","myself","least","ask","another","and","should","this","for"]},{"verseId":"brenton_job_30_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":25,"text":"Yet I wept over every helpless man; I groaned when I saw a man in distress.","searchKeywords":["yet","wept","over","every","helpless","man","groaned","when","saw","distress"]},{"verseId":"brenton_job_30_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":26,"text":"But I, when I waited for good things, behold, days of evils came the more upon me.","searchKeywords":["but","when","waited","for","good","things","behold","days","evils","came","the","more","upon"]},{"verseId":"brenton_job_30_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":27,"text":"My belly boiled, and would not cease: the days of poverty prevented me.","searchKeywords":["belly","boiled","and","would","not","cease","the","days","poverty","prevented"]},{"verseId":"brenton_job_30_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":28,"text":"I went mourning without restraint: and I have stood and cried out in the assembly.","searchKeywords":["went","mourning","without","restraint","and","have","stood","cried","out","the","assembly"]},{"verseId":"brenton_job_30_29","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":29,"text":"I am become a brother of monsters, and a companion of ostriches.","searchKeywords":["become","brother","monsters","and","companion","ostriches"]},{"verseId":"brenton_job_30_30","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":30,"text":"And my skin has been greatly blackened, and my bones are burned with heat.","searchKeywords":["and","skin","has","been","greatly","blackened","bones","are","burned","with","heat"]},{"verseId":"brenton_job_30_31","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":30,"verse":31,"text":"My harp also has been turned into mourning, and my song into my weeping.","searchKeywords":["harp","also","has","been","turned","into","mourning","and","song","weeping"]}]