[{"verseId":"brenton_job_13_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":1,"text":"Behold, mine eye has seen these things, and mine ear has heard .","searchKeywords":["behold","mine","eye","has","seen","these","things","and","ear","heard"]},{"verseId":"brenton_job_13_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":2,"text":"And I know all that ye too know; and I have not less understanding than you.","searchKeywords":["and","know","all","that","too","have","not","less","understanding","than","you"]},{"verseId":"brenton_job_13_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":3,"text":"Nevertheless I will speak to the Lord, and I will reason before him, if he will.","searchKeywords":["nevertheless","will","speak","the","lord","and","reason","before","him"]},{"verseId":"brenton_job_13_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":4,"text":"But ye are all bad physicians, and healers of diseases.","searchKeywords":["but","are","all","bad","physicians","and","healers","diseases"]},{"verseId":"brenton_job_13_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":5,"text":"But would that ye were silent, and it would be wisdom to you in the end.","searchKeywords":["but","would","that","were","silent","and","wisdom","you","the","end"]},{"verseId":"brenton_job_13_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":6,"text":"But hear ye the reasoning of my mouth, and attend to the judgment of my lips.","searchKeywords":["but","hear","the","reasoning","mouth","and","attend","judgment","lips"]},{"verseId":"brenton_job_13_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":7,"text":"Do ye not speak before the Lord, and utter deceit before him?","searchKeywords":["not","speak","before","the","lord","and","utter","deceit","him"]},{"verseId":"brenton_job_13_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":8,"text":"Or will ye draw back? nay, do ye yourselves be judges.","searchKeywords":["will","draw","back","nay","yourselves","judges"]},{"verseId":"brenton_job_13_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":9,"text":"For well if he would thoroughly search you: for though doing all things ye should attach yourselves to him,","searchKeywords":["for","well","would","thoroughly","search","you","though","doing","all","things","should","attach","yourselves","him"]},{"verseId":"brenton_job_13_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":10,"text":"he will not reprove you at all the less: but if moreover ye should secretly respect persons,","searchKeywords":["will","not","reprove","you","all","the","less","but","moreover","should","secretly","respect","persons"]},{"verseId":"brenton_job_13_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":11,"text":"shall not his whirlpool sweep you round, and terror from him fall upon you?","searchKeywords":["shall","not","his","whirlpool","sweep","you","round","and","terror","from","him","fall","upon"]},{"verseId":"brenton_job_13_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":12,"text":"And your glorying shall prove in the end to you like ashes, and your body of clay.","searchKeywords":["and","your","glorying","shall","prove","the","end","you","like","ashes","body","clay"]},{"verseId":"brenton_job_13_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":13,"text":"Be silent, that I may speak, and cease from anger,","searchKeywords":["silent","that","may","speak","and","cease","from","anger"]},{"verseId":"brenton_job_13_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":14,"text":"while I may take my flesh in my teeth, and put my life in my hand.","searchKeywords":["while","may","take","flesh","teeth","and","put","life","hand"]},{"verseId":"brenton_job_13_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":15,"text":"Though the Mighty One should lay hand upon me, forasmuch as he has begun, verily I will speak, and plead before him.","searchKeywords":["though","the","mighty","one","should","lay","hand","upon","forasmuch","has","begun","verily","will","speak","and","plead","before","him"]},{"verseId":"brenton_job_13_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":16,"text":"And this shall turn to me for salvation; for fraud shall have no entrance before him.","searchKeywords":["and","this","shall","turn","for","salvation","fraud","have","entrance","before","him"]},{"verseId":"brenton_job_13_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":17,"text":"Hear, hear ye my words, for I will declare in your hearing.","searchKeywords":["hear","words","for","will","declare","your","hearing"]},{"verseId":"brenton_job_13_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":18,"text":"Behold, I am near my judgment: I know that I shall appear evidently just.","searchKeywords":["behold","near","judgment","know","that","shall","appear","evidently","just"]},{"verseId":"brenton_job_13_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":19,"text":"For who is he that shall plead with me, that I should now be silent, and expire?","searchKeywords":["for","who","that","shall","plead","with","should","now","silent","and","expire"]},{"verseId":"brenton_job_13_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":20,"text":"But grant me two things: then I will not hide myself from thy face.","searchKeywords":["but","grant","two","things","then","will","not","hide","myself","from","thy","face"]},{"verseId":"brenton_job_13_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":21,"text":"Withhold hand from me: and let not thy fear terrify me.","searchKeywords":["withhold","hand","from","and","let","not","thy","fear","terrify"]},{"verseId":"brenton_job_13_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":22,"text":"Then shalt thou call, and I will hearken to thee: or thou shalt speak, and I will give thee an answer.","searchKeywords":["then","shalt","thou","call","and","will","hearken","thee","speak","give","answer"]},{"verseId":"brenton_job_13_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":23,"text":"How many are my sins and my transgressions? teach me what they are.","searchKeywords":["how","many","are","sins","and","transgressions","teach","what","they"]},{"verseId":"brenton_job_13_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":24,"text":"Wherefore hidest thou thyself from me, and deemest me thine enemy?","searchKeywords":["wherefore","hidest","thou","thyself","from","and","deemest","thine","enemy"]},{"verseId":"brenton_job_13_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":25,"text":"Wilt thou be startled , as a leaf shaken by the wind? or wilt thou set thyself against me as against grass borne upon the breeze?","searchKeywords":["wilt","thou","startled","leaf","shaken","the","wind","set","thyself","against","grass","borne","upon","breeze"]},{"verseId":"brenton_job_13_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":26,"text":"For thou hast written evil things against me, and thou hast compassed me with the sins of my youth.","searchKeywords":["for","thou","hast","written","evil","things","against","and","compassed","with","the","sins","youth"]},{"verseId":"brenton_job_13_27","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":27,"text":"And thou hast placed my foot in the stocks; and thou hast watched all my works, and hast penetrated to my heels.","searchKeywords":["and","thou","hast","placed","foot","the","stocks","watched","all","works","penetrated","heels"]},{"verseId":"brenton_job_13_28","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":13,"verse":28,"text":"that which waxes old like a bottle, or like a moth-eaten garment.","searchKeywords":["that","which","waxes","old","like","bottle","moth","eaten","garment"]}]