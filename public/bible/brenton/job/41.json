[{"verseId":"brenton_job_41_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":1,"text":"Hast thou not seen him? and hast thou not wondered at the things said ?","searchKeywords":["hast","thou","not","seen","him","and","wondered","the","things","said"]},{"verseId":"brenton_job_41_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":2,"text":"Dost thou not fear because preparation has been made by me? for who is there that resists me?","searchKeywords":["dost","thou","not","fear","because","preparation","has","been","made","for","who","there","that","resists"]},{"verseId":"brenton_job_41_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":3,"text":"Or who will resist me, and abide, since the whole under heaven is mine?","searchKeywords":["who","will","resist","and","abide","since","the","whole","under","heaven","mine"]},{"verseId":"brenton_job_41_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":4,"text":"I will not be silent because of him: though because of his power shall pity his antagonist.","searchKeywords":["will","not","silent","because","him","though","his","power","shall","pity","antagonist"]},{"verseId":"brenton_job_41_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":5,"text":"Who will open the face of his garment? and who can enter within the fold of his breast-plate?","searchKeywords":["who","will","open","the","face","his","garment","and","can","enter","within","fold","breast","plate"]},{"verseId":"brenton_job_41_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":6,"text":"Who will open the doors of his face? terror is round about his teeth.","searchKeywords":["who","will","open","the","doors","his","face","terror","round","about","teeth"]},{"verseId":"brenton_job_41_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":7,"text":"His inwards are brazen plates, and the texture of his as a smyrite stone.","searchKeywords":["his","inwards","are","brazen","plates","and","the","texture","smyrite","stone"]},{"verseId":"brenton_job_41_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":8,"text":"One cleaves fast to another, and the air cannot come between them.","searchKeywords":["one","cleaves","fast","another","and","the","air","cannot","come","between","them"]},{"verseId":"brenton_job_41_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":9,"text":"They will remain united each to the other: they are closely joined, and cannot be separated.","searchKeywords":["they","will","remain","united","each","the","other","are","closely","joined","and","cannot","separated"]},{"verseId":"brenton_job_41_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":10,"text":"At his sneezing a light shines, and his eyes are the appearance of the morning star.","searchKeywords":["his","sneezing","light","shines","and","eyes","are","the","appearance","morning","star"]},{"verseId":"brenton_job_41_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":11,"text":"Out of his mouth proceed as it were burning lamps, and as it were hearths of fire are cast abroad.","searchKeywords":["out","his","mouth","proceed","were","burning","lamps","and","hearths","fire","are","cast","abroad"]},{"verseId":"brenton_job_41_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":12,"text":"Out of his nostrils proceeds smoke of a furnace burning with fire of coals.","searchKeywords":["out","his","nostrils","proceeds","smoke","furnace","burning","with","fire","coals"]},{"verseId":"brenton_job_41_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":13,"text":"His breath is live coals, and a flame goes out of his mouth.","searchKeywords":["his","breath","live","coals","and","flame","goes","out","mouth"]},{"verseId":"brenton_job_41_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":14,"text":"And power is lodged in his neck, before him destruction runs.","searchKeywords":["and","power","lodged","his","neck","before","him","destruction","runs"]},{"verseId":"brenton_job_41_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":15,"text":"The flesh also of his body is joined together: pours upon him, he shall not be moved.","searchKeywords":["the","flesh","also","his","body","joined","together","pours","upon","him","shall","not","moved"]},{"verseId":"brenton_job_41_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":16,"text":"His heart is firm as a stone, and it stands like an unyielding anvil.","searchKeywords":["his","heart","firm","stone","and","stands","like","unyielding","anvil"]},{"verseId":"brenton_job_41_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":17,"text":"And when he turns, a terror to the four-footed wild beasts which leap upon the earth.","searchKeywords":["and","when","turns","terror","the","four","footed","wild","beasts","which","leap","upon","earth"]},{"verseId":"brenton_job_41_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":18,"text":"If spears should come against him, will effect nothing, the spear or the breast-plate.","searchKeywords":["spears","should","come","against","him","will","effect","nothing","the","spear","breast","plate"]},{"verseId":"brenton_job_41_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":19,"text":"For he considers iron as chaff, and brass as rotten wood.","searchKeywords":["for","considers","iron","chaff","and","brass","rotten","wood"]},{"verseId":"brenton_job_41_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":20,"text":"The bow of brass shall not wound him, he deems a slinger as grass.","searchKeywords":["the","bow","brass","shall","not","wound","him","deems","slinger","grass"]},{"verseId":"brenton_job_41_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":21,"text":"Mauls are counted as stubble; and he laughs to scorn the waving of the firebrand.","searchKeywords":["mauls","are","counted","stubble","and","laughs","scorn","the","waving","firebrand"]},{"verseId":"brenton_job_41_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":22,"text":"His lair is sharp points; and all the gold of the sea under him is as an immense clay.","searchKeywords":["his","lair","sharp","points","and","all","the","gold","sea","under","him","immense","clay"]},{"verseId":"brenton_job_41_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":23,"text":"He makes the deep boil like a brazen caldron; and he regards the sea as a pot of ointment,","searchKeywords":["makes","the","deep","boil","like","brazen","caldron","and","regards","sea","pot","ointment"]},{"verseId":"brenton_job_41_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":24,"text":"and the lowest part of the deep as a captive: he reckons the deep as range.","searchKeywords":["and","the","lowest","part","deep","captive","reckons","range"]},{"verseId":"brenton_job_41_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":25,"text":"There is nothing upon the earth like to him, formed to be sported with by my angels.","searchKeywords":["there","nothing","upon","the","earth","like","him","formed","sported","with","angels"]},{"verseId":"brenton_job_41_26","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":41,"verse":26,"text":"He beholds every high thing: and he is king of all that are in the waters.","searchKeywords":["beholds","every","high","thing","and","king","all","that","are","the","waters"]}]