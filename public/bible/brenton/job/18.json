[{"verseId":"brenton_job_18_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":1,"text":"Then Baldad the Sauchite answered and said,","searchKeywords":["then","baldad","the","sauchite","answered","and","said"]},{"verseId":"brenton_job_18_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":2,"text":"How long wilt thou continue? forbear, that we also may speak.","searchKeywords":["how","long","wilt","thou","continue","forbear","that","also","may","speak"]},{"verseId":"brenton_job_18_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":3,"text":"For wherefore have we been silent before thee like brutes?","searchKeywords":["for","wherefore","have","been","silent","before","thee","like","brutes"]},{"verseId":"brenton_job_18_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":4,"text":"Anger has possessed thee: for what if thou shouldest die; would under heaven be desolate? or shall the mountains be overthrown from their foundations?","searchKeywords":["anger","has","possessed","thee","for","what","thou","shouldest","die","would","under","heaven","desolate","shall","the","mountains","overthrown","from","their","foundations"]},{"verseId":"brenton_job_18_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":5,"text":"But the light of the ungodly shall be quenched, and their flame shall not go up.","searchKeywords":["but","the","light","ungodly","shall","quenched","and","their","flame","not"]},{"verseId":"brenton_job_18_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":6,"text":"His light darkness in habitation, and his lamp shall be put out with him.","searchKeywords":["his","light","darkness","habitation","and","lamp","shall","put","out","with","him"]},{"verseId":"brenton_job_18_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":7,"text":"Let the meanest of men spoil his goods, and let his counsel deceive .","searchKeywords":["let","the","meanest","men","spoil","his","goods","and","counsel","deceive"]},{"verseId":"brenton_job_18_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":8,"text":"His foot also has been caught in a snare, let it be entangled in a net.","searchKeywords":["his","foot","also","has","been","caught","snare","let","entangled","net"]},{"verseId":"brenton_job_18_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":9,"text":"And let snares come upon him: he shall strengthen those that thirst for his destruction.","searchKeywords":["and","let","snares","come","upon","him","shall","strengthen","those","that","thirst","for","his","destruction"]},{"verseId":"brenton_job_18_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":10,"text":"His snare is hid in the earth, and that which shall take him is by the path.","searchKeywords":["his","snare","hid","the","earth","and","that","which","shall","take","him","path"]},{"verseId":"brenton_job_18_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":11,"text":"Let pains destroy him round about, and let many come about him,","searchKeywords":["let","pains","destroy","him","round","about","and","many","come"]},{"verseId":"brenton_job_18_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":12,"text":"with distressing hunger: and a signal destruction has been prepared for him.","searchKeywords":["with","distressing","hunger","and","signal","destruction","has","been","prepared","for","him"]},{"verseId":"brenton_job_18_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":13,"text":"Let the soles of his feet be devoured: and death shall consume his beauty.","searchKeywords":["let","the","soles","his","feet","devoured","and","death","shall","consume","beauty"]},{"verseId":"brenton_job_18_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":14,"text":"And let health be utterly banished from his tabernacle, and let distress seize upon him with a charge from the king.","searchKeywords":["and","let","health","utterly","banished","from","his","tabernacle","distress","seize","upon","him","with","charge","the","king"]},{"verseId":"brenton_job_18_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":15,"text":"It shall dwell in his tabernacle in his night: his excellency shall be sown with brimstone.","searchKeywords":["shall","dwell","his","tabernacle","night","excellency","sown","with","brimstone"]},{"verseId":"brenton_job_18_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":16,"text":"His roots shall be dried up from beneath, and his crop shall fall away from above.","searchKeywords":["his","roots","shall","dried","from","beneath","and","crop","fall","away","above"]},{"verseId":"brenton_job_18_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":17,"text":"Let his memorial perish out of the earth, and his name shall be publicly cast out.","searchKeywords":["let","his","memorial","perish","out","the","earth","and","name","shall","publicly","cast"]},{"verseId":"brenton_job_18_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":18,"text":"Let drive him from light into darkness.","searchKeywords":["let","drive","him","from","light","into","darkness"]},{"verseId":"brenton_job_18_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":19,"text":"He shall not be known among his people, nor his house preserved on the earth.","searchKeywords":["shall","not","known","among","his","people","nor","house","preserved","the","earth"]},{"verseId":"brenton_job_18_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":20,"text":"But strangers shall dwell in his possessions: the last groaned for him, and wonder seized the first.","searchKeywords":["but","strangers","shall","dwell","his","possessions","the","last","groaned","for","him","and","wonder","seized","first"]},{"verseId":"brenton_job_18_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":18,"verse":21,"text":"These are the houses of the unrighteous, and this is the place of them that know not the Lord.","searchKeywords":["these","are","the","houses","unrighteous","and","this","place","them","that","know","not","lord"]}]