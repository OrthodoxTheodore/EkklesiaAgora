[{"verseId":"brenton_job_17_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":1,"text":"I perish, carried away by the wind, and I seek for burial, and obtain not.","searchKeywords":["perish","carried","away","the","wind","and","seek","for","burial","obtain","not"]},{"verseId":"brenton_job_17_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":2,"text":"Weary I intreat; and what have I done? and strangers have stolen my goods.","searchKeywords":["weary","intreat","and","what","have","done","strangers","stolen","goods"]},{"verseId":"brenton_job_17_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":3,"text":"Who is this? let him join hands with me.","searchKeywords":["who","this","let","him","join","hands","with"]},{"verseId":"brenton_job_17_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":4,"text":"For thou hast hid their heart from wisdom; therefore thou shalt not exalt them.","searchKeywords":["for","thou","hast","hid","their","heart","from","wisdom","therefore","shalt","not","exalt","them"]},{"verseId":"brenton_job_17_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":5,"text":"He shall promise mischief to companions: but eyes have failed for children.","searchKeywords":["shall","promise","mischief","companions","but","eyes","have","failed","for","children"]},{"verseId":"brenton_job_17_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":6,"text":"But thou hast made me a byword among the nations, and I am become a scorn to them.","searchKeywords":["but","thou","hast","made","byword","among","the","nations","and","become","scorn","them"]},{"verseId":"brenton_job_17_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":7,"text":"For my eyes are dimmed through pain; I have been grievously beset by all.","searchKeywords":["for","eyes","are","dimmed","through","pain","have","been","grievously","beset","all"]},{"verseId":"brenton_job_17_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":8,"text":"Wonder has seized true men upon this; and let the just rise up against the transgressor.","searchKeywords":["wonder","has","seized","true","men","upon","this","and","let","the","just","rise","against","transgressor"]},{"verseId":"brenton_job_17_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":9,"text":"But let the faithful hold on his own way, and let him that is pure of hands take courage.","searchKeywords":["but","let","the","faithful","hold","his","own","way","and","him","that","pure","hands","take","courage"]},{"verseId":"brenton_job_17_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":10,"text":"Howbeit, do ye all strengthen and come now, for I do not find truth in you.","searchKeywords":["howbeit","all","strengthen","and","come","now","for","not","find","truth","you"]},{"verseId":"brenton_job_17_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":11,"text":"My days have passed in groaning, and my heart-strings are broken.","searchKeywords":["days","have","passed","groaning","and","heart","strings","are","broken"]},{"verseId":"brenton_job_17_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":12,"text":"I have turned the night into day: the light is short because of darkness.","searchKeywords":["have","turned","the","night","into","day","light","short","because","darkness"]},{"verseId":"brenton_job_17_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":13,"text":"For if I remain, Hades is my habitation: and my bed has been made in darkness.","searchKeywords":["for","remain","hades","habitation","and","bed","has","been","made","darkness"]},{"verseId":"brenton_job_17_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":14,"text":"I have called upon death to be my father, and corruption my mother and sister.","searchKeywords":["have","called","upon","death","father","and","corruption","mother","sister"]},{"verseId":"brenton_job_17_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":15,"text":"Where then is yet my hope? or shall I see my good?","searchKeywords":["where","then","yet","hope","shall","see","good"]},{"verseId":"brenton_job_17_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":17,"verse":16,"text":"Will they go down with me to Hades, or shall we go down together to the tomb?","searchKeywords":["will","they","down","with","hades","shall","together","the","tomb"]}]