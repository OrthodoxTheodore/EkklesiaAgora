[{"verseId":"brenton_job_29_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":1,"text":"And Job continued and said in his parable,","searchKeywords":["and","job","continued","said","his","parable"]},{"verseId":"brenton_job_29_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":2,"text":"Oh that I were as in months past, wherein God preserved me!","searchKeywords":["that","were","months","past","wherein","god","preserved"]},{"verseId":"brenton_job_29_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":3,"text":"As when his lamp shone over my head; when by his light I walked through darkness.","searchKeywords":["when","his","lamp","shone","over","head","light","walked","through","darkness"]},{"verseId":"brenton_job_29_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":4,"text":"when I steadfastly pursued my ways, when God took care of my house.","searchKeywords":["when","steadfastly","pursued","ways","god","took","care","house"]},{"verseId":"brenton_job_29_5","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":5,"text":"When I was very fruitful, and my children were about me;","searchKeywords":["when","was","very","fruitful","and","children","were","about"]},{"verseId":"brenton_job_29_6","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":6,"text":"when my ways were moistened with butter, and the mountains flowed for me with milk.","searchKeywords":["when","ways","were","moistened","with","butter","and","the","mountains","flowed","for","milk"]},{"verseId":"brenton_job_29_7","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":7,"text":"When I went forth early in the city, and the seat was placed for me in the streets.","searchKeywords":["when","went","forth","early","the","city","and","seat","was","placed","for","streets"]},{"verseId":"brenton_job_29_8","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":8,"text":"The young men saw me, and hid themselves: and all the old men stood up.","searchKeywords":["the","young","men","saw","and","hid","themselves","all","old","stood"]},{"verseId":"brenton_job_29_9","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":9,"text":"And the great men ceased speaking, and laid their finger on their mouth.","searchKeywords":["and","the","great","men","ceased","speaking","laid","their","finger","mouth"]},{"verseId":"brenton_job_29_10","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":10,"text":"And they that heard blessed me, and their tongue clave to their throat.","searchKeywords":["and","they","that","heard","blessed","their","tongue","clave","throat"]},{"verseId":"brenton_job_29_11","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":11,"text":"For the ear heard, and blessed me; and the eye saw me, and turned aside.","searchKeywords":["for","the","ear","heard","and","blessed","eye","saw","turned","aside"]},{"verseId":"brenton_job_29_12","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":12,"text":"For I saved the poor out of the hand of the oppressor, and helped the fatherless who had no helper.","searchKeywords":["for","saved","the","poor","out","hand","oppressor","and","helped","fatherless","who","had","helper"]},{"verseId":"brenton_job_29_13","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":13,"text":"Let the blessing of the perishing one come upon me; yea, the mouth of the widow has blessed me.","searchKeywords":["let","the","blessing","perishing","one","come","upon","yea","mouth","widow","has","blessed"]},{"verseId":"brenton_job_29_14","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":14,"text":"Also I put on righteousness, and clothed myself with judgment like a mantle.","searchKeywords":["also","put","righteousness","and","clothed","myself","with","judgment","like","mantle"]},{"verseId":"brenton_job_29_15","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":15,"text":"I was the eye of the blind, and the foot of the lame.","searchKeywords":["was","the","eye","blind","and","foot","lame"]},{"verseId":"brenton_job_29_16","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":16,"text":"I was the father of the helpless; and I searched out the cause which I knew not.","searchKeywords":["was","the","father","helpless","and","searched","out","cause","which","knew","not"]},{"verseId":"brenton_job_29_17","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":17,"text":"And I broke the jaw-teeth of the unrighteous; I plucked the spoil out of the midst of their teeth.","searchKeywords":["and","broke","the","jaw","teeth","unrighteous","plucked","spoil","out","midst","their"]},{"verseId":"brenton_job_29_18","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":18,"text":"And I said, My age shall continue as the stem of a palm-tree; I shall live a long while.","searchKeywords":["and","said","age","shall","continue","the","stem","palm","tree","live","long","while"]},{"verseId":"brenton_job_29_19","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":19,"text":"root was spread out by the water, and the dew would lodge on my crop.","searchKeywords":["root","was","spread","out","the","water","and","dew","would","lodge","crop"]},{"verseId":"brenton_job_29_20","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":20,"text":"My glory was fresh in me, and my bow prospered in his hand.","searchKeywords":["glory","was","fresh","and","bow","prospered","his","hand"]},{"verseId":"brenton_job_29_21","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":21,"text":"heard me, and gave heed, and they were silent at my counsel.","searchKeywords":["heard","and","gave","heed","they","were","silent","counsel"]},{"verseId":"brenton_job_29_22","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":22,"text":"At my word they spoke not again, and they were very glad whenever I spoke to them.","searchKeywords":["word","they","spoke","not","again","and","were","very","glad","whenever","them"]},{"verseId":"brenton_job_29_23","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":23,"text":"As the thirsty earth expecting the rain, so they my speech.","searchKeywords":["the","thirsty","earth","expecting","rain","they","speech"]},{"verseId":"brenton_job_29_24","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":24,"text":"Were I to laugh on them, they would not believe ; and the light of my face has not failed.","searchKeywords":["were","laugh","them","they","would","not","believe","and","the","light","face","has","failed"]},{"verseId":"brenton_job_29_25","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":29,"verse":25,"text":"I chose out their way, and sat chief, and dwelt as a king in the midst of warriors, as one comforting mourners.","searchKeywords":["chose","out","their","way","and","sat","chief","dwelt","king","the","midst","warriors","one","comforting","mourners"]}]