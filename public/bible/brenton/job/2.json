[{"verseId":"brenton_job_2_1","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":2,"verse":1,"text":"And it came to pass on a certain day, that the angels of God came to stand before the Lord, and the devil came among them to stand before the Lord.","searchKeywords":["and","came","pass","certain","day","that","the","angels","god","stand","before","lord","devil","among","them"]},{"verseId":"brenton_job_2_2","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":2,"verse":2,"text":"And the Lord said to the devil, Whence comest thou? Then the devil said before the Lord, I am come from going through the world, and walking about the whole earth.","searchKeywords":["and","the","lord","said","devil","whence","comest","thou","then","before","come","from","going","through","world","walking","about","whole","earth"]},{"verseId":"brenton_job_2_3","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":2,"verse":3,"text":"And the Lord said to the devil, Hast thou then observed my servant Job, that there is none of upon the earth like him, a harmless, true, blameless, godly man, abstaining from all evil? and he yet cleaves to innocence, whereas thou hast told to destroy his substance without cause?","searchKeywords":["and","the","lord","said","devil","hast","thou","then","observed","servant","job","that","there","none","upon","earth","like","him","harmless","true","blameless","godly","man","abstaining","from","all","evil","yet","cleaves","innocence","whereas","told","destroy","his","substance","without","cause"]},{"verseId":"brenton_job_2_4","translationId":"brenton","testament":"OT","bookIndex":29,"bookName":"Job","bookAbbrev":"job","chapter":2,"verse":4,"text":"And the devil answered and said to the Lord, Skin for skin, all that a man has will he give as a ransom for his life.","searchKeywords":["and","the","devil","answered","sa