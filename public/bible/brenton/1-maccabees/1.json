[{"verseId":"brenton_1-maccabees_1_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":1,"text":"it happened, after that Alexander of Philip, the Macedonian, who came out of the land of Chettiim, had smitten Darius king of the Persians and Medes, that he reigned in his stead, the first over Greece,","searchKeywords":["happened","after","that","alexander","philip","the","macedonian","who","came","out","land","chettiim","had","smitten","darius","king","persians","and","medes","reigned","his","stead","first","over","greece"]},{"verseId":"brenton_1-maccabees_1_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":2,"text":"and made many wars, and won many strong holds, and slew the kings of the earth,","searchKeywords":["and","made","many","wars","won","strong","holds","slew","the","kings","earth"]},{"verseId":"brenton_1-maccabees_1_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":3,"text":"and went through to the ends of the earth, and took spoils of many nations, insomuch that the earth was quiet before him; whereupon he was exalted, and his heart was lifted up.","searchKeywords":["and","went","through","the","ends","earth","took","spoils","many","nations","insomuch","that","was","quiet","before","him","whereupon","exalted","his","heart","lifted"]},{"verseId":"brenton_1-maccabees_1_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":4,"text":"And he gathered a mighty strong host, and ruled over countries, and nations, and kings, who became tributaries unto him.","searchKeywords":["and","gathered","mighty","strong","host","ruled","over","countries","nations","kings","who","became","tributaries","unto","him"]},{"verseId":"brenton_1-maccabees_1_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":5,"text":"And after these things he fell sick, and perceived that he should die.","searchKeywords":["and","after","these","things","fell","sick","perceived","that","should","die"]},{"verseId":"brenton_1-maccabees_1_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":6,"text":"Wherefore he called his servants, such as were honourable, and had been brought up with him from his youth, and parted his kingdom among them, while he was yet alive.","searchKeywords":["wherefore","called","his","servants","such","were","honourable","and","had","been","brought","with","him","from","youth","parted","kingdom","among","them","while","was","yet","alive"]},{"verseId":"brenton_1-maccabees_1_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":7,"text":"So Alexander reigned twelve years, and died.","searchKeywords":["alexander","reigned","twelve","years","and","died"]},{"verseId":"brenton_1-maccabees_1_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":8,"text":"And his servants bare rule every one in his place.","searchKeywords":["and","his","servants","bare","rule","every","one","place"]},{"verseId":"brenton_1-maccabees_1_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":9,"text":"And after his death they all put crowns ; so did their sons after them many years: and evils were multiplied in the earth.","searchKeywords":["and","after","his","death","they","all","put","crowns","did","their","sons","them","many","years","evils","were","multiplied","the","earth"]},{"verseId":"brenton_1-maccabees_1_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":10,"text":"And there came out of them a wicked root, Antiochus Epiphanes, son of Antiochus the king, who had been an hostage at Rome, and he reigned in the hundred and thirty and seventh year of the kingdom of the Greeks.","searchKeywords":["and","there","came","out","them","wicked","root","antiochus","epiphanes","son","the","king","who","had","been","hostage","rome","reigned","hundred","thirty","seventh","year","kingdom","greeks"]},{"verseId":"brenton_1-maccabees_1_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":11,"text":"In those days went there out of Israel wicked men, who persuaded many, saying, Let us go and make a covenant with the heathen that are round about us: for since we departed from them we have had much sorrow.","searchKeywords":["those","days","went","there","out","israel","wicked","men","who","persuaded","many","saying","let","and","make","covenant","with","the","heathen","that","are","round","about","for","since","departed","from","them","have","had","much","sorrow"]},{"verseId":"brenton_1-maccabees_1_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":12,"text":"So this device pleased them well.","searchKeywords":["this","device","pleased","them","well"]},{"verseId":"brenton_1-maccabees_1_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":13,"text":"Then certain of the people were so forward herein, that they went to the king, who gave them licence to do after the ordinances of the heathen:","searchKeywords":["then","certain","the","people","were","forward","herein","that","they","went","king","who","gave","them","licence","after","ordinances","heathen"]},{"verseId":"brenton_1-maccabees_1_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":14,"text":"whereupon they built a place of exercise at Jerusalem according to the customs of the heathen:","searchKeywords":["whereupon","they","built","place","exercise","jerusalem","according","the","customs","heathen"]},{"verseId":"brenton_1-maccabees_1_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":15,"text":"and made themselves uncircumcised, and forsook the holy covenant, and joined themselves to the heathen, and were sold to do mischief.","searchKeywords":["and","made","themselves","uncircumcised","forsook","the","holy","covenant","joined","heathen","were","sold","mischief"]},{"verseId":"brenton_1-maccabees_1_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":16,"text":"Now when the kingdom was established before Antiochus, he thought to reign over Egypt, that he might have the dominion of two realms.","searchKeywords":["now","when","the","kingdom","was","established","before","antiochus","thought","reign","over","egypt","that","might","have","dominion","two","realms"]},{"verseId":"brenton_1-maccabees_1_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":17,"text":"Wherefore he entered into Egypt with a great multitude, with chariots, and elephants, and horsemen, and a great navy,","searchKeywords":["wherefore","entered","into","egypt","with","great","multitude","chariots","and","elephants","horsemen","navy"]},{"verseId":"brenton_1-maccabees_1_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":18,"text":"and made war against Ptolemee king of Egypt: but Ptolemee was afraid of him, and fled; and many were wounded to death.","searchKeywords":["and","made","war","against","ptolemee","king","egypt","but","was","afraid","him","fled","many","were","wounded","death"]},{"verseId":"brenton_1-maccabees_1_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":19,"text":"Thus they got the strong cities in the land of Egypt, and he took the spoils thereof.","searchKeywords":["thus","they","got","the","strong","cities","land","egypt","and","took","spoils","thereof"]},{"verseId":"brenton_1-maccabees_1_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":20,"text":"And after that Antiochus had smitten Egypt, he returned again in the hundred forty and third year, and went up against Israel and Jerusalem with a great multitude,","searchKeywords":["and","after","that","antiochus","had","smitten","egypt","returned","again","the","hundred","forty","third","year","went","against","israel","jerusalem","with","great","multitude"]},{"verseId":"brenton_1-maccabees_1_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":21,"text":"and entered proudly into the sanctuary, and took away the golden altar, and the candlestick of light, and all the vessels thereof,","searchKeywords":["and","entered","proudly","into","the","sanctuary","took","away","golden","altar","candlestick","light","all","vessels","thereof"]},{"verseId":"brenton_1-maccabees_1_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":22,"text":"and the table of the shewbread, and the pouring vessels, and the vials, and the censers of gold, and the veil, and the crowns, and the golden ornaments that were before the temple, all which he pulled off.","searchKeywords":["and","the","table","shewbread","pouring","vessels","vials","censers","gold","veil","crowns","golden","ornaments","that","were","before","temple","all","which","pulled","off"]},{"verseId":"brenton_1-maccabees_1_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":23,"text":"He took also the silver and the gold, and the precious vessels: also he took the hidden treasures which he found.","searchKeywords":["took","also","the","silver","and","gold","precious","vessels","hidden","treasures","which","found"]},{"verseId":"brenton_1-maccabees_1_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":24,"text":"And when he had taken all away, he went into his own land, having made a great massacre, and spoken very proudly.","searchKeywords":["and","when","had","taken","all","away","went","into","his","own","land","having","made","great","massacre","spoken","very","proudly"]},{"verseId":"brenton_1-maccabees_1_25","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":25,"text":"Therefore there was great mourning in Israel, in every place where they were;","searchKeywords":["therefore","there","was","great","mourning","israel","every","place","where","they","were"]},{"verseId":"brenton_1-maccabees_1_26","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":26,"text":"so that the princes and elders mourned, the virgins and young men were made feeble, and the beauty of women was changed.","searchKeywords":["that","the","princes","and","elders","mourned","virgins","young","men","were","made","feeble","beauty","women","was","changed"]},{"verseId":"brenton_1-maccabees_1_27","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":27,"text":"Every bridegroom took up lamentation, and she that sat in the marriage chamber was in heaviness.","searchKeywords":["every","bridegroom","took","lamentation","and","she","that","sat","the","marriage","chamber","was","heaviness"]},{"verseId":"brenton_1-maccabees_1_28","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":28,"text":"The land also was moved for the inhabitants thereof, and all the house of Jacob was covered with confusion.","searchKeywords":["the","land","also","was","moved","for","inhabitants","thereof","and","all","house","jacob","covered","with","confusion"]},{"verseId":"brenton_1-maccabees_1_29","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":29,"text":"And after two years fully expired, the king sent his chief collector of tribute unto the cities of Juda, who came unto Jerusalem with a great multitude,","searchKeywords":["and","after","two","years","fully","expired","the","king","sent","his","chief","collector","tribute","unto","cities","juda","who","came","jerusalem","with","great","multitude"]},{"verseId":"brenton_1-maccabees_1_30","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":30,"text":"and spake peaceable words unto them, was deceit: for when they had given him credence, he fell suddenly upon the city, and smote it very sore, and destroyed much people of Israel.","searchKeywords":["and","spake","peaceable","words","unto","them","was","deceit","for","when","they","had","given","him","credence","fell","suddenly","upon","the","city","smote","very","sore","destroyed","much","people","israel"]},{"verseId":"brenton_1-maccabees_1_31","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":31,"text":"And when he had taken the spoils of the city, he set it on fire, and pulled down the houses and walls thereof on every side.","searchKeywords":["and","when","had","taken","the","spoils","city","set","fire","pulled","down","houses","walls","thereof","every","side"]},{"verseId":"brenton_1-maccabees_1_32","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":32,"text":"But the women and children took they captive, and possessed the cattle.","searchKeywords":["but","the","women","and","children","took","they","captive","possessed","cattle"]},{"verseId":"brenton_1-maccabees_1_33","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":33,"text":"Then builded they the city of David with a great and strong wall, with mighty towers, and made it a stronghold for them.","searchKeywords":["then","builded","they","the","city","david","with","great","and","strong","wall","mighty","towers","made","stronghold","for","them"]},{"verseId":"brenton_1-maccabees_1_34","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":34,"text":"And they put therein a sinful nation, wicked men, and fortified therein.","searchKeywords":["and","they","put","therein","sinful","nation","wicked","men","fortified"]},{"verseId":"brenton_1-maccabees_1_35","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":35,"text":"They stored it also with armour and victuals, and when they had gathered together the spoils of Jerusalem, they laid them up there, and so they became a sore snare:","searchKeywords":["they","stored","also","with","armour","and","victuals","when","had","gathered","together","the","spoils","jerusalem","laid","them","there","became","sore","snare"]},{"verseId":"brenton_1-maccabees_1_36","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":36,"text":"for it was a place to lie in wait against the sanctuary, and an evil adversary to Israel.","searchKeywords":["for","was","place","lie","wait","against","the","sanctuary","and","evil","adversary","israel"]},{"verseId":"brenton_1-maccabees_1_37","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":37,"text":"Thus they shed innocent blood on every side of the sanctuary, and defiled it:","searchKeywords":["thus","they","shed","innocent","blood","every","side","the","sanctuary","and","defiled"]},{"verseId":"brenton_1-maccabees_1_38","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":38,"text":"insomuch that the inhabitants of Jerusalem fled because of them: whereupon was made an habitation of strangers, and became strange to those that were born in her; and her own children left her.","searchKeywords":["insomuch","that","the","inhabitants","jerusalem","fled","because","them","whereupon","was","made","habitation","strangers","and","became","strange","those","were","born","her","own","children","left"]},{"verseId":"brenton_1-maccabees_1_39","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":39,"text":"Her sanctuary was laid waste like a wilderness, her feasts were turned into mourning, her sabbaths into reproach, her honour into contempt.","searchKeywords":["her","sanctuary","was","laid","waste","like","wilderness","feasts","were","turned","into","mourning","sabbaths","reproach","honour","contempt"]},{"verseId":"brenton_1-maccabees_1_40","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":40,"text":"As had been her glory, so was her dishonour increased, and her excellency was turned into mourning.","searchKeywords":["had","been","her","glory","was","dishonour","increased","and","excellency","turned","into","mourning"]},{"verseId":"brenton_1-maccabees_1_41","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":41,"text":"Moreover king Antiochus wrote to his whole kingdom, that all should be one people,","searchKeywords":["moreover","king","antiochus","wrote","his","whole","kingdom","that","all","should","one","people"]},{"verseId":"brenton_1-maccabees_1_42","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":42,"text":"and every one should leave his laws: so all the heathen agreed according to the commandment of the king.","searchKeywords":["and","every","one","should","leave","his","laws","all","the","heathen","agreed","according","commandment","king"]},{"verseId":"brenton_1-maccabees_1_43","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":43,"text":"Yea, many also of the Israelites consented to his religion, and sacrificed unto idols, and profaned the sabbath.","searchKeywords":["yea","many","also","the","israelites","consented","his","religion","and","sacrificed","unto","idols","profaned","sabbath"]},{"verseId":"brenton_1-maccabees_1_44","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":44,"text":"For the king had sent letters by messengers unto Jerusalem and the cities of Juda, that they should follow the strange laws of the land,","searchKeywords":["for","the","king","had","sent","letters","messengers","unto","jerusalem","and","cities","juda","that","they","should","follow","strange","laws","land"]},{"verseId":"brenton_1-maccabees_1_45","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":45,"text":"and forbid burnt offerings, and sacrifice, and drink offerings, in the temple; and that they should profane the sabbaths and festival days:","searchKeywords":["and","forbid","burnt","offerings","sacrifice","drink","the","temple","that","they","should","profane","sabbaths","festival","days"]},{"verseId":"brenton_1-maccabees_1_46","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":46,"text":"and pollute the sanctuary and holy people:","searchKeywords":["and","pollute","the","sanctuary","holy","people"]},{"verseId":"brenton_1-maccabees_1_47","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":47,"text":"set up altars, and groves, and chapels of idols, and sacrifice swine's flesh, and unclean beasts:","searchKeywords":["set","altars","and","groves","chapels","idols","sacrifice","swine","flesh","unclean","beasts"]},{"verseId":"brenton_1-maccabees_1_48","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":48,"text":"that they should also leave their children uncircumcised, and make their souls abominable with all manner of uncleanness and profanation:","searchKeywords":["that","they","should","also","leave","their","children","uncircumcised","and","make","souls","abominable","with","all","manner","uncleanness","profanation"]},{"verseId":"brenton_1-maccabees_1_49","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":49,"text":"to the end they might forget the law, and change all the ordinances.","searchKeywords":["the","end","they","might","forget","law","and","change","all","ordinances"]},{"verseId":"brenton_1-maccabees_1_50","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":50,"text":"And whosoever would not do according to the commandment of the king, , he should die.","searchKeywords":["and","whosoever","would","not","according","the","commandment","king","should","die"]},{"verseId":"brenton_1-maccabees_1_51","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":51,"text":"In the selfsame manner wrote he to his whole kingdom, and appointed overseers over all the people, commanding the cities of Juda to sacrifice, city by city.","searchKeywords":["the","selfsame","manner","wrote","his","whole","kingdom","and","appointed","overseers","over","all","people","commanding","cities","juda","sacrifice","city"]},{"verseId":"brenton_1-maccabees_1_52","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":52,"text":"Then many of the people were gathered unto them, to wit, every one that forsook the law; and so they committed evils in the land;","searchKeywords":["then","many","the","people","were","gathered","unto","them","wit","every","one","that","forsook","law","and","they","committed","evils","land"]},{"verseId":"brenton_1-maccabees_1_53","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":53,"text":"and drove the Israelites into secret places, even wheresoever they could flee for succour.","searchKeywords":["and","drove","the","israelites","into","secret","places","even","wheresoever","they","could","flee","for","succour"]},{"verseId":"brenton_1-maccabees_1_54","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":54,"text":"Now the fifteenth day of Casleu, in the hundred forty and fifth year, they set up the abomination of desolation upon the altar, and builded idol altars throughout the cities of Juda on every side;","searchKeywords":["now","the","fifteenth","day","casleu","hundred","forty","and","fifth","year","they","set","abomination","desolation","upon","altar","builded","idol","altars","throughout","cities","juda","every","side"]},{"verseId":"brenton_1-maccabees_1_55","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":55,"text":"and burnt incense at the doors of their houses, and in the streets.","searchKeywords":["and","burnt","incense","the","doors","their","houses","streets"]},{"verseId":"brenton_1-maccabees_1_56","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":56,"text":"And when they had rent in pieces the books of the law which they found, they burnt them with fire.","searchKeywords":["and","when","they","had","rent","pieces","the","books","law","which","found","burnt","them","with","fire"]},{"verseId":"brenton_1-maccabees_1_57","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":57,"text":"And wheresoever was found with any the book of the testament, or if any consented to the law, the king's commandment was, that they should put him to death.","searchKeywords":["and","wheresoever","was","found","with","any","the","book","testament","consented","law","king","commandment","that","they","should","put","him","death"]},{"verseId":"brenton_1-maccabees_1_58","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":58,"text":"Thus did they by their authority unto the Israelites every month, to as many as were found in the cities.","searchKeywords":["thus","did","they","their","authority","unto","the","israelites","every","month","many","were","found","cities"]},{"verseId":"brenton_1-maccabees_1_59","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":59,"text":"Now the five and twentieth day of the month they did sacrifice upon the idol altar, which was upon the altar of God.","searchKeywords":["now","the","five","and","twentieth","day","month","they","did","sacrifice","upon","idol","altar","which","was","god"]},{"verseId":"brenton_1-maccabees_1_60","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":60,"text":"At which time according to the commandment they put to death certain women, that had caused their children to be circumcised.","searchKeywords":["which","time","according","the","commandment","they","put","death","certain","women","that","had","caused","their","children","circumcised"]},{"verseId":"brenton_1-maccabees_1_61","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":61,"text":"And they hanged the infants about their necks, and rifled their houses, and slew them that had circumcised them.","searchKeywords":["and","they","hanged","the","infants","about","their","necks","rifled","houses","slew","them","that","had","circumcised"]},{"verseId":"brenton_1-maccabees_1_62","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":62,"text":"Howbeit many in Israel were fully resolved and confirmed in themselves not to eat any unclean thing.","searchKeywords":["howbeit","many","israel","were","fully","resolved","and","confirmed","themselves","not","eat","any","unclean","thing"]},{"verseId":"brenton_1-maccabees_1_63","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":63,"text":"Wherefore they chose rather to die, that they might not be defiled with meats, and that they might not profane the holy covenant: so then they died.","searchKeywords":["wherefore","they","chose","rather","die","that","might","not","defiled","with","meats","and","profane","the","holy","covenant","then","died"]},{"verseId":"brenton_1-maccabees_1_64","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":1,"verse":64,"text":"And there was very great wrath upon Israel.","searchKeywords":["and","there","was","very","great","wrath","upon","israel"]}]