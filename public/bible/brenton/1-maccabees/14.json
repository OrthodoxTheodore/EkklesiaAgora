[{"verseId":"brenton_1-maccabees_14_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":1,"text":"Now in the hundred threescore and twelfth year king Demetrius gathered his forces together, and went into Media, to get him help to fight against Tryphon.","searchKeywords":["now","the","hundred","threescore","and","twelfth","year","king","demetrius","gathered","his","forces","together","went","into","media","get","him","help","fight","against","tryphon"]},{"verseId":"brenton_1-maccabees_14_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":2,"text":"But when Arsaces, the king of Persia and Media, heard that Demetrius was entered within his borders, he sent one of his princes to take him alive:","searchKeywords":["but","when","arsaces","the","king","persia","and","media","heard","that","demetrius","was","entered","within","his","borders","sent","one","princes","take","him","alive"]},{"verseId":"brenton_1-maccabees_14_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":3,"text":"who went and smote the host of Demetrius, and took him, and brought him to Arsaces, by whom he was put in ward.","searchKeywords":["who","went","and","smote","the","host","demetrius","took","him","brought","arsaces","whom","was","put","ward"]},{"verseId":"brenton_1-maccabees_14_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":4,"text":"As for the land , that was quiet all the days of Simon; for he sought the good of his nation in such wise, as that evermore his authority and honour pleased them well.","searchKeywords":["for","the","land","that","was","quiet","all","days","simon","sought","good","his","nation","such","wise","evermore","authority","and","honour","pleased","them","well"]},{"verseId":"brenton_1-maccabees_14_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":5,"text":"And as he was honourable in all his acts, so in this, that he took Joppe for an haven, and made an entrance to the isles of the sea,","searchKeywords":["and","was","honourable","all","his","acts","this","that","took","joppe","for","haven","made","entrance","the","isles","sea"]},{"verseId":"brenton_1-maccabees_14_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":6,"text":"and enlarged the bounds of his nation, and recovered the country,","searchKeywords":["and","enlarged","the","bounds","his","nation","recovered","country"]},{"verseId":"brenton_1-maccabees_14_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":7,"text":"and gathered together a great number of captives, and had the dominion of Gazara, and Bethsura, and the tower, out of the which he took all uncleanness, neither was there any that resisted him.","searchKeywords":["and","gathered","together","great","number","captives","had","the","dominion","gazara","bethsura","tower","out","which","took","all","uncleanness","neither","was","there","any","that","resisted","him"]},{"verseId":"brenton_1-maccabees_14_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":8,"text":"Then did they till their ground in peace, and the earth gave her increase, and the trees of the field their fruit.","searchKeywords":["then","did","they","till","their","ground","peace","and","the","earth","gave","her","increase","trees","field","fruit"]},{"verseId":"brenton_1-maccabees_14_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":9,"text":"The ancient men sat all in the streets, communing together of good things, and the young men put on glorious and warlike apparel.","searchKeywords":["the","ancient","men","sat","all","streets","communing","together","good","things","and","young","put","glorious","warlike","apparel"]},{"verseId":"brenton_1-maccabees_14_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":10,"text":"He provided victuals for the cities, and set in them all manner of munition, so that his honourable name was renowned unto the end of the world.","searchKeywords":["provided","victuals","for","the","cities","and","set","them","all","manner","munition","that","his","honourable","name","was","renowned","unto","end","world"]},{"verseId":"brenton_1-maccabees_14_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":11,"text":"He made peace in the land, and Israel rejoiced with great joy:","searchKeywords":["made","peace","the","land","and","israel","rejoiced","with","great","joy"]},{"verseId":"brenton_1-maccabees_14_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":12,"text":"for every man sat under his vine and his fig tree, and there was none to fray them:","searchKeywords":["for","every","man","sat","under","his","vine","and","fig","tree","there","was","none","fray","them"]},{"verseId":"brenton_1-maccabees_14_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":13,"text":"neither was there any left in the land to fight against them: yea, the kings themselves were overthrown in those days.","searchKeywords":["neither","was","there","any","left","the","land","fight","against","them","yea","kings","themselves","were","overthrown","those","days"]},{"verseId":"brenton_1-maccabees_14_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":14,"text":"Moreover he strengthened all those of his people that were brought low: the law he searched out; and every contemner of the law and wicked person he took away.","searchKeywords":["moreover","strengthened","all","those","his","people","that","were","brought","low","the","law","searched","out","and","every","contemner","wicked","person","took","away"]},{"verseId":"brenton_1-maccabees_14_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":15,"text":"He beautified the sanctuary, and multiplied the vessels of the temple.","searchKeywords":["beautified","the","sanctuary","and","multiplied","vessels","temple"]},{"verseId":"brenton_1-maccabees_14_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":16,"text":"Now when it was heard at Rome, and as far as Sparta, that Jonathan was dead, they were very sorry.","searchKeywords":["now","when","was","heard","rome","and","far","sparta","that","jonathan","dead","they","were","very","sorry"]},{"verseId":"brenton_1-maccabees_14_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":17,"text":"But as soon as they heard that his brother Simon was made high priest in his stead, and ruled the country, and the cities therein:","searchKeywords":["but","soon","they","heard","that","his","brother","simon","was","made","high","priest","stead","and","ruled","the","country","cities","therein"]},{"verseId":"brenton_1-maccabees_14_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":18,"text":"they wrote unto him in tables of brass, to renew the friendship and league which they had made with Judas and Jonathan his brethren:","searchKeywords":["they","wrote","unto","him","tables","brass","renew","the","friendship","and","league","which","had","made","with","judas","jonathan","his","brethren"]},{"verseId":"brenton_1-maccabees_14_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":19,"text":"which writings were read before the congregation at Jerusalem.","searchKeywords":["which","writings","were","read","before","the","congregation","jerusalem"]},{"verseId":"brenton_1-maccabees_14_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":20,"text":"And this is the copy of the letters that the Lacedemonians sent; The rulers of the Lacedemonians, with the city, unto Simon the high priest, and the elders, and priests, and residue of the people of the Jews, our brethren, greeting:","searchKeywords":["and","this","the","copy","letters","that","lacedemonians","sent","rulers","with","city","unto","simon","high","priest","elders","priests","residue","people","jews","our","brethren","greeting"]},{"verseId":"brenton_1-maccabees_14_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":21,"text":"The ambassadors that were sent unto our people certified us of your glory and honour: wherefore we were glad of their coming,","searchKeywords":["the","ambassadors","that","were","sent","unto","our","people","certified","your","glory","and","honour","wherefore","glad","their","coming"]},{"verseId":"brenton_1-maccabees_14_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":22,"text":"and did register the things that they spake in the council of the people in this manner; Numenius of Antiochus, and Antipater of Jason, the Jews' ambassadors, came unto us, to renew the friendship they had with us.","searchKeywords":["and","did","register","the","things","that","they","spake","council","people","this","manner","numenius","antiochus","antipater","jason","jews","ambassadors","came","unto","renew","friendship","had","with"]},{"verseId":"brenton_1-maccabees_14_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":23,"text":"And it pleased the people to entertain the men honourably, and to put the copy of their ambassage in public records, to the end the people of the Lacedemonians might have a memorial thereof: furthermore we have written a copy thereof unto Simon the high priest.","searchKeywords":["and","pleased","the","people","entertain","men","honourably","put","copy","their","ambassage","public","records","end","lacedemonians","might","have","memorial","thereof","furthermore","written","unto","simon","high","priest"]},{"verseId":"brenton_1-maccabees_14_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":24,"text":"After this Simon sent Numenius to Rome with a great shield of gold of a thousand pound weight, to confirm the league with them.","searchKeywords":["after","this","simon","sent","numenius","rome","with","great","shield","gold","thousand","pound","weight","confirm","the","league","them"]},{"verseId":"brenton_1-maccabees_14_25","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":25,"text":"Whereof when the people heard, they said, What thanks shall we give to Simon and his sons?","searchKeywords":["whereof","when","the","people","heard","they","said","what","thanks","shall","give","simon","and","his","sons"]},{"verseId":"brenton_1-maccabees_14_26","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":26,"text":"For he and his brethren and the house of his father have established Israel, and chased away in fight their enemies from them, and confirmed their liberty.","searchKeywords":["for","and","his","brethren","the","house","father","have","established","israel","chased","away","fight","their","enemies","from","them","confirmed","liberty"]},{"verseId":"brenton_1-maccabees_14_27","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":27,"text":"So then they wrote in tables of brass, which they set upon pillars in mount Sion: and this is the copy of the writing; The eighteenth day of Elul, in the hundred threescore and twelfth year, being the third year of Simon the high priest,","searchKeywords":["then","they","wrote","tables","brass","which","set","upon","pillars","mount","sion","and","this","the","copy","writing","eighteenth","day","elul","hundred","threescore","twelfth","year","being","third","simon","high","priest"]},{"verseId":"brenton_1-maccabees_14_28","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":28,"text":"at Saramel in the great congregation of the priests, and people, and rulers of the nation, and elders of the country, were these things notified unto us.","searchKeywords":["saramel","the","great","congregation","priests","and","people","rulers","nation","elders","country","were","these","things","notified","unto"]},{"verseId":"brenton_1-maccabees_14_29","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":29,"text":"Forasmuch as oftentimes there have been wars in the country, wherein for the maintenance of their sanctuary, and the law, Simon the son of Mattathias, of the posterity of Jarib, together with his brethren, put themselves in jeopardy, and resisting the enemies of their nation did their nation great honour:","searchKeywords":["forasmuch","oftentimes","there","have","been","wars","the","country","wherein","for","maintenance","their","sanctuary","and","law","simon","son","mattathias","posterity","jarib","together","with","his","brethren","put","themselves","jeopardy","resisting","enemies","nation","did","great","honour"]},{"verseId":"brenton_1-maccabees_14_30","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":30,"text":"(For after that Jonathan, having gathered his nation together, and been their high priest, was added to his people,","searchKeywords":["for","after","that","jonathan","having","gathered","his","nation","together","and","been","their","high","priest","was","added","people"]},{"verseId":"brenton_1-maccabees_14_31","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":31,"text":"their enemies purposed to invade their country, that they might destroy it, and lay hands on the sanctuary:","searchKeywords":["their","enemies","purposed","invade","country","that","they","might","destroy","and","lay","hands","the","sanctuary"]},{"verseId":"brenton_1-maccabees_14_32","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":32,"text":"at which time Simon rose up, and fought for his nation, and spent much of his own substance, and armed the valiant men of his nation, and gave them wages,","searchKeywords":["which","time","simon","rose","and","fought","for","his","nation","spent","much","own","substance","armed","the","valiant","men","gave","them","wages"]},{"verseId":"brenton_1-maccabees_14_33","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":33,"text":"and fortified the cities of Judea, together with Bethsura, that lieth upon the borders of Judea, where the armour of the enemies had been before; but he set a garrison of Jews there:","searchKeywords":["and","fortified","the","cities","judea","together","with","bethsura","that","lieth","upon","borders","where","armour","enemies","had","been","before","but","set","garrison","jews","there"]},{"verseId":"brenton_1-maccabees_14_34","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":34,"text":"moreover he fortified Joppe, which lieth upon the sea, and Gazara, that bordereth upon Azotus, where the enemies had dwelt before: but he placed Jews there, and furnished them with all things convenient for the reparation thereof.)","searchKeywords":["moreover","fortified","joppe","which","lieth","upon","the","sea","and","gazara","that","bordereth","azotus","where","enemies","had","dwelt","before","but","placed","jews","there","furnished","them","with","all","things","convenient","for","reparation","thereof"]},{"verseId":"brenton_1-maccabees_14_35","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":35,"text":"The people therefore, seeing the acts of Simon, and unto what glory he thought to bring his nation, made him their governor and chief priest, because he had done all these things, and for the justice and faith which he kept to his nation, and for that he sought by all means to exalt his people.","searchKeywords":["the","people","therefore","seeing","acts","simon","and","unto","what","glory","thought","bring","his","nation","made","him","their","governor","chief","priest","because","had","done","all","these","things","for","justice","faith","which","kept","that","sought","means","exalt"]},{"verseId":"brenton_1-maccabees_14_36","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":36,"text":"For in his time things prospered in his hands, so that the heathen were taken out of their country, and they also that were in the city of David in Jerusalem, who had made themselves a tower, out of which they issued, and polluted all about the sanctuary, and did much hurt in the holy place:","searchKeywords":["for","his","time","things","prospered","hands","that","the","heathen","were","taken","out","their","country","and","they","also","city","david","jerusalem","who","had","made","themselves","tower","which","issued","polluted","all","about","sanctuary","did","much","hurt","holy","place"]},{"verseId":"brenton_1-maccabees_14_37","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":37,"text":"but he placed Jews therein, and fortified it for the safety of the country and the city, and raised up the walls of Jerusalem.","searchKeywords":["but","placed","jews","therein","and","fortified","for","the","safety","country","city","raised","walls","jerusalem"]},{"verseId":"brenton_1-maccabees_14_38","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":38,"text":"King Demetrius also confirmed him in the high priesthood according to those things,","searchKeywords":["king","demetrius","also","confirmed","him","the","high","priesthood","according","those","things"]},{"verseId":"brenton_1-maccabees_14_39","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":39,"text":"and made him one of his friends, and honoured him with great honour.","searchKeywords":["and","made","him","one","his","friends","honoured","with","great","honour"]},{"verseId":"brenton_1-maccabees_14_40","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":40,"text":"For he had heard say, that the Romans had called the Jews their friends and confederates and brethren; and that they had entertained the ambassadors of Simon honourably:","searchKeywords":["for","had","heard","say","that","the","romans","called","jews","their","friends","and","confederates","brethren","they","entertained","ambassadors","simon","honourably"]},{"verseId":"brenton_1-maccabees_14_41","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":41,"text":"also that the Jews and priests were well pleased that Simon should be their governor and high priest for ever, until there should arise a faithful prophet;","searchKeywords":["also","that","the","jews","and","priests","were","well","pleased","simon","should","their","governor","high","priest","for","ever","until","there","arise","faithful","prophet"]},{"verseId":"brenton_1-maccabees_14_42","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":42,"text":"moreover that he should be their captain, and should take charge of the sanctuary, to set them over their works, and over the country, and over the armour, and over the fortresses, that, , he should take charge of the sanctuary;","searchKeywords":["moreover","that","should","their","captain","and","take","charge","the","sanctuary","set","them","over","works","country","armour","fortresses"]},{"verseId":"brenton_1-maccabees_14_43","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":43,"text":"beside this, that he should be obeyed of every man, and that all the writings in the country should be made in his name, and that he should be clothed in purple, and wear gold:","searchKeywords":["beside","this","that","should","obeyed","every","man","and","all","the","writings","country","made","his","name","clothed","purple","wear","gold"]},{"verseId":"brenton_1-maccabees_14_44","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":44,"text":"Also that it should be lawful for none of the people or priests to break any of these things, or to gainsay his words, or to gather an assembly in the country without him, or to be clothed in purple, or wear a buckle of gold:","searchKeywords":["also","that","should","lawful","for","none","the","people","priests","break","any","these","things","gainsay","his","words","gather","assembly","country","without","him","clothed","purple","wear","buckle","gold"]},{"verseId":"brenton_1-maccabees_14_45","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":45,"text":"and whosoever should do otherwise, or break any of these things, he should be punished.","searchKeywords":["and","whosoever","should","otherwise","break","any","these","things","punished"]},{"verseId":"brenton_1-maccabees_14_46","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":46,"text":"Thus it liked all the people to deal with Simon, and to do as hath been said.","searchKeywords":["thus","liked","all","the","people","deal","with","simon","and","hath","been","said"]},{"verseId":"brenton_1-maccabees_14_47","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":47,"text":"Then Simon accepted hereof, and was well pleased to be high priest, and captain and governor of the Jews and priests, and to defend them all.","searchKeywords":["then","simon","accepted","hereof","and","was","well","pleased","high","priest","captain","governor","the","jews","priests","defend","them","all"]},{"verseId":"brenton_1-maccabees_14_48","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":48,"text":"So they commanded that this writing should be put in tables of brass, and that they should be set up within the compass of the sanctuary in a conspicuous place;","searchKeywords":["they","commanded","that","this","writing","should","put","tables","brass","and","set","within","the","compass","sanctuary","conspicuous","place"]},{"verseId":"brenton_1-maccabees_14_49","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":14,"verse":49,"text":"also that the copies thereof should be laid up in the treasury, to the end that Simon and his sons might have them.","searchKeywords":["also","that","the","copies","thereof","should","laid","treasury","end","simon","and","his","sons","might","have","them"]}]