[{"verseId":"brenton_1-maccabees_16_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":1,"text":"Then came up John from Gazara, and told Simon his father what Cendebeus had done.","searchKeywords":["then","came","john","from","gazara","and","told","simon","his","father","what","cendebeus","had","done"]},{"verseId":"brenton_1-maccabees_16_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":2,"text":"Wherefore Simon called his two eldest sons, Judas and John, and said unto them, I, and my brethren, and my father's house, have ever from our youth unto this day fought against the enemies of Israel; and things have prospered so well in our hands, that we have delivered Israel oftentimes.","searchKeywords":["wherefore","simon","called","his","two","eldest","sons","judas","and","john","said","unto","them","brethren","father","house","have","ever","from","our","youth","this","day","fought","against","the","enemies","israel","things","prospered","well","hands","that","delivered","oftentimes"]},{"verseId":"brenton_1-maccabees_16_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":3,"text":"But now I am old, and ye, by mercy, are of a sufficient age: be ye instead of me and my brother, and go and fight for our nation, and the help from heaven be with you.","searchKeywords":["but","now","old","and","mercy","are","sufficient","age","instead","brother","fight","for","our","nation","the","help","from","heaven","with","you"]},{"verseId":"brenton_1-maccabees_16_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":4,"text":"So he chose out of the country twenty thousand men of war with horsemen, who went out against Cendebeus, and rested that night at Modin.","searchKeywords":["chose","out","the","country","twenty","thousand","men","war","with","horsemen","who","went","against","cendebeus","and","rested","that","night","modin"]},{"verseId":"brenton_1-maccabees_16_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":5,"text":"And when as they rose in the morning, and went into the plain, behold, a mighty great host both of footmen and horsemen came against them: howbeit there was a water brook betwixt them.","searchKeywords":["and","when","they","rose","the","morning","went","into","plain","behold","mighty","great","host","both","footmen","horsemen","came","against","them","howbeit","there","was","water","brook","betwixt"]},{"verseId":"brenton_1-maccabees_16_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":6,"text":"So he and his people pitched over against them: and when he saw that the people were afraid to go over the water brook, he went first over himself, and then the men seeing him passed through after him.","searchKeywords":["and","his","people","pitched","over","against","them","when","saw","that","the","were","afraid","water","brook","went","first","himself","then","men","seeing","him","passed","through","after"]},{"verseId":"brenton_1-maccabees_16_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":7,"text":", he divided his men, and set the horsemen in the midst of the footmen: for the enemies' horsemen were very many.","searchKeywords":["divided","his","men","and","set","the","horsemen","midst","footmen","for","enemies","were","very","many"]},{"verseId":"brenton_1-maccabees_16_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":8,"text":"Then sounded they with the holy trumpets: whereupon Cendebeus and his host were put to flight, so that many of them were slain, and the remnant gat them to the strong hold.","searchKeywords":["then","sounded","they","with","the","holy","trumpets","whereupon","cendebeus","and","his","host","were","put","flight","that","many","them","slain","remnant","gat","strong","hold"]},{"verseId":"brenton_1-maccabees_16_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":9,"text":"At that time was Judas John's brother wounded; but John still followed after them, until he came to Cedron, which had built.","searchKeywords":["that","time","was","judas","john","brother","wounded","but","still","followed","after","them","until","came","cedron","which","had","built"]},{"verseId":"brenton_1-maccabees_16_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":10,"text":"So they fled even unto the towers in the fields of Azotus; wherefore he burned it with fire: so that there were slain of them about two thousand men. Afterward he returned into the land of Judea in peace.","searchKeywords":["they","fled","even","unto","the","towers","fields","azotus","wherefore","burned","with","fire","that","there","were","slain","them","about","two","thousand","men","afterward","returned","into","land","judea","peace"]},{"verseId":"brenton_1-maccabees_16_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":11,"text":"Moreover in the plain of Jericho was Ptolemeus the of Abubus made captain, and he had abundance of silver and gold:","searchKeywords":["moreover","the","plain","jericho","was","ptolemeus","abubus","made","captain","and","had","abundance","silver","gold"]},{"verseId":"brenton_1-maccabees_16_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":12,"text":"for he was the high priest's son in law.","searchKeywords":["for","was","the","high","priest","son","law"]},{"verseId":"brenton_1-maccabees_16_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":13,"text":"Wherefore his heart being lifted up, he thought to get the country to himself, and thereupon consulted deceitfully against Simon and his sons to destroy them.","searchKeywords":["wherefore","his","heart","being","lifted","thought","get","the","country","himself","and","thereupon","consulted","deceitfully","against","simon","sons","destroy","them"]},{"verseId":"brenton_1-maccabees_16_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":14,"text":"Now Simon was visiting the cities that were in the country, and taking care for the good ordering of them; at which time he came down himself to Jericho with his sons, Mattathias and Judas, in the hundred threescore and seventeenth year, in the eleventh month, called Sabat:","searchKeywords":["now","simon","was","visiting","the","cities","that","were","country","and","taking","care","for","good","ordering","them","which","time","came","down","himself","jericho","with","his","sons","mattathias","judas","hundred","threescore","seventeenth","year","eleventh","month","called","sabat"]},{"verseId":"brenton_1-maccabees_16_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":15,"text":"where the of Abubus receiving them deceitfully into a little hold, called Docus, which he had built, made them a great banquet: howbeit he had hid men there.","searchKeywords":["where","the","abubus","receiving","them","deceitfully","into","little","hold","called","docus","which","had","built","made","great","banquet","howbeit","hid","men","there"]},{"verseId":"brenton_1-maccabees_16_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":16,"text":"So when Simon and his sons had drunk largely, Ptolemee and his men rose up, and took their weapons, and came upon Simon into the banqueting place, and slew him, and his two sons, and certain of his servants.","searchKeywords":["when","simon","and","his","sons","had","drunk","largely","ptolemee","men","rose","took","their","weapons","came","upon","into","the","banqueting","place","slew","him","two","certain","servants"]},{"verseId":"brenton_1-maccabees_16_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":17,"text":"In which doing he committed a great treachery, and recompensed evil for good.","searchKeywords":["which","doing","committed","great","treachery","and","recompensed","evil","for","good"]},{"verseId":"brenton_1-maccabees_16_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":18,"text":"Then Ptolemee wrote these things, and sent to the king, that he should send him an host to aid him, and he would deliver him the country and cities.","searchKeywords":["then","ptolemee","wrote","these","things","and","sent","the","king","that","should","send","him","host","aid","would","deliver","country","cities"]},{"verseId":"brenton_1-maccabees_16_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":19,"text":"He sent others also to Gazara to kill John: and unto the tribunes he sent letters to come unto him, that he might give them silver, and gold, and rewards.","searchKeywords":["sent","others","also","gazara","kill","john","and","unto","the","tribunes","letters","come","him","that","might","give","them","silver","gold","rewards"]},{"verseId":"brenton_1-maccabees_16_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":20,"text":"And others he sent to take Jerusalem, and the mountain of the temple.","searchKeywords":["and","others","sent","take","jerusalem","the","mountain","temple"]},{"verseId":"brenton_1-maccabees_16_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":21,"text":"Now one had run afore to Gazara, and told John that his father and brethren were slain, and, hath sent to slay thee also.","searchKeywords":["now","one","had","run","afore","gazara","and","told","john","that","his","father","brethren","were","slain","hath","sent","slay","thee","also"]},{"verseId":"brenton_1-maccabees_16_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":22,"text":"Hereof when he heard, he was sore astonished: so he laid hands on them that were come to destroy him, and slew them; for he knew that they sought to make him away.","searchKeywords":["hereof","when","heard","was","sore","astonished","laid","hands","them","that","were","come","destroy","him","and","slew","for","knew","they","sought","make","away"]},{"verseId":"brenton_1-maccabees_16_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":23,"text":"As concerning the rest of the acts of John, and his wars, and worthy deeds which he did, and the building of the walls which he made, and his doings,","searchKeywords":["concerning","the","rest","acts","john","and","his","wars","worthy","deeds","which","did","building","walls","made","doings"]},{"verseId":"brenton_1-maccabees_16_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":16,"verse":24,"text":"behold, these are written in the chronicles of his priesthood, from the time he was made high priest after his father.","searchKeywords":["behold","these","are","written","the","chronicles","his","priesthood","from","time","was","made","high","priest","after","father"]}]