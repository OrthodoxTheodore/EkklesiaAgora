[{"verseId":"brenton_1-maccabees_5_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":1,"text":"Now when the nations round about heard that the altar was built, and the sanctuary renewed as before, it displeased them very much.","searchKeywords":["now","when","the","nations","round","about","heard","that","altar","was","built","and","sanctuary","renewed","before","displeased","them","very","much"]},{"verseId":"brenton_1-maccabees_5_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":2,"text":"Wherefore they thought to destroy the generation of Jacob that was among them, and thereupon they began to slay and destroy the people.","searchKeywords":["wherefore","they","thought","destroy","the","generation","jacob","that","was","among","them","and","thereupon","began","slay","people"]},{"verseId":"brenton_1-maccabees_5_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":3,"text":"Then Judas fought against the children of Esau in Idumea at Acrabattine, because they besieged Israel: and he gave them a great overthrow, and abated their courage, and took their spoils.","searchKeywords":["then","judas","fought","against","the","children","esau","idumea","acrabattine","because","they","besieged","israel","and","gave","them","great","overthrow","abated","their","courage","took","spoils"]},{"verseId":"brenton_1-maccabees_5_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":4,"text":"Also he remembered the injury of the children of Bæan, who had been a snare and an offence unto the people, in that they lay in wait for them in the ways.","searchKeywords":["also","remembered","the","injury","children","who","had","been","snare","and","offence","unto","people","that","they","lay","wait","for","them","ways"]},{"verseId":"brenton_1-maccabees_5_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":5,"text":"He shut them up therefore in the towers, and encamped against them, and destroyed them utterly, and burned the towers of that with fire, and all that were therein.","searchKeywords":["shut","them","therefore","the","towers","and","encamped","against","destroyed","utterly","burned","that","with","fire","all","were","therein"]},{"verseId":"brenton_1-maccabees_5_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":6,"text":"Afterward he passed over to the children of Ammon, where he found a mighty power, and much people, with Timotheus their captain.","searchKeywords":["afterward","passed","over","the","children","ammon","where","found","mighty","power","and","much","people","with","timotheus","their","captain"]},{"verseId":"brenton_1-maccabees_5_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":7,"text":"So he fought many battles with them, till at length they were discomfited before him; and he smote them.","searchKeywords":["fought","many","battles","with","them","till","length","they","were","discomfited","before","him","and","smote"]},{"verseId":"brenton_1-maccabees_5_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":8,"text":"And when he had taken Jazer, with the towns belonging thereto, he returned into Judea.","searchKeywords":["and","when","had","taken","jazer","with","the","towns","belonging","thereto","returned","into","judea"]},{"verseId":"brenton_1-maccabees_5_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":9,"text":"Then the heathen that were at Galaad assembled themselves together against the Israelites that were in their quarters, to destroy them: but they fled to the fortress of Dathema,","searchKeywords":["then","the","heathen","that","were","galaad","assembled","themselves","together","against","israelites","their","quarters","destroy","them","but","they","fled","fortress","dathema"]},{"verseId":"brenton_1-maccabees_5_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":10,"text":"and sent letters unto Judas and his brethren, saying, The heathen that are round about us are assembled together against us to destroy us:","searchKeywords":["and","sent","letters","unto","judas","his","brethren","saying","the","heathen","that","are","round","about","assembled","together","against","destroy"]},{"verseId":"brenton_1-maccabees_5_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":11,"text":"and they are preparing to come and take the fortress where unto we are fled, Timotheus being captain of their host.","searchKeywords":["and","they","are","preparing","come","take","the","fortress","where","unto","fled","timotheus","being","captain","their","host"]},{"verseId":"brenton_1-maccabees_5_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":12,"text":"Come now therefore, and deliver us from their hands, for many of us are slain:","searchKeywords":["come","now","therefore","and","deliver","from","their","hands","for","many","are","slain"]},{"verseId":"brenton_1-maccabees_5_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":13,"text":"yea, all our brethren that were in the places of Tobie are put to death: their wives and their children also they have carried away captives, and borne away their stuff; and they have destroyed there about a thousand men.","searchKeywords":["yea","all","our","brethren","that","were","the","places","tobie","are","put","death","their","wives","and","children","also","they","have","carried","away","captives","borne","stuff","destroyed","there","about","thousand","men"]},{"verseId":"brenton_1-maccabees_5_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":14,"text":"While these letters were yet being read, behold, there came other messengers from Galilee with their clothes rent, who reported on this wise,","searchKeywords":["while","these","letters","were","yet","being","read","behold","there","came","other","messengers","from","galilee","with","their","clothes","rent","who","reported","this","wise"]},{"verseId":"brenton_1-maccabees_5_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":15,"text":"saying that they of Ptolemais, and of Tyrus, and Sidon, and all Galilee of the Gentiles, were assembled together against them to consume us.","searchKeywords":["saying","that","they","ptolemais","and","tyrus","sidon","all","galilee","the","gentiles","were","assembled","together","against","them","consume"]},{"verseId":"brenton_1-maccabees_5_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":16,"text":"Now when Judas and the people heard these words, there assembled a great congregation together, to consult what they should do for their brethren, that were in trouble, and assaulted of them.","searchKeywords":["now","when","judas","and","the","people","heard","these","words","there","assembled","great","congregation","together","consult","what","they","should","for","their","brethren","that","were","trouble","assaulted","them"]},{"verseId":"brenton_1-maccabees_5_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":17,"text":"Then said Judas unto Simon his brother, Choose thee out men, and go and deliver thy brethren that are in Galilee, for I and Jonathan my brother will go into the country of Galaad.","searchKeywords":["then","said","judas","unto","simon","his","brother","choose","thee","out","men","and","deliver","thy","brethren","that","are","galilee","for","jonathan","will","into","the","country","galaad"]},{"verseId":"brenton_1-maccabees_5_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":18,"text":"So he left Joseph the of Zacharias, and Azarias, captains of the people, with the remnant of the host in Judea to keep it.","searchKeywords":["left","joseph","the","zacharias","and","azarias","captains","people","with","remnant","host","judea","keep"]},{"verseId":"brenton_1-maccabees_5_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":19,"text":"Unto whom he gave commandment, saying, Take ye the charge of this people, and see that ye make not war against the heathen until the time that we come again.","searchKeywords":["unto","whom","gave","commandment","saying","take","the","charge","this","people","and","see","that","make","not","war","against","heathen","until","time","come","again"]},{"verseId":"brenton_1-maccabees_5_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":20,"text":"Now unto Simon were given three thousand men to go into Galilee, and unto Judas eight thousand men for the country of Galaad.","searchKeywords":["now","unto","simon","were","given","three","thousand","men","into","galilee","and","judas","eight","for","the","country","galaad"]},{"verseId":"brenton_1-maccabees_5_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":21,"text":"Then went Simon into Galilee, where he fought many battles with the heathen, so that the heathen were discomfited by him.","searchKeywords":["then","went","simon","into","galilee","where","fought","many","battles","with","the","heathen","that","were","discomfited","him"]},{"verseId":"brenton_1-maccabees_5_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":22,"text":"And he pursued them unto the gate of Ptolemais; and there were slain of the heathen about three thousand men, whose spoils he took.","searchKeywords":["and","pursued","them","unto","the","gate","ptolemais","there","were","slain","heathen","about","three","thousand","men","whose","spoils","took"]},{"verseId":"brenton_1-maccabees_5_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":23,"text":"And those that were in Galilee, and in Arbattis, with their wives and their children, and all that they had, took he away , and brought them into Judea with great joy.","searchKeywords":["and","those","that","were","galilee","arbattis","with","their","wives","children","all","they","had","took","away","brought","them","into","judea","great","joy"]},{"verseId":"brenton_1-maccabees_5_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":24,"text":"Judas Maccabeus also and his brother Jonathan went over Jordan, and travelled three days' journey in the wilderness,","searchKeywords":["judas","maccabeus","also","and","his","brother","jonathan","went","over","jordan","travelled","three","days","journey","the","wilderness"]},{"verseId":"brenton_1-maccabees_5_25","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":25,"text":"where they met with the Nabathites, who came unto them in a peaceable manner, and told them every thing that had happened to their brethren in the land of Galaad:","searchKeywords":["where","they","met","with","the","nabathites","who","came","unto","them","peaceable","manner","and","told","every","thing","that","had","happened","their","brethren","land","galaad"]},{"verseId":"brenton_1-maccabees_5_26","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":26,"text":"and how that many of them were shut up in Bosora, and Bosor, and Alema, Casphor, Maked, and Carnaim; all these cities are strong and great:","searchKeywords":["and","how","that","many","them","were","shut","bosora","bosor","alema","casphor","maked","carnaim","all","these","cities","are","strong","great"]},{"verseId":"brenton_1-maccabees_5_27","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":27,"text":"and that they were shut up in the rest of the cities of the country of Galaad, and that against to morrow they had appointed to bring their host against the forts, and to take them, and to destroy them all in one day.","searchKeywords":["and","that","they","were","shut","the","rest","cities","country","galaad","against","morrow","had","appointed","bring","their","host","forts","take","them","destroy","all","one","day"]},{"verseId":"brenton_1-maccabees_5_28","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":28,"text":"Hereupon Judas and his host turned suddenly by the way of the wilderness unto Bosora; and when he had won the city, he slew all the males with the edge of the sword, and took all their spoils, and burned the city with fire.","searchKeywords":["hereupon","judas","and","his","host","turned","suddenly","the","way","wilderness","unto","bosora","when","had","won","city","slew","all","males","with","edge","sword","took","their","spoils","burned","fire"]},{"verseId":"brenton_1-maccabees_5_29","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":29,"text":"From whence he removed by night, and went till he came to the fortress.","searchKeywords":["from","whence","removed","night","and","went","till","came","the","fortress"]},{"verseId":"brenton_1-maccabees_5_30","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":30,"text":"And betimes in the morning they looked up, and, behold, there was an innumerable people bearing ladders and other engines of war, to take the fortress: for they assaulted them.","searchKeywords":["and","betimes","the","morning","they","looked","behold","there","was","innumerable","people","bearing","ladders","other","engines","war","take","fortress","for","assaulted","them"]},{"verseId":"brenton_1-maccabees_5_31","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":31,"text":"When Judas therefore saw that the battle was begun, and that the cry of the city went up to heaven, with trumpets, and a great sound,","searchKeywords":["when","judas","therefore","saw","that","the","battle","was","begun","and","cry","city","went","heaven","with","trumpets","great","sound"]},{"verseId":"brenton_1-maccabees_5_32","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":32,"text":"he said unto his host, Fight this day for your brethren.","searchKeywords":["said","unto","his","host","fight","this","day","for","your","brethren"]},{"verseId":"brenton_1-maccabees_5_33","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":33,"text":"So he went forth behind them in three companies, who sounded their trumpets, and cried with prayer.","searchKeywords":["went","forth","behind","them","three","companies","who","sounded","their","trumpets","and","cried","with","prayer"]},{"verseId":"brenton_1-maccabees_5_34","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":34,"text":"Then the host of Timotheus, knowing that it was Maccabeus, fled from him: wherefore he smote them with a great slaughter; so that there were killed of them that day about eight thousand men.","searchKeywords":["then","the","host","timotheus","knowing","that","was","maccabeus","fled","from","him","wherefore","smote","them","with","great","slaughter","there","were","killed","day","about","eight","thousand","men"]},{"verseId":"brenton_1-maccabees_5_35","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":35,"text":"This done, Judas turned aside to Maspha; and after he had assaulted it, he took it, and slew all the males therein, and received the spoils thereof, and burnt it with fire.","searchKeywords":["this","done","judas","turned","aside","maspha","and","after","had","assaulted","took","slew","all","the","males","therein","received","spoils","thereof","burnt","with","fire"]},{"verseId":"brenton_1-maccabees_5_36","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":36,"text":"From thence went he, and took Casphon, Maged, Bosor, and the other cities of the country of Galaad.","searchKeywords":["from","thence","went","and","took","casphon","maged","bosor","the","other","cities","country","galaad"]},{"verseId":"brenton_1-maccabees_5_37","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":37,"text":"After these things gathered Timotheus another host, and encamped against Raphon beyond the brook.","searchKeywords":["after","these","things","gathered","timotheus","another","host","and","encamped","against","raphon","beyond","the","brook"]},{"verseId":"brenton_1-maccabees_5_38","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":38,"text":"So Judas sent to espy the host, who brought him word, saying, All the heathen that be round about us are assembled unto them, even a very great host.","searchKeywords":["judas","sent","espy","the","host","who","brought","him","word","saying","all","heathen","that","round","about","are","assembled","unto","them","even","very","great"]},{"verseId":"brenton_1-maccabees_5_39","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":39,"text":"He hath also hired the Arabians to help them, and they have pitched their tents beyond the brook, ready to come and fight against thee. Upon this Judas went to meet them.","searchKeywords":["hath","also","hired","the","arabians","help","them","and","they","have","pitched","their","tents","beyond","brook","ready","come","fight","against","thee","upon","this","judas","went","meet"]},{"verseId":"brenton_1-maccabees_5_40","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":40,"text":"Then Timotheus said unto the captains of his host, When Judas and his host come near the brook, if he pass over first unto us, we shall not be able to withstand him; for he will mightily prevail against us:","searchKeywords":["then","timotheus","said","unto","the","captains","his","host","when","judas","and","come","near","brook","pass","over","first","shall","not","able","withstand","him","for","will","mightily","prevail","against"]},{"verseId":"brenton_1-maccabees_5_41","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":41,"text":"but if he be afraid, and camp beyond the river, we shall go over unto him, and prevail against him.","searchKeywords":["but","afraid","and","camp","beyond","the","river","shall","over","unto","him","prevail","against"]},{"verseId":"brenton_1-maccabees_5_42","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":42,"text":"Now when Judas came near the brook, he caused the scribes of the people to remain by the brook: unto whom he gave commandment, saying, Suffer no man to remain in the camp, but let all come to the battle.","searchKeywords":["now","when","judas","came","near","the","brook","caused","scribes","people","remain","unto","whom","gave","commandment","saying","suffer","man","camp","but","let","all","come","battle"]},{"verseId":"brenton_1-maccabees_5_43","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":43,"text":"So he went first over unto them, and all the people after him: then all the heathen, being discomfited before him, cast away their weapons, and fled unto the temple that was at Carnaim.","searchKeywords":["went","first","over","unto","them","and","all","the","people","after","him","then","heathen","being","discomfited","before","cast","away","their","weapons","fled","temple","that","was","carnaim"]},{"verseId":"brenton_1-maccabees_5_44","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":44,"text":"But they took the city, and burned the temple with all that were therein. Thus was Carnaim subdued, neither could they stand any longer before Judas.","searchKeywords":["but","they","took","the","city","and","burned","temple","with","all","that","were","therein","thus","was","carnaim","subdued","neither","could","stand","any","longer","before","judas"]},{"verseId":"brenton_1-maccabees_5_45","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":45,"text":"Then Judas gathered together all the Israelites that were in the country of Galaad, from the least unto the greatest, even their wives, and their children, and their stuff, a very great host, to the end they might come into the land of Judea.","searchKeywords":["then","judas","gathered","together","all","the","israelites","that","were","country","galaad","from","least","unto","greatest","even","their","wives","and","children","stuff","very","great","host","end","they","might","come","into","land","judea"]},{"verseId":"brenton_1-maccabees_5_46","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":46,"text":"Now when they came unto Ephron (this was a great city in the way as they should go, very well fortified) they could not turn from it, either on the right hand or the left, but must needs pass through the midst of it.","searchKeywords":["now","when","they","came","unto","ephron","this","was","great","city","the","way","should","very","well","fortified","could","not","turn","from","either","right","hand","left","but","must","needs","pass","through","midst"]},{"verseId":"brenton_1-maccabees_5_47","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":47,"text":"Then they of the city shut them out, and stopped up the gates with stones.","searchKeywords":["then","they","the","city","shut","them","out","and","stopped","gates","with","stones"]},{"verseId":"brenton_1-maccabees_5_48","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":48,"text":"Whereupon Judas sent unto them in peaceable manner, saying, Let us pass through your land to go into our own country, and none shall do you any hurt; we will only pass through on foot: howbeit they would not open unto him.","searchKeywords":["whereupon","judas","sent","unto","them","peaceable","manner","saying","let","pass","through","your","land","into","our","own","country","and","none","shall","you","any","hurt","will","only","foot","howbeit","they","would","not","open","him"]},{"verseId":"brenton_1-maccabees_5_49","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":49,"text":"Wherefore Judas commanded a proclamation to be made throughout the host, that every man should pitch his tent in the place where he was.","searchKeywords":["wherefore","judas","commanded","proclamation","made","throughout","the","host","that","every","man","should","pitch","his","tent","place","where","was"]},{"verseId":"brenton_1-maccabees_5_50","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":50,"text":"So the soldiers pitched, and assaulted the city all that day and all that night, till at the length the city was delivered into his hands:","searchKeywords":["the","soldiers","pitched","and","assaulted","city","all","that","day","night","till","length","was","delivered","into","his","hands"]},{"verseId":"brenton_1-maccabees_5_51","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":51,"text":"who then slew all the males with the edge of the sword, and rased the city, and took the spoils thereof, and passed through the city over them that were slain.","searchKeywords":["who","then","slew","all","the","males","with","edge","sword","and","rased","city","took","spoils","thereof","passed","through","over","them","that","were","slain"]},{"verseId":"brenton_1-maccabees_5_52","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":52,"text":"After this went they over Jordan into the great plain before Bethsan.","searchKeywords":["after","this","went","they","over","jordan","into","the","great","plain","before","bethsan"]},{"verseId":"brenton_1-maccabees_5_53","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":53,"text":"And Judas gathered together those that came behind, and exhorted the people all the way through, till they came into the land of Judea.","searchKeywords":["and","judas","gathered","together","those","that","came","behind","exhorted","the","people","all","way","through","till","they","into","land","judea"]},{"verseId":"brenton_1-maccabees_5_54","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":54,"text":"So they went up to mount Sion with joy and gladness, where they offered burnt offerings, because not one of them was slain until they had returned in peace.","searchKeywords":["they","went","mount","sion","with","joy","and","gladness","where","offered","burnt","offerings","because","not","one","them","was","slain","until","had","returned","peace"]},{"verseId":"brenton_1-maccabees_5_55","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":55,"text":"Now what time as Judas and Jonathan were in the land of Galaad, and Simon his brother in Galilee before Ptolemais,","searchKeywords":["now","what","time","judas","and","jonathan","were","the","land","galaad","simon","his","brother","galilee","before","ptolemais"]},{"verseId":"brenton_1-maccabees_5_56","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":56,"text":"Joseph the of Zacharias, and Azarias, captains of the garrisons, heard of the valiant acts and warlike deeds which they had done.","searchKeywords":["joseph","the","zacharias","and","azarias","captains","garrisons","heard","valiant","acts","warlike","deeds","which","they","had","done"]},{"verseId":"brenton_1-maccabees_5_57","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":57,"text":"Wherefore they said, Let us also get us a name, and go fight against the heathen that are round about us.","searchKeywords":["wherefore","they","said","let","also","get","name","and","fight","against","the","heathen","that","are","round","about"]},{"verseId":"brenton_1-maccabees_5_58","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":58,"text":"So when they had given charge unto the garrison that was with them, they went toward Jamnia.","searchKeywords":["when","they","had","given","charge","unto","the","garrison","that","was","with","them","went","toward","jamnia"]},{"verseId":"brenton_1-maccabees_5_59","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":59,"text":"Then came Gorgias and his men out of the city to fight against them.","searchKeywords":["then","came","gorgias","and","his","men","out","the","city","fight","against","them"]},{"verseId":"brenton_1-maccabees_5_60","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":60,"text":"And so it was, that Joseph and Azarias were put to flight, and pursued unto the borders of Judea: and there were slain that day of the people of Israel about two thousand men.","searchKeywords":["and","was","that","joseph","azarias","were","put","flight","pursued","unto","the","borders","judea","there","slain","day","people","israel","about","two","thousand","men"]},{"verseId":"brenton_1-maccabees_5_61","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":61,"text":"Thus was there a great overthrow among the children of Israel, because they were not obedient unto Judas and his brethren, but thought to do some valiant act.","searchKeywords":["thus","was","there","great","overthrow","among","the","children","israel","because","they","were","not","obedient","unto","judas","and","his","brethren","but","thought","some","valiant","act"]},{"verseId":"brenton_1-maccabees_5_62","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":62,"text":"Moreover these men came not of the seed of those, by whose hand deliverance was given unto Israel.","searchKeywords":["moreover","these","men","came","not","the","seed","those","whose","hand","deliverance","was","given","unto","israel"]},{"verseId":"brenton_1-maccabees_5_63","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":63,"text":"Howbeit the man Judas and his brethren were greatly renowned in the sight of all Israel, and of all the heathen, wheresoever their name was heard of:","searchKeywords":["howbeit","the","man","judas","and","his","brethren","were","greatly","renowned","sight","all","israel","heathen","wheresoever","their","name","was","heard"]},{"verseId":"brenton_1-maccabees_5_64","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":64,"text":"insomuch as the people assembled unto them with joyful acclamations.","searchKeywords":["insomuch","the","people","assembled","unto","them","with","joyful","acclamations"]},{"verseId":"brenton_1-maccabees_5_65","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":65,"text":"Afterward went Judas forth with his brethren, and fought against the children of Esau in the land toward the south, where he smote Hebron, and the towns thereof, and pulled down the fortress of it, and burned the towers thereof round about.","searchKeywords":["afterward","went","judas","forth","with","his","brethren","and","fought","against","the","children","esau","land","toward","south","where","smote","hebron","towns","thereof","pulled","down","fortress","burned","towers","round","about"]},{"verseId":"brenton_1-maccabees_5_66","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":66,"text":"From thence he removed to go into the land of the Philistines, and passed through Samaria.","searchKeywords":["from","thence","removed","into","the","land","philistines","and","passed","through","samaria"]},{"verseId":"brenton_1-maccabees_5_67","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":67,"text":"At that time certain priests, desirous to shew their valour, were slain in battle, for that they went out to fight unadvisedly.","searchKeywords":["that","time","certain","priests","desirous","shew","their","valour","were","slain","battle","for","they","went","out","fight","unadvisedly"]},{"verseId":"brenton_1-maccabees_5_68","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":5,"verse":68,"text":"So Judas turned to Azotus in the land of the Philistines, and when he had pulled down their altars, and burned their carved images with fire, and spoiled their cities, he returned into the land of Judea.","searchKeywords":["judas","turned","azotus","the","land","philistines","and","when","had","pulled","down","their","altars","burned","carved","images","with","fire","spoiled","cities","returned","into","judea"]}]