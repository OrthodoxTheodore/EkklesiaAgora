[{"verseId":"brenton_1-maccabees_12_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":1,"text":"Now when Jonathan saw that the time served him, he chose certain men, and sent them to Rome, for to confirm and renew the friendship that they had with them.","searchKeywords":["now","when","jonathan","saw","that","the","time","served","him","chose","certain","men","and","sent","them","rome","for","confirm","renew","friendship","they","had","with"]},{"verseId":"brenton_1-maccabees_12_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":2,"text":"He sent letters also to the Lacedemonians, and to other places, for the same purpose.","searchKeywords":["sent","letters","also","the","lacedemonians","and","other","places","for","same","purpose"]},{"verseId":"brenton_1-maccabees_12_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":3,"text":"So they went unto Rome, and entered into the senate, and said, Jonathan the high priest, and the people of the Jews, sent us unto you, to the end ye should renew the friendship, which ye had with them, and league, as in former time.","searchKeywords":["they","went","unto","rome","and","entered","into","the","senate","said","jonathan","high","priest","people","jews","sent","you","end","should","renew","friendship","which","had","with","them","league","former","time"]},{"verseId":"brenton_1-maccabees_12_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":4,"text":"Upon this gave them letters unto the governors of every place, that they should bring them into the land of Judea peaceably.","searchKeywords":["upon","this","gave","them","letters","unto","the","governors","every","place","that","they","should","bring","into","land","judea","peaceably"]},{"verseId":"brenton_1-maccabees_12_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":5,"text":"And this is the copy of the letters which Jonathan wrote to the Lacedemonians:","searchKeywords":["and","this","the","copy","letters","which","jonathan","wrote","lacedemonians"]},{"verseId":"brenton_1-maccabees_12_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":6,"text":"Jonathan the high priest, and the elders of the nation, and the priests, and the other people of the Jews, unto the Lacedemonians their brethren send greeting:","searchKeywords":["jonathan","the","high","priest","and","elders","nation","priests","other","people","jews","unto","lacedemonians","their","brethren","send","greeting"]},{"verseId":"brenton_1-maccabees_12_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":7,"text":"There were letters sent in times past unto Onias the high priest from Darius, who reigned then among you, to signify that ye are our brethren, as the copy here underwritten doth specify.","searchKeywords":["there","were","letters","sent","times","past","unto","onias","the","high","priest","from","darius","who","reigned","then","among","you","signify","that","are","our","brethren","copy","here","underwritten","doth","specify"]},{"verseId":"brenton_1-maccabees_12_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":8,"text":"At which time Onias entreated the ambassador that was sent honourably, and received the letters, wherein declaration was made of the league and friendship.","searchKeywords":["which","time","onias","entreated","the","ambassador","that","was","sent","honourably","and","received","letters","wherein","declaration","made","league","friendship"]},{"verseId":"brenton_1-maccabees_12_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":9,"text":"Therefore we also, albeit we need none of these things, for that we have the holy books of scripture in our hands to comfort us,","searchKeywords":["therefore","also","albeit","need","none","these","things","for","that","have","the","holy","books","scripture","our","hands","comfort"]},{"verseId":"brenton_1-maccabees_12_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":10,"text":"have nevertheless attempted to send unto you for the renewing of brotherhood and friendship, lest we should become strangers unto you altogether: for there is a long time passed since ye sent unto us.","searchKeywords":["have","nevertheless","attempted","send","unto","you","for","the","renewing","brotherhood","and","friendship","lest","should","become","strangers","altogether","there","long","time","passed","since","sent"]},{"verseId":"brenton_1-maccabees_12_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":11,"text":"We therefore at all times without ceasing, both in our feasts, and other convenient days, do remember you in the sacrifices which we offer, and in our prayers, as reason is, and as it becometh us to think upon our brethren:","searchKeywords":["therefore","all","times","without","ceasing","both","our","feasts","and","other","convenient","days","remember","you","the","sacrifices","which","offer","prayers","reason","becometh","think","upon","brethren"]},{"verseId":"brenton_1-maccabees_12_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":12,"text":"and we are right glad of your honour.","searchKeywords":["and","are","right","glad","your","honour"]},{"verseId":"brenton_1-maccabees_12_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":13,"text":"As for ourselves, we have had great troubles and wars on every side, forsomuch as the kings that are round about us have fought against us.","searchKeywords":["for","ourselves","have","had","great","troubles","and","wars","every","side","forsomuch","the","kings","that","are","round","about","fought","against"]},{"verseId":"brenton_1-maccabees_12_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":14,"text":"Howbeit we would not be troublesome unto you, nor to others of our confederates and friends, in these wars:","searchKeywords":["howbeit","would","not","troublesome","unto","you","nor","others","our","confederates","and","friends","these","wars"]},{"verseId":"brenton_1-maccabees_12_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":15,"text":"for we have help from heaven that succoureth us, so as we are delivered from our enemies, and our enemies are brought under foot.","searchKeywords":["for","have","help","from","heaven","that","succoureth","are","delivered","our","enemies","and","brought","under","foot"]},{"verseId":"brenton_1-maccabees_12_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":16,"text":"For this cause we chose Numenius of Antiochus, and Antipater of Jason, and sent them unto the Romans, to renew the amity that we had with them, and the former league.","searchKeywords":["for","this","cause","chose","numenius","antiochus","and","antipater","jason","sent","them","unto","the","romans","renew","amity","that","had","with","former","league"]},{"verseId":"brenton_1-maccabees_12_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":17,"text":"We commanded them also to go unto you, and to salute you, and to deliver you our letters concerning the renewing of our brotherhood.","searchKeywords":["commanded","them","also","unto","you","and","salute","deliver","our","letters","concerning","the","renewing","brotherhood"]},{"verseId":"brenton_1-maccabees_12_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":18,"text":"Wherefore now ye shall do well to give us an answer thereto.","searchKeywords":["wherefore","now","shall","well","give","answer","thereto"]},{"verseId":"brenton_1-maccabees_12_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":19,"text":"And this is the copy of the letters which Oniares sent.","searchKeywords":["and","this","the","copy","letters","which","oniares","sent"]},{"verseId":"brenton_1-maccabees_12_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":20,"text":"Areus king of the Lacedemonians to Onias the high priest, greeting:","searchKeywords":["areus","king","the","lacedemonians","onias","high","priest","greeting"]},{"verseId":"brenton_1-maccabees_12_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":21,"text":"It is found in writing, that the Lacedemonians and Jews are brethren, and that they are of the stock of Abraham:","searchKeywords":["found","writing","that","the","lacedemonians","and","jews","are","brethren","they","stock","abraham"]},{"verseId":"brenton_1-maccabees_12_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":22,"text":"now therefore, since this is come to our knowledge, ye shall do well to write unto us of your prosperity.","searchKeywords":["now","therefore","since","this","come","our","knowledge","shall","well","write","unto","your","prosperity"]},{"verseId":"brenton_1-maccabees_12_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":23,"text":"We do write back again to you, that your cattle and goods are our's, and our's are your's. We do command therefore to make report unto you on this wise.","searchKeywords":["write","back","again","you","that","your","cattle","and","goods","are","our","command","therefore","make","report","unto","this","wise"]},{"verseId":"brenton_1-maccabees_12_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":24,"text":"Now when Jonathan heard that Demetrius' princes were come to fight against him with a greater host than afore,","searchKeywords":["now","when","jonathan","heard","that","demetrius","princes","were","come","fight","against","him","with","greater","host","than","afore"]},{"verseId":"brenton_1-maccabees_12_25","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":25,"text":"he removed from Jerusalem, and met them in the land of Amathis: for he gave them no respite to enter his country.","searchKeywords":["removed","from","jerusalem","and","met","them","the","land","amathis","for","gave","respite","enter","his","country"]},{"verseId":"brenton_1-maccabees_12_26","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":26,"text":"He sent spies also unto their tents, who came again, and told him that they were appointed to come upon them in the night season.","searchKeywords":["sent","spies","also","unto","their","tents","who","came","again","and","told","him","that","they","were","appointed","come","upon","them","the","night","season"]},{"verseId":"brenton_1-maccabees_12_27","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":27,"text":"Wherefore so soon as the sun was down, Jonathan commanded his men to watch, and to be in arms, that all the night long they might be ready to fight: also he sent forth centinels round about the host.","searchKeywords":["wherefore","soon","the","sun","was","down","jonathan","commanded","his","men","watch","and","arms","that","all","night","long","they","might","ready","fight","also","sent","forth","centinels","round","about","host"]},{"verseId":"brenton_1-maccabees_12_28","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":28,"text":"But when the adversaries heard that Jonathan and his men were ready for battle, they feared, and trembled in their hearts, and they kindled fires in their camp.","searchKeywords":["but","when","the","adversaries","heard","that","jonathan","and","his","men","were","ready","for","battle","they","feared","trembled","their","hearts","kindled","fires","camp"]},{"verseId":"brenton_1-maccabees_12_29","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":29,"text":"Howbeit Jonathan and his company knew it not till the morning: for they saw the lights burning.","searchKeywords":["howbeit","jonathan","and","his","company","knew","not","till","the","morning","for","they","saw","lights","burning"]},{"verseId":"brenton_1-maccabees_12_30","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":30,"text":"Then Jonathan pursued after them, but overtook them not: for they were gone over the river Eleutherus.","searchKeywords":["then","jonathan","pursued","after","them","but","overtook","not","for","they","were","gone","over","the","river","eleutherus"]},{"verseId":"brenton_1-maccabees_12_31","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":31,"text":"Wherefore Jonathan turned to the Arabians, who were called Zabadeans, and smote them, and took their spoils.","searchKeywords":["wherefore","jonathan","turned","the","arabians","who","were","called","zabadeans","and","smote","them","took","their","spoils"]},{"verseId":"brenton_1-maccabees_12_32","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":32,"text":"And removing thence, he came to Damascus, and so passed through all the country.","searchKeywords":["and","removing","thence","came","damascus","passed","through","all","the","country"]},{"verseId":"brenton_1-maccabees_12_33","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":33,"text":"Simon also went forth, and passed through the country unto Ascalon, and the holds there adjoining, from whence he turned aside to Joppe, and won it.","searchKeywords":["simon","also","went","forth","and","passed","through","the","country","unto","ascalon","holds","there","adjoining","from","whence","turned","aside","joppe","won"]},{"verseId":"brenton_1-maccabees_12_34","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":34,"text":"For he had heard that they would deliver the hold unto them that took Demetrius' part: wherefore he set a garrison there to keep it.","searchKeywords":["for","had","heard","that","they","would","deliver","the","hold","unto","them","took","demetrius","part","wherefore","set","garrison","there","keep"]},{"verseId":"brenton_1-maccabees_12_35","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":35,"text":"After this came Jonathan home again, and calling the elders of the people together, he consulted with them about building strong holds in Judea,","searchKeywords":["after","this","came","jonathan","home","again","and","calling","the","elders","people","together","consulted","with","them","about","building","strong","holds","judea"]},{"verseId":"brenton_1-maccabees_12_36","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":36,"text":"and making the walls of Jerusalem higher, and raising a great mount between the tower and the city, for to separate it from the city, that so it might be alone, that men might neither sell nor buy in it.","searchKeywords":["and","making","the","walls","jerusalem","higher","raising","great","mount","between","tower","city","for","separate","from","that","might","alone","men","neither","sell","nor","buy"]},{"verseId":"brenton_1-maccabees_12_37","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":37,"text":"Upon this they came together to build up the city, forasmuch as the wall toward the brook on the east side was fallen down, and they repaired that which was called Caphenatha.","searchKeywords":["upon","this","they","came","together","build","the","city","forasmuch","wall","toward","brook","east","side","was","fallen","down","and","repaired","that","which","called","caphenatha"]},{"verseId":"brenton_1-maccabees_12_38","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":38,"text":"Simon also set up Adida in Sephela, and made it strong with gates and bars.","searchKeywords":["simon","also","set","adida","sephela","and","made","strong","with","gates","bars"]},{"verseId":"brenton_1-maccabees_12_39","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":39,"text":"Now Tryphon went about to get the kingdom of Asia, and to kill Antiochus the king, that he might set the crown upon his own head.","searchKeywords":["now","tryphon","went","about","get","the","kingdom","asia","and","kill","antiochus","king","that","might","set","crown","upon","his","own","head"]},{"verseId":"brenton_1-maccabees_12_40","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":40,"text":"Howbeit he was afraid that Jonathan would not suffer him, and that he would fight against him; wherefore he sought a way how to take Jonathan, that he might kill him. So he removed, and came to Bethsan.","searchKeywords":["howbeit","was","afraid","that","jonathan","would","not","suffer","him","and","fight","against","wherefore","sought","way","how","take","might","kill","removed","came","bethsan"]},{"verseId":"brenton_1-maccabees_12_41","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":41,"text":"Then Jonathan went out to meet him with forty thousand men chosen for the battle, and came to Bethsan.","searchKeywords":["then","jonathan","went","out","meet","him","with","forty","thousand","men","chosen","for","the","battle","and","came","bethsan"]},{"verseId":"brenton_1-maccabees_12_42","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":42,"text":"Now when Tryphon saw that Jonathan came with so great a force, he durst not stretch his hand against him;","searchKeywords":["now","when","tryphon","saw","that","jonathan","came","with","great","force","durst","not","stretch","his","hand","against","him"]},{"verseId":"brenton_1-maccabees_12_43","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":43,"text":"but received him honourably, and commended him unto all his friends, and gave him gifts, and commanded his men of war to be as obedient unto him, as to himself.","searchKeywords":["but","received","him","honourably","and","commended","unto","all","his","friends","gave","gifts","commanded","men","war","obedient","himself"]},{"verseId":"brenton_1-maccabees_12_44","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":44,"text":"Unto Jonathan also he said, Why hast thou put all this people to so great trouble, seeing there is no war betwixt us?","searchKeywords":["unto","jonathan","also","said","why","hast","thou","put","all","this","people","great","trouble","seeing","there","war","betwixt"]},{"verseId":"brenton_1-maccabees_12_45","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":45,"text":"Therefore send them now home again, and choose a few men to wait on thee, and come thou with me to Ptolemais, for I will give it thee, and the rest of the strong holds and forces, and all that have any charge: as for me, I will return and depart: for this is the cause of my coming.","searchKeywords":["therefore","send","them","now","home","again","and","choose","few","men","wait","thee","come","thou","with","ptolemais","for","will","give","the","rest","strong","holds","forces","all","that","have","any","charge","return","depart","this","cause","coming"]},{"verseId":"brenton_1-maccabees_12_46","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":46,"text":"So Jonathan believing him did as he bade him, and sent away his host, who went into the land of Judea.","searchKeywords":["jonathan","believing","him","did","bade","and","sent","away","his","host","who","went","into","the","land","judea"]},{"verseId":"brenton_1-maccabees_12_47","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":47,"text":"And with himself he retained but three thousand men, of whom he sent two thousand into Galilee, and one thousand went with him.","searchKeywords":["and","with","himself","retained","but","three","thousand","men","whom","sent","two","into","galilee","one","went","him"]},{"verseId":"brenton_1-maccabees_12_48","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":48,"text":"Now as soon as Jonathan entered into Ptolemais, they of Ptolemais shut the gates, and took him, and all them that came with him they slew with the sword.","searchKeywords":["now","soon","jonathan","entered","into","ptolemais","they","shut","the","gates","and","took","him","all","them","that","came","with","slew","sword"]},{"verseId":"brenton_1-maccabees_12_49","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":49,"text":"Then sent Tryphon an host of footmen and horsemen into Galilee, and into the great plain, to destroy all Jonathan's company.","searchKeywords":["then","sent","tryphon","host","footmen","and","horsemen","into","galilee","the","great","plain","destroy","all","jonathan","company"]},{"verseId":"brenton_1-maccabees_12_50","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":50,"text":"But when they knew that Jonathan and they that were with him were taken and slain, they encouraged one another, and went close together, prepared to fight.","searchKeywords":["but","when","they","knew","that","jonathan","and","were","with","him","taken","slain","encouraged","one","another","went","close","together","prepared","fight"]},{"verseId":"brenton_1-maccabees_12_51","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":51,"text":"They therefore that followed upon them, perceiving that they were ready to fight for their lives, turned back again.","searchKeywords":["they","therefore","that","followed","upon","them","perceiving","were","ready","fight","for","their","lives","turned","back","again"]},{"verseId":"brenton_1-maccabees_12_52","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":52,"text":"Whereupon they all came into the land of Judea peaceably, and there they bewailed Jonathan, and them that were with him, and they were sore afraid; wherefore all Israel made great lamentation.","searchKeywords":["whereupon","they","all","came","into","the","land","judea","peaceably","and","there","bewailed","jonathan","them","that","were","with","him","sore","afraid","wherefore","israel","made","great","lamentation"]},{"verseId":"brenton_1-maccabees_12_53","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":12,"verse":53,"text":"Then all the heathen that were round about them sought to destroy them: for said they, They have no captain, nor any to help them: now therefore let us make war upon them, and take away their memorial from among men.","searchKeywords":["then","all","the","heathen","that","were","round","about","them","sought","destroy","for","said","they","have","captain","nor","any","help","now","therefore","let","make","war","upon","and","take","away","their","memorial","from","among","men"]}]