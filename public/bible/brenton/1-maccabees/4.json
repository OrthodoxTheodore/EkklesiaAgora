[{"verseId":"brenton_1-maccabees_4_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":1,"text":"Then took Gorgias five thousand footmen, and a thousand of the best horsemen, and removed out of the camp by night;","searchKeywords":["then","took","gorgias","five","thousand","footmen","and","the","best","horsemen","removed","out","camp","night"]},{"verseId":"brenton_1-maccabees_4_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":2,"text":"to the end he might rush in upon the camp of the Jews, and smite them suddenly. And the men of the fortress were his guides.","searchKeywords":["the","end","might","rush","upon","camp","jews","and","smite","them","suddenly","men","fortress","were","his","guides"]},{"verseId":"brenton_1-maccabees_4_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":3,"text":"Now when Judas heard thereof, he himself removed, and the valiant men with him, that he might smite the king's army which was at Emmaus,","searchKeywords":["now","when","judas","heard","thereof","himself","removed","and","the","valiant","men","with","him","that","might","smite","king","army","which","was","emmaus"]},{"verseId":"brenton_1-maccabees_4_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":4,"text":"while as yet the forces were dispersed from the camp.","searchKeywords":["while","yet","the","forces","were","dispersed","from","camp"]},{"verseId":"brenton_1-maccabees_4_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":5,"text":"In the mean season came Gorgias by night into the camp of Judas: and when he found no man there, he sought them in the mountains: for he said, These flee from us.","searchKeywords":["the","mean","season","came","gorgias","night","into","camp","judas","and","when","found","man","there","sought","them","mountains","for","said","these","flee","from"]},{"verseId":"brenton_1-maccabees_4_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":6,"text":"But as soon as it was day, Judas shewed himself in the plain with three thousand men, who nevertheless had neither armour nor swords to their minds.","searchKeywords":["but","soon","was","day","judas","shewed","himself","the","plain","with","three","thousand","men","who","nevertheless","had","neither","armour","nor","swords","their","minds"]},{"verseId":"brenton_1-maccabees_4_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":7,"text":"And they saw the camp of the heathen, that it was strong and well harnessed, and compassed round about with horsemen; and these were expert of war.","searchKeywords":["and","they","saw","the","camp","heathen","that","was","strong","well","harnessed","compassed","round","about","with","horsemen","these","were","expert","war"]},{"verseId":"brenton_1-maccabees_4_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":8,"text":"Then said Judas to the men that were with him, Fear ye not their multitude, neither be ye afraid of their assault.","searchKeywords":["then","said","judas","the","men","that","were","with","him","fear","not","their","multitude","neither","afraid","assault"]},{"verseId":"brenton_1-maccabees_4_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":9,"text":"Remember how our fathers were delivered in the Red sea, when Pharaoh pursued them with an army.","searchKeywords":["remember","how","our","fathers","were","delivered","the","red","sea","when","pharaoh","pursued","them","with","army"]},{"verseId":"brenton_1-maccabees_4_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":10,"text":"Now therefore let us cry unto heaven, if peradventure the Lord will have mercy upon us, and remember the covenant of our fathers, and destroy this host before our face this day:","searchKeywords":["now","therefore","let","cry","unto","heaven","peradventure","the","lord","will","have","mercy","upon","and","remember","covenant","our","fathers","destroy","this","host","before","face","day"]},{"verseId":"brenton_1-maccabees_4_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":11,"text":"that so all the heathen may know that there is one who delivereth and saveth Israel.","searchKeywords":["that","all","the","heathen","may","know","there","one","who","delivereth","and","saveth","israel"]},{"verseId":"brenton_1-maccabees_4_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":12,"text":"Then the strangers lifted up their eyes, and saw them coming over against them.","searchKeywords":["then","the","strangers","lifted","their","eyes","and","saw","them","coming","over","against"]},{"verseId":"brenton_1-maccabees_4_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":13,"text":"Wherefore they went out of the camp to battle; but they that were with Judas sounded their trumpets.","searchKeywords":["wherefore","they","went","out","the","camp","battle","but","that","were","with","judas","sounded","their","trumpets"]},{"verseId":"brenton_1-maccabees_4_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":14,"text":"So they joined battle, and the heathen being discomfited, fled into the plain.","searchKeywords":["they","joined","battle","and","the","heathen","being","discomfited","fled","into","plain"]},{"verseId":"brenton_1-maccabees_4_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":15,"text":"Howbeit all the hindmost of them were slain with the sword: for they pursued them unto Gazera, and unto the plains of Idumea, and Azotus, and Jamnia, so that there were slain of them as many as three thousand men.","searchKeywords":["howbeit","all","the","hindmost","them","were","slain","with","sword","for","they","pursued","unto","gazera","and","plains","idumea","azotus","jamnia","that","there","many","three","thousand","men"]},{"verseId":"brenton_1-maccabees_4_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":16,"text":"This done, Judas returned again with his host from pursuing them,","searchKeywords":["this","done","judas","returned","again","with","his","host","from","pursuing","them"]},{"verseId":"brenton_1-maccabees_4_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":17,"text":"and said to the people, Be not greedy of the spoils, inasmuch as there is a battle before us,","searchKeywords":["and","said","the","people","not","greedy","spoils","inasmuch","there","battle","before"]},{"verseId":"brenton_1-maccabees_4_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":18,"text":"and Gorgias and his host are here by us in the mountain: but stand ye now against our enemies, and overcome them, and after this ye may boldly take the spoils.","searchKeywords":["and","gorgias","his","host","are","here","the","mountain","but","stand","now","against","our","enemies","overcome","them","after","this","may","boldly","take","spoils"]},{"verseId":"brenton_1-maccabees_4_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":19,"text":"As Judas was yet speaking these words, there appeared a part of them looking out of the mountain:","searchKeywords":["judas","was","yet","speaking","these","words","there","appeared","part","them","looking","out","the","mountain"]},{"verseId":"brenton_1-maccabees_4_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":20,"text":"who when they perceived that the Jews had put their host to flight, and were burning the tents; for the smoke that was seen declared what was done:","searchKeywords":["who","when","they","perceived","that","the","jews","had","put","their","host","flight","and","were","burning","tents","for","smoke","was","seen","declared","what","done"]},{"verseId":"brenton_1-maccabees_4_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":21,"text":"when therefore they perceived these things, they were sore afraid, and seeing also the host of Judas in the plain ready to fight,","searchKeywords":["when","therefore","they","perceived","these","things","were","sore","afraid","and","seeing","also","the","host","judas","plain","ready","fight"]},{"verseId":"brenton_1-maccabees_4_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":22,"text":"they fled every one into the land of strangers.","searchKeywords":["they","fled","every","one","into","the","land","strangers"]},{"verseId":"brenton_1-maccabees_4_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":23,"text":"Then Judas returned to spoil the tents, where they got much gold, and silver, and blue silk, and purple of the sea, and great riches.","searchKeywords":["then","judas","returned","spoil","the","tents","where","they","got","much","gold","and","silver","blue","silk","purple","sea","great","riches"]},{"verseId":"brenton_1-maccabees_4_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":24,"text":"After this they went home, and sung a song of thanksgiving, and praised the Lord in heaven: because it is good, because his mercy for ever.","searchKeywords":["after","this","they","went","home","and","sung","song","thanksgiving","praised","the","lord","heaven","because","good","his","mercy","for","ever"]},{"verseId":"brenton_1-maccabees_4_25","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":25,"text":"Thus Israel had a great deliverance that day.","searchKeywords":["thus","israel","had","great","deliverance","that","day"]},{"verseId":"brenton_1-maccabees_4_26","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":26,"text":"Now all the strangers that had escaped came and told Lysias what had happened:","searchKeywords":["now","all","the","strangers","that","had","escaped","came","and","told","lysias","what","happened"]},{"verseId":"brenton_1-maccabees_4_27","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":27,"text":"who, when he heard thereof, was confounded and discouraged, because neither such things as he would were done unto Israel, nor such things as the king commanded him were come to pass.","searchKeywords":["who","when","heard","thereof","was","confounded","and","discouraged","because","neither","such","things","would","were","done","unto","israel","nor","the","king","commanded","him","come","pass"]},{"verseId":"brenton_1-maccabees_4_28","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":28,"text":"In the following year therefore, Lysias gathered together threescore thousand choice men , and five thousand horsemen, that he might subdue them.","searchKeywords":["the","following","year","therefore","lysias","gathered","together","threescore","thousand","choice","men","and","five","horsemen","that","might","subdue","them"]},{"verseId":"brenton_1-maccabees_4_29","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":29,"text":"So they came into Idumea, and pitched their tents at Bethsura, and Judas met them with ten thousand men.","searchKeywords":["they","came","into","idumea","and","pitched","their","tents","bethsura","judas","met","them","with","ten","thousand","men"]},{"verseId":"brenton_1-maccabees_4_30","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":30,"text":"And when he saw that mighty army, he prayed and said, Blessed art thou, O Saviour of Israel, who didst quell the violence of the mighty man by the hand of thy servant David, and gavest the host of strangers into the hands of Jonathan the son of Saul, and his armour-bearer;","searchKeywords":["and","when","saw","that","mighty","army","prayed","said","blessed","art","thou","saviour","israel","who","didst","quell","the","violence","man","hand","thy","servant","david","gavest","host","strangers","into","hands","jonathan","son","saul","his","armour","bearer"]},{"verseId":"brenton_1-maccabees_4_31","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":31,"text":"shut up this army in the hand of thy people Israel, and let them be confounded in their power and horsemen:","searchKeywords":["shut","this","army","the","hand","thy","people","israel","and","let","them","confounded","their","power","horsemen"]},{"verseId":"brenton_1-maccabees_4_32","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":32,"text":"make them to be of no courage, and cause the boldness of their strength to fall away, and let them quake at their destruction:","searchKeywords":["make","them","courage","and","cause","the","boldness","their","strength","fall","away","let","quake","destruction"]},{"verseId":"brenton_1-maccabees_4_33","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":33,"text":"cast them down with the sword of them that love thee, and let all those that know thy name praise thee with thanksgiving.","searchKeywords":["cast","them","down","with","the","sword","that","love","thee","and","let","all","those","know","thy","name","praise","thanksgiving"]},{"verseId":"brenton_1-maccabees_4_34","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":34,"text":"So they joined battle; and there were slain of the host of Lysias about five thousand men, even before them were they slain.","searchKeywords":["they","joined","battle","and","there","were","slain","the","host","lysias","about","five","thousand","men","even","before","them"]},{"verseId":"brenton_1-maccabees_4_35","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":35,"text":"Now when Lysias saw his army put to flight, and the manliness of Judas' soldiers, and how they were ready either to live or die valiantly, he went into Antiochia, and gathered together a company of strangers, and having made his army greater than it was, he purposed to come again into Judea.","searchKeywords":["now","when","lysias","saw","his","army","put","flight","and","the","manliness","judas","soldiers","how","they","were","ready","either","live","die","valiantly","went","into","antiochia","gathered","together","company","strangers","having","made","greater","than","was","purposed","come","again","judea"]},{"verseId":"brenton_1-maccabees_4_36","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":36,"text":"Then said Judas and his brethren, Behold, our enemies are discomfited: let us go up to cleanse and dedicate the sanctuary.","searchKeywords":["then","said","judas","and","his","brethren","behold","our","enemies","are","discomfited","let","cleanse","dedicate","the","sanctuary"]},{"verseId":"brenton_1-maccabees_4_37","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":37,"text":"Upon this all the host assembled themselves together, and went up into mount Sion.","searchKeywords":["upon","this","all","the","host","assembled","themselves","together","and","went","into","mount","sion"]},{"verseId":"brenton_1-maccabees_4_38","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":38,"text":"And when they saw the sanctuary desolate, and the altar profaned, and the gates burned up, and shrubs growing in the courts as in a forest, or in one of the mountains, yea, and the priests' chambers pulled down;","searchKeywords":["and","when","they","saw","the","sanctuary","desolate","altar","profaned","gates","burned","shrubs","growing","courts","forest","one","mountains","yea","priests","chambers","pulled","down"]},{"verseId":"brenton_1-maccabees_4_39","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":39,"text":"they rent their clothes, and made great lamentation, and cast ashes upon their heads,","searchKeywords":["they","rent","their","clothes","and","made","great","lamentation","cast","ashes","upon","heads"]},{"verseId":"brenton_1-maccabees_4_40","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":40,"text":"and fell down flat to the ground upon their faces, and blew an alarm with the trumpets, and cried toward heaven.","searchKeywords":["and","fell","down","flat","the","ground","upon","their","faces","blew","alarm","with","trumpets","cried","toward","heaven"]},{"verseId":"brenton_1-maccabees_4_41","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":41,"text":"Then Judas appointed certain men to fight against those that were in the fortress, until he had cleansed the sanctuary.","searchKeywords":["then","judas","appointed","certain","men","fight","against","those","that","were","the","fortress","until","had","cleansed","sanctuary"]},{"verseId":"brenton_1-maccabees_4_42","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":42,"text":"So he chose priests of blameless conversation, such as had pleasure in the law:","searchKeywords":["chose","priests","blameless","conversation","such","had","pleasure","the","law"]},{"verseId":"brenton_1-maccabees_4_43","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":43,"text":"who cleansed the sanctuary, and bare out the defiled stones into an unclean place.","searchKeywords":["who","cleansed","the","sanctuary","and","bare","out","defiled","stones","into","unclean","place"]},{"verseId":"brenton_1-maccabees_4_44","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":44,"text":"And when as they consulted what to do with the altar of burnt offerings, which was profaned;","searchKeywords":["and","when","they","consulted","what","with","the","altar","burnt","offerings","which","was","profaned"]},{"verseId":"brenton_1-maccabees_4_45","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":45,"text":"they thought it best to pull it down, lest it should be a reproach to them, because the heathen had defiled it: wherefore they pulled it down,","searchKeywords":["they","thought","best","pull","down","lest","should","reproach","them","because","the","heathen","had","defiled","wherefore","pulled"]},{"verseId":"brenton_1-maccabees_4_46","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":46,"text":"and laid up the stones in the mountain of the temple in a convenient place, until there should come a prophet to shew what should be done with them.","searchKeywords":["and","laid","the","stones","mountain","temple","convenient","place","until","there","should","come","prophet","shew","what","done","with","them"]},{"verseId":"brenton_1-maccabees_4_47","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":47,"text":"Then they took whole stones according to the law, and built a new altar according to the former;","searchKeywords":["then","they","took","whole","stones","according","the","law","and","built","new","altar","former"]},{"verseId":"brenton_1-maccabees_4_48","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":48,"text":"and made up the sanctuary, and the things that were within the temple, and hallowed the courts.","searchKeywords":["and","made","the","sanctuary","things","that","were","within","temple","hallowed","courts"]},{"verseId":"brenton_1-maccabees_4_49","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":49,"text":"They made also new holy vessels, and into the temple they brought the candlestick, and the altar of incense, and the table.","searchKeywords":["they","made","also","new","holy","vessels","and","into","the","temple","brought","candlestick","altar","incense","table"]},{"verseId":"brenton_1-maccabees_4_50","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":50,"text":"And upon the altar they burned incense, and the lamps that were upon the candlestick they lighted, that they might give light in the temple.","searchKeywords":["and","upon","the","altar","they","burned","incense","lamps","that","were","candlestick","lighted","might","give","light","temple"]},{"verseId":"brenton_1-maccabees_4_51","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":51,"text":"Furthermore they set the loaves upon the table, and spread out the veils, and finished all the works which they had begun to make.","searchKeywords":["furthermore","they","set","the","loaves","upon","table","and","spread","out","veils","finished","all","works","which","had","begun","make"]},{"verseId":"brenton_1-maccabees_4_52","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":52,"text":"Now on the five and twentieth day of the ninth month, which the month Casleu, in the hundred forty and eighth year, they rose up betimes in the morning,","searchKeywords":["now","the","five","and","twentieth","day","ninth","month","which","casleu","hundred","forty","eighth","year","they","rose","betimes","morning"]},{"verseId":"brenton_1-maccabees_4_53","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":53,"text":"and offered sacrifice according to the law upon the new altar of burnt offerings, which they had made.","searchKeywords":["and","offered","sacrifice","according","the","law","upon","new","altar","burnt","offerings","which","they","had","made"]},{"verseId":"brenton_1-maccabees_4_54","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":54,"text":"At what time and day the heathen had profaned it, even in that was it dedicated with songs, and citherns, and harps, and cymbals.","searchKeywords":["what","time","and","day","the","heathen","had","profaned","even","that","was","dedicated","with","songs","citherns","harps","cymbals"]},{"verseId":"brenton_1-maccabees_4_55","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":55,"text":"Then all the people fell upon their faces, worshipping and praising heaven, who had given them good success.","searchKeywords":["then","all","the","people","fell","upon","their","faces","worshipping","and","praising","heaven","who","had","given","them","good","success"]},{"verseId":"brenton_1-maccabees_4_56","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":56,"text":"And so they kept the dedication of the altar eight days, and offered burnt offerings with gladness, and sacrificed the sacrifice of deliverance and praise.","searchKeywords":["and","they","kept","the","dedication","altar","eight","days","offered","burnt","offerings","with","gladness","sacrificed","sacrifice","deliverance","praise"]},{"verseId":"brenton_1-maccabees_4_57","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":57,"text":"They decked also the forefront of the temple with crowns of gold and with shields; and the gates and the chambers they renewed, and hanged doors upon them.","searchKeywords":["they","decked","also","the","forefront","temple","with","crowns","gold","and","shields","gates","chambers","renewed","hanged","doors","upon","them"]},{"verseId":"brenton_1-maccabees_4_58","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":58,"text":"Thus was there very great gladness among the people, for that the reproach of the heathen was put away.","searchKeywords":["thus","was","there","very","great","gladness","among","the","people","for","that","reproach","heathen","put","away"]},{"verseId":"brenton_1-maccabees_4_59","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":59,"text":"Moreover Judas and his brethren with the whole congregation of Israel ordained, that the days of the dedication of the altar should be kept in their season from year to year by the space of eight days, from the five and twentieth day of the month Casleu, with mirth and gladness.","searchKeywords":["moreover","judas","and","his","brethren","with","the","whole","congregation","israel","ordained","that","days","dedication","altar","should","kept","their","season","from","year","space","eight","five","twentieth","day","month","casleu","mirth","gladness"]},{"verseId":"brenton_1-maccabees_4_60","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":60,"text":"At that time also they builded up the mount Sion with high walls and strong towers round about, lest the Gentiles should come and tread it down, as they had done before.","searchKeywords":["that","time","also","they","builded","the","mount","sion","with","high","walls","and","strong","towers","round","about","lest","gentiles","should","come","tread","down","had","done","before"]},{"verseId":"brenton_1-maccabees_4_61","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":4,"verse":61,"text":"And they set there a garrison to keep it, and fortified Bethsura to preserve it; that the people might have a defence against Idumea.","searchKeywords":["and","they","set","there","garrison","keep","fortified","bethsura","preserve","that","the","people","might","have","defence","against","idumea"]}]