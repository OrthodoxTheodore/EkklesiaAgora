[{"verseId":"brenton_1-maccabees_11_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":1,"text":"And the king of Egypt gathered together a great host, like the sand that lieth upon the sea shore, and many ships, and went about through deceit to get Alexander's kingdom, and join it to his own.","searchKeywords":["and","the","king","egypt","gathered","together","great","host","like","sand","that","lieth","upon","sea","shore","many","ships","went","about","through","deceit","get","alexander","kingdom","join","his","own"]},{"verseId":"brenton_1-maccabees_11_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":2,"text":"Whereupon he took his journey into Syria in peaceable manner, so as they of the cities opened unto him, and met him: for king Alexander had commanded them so to do, because he was his father in law.","searchKeywords":["whereupon","took","his","journey","into","syria","peaceable","manner","they","the","cities","opened","unto","him","and","met","for","king","alexander","had","commanded","them","because","was","father","law"]},{"verseId":"brenton_1-maccabees_11_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":3,"text":"Now as Ptolemee entered into the cities, he set in every one of them a garrison of soldiers to keep it.","searchKeywords":["now","ptolemee","entered","into","the","cities","set","every","one","them","garrison","soldiers","keep"]},{"verseId":"brenton_1-maccabees_11_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":4,"text":"And when he came near to Azotus, they shewed him the temple of Dagon that was burnt, and Azotus and the suburbs thereof that were destroyed, and the bodies that were cast abroad, and them that he had burnt in the battle: for they had made heaps of them by the way where he should pass.","searchKeywords":["and","when","came","near","azotus","they","shewed","him","the","temple","dagon","that","was","burnt","suburbs","thereof","were","destroyed","bodies","cast","abroad","them","had","battle","for","made","heaps","way","where","should","pass"]},{"verseId":"brenton_1-maccabees_11_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":5,"text":"Also they told the king whatsoever Jonathan had done, to the intent he might blame him: but the king held his peace.","searchKeywords":["also","they","told","the","king","whatsoever","jonathan","had","done","intent","might","blame","him","but","held","his","peace"]},{"verseId":"brenton_1-maccabees_11_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":6,"text":"Then Jonathan met the king with great pomp at Joppe, where they saluted one another, and lodged.","searchKeywords":["then","jonathan","met","the","king","with","great","pomp","joppe","where","they","saluted","one","another","and","lodged"]},{"verseId":"brenton_1-maccabees_11_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":7,"text":"Afterward Jonathan, when he had gone with the king to the river called Eleutherus, returned again to Jerusalem.","searchKeywords":["afterward","jonathan","when","had","gone","with","the","king","river","called","eleutherus","returned","again","jerusalem"]},{"verseId":"brenton_1-maccabees_11_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":8,"text":"King Ptolemee therefore, having gotten the dominion of the cities by the sea unto Seleucia upon the sea coast, imagined wicked counsels against Alexander.","searchKeywords":["king","ptolemee","therefore","having","gotten","the","dominion","cities","sea","unto","seleucia","upon","coast","imagined","wicked","counsels","against","alexander"]},{"verseId":"brenton_1-maccabees_11_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":9,"text":"Whereupon he sent ambassadors unto king Demetrius, saying, Come, let us make a league betwixt us, and I will give thee my daughter whom Alexander hath, and thou shalt reign in thy father's kingdom:","searchKeywords":["whereupon","sent","ambassadors","unto","king","demetrius","saying","come","let","make","league","betwixt","and","will","give","thee","daughter","whom","alexander","hath","thou","shalt","reign","thy","father","kingdom"]},{"verseId":"brenton_1-maccabees_11_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":10,"text":"for I repent that I gave my daughter unto him, for he sought to slay me.","searchKeywords":["for","repent","that","gave","daughter","unto","him","sought","slay"]},{"verseId":"brenton_1-maccabees_11_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":11,"text":"Thus did he slander him, because he was desirous of his kingdom.","searchKeywords":["thus","did","slander","him","because","was","desirous","his","kingdom"]},{"verseId":"brenton_1-maccabees_11_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":12,"text":"Wherefore he took his daughter from him, and gave her to Demetrius, and forsook Alexander, so that their hatred was openly known.","searchKeywords":["wherefore","took","his","daughter","from","him","and","gave","her","demetrius","forsook","alexander","that","their","hatred","was","openly","known"]},{"verseId":"brenton_1-maccabees_11_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":13,"text":"Then Ptolemee entered into Antioch, where he set two crowns upon his head, the crown of Asia, and of Egypt.","searchKeywords":["then","ptolemee","entered","into","antioch","where","set","two","crowns","upon","his","head","the","crown","asia","and","egypt"]},{"verseId":"brenton_1-maccabees_11_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":14,"text":"In the mean season was king Alexander in Cilicia, because those that dwelt in those parts had revolted from him.","searchKeywords":["the","mean","season","was","king","alexander","cilicia","because","those","that","dwelt","parts","had","revolted","from","him"]},{"verseId":"brenton_1-maccabees_11_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":15,"text":"But when Alexander heard of this, he came to war against him: whereupon Ptolemee brought forth his host, and met him with a mighty power, and put him to flight.","searchKeywords":["but","when","alexander","heard","this","came","war","against","him","whereupon","ptolemee","brought","forth","his","host","and","met","with","mighty","power","put","flight"]},{"verseId":"brenton_1-maccabees_11_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":16,"text":"So Alexander fled into Arabia, there to be defended; but king Ptolemee was exalted:","searchKeywords":["alexander","fled","into","arabia","there","defended","but","king","ptolemee","was","exalted"]},{"verseId":"brenton_1-maccabees_11_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":17,"text":"for Zabdiel the Arabian took off Alexander's head, and sent it unto Ptolemee.","searchKeywords":["for","zabdiel","the","arabian","took","off","alexander","head","and","sent","unto","ptolemee"]},{"verseId":"brenton_1-maccabees_11_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":18,"text":"King Ptolemee also died the third day after, and they that were in the strong holds were slain one of another.","searchKeywords":["king","ptolemee","also","died","the","third","day","after","and","they","that","were","strong","holds","slain","one","another"]},{"verseId":"brenton_1-maccabees_11_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":19,"text":"By this means Demetrius reigned in the hundred threescore and seventh year.","searchKeywords":["this","means","demetrius","reigned","the","hundred","threescore","and","seventh","year"]},{"verseId":"brenton_1-maccabees_11_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":20,"text":"At the same time Jonathan gathered together them that were in Judea, to take the tower that was in Jerusalem: and he made many engines of war against it.","searchKeywords":["the","same","time","jonathan","gathered","together","them","that","were","judea","take","tower","was","jerusalem","and","made","many","engines","war","against"]},{"verseId":"brenton_1-maccabees_11_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":21,"text":"Then certain ungodly persons, who hated their own people, went unto the king, and told him that Jonathan besieged the tower.","searchKeywords":["then","certain","ungodly","persons","who","hated","their","own","people","went","unto","the","king","and","told","him","that","jonathan","besieged","tower"]},{"verseId":"brenton_1-maccabees_11_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":22,"text":"Whereof when he heard, he was angry, and immediately removing, he came to Ptolemais, and wrote unto Jonathan, that he should not lay siege to the tower, but come and speak with him at Ptolemais in great haste.","searchKeywords":["whereof","when","heard","was","angry","and","immediately","removing","came","ptolemais","wrote","unto","jonathan","that","should","not","lay","siege","the","tower","but","come","speak","with","him","great","haste"]},{"verseId":"brenton_1-maccabees_11_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":23,"text":"Nevertheless Jonathan, when he heard this, commanded to besiege it : and he chose certain of the elders of Israel and the priests, and put himself in peril;","searchKeywords":["nevertheless","jonathan","when","heard","this","commanded","besiege","and","chose","certain","the","elders","israel","priests","put","himself","peril"]},{"verseId":"brenton_1-maccabees_11_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":24,"text":"and took silver and gold, and raiment, and divers presents besides, and went to Ptolemais unto the king, where he found favour in his sight.","searchKeywords":["and","took","silver","gold","raiment","divers","presents","besides","went","ptolemais","unto","the","king","where","found","favour","his","sight"]},{"verseId":"brenton_1-maccabees_11_25","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":25,"text":"And though certain ungodly men of the people had made complaints against him,","searchKeywords":["and","though","certain","ungodly","men","the","people","had","made","complaints","against","him"]},{"verseId":"brenton_1-maccabees_11_26","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":26,"text":"yet the king entreated him as his predecessors had done before, and promoted him in the sight of all his friends,","searchKeywords":["yet","the","king","entreated","him","his","predecessors","had","done","before","and","promoted","sight","all","friends"]},{"verseId":"brenton_1-maccabees_11_27","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":27,"text":"and confirmed him in the high priesthood, and in all the honours that he had before, and gave him pre-eminence among his chief friends.","searchKeywords":["and","confirmed","him","the","high","priesthood","all","honours","that","had","before","gave","pre","eminence","among","his","chief","friends"]},{"verseId":"brenton_1-maccabees_11_28","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":28,"text":"Then Jonathan desired the king, that he would make Judea free from tribute, as also the three governments, with the country of Samaria; and he promised him three hundred talents.","searchKeywords":["then","jonathan","desired","the","king","that","would","make","judea","free","from","tribute","also","three","governments","with","country","samaria","and","promised","him","hundred","talents"]},{"verseId":"brenton_1-maccabees_11_29","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":29,"text":"So the king consented, and wrote letters unto Jonathan of all these things after this manner:","searchKeywords":["the","king","consented","and","wrote","letters","unto","jonathan","all","these","things","after","this","manner"]},{"verseId":"brenton_1-maccabees_11_30","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":30,"text":"King Demetrius unto his brother Jonathan, and unto the nation of the Jews, sendeth greeting:","searchKeywords":["king","demetrius","unto","his","brother","jonathan","and","the","nation","jews","sendeth","greeting"]},{"verseId":"brenton_1-maccabees_11_31","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":31,"text":"We send you here a copy of the letter which we did write unto our cousin Lasthenes concerning you, that ye might see it.","searchKeywords":["send","you","here","copy","the","letter","which","did","write","unto","our","cousin","lasthenes","concerning","that","might","see"]},{"verseId":"brenton_1-maccabees_11_32","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":32,"text":"King Demetrius unto his father Lasthenes sendeth greeting:","searchKeywords":["king","demetrius","unto","his","father","lasthenes","sendeth","greeting"]},{"verseId":"brenton_1-maccabees_11_33","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":33,"text":"We are determined to do good to the people of the Jews, who are our friends, and keep covenants with us, because of their good will toward us.","searchKeywords":["are","determined","good","the","people","jews","who","our","friends","and","keep","covenants","with","because","their","will","toward"]},{"verseId":"brenton_1-maccabees_11_34","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":34,"text":"Wherefore we have ratified unto them the borders of Judea, with the three governments of Apherema and Lydda and Ramathem, that are added unto Judea from the country of Samaria, and all things appertaining unto them, for all such as do sacrifice in Jerusalem, instead of the payments which the king received of them yearly aforetime out of the fruits of the earth and of trees.","searchKeywords":["wherefore","have","ratified","unto","them","the","borders","judea","with","three","governments","apherema","and","lydda","ramathem","that","are","added","from","country","samaria","all","things","appertaining","for","such","sacrifice","jerusalem","instead","payments","which","king","received","yearly","aforetime","out","fruits","earth","trees"]},{"verseId":"brenton_1-maccabees_11_35","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":35,"text":"And as for other things that belong unto us, of the tithes and customs pertaining unto us, as also the saltpits, and the crown taxes, which are due unto us, we discharge them of them all for their relief.","searchKeywords":["and","for","other","things","that","belong","unto","the","tithes","customs","pertaining","also","saltpits","crown","taxes","which","are","due","discharge","them","all","their","relief"]},{"verseId":"brenton_1-maccabees_11_36","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":36,"text":"And nothing hereof shall be revoked from this time forth for ever.","searchKeywords":["and","nothing","hereof","shall","revoked","from","this","time","forth","for","ever"]},{"verseId":"brenton_1-maccabees_11_37","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":37,"text":"Now therefore see that thou make a copy of these things, and let it be delivered unto Jonathan, and set upon the holy mount in a conspicuous place.","searchKeywords":["now","therefore","see","that","thou","make","copy","these","things","and","let","delivered","unto","jonathan","set","upon","the","holy","mount","conspicuous","place"]},{"verseId":"brenton_1-maccabees_11_38","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":38,"text":"After this, when king Demetrius saw that the land was quiet before him, and that no resistance was made against him, he sent away all his forces, every one to his own place, except certain bands of strangers, whom he had gathered from the isles of the heathen: wherefore all the forces of his fathers hated him.","searchKeywords":["after","this","when","king","demetrius","saw","that","the","land","was","quiet","before","him","and","resistance","made","against","sent","away","all","his","forces","every","one","own","place","except","certain","bands","strangers","whom","had","gathered","from","isles","heathen","wherefore","fathers","hated"]},{"verseId":"brenton_1-maccabees_11_39","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":39,"text":"Moreover there was one Tryphon, that had been of Alexander's part afore, who, seeing that all the host murmured against Demetrius, went to Simalcue the Arabian, that brought up Antiochus the young son of Alexander,","searchKeywords":["moreover","there","was","one","tryphon","that","had","been","alexander","part","afore","who","seeing","all","the","host","murmured","against","demetrius","went","simalcue","arabian","brought","antiochus","young","son"]},{"verseId":"brenton_1-maccabees_11_40","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":40,"text":"and lay sore upon him to deliver him , that he might reign in his father's stead: he told him therefore all that Demetrius had done, and how his men of war were at enmity with him, and there he remained a long season.","searchKeywords":["and","lay","sore","upon","him","deliver","that","might","reign","his","father","stead","told","therefore","all","demetrius","had","done","how","men","war","were","enmity","with","there","remained","long","season"]},{"verseId":"brenton_1-maccabees_11_41","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":41,"text":"In the mean time Jonathan sent unto king Demetrius, that he would cast those of the tower out of Jerusalem, and those also in the fortresses: for they fought against Israel.","searchKeywords":["the","mean","time","jonathan","sent","unto","king","demetrius","that","would","cast","those","tower","out","jerusalem","and","also","fortresses","for","they","fought","against","israel"]},{"verseId":"brenton_1-maccabees_11_42","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":42,"text":"So Demetrius sent unto Jonathan, saying, I will not only do this for thee and thy people, but I will greatly honour thee and thy nation, if opportunity serve.","searchKeywords":["demetrius","sent","unto","jonathan","saying","will","not","only","this","for","thee","and","thy","people","but","greatly","honour","nation","opportunity","serve"]},{"verseId":"brenton_1-maccabees_11_43","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":43,"text":"Now therefore thou shalt do well, if thou send me men to help me; for all my forces are gone from me.","searchKeywords":["now","therefore","thou","shalt","well","send","men","help","for","all","forces","are","gone","from"]},{"verseId":"brenton_1-maccabees_11_44","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":44,"text":"Upon this Jonathan sent him three thousand strong men unto Antioch: and when they came to the king, the king was very glad of their coming.","searchKeywords":["upon","this","jonathan","sent","him","three","thousand","strong","men","unto","antioch","and","when","they","came","the","king","was","very","glad","their","coming"]},{"verseId":"brenton_1-maccabees_11_45","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":45,"text":"Howbeit they that were of the city gathered themselves together into the midst of the city, to the number of an hundred and twenty thousand men, and would have slain the king.","searchKeywords":["howbeit","they","that","were","the","city","gathered","themselves","together","into","midst","number","hundred","and","twenty","thousand","men","would","have","slain","king"]},{"verseId":"brenton_1-maccabees_11_46","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":46,"text":"Wherefore the king fled into the court, but they of the city kept the passages of the city, and began to fight.","searchKeywords":["wherefore","the","king","fled","into","court","but","they","city","kept","passages","and","began","fight"]},{"verseId":"brenton_1-maccabees_11_47","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":47,"text":"Then the king called to the Jews for help, who came unto him all at once, and dispersing themselves through the city slew that day in the city to the number of an hundred thousand.","searchKeywords":["then","the","king","called","jews","for","help","who","came","unto","him","all","once","and","dispersing","themselves","through","city","slew","that","day","number","hundred","thousand"]},{"verseId":"brenton_1-maccabees_11_48","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":48,"text":"Also they set fire on the city, and gat many spoils that day, and delivered the king.","searchKeywords":["also","they","set","fire","the","city","and","gat","many","spoils","that","day","delivered","king"]},{"verseId":"brenton_1-maccabees_11_49","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":49,"text":"So when they of the city saw that the Jews had got the city as they would, their courage was abated: wherefore they made supplication to the king, and cried, saying,","searchKeywords":["when","they","the","city","saw","that","jews","had","got","would","their","courage","was","abated","wherefore","made","supplication","king","and","cried","saying"]},{"verseId":"brenton_1-maccabees_11_50","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":50,"text":"Grant us peace, and let the Jews cease from assaulting us and the city.","searchKeywords":["grant","peace","and","let","the","jews","cease","from","assaulting","city"]},{"verseId":"brenton_1-maccabees_11_51","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":51,"text":"With that they cast away their weapons, and made peace; and the Jews were honoured in the sight of the king, and in the sight of all that were in his realm; and they returned to Jerusalem, having great spoils.","searchKeywords":["with","that","they","cast","away","their","weapons","and","made","peace","the","jews","were","honoured","sight","king","all","his","realm","returned","jerusalem","having","great","spoils"]},{"verseId":"brenton_1-maccabees_11_52","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":52,"text":"So king Demetrius sat on the throne of his kingdom, and the land was quiet before him.","searchKeywords":["king","demetrius","sat","the","throne","his","kingdom","and","land","was","quiet","before","him"]},{"verseId":"brenton_1-maccabees_11_53","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":53,"text":"Nevertheless he dissembled in all that ever he spake, and estranged himself from Jonathan, neither rewarded he him according to the benefits which he had received of him, but troubled him very sore.","searchKeywords":["nevertheless","dissembled","all","that","ever","spake","and","estranged","himself","from","jonathan","neither","rewarded","him","according","the","benefits","which","had","received","but","troubled","very","sore"]},{"verseId":"brenton_1-maccabees_11_54","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":54,"text":"After this returned Tryphon, and with him the young child Antiochus, who reigned, and was crowned.","searchKeywords":["after","this","returned","tryphon","and","with","him","the","young","child","antiochus","who","reigned","was","crowned"]},{"verseId":"brenton_1-maccabees_11_55","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":55,"text":"Then there gathered unto him all the men of war, whom Demetrius had put away, and they fought against Demetrius, who turned his back and fled.","searchKeywords":["then","there","gathered","unto","him","all","the","men","war","whom","demetrius","had","put","away","and","they","fought","against","who","turned","his","back","fled"]},{"verseId":"brenton_1-maccabees_11_56","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":56,"text":"Moreover Tryphon took the elephants, and won Antioch.","searchKeywords":["moreover","tryphon","took","the","elephants","and","won","antioch"]},{"verseId":"brenton_1-maccabees_11_57","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":57,"text":"At that time young Antiochus wrote unto Jonathan, saying, I confirm thee in the high priesthood, and appoint thee ruler over the four governments, and to be one of the king's friends.","searchKeywords":["that","time","young","antiochus","wrote","unto","jonathan","saying","confirm","thee","the","high","priesthood","and","appoint","ruler","over","four","governments","one","king","friends"]},{"verseId":"brenton_1-maccabees_11_58","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":58,"text":"Upon this he sent him golden vessels to be served in, and gave him leave to drink in gold, and to be clothed in purple, and to wear a golden buckle.","searchKeywords":["upon","this","sent","him","golden","vessels","served","and","gave","leave","drink","gold","clothed","purple","wear","buckle"]},{"verseId":"brenton_1-maccabees_11_59","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":59,"text":"His brother Simon also he made captain from the place called The ladder of Tyrus unto the borders of Egypt.","searchKeywords":["his","brother","simon","also","made","captain","from","the","place","called","ladder","tyrus","unto","borders","egypt"]},{"verseId":"brenton_1-maccabees_11_60","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":60,"text":"Then Jonathan went forth, and passed through the cities beyond the water, and all the forces of Syria gathered themselves unto him for to help him: and when he came to Ascalon, they of the city met him honourably.","searchKeywords":["then","jonathan","went","forth","and","passed","through","the","cities","beyond","water","all","forces","syria","gathered","themselves","unto","him","for","help","when","came","ascalon","they","city","met","honourably"]},{"verseId":"brenton_1-maccabees_11_61","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":61,"text":"From whence he went to Gaza, but they of Gaza shut him out; wherefore he laid siege unto it, and burned the suburbs thereof with fire, and spoiled them.","searchKeywords":["from","whence","went","gaza","but","they","shut","him","out","wherefore","laid","siege","unto","and","burned","the","suburbs","thereof","with","fire","spoiled","them"]},{"verseId":"brenton_1-maccabees_11_62","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":62,"text":"Afterward, when they of Gaza made supplication unto Jonathan, he made peace with them, and took the sons of their chief men for hostages, and sent them to Jerusalem, and passed through the country unto Damascus.","searchKeywords":["afterward","when","they","gaza","made","supplication","unto","jonathan","peace","with","them","and","took","the","sons","their","chief","men","for","hostages","sent","jerusalem","passed","through","country","damascus"]},{"verseId":"brenton_1-maccabees_11_63","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":63,"text":"Now when Jonathan heard that Demetrius' princes were come to Cades, which is in Galilee, with a great power, purposing to remove him out of the country,","searchKeywords":["now","when","jonathan","heard","that","demetrius","princes","were","come","cades","which","galilee","with","great","power","purposing","remove","him","out","the","country"]},{"verseId":"brenton_1-maccabees_11_64","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":64,"text":"he went to meet them, and left Simon his brother in the country.","searchKeywords":["went","meet","them","and","left","simon","his","brother","the","country"]},{"verseId":"brenton_1-maccabees_11_65","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":65,"text":"Then Simon encamped against Bethsura, and fought against it a long season, and shut it up:","searchKeywords":["then","simon","encamped","against","bethsura","and","fought","long","season","shut"]},{"verseId":"brenton_1-maccabees_11_66","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":66,"text":"but they desired to have peace with him, which he granted them, and then put them out from thence, and took the city, and set a garrison in it.","searchKeywords":["but","they","desired","have","peace","with","him","which","granted","them","and","then","put","out","from","thence","took","the","city","set","garrison"]},{"verseId":"brenton_1-maccabees_11_67","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":67,"text":"As for Jonathan and his host, they pitched at the water of Gennesar, from whence betimes in the morning they gat them to the plain of Nasor.","searchKeywords":["for","jonathan","and","his","host","they","pitched","the","water","gennesar","from","whence","betimes","morning","gat","them","plain","nasor"]},{"verseId":"brenton_1-maccabees_11_68","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":68,"text":"And, behold, the host of strangers met them in the plain, who, having laid men in ambush for him in the mountains, came themselves over against him.","searchKeywords":["and","behold","the","host","strangers","met","them","plain","who","having","laid","men","ambush","for","him","mountains","came","themselves","over","against"]},{"verseId":"brenton_1-maccabees_11_69","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":69,"text":"So when they that lay in ambush rose out of their places, and joined battle, all that were of Jonathan's side fled;","searchKeywords":["when","they","that","lay","ambush","rose","out","their","places","and","joined","battle","all","were","jonathan","side","fled"]},{"verseId":"brenton_1-maccabees_11_70","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":70,"text":"insomuch as there was not one of them left, except Mattathias the of Absalom, and Judas the of Calphi, the captains of the host.","searchKeywords":["insomuch","there","was","not","one","them","left","except","mattathias","the","absalom","and","judas","calphi","captains","host"]},{"verseId":"brenton_1-maccabees_11_71","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":71,"text":"Then Jonathan rent his clothes, and cast earth upon his head, and prayed.","searchKeywords":["then","jonathan","rent","his","clothes","and","cast","earth","upon","head","prayed"]},{"verseId":"brenton_1-maccabees_11_72","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":72,"text":"Afterwards turning again to battle, he put them to flight, and so they ran away.","searchKeywords":["afterwards","turning","again","battle","put","them","flight","and","they","ran","away"]},{"verseId":"brenton_1-maccabees_11_73","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":73,"text":"Now when his own men that were fled saw this, they turned again unto him, and with him pursued them to Cades, even unto their own tents, and there they camped.","searchKeywords":["now","when","his","own","men","that","were","fled","saw","this","they","turned","again","unto","him","and","with","pursued","them","cades","even","their","tents","there","camped"]},{"verseId":"brenton_1-maccabees_11_74","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":11,"verse":74,"text":"So there were slain of the heathen that day about three thousand men: but Jonathan returned to Jerusalem.","searchKeywords":["there","were","slain","the","heathen","that","day","about","three","thousand","men","but","jonathan","returned","jerusalem"]}]