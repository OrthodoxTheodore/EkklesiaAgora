[{"verseId":"brenton_1-maccabees_3_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":1,"text":"Then his son Judas, called Maccabeus, rose up in his stead.","searchKeywords":["then","his","son","judas","called","maccabeus","rose","stead"]},{"verseId":"brenton_1-maccabees_3_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":2,"text":"And all his brethren helped him, and so did all they that held with his father, and they fought with cheerfulness the battle of Israel.","searchKeywords":["and","all","his","brethren","helped","him","did","they","that","held","with","father","fought","cheerfulness","the","battle","israel"]},{"verseId":"brenton_1-maccabees_3_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":3,"text":"So he gat his people great honour, and put on a breastplate as a giant, and girt his warlike harness about him, and he made battles, protecting the host with his sword.","searchKeywords":["gat","his","people","great","honour","and","put","breastplate","giant","girt","warlike","harness","about","him","made","battles","protecting","the","host","with","sword"]},{"verseId":"brenton_1-maccabees_3_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":4,"text":"In his acts he was like a lion, and like a lion's whelp roaring for his prey.","searchKeywords":["his","acts","was","like","lion","and","whelp","roaring","for","prey"]},{"verseId":"brenton_1-maccabees_3_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":5,"text":"For he pursued the wicked, and sought them out, and burnt up those that vexed his people.","searchKeywords":["for","pursued","the","wicked","and","sought","them","out","burnt","those","that","vexed","his","people"]},{"verseId":"brenton_1-maccabees_3_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":6,"text":"Wherefore the wicked shrunk for fear of him, and all the workers of iniquity were troubled, because salvation prospered in his hand.","searchKeywords":["wherefore","the","wicked","shrunk","for","fear","him","and","all","workers","iniquity","were","troubled","because","salvation","prospered","his","hand"]},{"verseId":"brenton_1-maccabees_3_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":7,"text":"He grieved also many kings, and made Jacob glad with his acts, and his memorial is blessed for ever.","searchKeywords":["grieved","also","many","kings","and","made","jacob","glad","with","his","acts","memorial","blessed","for","ever"]},{"verseId":"brenton_1-maccabees_3_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":8,"text":"Moreover he went through the cities of Juda, destroying the ungodly out of them, and turning away wrath from Israel:","searchKeywords":["moreover","went","through","the","cities","juda","destroying","ungodly","out","them","and","turning","away","wrath","from","israel"]},{"verseId":"brenton_1-maccabees_3_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":9,"text":"so that he was renowned unto the utmost part of the earth, and he received unto him such as were ready to perish.","searchKeywords":["that","was","renowned","unto","the","utmost","part","earth","and","received","him","such","were","ready","perish"]},{"verseId":"brenton_1-maccabees_3_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":10,"text":"Then Apollonius gathered the Gentiles together, and a great host out of Samaria, to fight against Israel.","searchKeywords":["then","apollonius","gathered","the","gentiles","together","and","great","host","out","samaria","fight","against","israel"]},{"verseId":"brenton_1-maccabees_3_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":11,"text":"Which thing when Judas perceived, he went forth to meet him, and so he smote him, and slew him: many also fell down slain, but the rest fled.","searchKeywords":["which","thing","when","judas","perceived","went","forth","meet","him","and","smote","slew","many","also","fell","down","slain","but","the","rest","fled"]},{"verseId":"brenton_1-maccabees_3_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":12,"text":"Wherefore Judas took their spoils, and Apollonius' sword also, and therewith he fought all his life long.","searchKeywords":["wherefore","judas","took","their","spoils","and","apollonius","sword","also","therewith","fought","all","his","life","long"]},{"verseId":"brenton_1-maccabees_3_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":13,"text":"Now when Seron, a prince of the army of Syria, heard say that Judas had gathered unto him a multitude and company of the faithful to go out with him to war;","searchKeywords":["now","when","seron","prince","the","army","syria","heard","say","that","judas","had","gathered","unto","him","multitude","and","company","faithful","out","with","war"]},{"verseId":"brenton_1-maccabees_3_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":14,"text":"he said, I will get me a name and honour in the kingdom; for I will go fight with Judas and them that are with him, who despise the king's commandment.","searchKeywords":["said","will","get","name","and","honour","the","kingdom","for","fight","with","judas","them","that","are","him","who","despise","king","commandment"]},{"verseId":"brenton_1-maccabees_3_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":15,"text":"So he made him ready to go up, and there went with him a mighty host of the ungodly to help him, and to be avenged of the children of Israel.","searchKeywords":["made","him","ready","and","there","went","with","mighty","host","the","ungodly","help","avenged","children","israel"]},{"verseId":"brenton_1-maccabees_3_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":16,"text":"And when he came near to the going up of Bethhoron, Judas went forth to meet him with a small company:","searchKeywords":["and","when","came","near","the","going","bethhoron","judas","went","forth","meet","him","with","small","company"]},{"verseId":"brenton_1-maccabees_3_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":17,"text":"who, when they saw the host coming to meet them, said unto Judas, How shall we be able, being so few, to fight against so great a multitude so strong, seeing we are ready to faint with fasting all this day?","searchKeywords":["who","when","they","saw","the","host","coming","meet","them","said","unto","judas","how","shall","able","being","few","fight","against","great","multitude","strong","seeing","are","ready","faint","with","fasting","all","this","day"]},{"verseId":"brenton_1-maccabees_3_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":18,"text":"Unto whom Judas answered, It is no hard matter for many to be shut up in the hands of a few; and with heaven it is all one, to deliver with a great multitude, or a small company;","searchKeywords":["unto","whom","judas","answered","hard","matter","for","many","shut","the","hands","few","and","with","heaven","all","one","deliver","great","multitude","small","company"]},{"verseId":"brenton_1-maccabees_3_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":19,"text":"for the victory of battle standeth not in the multitude of an host; but strength cometh from heaven.","searchKeywords":["for","the","victory","battle","standeth","not","multitude","host","but","strength","cometh","from","heaven"]},{"verseId":"brenton_1-maccabees_3_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":20,"text":"They come against us in much pride and iniquity to destroy us, and our wives and children, and to spoil us:","searchKeywords":["they","come","against","much","pride","and","iniquity","destroy","our","wives","children","spoil"]},{"verseId":"brenton_1-maccabees_3_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":21,"text":"but we fight for our lives and our laws.","searchKeywords":["but","fight","for","our","lives","and","laws"]},{"verseId":"brenton_1-maccabees_3_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":22,"text":"Wherefore the Lord himself will overthrow them before our face: and as for you, be ye not afraid of them.","searchKeywords":["wherefore","the","lord","himself","will","overthrow","them","before","our","face","and","for","you","not","afraid"]},{"verseId":"brenton_1-maccabees_3_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":23,"text":"Now as soon as he had left off speaking, he leaped suddenly upon them, and so Seron and his host were overthrown before him.","searchKeywords":["now","soon","had","left","off","speaking","leaped","suddenly","upon","them","and","seron","his","host","were","overthrown","before","him"]},{"verseId":"brenton_1-maccabees_3_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":24,"text":"And they pursued them from the going down of Bethhoron unto the plain, where were slain about eight hundred men of them; and the residue fled into the land of the Philistines.","searchKeywords":["and","they","pursued","them","from","the","going","down","bethhoron","unto","plain","where","were","slain","about","eight","hundred","men","residue","fled","into","land","philistines"]},{"verseId":"brenton_1-maccabees_3_25","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":25,"text":"Then began the fear of Judas and his brethren, and exceeding great dread, to fall upon the nations round about them:","searchKeywords":["then","began","the","fear","judas","and","his","brethren","exceeding","great","dread","fall","upon","nations","round","about","them"]},{"verseId":"brenton_1-maccabees_3_26","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":26,"text":"insomuch as his fame came unto the king, and all nations talked of the battles of Judas.","searchKeywords":["insomuch","his","fame","came","unto","the","king","and","all","nations","talked","battles","judas"]},{"verseId":"brenton_1-maccabees_3_27","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":27,"text":"Now when king Antiochus heard these things, he was full of indignation: wherefore he sent and gathered together all the forces of his realm, a very strong army.","searchKeywords":["now","when","king","antiochus","heard","these","things","was","full","indignation","wherefore","sent","and","gathered","together","all","the","forces","his","realm","very","strong","army"]},{"verseId":"brenton_1-maccabees_3_28","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":28,"text":"He opened also his treasure, and gave his soldiers pay for a year, commanding them to be ready whensoever he should need them.","searchKeywords":["opened","also","his","treasure","and","gave","soldiers","pay","for","year","commanding","them","ready","whensoever","should","need"]},{"verseId":"brenton_1-maccabees_3_29","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":29,"text":"Nevertheless, when he saw that the money of his treasures failed, and that the tributes in the country were small, because of the dissension and plague, which he had brought upon the land in taking away the laws which had been of old time;","searchKeywords":["nevertheless","when","saw","that","the","money","his","treasures","failed","and","tributes","country","were","small","because","dissension","plague","which","had","brought","upon","land","taking","away","laws","been","old","time"]},{"verseId":"brenton_1-maccabees_3_30","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":30,"text":"he feared that he should not be able to bear the charges any longer, nor to have such gifts to give so liberally as he did before: for he had abounded above the kings that were before him.","searchKeywords":["feared","that","should","not","able","bear","the","charges","any","longer","nor","have","such","gifts","give","liberally","did","before","for","had","abounded","above","kings","were","him"]},{"verseId":"brenton_1-maccabees_3_31","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":31,"text":"Wherefore, being greatly perplexed in his mind, he determined to go into Persia, there to take the tributes of the countries, and to gather much money.","searchKeywords":["wherefore","being","greatly","perplexed","his","mind","determined","into","persia","there","take","the","tributes","countries","and","gather","much","money"]},{"verseId":"brenton_1-maccabees_3_32","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":32,"text":"So he left Lysias, a nobleman, and one of the blood royal, to oversee the affairs of the king from the river Euphrates unto the borders of Egypt:","searchKeywords":["left","lysias","nobleman","and","one","the","blood","royal","oversee","affairs","king","from","river","euphrates","unto","borders","egypt"]},{"verseId":"brenton_1-maccabees_3_33","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":33,"text":"and to bring up his son Antiochus, until he came again.","searchKeywords":["and","bring","his","son","antiochus","until","came","again"]},{"verseId":"brenton_1-maccabees_3_34","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":34,"text":"Moreover he delivered unto him the half of his forces, and the elephants, and gave him charge of all things that he would have done, as also concerning them that dwelt in Juda and Jerusalem;","searchKeywords":["moreover","delivered","unto","him","the","half","his","forces","and","elephants","gave","charge","all","things","that","would","have","done","also","concerning","them","dwelt","juda","jerusalem"]},{"verseId":"brenton_1-maccabees_3_35","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":35,"text":", that he should send an army against them, to destroy and root out the strength of Israel, and the remnant of Jerusalem, and to take away their memorial from that place;","searchKeywords":["that","should","send","army","against","them","destroy","and","root","out","the","strength","israel","remnant","jerusalem","take","away","their","memorial","from","place"]},{"verseId":"brenton_1-maccabees_3_36","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":36,"text":"and that he should place strangers in all their quarters, and divide their land by lot.","searchKeywords":["and","that","should","place","strangers","all","their","quarters","divide","land","lot"]},{"verseId":"brenton_1-maccabees_3_37","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":37,"text":"So the king took the half of the forces that remained, and departed from Antioch, his royal city, the hundred forty and seventh year; and he passed the river Euphrates, and went through the high countries.","searchKeywords":["the","king","took","half","forces","that","remained","and","departed","from","antioch","his","royal","city","hundred","forty","seventh","year","passed","river","euphrates","went","through","high","countries"]},{"verseId":"brenton_1-maccabees_3_38","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":38,"text":"Then Lysias chose Ptolemee the of Dorymenes, and Nicanor, and Gorgias, mighty men of the king's friends:","searchKeywords":["then","lysias","chose","ptolemee","the","dorymenes","and","nicanor","gorgias","mighty","men","king","friends"]},{"verseId":"brenton_1-maccabees_3_39","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":39,"text":"and with them he sent forty thousand footmen, and seven thousand horsemen, to go into the land of Juda, and to destroy it, as the king commanded.","searchKeywords":["and","with","them","sent","forty","thousand","footmen","seven","horsemen","into","the","land","juda","destroy","king","commanded"]},{"verseId":"brenton_1-maccabees_3_40","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":40,"text":"So they went forth with all their power, and came and pitched by Emmaus in the plain country.","searchKeywords":["they","went","forth","with","all","their","power","and","came","pitched","emmaus","the","plain","country"]},{"verseId":"brenton_1-maccabees_3_41","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":41,"text":"And the merchants of the country, hearing the fame of them, took silver and gold very much, with servants, and came into the camp to buy the children of Israel for slaves: a power also of Syria and of the land of the Philistines joined themselves unto them.","searchKeywords":["and","the","merchants","country","hearing","fame","them","took","silver","gold","very","much","with","servants","came","into","camp","buy","children","israel","for","slaves","power","also","syria","land","philistines","joined","themselves","unto"]},{"verseId":"brenton_1-maccabees_3_42","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":42,"text":"Now when Judas and his brethren saw that miseries were multiplied, and that the forces did encamp themselves in their borders; for they knew how the king had given commandment to destroy the people, and utterly abolish them;","searchKeywords":["now","when","judas","and","his","brethren","saw","that","miseries","were","multiplied","the","forces","did","encamp","themselves","their","borders","for","they","knew","how","king","had","given","commandment","destroy","people","utterly","abolish","them"]},{"verseId":"brenton_1-maccabees_3_43","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":43,"text":"they said one to another, Let us restore the decayed estate of our people, and let us fight for our people and the sanctuary.","searchKeywords":["they","said","one","another","let","restore","the","decayed","estate","our","people","and","fight","for","sanctuary"]},{"verseId":"brenton_1-maccabees_3_44","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":44,"text":"Then the congregation gathered together, that they might be ready for battle, and that they might pray, and ask mercy and compassion.","searchKeywords":["then","the","congregation","gathered","together","that","they","might","ready","for","battle","and","pray","ask","mercy","compassion"]},{"verseId":"brenton_1-maccabees_3_45","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":45,"text":"Now Jerusalem was laid void as a wilderness, there was none of her children that went in or out: the sanctuary also was trodden down, and aliens kept the strong hold; the heathen had their habitation in that place; and joy was taken from Jacob, and the pipe with the harp ceased.","searchKeywords":["now","jerusalem","was","laid","void","wilderness","there","none","her","children","that","went","out","the","sanctuary","also","trodden","down","and","aliens","kept","strong","hold","heathen","had","their","habitation","place","joy","taken","from","jacob","pipe","with","harp","ceased"]},{"verseId":"brenton_1-maccabees_3_46","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":46,"text":"Wherefore the Israelites assembled themselves together, and came to Maspha, over against Jerusalem; for in Maspha was the place where they prayed aforetime in Israel.","searchKeywords":["wherefore","the","israelites","assembled","themselves","together","and","came","maspha","over","against","jerusalem","for","was","place","where","they","prayed","aforetime","israel"]},{"verseId":"brenton_1-maccabees_3_47","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":47,"text":"Then they fasted that day, and put on sackcloth, and cast ashes upon their heads, and rent their clothes,","searchKeywords":["then","they","fasted","that","day","and","put","sackcloth","cast","ashes","upon","their","heads","rent","clothes"]},{"verseId":"brenton_1-maccabees_3_48","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":48,"text":"and laid open the book of the law, wherein the heathen had sought to paint the likeness of their images.","searchKeywords":["and","laid","open","the","book","law","wherein","heathen","had","sought","paint","likeness","their","images"]},{"verseId":"brenton_1-maccabees_3_49","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":49,"text":"They brought also the priest's garments, and the firstfruits, and the tithes: and the Nazarites they stirred up, who had accomplished their days.","searchKeywords":["they","brought","also","the","priest","garments","and","firstfruits","tithes","nazarites","stirred","who","had","accomplished","their","days"]},{"verseId":"brenton_1-maccabees_3_50","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":50,"text":"Then cried they with a loud voice toward heaven, saying, What shall we do with these, and whither shall we carry them away?","searchKeywords":["then","cried","they","with","loud","voice","toward","heaven","saying","what","shall","these","and","whither","carry","them","away"]},{"verseId":"brenton_1-maccabees_3_51","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":51,"text":"For thy sanctuary is trodden down and profaned, and thy priests are in heaviness, and brought low.","searchKeywords":["for","thy","sanctuary","trodden","down","and","profaned","priests","are","heaviness","brought","low"]},{"verseId":"brenton_1-maccabees_3_52","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":52,"text":"And, lo, the heathen are assembled together against us to destroy us: what things they imagine against us, thou knowest.","searchKeywords":["and","the","heathen","are","assembled","together","against","destroy","what","things","they","imagine","thou","knowest"]},{"verseId":"brenton_1-maccabees_3_53","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":53,"text":"How shall we be able to stand against them, except thou, , be our help?","searchKeywords":["how","shall","able","stand","against","them","except","thou","our","help"]},{"verseId":"brenton_1-maccabees_3_54","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":54,"text":"Then sounded they with trumpets, and cried with a loud voice.","searchKeywords":["then","sounded","they","with","trumpets","and","cried","loud","voice"]},{"verseId":"brenton_1-maccabees_3_55","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":55,"text":"And after this Judas ordained captains over the people, captains over thousands, and over hundreds, and over fifties, and over tens.","searchKeywords":["and","after","this","judas","ordained","captains","over","the","people","thousands","hundreds","fifties","tens"]},{"verseId":"brenton_1-maccabees_3_56","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":56,"text":"But as for such as were building houses, or had betrothed wives, or were planting vineyards, or were fearful, those he commanded that they should return, every man to his own house, according to the law.","searchKeywords":["but","for","such","were","building","houses","had","betrothed","wives","planting","vineyards","fearful","those","commanded","that","they","should","return","every","man","his","own","house","according","the","law"]},{"verseId":"brenton_1-maccabees_3_57","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":57,"text":"So the camp removed, and pitched upon the south side of Emmaus.","searchKeywords":["the","camp","removed","and","pitched","upon","south","side","emmaus"]},{"verseId":"brenton_1-maccabees_3_58","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":58,"text":"And Judas said, Arm yourselves, and be valiant men, and see that ye be in readiness against the morning, that ye may fight with these nations, that are assembled together against us to destroy us and our sanctuary:","searchKeywords":["and","judas","said","arm","yourselves","valiant","men","see","that","readiness","against","the","morning","may","fight","with","these","nations","are","assembled","together","destroy","our","sanctuary"]},{"verseId":"brenton_1-maccabees_3_59","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":59,"text":"for it is better for us to die in battle, than to behold the calamities of our people and our sanctuary.","searchKeywords":["for","better","die","battle","than","behold","the","calamities","our","people","and","sanctuary"]},{"verseId":"brenton_1-maccabees_3_60","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":3,"verse":60,"text":"Nevertheless, as the will is in heaven, so let him do.","searchKeywords":["nevertheless","the","will","heaven","let","him"]}]