[{"verseId":"brenton_1-maccabees_15_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":1,"text":"Moreover Antiochus son of Demetrius the king sent letters from the isles of the sea unto Simon the priest and prince of the Jews, and to all the people;","searchKeywords":["moreover","antiochus","son","demetrius","the","king","sent","letters","from","isles","sea","unto","simon","priest","and","prince","jews","all","people"]},{"verseId":"brenton_1-maccabees_15_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":2,"text":"the contents whereof were these: King Antiochus to Simon the high priest and prince of his nation, and to the people of the Jews, greeting:","searchKeywords":["the","contents","whereof","were","these","king","antiochus","simon","high","priest","and","prince","his","nation","people","jews","greeting"]},{"verseId":"brenton_1-maccabees_15_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":3,"text":"Forasmuch as certain pestilent men have usurped the kingdom of our fathers, and my purpose is to challenge it again, that I may restore it to the old estate, and to that end have gathered a multitude of foreign soldiers together, and prepared ships of war;","searchKeywords":["forasmuch","certain","pestilent","men","have","usurped","the","kingdom","our","fathers","and","purpose","challenge","again","that","may","restore","old","estate","end","gathered","multitude","foreign","soldiers","together","prepared","ships","war"]},{"verseId":"brenton_1-maccabees_15_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":4,"text":"my meaning also being to go through the country, that I may be avenged of them that have destroyed it, and made many cities in the kingdom desolate:","searchKeywords":["meaning","also","being","through","the","country","that","may","avenged","them","have","destroyed","and","made","many","cities","kingdom","desolate"]},{"verseId":"brenton_1-maccabees_15_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":5,"text":"now therefore I confirm unto thee all the oblations which the kings before me granted thee, and whatsoever gifts besides they granted.","searchKeywords":["now","therefore","confirm","unto","thee","all","the","oblations","which","kings","before","granted","and","whatsoever","gifts","besides","they"]},{"verseId":"brenton_1-maccabees_15_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":6,"text":"I give thee leave also to coin money for thy country with thine own stamp.","searchKeywords":["give","thee","leave","also","coin","money","for","thy","country","with","thine","own","stamp"]},{"verseId":"brenton_1-maccabees_15_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":7,"text":"And as concerning Jerusalem and the sanctuary, let them be free; and all the armour that thou hast made, and fortresses that thou hast built, and keepest in thine hands, let them remain unto thee.","searchKeywords":["and","concerning","jerusalem","the","sanctuary","let","them","free","all","armour","that","thou","hast","made","fortresses","built","keepest","thine","hands","remain","unto","thee"]},{"verseId":"brenton_1-maccabees_15_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":8,"text":"And if any thing be, or shall be, owing to the king, let it be forgiven thee from this time forth for evermore.","searchKeywords":["and","any","thing","shall","owing","the","king","let","forgiven","thee","from","this","time","forth","for","evermore"]},{"verseId":"brenton_1-maccabees_15_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":9,"text":"Furthermore, when we have obtained our kingdom, we will honour thee, and thy nation, and thy temple, with great honour, so that your honour shall be known throughout the world.","searchKeywords":["furthermore","when","have","obtained","our","kingdom","will","honour","thee","and","thy","nation","temple","with","great","that","your","shall","known","throughout","the","world"]},{"verseId":"brenton_1-maccabees_15_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":10,"text":"In the hundred threescore and fourteenth year went Antiochus into the land of his fathers: at which time all the forces came together unto him, so that few were left with Tryphon.","searchKeywords":["the","hundred","threescore","and","fourteenth","year","went","antiochus","into","land","his","fathers","which","time","all","forces","came","together","unto","him","that","few","were","left","with","tryphon"]},{"verseId":"brenton_1-maccabees_15_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":11,"text":"Wherefore being pursued by king Antiochus, he fled unto Dora, which lieth by the sea side:","searchKeywords":["wherefore","being","pursued","king","antiochus","fled","unto","dora","which","lieth","the","sea","side"]},{"verseId":"brenton_1-maccabees_15_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":12,"text":"for he saw that troubles came upon him all at once, and that his forces had forsaken him.","searchKeywords":["for","saw","that","troubles","came","upon","him","all","once","and","his","forces","had","forsaken"]},{"verseId":"brenton_1-maccabees_15_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":13,"text":"Then camped Antiochus against Dora, having with him an hundred and twenty thousand men of war, and eight thousand horsemen.","searchKeywords":["then","camped","antiochus","against","dora","having","with","him","hundred","and","twenty","thousand","men","war","eight","horsemen"]},{"verseId":"brenton_1-maccabees_15_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":14,"text":"And when he had compassed the city round about, and joined ships close to the town on the sea side, he vexed the city by land and by sea, neither suffered he any to go out or in.","searchKeywords":["and","when","had","compassed","the","city","round","about","joined","ships","close","town","sea","side","vexed","land","neither","suffered","any","out"]},{"verseId":"brenton_1-maccabees_15_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":15,"text":"In the mean season came Numenius and his company from Rome, having letters to the kings and countries; wherein were written these things:","searchKeywords":["the","mean","season","came","numenius","and","his","company","from","rome","having","letters","kings","countries","wherein","were","written","these","things"]},{"verseId":"brenton_1-maccabees_15_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":16,"text":"Lucius, consul of the Romans unto king Ptolemee, greeting:","searchKeywords":["lucius","consul","the","romans","unto","king","ptolemee","greeting"]},{"verseId":"brenton_1-maccabees_15_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":17,"text":"The Jews' ambassadors, our friends and confederates, came unto us to renew the old friendship and league, being sent from Simon the high priest, and from the people of the Jews:","searchKeywords":["the","jews","ambassadors","our","friends","and","confederates","came","unto","renew","old","friendship","league","being","sent","from","simon","high","priest","people"]},{"verseId":"brenton_1-maccabees_15_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":18,"text":"and they brought a shield of gold of a thousand pound.","searchKeywords":["and","they","brought","shield","gold","thousand","pound"]},{"verseId":"brenton_1-maccabees_15_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":19,"text":"We thought it good therefore to write unto the kings and countries, that they should do them no harm, nor fight against them, their cities, or countries, nor yet aid their enemies against them.","searchKeywords":["thought","good","therefore","write","unto","the","kings","and","countries","that","they","should","them","harm","nor","fight","against","their","cities","yet","aid","enemies"]},{"verseId":"brenton_1-maccabees_15_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":20,"text":"It seemed also good to us to receive the shield of them.","searchKeywords":["seemed","also","good","receive","the","shield","them"]},{"verseId":"brenton_1-maccabees_15_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":21,"text":"If therefore there be any pestilent fellows, that have fled from their country unto you, deliver them unto Simon the high priest, that he may punish them according to their own law.","searchKeywords":["therefore","there","any","pestilent","fellows","that","have","fled","from","their","country","unto","you","deliver","them","simon","the","high","priest","may","punish","according","own","law"]},{"verseId":"brenton_1-maccabees_15_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":22,"text":"The same things wrote he likewise unto Demetrius the king, and Attalus, to Ariarathes, and Arsaces,","searchKeywords":["the","same","things","wrote","likewise","unto","demetrius","king","and","attalus","ariarathes","arsaces"]},{"verseId":"brenton_1-maccabees_15_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":23,"text":"and to all the countries, and to Sampsames, and the Lacedemonians, and to Delus, and Myndus, and Sicyon, and Caria, and Samos, and Pamphylia, and Lycia, and Halicarnassus, and Rhodus, and Phaselis, and Cos, and Side, and Aradus, and Gortyna, and Cnidus, and Cyprus, and Cyrene.","searchKeywords":["and","all","the","countries","sampsames","lacedemonians","delus","myndus","sicyon","caria","samos","pamphylia","lycia","halicarnassus","rhodus","phaselis","cos","side","aradus","gortyna","cnidus","cyprus","cyrene"]},{"verseId":"brenton_1-maccabees_15_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":24,"text":"And the copy hereof they wrote to Simon the high priest.","searchKeywords":["and","the","copy","hereof","they","wrote","simon","high","priest"]},{"verseId":"brenton_1-maccabees_15_25","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":25,"text":"So Antiochus the king camped against Dora the second , assaulting it continually, and making engines, by which means he shut up Tryphon, that he could neither go out nor in.","searchKeywords":["antiochus","the","king","camped","against","dora","second","assaulting","continually","and","making","engines","which","means","shut","tryphon","that","could","neither","out","nor"]},{"verseId":"brenton_1-maccabees_15_26","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":26,"text":"At that time Simon sent him two thousand chosen men to aid him; silver also, and gold, and much armour.","searchKeywords":["that","time","simon","sent","him","two","thousand","chosen","men","aid","silver","also","and","gold","much","armour"]},{"verseId":"brenton_1-maccabees_15_27","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":27,"text":"Nevertheless he would not receive them, but brake all the covenants which he had made with him afore, and became strange unto him.","searchKeywords":["nevertheless","would","not","receive","them","but","brake","all","the","covenants","which","had","made","with","him","afore","and","became","strange","unto"]},{"verseId":"brenton_1-maccabees_15_28","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":28,"text":"Furthermore he sent unto him Athenobius, one of his friends, to commune with him, and say, Ye withhold Joppe and Gazara, with the tower that is in Jerusalem, which are cities of my realm.","searchKeywords":["furthermore","sent","unto","him","athenobius","one","his","friends","commune","with","and","say","withhold","joppe","gazara","the","tower","that","jerusalem","which","are","cities","realm"]},{"verseId":"brenton_1-maccabees_15_29","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":29,"text":"The borders thereof ye have wasted, and done great hurt in the land, and got the dominion of many places within my kingdom.","searchKeywords":["the","borders","thereof","have","wasted","and","done","great","hurt","land","got","dominion","many","places","within","kingdom"]},{"verseId":"brenton_1-maccabees_15_30","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":30,"text":"Now therefore deliver the cities which ye have taken, and the tributes of the places, whereof ye have gotten dominion without the borders of Judea:","searchKeywords":["now","therefore","deliver","the","cities","which","have","taken","and","tributes","places","whereof","gotten","dominion","without","borders","judea"]},{"verseId":"brenton_1-maccabees_15_31","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":31,"text":"or else give me for them five hundred talents of silver; and for the harm that ye have done, and the tributes of the cities, other five hundred talents: if not, we will come and fight against you.","searchKeywords":["else","give","for","them","five","hundred","talents","silver","and","the","harm","that","have","done","tributes","cities","other","not","will","come","fight","against","you"]},{"verseId":"brenton_1-maccabees_15_32","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":32,"text":"So Athenobius the king's friend came to Jerusalem: and when he saw the glory of Simon, and the cupboard of gold and silver plate, and his great attendance, he was astonished, and told him the king's message.","searchKeywords":["athenobius","the","king","friend","came","jerusalem","and","when","saw","glory","simon","cupboard","gold","silver","plate","his","great","attendance","was","astonished","told","him","message"]},{"verseId":"brenton_1-maccabees_15_33","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":33,"text":"Then answered Simon, and said unto him, We have neither taken other men's land, nor holden that which appertaineth to others, but the inheritance of our fathers, which our enemies had wrongfully in possession a certain time.","searchKeywords":["then","answered","simon","and","said","unto","him","have","neither","taken","other","men","land","nor","holden","that","which","appertaineth","others","but","the","inheritance","our","fathers","enemies","had","wrongfully","possession","certain","time"]},{"verseId":"brenton_1-maccabees_15_34","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":34,"text":"Wherefore we, having opportunity, hold the inheritance of our fathers.","searchKeywords":["wherefore","having","opportunity","hold","the","inheritance","our","fathers"]},{"verseId":"brenton_1-maccabees_15_35","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":35,"text":"And whereas thou demandest Joppe and Gazara, albeit they did great harm unto the people in our country, yet will we give an hundred talents for them.","searchKeywords":["and","whereas","thou","demandest","joppe","gazara","albeit","they","did","great","harm","unto","the","people","our","country","yet","will","give","hundred","talents","for","them"]},{"verseId":"brenton_1-maccabees_15_36","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":36,"text":"but returned in a rage to the king, and made report unto him of these speeches, and of the glory of Simon, and of all that he had seen: whereupon the king was exceeding wroth.","searchKeywords":["but","returned","rage","the","king","and","made","report","unto","him","these","speeches","glory","simon","all","that","had","seen","whereupon","was","exceeding","wroth"]},{"verseId":"brenton_1-maccabees_15_37","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":37,"text":"In the mean time fled Tryphon by ship unto Orthosias.","searchKeywords":["the","mean","time","fled","tryphon","ship","unto","orthosias"]},{"verseId":"brenton_1-maccabees_15_38","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":38,"text":"Then the king made Cendebeus captain of the sea coast, and gave him an host of footmen and horsemen,","searchKeywords":["then","the","king","made","cendebeus","captain","sea","coast","and","gave","him","host","footmen","horsemen"]},{"verseId":"brenton_1-maccabees_15_39","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":39,"text":"and commanded him to remove his host toward Judea: also he commanded him to build up Cedron, and to fortify the gates, and to war against the people; but as for the king , he pursued Tryphon.","searchKeywords":["and","commanded","him","remove","his","host","toward","judea","also","build","cedron","fortify","the","gates","war","against","people","but","for","king","pursued","tryphon"]},{"verseId":"brenton_1-maccabees_15_40","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":40,"text":"So Cendebeus came to Jamnia, and began to provoke the people, and to invade Judea, and to take the people prisoners, and slay them.","searchKeywords":["cendebeus","came","jamnia","and","began","provoke","the","people","invade","judea","take","prisoners","slay","them"]},{"verseId":"brenton_1-maccabees_15_41","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":15,"verse":41,"text":"And when he had built up Cedron, he set horsemen there, and an host , to the end that issuing out they might make outroads upon the ways of Judea, as the king had commanded him.","searchKeywords":["and","when","had","built","cedron","set","horsemen","there","host","the","end","that","issuing","out","they","might","make","outroads","upon","ways","judea","king","commanded","him"]}]