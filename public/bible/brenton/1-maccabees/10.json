[{"verseId":"brenton_1-maccabees_10_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":1,"text":"In the hundred and sixtieth year Alexander, the of Antiochus Epiphanes, went up and took Ptolemais: for the people had received him, by means whereof he reigned there.","searchKeywords":["the","hundred","and","sixtieth","year","alexander","antiochus","epiphanes","went","took","ptolemais","for","people","had","received","him","means","whereof","reigned","there"]},{"verseId":"brenton_1-maccabees_10_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":2,"text":"Now when king Demetrius heard thereof, he gathered together an exceeding great host, and went forth against him to fight.","searchKeywords":["now","when","king","demetrius","heard","thereof","gathered","together","exceeding","great","host","and","went","forth","against","him","fight"]},{"verseId":"brenton_1-maccabees_10_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":3,"text":"Moreover Demetrius sent letters unto Jonathan with loving words, so as he magnified him.","searchKeywords":["moreover","demetrius","sent","letters","unto","jonathan","with","loving","words","magnified","him"]},{"verseId":"brenton_1-maccabees_10_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":4,"text":"For said he, Let us first make peace with him, before he join with Alexander against us:","searchKeywords":["for","said","let","first","make","peace","with","him","before","join","alexander","against"]},{"verseId":"brenton_1-maccabees_10_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":5,"text":"else he will remember all the evils that we have done against him, and against his brethren and his people.","searchKeywords":["else","will","remember","all","the","evils","that","have","done","against","him","and","his","brethren","people"]},{"verseId":"brenton_1-maccabees_10_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":6,"text":"Wherefore he gave him authority to gather together an host, and to provide weapons, that he might aid him in battle: he commanded also that the hostages that were in the tower should be delivered him.","searchKeywords":["wherefore","gave","him","authority","gather","together","host","and","provide","weapons","that","might","aid","battle","commanded","also","the","hostages","were","tower","should","delivered"]},{"verseId":"brenton_1-maccabees_10_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":7,"text":"Then came Jonathan to Jerusalem, and read the letters in the audience of all the people, and of them that were in the tower:","searchKeywords":["then","came","jonathan","jerusalem","and","read","the","letters","audience","all","people","them","that","were","tower"]},{"verseId":"brenton_1-maccabees_10_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":8,"text":"who were sore afraid, when they heard that the king had given him authority to gather together an host.","searchKeywords":["who","were","sore","afraid","when","they","heard","that","the","king","had","given","him","authority","gather","together","host"]},{"verseId":"brenton_1-maccabees_10_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":9,"text":"Whereupon they of the tower delivered their hostages unto Jonathan, and he delivered them unto their parents.","searchKeywords":["whereupon","they","the","tower","delivered","their","hostages","unto","jonathan","and","them","parents"]},{"verseId":"brenton_1-maccabees_10_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":10,"text":"This done, Jonathan settled himself in Jerusalem, and began to build and repair the city.","searchKeywords":["this","done","jonathan","settled","himself","jerusalem","and","began","build","repair","the","city"]},{"verseId":"brenton_1-maccabees_10_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":11,"text":"And he commanded the workmen to build the walls and the mount Sion round about with square stones for fortification; and they did so.","searchKeywords":["and","commanded","the","workmen","build","walls","mount","sion","round","about","with","square","stones","for","fortification","they","did"]},{"verseId":"brenton_1-maccabees_10_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":12,"text":"Then the strangers, that were in the fortresses which Bacchides had built, fled away;","searchKeywords":["then","the","strangers","that","were","fortresses","which","bacchides","had","built","fled","away"]},{"verseId":"brenton_1-maccabees_10_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":13,"text":"insomuch as every man left his place, and went into his own country.","searchKeywords":["insomuch","every","man","left","his","place","and","went","into","own","country"]},{"verseId":"brenton_1-maccabees_10_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":14,"text":"Only at Bethsura certain of those that had forsaken the law and the commandments remained still: for it was their place of refuge.","searchKeywords":["only","bethsura","certain","those","that","had","forsaken","the","law","and","commandments","remained","still","for","was","their","place","refuge"]},{"verseId":"brenton_1-maccabees_10_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":15,"text":"Now when king Alexander had heard what promises Demetrius had sent unto Jonathan: when also it was told him of the battles and noble acts which he and his brethren had done, and of the pains that they had endured,","searchKeywords":["now","when","king","alexander","had","heard","what","promises","demetrius","sent","unto","jonathan","also","was","told","him","the","battles","and","noble","acts","which","his","brethren","done","pains","that","they","endured"]},{"verseId":"brenton_1-maccabees_10_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":16,"text":"he said, Shall we find such another man? now therefore we will make him our friend and confederate.","searchKeywords":["said","shall","find","such","another","man","now","therefore","will","make","him","our","friend","and","confederate"]},{"verseId":"brenton_1-maccabees_10_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":17,"text":"Upon this he wrote a letter, and sent it unto him, according to these words, saying,","searchKeywords":["upon","this","wrote","letter","and","sent","unto","him","according","these","words","saying"]},{"verseId":"brenton_1-maccabees_10_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":18,"text":"King Alexander to his brother Jonathan sendeth greeting:","searchKeywords":["king","alexander","his","brother","jonathan","sendeth","greeting"]},{"verseId":"brenton_1-maccabees_10_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":19,"text":"We have heard of thee, that thou art a man of great power, and meet to be our friend.","searchKeywords":["have","heard","thee","that","thou","art","man","great","power","and","meet","our","friend"]},{"verseId":"brenton_1-maccabees_10_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":20,"text":"Wherefore now this day we ordain thee to be the high priest of thy nation, and to be called the king's friend; (and therewithal he sent him a purple robe and a crown of gold:) and to take our part, and keep friendship with us.","searchKeywords":["wherefore","now","this","day","ordain","thee","the","high","priest","thy","nation","and","called","king","friend","therewithal","sent","him","purple","robe","crown","gold","take","our","part","keep","friendship","with"]},{"verseId":"brenton_1-maccabees_10_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":21,"text":"So in the seventh month of the hundred and sixtieth year, at the feast of the tabernacles, Jonathan put on the holy robe, and gathered together forces, and provided much armour.","searchKeywords":["the","seventh","month","hundred","and","sixtieth","year","feast","tabernacles","jonathan","put","holy","robe","gathered","together","forces","provided","much","armour"]},{"verseId":"brenton_1-maccabees_10_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":22,"text":"Whereof when Demetrius heard, he was very sorry, and said,","searchKeywords":["whereof","when","demetrius","heard","was","very","sorry","and","said"]},{"verseId":"brenton_1-maccabees_10_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":23,"text":"What have we done, that Alexander hath prevented us in making amity with the Jews to strengthen himself?","searchKeywords":["what","have","done","that","alexander","hath","prevented","making","amity","with","the","jews","strengthen","himself"]},{"verseId":"brenton_1-maccabees_10_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":24,"text":"I also will write unto them words of encouragement, dignities and gifts, that I may have their aid.","searchKeywords":["also","will","write","unto","them","words","encouragement","dignities","and","gifts","that","may","have","their","aid"]},{"verseId":"brenton_1-maccabees_10_25","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":25,"text":"He sent unto them therefore to this effect: King Demetrius unto the people of the Jews sendeth greeting:","searchKeywords":["sent","unto","them","therefore","this","effect","king","demetrius","the","people","jews","sendeth","greeting"]},{"verseId":"brenton_1-maccabees_10_26","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":26,"text":"Whereas ye have kept covenants with us, and continued in our friendship, not joining yourselves with our enemies, we have heard hereof, and are glad.","searchKeywords":["whereas","have","kept","covenants","with","and","continued","our","friendship","not","joining","yourselves","enemies","heard","hereof","are","glad"]},{"verseId":"brenton_1-maccabees_10_27","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":27,"text":"Wherefore now continue ye still to be faithful unto us, and we will well recompense you for the things ye do in our behalf,","searchKeywords":["wherefore","now","continue","still","faithful","unto","and","will","well","recompense","you","for","the","things","our","behalf"]},{"verseId":"brenton_1-maccabees_10_28","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":28,"text":"and will grant you many immunities, and give you rewards.","searchKeywords":["and","will","grant","you","many","immunities","give","rewards"]},{"verseId":"brenton_1-maccabees_10_29","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":29,"text":"And now do I free you, and I release all the Jews, from tributes, and from the customs of salt, and from crown taxes,","searchKeywords":["and","now","free","you","release","all","the","jews","from","tributes","customs","salt","crown","taxes"]},{"verseId":"brenton_1-maccabees_10_30","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":30,"text":"and from that which appertaineth unto me to receive for the third part of the seed, and the half of the fruit of the trees, I release it from this day forth, so that they shall not be taken of the land of Juda, nor of the three governments which are added thereunto out of the country of Samaria and Galilee, from this day forth for evermore.","searchKeywords":["and","from","that","which","appertaineth","unto","receive","for","the","third","part","seed","half","fruit","trees","release","this","day","forth","they","shall","not","taken","land","juda","nor","three","governments","are","added","thereunto","out","country","samaria","galilee","evermore"]},{"verseId":"brenton_1-maccabees_10_31","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":31,"text":"Let Jerusalem also be holy and free, with the borders thereof, both from tenths and tributes.","searchKeywords":["let","jerusalem","also","holy","and","free","with","the","borders","thereof","both","from","tenths","tributes"]},{"verseId":"brenton_1-maccabees_10_32","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":32,"text":"And as for the tower which is at Jerusalem, I yield up my authority over it, and give it to the high priest, that he may set in it such men as he shall choose to keep it.","searchKeywords":["and","for","the","tower","which","jerusalem","yield","authority","over","give","high","priest","that","may","set","such","men","shall","choose","keep"]},{"verseId":"brenton_1-maccabees_10_33","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":33,"text":"Moreover I freely set at liberty every one of the Jews, that were carried captives out of the land of Juda into any part of my kingdom, and that all my officers remit the tributes even of their cattle.","searchKeywords":["moreover","freely","set","liberty","every","one","the","jews","that","were","carried","captives","out","land","juda","into","any","part","kingdom","and","all","officers","remit","tributes","even","their","cattle"]},{"verseId":"brenton_1-maccabees_10_34","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":34,"text":"Furthermore that all the feasts, and sabbaths, and new moons, and solemn days, and the three days before the feast, and the three days after the feast, shall be all days of immunity and freedom for all the Jews in my realm.","searchKeywords":["furthermore","that","all","the","feasts","and","sabbaths","new","moons","solemn","days","three","before","feast","after","shall","immunity","freedom","for","jews","realm"]},{"verseId":"brenton_1-maccabees_10_35","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":35,"text":"Also no man shall have authority to meddle , or to molest any of them in any matter.","searchKeywords":["also","man","shall","have","authority","meddle","molest","any","them","matter"]},{"verseId":"brenton_1-maccabees_10_36","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":36,"text":"further, that there be enrolled among the king's forces about thirty thousand men of the Jews, unto whom pay shall be given, as belongeth to all the king's forces.","searchKeywords":["further","that","there","enrolled","among","the","king","forces","about","thirty","thousand","men","jews","unto","whom","pay","shall","given","belongeth","all"]},{"verseId":"brenton_1-maccabees_10_37","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":37,"text":"And of them shall be placed in the king's strong holds, of whom also shall be set over the affairs of the kingdom, which are of trust: and that their overseers and governors be of themselves, and that they live after their own laws, even as the king hath commanded in the land of Judea.","searchKeywords":["and","them","shall","placed","the","king","strong","holds","whom","also","set","over","affairs","kingdom","which","are","trust","that","their","overseers","governors","themselves","they","live","after","own","laws","even","hath","commanded","land","judea"]},{"verseId":"brenton_1-maccabees_10_38","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":38,"text":"And concerning the three governments that are added to Judea from the country of Samaria, let them be joined with Judea, that they may be reckoned to be under one, nor bound to obey other authority than the high priest's.","searchKeywords":["and","concerning","the","three","governments","that","are","added","judea","from","country","samaria","let","them","joined","with","they","may","reckoned","under","one","nor","bound","obey","other","authority","than","high","priest"]},{"verseId":"brenton_1-maccabees_10_39","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":39,"text":"Ptolemais, and the land pertaining thereto, I give as a free gift to the sanctuary at Jerusalem for the necessary expences of the sanctuary.","searchKeywords":["ptolemais","and","the","land","pertaining","thereto","give","free","gift","sanctuary","jerusalem","for","necessary","expences"]},{"verseId":"brenton_1-maccabees_10_40","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":40,"text":"Moreover I give every year fifteen thousand shekels of silver out of the king's accounts from the places appertaining.","searchKeywords":["moreover","give","every","year","fifteen","thousand","shekels","silver","out","the","king","accounts","from","places","appertaining"]},{"verseId":"brenton_1-maccabees_10_41","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":41,"text":"And all the overplus, which the officers paid not in as in former time, from henceforth shall be given toward the works of the temple.","searchKeywords":["and","all","the","overplus","which","officers","paid","not","former","time","from","henceforth","shall","given","toward","works","temple"]},{"verseId":"brenton_1-maccabees_10_42","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":42,"text":"And beside this, the five thousand shekels of silver, which they took from the uses of the temple out of the accounts year by year, even those things shall be released, because they appertain to the priests that minister.","searchKeywords":["and","beside","this","the","five","thousand","shekels","silver","which","they","took","from","uses","temple","out","accounts","year","even","those","things","shall","released","because","appertain","priests","that","minister"]},{"verseId":"brenton_1-maccabees_10_43","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":43,"text":"And whosoever they be that flee unto the temple at Jerusalem, or be within the liberties thereof, being indebted unto the king, or for any other matter, let them be at liberty, and all that they have in my realm.","searchKeywords":["and","whosoever","they","that","flee","unto","the","temple","jerusalem","within","liberties","thereof","being","indebted","king","for","any","other","matter","let","them","liberty","all","have","realm"]},{"verseId":"brenton_1-maccabees_10_44","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":44,"text":"For the building also and repairing of the works of the sanctuary, expences shall be given out of the king's accounts.","searchKeywords":["for","the","building","also","and","repairing","works","sanctuary","expences","shall","given","out","king","accounts"]},{"verseId":"brenton_1-maccabees_10_45","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":45,"text":"Yea, and for the building of the walls of Jerusalem, and the fortifying thereof round about, expences shall be given out of the king's accounts, as also for the building of the walls in Judea.","searchKeywords":["yea","and","for","the","building","walls","jerusalem","fortifying","thereof","round","about","expences","shall","given","out","king","accounts","also","judea"]},{"verseId":"brenton_1-maccabees_10_46","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":46,"text":"Now when Jonathan and the people heard these words, they gave no credit unto them, nor received them, because they remembered the great evil that he had done in Israel; for he had afflicted them very sore.","searchKeywords":["now","when","jonathan","and","the","people","heard","these","words","they","gave","credit","unto","them","nor","received","because","remembered","great","evil","that","had","done","israel","for","afflicted","very","sore"]},{"verseId":"brenton_1-maccabees_10_47","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":47,"text":"But with Alexander they were well pleased, because he was the first that entreated of true peace with them, and they were confederate with him always.","searchKeywords":["but","with","alexander","they","were","well","pleased","because","was","the","first","that","entreated","true","peace","them","and","confederate","him","always"]},{"verseId":"brenton_1-maccabees_10_48","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":48,"text":"Then gathered king Alexander great forces, and camped over against Demetrius.","searchKeywords":["then","gathered","king","alexander","great","forces","and","camped","over","against","demetrius"]},{"verseId":"brenton_1-maccabees_10_49","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":49,"text":"And after the two kings had joined battle, Demetrius' host fled: but Alexander followed after him, and prevailed against them.","searchKeywords":["and","after","the","two","kings","had","joined","battle","demetrius","host","fled","but","alexander","followed","him","prevailed","against","them"]},{"verseId":"brenton_1-maccabees_10_50","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":50,"text":"And he continued the battle very sore until the sun went down: and that day was Demetrius slain.","searchKeywords":["and","continued","the","battle","very","sore","until","sun","went","down","that","day","was","demetrius","slain"]},{"verseId":"brenton_1-maccabees_10_51","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":51,"text":"Afterward Alexander sent ambassadors to Ptolemee king of Egypt with a message to this effect:","searchKeywords":["afterward","alexander","sent","ambassadors","ptolemee","king","egypt","with","message","this","effect"]},{"verseId":"brenton_1-maccabees_10_52","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":52,"text":"Forasmuch as I am come again to my realm, and am set in the throne of my progenitors, and have gotten the dominion, and overthrown Demetrius, and recovered our country;","searchKeywords":["forasmuch","come","again","realm","and","set","the","throne","progenitors","have","gotten","dominion","overthrown","demetrius","recovered","our","country"]},{"verseId":"brenton_1-maccabees_10_53","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":53,"text":"for after I had joined battle with him, both he and his host was discomfited by us, so that we sit in the throne of his kingdom:","searchKeywords":["for","after","had","joined","battle","with","him","both","and","his","host","was","discomfited","that","sit","the","throne","kingdom"]},{"verseId":"brenton_1-maccabees_10_54","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":54,"text":"now therefore let us make a league of amity together, and give me now thy daughter to wife: and I will be thy son in law, and will give both thee and her gifts according to thy dignity.","searchKeywords":["now","therefore","let","make","league","amity","together","and","give","thy","daughter","wife","will","son","law","both","thee","her","gifts","according","dignity"]},{"verseId":"brenton_1-maccabees_10_55","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":55,"text":"Then Ptolemee the king gave answer, saying, Happy be the day wherein thou didst return into the land of thy fathers, and satest in the throne of their kingdom.","searchKeywords":["then","ptolemee","the","king","gave","answer","saying","happy","day","wherein","thou","didst","return","into","land","thy","fathers","and","satest","throne","their","kingdom"]},{"verseId":"brenton_1-maccabees_10_56","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":56,"text":"And now will I do to thee, as thou hast written: meet me therefore at Ptolemais, that we may see one another; for I will marry my daughter to thee according to thy desire.","searchKeywords":["and","now","will","thee","thou","hast","written","meet","therefore","ptolemais","that","may","see","one","another","for","marry","daughter","according","thy","desire"]},{"verseId":"brenton_1-maccabees_10_57","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":57,"text":"So Ptolemee went out of Egypt with his daughter Cleopatra, and they came unto Ptolemais in the hundred threescore and second year:","searchKeywords":["ptolemee","went","out","egypt","with","his","daughter","cleopatra","and","they","came","unto","ptolemais","the","hundred","threescore","second","year"]},{"verseId":"brenton_1-maccabees_10_58","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":58,"text":"where king Alexander meeting him, he gave unto him his daughter Cleopatra, and celebrated her marriage at Ptolemais with great glory, as the manner of kings is.","searchKeywords":["where","king","alexander","meeting","him","gave","unto","his","daughter","cleopatra","and","celebrated","her","marriage","ptolemais","with","great","glory","the","manner","kings"]},{"verseId":"brenton_1-maccabees_10_59","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":59,"text":"Now king Alexander had written unto Jonathan, that he should come and meet him.","searchKeywords":["now","king","alexander","had","written","unto","jonathan","that","should","come","and","meet","him"]},{"verseId":"brenton_1-maccabees_10_60","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":60,"text":"Who thereupon went honourably to Ptolemais, where he met the two kings, and gave them and their friends silver and gold, and many presents, and found favour in their sight.","searchKeywords":["who","thereupon","went","honourably","ptolemais","where","met","the","two","kings","and","gave","them","their","friends","silver","gold","many","presents","found","favour","sight"]},{"verseId":"brenton_1-maccabees_10_61","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":61,"text":"At that time certain pestilent fellows of Israel, men of a wicked life, assembled themselves against him, to accuse him: but the king would not hear them.","searchKeywords":["that","time","certain","pestilent","fellows","israel","men","wicked","life","assembled","themselves","against","him","accuse","but","the","king","would","not","hear","them"]},{"verseId":"brenton_1-maccabees_10_62","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":62,"text":"Yea more than that, the king commanded to take off his garments, and clothe him in purple: and they did so.","searchKeywords":["yea","more","than","that","the","king","commanded","take","off","his","garments","and","clothe","him","purple","they","did"]},{"verseId":"brenton_1-maccabees_10_63","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":63,"text":"Also he made him sit by himself, and said unto his princes, Go with him into the midst of the city, and make proclamation, that no man complain against him of any matter, and that no man trouble him for any manner of cause.","searchKeywords":["also","made","him","sit","himself","and","said","unto","his","princes","with","into","the","midst","city","make","proclamation","that","man","complain","against","any","matter","trouble","for","manner","cause"]},{"verseId":"brenton_1-maccabees_10_64","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":64,"text":"Now when his accusers saw that he was honoured according to the proclamation, and clothed in purple, they fled all away.","searchKeywords":["now","when","his","accusers","saw","that","was","honoured","according","the","proclamation","and","clothed","purple","they","fled","all","away"]},{"verseId":"brenton_1-maccabees_10_65","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":65,"text":"So the king honoured him, and wrote him among his chief friends, and made him a duke, and partaker of his dominion.","searchKeywords":["the","king","honoured","him","and","wrote","among","his","chief","friends","made","duke","partaker","dominion"]},{"verseId":"brenton_1-maccabees_10_66","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":66,"text":"Afterward Jonathan returned to Jerusalem with peace and gladness.","searchKeywords":["afterward","jonathan","returned","jerusalem","with","peace","and","gladness"]},{"verseId":"brenton_1-maccabees_10_67","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":67,"text":"Furthermore in the hundred threescore and fifth year came Demetrius son of Demetrius out of Crete into the land of his fathers:","searchKeywords":["furthermore","the","hundred","threescore","and","fifth","year","came","demetrius","son","out","crete","into","land","his","fathers"]},{"verseId":"brenton_1-maccabees_10_68","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":68,"text":"whereof when king Alexander heard tell, he was right sorry, and returned into Antioch.","searchKeywords":["whereof","when","king","alexander","heard","tell","was","right","sorry","and","returned","into","antioch"]},{"verseId":"brenton_1-maccabees_10_69","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":69,"text":"Then Demetrius made Apollonius the governor of Celosyria his general, who gathered together a great host, and camped in Jamnia, and sent unto Jonathan the high priest, saying,","searchKeywords":["then","demetrius","made","apollonius","the","governor","celosyria","his","general","who","gathered","together","great","host","and","camped","jamnia","sent","unto","jonathan","high","priest","saying"]},{"verseId":"brenton_1-maccabees_10_70","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":70,"text":"Thou alone liftest up thyself against us, and I am laughed to scorn for thy sake, and reproached: and why dost thou vaunt thy power against us in the mountains?","searchKeywords":["thou","alone","liftest","thyself","against","and","laughed","scorn","for","thy","sake","reproached","why","dost","vaunt","power","the","mountains"]},{"verseId":"brenton_1-maccabees_10_71","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":71,"text":"Now therefore, if thou trustest in thine own strength, come down to us into the plain field, and there let us try the matter together: for with me is the power of the cities.","searchKeywords":["now","therefore","thou","trustest","thine","own","strength","come","down","into","the","plain","field","and","there","let","try","matter","together","for","with","power","cities"]},{"verseId":"brenton_1-maccabees_10_72","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":72,"text":"Ask and learn who I am, and the rest that take our part, and they shall tell thee that thy foot is not able to stand before our face; for thy fathers have been twice put to flight in their own land.","searchKeywords":["ask","and","learn","who","the","rest","that","take","our","part","they","shall","tell","thee","thy","foot","not","able","stand","before","face","for","fathers","have","been","twice","put","flight","their","own","land"]},{"verseId":"brenton_1-maccabees_10_73","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":73,"text":"Wherefore now thou shalt not be able to abide the horsemen and so great a power in the plain, where is neither stone nor flint, nor place to flee unto.","searchKeywords":["wherefore","now","thou","shalt","not","able","abide","the","horsemen","and","great","power","plain","where","neither","stone","nor","flint","place","flee","unto"]},{"verseId":"brenton_1-maccabees_10_74","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":74,"text":"So when Jonathan heard these words of Apollonius, he was moved in his mind, and choosing ten thousand men he went out of Jerusalem, where Simon his brother met him for to help him.","searchKeywords":["when","jonathan","heard","these","words","apollonius","was","moved","his","mind","and","choosing","ten","thousand","men","went","out","jerusalem","where","simon","brother","met","him","for","help"]},{"verseId":"brenton_1-maccabees_10_75","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":75,"text":"And he pitched his tents against Joppe: but they shut him out of the city, because Apollonius had a garrison in Joppe.","searchKeywords":["and","pitched","his","tents","against","joppe","but","they","shut","him","out","the","city","because","apollonius","had","garrison"]},{"verseId":"brenton_1-maccabees_10_76","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":76,"text":"Then Jonathan laid siege unto it: whereupon they of the city let him in for fear: and so Jonathan won Joppe.","searchKeywords":["then","jonathan","laid","siege","unto","whereupon","they","the","city","let","him","for","fear","and","won","joppe"]},{"verseId":"brenton_1-maccabees_10_77","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":77,"text":"Whereof when Apollonius heard, he took three thousand horsemen, with a great host , and went to Azotus as one that journeyed, and therewithal drew him forth into the plain, because he had a great number of horsemen, in whom he put his trust.","searchKeywords":["whereof","when","apollonius","heard","took","three","thousand","horsemen","with","great","host","and","went","azotus","one","that","journeyed","therewithal","drew","him","forth","into","the","plain","because","had","number","whom","put","his","trust"]},{"verseId":"brenton_1-maccabees_10_78","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":78,"text":"Then Jonathan followed after him to Azotus, where the armies joined battle.","searchKeywords":["then","jonathan","followed","after","him","azotus","where","the","armies","joined","battle"]},{"verseId":"brenton_1-maccabees_10_79","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":79,"text":"Now Apollonius had left a thousand horsemen in ambush.","searchKeywords":["now","apollonius","had","left","thousand","horsemen","ambush"]},{"verseId":"brenton_1-maccabees_10_80","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":80,"text":"And Jonathan knew that there was an ambushment behind him; for they had compassed in his host, and cast darts at the people, from morning till evening.","searchKeywords":["and","jonathan","knew","that","there","was","ambushment","behind","him","for","they","had","compassed","his","host","cast","darts","the","people","from","morning","till","evening"]},{"verseId":"brenton_1-maccabees_10_81","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":81,"text":"But the people stood still, as Jonathan had commanded them: and so the enemies' horses were tired.","searchKeywords":["but","the","people","stood","still","jonathan","had","commanded","them","and","enemies","horses","were","tired"]},{"verseId":"brenton_1-maccabees_10_82","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":82,"text":"Then brought Simon forth his host, and set them against the footmen, (for the horsemen were spent,) who were discomfited by him, and fled.","searchKeywords":["then","brought","simon","forth","his","host","and","set","them","against","the","footmen","for","horsemen","were","spent","who","discomfited","him","fled"]},{"verseId":"brenton_1-maccabees_10_83","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":83,"text":"The horsemen also, being scattered in the field, fled to Azotus, and went into Beth-dagon, their idol's temple, for safety.","searchKeywords":["the","horsemen","also","being","scattered","field","fled","azotus","and","went","into","beth","dagon","their","idol","temple","for","safety"]},{"verseId":"brenton_1-maccabees_10_84","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":84,"text":"But Jonathan set fire on Azotus, and the cities round about it, and took their spoils; and the temple of Dagon, with them that were fled into it, he burned with fire.","searchKeywords":["but","jonathan","set","fire","azotus","and","the","cities","round","about","took","their","spoils","temple","dagon","with","them","that","were","fled","into","burned"]},{"verseId":"brenton_1-maccabees_10_85","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":85,"text":"Thus there were burned and slain with the sword well nigh eight thousand men.","searchKeywords":["thus","there","were","burned","and","slain","with","the","sword","well","nigh","eight","thousand","men"]},{"verseId":"brenton_1-maccabees_10_86","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":86,"text":"And from thence Jonathan removed his host, and camped against Ascalon, where the men of the city came forth, and met him with great pomp.","searchKeywords":["and","from","thence","jonathan","removed","his","host","camped","against","ascalon","where","the","men","city","came","forth","met","him","with","great","pomp"]},{"verseId":"brenton_1-maccabees_10_87","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":87,"text":"After this returned Jonathan and his host unto Jerusalem, having many spoils.","searchKeywords":["after","this","returned","jonathan","and","his","host","unto","jerusalem","having","many","spoils"]},{"verseId":"brenton_1-maccabees_10_88","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":88,"text":"Now when king Alexander heard these things, he honoured Jonathan yet more,","searchKeywords":["now","when","king","alexander","heard","these","things","honoured","jonathan","yet","more"]},{"verseId":"brenton_1-maccabees_10_89","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":10,"verse":89,"text":"and sent him a buckle of gold, as the use is to be given to such as are of the king's blood: he gave him also Accaron with the borders thereof in possession.","searchKeywords":["and","sent","him","buckle","gold","the","use","given","such","are","king","blood","gave","also","accaron","with","borders","thereof","possession"]}]