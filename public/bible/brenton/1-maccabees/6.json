[{"verseId":"brenton_1-maccabees_6_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":1,"text":"About that time king Antiochus travelling through the high countries heard say, that Elymais in the country of Persia was a city greatly renowned for riches, silver, and gold;","searchKeywords":["about","that","time","king","antiochus","travelling","through","the","high","countries","heard","say","elymais","country","persia","was","city","greatly","renowned","for","riches","silver","and","gold"]},{"verseId":"brenton_1-maccabees_6_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":2,"text":"and that there was in it a very rich temple, wherein were coverings of gold, and breastplates, and shields, which Alexander, of Philip, the Macedonian king, who reigned first among the Grecians, had left there:","searchKeywords":["and","that","there","was","very","rich","temple","wherein","were","coverings","gold","breastplates","shields","which","alexander","philip","the","macedonian","king","who","reigned","first","among","grecians","had","left"]},{"verseId":"brenton_1-maccabees_6_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":3,"text":"wherefore he came and sought to take the city, and to spoil it; but he was not able, because they of the city, having had warning thereof,","searchKeywords":["wherefore","came","and","sought","take","the","city","spoil","but","was","not","able","because","they","having","had","warning","thereof"]},{"verseId":"brenton_1-maccabees_6_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":4,"text":"rose up against him in battle: so he fled, and departed thence with great heaviness, and returned to Babylon.","searchKeywords":["rose","against","him","battle","fled","and","departed","thence","with","great","heaviness","returned","babylon"]},{"verseId":"brenton_1-maccabees_6_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":5,"text":"Moreover there came one who brought him tidings into Persia, that the armies, which went against the land of Judea, were put to flight:","searchKeywords":["moreover","there","came","one","who","brought","him","tidings","into","persia","that","the","armies","which","went","against","land","judea","were","put","flight"]},{"verseId":"brenton_1-maccabees_6_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":6,"text":"and that Lysias, who went forth first with a great power, was driven away of the Jews; and that they were made strong by the armour, and power, and store of spoils, which they had gotten of the armies, whom they had destroyed:","searchKeywords":["and","that","lysias","who","went","forth","first","with","great","power","was","driven","away","the","jews","they","were","made","strong","armour","store","spoils","which","had","gotten","armies","whom","destroyed"]},{"verseId":"brenton_1-maccabees_6_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":7,"text":"also that they had pulled down the abomination, which he had set up upon the altar in Jerusalem, and that they had compassed about the sanctuary with high walls, as before, and his city Bethsura.","searchKeywords":["also","that","they","had","pulled","down","the","abomination","which","set","upon","altar","jerusalem","and","compassed","about","sanctuary","with","high","walls","before","his","city","bethsura"]},{"verseId":"brenton_1-maccabees_6_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":8,"text":"Now when the king heard these words, he was astonished and sore moved: whereupon he laid him down upon his bed, and fell sick for grief, because it had not befallen him as he looked for.","searchKeywords":["now","when","the","king","heard","these","words","was","astonished","and","sore","moved","whereupon","laid","him","down","upon","his","bed","fell","sick","for","grief","because","had","not","befallen","looked"]},{"verseId":"brenton_1-maccabees_6_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":9,"text":"And there he continued many days: for his grief was ever more and more, and he made account that he should die.","searchKeywords":["and","there","continued","many","days","for","his","grief","was","ever","more","made","account","that","should","die"]},{"verseId":"brenton_1-maccabees_6_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":10,"text":"Wherefore he called for all his friends, and said unto them, The sleep is gone from mine eyes, and my heart faileth for very care.","searchKeywords":["wherefore","called","for","all","his","friends","and","said","unto","them","the","sleep","gone","from","mine","eyes","heart","faileth","very","care"]},{"verseId":"brenton_1-maccabees_6_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":11,"text":"And I thought with myself, Into what tribulation am I come, and how great a flood is it wherein now I am! for I was bountiful and beloved in my power.","searchKeywords":["and","thought","with","myself","into","what","tribulation","come","how","great","flood","wherein","now","for","was","bountiful","beloved","power"]},{"verseId":"brenton_1-maccabees_6_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":12,"text":"But now I remember the evils that I did at Jerusalem, and that I took all the vessels of gold and silver that were therein, and sent to destroy the inhabitants of Judea without a cause.","searchKeywords":["but","now","remember","the","evils","that","did","jerusalem","and","took","all","vessels","gold","silver","were","therein","sent","destroy","inhabitants","judea","without","cause"]},{"verseId":"brenton_1-maccabees_6_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":13,"text":"I perceive therefore that for this cause these troubles are come upon me, and, behold, I perish through great grief in a strange land.","searchKeywords":["perceive","therefore","that","for","this","cause","these","troubles","are","come","upon","and","behold","perish","through","great","grief","strange","land"]},{"verseId":"brenton_1-maccabees_6_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":14,"text":"Then called he for Philip, one of his friends, whom he made ruler over all his realm.","searchKeywords":["then","called","for","philip","one","his","friends","whom","made","ruler","over","all","realm"]},{"verseId":"brenton_1-maccabees_6_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":15,"text":"And gave him the crown, and his robe, and his signet, to the end he should bring up his son Antiochus, and nourish him up for the kingdom.","searchKeywords":["and","gave","him","the","crown","his","robe","signet","end","should","bring","son","antiochus","nourish","for","kingdom"]},{"verseId":"brenton_1-maccabees_6_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":16,"text":"So king Antiochus died there in the hundred forty and ninth year.","searchKeywords":["king","antiochus","died","there","the","hundred","forty","and","ninth","year"]},{"verseId":"brenton_1-maccabees_6_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":17,"text":"Now when Lysias knew that the king was dead, he set up Antiochus his son, whom he had brought up being young, to reign in his stead, and his name he called Eupator.","searchKeywords":["now","when","lysias","knew","that","the","king","was","dead","set","antiochus","his","son","whom","had","brought","being","young","reign","stead","and","name","called","eupator"]},{"verseId":"brenton_1-maccabees_6_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":18,"text":"About this time they that were in the tower shut up the Israelites round about the sanctuary, and sought always their hurt, and the strengthening of the heathen.","searchKeywords":["about","this","time","they","that","were","the","tower","shut","israelites","round","sanctuary","and","sought","always","their","hurt","strengthening","heathen"]},{"verseId":"brenton_1-maccabees_6_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":19,"text":"Wherefore Judas, purposing to destroy them, called all the people together to besiege them.","searchKeywords":["wherefore","judas","purposing","destroy","them","called","all","the","people","together","besiege"]},{"verseId":"brenton_1-maccabees_6_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":20,"text":"So they came together, and besieged them in the hundred and fiftieth year, and he made mounts for shot against them, and engines.","searchKeywords":["they","came","together","and","besieged","them","the","hundred","fiftieth","year","made","mounts","for","shot","against","engines"]},{"verseId":"brenton_1-maccabees_6_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":21,"text":"Howbeit certain of them that were besieged got forth, unto whom some ungodly men of Israel joined themselves:","searchKeywords":["howbeit","certain","them","that","were","besieged","got","forth","unto","whom","some","ungodly","men","israel","joined","themselves"]},{"verseId":"brenton_1-maccabees_6_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":22,"text":"and they went unto the king, and said, How long will it be ere thou execute judgment, and avenge our brethren?","searchKeywords":["and","they","went","unto","the","king","said","how","long","will","ere","thou","execute","judgment","avenge","our","brethren"]},{"verseId":"brenton_1-maccabees_6_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":23,"text":"We have been willing to serve thy father, and to do as he would have us, and to obey his commandments;","searchKeywords":["have","been","willing","serve","thy","father","and","would","obey","his","commandments"]},{"verseId":"brenton_1-maccabees_6_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":24,"text":"for which cause they of our nation besiege the tower, and are alienated from us: moreover as many of us as they could light on they slew, and spoiled our inheritance.","searchKeywords":["for","which","cause","they","our","nation","besiege","the","tower","and","are","alienated","from","moreover","many","could","light","slew","spoiled","inheritance"]},{"verseId":"brenton_1-maccabees_6_25","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":25,"text":"Neither have they stretched out their hand against us only, but also against all their borders.","searchKeywords":["neither","have","they","stretched","out","their","hand","against","only","but","also","all","borders"]},{"verseId":"brenton_1-maccabees_6_26","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":26,"text":"And, behold, this day are they besieging the tower at Jerusalem, to take it: the sanctuary also and Bethsura have they fortified.","searchKeywords":["and","behold","this","day","are","they","besieging","the","tower","jerusalem","take","sanctuary","also","bethsura","have","fortified"]},{"verseId":"brenton_1-maccabees_6_27","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":27,"text":"Wherefore if thou dost not prevent them quickly, they will do greater things than these, neither shalt thou be able to rule them.","searchKeywords":["wherefore","thou","dost","not","prevent","them","quickly","they","will","greater","things","than","these","neither","shalt","able","rule"]},{"verseId":"brenton_1-maccabees_6_28","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":28,"text":"Now when the king heard this, he was angry, and gathered together all his friends, and the captains of his army, and those that had charge of the horse.","searchKeywords":["now","when","the","king","heard","this","was","angry","and","gathered","together","all","his","friends","captains","army","those","that","had","charge","horse"]},{"verseId":"brenton_1-maccabees_6_29","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":29,"text":"There came also unto him from other kingdoms, and from isles of the sea, bands of hired soldiers.","searchKeywords":["there","came","also","unto","him","from","other","kingdoms","and","isles","the","sea","bands","hired","soldiers"]},{"verseId":"brenton_1-maccabees_6_30","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":30,"text":"So that the number of his army was an hundred thousand footmen, and twenty thousand horsemen, and two and thirty elephants exercised in battle.","searchKeywords":["that","the","number","his","army","was","hundred","thousand","footmen","and","twenty","horsemen","two","thirty","elephants","exercised","battle"]},{"verseId":"brenton_1-maccabees_6_31","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":31,"text":"These went through Idumea, and pitched against Bethsura, which they assaulted many days, making engines; but they came out, and burned them with fire, and fought valiantly.","searchKeywords":["these","went","through","idumea","and","pitched","against","bethsura","which","they","assaulted","many","days","making","engines","but","came","out","burned","them","with","fire","fought","valiantly"]},{"verseId":"brenton_1-maccabees_6_32","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":32,"text":"Upon this Judas removed from the tower, and pitched in Bethzacharias, over against the king's camp.","searchKeywords":["upon","this","judas","removed","from","the","tower","and","pitched","bethzacharias","over","against","king","camp"]},{"verseId":"brenton_1-maccabees_6_33","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":33,"text":"Then the king rising very early marched fiercely with his host toward Bethzacharias, where his armies made them ready to battle, and sounded the trumpets.","searchKeywords":["then","the","king","rising","very","early","marched","fiercely","with","his","host","toward","bethzacharias","where","armies","made","them","ready","battle","and","sounded","trumpets"]},{"verseId":"brenton_1-maccabees_6_34","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":34,"text":"And to the end they might provoke the elephants to fight, they shewed them the blood of grapes and mulberries.","searchKeywords":["and","the","end","they","might","provoke","elephants","fight","shewed","them","blood","grapes","mulberries"]},{"verseId":"brenton_1-maccabees_6_35","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":35,"text":"Moreover they divided the beasts among the armies, and for every elephant they appointed a thousand men, armed with coats of mail, and with helmets of brass on their heads; and beside this, for every beast were ordained five hundred horsemen of the best.","searchKeywords":["moreover","they","divided","the","beasts","among","armies","and","for","every","elephant","appointed","thousand","men","armed","with","coats","mail","helmets","brass","their","heads","beside","this","beast","were","ordained","five","hundred","horsemen","best"]},{"verseId":"brenton_1-maccabees_6_36","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":36,"text":"These were ready at every occasion: wheresoever the beast was, and whithersoever the beast went, they went also, neither departed they from him.","searchKeywords":["these","were","ready","every","occasion","wheresoever","the","beast","was","and","whithersoever","went","they","also","neither","departed","from","him"]},{"verseId":"brenton_1-maccabees_6_37","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":37,"text":"And upon the beasts were there strong towers of wood, which covered every one of them, and were girt fast unto them with devices: there were also upon every one two and thirty strong men, that fought upon them, beside the Indian that ruled him.","searchKeywords":["and","upon","the","beasts","were","there","strong","towers","wood","which","covered","every","one","them","girt","fast","unto","with","devices","also","two","thirty","men","that","fought","beside","indian","ruled","him"]},{"verseId":"brenton_1-maccabees_6_38","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":38,"text":"As for the remnant of the horsemen, they set them on this side and that side at the two parts of the host, giving them signs what to do, and being harnessed all over amidst the ranks.","searchKeywords":["for","the","remnant","horsemen","they","set","them","this","side","and","that","two","parts","host","giving","signs","what","being","harnessed","all","over","amidst","ranks"]},{"verseId":"brenton_1-maccabees_6_39","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":39,"text":"Now when the sun shone upon the shields of gold and brass, the mountains glistered therewith, and shined like lamps of fire.","searchKeywords":["now","when","the","sun","shone","upon","shields","gold","and","brass","mountains","glistered","therewith","shined","like","lamps","fire"]},{"verseId":"brenton_1-maccabees_6_40","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":40,"text":"So part of the king's army being spread upon the high mountains, and part on the valleys below, they marched on safely and in order.","searchKeywords":["part","the","king","army","being","spread","upon","high","mountains","and","valleys","below","they","marched","safely","order"]},{"verseId":"brenton_1-maccabees_6_41","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":41,"text":"Wherefore all that heard the noise of their multitude, and the marching of the company, and the rattling of the harness, were moved: for the army was very great and mighty.","searchKeywords":["wherefore","all","that","heard","the","noise","their","multitude","and","marching","company","rattling","harness","were","moved","for","army","was","very","great","mighty"]},{"verseId":"brenton_1-maccabees_6_42","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":42,"text":"Then Judas and his host drew near, and entered into battle, and there were slain of the king's army six hundred men.","searchKeywords":["then","judas","and","his","host","drew","near","entered","into","battle","there","were","slain","the","king","army","six","hundred","men"]},{"verseId":"brenton_1-maccabees_6_43","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":43,"text":"Eleazar also, Savaran, perceiving that one of the beasts, armed with royal harness, was higher than all the rest, and supposing that the king was upon him,","searchKeywords":["eleazar","also","savaran","perceiving","that","one","the","beasts","armed","with","royal","harness","was","higher","than","all","rest","and","supposing","king","upon","him"]},{"verseId":"brenton_1-maccabees_6_44","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":44,"text":"put himself in jeopardy, to the end he might deliver his people, and get him a perpetual name:","searchKeywords":["put","himself","jeopardy","the","end","might","deliver","his","people","and","get","him","perpetual","name"]},{"verseId":"brenton_1-maccabees_6_45","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":45,"text":"wherefore he ran upon him courageously through the midst of the battle, slaying on the right hand and on the left, so that they were divided from him on both sides.","searchKeywords":["wherefore","ran","upon","him","courageously","through","the","midst","battle","slaying","right","hand","and","left","that","they","were","divided","from","both","sides"]},{"verseId":"brenton_1-maccabees_6_46","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":46,"text":"Which done, he crept under the elephant, and thrust him under, and slew him: whereupon the elephant fell down upon him, and there he died.","searchKeywords":["which","done","crept","under","the","elephant","and","thrust","him","slew","whereupon","fell","down","upon","there","died"]},{"verseId":"brenton_1-maccabees_6_47","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":47,"text":"Howbeit seeing the strength of the king, and the violence of his forces, turned away from them.","searchKeywords":["howbeit","seeing","the","strength","king","and","violence","his","forces","turned","away","from","them"]},{"verseId":"brenton_1-maccabees_6_48","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":48,"text":"Then the king's army went up to Jerusalem to meet them, and the king pitched his tents against Judea, and against mount Sion.","searchKeywords":["then","the","king","army","went","jerusalem","meet","them","and","pitched","his","tents","against","judea","mount","sion"]},{"verseId":"brenton_1-maccabees_6_49","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":49,"text":"But with them that were in Bethsura he made peace: for they came out of the city, because they had no victuals there to endure the siege, it being a year of rest to the land.","searchKeywords":["but","with","them","that","were","bethsura","made","peace","for","they","came","out","the","city","because","had","victuals","there","endure","siege","being","year","rest","land"]},{"verseId":"brenton_1-maccabees_6_50","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":50,"text":"So the king took Bethsura, and set a garrison there to keep it.","searchKeywords":["the","king","took","bethsura","and","set","garrison","there","keep"]},{"verseId":"brenton_1-maccabees_6_51","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":51,"text":"As for the sanctuary, he besieged it many days: and set there artillery with engines and instruments to cast fire and stones, and pieces to cast darts and slings.","searchKeywords":["for","the","sanctuary","besieged","many","days","and","set","there","artillery","with","engines","instruments","cast","fire","stones","pieces","darts","slings"]},{"verseId":"brenton_1-maccabees_6_52","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":52,"text":"Whereupon they also made engines against their engines, and held them battle a long season.","searchKeywords":["whereupon","they","also","made","engines","against","their","and","held","them","battle","long","season"]},{"verseId":"brenton_1-maccabees_6_53","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":53,"text":"Yet at the last, their vessels being without victuals, (for that it was the seventh year, and they in Judea, that were delivered from the Gentiles, had eaten up the residue of the store;)","searchKeywords":["yet","the","last","their","vessels","being","without","victuals","for","that","was","seventh","year","and","they","judea","were","delivered","from","gentiles","had","eaten","residue","store"]},{"verseId":"brenton_1-maccabees_6_54","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":54,"text":"there were but a few left in the sanctuary, because the famine did so prevail against them, that they were fain to disperse themselves, every man to his own place.","searchKeywords":["there","were","but","few","left","the","sanctuary","because","famine","did","prevail","against","them","that","they","fain","disperse","themselves","every","man","his","own","place"]},{"verseId":"brenton_1-maccabees_6_55","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":55,"text":"At that time Lysias heard say, that Philip, whom Antiochus the king, whiles he lived, had appointed to bring up his son Antiochus, that he might be king,","searchKeywords":["that","time","lysias","heard","say","philip","whom","antiochus","the","king","whiles","lived","had","appointed","bring","his","son","might"]},{"verseId":"brenton_1-maccabees_6_56","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":56,"text":"was returned out of Persia and Media, and the king's host also that went with him, and that he sought to take unto him the ruling of affairs.","searchKeywords":["was","returned","out","persia","and","media","the","king","host","also","that","went","with","him","sought","take","unto","ruling","affairs"]},{"verseId":"brenton_1-maccabees_6_57","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":57,"text":"Wherefore he went in all haste, and said to the king and the captains of the host and the company, We decay daily, and our victuals are but small, and the place we lay siege unto is strong, and the affairs of the kingdom lie upon us:","searchKeywords":["wherefore","went","all","haste","and","said","the","king","captains","host","company","decay","daily","our","victuals","are","but","small","place","lay","siege","unto","strong","affairs","kingdom","lie","upon"]},{"verseId":"brenton_1-maccabees_6_58","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":58,"text":"now therefore let us be friends with these men, and make peace with them, and with all their nation;","searchKeywords":["now","therefore","let","friends","with","these","men","and","make","peace","them","all","their","nation"]},{"verseId":"brenton_1-maccabees_6_59","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":59,"text":"and covenant with them, that they shall live after their laws, as they did before: for they are therefore displeased, and have done all these things, because we abolished their laws.","searchKeywords":["and","covenant","with","them","that","they","shall","live","after","their","laws","did","before","for","are","therefore","displeased","have","done","all","these","things","because","abolished"]},{"verseId":"brenton_1-maccabees_6_60","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":60,"text":"So the king and the princes were content: wherefore he sent unto them to make peace; and they accepted thereof.","searchKeywords":["the","king","and","princes","were","content","wherefore","sent","unto","them","make","peace","they","accepted","thereof"]},{"verseId":"brenton_1-maccabees_6_61","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":61,"text":"Also the king and the princes made an oath unto them: whereupon they went out of the strong hold.","searchKeywords":["also","the","king","and","princes","made","oath","unto","them","whereupon","they","went","out","strong","hold"]},{"verseId":"brenton_1-maccabees_6_62","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":62,"text":"Then the king entered into mount Sion: but when he saw the strength of the place, he brake his oath that he had made, and gave commandment to pull down the wall round about.","searchKeywords":["then","the","king","entered","into","mount","sion","but","when","saw","strength","place","brake","his","oath","that","had","made","and","gave","commandment","pull","down","wall","round","about"]},{"verseId":"brenton_1-maccabees_6_63","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":6,"verse":63,"text":"Afterward departed he in all haste, and returned unto Antiochia, where he found Philip to be master of the city: so he fought against him, and took the city by force.","searchKeywords":["afterward","departed","all","haste","and","returned","unto","antiochia","where","found","philip","master","the","city","fought","against","him","took","force"]}]