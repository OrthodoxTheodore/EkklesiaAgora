[{"verseId":"brenton_1-maccabees_9_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":1,"text":"Furthermore when Demetrius heard that Nicanor and his host were slain in battle, he sent Bacchides and Alcimus into the land of Judea the second time, and with them the chief strength of his host:","searchKeywords":["furthermore","when","demetrius","heard","that","nicanor","and","his","host","were","slain","battle","sent","bacchides","alcimus","into","the","land","judea","second","time","with","them","chief","strength"]},{"verseId":"brenton_1-maccabees_9_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":2,"text":"who went forth by the way that leadeth to Galgala, and pitched their tents before Masaloth, which is in Arbela, and after they had won it, they slew much people.","searchKeywords":["who","went","forth","the","way","that","leadeth","galgala","and","pitched","their","tents","before","masaloth","which","arbela","after","they","had","won","slew","much","people"]},{"verseId":"brenton_1-maccabees_9_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":3,"text":"Also the first month of the hundred fifty and second year they encamped before Jerusalem:","searchKeywords":["also","the","first","month","hundred","fifty","and","second","year","they","encamped","before","jerusalem"]},{"verseId":"brenton_1-maccabees_9_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":4,"text":"from whence they removed, and went to Berea, with twenty thousand footmen and two thousand horsemen.","searchKeywords":["from","whence","they","removed","and","went","berea","with","twenty","thousand","footmen","two","horsemen"]},{"verseId":"brenton_1-maccabees_9_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":5,"text":"Now Judas had pitched his tents at Eleasa, and three thousand chosen men with him:","searchKeywords":["now","judas","had","pitched","his","tents","eleasa","and","three","thousand","chosen","men","with","him"]},{"verseId":"brenton_1-maccabees_9_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":6,"text":"who seeing the multitude of the other army to be so great, were sore afraid; whereupon many conveyed themselves out of the host, insomuch as there abode of them no more but eight hundred men.","searchKeywords":["who","seeing","the","multitude","other","army","great","were","sore","afraid","whereupon","many","conveyed","themselves","out","host","insomuch","there","abode","them","more","but","eight","hundred","men"]},{"verseId":"brenton_1-maccabees_9_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":7,"text":"When Judas therefore saw that his host slipt away, and that the battle pressed upon him, he was sore troubled in mind, and much distressed, for that he had no time to gather them together.","searchKeywords":["when","judas","therefore","saw","that","his","host","slipt","away","and","the","battle","pressed","upon","him","was","sore","troubled","mind","much","distressed","for","had","time","gather","them","together"]},{"verseId":"brenton_1-maccabees_9_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":8,"text":"Nevertheless unto them that remained he said, Let us arise and go up against our enemies, if peradventure we may be able to fight with them.","searchKeywords":["nevertheless","unto","them","that","remained","said","let","arise","and","against","our","enemies","peradventure","may","able","fight","with"]},{"verseId":"brenton_1-maccabees_9_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":9,"text":"But they dehorted him, saying, We shall never be able: let us now rather save our lives, and hereafter we will return with our brethren, and fight against them: for we are but few.","searchKeywords":["but","they","dehorted","him","saying","shall","never","able","let","now","rather","save","our","lives","and","hereafter","will","return","with","brethren","fight","against","them","for","are","few"]},{"verseId":"brenton_1-maccabees_9_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":10,"text":"Then Judas said, God forbid that I should do this thing, and flee away from them: if our time be come, let us die manfully for our brethren, and let us not stain our honour.","searchKeywords":["then","judas","said","god","forbid","that","should","this","thing","and","flee","away","from","them","our","time","come","let","die","manfully","for","brethren","not","stain","honour"]},{"verseId":"brenton_1-maccabees_9_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":11,"text":"With that the host removed out of their tents, and stood over against them, their horsemen being divided into two troops, and their slingers and archers going before the host, and they that marched in the foreward were all mighty men.","searchKeywords":["with","that","the","host","removed","out","their","tents","and","stood","over","against","them","horsemen","being","divided","into","two","troops","slingers","archers","going","before","they","marched","foreward","were","all","mighty","men"]},{"verseId":"brenton_1-maccabees_9_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":12,"text":"As for Bacchides, he was in the right wing: so the host drew near on the two parts, and sounded their trumpets.","searchKeywords":["for","bacchides","was","the","right","wing","host","drew","near","two","parts","and","sounded","their","trumpets"]},{"verseId":"brenton_1-maccabees_9_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":13,"text":"They also of Judas' side, even they sounded their trumpets also, so that the earth shook at the noise of the armies, and the battle continued from morning till night.","searchKeywords":["they","also","judas","side","even","sounded","their","trumpets","that","the","earth","shook","noise","armies","and","battle","continued","from","morning","till","night"]},{"verseId":"brenton_1-maccabees_9_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":14,"text":"Now when Judas perceived that Bacchides and the strength of his army were on the right side, he took with him all the hardy men,","searchKeywords":["now","when","judas","perceived","that","bacchides","and","the","strength","his","army","were","right","side","took","with","him","all","hardy","men"]},{"verseId":"brenton_1-maccabees_9_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":15,"text":"who discomfited the right wing, and pursued them unto the mount Azotus.","searchKeywords":["who","discomfited","the","right","wing","and","pursued","them","unto","mount","azotus"]},{"verseId":"brenton_1-maccabees_9_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":16,"text":"But when they of the left wing saw that they of the right wing were discomfited, they followed upon Judas and those that were with him hard at the heels from behind:","searchKeywords":["but","when","they","the","left","wing","saw","that","right","were","discomfited","followed","upon","judas","and","those","with","him","hard","heels","from","behind"]},{"verseId":"brenton_1-maccabees_9_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":17,"text":"whereupon there was a sore battle, insomuch as many were slain on both parts.","searchKeywords":["whereupon","there","was","sore","battle","insomuch","many","were","slain","both","parts"]},{"verseId":"brenton_1-maccabees_9_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":18,"text":"Judas also was killed, and the remnant fled.","searchKeywords":["judas","also","was","killed","and","the","remnant","fled"]},{"verseId":"brenton_1-maccabees_9_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":19,"text":"Then Jonathan and Simon took Judas their brother, and buried him in the sepulchre of his fathers in Modin.","searchKeywords":["then","jonathan","and","simon","took","judas","their","brother","buried","him","the","sepulchre","his","fathers","modin"]},{"verseId":"brenton_1-maccabees_9_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":20,"text":"Moreover they bewailed him, and all Israel made great lamentation for him, and mourned many days, saying,","searchKeywords":["moreover","they","bewailed","him","and","all","israel","made","great","lamentation","for","mourned","many","days","saying"]},{"verseId":"brenton_1-maccabees_9_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":21,"text":"How is the valiant man fallen, that delivered Israel!","searchKeywords":["how","the","valiant","man","fallen","that","delivered","israel"]},{"verseId":"brenton_1-maccabees_9_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":22,"text":"As for the other things concerning Judas and his wars, and the noble acts which he did, and his greatness, they are not written, for they were very many.","searchKeywords":["for","the","other","things","concerning","judas","and","his","wars","noble","acts","which","did","greatness","they","are","not","written","were","very","many"]},{"verseId":"brenton_1-maccabees_9_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":23,"text":"Now after the death of Judas the wicked began to put forth their heads in all the coasts of Israel, and there arose up all such as wrought iniquity.","searchKeywords":["now","after","the","death","judas","wicked","began","put","forth","their","heads","all","coasts","israel","and","there","arose","such","wrought","iniquity"]},{"verseId":"brenton_1-maccabees_9_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":24,"text":"In those days also was there a very great famine, by reason whereof the country revolted, and went with them.","searchKeywords":["those","days","also","was","there","very","great","famine","reason","whereof","the","country","revolted","and","went","with","them"]},{"verseId":"brenton_1-maccabees_9_25","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":25,"text":"Then Bacchides chose the wicked men, and made them lords of the country.","searchKeywords":["then","bacchides","chose","the","wicked","men","and","made","them","lords","country"]},{"verseId":"brenton_1-maccabees_9_26","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":26,"text":"And they made enquiry and search for Judas' friends, and brought them unto Bacchides, who took vengeance of them, and used them despitefully.","searchKeywords":["and","they","made","enquiry","search","for","judas","friends","brought","them","unto","bacchides","who","took","vengeance","used","despitefully"]},{"verseId":"brenton_1-maccabees_9_27","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":27,"text":"So was there a great affliction in Israel, the like whereof was not since the time that a prophet was not seen among them.","searchKeywords":["was","there","great","affliction","israel","the","like","whereof","not","since","time","that","prophet","seen","among","them"]},{"verseId":"brenton_1-maccabees_9_28","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":28,"text":"For this cause all Judas' friends came together, and said unto Jonathan,","searchKeywords":["for","this","cause","all","judas","friends","came","together","and","said","unto","jonathan"]},{"verseId":"brenton_1-maccabees_9_29","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":29,"text":"Since thy brother Judas died, we have no man like him to go forth against our enemies, and Bacchides, and against them of our nation that are adversaries to us.","searchKeywords":["since","thy","brother","judas","died","have","man","like","him","forth","against","our","enemies","and","bacchides","them","nation","that","are","adversaries"]},{"verseId":"brenton_1-maccabees_9_30","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":30,"text":"Now therefore we have chosen thee this day to be our prince and captain in his stead, that thou mayest fight our battles.","searchKeywords":["now","therefore","have","chosen","thee","this","day","our","prince","and","captain","his","stead","that","thou","mayest","fight","battles"]},{"verseId":"brenton_1-maccabees_9_31","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":31,"text":"Upon this Jonathan took the governance upon him at that time, and rose up instead of his brother Judas.","searchKeywords":["upon","this","jonathan","took","the","governance","him","that","time","and","rose","instead","his","brother","judas"]},{"verseId":"brenton_1-maccabees_9_32","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":32,"text":"But when Bacchides gat knowledge thereof, he sought for to slay him.","searchKeywords":["but","when","bacchides","gat","knowledge","thereof","sought","for","slay","him"]},{"verseId":"brenton_1-maccabees_9_33","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":33,"text":"Then Jonathan, and Simon his brother, and all that were with him, perceiving that, fled into the wilderness of Thecoe, and pitched their tents by the water of the pool Asphar.","searchKeywords":["then","jonathan","and","simon","his","brother","all","that","were","with","him","perceiving","fled","into","the","wilderness","thecoe","pitched","their","tents","water","pool","asphar"]},{"verseId":"brenton_1-maccabees_9_34","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":34,"text":"Which when Bacchides understood, he came near to Jordan with all his host upon the sabbath day.","searchKeywords":["which","when","bacchides","understood","came","near","jordan","with","all","his","host","upon","the","sabbath","day"]},{"verseId":"brenton_1-maccabees_9_35","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":35,"text":"Now Jonathan had sent his brother , a captain of the people, to pray his friends the Nabathites, that they might leave with them their carriage, which was much.","searchKeywords":["now","jonathan","had","sent","his","brother","captain","the","people","pray","friends","nabathites","that","they","might","leave","with","them","their","carriage","which","was","much"]},{"verseId":"brenton_1-maccabees_9_36","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":36,"text":"But the children of Jambri came out of Medaba, and took John, and all that he had, and went their way with it.","searchKeywords":["but","the","children","jambri","came","out","medaba","and","took","john","all","that","had","went","their","way","with"]},{"verseId":"brenton_1-maccabees_9_37","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":37,"text":"After this came word to Jonathan and Simon his brother, that the children of Jambri made a great marriage, and were bringing the bride from Nadabatha with a great train, as being the daughter of one of the great princes of Chanaan.","searchKeywords":["after","this","came","word","jonathan","and","simon","his","brother","that","the","children","jambri","made","great","marriage","were","bringing","bride","from","nadabatha","with","train","being","daughter","one","princes","chanaan"]},{"verseId":"brenton_1-maccabees_9_38","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":38,"text":"Therefore they remembered John their brother, and went up, and hid themselves under the covert of the mountain:","searchKeywords":["therefore","they","remembered","john","their","brother","and","went","hid","themselves","under","the","covert","mountain"]},{"verseId":"brenton_1-maccabees_9_39","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":39,"text":"where they lifted up their eyes, and looked, and, behold, there was much ado and great carriage: and the bridegroom came forth, and his friends and brethren, to meet them with drums, and instruments of music, and many weapons.","searchKeywords":["where","they","lifted","their","eyes","and","looked","behold","there","was","much","ado","great","carriage","the","bridegroom","came","forth","his","friends","brethren","meet","them","with","drums","instruments","music","many","weapons"]},{"verseId":"brenton_1-maccabees_9_40","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":40,"text":"Then Jonathan and they that were with him rose up against them from the place where they lay in ambush, and made a slaughter of them in such sort, as many fell down dead, and the remnant fled into the mountain, and they took all their spoils.","searchKeywords":["then","jonathan","and","they","that","were","with","him","rose","against","them","from","the","place","where","lay","ambush","made","slaughter","such","sort","many","fell","down","dead","remnant","fled","into","mountain","took","all","their","spoils"]},{"verseId":"brenton_1-maccabees_9_41","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":41,"text":"Thus was the marriage turned into mourning, and the noise of their melody into lamentation.","searchKeywords":["thus","was","the","marriage","turned","into","mourning","and","noise","their","melody","lamentation"]},{"verseId":"brenton_1-maccabees_9_42","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":42,"text":"So when they had avenged fully the blood of their brother, they turned again to the marsh of Jordan.","searchKeywords":["when","they","had","avenged","fully","the","blood","their","brother","turned","again","marsh","jordan"]},{"verseId":"brenton_1-maccabees_9_43","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":43,"text":"Now when Bacchides heard hereof, he came on the sabbath day unto the banks of Jordan with a great power.","searchKeywords":["now","when","bacchides","heard","hereof","came","the","sabbath","day","unto","banks","jordan","with","great","power"]},{"verseId":"brenton_1-maccabees_9_44","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":44,"text":"Then Jonathan said to his company, Let us go up now and fight for our lives, for it standeth not with us to day, as in time past:","searchKeywords":["then","jonathan","said","his","company","let","now","and","fight","for","our","lives","standeth","not","with","day","time","past"]},{"verseId":"brenton_1-maccabees_9_45","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":45,"text":"for, behold, the battle is before us and behind us, and the water of Jordan on this side and that side, the marsh likewise and wood, neither is there place for us to turn aside.","searchKeywords":["for","behold","the","battle","before","and","behind","water","jordan","this","side","that","marsh","likewise","wood","neither","there","place","turn","aside"]},{"verseId":"brenton_1-maccabees_9_46","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":46,"text":"Wherefore cry ye now unto heaven, that ye may be delivered from the hand of your enemies.","searchKeywords":["wherefore","cry","now","unto","heaven","that","may","delivered","from","the","hand","your","enemies"]},{"verseId":"brenton_1-maccabees_9_47","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":47,"text":"With that they joined battle, and Jonathan stretched forth his hand to smite Bacchides, but he turned back from him.","searchKeywords":["with","that","they","joined","battle","and","jonathan","stretched","forth","his","hand","smite","bacchides","but","turned","back","from","him"]},{"verseId":"brenton_1-maccabees_9_48","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":48,"text":"Then Jonathan and they that were with him leapt into Jordan, and swam over unto the farther bank: howbeit the other passed not over Jordan unto them.","searchKeywords":["then","jonathan","and","they","that","were","with","him","leapt","into","jordan","swam","over","unto","the","farther","bank","howbeit","other","passed","not","them"]},{"verseId":"brenton_1-maccabees_9_49","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":49,"text":"So there were slain of Bacchides' side that day about a thousand men.","searchKeywords":["there","were","slain","bacchides","side","that","day","about","thousand","men"]},{"verseId":"brenton_1-maccabees_9_50","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":50,"text":"Afterward returned to Jerusalem, and repaired the strong cities in Judea; the fort in Jericho, and Emmaus, and Bethhoron, and Bethel, and Thamnatha, Pharathoni, and Taphon, with high walls, with gates, and with bars.","searchKeywords":["afterward","returned","jerusalem","and","repaired","the","strong","cities","judea","fort","jericho","emmaus","bethhoron","bethel","thamnatha","pharathoni","taphon","with","high","walls","gates","bars"]},{"verseId":"brenton_1-maccabees_9_51","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":51,"text":"And in them he set a garrison, that they might work malice upon Israel.","searchKeywords":["and","them","set","garrison","that","they","might","work","malice","upon","israel"]},{"verseId":"brenton_1-maccabees_9_52","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":52,"text":"He fortified also the city Bethsura, and Gazara, and the tower, and put forces in them, and provision of victuals.","searchKeywords":["fortified","also","the","city","bethsura","and","gazara","tower","put","forces","them","provision","victuals"]},{"verseId":"brenton_1-maccabees_9_53","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":53,"text":"Besides, he took the chief men's sons in the country for hostages, and put them into the tower at Jerusalem to be kept.","searchKeywords":["besides","took","the","chief","men","sons","country","for","hostages","and","put","them","into","tower","jerusalem","kept"]},{"verseId":"brenton_1-maccabees_9_54","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":54,"text":"Moreover in the hundred fifty and third year, in the second month, Alcimus commanded that the wall of the inner court of the sanctuary should be pulled down; he pulled down also the works of the prophets.","searchKeywords":["moreover","the","hundred","fifty","and","third","year","second","month","alcimus","commanded","that","wall","inner","court","sanctuary","should","pulled","down","also","works","prophets"]},{"verseId":"brenton_1-maccabees_9_55","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":55,"text":"And as he began to pull down, even at that time was Alcimus plagued, and his enterprizes hindered: for his mouth was stopped, and he was taken with a palsy, so that he could no more speak any thing, nor give order concerning his house.","searchKeywords":["and","began","pull","down","even","that","time","was","alcimus","plagued","his","enterprizes","hindered","for","mouth","stopped","taken","with","palsy","could","more","speak","any","thing","nor","give","order","concerning","house"]},{"verseId":"brenton_1-maccabees_9_56","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":56,"text":"So Alcimus died at that time with great torment.","searchKeywords":["alcimus","died","that","time","with","great","torment"]},{"verseId":"brenton_1-maccabees_9_57","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":57,"text":"Now when Bacchides saw that Alcimus was dead, he returned to the king: whereupon the land of Juda was in rest two years.","searchKeywords":["now","when","bacchides","saw","that","alcimus","was","dead","returned","the","king","whereupon","land","juda","rest","two","years"]},{"verseId":"brenton_1-maccabees_9_58","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":58,"text":"Then all the ungodly men held a council, saying, Behold, Jonathan and his company are at ease, and dwell without care: now therefore we will bring Bacchides hither, who shall take them all in one night.","searchKeywords":["then","all","the","ungodly","men","held","council","saying","behold","jonathan","and","his","company","are","ease","dwell","without","care","now","therefore","will","bring","bacchides","hither","who","shall","take","them","one","night"]},{"verseId":"brenton_1-maccabees_9_59","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":59,"text":"So they went and consulted with him.","searchKeywords":["they","went","and","consulted","with","him"]},{"verseId":"brenton_1-maccabees_9_60","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":60,"text":"Then removed he, and came with a great host, and sent letters privily to his adherents in Judea, that they should take Jonathan and those that were with him: howbeit they could not, because their counsel was known unto them.","searchKeywords":["then","removed","and","came","with","great","host","sent","letters","privily","his","adherents","judea","that","they","should","take","jonathan","those","were","him","howbeit","could","not","because","their","counsel","was","known","unto","them"]},{"verseId":"brenton_1-maccabees_9_61","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":61,"text":"Wherefore they took of the men of the country, that were authors of that mischief, about fifty persons, and slew them.","searchKeywords":["wherefore","they","took","the","men","country","that","were","authors","mischief","about","fifty","persons","and","slew","them"]},{"verseId":"brenton_1-maccabees_9_62","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":62,"text":"Afterward Jonathan, and Simon, and they that were with him, got them away to Bethbasi, which is in the wilderness, and they repaired the decays thereof, and made it strong.","searchKeywords":["afterward","jonathan","and","simon","they","that","were","with","him","got","them","away","bethbasi","which","the","wilderness","repaired","decays","thereof","made","strong"]},{"verseId":"brenton_1-maccabees_9_63","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":63,"text":"Which thing when Bacchides knew, he gathered together all his host, and sent word to them that were of Judea.","searchKeywords":["which","thing","when","bacchides","knew","gathered","together","all","his","host","and","sent","word","them","that","were","judea"]},{"verseId":"brenton_1-maccabees_9_64","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":64,"text":"Then went he and laid siege against Bethbasi; and they fought against it a long season, and made engines of war.","searchKeywords":["then","went","and","laid","siege","against","bethbasi","they","fought","long","season","made","engines","war"]},{"verseId":"brenton_1-maccabees_9_65","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":65,"text":"But Jonathan left his brother Simon in the city, and went forth himself into the country, and with a certain number went he forth.","searchKeywords":["but","jonathan","left","his","brother","simon","the","city","and","went","forth","himself","into","country","with","certain","number"]},{"verseId":"brenton_1-maccabees_9_66","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":66,"text":"And he smote Odonarres and his brethren, and the children of Phasiron in their tent.","searchKeywords":["and","smote","odonarres","his","brethren","the","children","phasiron","their","tent"]},{"verseId":"brenton_1-maccabees_9_67","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":67,"text":"And when he began to smite them, and came up with his forces, Simon and his company went out of the city, and burned up the engines of war,","searchKeywords":["and","when","began","smite","them","came","with","his","forces","simon","company","went","out","the","city","burned","engines","war"]},{"verseId":"brenton_1-maccabees_9_68","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":68,"text":"and fought against Bacchides, who was discomfited by them, and they afflicted him sore: for his counsel and travail was in vain.","searchKeywords":["and","fought","against","bacchides","who","was","discomfited","them","they","afflicted","him","sore","for","his","counsel","travail","vain"]},{"verseId":"brenton_1-maccabees_9_69","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":69,"text":"Wherefore he was very wroth at the wicked men that gave him counsel to come into the country, insomuch as he slew many of them, and purposed to return into his own country.","searchKeywords":["wherefore","was","very","wroth","the","wicked","men","that","gave","him","counsel","come","into","country","insomuch","slew","many","them","and","purposed","return","his","own"]},{"verseId":"brenton_1-maccabees_9_70","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":70,"text":"Whereof when Jonathan had knowledge, he sent ambassadors unto him, to the end he should make peace with him, and deliver them the prisoners.","searchKeywords":["whereof","when","jonathan","had","knowledge","sent","ambassadors","unto","him","the","end","should","make","peace","with","and","deliver","them","prisoners"]},{"verseId":"brenton_1-maccabees_9_71","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":71,"text":"Which thing he accepted, and did according to his demands, and sware unto him that he would never do him harm all the days of his life.","searchKeywords":["which","thing","accepted","and","did","according","his","demands","sware","unto","him","that","would","never","harm","all","the","days","life"]},{"verseId":"brenton_1-maccabees_9_72","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":72,"text":"When therefore he had restored unto him the prisoners that he had taken aforetime out of the land of Judea, he returned and went his way into his own land, neither came he any more into their borders.","searchKeywords":["when","therefore","had","restored","unto","him","the","prisoners","that","taken","aforetime","out","land","judea","returned","and","went","his","way","into","own","neither","came","any","more","their","borders"]},{"verseId":"brenton_1-maccabees_9_73","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":9,"verse":73,"text":"Thus the sword ceased from Israel: but Jonathan dwelt at Machmas, and began to govern the people; and he destroyed the ungodly men out of Israel.","searchKeywords":["thus","the","sword","ceased","from","israel","but","jonathan","dwelt","machmas","and","began","govern","people","destroyed","ungodly","men","out"]}]