[{"verseId":"brenton_1-maccabees_13_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":1,"text":"Now when Simon heard that Tryphon had gathered together a great host to invade the land of Judea, and destroy it,","searchKeywords":["now","when","simon","heard","that","tryphon","had","gathered","together","great","host","invade","the","land","judea","and","destroy"]},{"verseId":"brenton_1-maccabees_13_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":2,"text":"and saw that the people was in great trembling and fear, he went up to Jerusalem, and gathered the people together,","searchKeywords":["and","saw","that","the","people","was","great","trembling","fear","went","jerusalem","gathered","together"]},{"verseId":"brenton_1-maccabees_13_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":3,"text":"and gave them exhortation, saying, Ye yourselves know what great things I, and my brethren, and my father's house, have done for the laws and the sanctuary, the battles also and troubles which we have seen,","searchKeywords":["and","gave","them","exhortation","saying","yourselves","know","what","great","things","brethren","father","house","have","done","for","the","laws","sanctuary","battles","also","troubles","which","seen"]},{"verseId":"brenton_1-maccabees_13_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":4,"text":"by reason whereof all my brethren are slain for Israel's sake, and I am left alone.","searchKeywords":["reason","whereof","all","brethren","are","slain","for","israel","sake","and","left","alone"]},{"verseId":"brenton_1-maccabees_13_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":5,"text":"Now therefore be it far from me, that I should spare mine own life in any time of trouble: for I am no better than my brethren.","searchKeywords":["now","therefore","far","from","that","should","spare","mine","own","life","any","time","trouble","for","better","than","brethren"]},{"verseId":"brenton_1-maccabees_13_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":6,"text":"Doubtless I will avenge my nation, and the sanctuary, and our wives, and our children: for all the heathen are gathered to destroy us of very malice.","searchKeywords":["doubtless","will","avenge","nation","and","the","sanctuary","our","wives","children","for","all","heathen","are","gathered","destroy","very","malice"]},{"verseId":"brenton_1-maccabees_13_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":7,"text":"Now as soon as the people heard these words, their spirit revived.","searchKeywords":["now","soon","the","people","heard","these","words","their","spirit","revived"]},{"verseId":"brenton_1-maccabees_13_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":8,"text":"And they answered with a loud voice, saying, Thou shalt be our leader instead of Judas and Jonathan thy brother.","searchKeywords":["and","they","answered","with","loud","voice","saying","thou","shalt","our","leader","instead","judas","jonathan","thy","brother"]},{"verseId":"brenton_1-maccabees_13_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":9,"text":"Fight thou our battles, and whatsoever thou commandest us, that will we do.","searchKeywords":["fight","thou","our","battles","and","whatsoever","commandest","that","will"]},{"verseId":"brenton_1-maccabees_13_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":10,"text":"So then he gathered together all the men of war, and made haste to finish the walls of Jerusalem, and he fortified it round about.","searchKeywords":["then","gathered","together","all","the","men","war","and","made","haste","finish","walls","jerusalem","fortified","round","about"]},{"verseId":"brenton_1-maccabees_13_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":11,"text":"Also he sent Jonathan the of Absalom, and with him a great power, to Joppe: who casting out them that were therein remained there in it.","searchKeywords":["also","sent","jonathan","the","absalom","and","with","him","great","power","joppe","who","casting","out","them","that","were","therein","remained","there"]},{"verseId":"brenton_1-maccabees_13_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":12,"text":"So Tryphon removed from Ptolemais with a great power to invade the land of Judea, and Jonathan was with him in ward.","searchKeywords":["tryphon","removed","from","ptolemais","with","great","power","invade","the","land","judea","and","jonathan","was","him","ward"]},{"verseId":"brenton_1-maccabees_13_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":13,"text":"But Simon pitched his tents at Adida, over against the plain.","searchKeywords":["but","simon","pitched","his","tents","adida","over","against","the","plain"]},{"verseId":"brenton_1-maccabees_13_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":14,"text":"Now when Tryphon knew that Simon was risen up instead of his brother Jonathan, and meant to join battle with him, he sent messengers unto him, saying,","searchKeywords":["now","when","tryphon","knew","that","simon","was","risen","instead","his","brother","jonathan","and","meant","join","battle","with","him","sent","messengers","unto","saying"]},{"verseId":"brenton_1-maccabees_13_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":15,"text":"Whereas we have Jonathan thy brother in hold, it is for money that he is owing unto the king's treasure, concerning the business that was committed unto him.","searchKeywords":["whereas","have","jonathan","thy","brother","hold","for","money","that","owing","unto","the","king","treasure","concerning","business","was","committed","him"]},{"verseId":"brenton_1-maccabees_13_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":16,"text":"Wherefore now send an hundred talents of silver, and two of his sons for hostages, that when he is at liberty he may not revolt from us, and we will let him go.","searchKeywords":["wherefore","now","send","hundred","talents","silver","and","two","his","sons","for","hostages","that","when","liberty","may","not","revolt","from","will","let","him"]},{"verseId":"brenton_1-maccabees_13_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":17,"text":"Hereupon Simon, albeit he perceived that they spake deceitfully unto him, yet sent he the money and the children, lest peradventure he should procure to himself great hatred of the people:","searchKeywords":["hereupon","simon","albeit","perceived","that","they","spake","deceitfully","unto","him","yet","sent","the","money","and","children","lest","peradventure","should","procure","himself","great","hatred","people"]},{"verseId":"brenton_1-maccabees_13_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":18,"text":"who might have said, Because I sent him not the money and the children, therefore is dead.","searchKeywords":["who","might","have","said","because","sent","him","not","the","money","and","children","therefore","dead"]},{"verseId":"brenton_1-maccabees_13_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":19,"text":"So he sent them the children and the hundred talents: howbeit dissembled, neither would he let Jonathan go.","searchKeywords":["sent","them","the","children","and","hundred","talents","howbeit","dissembled","neither","would","let","jonathan"]},{"verseId":"brenton_1-maccabees_13_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":20,"text":"And after this came Tryphon to invade the land, and destroy it, going round about by the way that leadeth unto Adora: but Simon and his host marched against him in every place, wheresoever he went.","searchKeywords":["and","after","this","came","tryphon","invade","the","land","destroy","going","round","about","way","that","leadeth","unto","adora","but","simon","his","host","marched","against","him","every","place","wheresoever","went"]},{"verseId":"brenton_1-maccabees_13_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":21,"text":"Now they that were in the tower sent messengers unto Tryphon, to the end that he should hasten his coming unto them by the wilderness, and send them victuals.","searchKeywords":["now","they","that","were","the","tower","sent","messengers","unto","tryphon","end","should","hasten","his","coming","them","wilderness","and","send","victuals"]},{"verseId":"brenton_1-maccabees_13_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":22,"text":"Wherefore Tryphon made ready all his horsemen to come that night: but there fell a very great snow, by reason whereof he came not. So he departed, and came into the country of Galaad.","searchKeywords":["wherefore","tryphon","made","ready","all","his","horsemen","come","that","night","but","there","fell","very","great","snow","reason","whereof","came","not","departed","and","into","the","country","galaad"]},{"verseId":"brenton_1-maccabees_13_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":23,"text":"And when he came near to Bascama, he slew Jonathan, who was buried there.","searchKeywords":["and","when","came","near","bascama","slew","jonathan","who","was","buried","there"]},{"verseId":"brenton_1-maccabees_13_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":24,"text":"Afterward Tryphon returned and went into his own land.","searchKeywords":["afterward","tryphon","returned","and","went","into","his","own","land"]},{"verseId":"brenton_1-maccabees_13_25","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":25,"text":"Then sent Simon, and took the bones of Jonathan his brother, and buried them in Modin, the city of his fathers.","searchKeywords":["then","sent","simon","and","took","the","bones","jonathan","his","brother","buried","them","modin","city","fathers"]},{"verseId":"brenton_1-maccabees_13_26","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":26,"text":"And all Israel made great lamentation for him, and bewailed him many days.","searchKeywords":["and","all","israel","made","great","lamentation","for","him","bewailed","many","days"]},{"verseId":"brenton_1-maccabees_13_27","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":27,"text":"Simon also built a monument upon the sepulchre of his father and his brethren, and raised it aloft to the sight, with hewn stone behind and before.","searchKeywords":["simon","also","built","monument","upon","the","sepulchre","his","father","and","brethren","raised","aloft","sight","with","hewn","stone","behind","before"]},{"verseId":"brenton_1-maccabees_13_28","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":28,"text":"Moreover he set up seven pyramids, one against another, for his father, and his mother, and his four brethren.","searchKeywords":["moreover","set","seven","pyramids","one","against","another","for","his","father","and","mother","four","brethren"]},{"verseId":"brenton_1-maccabees_13_29","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":29,"text":"And in these he made cunning devices, about the which he set great pillars, and upon the pillars he made all their armour for a perpetual memory, and by the armour ships carved, that they might be seen of all that sail on the sea.","searchKeywords":["and","these","made","cunning","devices","about","the","which","set","great","pillars","upon","all","their","armour","for","perpetual","memory","ships","carved","that","they","might","seen","sail","sea"]},{"verseId":"brenton_1-maccabees_13_30","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":30,"text":"This is the sepulchre which he made at Modin, and it standeth yet unto this day.","searchKeywords":["this","the","sepulchre","which","made","modin","and","standeth","yet","unto","day"]},{"verseId":"brenton_1-maccabees_13_31","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":31,"text":"Now Tryphon dealt deceitfully with the young king Antiochus, and slew him.","searchKeywords":["now","tryphon","dealt","deceitfully","with","the","young","king","antiochus","and","slew","him"]},{"verseId":"brenton_1-maccabees_13_32","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":32,"text":"And he reigned in his stead, and crowned himself king of Asia, and brought a great calamity upon the land.","searchKeywords":["and","reigned","his","stead","crowned","himself","king","asia","brought","great","calamity","upon","the","land"]},{"verseId":"brenton_1-maccabees_13_33","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":33,"text":"Then Simon built up the strong holds in Judea, and fenced them about with high towers, and great walls, and gates, and bars, and laid up victuals therein.","searchKeywords":["then","simon","built","the","strong","holds","judea","and","fenced","them","about","with","high","towers","great","walls","gates","bars","laid","victuals","therein"]},{"verseId":"brenton_1-maccabees_13_34","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":34,"text":"Moreover Simon chose men, and sent to king Demetrius, to the end he should give the land an immunity, because all that Tryphon did was to spoil.","searchKeywords":["moreover","simon","chose","men","and","sent","king","demetrius","the","end","should","give","land","immunity","because","all","that","tryphon","did","was","spoil"]},{"verseId":"brenton_1-maccabees_13_35","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":35,"text":"Unto whom king Demetrius answered and wrote after this manner:","searchKeywords":["unto","whom","king","demetrius","answered","and","wrote","after","this","manner"]},{"verseId":"brenton_1-maccabees_13_36","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":36,"text":"King Demetrius unto Simon the high priest, and friend of kings, as also unto the elders and nation of the Jews, sendeth greeting:","searchKeywords":["king","demetrius","unto","simon","the","high","priest","and","friend","kings","also","elders","nation","jews","sendeth","greeting"]},{"verseId":"brenton_1-maccabees_13_37","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":37,"text":"The golden crown, and the scarlet robe, which ye sent unto us, we have received: and we are ready to make a stedfast peace with you, yea, and to write unto our officers, to confirm the immunities which we have granted.","searchKeywords":["the","golden","crown","and","scarlet","robe","which","sent","unto","have","received","are","ready","make","stedfast","peace","with","you","yea","write","our","officers","confirm","immunities","granted"]},{"verseId":"brenton_1-maccabees_13_38","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":38,"text":"And whatsoever covenants we have made with you shall stand; and the strong holds, which ye have builded, shall be your own.","searchKeywords":["and","whatsoever","covenants","have","made","with","you","shall","stand","the","strong","holds","which","builded","your","own"]},{"verseId":"brenton_1-maccabees_13_39","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":39,"text":"As for any oversight or fault committed unto this day, we forgive it, and the crown tax also, which ye owe us: and if there were any other tribute paid in Jerusalem, it shall no more be paid.","searchKeywords":["for","any","oversight","fault","committed","unto","this","day","forgive","and","the","crown","tax","also","which","owe","there","were","other","tribute","paid","jerusalem","shall","more"]},{"verseId":"brenton_1-maccabees_13_40","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":40,"text":"And look who are meet among you to be in our court, let them be enrolled, and let there be peace betwixt us.","searchKeywords":["and","look","who","are","meet","among","you","our","court","let","them","enrolled","there","peace","betwixt"]},{"verseId":"brenton_1-maccabees_13_41","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":41,"text":"Thus the yoke of the heathen was taken away from Israel in the hundred and seventieth year.","searchKeywords":["thus","the","yoke","heathen","was","taken","away","from","israel","hundred","and","seventieth","year"]},{"verseId":"brenton_1-maccabees_13_42","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":42,"text":"Then the people of Israel began to write in their instruments and contracts, In the first year of Simon the high priest, the governor and leader of the Jews.","searchKeywords":["then","the","people","israel","began","write","their","instruments","and","contracts","first","year","simon","high","priest","governor","leader","jews"]},{"verseId":"brenton_1-maccabees_13_43","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":43,"text":"In those days Simon camped against Gaza, and besieged it round about; he made also an engine of war, and set it by the city, and battered a certain tower, and took it.","searchKeywords":["those","days","simon","camped","against","gaza","and","besieged","round","about","made","also","engine","war","set","the","city","battered","certain","tower","took"]},{"verseId":"brenton_1-maccabees_13_44","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":44,"text":"And they that were in the engine leaped into the city; whereupon there was a great uproar in the city:","searchKeywords":["and","they","that","were","the","engine","leaped","into","city","whereupon","there","was","great","uproar"]},{"verseId":"brenton_1-maccabees_13_45","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":45,"text":"insomuch as the people of the city rent their clothes, and climbed upon the walls with their wives and children, and cried with a loud voice, beseeching Simon to grant them peace.","searchKeywords":["insomuch","the","people","city","rent","their","clothes","and","climbed","upon","walls","with","wives","children","cried","loud","voice","beseeching","simon","grant","them","peace"]},{"verseId":"brenton_1-maccabees_13_46","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":46,"text":"And they said, Deal not with us according to our wickedness, but according to thy mercy.","searchKeywords":["and","they","said","deal","not","with","according","our","wickedness","but","thy","mercy"]},{"verseId":"brenton_1-maccabees_13_47","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":47,"text":"So Simon was appeased toward them, and fought no more against them, but put them out of the city, and cleansed the houses wherein the idols were, and so entered into it with songs and thanksgiving.","searchKeywords":["simon","was","appeased","toward","them","and","fought","more","against","but","put","out","the","city","cleansed","houses","wherein","idols","were","entered","into","with","songs","thanksgiving"]},{"verseId":"brenton_1-maccabees_13_48","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":48,"text":"Yea, he put all uncleanness out of it, and placed such men there as would keep the law, and made it stronger than it was before, and built therein a dwelling place for himself.","searchKeywords":["yea","put","all","uncleanness","out","and","placed","such","men","there","would","keep","the","law","made","stronger","than","was","before","built","therein","dwelling","place","for","himself"]},{"verseId":"brenton_1-maccabees_13_49","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":49,"text":"They also of the tower in Jerusalem were kept so strait, that they could neither come forth, nor go into the country, nor buy, nor sell: wherefore they were in great distress for want of victuals, and a great number of them perished through famine.","searchKeywords":["they","also","the","tower","jerusalem","were","kept","strait","that","could","neither","come","forth","nor","into","country","buy","sell","wherefore","great","distress","for","want","victuals","and","number","them","perished","through","famine"]},{"verseId":"brenton_1-maccabees_13_50","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":50,"text":"Then cried they to Simon, beseeching him to be at one with them: which thing he granted them; and when he had put them out from thence, he cleansed the tower from pollutions;","searchKeywords":["then","cried","they","simon","beseeching","him","one","with","them","which","thing","granted","and","when","had","put","out","from","thence","cleansed","the","tower","pollutions"]},{"verseId":"brenton_1-maccabees_13_51","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":51,"text":"and entered into it the three and twentieth day of the second month, in the hundred seventy and first year, with thanksgiving, and branches of palm trees, and with harps, and cymbals, and with viols, and hymns, and songs: because there was destroyed a great enemy out of Israel.","searchKeywords":["and","entered","into","the","three","twentieth","day","second","month","hundred","seventy","first","year","with","thanksgiving","branches","palm","trees","harps","cymbals","viols","hymns","songs","because","there","was","destroyed","great","enemy","out","israel"]},{"verseId":"brenton_1-maccabees_13_52","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":52,"text":"He ordained also that that day should be kept every year with gladness. Moreover the hill of the temple that was by the tower he made stronger than it was, and there he dwelt himself with his company.","searchKeywords":["ordained","also","that","day","should","kept","every","year","with","gladness","moreover","the","hill","temple","was","tower","made","stronger","than","and","there","dwelt","himself","his","company"]},{"verseId":"brenton_1-maccabees_13_53","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":13,"verse":53,"text":"And when Simon saw that John his son was a valiant man, he made him captain of all the hosts; and he dwelt in Gazara.","searchKeywords":["and","when","simon","saw","that","john","his","son","was","valiant","man","made","him","captain","all","the","hosts","dwelt","gazara"]}]