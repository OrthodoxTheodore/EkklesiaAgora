[{"verseId":"brenton_1-maccabees_7_1","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":1,"text":"In the hundred and one and fiftieth year Demetrius the of Seleucus departed from Rome, and came up with a few men unto a city of the sea coast, and reigned there.","searchKeywords":["the","hundred","and","one","fiftieth","year","demetrius","seleucus","departed","from","rome","came","with","few","men","unto","city","sea","coast","reigned","there"]},{"verseId":"brenton_1-maccabees_7_2","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":2,"text":"And as he entered into the palace of his ancestors, so it was, that his forces had taken Antiochus and Lysias, to bring them unto him.","searchKeywords":["and","entered","into","the","palace","his","ancestors","was","that","forces","had","taken","antiochus","lysias","bring","them","unto","him"]},{"verseId":"brenton_1-maccabees_7_3","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":3,"text":"Wherefore, when he knew it, he said, Let me not see their faces.","searchKeywords":["wherefore","when","knew","said","let","not","see","their","faces"]},{"verseId":"brenton_1-maccabees_7_4","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":4,"text":"So his host slew them. Now when Demetrius was set upon the throne of his kingdom,","searchKeywords":["his","host","slew","them","now","when","demetrius","was","set","upon","the","throne","kingdom"]},{"verseId":"brenton_1-maccabees_7_5","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":5,"text":"there came unto him all the wicked and ungodly men of Israel, having Alcimus, who was desirous to be high priest, for their captain:","searchKeywords":["there","came","unto","him","all","the","wicked","and","ungodly","men","israel","having","alcimus","who","was","desirous","high","priest","for","their","captain"]},{"verseId":"brenton_1-maccabees_7_6","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":6,"text":"and they accused the people to the king, saying, Judas and his brethren have slain all thy friends, and driven us out of our own land.","searchKeywords":["and","they","accused","the","people","king","saying","judas","his","brethren","have","slain","all","thy","friends","driven","out","our","own","land"]},{"verseId":"brenton_1-maccabees_7_7","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":7,"text":"Now therefore send some man whom thou trustest, and let him go and see what havock he hath made among us, and in the king's land, and let him punish them with all them that aid them.","searchKeywords":["now","therefore","send","some","man","whom","thou","trustest","and","let","him","see","what","havock","hath","made","among","the","king","land","punish","them","with","all","that","aid"]},{"verseId":"brenton_1-maccabees_7_8","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":8,"text":"Then the king chose Bacchides, a friend of the king, who ruled beyond the river, and was a great man in the kingdom, and faithful to the king.","searchKeywords":["then","the","king","chose","bacchides","friend","who","ruled","beyond","river","and","was","great","man","kingdom","faithful"]},{"verseId":"brenton_1-maccabees_7_9","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":9,"text":"And him he sent with that wicked Alcimus, whom he made high priest, and commanded that he should take vengeance of the children of Israel.","searchKeywords":["and","him","sent","with","that","wicked","alcimus","whom","made","high","priest","commanded","should","take","vengeance","the","children","israel"]},{"verseId":"brenton_1-maccabees_7_10","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":10,"text":"So they departed, and came with a great power into the land of Juda, where they sent messengers to Judas and his brethren with peaceable words deceitfully.","searchKeywords":["they","departed","and","came","with","great","power","into","the","land","juda","where","sent","messengers","judas","his","brethren","peaceable","words","deceitfully"]},{"verseId":"brenton_1-maccabees_7_11","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":11,"text":"But they gave no heed to their words; for they saw that they were come with great power.","searchKeywords":["but","they","gave","heed","their","words","for","saw","that","were","come","with","great","power"]},{"verseId":"brenton_1-maccabees_7_12","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":12,"text":"Then did there assemble unto Alcimus and Bacchides a company of scribes, to require justice.","searchKeywords":["then","did","there","assemble","unto","alcimus","and","bacchides","company","scribes","require","justice"]},{"verseId":"brenton_1-maccabees_7_13","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":13,"text":"Now the Assideans were the first among the children of Israel that sought peace of them:","searchKeywords":["now","the","assideans","were","first","among","children","israel","that","sought","peace","them"]},{"verseId":"brenton_1-maccabees_7_14","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":14,"text":"for said they, One that is a priest of the seed of Aaron is come with this army, and he will do us no wrong.","searchKeywords":["for","said","they","one","that","priest","the","seed","aaron","come","with","this","army","and","will","wrong"]},{"verseId":"brenton_1-maccabees_7_15","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":15,"text":"So he spake unto them peaceably, and sware unto them, saying, We will procure the harm neither of you nor your friends.","searchKeywords":["spake","unto","them","peaceably","and","sware","saying","will","procure","the","harm","neither","you","nor","your","friends"]},{"verseId":"brenton_1-maccabees_7_16","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":16,"text":"Whereupon they believed him: howbeit he took of them threescore men, and slew them in one day, according to the words which he wrote,","searchKeywords":["whereupon","they","believed","him","howbeit","took","them","threescore","men","and","slew","one","day","according","the","words","which","wrote"]},{"verseId":"brenton_1-maccabees_7_17","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":17,"text":"The flesh of thy saints , and their blood have they shed round about Jerusalem, and there was none to bury them.","searchKeywords":["the","flesh","thy","saints","and","their","blood","have","they","shed","round","about","jerusalem","there","was","none","bury","them"]},{"verseId":"brenton_1-maccabees_7_18","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":18,"text":"Wherefore the fear and dread of them fell upon all the people, who said, There is neither truth nor righteousness in them; for they have broken the covenant and oath that they made.","searchKeywords":["wherefore","the","fear","and","dread","them","fell","upon","all","people","who","said","there","neither","truth","nor","righteousness","for","they","have","broken","covenant","oath","that","made"]},{"verseId":"brenton_1-maccabees_7_19","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":19,"text":"After this removed Bacchides from Jerusalem, and pitched his tents in Bezeth, where he sent and took many of the men that had forsaken him, and certain of the people also, and when he had slain them, into the great pit.","searchKeywords":["after","this","removed","bacchides","from","jerusalem","and","pitched","his","tents","bezeth","where","sent","took","many","the","men","that","had","forsaken","him","certain","people","also","when","slain","them","into","great","pit"]},{"verseId":"brenton_1-maccabees_7_20","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":20,"text":"Then committed he the country to Alcimus, and left with him a power to aid him: so Bacchides went to the king.","searchKeywords":["then","committed","the","country","alcimus","and","left","with","him","power","aid","bacchides","went","king"]},{"verseId":"brenton_1-maccabees_7_21","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":21,"text":"But Alcimus contended for the high priesthood.","searchKeywords":["but","alcimus","contended","for","the","high","priesthood"]},{"verseId":"brenton_1-maccabees_7_22","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":22,"text":"And unto him resorted all such as troubled the people, who, after they had gotten the land of Juda into their power, did much hurt in Israel.","searchKeywords":["and","unto","him","resorted","all","such","troubled","the","people","who","after","they","had","gotten","land","juda","into","their","power","did","much","hurt","israel"]},{"verseId":"brenton_1-maccabees_7_23","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":23,"text":"Now when Judas saw all the mischief that Alcimus and his company had done among the Israelites, even above the heathen,","searchKeywords":["now","when","judas","saw","all","the","mischief","that","alcimus","and","his","company","had","done","among","israelites","even","above","heathen"]},{"verseId":"brenton_1-maccabees_7_24","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":24,"text":"he went out into all the coasts of Judea round about, and took vengeance of them that had revolted from him, so that they durst no more go forth into the country.","searchKeywords":["went","out","into","all","the","coasts","judea","round","about","and","took","vengeance","them","that","had","revolted","from","him","they","durst","more","forth","country"]},{"verseId":"brenton_1-maccabees_7_25","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":25,"text":"On the other side, when Alcimus saw that Judas and his company had gotten the upper hand, and knew that he was not able to abide their force, he went again to the king, and said evil things against them.","searchKeywords":["the","other","side","when","alcimus","saw","that","judas","and","his","company","had","gotten","upper","hand","knew","was","not","able","abide","their","force","went","again","king","said","evil","things","against","them"]},{"verseId":"brenton_1-maccabees_7_26","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":26,"text":"Then the king sent Nicanor, one of his honourable princes, a man that bare deadly hate unto Israel, with commandment to destroy the people.","searchKeywords":["then","the","king","sent","nicanor","one","his","honourable","princes","man","that","bare","deadly","hate","unto","israel","with","commandment","destroy","people"]},{"verseId":"brenton_1-maccabees_7_27","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":27,"text":"So Nicanor came to Jerusalem with a great force: and sent unto Judas and his brethren deceitfully with friendly words, saying,","searchKeywords":["nicanor","came","jerusalem","with","great","force","and","sent","unto","judas","his","brethren","deceitfully","friendly","words","saying"]},{"verseId":"brenton_1-maccabees_7_28","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":28,"text":"Let there be no battle between me and you; I will come with a few men, that I may see you in peace.","searchKeywords":["let","there","battle","between","and","you","will","come","with","few","men","that","may","see","peace"]},{"verseId":"brenton_1-maccabees_7_29","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":29,"text":"He came therefore to Judas, and they saluted one another peaceably. Howbeit the enemies were prepared to take away Judas by violence.","searchKeywords":["came","therefore","judas","and","they","saluted","one","another","peaceably","howbeit","the","enemies","were","prepared","take","away","violence"]},{"verseId":"brenton_1-maccabees_7_30","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":30,"text":"Which thing after it was known to Judas, , that he came unto him with deceit, he was sore afraid of him, and would see his face no more.","searchKeywords":["which","thing","after","was","known","judas","that","came","unto","him","with","deceit","sore","afraid","and","would","see","his","face","more"]},{"verseId":"brenton_1-maccabees_7_31","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":31,"text":"Nicanor also, when he saw that his counsel was discovered, went out to fight against Judas beside Capharsalama:","searchKeywords":["nicanor","also","when","saw","that","his","counsel","was","discovered","went","out","fight","against","judas","beside","capharsalama"]},{"verseId":"brenton_1-maccabees_7_32","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":32,"text":"and there were slain of Nicanor's side about five thousand men, and fled into the city of David.","searchKeywords":["and","there","were","slain","nicanor","side","about","five","thousand","men","fled","into","the","city","david"]},{"verseId":"brenton_1-maccabees_7_33","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":33,"text":"After this went Nicanor up to mount Sion, and there came out of the sanctuary certain of the priests and certain of the elders of the people, to salute him peaceably, and to shew him the burnt sacrifice that was offered for the king.","searchKeywords":["after","this","went","nicanor","mount","sion","and","there","came","out","the","sanctuary","certain","priests","elders","people","salute","him","peaceably","shew","burnt","sacrifice","that","was","offered","for","king"]},{"verseId":"brenton_1-maccabees_7_34","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":34,"text":"But he mocked them, and laughed at them, and abused them shamefully, and spake proudly,","searchKeywords":["but","mocked","them","and","laughed","abused","shamefully","spake","proudly"]},{"verseId":"brenton_1-maccabees_7_35","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":35,"text":"and sware in his wrath, saying, Unless Judas and his host be now delivered into my hands, if ever I come again in safety, I will burn up this house: and with that he went out in a great rage.","searchKeywords":["and","sware","his","wrath","saying","unless","judas","host","now","delivered","into","hands","ever","come","again","safety","will","burn","this","house","with","that","went","out","great","rage"]},{"verseId":"brenton_1-maccabees_7_36","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":36,"text":"Then the priests entered in, and stood before the altar and the temple, weeping, and saying,","searchKeywords":["then","the","priests","entered","and","stood","before","altar","temple","weeping","saying"]},{"verseId":"brenton_1-maccabees_7_37","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":37,"text":"Thou, O Lord, didst choose this house to be called by thy name, and to be a house of prayer and petition for thy people:","searchKeywords":["thou","lord","didst","choose","this","house","called","thy","name","and","prayer","petition","for","people"]},{"verseId":"brenton_1-maccabees_7_38","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":38,"text":"be avenged of this man and his host, and let them fall by the sword: remember their blasphemies, and suffer them not to continue any longer.","searchKeywords":["avenged","this","man","and","his","host","let","them","fall","the","sword","remember","their","blasphemies","suffer","not","continue","any","longer"]},{"verseId":"brenton_1-maccabees_7_39","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":39,"text":"So Nicanor went out of Jerusalem, and pitched his tents in Bethhoron, where a host out of Syria met him.","searchKeywords":["nicanor","went","out","jerusalem","and","pitched","his","tents","bethhoron","where","host","syria","met","him"]},{"verseId":"brenton_1-maccabees_7_40","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":40,"text":"But Judas pitched in Adasa with three thousand men, and there he prayed, saying,","searchKeywords":["but","judas","pitched","adasa","with","three","thousand","men","and","there","prayed","saying"]},{"verseId":"brenton_1-maccabees_7_41","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":41,"text":"O Lord, when they that were sent from the king of the Assyrians blasphemed, thine angel went out and smote an hundred fourscore and five thousand of them.","searchKeywords":["lord","when","they","that","were","sent","from","the","king","assyrians","blasphemed","thine","angel","went","out","and","smote","hundred","fourscore","five","thousand","them"]},{"verseId":"brenton_1-maccabees_7_42","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":42,"text":"Even so destroy thou this host before us this day, that the rest may know that he hath spoken blasphemously against thy sanctuary, and judge thou him according to his wickedness.","searchKeywords":["even","destroy","thou","this","host","before","day","that","the","rest","may","know","hath","spoken","blasphemously","against","thy","sanctuary","and","judge","him","according","his","wickedness"]},{"verseId":"brenton_1-maccabees_7_43","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":43,"text":"So the thirteenth day of the month Adar the hosts joined battle: but Nicanor's host was discomfited, and he himself was first slain in the battle.","searchKeywords":["the","thirteenth","day","month","adar","hosts","joined","battle","but","nicanor","host","was","discomfited","and","himself","first","slain"]},{"verseId":"brenton_1-maccabees_7_44","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":44,"text":"Now when Nicanor's host saw that he was slain, they cast away their weapons, and fled.","searchKeywords":["now","when","nicanor","host","saw","that","was","slain","they","cast","away","their","weapons","and","fled"]},{"verseId":"brenton_1-maccabees_7_45","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":45,"text":"Then they pursued after them a day's journey, from Adasa unto Gazera, sounding an alarm after them with their trumpets.","searchKeywords":["then","they","pursued","after","them","day","journey","from","adasa","unto","gazera","sounding","alarm","with","their","trumpets"]},{"verseId":"brenton_1-maccabees_7_46","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":46,"text":"Whereupon they came forth out of all the towns of Judea round about, and closed them in; so that they, turning back upon them that pursued them, were all slain with the sword, and not one of them was left.","searchKeywords":["whereupon","they","came","forth","out","all","the","towns","judea","round","about","and","closed","them","that","turning","back","upon","pursued","were","slain","with","sword","not","one","was","left"]},{"verseId":"brenton_1-maccabees_7_47","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":47,"text":"Afterwards they took the spoils, and the prey, and smote off Nicanor's head, and his right hand, which he stretched out so proudly, and brought them away, and hanged them up toward Jerusalem.","searchKeywords":["afterwards","they","took","the","spoils","and","prey","smote","off","nicanor","head","his","right","hand","which","stretched","out","proudly","brought","them","away","hanged","toward","jerusalem"]},{"verseId":"brenton_1-maccabees_7_48","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":48,"text":"For this cause the people rejoiced greatly, and kept that day a day of great gladness.","searchKeywords":["for","this","cause","the","people","rejoiced","greatly","and","kept","that","day","great","gladness"]},{"verseId":"brenton_1-maccabees_7_49","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":49,"text":"Moreover they ordained to keep yearly this day, being the thirteenth of Adar.","searchKeywords":["moreover","they","ordained","keep","yearly","this","day","being","the","thirteenth","adar"]},{"verseId":"brenton_1-maccabees_7_50","translationId":"brenton","testament":"OT","bookIndex":21,"bookName":"1 Maccabees","bookAbbrev":"1-maccabees","chapter":7,"verse":50,"text":"Thus the land of Juda was in rest a little while.","searchKeywords":["thus","the","land","juda","was","rest","little","while"]}]