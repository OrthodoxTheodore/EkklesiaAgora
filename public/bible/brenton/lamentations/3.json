[{"verseId":"brenton_lamentations_3_1","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":1,"text":"I am the man that sees poverty, through the rod of his wrath upon me.","searchKeywords":["the","man","that","sees","poverty","through","rod","his","wrath","upon"]},{"verseId":"brenton_lamentations_3_2","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":2,"text":"He has taken me, and led me away into darkness, and not light.","searchKeywords":["has","taken","and","led","away","into","darkness","not","light"]},{"verseId":"brenton_lamentations_3_3","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":3,"text":"Nay, against me has he turned his hand all the day.","searchKeywords":["nay","against","has","turned","his","hand","all","the","day"]},{"verseId":"brenton_lamentations_3_4","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":4,"text":"He has made old my flesh and my skin; he has broken my bones.","searchKeywords":["has","made","old","flesh","and","skin","broken","bones"]},{"verseId":"brenton_lamentations_3_5","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":5,"text":"He has built against me, and compassed my head, and brought travail .","searchKeywords":["has","built","against","and","compassed","head","brought","travail"]},{"verseId":"brenton_lamentations_3_6","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":6,"text":"He has set me in dark places, as them that have long been dead.","searchKeywords":["has","set","dark","places","them","that","have","long","been","dead"]},{"verseId":"brenton_lamentations_3_7","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":7,"text":"He has builded against me, and I cannot come forth: he has made my brazen heavy.","searchKeywords":["has","builded","against","and","cannot","come","forth","made","brazen","heavy"]},{"verseId":"brenton_lamentations_3_8","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":8,"text":"Yea, I cry and shout, he shuts out my prayer.","searchKeywords":["yea","cry","and","shout","shuts","out","prayer"]},{"verseId":"brenton_lamentations_3_9","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":9,"text":"He has built up my ways, he has hedged my paths;","searchKeywords":["has","built","ways","hedged","paths"]},{"verseId":"brenton_lamentations_3_10","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":10,"text":"he has troubled me, a she-bear lying in wait: he is to me a lion in secret places.","searchKeywords":["has","troubled","she","bear","lying","wait","lion","secret","places"]},{"verseId":"brenton_lamentations_3_11","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":11,"text":"He pursued after I departed, and brought me to a stand: he has utterly ruined me.","searchKeywords":["pursued","after","departed","and","brought","stand","has","utterly","ruined"]},{"verseId":"brenton_lamentations_3_12","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":12,"text":"He has bent his bow, and set me as a mark for the arrow.","searchKeywords":["has","bent","his","bow","and","set","mark","for","the","arrow"]},{"verseId":"brenton_lamentations_3_13","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":13,"text":"He has caused the arrows of his quiver to enter into my reins.","searchKeywords":["has","caused","the","arrows","his","quiver","enter","into","reins"]},{"verseId":"brenton_lamentations_3_14","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":14,"text":"I became a laughing-stock to all my people; and their song all the day.","searchKeywords":["became","laughing","stock","all","people","and","their","song","the","day"]},{"verseId":"brenton_lamentations_3_15","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":15,"text":"He has filled me with bitterness, he has drenched me with gall.","searchKeywords":["has","filled","with","bitterness","drenched","gall"]},{"verseId":"brenton_lamentations_3_16","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":16,"text":"And he has dashed out my teeth with gravel, he has fed me with ashes.","searchKeywords":["and","has","dashed","out","teeth","with","gravel","fed","ashes"]},{"verseId":"brenton_lamentations_3_17","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":17,"text":"He has also removed my soul from peace: I forgot prosperity.","searchKeywords":["has","also","removed","soul","from","peace","forgot","prosperity"]},{"verseId":"brenton_lamentations_3_18","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":18,"text":"Therefore my success has perished, and my hope from the Lord.","searchKeywords":["therefore","success","has","perished","and","hope","from","the","lord"]},{"verseId":"brenton_lamentations_3_19","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":19,"text":"I remembered by reason of my poverty, and because of persecution my bitterness and gall shall be remembered;","searchKeywords":["remembered","reason","poverty","and","because","persecution","bitterness","gall","shall"]},{"verseId":"brenton_lamentations_3_20","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":20,"text":"and my soul shall meditate with me.","searchKeywords":["and","soul","shall","meditate","with"]},{"verseId":"brenton_lamentations_3_21","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":21,"text":"This will I lay up in my heart, therefore will I endure. the mercies of the Lord, that he has not failed me, because his compassions are not exhausted. Pity , O Lord, early month: for we are not brought to an end, because his compassions are not exhausted. new every morning: great is thy faithfulness.","searchKeywords":["this","will","lay","heart","therefore","endure","the","mercies","lord","that","has","not","failed","because","his","compassions","are","exhausted","pity","early","month","for","brought","end","new","every","morning","great","thy","faithfulness"]},{"verseId":"brenton_lamentations_3_25","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":25,"text":"The Lord is good to them that wait for him: the soul which shall seek him","searchKeywords":["the","lord","good","them","that","wait","for","him","soul","which","shall","seek"]},{"verseId":"brenton_lamentations_3_26","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":26,"text":"good, and shall wait for, and quietly expect salvation of the Lord.","searchKeywords":["good","and","shall","wait","for","quietly","expect","salvation","the","lord"]},{"verseId":"brenton_lamentations_3_27","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":27,"text":"good for a man when he bears a yoke in his youth.","searchKeywords":["good","for","man","when","bears","yoke","his","youth"]},{"verseId":"brenton_lamentations_3_28","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":28,"text":"upon him.","searchKeywords":["upon","him"]},{"verseId":"brenton_lamentations_3_30","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":30,"text":"He will give cheek to him that smites him: he will be filled full with reproaches.","searchKeywords":["will","give","cheek","him","that","smites","filled","full","with","reproaches"]},{"verseId":"brenton_lamentations_3_32","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":32,"text":"For he that has brought down will pity, and according to the abundance of his mercy.","searchKeywords":["for","that","has","brought","down","will","pity","and","according","the","abundance","his","mercy"]},{"verseId":"brenton_lamentations_3_33","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":33,"text":"from his heart, though he has brought low the children of a man.","searchKeywords":["from","his","heart","though","has","brought","low","the","children","man"]},{"verseId":"brenton_lamentations_3_34","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":34,"text":"To bring down under his feet all the prisoners of the earth,","searchKeywords":["bring","down","under","his","feet","all","the","prisoners","earth"]},{"verseId":"brenton_lamentations_3_36","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":36,"text":"in his judgment, the Lord has not given commandment.","searchKeywords":["his","judgment","the","lord","has","not","given","commandment"]},{"verseId":"brenton_lamentations_3_39","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":39,"text":"Why should a living man complain, a man concerning his sin?","searchKeywords":["why","should","living","man","complain","concerning","his","sin"]},{"verseId":"brenton_lamentations_3_40","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":40,"text":"Our way has been searched out and examined, and we will turn to the Lord.","searchKeywords":["our","way","has","been","searched","out","and","examined","will","turn","the","lord"]},{"verseId":"brenton_lamentations_3_41","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":41,"text":"hands to the lofty One in heaven.","searchKeywords":["hands","the","lofty","one","heaven"]},{"verseId":"brenton_lamentations_3_43","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":43,"text":"Thou hast visited in wrath, and driven us away: thou hast slain, thou hast not pitied.","searchKeywords":["thou","hast","visited","wrath","and","driven","away","slain","not","pitied"]},{"verseId":"brenton_lamentations_3_45","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":45,"text":"Thou hast set us in the midst of the nations.","searchKeywords":["thou","hast","set","the","midst","nations"]},{"verseId":"brenton_lamentations_3_49","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":49,"text":"Mine eye is drowned , and I will not be silent, so that there shall be no rest,","searchKeywords":["mine","eye","drowned","and","will","not","silent","that","there","shall","rest"]},{"verseId":"brenton_lamentations_3_52","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":52,"text":"The fowlers chased me as a sparrow, all mine enemies destroyed my life in a pit without cause,","searchKeywords":["the","fowlers","chased","sparrow","all","mine","enemies","destroyed","life","pit","without","cause"]},{"verseId":"brenton_lamentations_3_55","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":55,"text":"I called upon thy name, O Lord, out of the lowest dungeon.","searchKeywords":["called","upon","thy","name","lord","out","the","lowest","dungeon"]},{"verseId":"brenton_lamentations_3_58","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":58,"text":"O Lord, thou hast pleaded the causes of my soul; thou hast redeemed my life.","searchKeywords":["lord","thou","hast","pleaded","the","causes","soul","redeemed","life"]},{"verseId":"brenton_lamentations_3_60","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":60,"text":"on all their devices against me.","searchKeywords":["all","their","devices","against"]},{"verseId":"brenton_lamentations_3_61","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":61,"text":"Thou hast heard their reproach all their devices against me;","searchKeywords":["thou","hast","heard","their","reproach","all","devices","against"]},{"verseId":"brenton_lamentations_3_65","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":3,"verse":65,"text":"Thou wilt give them a covering, the grief of my heart.","searchKeywords":["thou","wilt","give","them","covering","the","grief","heart"]}]