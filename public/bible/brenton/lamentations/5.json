[{"verseId":"brenton_lamentations_5_1","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":1,"text":"Remember, O Lord, what has happened to us: behold, and look on our reproach.","searchKeywords":["remember","lord","what","has","happened","behold","and","look","our","reproach"]},{"verseId":"brenton_lamentations_5_2","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":2,"text":"Our inheritance has been turned away to aliens, our houses to strangers:","searchKeywords":["our","inheritance","has","been","turned","away","aliens","houses","strangers"]},{"verseId":"brenton_lamentations_5_3","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":3,"text":"we are become orphans, we have no father, our mothers are as widows.","searchKeywords":["are","become","orphans","have","father","our","mothers","widows"]},{"verseId":"brenton_lamentations_5_4","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":4,"text":"We have drunk our water for money; our wood is sold to us on our neck:","searchKeywords":["have","drunk","our","water","for","money","wood","sold","neck"]},{"verseId":"brenton_lamentations_5_5","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":5,"text":"we have been persecuted, we have laboured, we have had no rest.","searchKeywords":["have","been","persecuted","laboured","had","rest"]},{"verseId":"brenton_lamentations_5_6","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":6,"text":"Egypt gave the hand , Assur to their own satisfaction.","searchKeywords":["egypt","gave","the","hand","assur","their","own","satisfaction"]},{"verseId":"brenton_lamentations_5_7","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":7,"text":"Our fathers sinned, are not: we have borne their iniquities.","searchKeywords":["our","fathers","sinned","are","not","have","borne","their","iniquities"]},{"verseId":"brenton_lamentations_5_8","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":8,"text":"Servants have ruled over us: there is none to ransom out of their hand.","searchKeywords":["servants","have","ruled","over","there","none","ransom","out","their","hand"]},{"verseId":"brenton_lamentations_5_9","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":9,"text":"We shall bring in our bread with our lives, because of the sword of the wilderness.","searchKeywords":["shall","bring","our","bread","with","lives","because","the","sword","wilderness"]},{"verseId":"brenton_lamentations_5_10","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":10,"text":"Our skin is blackened like an oven; they are convulsed, because of the storms of famine.","searchKeywords":["our","skin","blackened","like","oven","they","are","convulsed","because","the","storms","famine"]},{"verseId":"brenton_lamentations_5_11","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":11,"text":"They humbled the women in Sion, the virgins in the cities of Juda.","searchKeywords":["they","humbled","the","women","sion","virgins","cities","juda"]},{"verseId":"brenton_lamentations_5_12","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":12,"text":"Princes were hanged up by their hands: the elders were not honoured.","searchKeywords":["princes","were","hanged","their","hands","the","elders","not","honoured"]},{"verseId":"brenton_lamentations_5_13","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":13,"text":"The chosen men lifted up weeping, and the youths fainted under the wood.","searchKeywords":["the","chosen","men","lifted","weeping","and","youths","fainted","under","wood"]},{"verseId":"brenton_lamentations_5_14","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":14,"text":"And the elders ceased from the gate, the chosen men ceased from their music.","searchKeywords":["and","the","elders","ceased","from","gate","chosen","men","their","music"]},{"verseId":"brenton_lamentations_5_15","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":15,"text":"The joy of our heart has ceased; our dance is turned into mourning.","searchKeywords":["the","joy","our","heart","has","ceased","dance","turned","into","mourning"]},{"verseId":"brenton_lamentations_5_16","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":16,"text":"The crown has fallen our head: yea, woe to us! for we have sinned.","searchKeywords":["the","crown","has","fallen","our","head","yea","woe","for","have","sinned"]},{"verseId":"brenton_lamentations_5_17","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":17,"text":"For this has grief come; our heart is sorrowful: for this our eyes are darkened.","searchKeywords":["for","this","has","grief","come","our","heart","sorrowful","eyes","are","darkened"]},{"verseId":"brenton_lamentations_5_18","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":18,"text":"Over the mountain of Sion, because it is made desolate, foxes have walked therein.","searchKeywords":["over","the","mountain","sion","because","made","desolate","foxes","have","walked","therein"]},{"verseId":"brenton_lamentations_5_19","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":19,"text":"But thou, O Lord, shalt dwell for ever; thy throne to generation and generation.","searchKeywords":["but","thou","lord","shalt","dwell","for","ever","thy","throne","generation","and"]},{"verseId":"brenton_lamentations_5_20","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":20,"text":"Wherefore wilt thou utterly forget us, and abandon us a long time?","searchKeywords":["wherefore","wilt","thou","utterly","forget","and","abandon","long","time"]},{"verseId":"brenton_lamentations_5_21","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":21,"text":"Turn us, O Lord, to thee, and we shall be turned; and renew our days as before.","searchKeywords":["turn","lord","thee","and","shall","turned","renew","our","days","before"]},{"verseId":"brenton_lamentations_5_22","translationId":"brenton","testament":"OT","bookIndex":48,"bookName":"Lamentations","bookAbbrev":"lamentations","chapter":5,"verse":22,"text":"For thou hast indeed rejected us; thou hast been very wroth against us.","searchKeywords":["for","thou","hast","indeed","rejected","been","very","wroth","against"]}]