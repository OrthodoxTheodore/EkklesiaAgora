[{"verseId":"brenton_wisdom-of-solomon_1_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":1,"text":"righteousness, ye that be judges of the earth: think of the Lord with a good (heart,) and in simplicity of heart seek him.","searchKeywords":["righteousness","that","judges","the","earth","think","lord","with","good","heart","and","simplicity","seek","him"]},{"verseId":"brenton_wisdom-of-solomon_1_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":2,"text":"For he will be found of them that tempt him not; and sheweth himself unto such as do not distrust him.","searchKeywords":["for","will","found","them","that","tempt","him","not","and","sheweth","himself","unto","such","distrust"]},{"verseId":"brenton_wisdom-of-solomon_1_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":3,"text":"For froward thoughts separate from God: and his power, when it is tried, reproveth the unwise.","searchKeywords":["for","froward","thoughts","separate","from","god","and","his","power","when","tried","reproveth","the","unwise"]},{"verseId":"brenton_wisdom-of-solomon_1_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":4,"text":"For into a malicious soul wisdom shall not enter: nor dwell in the body that is subject unto sin.","searchKeywords":["for","into","malicious","soul","wisdom","shall","not","enter","nor","dwell","the","body","that","subject","unto","sin"]},{"verseId":"brenton_wisdom-of-solomon_1_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":5,"text":"For the holy spirit of discipline will flee deceit, and remove from thoughts that are without understanding, and will not abide when unrighteousness cometh in.","searchKeywords":["for","the","holy","spirit","discipline","will","flee","deceit","and","remove","from","thoughts","that","are","without","understanding","not","abide","when","unrighteousness","cometh"]},{"verseId":"brenton_wisdom-of-solomon_1_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":6,"text":"For wisdom is a loving spirit; and will not acquit a blasphemer of his words: for God is witness of his reins, and a true beholder of his heart, and a hearer of his tongue.","searchKeywords":["for","wisdom","loving","spirit","and","will","not","acquit","blasphemer","his","words","god","witness","reins","true","beholder","heart","hearer","tongue"]},{"verseId":"brenton_wisdom-of-solomon_1_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":7,"text":"For the Spirit of the Lord filleth the world: and that which containeth all things hath knowledge of the voice.","searchKeywords":["for","the","spirit","lord","filleth","world","and","that","which","containeth","all","things","hath","knowledge","voice"]},{"verseId":"brenton_wisdom-of-solomon_1_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":8,"text":"Therefore he that speaketh unrighteous things cannot be hidden: neither shall vengeance, when it punisheth, pass by him.","searchKeywords":["therefore","that","speaketh","unrighteous","things","cannot","hidden","neither","shall","vengeance","when","punisheth","pass","him"]},{"verseId":"brenton_wisdom-of-solomon_1_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":9,"text":"For inquisition shall be made into the counsels of the ungodly: and the sound of his words shall come unto the Lord for the manifestation of his wicked deeds.","searchKeywords":["for","inquisition","shall","made","into","the","counsels","ungodly","and","sound","his","words","come","unto","lord","manifestation","wicked","deeds"]},{"verseId":"brenton_wisdom-of-solomon_1_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":10,"text":"For the ear of jealousy heareth all things: and the noise of murmurings is not hid.","searchKeywords":["for","the","ear","jealousy","heareth","all","things","and","noise","murmurings","not","hid"]},{"verseId":"brenton_wisdom-of-solomon_1_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":11,"text":"Therefore beware of murmuring, which is unprofitable; and refrain your tongue from backbiting: for there is no word so secret, that shall go for nought: and the mouth that belieth slayeth the soul.","searchKeywords":["therefore","beware","murmuring","which","unprofitable","and","refrain","your","tongue","from","backbiting","for","there","word","secret","that","shall","nought","the","mouth","belieth","slayeth","soul"]},{"verseId":"brenton_wisdom-of-solomon_1_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":12,"text":"Seek not death in the error of your life: and pull not upon yourselves destruction with the works of your hands.","searchKeywords":["seek","not","death","the","error","your","life","and","pull","upon","yourselves","destruction","with","works","hands"]},{"verseId":"brenton_wisdom-of-solomon_1_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":13,"text":"For God made not death: neither hath he pleasure in the destruction of the living.","searchKeywords":["for","god","made","not","death","neither","hath","pleasure","the","destruction","living"]},{"verseId":"brenton_wisdom-of-solomon_1_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":14,"text":"For he created all things, that they might have their being: and the generations of the world were healthful; and there is no poison of destruction in them, nor the kingdom of death upon the earth:","searchKeywords":["for","created","all","things","that","they","might","have","their","being","and","the","generations","world","were","healthful","there","poison","destruction","them","nor","kingdom","death","upon","earth"]},{"verseId":"brenton_wisdom-of-solomon_1_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":15,"text":"(for righteousness is immortal:)","searchKeywords":["for","righteousness","immortal"]},{"verseId":"brenton_wisdom-of-solomon_1_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":1,"verse":16,"text":"but ungodly men with their works and words called it to them: for when they thought to have it their friend, they consumed to nought, and made a covenant with it, because they are worthy to take part with it.","searchKeywords":["but","ungodly","men","with","their","works","and","words","called","them","for","when","they","thought","have","friend","consumed","nought","made","covenant","because","are","worthy","take","part"]}]