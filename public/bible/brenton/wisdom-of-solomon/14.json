[{"verseId":"brenton_wisdom-of-solomon_14_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":1,"text":"Again, one preparing himself to sail, and about to pass through the raging waves, calleth upon a piece of wood more rotten than the vessel that carrieth him.","searchKeywords":["again","one","preparing","himself","sail","and","about","pass","through","the","raging","waves","calleth","upon","piece","wood","more","rotten","than","vessel","that","carrieth","him"]},{"verseId":"brenton_wisdom-of-solomon_14_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":2,"text":"For verily desire of gain devised that, and the workman built it by his skill.","searchKeywords":["for","verily","desire","gain","devised","that","and","the","workman","built","his","skill"]},{"verseId":"brenton_wisdom-of-solomon_14_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":3,"text":"But thy providence, O Father, governeth it: for thou hast made a way in the sea, and a safe path in the waves;","searchKeywords":["but","thy","providence","father","governeth","for","thou","hast","made","way","the","sea","and","safe","path","waves"]},{"verseId":"brenton_wisdom-of-solomon_14_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":4,"text":"shewing that thou canst save from all danger: yea, though a man went to sea without art.","searchKeywords":["shewing","that","thou","canst","save","from","all","danger","yea","though","man","went","sea","without","art"]},{"verseId":"brenton_wisdom-of-solomon_14_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":5,"text":"Nevertheless thou wouldest not that the works of thy wisdom should be idle, and therefore do men commit their lives to a small piece of wood, and passing the rough sea in a weak vessel are saved.","searchKeywords":["nevertheless","thou","wouldest","not","that","the","works","thy","wisdom","should","idle","and","therefore","men","commit","their","lives","small","piece","wood","passing","rough","sea","weak","vessel","are","saved"]},{"verseId":"brenton_wisdom-of-solomon_14_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":6,"text":"For in the old time also, when the proud giants perished, the hope of the world governed by thy hand escaped in a weak vessel, and left to all ages a seed of generation.","searchKeywords":["for","the","old","time","also","when","proud","giants","perished","hope","world","governed","thy","hand","escaped","weak","vessel","and","left","all","ages","seed","generation"]},{"verseId":"brenton_wisdom-of-solomon_14_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":7,"text":"For blessed is the wood whereby righteousness cometh.","searchKeywords":["for","blessed","the","wood","whereby","righteousness","cometh"]},{"verseId":"brenton_wisdom-of-solomon_14_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":8,"text":"But that which is made with hands is cursed, as well it, as he that made it: he, because he made it: and it, because, being corruptible, it was called God.","searchKeywords":["but","that","which","made","with","hands","cursed","well","because","and","being","corruptible","was","called","god"]},{"verseId":"brenton_wisdom-of-solomon_14_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":9,"text":"For the ungodly and his ungodliness are both alike hateful unto God.","searchKeywords":["for","the","ungodly","and","his","ungodliness","are","both","alike","hateful","unto","god"]},{"verseId":"brenton_wisdom-of-solomon_14_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":10,"text":"For that which is made shall be punished together with him that made it.","searchKeywords":["for","that","which","made","shall","punished","together","with","him"]},{"verseId":"brenton_wisdom-of-solomon_14_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":11,"text":"Therefore even upon the idols of the Gentiles shall there be a visitation: because in the creature of God they are become an abomination, and stumblingblocks to the souls of men, and a snare to the feet of the unwise.","searchKeywords":["therefore","even","upon","the","idols","gentiles","shall","there","visitation","because","creature","god","they","are","become","abomination","and","stumblingblocks","souls","men","snare","feet","unwise"]},{"verseId":"brenton_wisdom-of-solomon_14_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":12,"text":"For the devising of idols was the beginning of fornication, and the invention of them the corruption of life.","searchKeywords":["for","the","devising","idols","was","beginning","fornication","and","invention","them","corruption","life"]},{"verseId":"brenton_wisdom-of-solomon_14_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":13,"text":"For neither were they from the beginning, neither shall they be for ever.","searchKeywords":["for","neither","were","they","from","the","beginning","shall","ever"]},{"verseId":"brenton_wisdom-of-solomon_14_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":14,"text":"For by the vain glory of men they entered into the world, and therefore shall they come shortly to an end.","searchKeywords":["for","the","vain","glory","men","they","entered","into","world","and","therefore","shall","come","shortly","end"]},{"verseId":"brenton_wisdom-of-solomon_14_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":15,"text":"For a father afflicted with untimely mourning, when he hath made an image of his child soon taken away, now honoured him as a god, which was then a dead man, and delivered to those that were under him ceremonies and sacrifices.","searchKeywords":["for","father","afflicted","with","untimely","mourning","when","hath","made","image","his","child","soon","taken","away","now","honoured","him","god","which","was","then","dead","man","and","delivered","those","that","were","under","ceremonies","sacrifices"]},{"verseId":"brenton_wisdom-of-solomon_14_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":16,"text":"Thus in process of time an ungodly custom grown strong was kept as a law, and graven images were worshipped by the commandments of kings.","searchKeywords":["thus","process","time","ungodly","custom","grown","strong","was","kept","law","and","graven","images","were","worshipped","the","commandments","kings"]},{"verseId":"brenton_wisdom-of-solomon_14_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":17,"text":"Whom men could not honour in presence, because they dwelt far off, they took the counterfeit of his visage from far, and made an express image of a king whom they honoured, to the end that by this their forwardness they might flatter him that was absent, as if he were present.","searchKeywords":["whom","men","could","not","honour","presence","because","they","dwelt","far","off","took","the","counterfeit","his","visage","from","and","made","express","image","king","honoured","end","that","this","their","forwardness","might","flatter","him","was","absent","were","present"]},{"verseId":"brenton_wisdom-of-solomon_14_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":18,"text":"Also the singular diligence of the artificer did help to set forward the ignorant to more superstition.","searchKeywords":["also","the","singular","diligence","artificer","did","help","set","forward","ignorant","more","superstition"]},{"verseId":"brenton_wisdom-of-solomon_14_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":19,"text":"For he, peradventure willing to please one in authority, forced all his skill to make the resemblance of the best fashion.","searchKeywords":["for","peradventure","willing","please","one","authority","forced","all","his","skill","make","the","resemblance","best","fashion"]},{"verseId":"brenton_wisdom-of-solomon_14_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":20,"text":"And so the multitude, allured by the grace of the work, took him now for a god, which a little before was but honoured as a man.","searchKeywords":["and","the","multitude","allured","grace","work","took","him","now","for","god","which","little","before","was","but","honoured","man"]},{"verseId":"brenton_wisdom-of-solomon_14_21","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":21,"text":"And this was an occasion to deceive the world: for men, serving either calamity or tyranny, did ascribe unto stones and stocks the incommunicable name.","searchKeywords":["and","this","was","occasion","deceive","the","world","for","men","serving","either","calamity","tyranny","did","ascribe","unto","stones","stocks","incommunicable","name"]},{"verseId":"brenton_wisdom-of-solomon_14_22","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":22,"text":"Moreover this was not enough for them, that they erred in the knowledge of God; but whereas they lived in the great war of ignorance, those so great plagues called they peace.","searchKeywords":["moreover","this","was","not","enough","for","them","that","they","erred","the","knowledge","god","but","whereas","lived","great","war","ignorance","those","plagues","called","peace"]},{"verseId":"brenton_wisdom-of-solomon_14_23","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":23,"text":"For whilst they slew their children in sacrifices, or used secret ceremonies, or made revellings of strange rites;","searchKeywords":["for","whilst","they","slew","their","children","sacrifices","used","secret","ceremonies","made","revellings","strange","rites"]},{"verseId":"brenton_wisdom-of-solomon_14_24","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":24,"text":"they kept neither lives nor marriages any longer undefiled: but either one slew another traiterously or grieved him by adultery.","searchKeywords":["they","kept","neither","lives","nor","marriages","any","longer","undefiled","but","either","one","slew","another","traiterously","grieved","him","adultery"]},{"verseId":"brenton_wisdom-of-solomon_14_25","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":25,"text":"So that there reigned in all men without exception, blood, manslaughter, theft, and dissimulation, corruption, unfaithfulness, tumults, perjury,","searchKeywords":["that","there","reigned","all","men","without","exception","blood","manslaughter","theft","and","dissimulation","corruption","unfaithfulness","tumults","perjury"]},{"verseId":"brenton_wisdom-of-solomon_14_26","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":26,"text":"disquieting of good men, forgetfulness of good turns, defiling of souls, changing of kind, disorder in marriages, adultery, and shameless uncleanness.","searchKeywords":["disquieting","good","men","forgetfulness","turns","defiling","souls","changing","kind","disorder","marriages","adultery","and","shameless","uncleanness"]},{"verseId":"brenton_wisdom-of-solomon_14_27","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":27,"text":"For the worshipping of idols not to be named is the beginning, the cause, and the end, of all evil.","searchKeywords":["for","the","worshipping","idols","not","named","beginning","cause","and","end","all","evil"]},{"verseId":"brenton_wisdom-of-solomon_14_28","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":28,"text":"For either they are mad when they be merry, or prophesy lies, or live unjustly, or else lightly forswear themselves.","searchKeywords":["for","either","they","are","mad","when","merry","prophesy","lies","live","unjustly","else","lightly","forswear","themselves"]},{"verseId":"brenton_wisdom-of-solomon_14_29","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":29,"text":"For insomuch as their trust is in idols which have no life, though they swear falsely, yet they look not to be hurt.","searchKeywords":["for","insomuch","their","trust","idols","which","have","life","though","they","swear","falsely","yet","look","not","hurt"]},{"verseId":"brenton_wisdom-of-solomon_14_30","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":30,"text":"Howbeit for both causes shall they be justly punished: both because they thought not well of God, giving heed unto idols, and also unjustly swore in deceit, despising holiness.","searchKeywords":["howbeit","for","both","causes","shall","they","justly","punished","because","thought","not","well","god","giving","heed","unto","idols","and","also","unjustly","swore","deceit","despising","holiness"]},{"verseId":"brenton_wisdom-of-solomon_14_31","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":14,"verse":31,"text":"For it is not the power of them by whom they swear: but it is the just vengeance of sinners, that punisheth always the offence of the ungodly.","searchKeywords":["for","not","the","power","them","whom","they","swear","but","just","vengeance","sinners","that","punisheth","always","offence","ungodly"]}]