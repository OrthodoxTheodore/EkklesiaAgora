[{"verseId":"brenton_wisdom-of-solomon_5_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":1,"text":"Then shall the righteous man stand in great boldness before the face of such as have afflicted him, and made no account of his labours.","searchKeywords":["then","shall","the","righteous","man","stand","great","boldness","before","face","such","have","afflicted","him","and","made","account","his","labours"]},{"verseId":"brenton_wisdom-of-solomon_5_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":2,"text":"When they see it, they shall be troubled with terrible fear, and shall be amazed at the strangeness of his salvation, so far beyond all that they looked for.","searchKeywords":["when","they","see","shall","troubled","with","terrible","fear","and","amazed","the","strangeness","his","salvation","far","beyond","all","that","looked","for"]},{"verseId":"brenton_wisdom-of-solomon_5_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":3,"text":"And they repenting and groaning for anguish of spirit shall say within themselves,","searchKeywords":["and","they","repenting","groaning","for","anguish","spirit","shall","say","within","themselves"]},{"verseId":"brenton_wisdom-of-solomon_5_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":4,"text":"we fools accounted his life madness, and his end to be without honour:","searchKeywords":["fools","accounted","his","life","madness","and","end","without","honour"]},{"verseId":"brenton_wisdom-of-solomon_5_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":5,"text":"how is he numbered among the children of God, and his lot is among the saints!","searchKeywords":["how","numbered","among","the","children","god","and","his","lot","saints"]},{"verseId":"brenton_wisdom-of-solomon_5_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":6,"text":"Therefore have we erred from the way of truth, and the light of righteousness hath not shined unto us, and the sun of righteousness rose not upon us.","searchKeywords":["therefore","have","erred","from","the","way","truth","and","light","righteousness","hath","not","shined","unto","sun","rose","upon"]},{"verseId":"brenton_wisdom-of-solomon_5_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":7,"text":"We wearied ourselves in the way of wickedness and destruction: yea, we have gone through deserts, where there lay no way: but as for the way of the Lord, we have not known it.","searchKeywords":["wearied","ourselves","the","way","wickedness","and","destruction","yea","have","gone","through","deserts","where","there","lay","but","for","lord","not","known"]},{"verseId":"brenton_wisdom-of-solomon_5_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":8,"text":"What hath pride profited us? or what good hath riches with vaunting brought us?","searchKeywords":["what","hath","pride","profited","good","riches","with","vaunting","brought"]},{"verseId":"brenton_wisdom-of-solomon_5_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":9,"text":"All those things are passed away like a shadow, and as a post that hasted by;","searchKeywords":["all","those","things","are","passed","away","like","shadow","and","post","that","hasted"]},{"verseId":"brenton_wisdom-of-solomon_5_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":10,"text":"and as a ship that passeth over the waves of the water, which when it is gone by, the trace thereof cannot be found, neither the pathway of the keel in the waves:","searchKeywords":["and","ship","that","passeth","over","the","waves","water","which","when","gone","trace","thereof","cannot","found","neither","pathway","keel"]},{"verseId":"brenton_wisdom-of-solomon_5_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":11,"text":"or as when a bird hath flown through the air, there is no token of her way to be found, but the light air being beaten with the stroke of her wings, and parted with the violent noise and motion of them, is passed through, and therein afterwards no sign where she went is to be found;","searchKeywords":["when","bird","hath","flown","through","the","air","there","token","her","way","found","but","light","being","beaten","with","stroke","wings","and","parted","violent","noise","motion","them","passed","therein","afterwards","sign","where","she","went"]},{"verseId":"brenton_wisdom-of-solomon_5_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":12,"text":"or like as when an arrow is shot at a mark, it parteth the air, which immediately cometh together again, so that a man cannot know where it went through:","searchKeywords":["like","when","arrow","shot","mark","parteth","the","air","which","immediately","cometh","together","again","that","man","cannot","know","where","went","through"]},{"verseId":"brenton_wisdom-of-solomon_5_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":13,"text":"even so we in like manner, as soon as we were born, began to draw to our end, and had no sign of virtue to shew; but were consumed in our own wickedness.","searchKeywords":["even","like","manner","soon","were","born","began","draw","our","end","and","had","sign","virtue","shew","but","consumed","own","wickedness"]},{"verseId":"brenton_wisdom-of-solomon_5_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":14,"text":"For the hope of the ungodly is like dust that is blown away with the wind; like a thin froth that is driven away with the storm; like as the smoke which is dispersed here and there with a tempest, and passeth away as the remembrance of a guest that tarrieth but a day.","searchKeywords":["for","the","hope","ungodly","like","dust","that","blown","away","with","wind","thin","froth","driven","storm","smoke","which","dispersed","here","and","there","tempest","passeth","remembrance","guest","tarrieth","but","day"]},{"verseId":"brenton_wisdom-of-solomon_5_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":15,"text":"But the righteous live for evermore; their reward also is with the Lord, and the care of them is with the most High.","searchKeywords":["but","the","righteous","live","for","evermore","their","reward","also","with","lord","and","care","them","most","high"]},{"verseId":"brenton_wisdom-of-solomon_5_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":16,"text":"Therefore shall they receive a glorious kingdom, and a beautiful crown from the Lord's hand: for with his right hand shall he cover them, and with his arm shall he protect them.","searchKeywords":["therefore","shall","they","receive","glorious","kingdom","and","beautiful","crown","from","the","lord","hand","for","with","his","right","cover","them","arm","protect"]},{"verseId":"brenton_wisdom-of-solomon_5_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":17,"text":"He shall take to him his jealousy for complete armour, and make the creature his weapon for the revenge of enemies.","searchKeywords":["shall","take","him","his","jealousy","for","complete","armour","and","make","the","creature","weapon","revenge","enemies"]},{"verseId":"brenton_wisdom-of-solomon_5_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":18,"text":"He shall put on righteousness as a breastplate, and true judgment instead of an helmet.","searchKeywords":["shall","put","righteousness","breastplate","and","true","judgment","instead","helmet"]},{"verseId":"brenton_wisdom-of-solomon_5_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":19,"text":"He shall take holiness for an invincible shield.","searchKeywords":["shall","take","holiness","for","invincible","shield"]},{"verseId":"brenton_wisdom-of-solomon_5_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":20,"text":"His severe wrath shall he sharpen for a sword, and the world shall fight with him against the unwise.","searchKeywords":["his","severe","wrath","shall","sharpen","for","sword","and","the","world","fight","with","him","against","unwise"]},{"verseId":"brenton_wisdom-of-solomon_5_21","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":21,"text":"Then shall the right aiming thunderbolts go abroad; and from the clouds, as from a well drawn bow, shall they fly to the mark.","searchKeywords":["then","shall","the","right","aiming","thunderbolts","abroad","and","from","clouds","well","drawn","bow","they","fly","mark"]},{"verseId":"brenton_wisdom-of-solomon_5_22","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":22,"text":"And hailstones full of wrath shall be cast out of a stone bow, and the water of the sea shall rage against them, and the floods shall cruelly drown them.","searchKeywords":["and","hailstones","full","wrath","shall","cast","out","stone","bow","the","water","sea","rage","against","them","floods","cruelly","drown"]},{"verseId":"brenton_wisdom-of-solomon_5_23","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":5,"verse":23,"text":"Yea, a mighty wind shall stand up against them, and like a storm shall blow them away: thus iniquity shall lay waste the whole earth, and ill dealing shall overthrow the thrones of the mighty.","searchKeywords":["yea","mighty","wind","shall","stand","against","them","and","like","storm","blow","away","thus","iniquity","lay","waste","the","whole","earth","ill","dealing","overthrow","thrones"]}]