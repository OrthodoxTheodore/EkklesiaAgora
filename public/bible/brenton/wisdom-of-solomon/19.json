[{"verseId":"brenton_wisdom-of-solomon_19_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":1,"text":"As for the ungodly, wrath came upon them without mercy unto the end: for he knew before what they would do;","searchKeywords":["for","the","ungodly","wrath","came","upon","them","without","mercy","unto","end","knew","before","what","they","would"]},{"verseId":"brenton_wisdom-of-solomon_19_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":2,"text":"how that having given them leave to depart, and sent them hastily away, they would repent and pursue them.","searchKeywords":["how","that","having","given","them","leave","depart","and","sent","hastily","away","they","would","repent","pursue"]},{"verseId":"brenton_wisdom-of-solomon_19_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":3,"text":"For whilst they were yet mourning and making lamentation at the graves of the dead, they added another foolish device, and pursued them as fugitives, whom they had intreated to be gone.","searchKeywords":["for","whilst","they","were","yet","mourning","and","making","lamentation","the","graves","dead","added","another","foolish","device","pursued","them","fugitives","whom","had","intreated","gone"]},{"verseId":"brenton_wisdom-of-solomon_19_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":4,"text":"For the destiny, whereof they were worthy, drew them unto this end, and made them forget the things that had already happened, that they might fulfil the punishment which was wanting to their torments:","searchKeywords":["for","the","destiny","whereof","they","were","worthy","drew","them","unto","this","end","and","made","forget","things","that","had","already","happened","might","fulfil","punishment","which","was","wanting","their","torments"]},{"verseId":"brenton_wisdom-of-solomon_19_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":5,"text":"and that thy people might pass through a wonderful way: but they might find a strange death.","searchKeywords":["and","that","thy","people","might","pass","through","wonderful","way","but","they","find","strange","death"]},{"verseId":"brenton_wisdom-of-solomon_19_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":6,"text":"For the whole creature in his proper kind was fashioned again anew, serving the peculiar commandments that were given unto them, that thy children might be kept without hurt:","searchKeywords":["for","the","whole","creature","his","proper","kind","was","fashioned","again","anew","serving","peculiar","commandments","that","were","given","unto","them","thy","children","might","kept","without","hurt"]},{"verseId":"brenton_wisdom-of-solomon_19_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":7,"text":", a cloud shadowing the camp; and where water stood before, dry land appeared; and out of the Red sea a way without impediment; and out of the violent stream a green field:","searchKeywords":["cloud","shadowing","the","camp","and","where","water","stood","before","dry","land","appeared","out","red","sea","way","without","impediment","violent","stream","green","field"]},{"verseId":"brenton_wisdom-of-solomon_19_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":8,"text":"through which all the people went that were defended with thy hand, seeing thy marvellous strange wonders.","searchKeywords":["through","which","all","the","people","went","that","were","defended","with","thy","hand","seeing","marvellous","strange","wonders"]},{"verseId":"brenton_wisdom-of-solomon_19_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":9,"text":"For they went at large like horses, and leaped like lambs, praising thee, O Lord, who hadst delivered them.","searchKeywords":["for","they","went","large","like","horses","and","leaped","lambs","praising","thee","lord","who","hadst","delivered","them"]},{"verseId":"brenton_wisdom-of-solomon_19_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":10,"text":"For they were yet mindful of the things that were done while they sojourned in the strange land, how the ground brought forth flies instead of cattle, and how the river cast up a multitude of frogs instead of fishes.","searchKeywords":["for","they","were","yet","mindful","the","things","that","done","while","sojourned","strange","land","how","ground","brought","forth","flies","instead","cattle","and","river","cast","multitude","frogs","fishes"]},{"verseId":"brenton_wisdom-of-solomon_19_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":11,"text":"But afterward they saw a new generation of fowls, when, being led with their appetite, they asked delicate meats.","searchKeywords":["but","afterward","they","saw","new","generation","fowls","when","being","led","with","their","appetite","asked","delicate","meats"]},{"verseId":"brenton_wisdom-of-solomon_19_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":12,"text":"For quails came up unto them from the sea for their contentment.","searchKeywords":["for","quails","came","unto","them","from","the","sea","their","contentment"]},{"verseId":"brenton_wisdom-of-solomon_19_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":13,"text":"And punishments came upon the sinners not without former signs by the force of thunders: for they suffered justly according to their own wickedness, insomuch as they used a more hard and hateful behaviour toward strangers.","searchKeywords":["and","punishments","came","upon","the","sinners","not","without","former","signs","force","thunders","for","they","suffered","justly","according","their","own","wickedness","insomuch","used","more","hard","hateful","behaviour","toward","strangers"]},{"verseId":"brenton_wisdom-of-solomon_19_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":14,"text":"For the did not receive those, whom they knew not when they came: but these brought friends into bondage, that had well deserved of them.","searchKeywords":["for","the","did","not","receive","those","whom","they","knew","when","came","but","these","brought","friends","into","bondage","that","had","well","deserved","them"]},{"verseId":"brenton_wisdom-of-solomon_19_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":15,"text":"And not only so, but peradventure some respect shall be had of those, because they used strangers not friendly:","searchKeywords":["and","not","only","but","peradventure","some","respect","shall","had","those","because","they","used","strangers","friendly"]},{"verseId":"brenton_wisdom-of-solomon_19_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":16,"text":"but these very grievously afflicted them, whom they had received with feastings, and were already made partakers of the same laws with them.","searchKeywords":["but","these","very","grievously","afflicted","them","whom","they","had","received","with","feastings","and","were","already","made","partakers","the","same","laws"]},{"verseId":"brenton_wisdom-of-solomon_19_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":17,"text":"Therefore even with blindness were these stricken, as those were at the doors of the righteous man: when, being compassed about with horrible great darkness, every one sought the passage of his own doors.","searchKeywords":["therefore","even","with","blindness","were","these","stricken","those","the","doors","righteous","man","when","being","compassed","about","horrible","great","darkness","every","one","sought","passage","his","own"]},{"verseId":"brenton_wisdom-of-solomon_19_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":18,"text":"For the elements were changed in themselves by a kind of harmony, like as in a psaltery notes change the name of the tune, and yet are always sounds; which may well be perceived by the sight of the things that have been done.","searchKeywords":["for","the","elements","were","changed","themselves","kind","harmony","like","psaltery","notes","change","name","tune","and","yet","are","always","sounds","which","may","well","perceived","sight","things","that","have","been","done"]},{"verseId":"brenton_wisdom-of-solomon_19_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":19,"text":"For earthly things were turned into watery, and the things, that before swam in the water, now went upon the ground.","searchKeywords":["for","earthly","things","were","turned","into","watery","and","the","that","before","swam","water","now","went","upon","ground"]},{"verseId":"brenton_wisdom-of-solomon_19_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":20,"text":"The fire had power in the water, forgetting his own virtue: and the water forgat his own quenching nature.","searchKeywords":["the","fire","had","power","water","forgetting","his","own","virtue","and","forgat","quenching","nature"]},{"verseId":"brenton_wisdom-of-solomon_19_21","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":21,"text":"On the other side, the flames wasted not the flesh of the corruptible living things, though they walked therein; neither melted they the icy kind of heavenly meat, that was of nature apt to melt.","searchKeywords":["the","other","side","flames","wasted","not","flesh","corruptible","living","things","though","they","walked","therein","neither","melted","icy","kind","heavenly","meat","that","was","nature","apt","melt"]},{"verseId":"brenton_wisdom-of-solomon_19_22","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":19,"verse":22,"text":"For in all things, O Lord, thou didst magnify thy people, and glorify them, neither didst thou lightly regard them: but didst assist them in every time and place.","searchKeywords":["for","all","things","lord","thou","didst","magnify","thy","people","and","glorify","them","neither","lightly","regard","but","assist","every","time","place"]}]