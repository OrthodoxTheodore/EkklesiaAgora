[{"verseId":"brenton_wisdom-of-solomon_7_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":1,"text":"I myself also am a mortal man, like to all, and the offspring of him that was first made of the earth,","searchKeywords":["myself","also","mortal","man","like","all","and","the","offspring","him","that","was","first","made","earth"]},{"verseId":"brenton_wisdom-of-solomon_7_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":2,"text":"and in my mother's womb was fashioned to be flesh in the time of ten months, being compacted in blood, of the seed of man, and the pleasure that came with sleep.","searchKeywords":["and","mother","womb","was","fashioned","flesh","the","time","ten","months","being","compacted","blood","seed","man","pleasure","that","came","with","sleep"]},{"verseId":"brenton_wisdom-of-solomon_7_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":3,"text":"And when I was born, I drew in the common air, and fell upon the earth, which is of like nature, and the first voice which I uttered was crying, as all others do.","searchKeywords":["and","when","was","born","drew","the","common","air","fell","upon","earth","which","like","nature","first","voice","uttered","crying","all","others"]},{"verseId":"brenton_wisdom-of-solomon_7_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":4,"text":"I was nursed in swaddling clothes, and that with cares.","searchKeywords":["was","nursed","swaddling","clothes","and","that","with","cares"]},{"verseId":"brenton_wisdom-of-solomon_7_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":5,"text":"For there is no king that had any other beginning of birth.","searchKeywords":["for","there","king","that","had","any","other","beginning","birth"]},{"verseId":"brenton_wisdom-of-solomon_7_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":6,"text":"For all men have one entrance into life, and the like going out.","searchKeywords":["for","all","men","have","one","entrance","into","life","and","the","like","going","out"]},{"verseId":"brenton_wisdom-of-solomon_7_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":7,"text":"Wherefore I prayed, and understanding was given me: I called , and the spirit of wisdom came to me.","searchKeywords":["wherefore","prayed","and","understanding","was","given","called","the","spirit","wisdom","came"]},{"verseId":"brenton_wisdom-of-solomon_7_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":8,"text":"I preferred her before sceptres and thrones, and esteemed riches nothing in comparison of her.","searchKeywords":["preferred","her","before","sceptres","and","thrones","esteemed","riches","nothing","comparison"]},{"verseId":"brenton_wisdom-of-solomon_7_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":9,"text":"Neither compared I unto her any precious stone, because all gold in respect of her is as a little sand, and silver shall be counted as clay before her.","searchKeywords":["neither","compared","unto","her","any","precious","stone","because","all","gold","respect","little","sand","and","silver","shall","counted","clay","before"]},{"verseId":"brenton_wisdom-of-solomon_7_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":10,"text":"I loved her above health and beauty, and chose to have her instead of light: for the light that cometh from her never goeth out.","searchKeywords":["loved","her","above","health","and","beauty","chose","have","instead","light","for","the","that","cometh","from","never","goeth","out"]},{"verseId":"brenton_wisdom-of-solomon_7_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":11,"text":"All good things together came to me with her, and innumerable riches in her hands.","searchKeywords":["all","good","things","together","came","with","her","and","innumerable","riches","hands"]},{"verseId":"brenton_wisdom-of-solomon_7_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":12,"text":"And I rejoiced in all, because wisdom goeth before them: and I knew not that she was the mother of them.","searchKeywords":["and","rejoiced","all","because","wisdom","goeth","before","them","knew","not","that","she","was","the","mother"]},{"verseId":"brenton_wisdom-of-solomon_7_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":13,"text":"I learned diligently, and do communicate liberally: I do not hide her riches.","searchKeywords":["learned","diligently","and","communicate","liberally","not","hide","her","riches"]},{"verseId":"brenton_wisdom-of-solomon_7_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":14,"text":"For she is a treasure unto men that never faileth: which they that use become the friends of God, being commended for the gifts that come from learning.","searchKeywords":["for","she","treasure","unto","men","that","never","faileth","which","they","use","become","the","friends","god","being","commended","gifts","come","from","learning"]},{"verseId":"brenton_wisdom-of-solomon_7_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":15,"text":"God hath granted me to speak as I would, and to conceive as is meet for the things that are given me: because it is he that leadeth unto wisdom, and directeth the wise.","searchKeywords":["god","hath","granted","speak","would","and","conceive","meet","for","the","things","that","are","given","because","leadeth","unto","wisdom","directeth","wise"]},{"verseId":"brenton_wisdom-of-solomon_7_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":16,"text":"For in his hand are both we and our words; all wisdom also, and knowledge of workmanship.","searchKeywords":["for","his","hand","are","both","and","our","words","all","wisdom","also","knowledge","workmanship"]},{"verseId":"brenton_wisdom-of-solomon_7_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":17,"text":"For he hath given me certain knowledge of the things that are, namely, to know how the world was made, and the operation of the elements:","searchKeywords":["for","hath","given","certain","knowledge","the","things","that","are","namely","know","how","world","was","made","and","operation","elements"]},{"verseId":"brenton_wisdom-of-solomon_7_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":18,"text":"the beginning, ending, and midst of the times: the alterations of the turning , and change of seasons:","searchKeywords":["the","beginning","ending","and","midst","times","alterations","turning","change","seasons"]},{"verseId":"brenton_wisdom-of-solomon_7_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":19,"text":"the circuits of years, and positions of stars:","searchKeywords":["the","circuits","years","and","positions","stars"]},{"verseId":"brenton_wisdom-of-solomon_7_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":20,"text":"the natures of living creatures, and the furies of wild beasts: the violence of winds, and the reasonings of men: the diversities of plants, and the virtues of roots:","searchKeywords":["the","natures","living","creatures","and","furies","wild","beasts","violence","winds","reasonings","men","diversities","plants","virtues","roots"]},{"verseId":"brenton_wisdom-of-solomon_7_21","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":21,"text":"and all such things as are either secret or manifest, I know.","searchKeywords":["and","all","such","things","are","either","secret","manifest","know"]},{"verseId":"brenton_wisdom-of-solomon_7_22","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":22,"text":"For wisdom, which is the worker of all things, taught me: for in her is an understanding spirit, holy, one only, manifold, subtil, lively, clear, undefiled, plain, not subject to hurt, loving the thing that is good, quick, which cannot be letted, ready to do good,","searchKeywords":["for","wisdom","which","the","worker","all","things","taught","her","understanding","spirit","holy","one","only","manifold","subtil","lively","clear","undefiled","plain","not","subject","hurt","loving","thing","that","good","quick","cannot","letted","ready"]},{"verseId":"brenton_wisdom-of-solomon_7_23","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":23,"text":"kind to man, stedfast, sure, free from care, having all power, overseeing all things, and going through all understanding, pure, and most subtil, spirits.","searchKeywords":["kind","man","stedfast","sure","free","from","care","having","all","power","overseeing","things","and","going","through","understanding","pure","most","subtil","spirits"]},{"verseId":"brenton_wisdom-of-solomon_7_24","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":24,"text":"For wisdom is more moving than any motion: she passeth and goeth through all things by reason of her pureness.","searchKeywords":["for","wisdom","more","moving","than","any","motion","she","passeth","and","goeth","through","all","things","reason","her","pureness"]},{"verseId":"brenton_wisdom-of-solomon_7_25","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":25,"text":"For she is the breath of the power of God, and a pure influence flowing from the glory of the Almighty: therefore can no defiled thing fall into her.","searchKeywords":["for","she","the","breath","power","god","and","pure","influence","flowing","from","glory","almighty","therefore","can","defiled","thing","fall","into","her"]},{"verseId":"brenton_wisdom-of-solomon_7_26","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":26,"text":"For she is the brightness of the everlasting light, the unspotted mirror of the power of God, and the image of his goodness.","searchKeywords":["for","she","the","brightness","everlasting","light","unspotted","mirror","power","god","and","image","his","goodness"]},{"verseId":"brenton_wisdom-of-solomon_7_27","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":27,"text":"And being but one, she can do all things: and remaining in herself, she maketh all things new: and in all ages entering into holy souls, she maketh them friends of God, and prophets.","searchKeywords":["and","being","but","one","she","can","all","things","remaining","herself","maketh","new","ages","entering","into","holy","souls","them","friends","god","prophets"]},{"verseId":"brenton_wisdom-of-solomon_7_28","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":28,"text":"For God loveth none but him that dwelleth with wisdom.","searchKeywords":["for","god","loveth","none","but","him","that","dwelleth","with","wisdom"]},{"verseId":"brenton_wisdom-of-solomon_7_29","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":29,"text":"For she is more beautiful than the sun, and above all the order of stars: being compared with the light, she is found before it.","searchKeywords":["for","she","more","beautiful","than","the","sun","and","above","all","order","stars","being","compared","with","light","found","before"]},{"verseId":"brenton_wisdom-of-solomon_7_30","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":7,"verse":30,"text":"For after this cometh night: but vice shall not prevail against wisdom.","searchKeywords":["for","after","this","cometh","night","but","vice","shall","not","prevail","against","wisdom"]}]