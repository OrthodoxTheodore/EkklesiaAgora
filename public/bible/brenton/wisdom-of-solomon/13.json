[{"verseId":"brenton_wisdom-of-solomon_13_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":1,"text":"Surely vain are all men by nature, who are ignorant of God, and could not out of the good things that are seen know him that is: neither by considering the works did they acknowledge the workmaster;","searchKeywords":["surely","vain","are","all","men","nature","who","ignorant","god","and","could","not","out","the","good","things","that","seen","know","him","neither","considering","works","did","they","acknowledge","workmaster"]},{"verseId":"brenton_wisdom-of-solomon_13_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":2,"text":"but deemed either fire, or wind, or the swift air, or the circle of the stars, or the violent water, or the lights of heaven, to be the gods which govern the world.","searchKeywords":["but","deemed","either","fire","wind","the","swift","air","circle","stars","violent","water","lights","heaven","gods","which","govern","world"]},{"verseId":"brenton_wisdom-of-solomon_13_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":3,"text":"With whose beauty if they being delighted took them to be gods; let them know how much better the Lord of them is: for the first author of beauty hath created them.","searchKeywords":["with","whose","beauty","they","being","delighted","took","them","gods","let","know","how","much","better","the","lord","for","first","author","hath","created"]},{"verseId":"brenton_wisdom-of-solomon_13_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":4,"text":"But if they were astonished at their power and virtue, let them understand by them, how much mightier he is that made them.","searchKeywords":["but","they","were","astonished","their","power","and","virtue","let","them","understand","how","much","mightier","that","made"]},{"verseId":"brenton_wisdom-of-solomon_13_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":5,"text":"For by the greatness and beauty of the creatures proportionably the maker of them is seen.","searchKeywords":["for","the","greatness","and","beauty","creatures","proportionably","maker","them","seen"]},{"verseId":"brenton_wisdom-of-solomon_13_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":6,"text":"But yet for this they are the less to be blamed: for they peradventure err, seeking God, and desirous to find him.","searchKeywords":["but","yet","for","this","they","are","the","less","blamed","peradventure","err","seeking","god","and","desirous","find","him"]},{"verseId":"brenton_wisdom-of-solomon_13_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":7,"text":"For being conversant in his works they search diligently, and believe their sight: because the things are beautiful that are seen.","searchKeywords":["for","being","conversant","his","works","they","search","diligently","and","believe","their","sight","because","the","things","are","beautiful","that","seen"]},{"verseId":"brenton_wisdom-of-solomon_13_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":8,"text":"Howbeit neither are they to be pardoned.","searchKeywords":["howbeit","neither","are","they","pardoned"]},{"verseId":"brenton_wisdom-of-solomon_13_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":9,"text":"For if they were able to know so much, that they could aim at the world; how did they not sooner find out the Lord thereof?","searchKeywords":["for","they","were","able","know","much","that","could","aim","the","world","how","did","not","sooner","find","out","lord","thereof"]},{"verseId":"brenton_wisdom-of-solomon_13_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":10,"text":"But miserable are they, and in dead things is their hope, who called them gods, which are the works of men's hands, gold and silver, to shew art in, and resemblances of beasts, or a stone good for nothing, the work of an ancient hand.","searchKeywords":["but","miserable","are","they","and","dead","things","their","hope","who","called","them","gods","which","the","works","men","hands","gold","silver","shew","art","resemblances","beasts","stone","good","for","nothing","work","ancient","hand"]},{"verseId":"brenton_wisdom-of-solomon_13_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":11,"text":"Now a carpenter that felleth timber, after he hath sawn down a tree meet for the purpose, and taken off all the bark skilfully round about, and hath wrought it handsomely, and made a vessel thereof fit for the service of man's life;","searchKeywords":["now","carpenter","that","felleth","timber","after","hath","sawn","down","tree","meet","for","the","purpose","and","taken","off","all","bark","skilfully","round","about","wrought","handsomely","made","vessel","thereof","fit","service","man","life"]},{"verseId":"brenton_wisdom-of-solomon_13_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":12,"text":"and after spending the refuse of his work to dress his meat, hath filled himself;","searchKeywords":["and","after","spending","the","refuse","his","work","dress","meat","hath","filled","himself"]},{"verseId":"brenton_wisdom-of-solomon_13_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":13,"text":"and taking the very refuse among those which served to no use, being a crooked piece of wood, and full of knots, hath carved it diligently when he had nothing else to do, and formed it by the skill of his understanding, and fashioned it to the image of a man;","searchKeywords":["and","taking","the","very","refuse","among","those","which","served","use","being","crooked","piece","wood","full","knots","hath","carved","diligently","when","had","nothing","else","formed","skill","his","understanding","fashioned","image","man"]},{"verseId":"brenton_wisdom-of-solomon_13_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":14,"text":"or made it like some vile beast, laying it over with vermilion, and with paint colouring it red, and colouring every spot therein;","searchKeywords":["made","like","some","vile","beast","laying","over","with","vermilion","and","paint","colouring","red","every","spot","therein"]},{"verseId":"brenton_wisdom-of-solomon_13_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":15,"text":"and when he had made a convenient room for it, set it in a wall, and made it fast with iron:","searchKeywords":["and","when","had","made","convenient","room","for","set","wall","fast","with","iron"]},{"verseId":"brenton_wisdom-of-solomon_13_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":16,"text":"for he provided for it that it might not fall, knowing that it was unable to help itself; for it is an image, and hath need of help.","searchKeywords":["for","provided","that","might","not","fall","knowing","was","unable","help","itself","image","and","hath","need"]},{"verseId":"brenton_wisdom-of-solomon_13_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":17,"text":"Then maketh he prayer for his goods, for his wife and children, and is not ashamed to speak to that which hath no life.","searchKeywords":["then","maketh","prayer","for","his","goods","wife","and","children","not","ashamed","speak","that","which","hath","life"]},{"verseId":"brenton_wisdom-of-solomon_13_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":18,"text":"For health he calleth upon that which is weak: for life prayeth to that which is dead: for aid humbly beseecheth that which hath least means to help: and for a good journey he asketh of that which cannot set a foot forward:","searchKeywords":["for","health","calleth","upon","that","which","weak","life","prayeth","dead","aid","humbly","beseecheth","hath","least","means","help","and","good","journey","asketh","cannot","set","foot","forward"]},{"verseId":"brenton_wisdom-of-solomon_13_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":13,"verse":19,"text":"and for gaining and getting, and for good success of his hands, asketh ability to do of him, that is most unable to do any thing.","searchKeywords":["and","for","gaining","getting","good","success","his","hands","asketh","ability","him","that","most","unable","any","thing"]}]