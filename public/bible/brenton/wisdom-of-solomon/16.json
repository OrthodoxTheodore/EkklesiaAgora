[{"verseId":"brenton_wisdom-of-solomon_16_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":1,"text":"Therefore by the like were they punished worthily, and by the multitude of beasts tormented.","searchKeywords":["therefore","the","like","were","they","punished","worthily","and","multitude","beasts","tormented"]},{"verseId":"brenton_wisdom-of-solomon_16_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":2,"text":"Instead of which punishment, dealing graciously with thine own people, thou preparedst for them meat of a strange taste, even quails to stir up their appetite:","searchKeywords":["instead","which","punishment","dealing","graciously","with","thine","own","people","thou","preparedst","for","them","meat","strange","taste","even","quails","stir","their","appetite"]},{"verseId":"brenton_wisdom-of-solomon_16_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":3,"text":"to the end that they, desiring food, might for the ugly sight of the beasts sent among them lothe even that, which they must needs desire; but these, suffering penury for a short space, might be made partakers of a strange taste.","searchKeywords":["the","end","that","they","desiring","food","might","for","ugly","sight","beasts","sent","among","them","lothe","even","which","must","needs","desire","but","these","suffering","penury","short","space","made","partakers","strange","taste"]},{"verseId":"brenton_wisdom-of-solomon_16_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":4,"text":"For it was requisite, that upon them exercising tyranny should come penury, which they could not avoid: but to these it should only be shewed how their enemies were tormented.","searchKeywords":["for","was","requisite","that","upon","them","exercising","tyranny","should","come","penury","which","they","could","not","avoid","but","these","only","shewed","how","their","enemies","were","tormented"]},{"verseId":"brenton_wisdom-of-solomon_16_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":5,"text":"For when the horrible fierceness of beasts came upon these, and they perished with the stings of crooked serpents, thy wrath endured not for ever:","searchKeywords":["for","when","the","horrible","fierceness","beasts","came","upon","these","and","they","perished","with","stings","crooked","serpents","thy","wrath","endured","not","ever"]},{"verseId":"brenton_wisdom-of-solomon_16_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":6,"text":"But they were troubled for a small season, that they might be admonished, having a sign of salvation, to put them in remembrance of the commandment of thy law.","searchKeywords":["but","they","were","troubled","for","small","season","that","might","admonished","having","sign","salvation","put","them","remembrance","the","commandment","thy","law"]},{"verseId":"brenton_wisdom-of-solomon_16_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":7,"text":"For he that turned himself toward it was not saved by the thing that he saw, but by thee, that art the Saviour of all.","searchKeywords":["for","that","turned","himself","toward","was","not","saved","the","thing","saw","but","thee","art","saviour","all"]},{"verseId":"brenton_wisdom-of-solomon_16_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":8,"text":"And in this thou madest thine enemies confess, that it is thou who deliverest from all evil:","searchKeywords":["and","this","thou","madest","thine","enemies","confess","that","who","deliverest","from","all","evil"]},{"verseId":"brenton_wisdom-of-solomon_16_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":9,"text":"for them the bitings of grasshoppers and flies killed, neither was there found any remedy for their life: for they were worthy to be punished by such.","searchKeywords":["for","them","the","bitings","grasshoppers","and","flies","killed","neither","was","there","found","any","remedy","their","life","they","were","worthy","punished","such"]},{"verseId":"brenton_wisdom-of-solomon_16_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":10,"text":"But thy sons not the very teeth of venomous dragons overcame: for thy mercy was by them, and healed them.","searchKeywords":["but","thy","sons","not","the","very","teeth","venomous","dragons","overcame","for","mercy","was","them","and","healed"]},{"verseId":"brenton_wisdom-of-solomon_16_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":11,"text":"For they were pricked, that they should remember thy words; and were quickly saved, that not falling into deep forgetfulness, they might be continually mindful of thy goodness.","searchKeywords":["for","they","were","pricked","that","should","remember","thy","words","and","quickly","saved","not","falling","into","deep","forgetfulness","might","continually","mindful","goodness"]},{"verseId":"brenton_wisdom-of-solomon_16_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":12,"text":"For it was neither herb, nor mollifying plaister, that restored them to health: but thy word, O Lord, which healeth all things.","searchKeywords":["for","was","neither","herb","nor","mollifying","plaister","that","restored","them","health","but","thy","word","lord","which","healeth","all","things"]},{"verseId":"brenton_wisdom-of-solomon_16_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":13,"text":"For thou hast power of life and death: thou leadest to the gates of hell, and bringest up again.","searchKeywords":["for","thou","hast","power","life","and","death","leadest","the","gates","hell","bringest","again"]},{"verseId":"brenton_wisdom-of-solomon_16_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":14,"text":"A man indeed killeth through his malice: and the spirit, when it is gone forth, returneth not; neither the soul received up cometh again.","searchKeywords":["man","indeed","killeth","through","his","malice","and","the","spirit","when","gone","forth","returneth","not","neither","soul","received","cometh","again"]},{"verseId":"brenton_wisdom-of-solomon_16_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":15,"text":"But it is not possible to escape thine hand.","searchKeywords":["but","not","possible","escape","thine","hand"]},{"verseId":"brenton_wisdom-of-solomon_16_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":16,"text":"For the ungodly, that denied to know thee, were scourged by the strength of thine arm: with strange rains, hails, and showers, were they persecuted, that they could not avoid, and through fire were they consumed.","searchKeywords":["for","the","ungodly","that","denied","know","thee","were","scourged","strength","thine","arm","with","strange","rains","hails","and","showers","they","persecuted","could","not","avoid","through","fire","consumed"]},{"verseId":"brenton_wisdom-of-solomon_16_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":17,"text":"For, which is most to be wondered at, the fire had more force in the water, that quencheth all things: for the world fighteth for the righteous.","searchKeywords":["for","which","most","wondered","the","fire","had","more","force","water","that","quencheth","all","things","world","fighteth","righteous"]},{"verseId":"brenton_wisdom-of-solomon_16_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":18,"text":"For sometime the flame was mitigated, that it might not burn up the beasts that were sent against the ungodly; but themselves might see and perceive that they were persecuted with the judgment of God.","searchKeywords":["for","sometime","the","flame","was","mitigated","that","might","not","burn","beasts","were","sent","against","ungodly","but","themselves","see","and","perceive","they","persecuted","with","judgment","god"]},{"verseId":"brenton_wisdom-of-solomon_16_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":19,"text":"And at another time it burneth even in the midst of water above the power of fire, that it might destroy the fruits of an unjust land.","searchKeywords":["and","another","time","burneth","even","the","midst","water","above","power","fire","that","might","destroy","fruits","unjust","land"]},{"verseId":"brenton_wisdom-of-solomon_16_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":20,"text":"Instead whereof thou feddest thine own people with angels' food, and didst send them from heaven bread prepared without their labour, able to content every man's delight, and agreeing to every taste.","searchKeywords":["instead","whereof","thou","feddest","thine","own","people","with","angels","food","and","didst","send","them","from","heaven","bread","prepared","without","their","labour","able","content","every","man","delight","agreeing","taste"]},{"verseId":"brenton_wisdom-of-solomon_16_21","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":21,"text":"For thy sustenance declared thy sweetness unto thy children, and serving to the appetite of the eater, tempered itself to every man's liking.","searchKeywords":["for","thy","sustenance","declared","sweetness","unto","children","and","serving","the","appetite","eater","tempered","itself","every","man","liking"]},{"verseId":"brenton_wisdom-of-solomon_16_22","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":22,"text":"But snow and ice endured the fire, and melted not, that they might know that fire burning in the hail, and sparkling in the rain, did destroy the fruits of the enemies.","searchKeywords":["but","snow","and","ice","endured","the","fire","melted","not","that","they","might","know","burning","hail","sparkling","rain","did","destroy","fruits","enemies"]},{"verseId":"brenton_wisdom-of-solomon_16_23","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":23,"text":"But this again did even forget his own strength, that the righteous might be nourished.","searchKeywords":["but","this","again","did","even","forget","his","own","strength","that","the","righteous","might","nourished"]},{"verseId":"brenton_wisdom-of-solomon_16_24","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":24,"text":"For the creature that serveth thee, who art the Maker, increaseth his strength against the unrighteous for their punishment, and abateth his strength for the benefit of such as put their trust in thee.","searchKeywords":["for","the","creature","that","serveth","thee","who","art","maker","increaseth","his","strength","against","unrighteous","their","punishment","and","abateth","benefit","such","put","trust"]},{"verseId":"brenton_wisdom-of-solomon_16_25","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":25,"text":"Therefore even then was it altered into all fashions, and was obedient to thy grace, that nourisheth all things, according to the desire of them that had need:","searchKeywords":["therefore","even","then","was","altered","into","all","fashions","and","obedient","thy","grace","that","nourisheth","things","according","the","desire","them","had","need"]},{"verseId":"brenton_wisdom-of-solomon_16_26","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":26,"text":"that thy children, O Lord, whom thou lovest, might know, that it is not the growing of fruits that nourisheth man: but that it is thy word, which preserveth them that put their trust in thee.","searchKeywords":["that","thy","children","lord","whom","thou","lovest","might","know","not","the","growing","fruits","nourisheth","man","but","word","which","preserveth","them","put","their","trust","thee"]},{"verseId":"brenton_wisdom-of-solomon_16_27","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":27,"text":"For that which was not destroyed of the fire, being warmed with a little sunbeam, soon melted away:","searchKeywords":["for","that","which","was","not","destroyed","the","fire","being","warmed","with","little","sunbeam","soon","melted","away"]},{"verseId":"brenton_wisdom-of-solomon_16_28","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":28,"text":"that it might be known, that we must prevent the sun to give thee thanks, and at the dayspring pray unto thee.","searchKeywords":["that","might","known","must","prevent","the","sun","give","thee","thanks","and","dayspring","pray","unto"]},{"verseId":"brenton_wisdom-of-solomon_16_29","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":16,"verse":29,"text":"For the hope of the unthankful shall melt away as the winter's hoar frost, and shall run away as unprofitable water.","searchKeywords":["for","the","hope","unthankful","shall","melt","away","winter","hoar","frost","and","run","unprofitable","water"]}]