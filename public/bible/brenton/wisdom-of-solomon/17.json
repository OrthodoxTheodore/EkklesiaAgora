[{"verseId":"brenton_wisdom-of-solomon_17_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":1,"text":"For great are thy judgments, and cannot be expressed: therefore unnurtured souls have erred.","searchKeywords":["for","great","are","thy","judgments","and","cannot","expressed","therefore","unnurtured","souls","have","erred"]},{"verseId":"brenton_wisdom-of-solomon_17_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":2,"text":"For when unrighteous men thought to oppress the holy nation; they being shut up in their houses, the prisoners of darkness, and fettered with the bonds of a long night, lay [there] exiled from the eternal providence.","searchKeywords":["for","when","unrighteous","men","thought","oppress","the","holy","nation","they","being","shut","their","houses","prisoners","darkness","and","fettered","with","bonds","long","night","lay","there","exiled","from","eternal","providence"]},{"verseId":"brenton_wisdom-of-solomon_17_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":3,"text":"For while they supposed to lie hid in their secret sins, they were scattered under a dark veil of forgetfulness, being horribly astonished, and troubled with [strange] apparitions.","searchKeywords":["for","while","they","supposed","lie","hid","their","secret","sins","were","scattered","under","dark","veil","forgetfulness","being","horribly","astonished","and","troubled","with","strange","apparitions"]},{"verseId":"brenton_wisdom-of-solomon_17_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":4,"text":"For neither might the corner that held them keep them from fear: but noises [as of waters] falling down sounded about them, and sad visions appeared unto them with heavy countenances.","searchKeywords":["for","neither","might","the","corner","that","held","them","keep","from","fear","but","noises","waters","falling","down","sounded","about","and","sad","visions","appeared","unto","with","heavy","countenances"]},{"verseId":"brenton_wisdom-of-solomon_17_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":5,"text":"No power of the fire might give them light: neither could the bright flames of the stars endure to lighten that horrible night.","searchKeywords":["power","the","fire","might","give","them","light","neither","could","bright","flames","stars","endure","lighten","that","horrible","night"]},{"verseId":"brenton_wisdom-of-solomon_17_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":6,"text":"Only there appeared unto them a fire kindled of itself, very dreadful: for being much terrified, they thought the things which they saw to be worse than the sight they saw not.","searchKeywords":["only","there","appeared","unto","them","fire","kindled","itself","very","dreadful","for","being","much","terrified","they","thought","the","things","which","saw","worse","than","sight","not"]},{"verseId":"brenton_wisdom-of-solomon_17_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":7,"text":"As for the illusions of art magic, they were put down, and their vaunting in wisdom was reproved with disgrace.","searchKeywords":["for","the","illusions","art","magic","they","were","put","down","and","their","vaunting","wisdom","was","reproved","with","disgrace"]},{"verseId":"brenton_wisdom-of-solomon_17_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":8,"text":"For they, that promised to drive away terrors and troubles from a sick soul, were sick themselves of fear, worthy to be laughed at.","searchKeywords":["for","they","that","promised","drive","away","terrors","and","troubles","from","sick","soul","were","themselves","fear","worthy","laughed"]},{"verseId":"brenton_wisdom-of-solomon_17_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":9,"text":"For though no terrible thing did fear them; yet being scared with beasts that passed by, and hissing of serpents,","searchKeywords":["for","though","terrible","thing","did","fear","them","yet","being","scared","with","beasts","that","passed","and","hissing","serpents"]},{"verseId":"brenton_wisdom-of-solomon_17_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":10,"text":"they died for fear, denying that they saw the air, which could of no side be avoided.","searchKeywords":["they","died","for","fear","denying","that","saw","the","air","which","could","side","avoided"]},{"verseId":"brenton_wisdom-of-solomon_17_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":11,"text":"For wickedness, condemned by her own witness, is very timorous, and being pressed with conscience, always forecasteth grievous things.","searchKeywords":["for","wickedness","condemned","her","own","witness","very","timorous","and","being","pressed","with","conscience","always","forecasteth","grievous","things"]},{"verseId":"brenton_wisdom-of-solomon_17_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":12,"text":"For fear is nothing else but a betraying of the succours which reason offereth.","searchKeywords":["for","fear","nothing","else","but","betraying","the","succours","which","reason","offereth"]},{"verseId":"brenton_wisdom-of-solomon_17_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":13,"text":"And the expectation from within, being less, counteth the ignorance more than the cause which bringeth the torment.","searchKeywords":["and","the","expectation","from","within","being","less","counteth","ignorance","more","than","cause","which","bringeth","torment"]},{"verseId":"brenton_wisdom-of-solomon_17_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":14,"text":"But they sleeping the same sleep that night, which was indeed intolerable, and which came upon them out of the bottoms of inevitable hell,","searchKeywords":["but","they","sleeping","the","same","sleep","that","night","which","was","indeed","intolerable","and","came","upon","them","out","bottoms","inevitable","hell"]},{"verseId":"brenton_wisdom-of-solomon_17_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":15,"text":"were partly vexed with monstrous apparitions, and partly fainted, their heart failing them: for a sudden fear, and not looked for, came upon them.","searchKeywords":["were","partly","vexed","with","monstrous","apparitions","and","fainted","their","heart","failing","them","for","sudden","fear","not","looked","came","upon"]},{"verseId":"brenton_wisdom-of-solomon_17_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":16,"text":"So then whosoever there fell down was straitly kept, shut up in a prison without iron bars.","searchKeywords":["then","whosoever","there","fell","down","was","straitly","kept","shut","prison","without","iron","bars"]},{"verseId":"brenton_wisdom-of-solomon_17_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":17,"text":"For whether he were husbandman, or shepherd, or a labourer in the field, he was overtaken, and endured that necessity, which could not be avoided: for they were all bound with one chain of darkness.","searchKeywords":["for","whether","were","husbandman","shepherd","labourer","the","field","was","overtaken","and","endured","that","necessity","which","could","not","avoided","they","all","bound","with","one","chain","darkness"]},{"verseId":"brenton_wisdom-of-solomon_17_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":18,"text":"Whether it were a whistling wind, or a melodious noise of birds among the spreading branches, or a pleasing fall of water running violently,","searchKeywords":["whether","were","whistling","wind","melodious","noise","birds","among","the","spreading","branches","pleasing","fall","water","running","violently"]},{"verseId":"brenton_wisdom-of-solomon_17_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":19,"text":"or a terrible sound of stones cast down, or a running that could not be seen of skipping beasts, or a roaring voice of most savage wild beasts, or a rebounding echo from the hollow mountains: these things made them to swoon for fear.","searchKeywords":["terrible","sound","stones","cast","down","running","that","could","not","seen","skipping","beasts","roaring","voice","most","savage","wild","rebounding","echo","from","the","hollow","mountains","these","things","made","them","swoon","for","fear"]},{"verseId":"brenton_wisdom-of-solomon_17_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":20,"text":"For the whole world shined with clear light, and none were hindered in their labour:","searchKeywords":["for","the","whole","world","shined","with","clear","light","and","none","were","hindered","their","labour"]},{"verseId":"brenton_wisdom-of-solomon_17_21","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":17,"verse":21,"text":"over them only was spread a heavy night, an image of that darkness which should afterward receive them: but yet were they unto themselves more grievous than the darkness.","searchKeywords":["over","them","only","was","spread","heavy","night","image","that","darkness","which","should","afterward","receive","but","yet","were","they","unto","themselves","more","grievous","than","the"]}]