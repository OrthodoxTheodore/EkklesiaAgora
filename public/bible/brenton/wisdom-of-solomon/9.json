[{"verseId":"brenton_wisdom-of-solomon_9_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":1,"text":"O God of my fathers, and Lord of mercy, who hast made all things with thy word,","searchKeywords":["god","fathers","and","lord","mercy","who","hast","made","all","things","with","thy","word"]},{"verseId":"brenton_wisdom-of-solomon_9_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":2,"text":"and ordained man through thy wisdom, that he should have dominion over the creatures which thou hast made,","searchKeywords":["and","ordained","man","through","thy","wisdom","that","should","have","dominion","over","the","creatures","which","thou","hast","made"]},{"verseId":"brenton_wisdom-of-solomon_9_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":3,"text":"and order the world according to equity and righteousness, and execute judgment with an upright heart:","searchKeywords":["and","order","the","world","according","equity","righteousness","execute","judgment","with","upright","heart"]},{"verseId":"brenton_wisdom-of-solomon_9_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":4,"text":"give me wisdom, that sitteth by thy throne; and reject me not from among thy children:","searchKeywords":["give","wisdom","that","sitteth","thy","throne","and","reject","not","from","among","children"]},{"verseId":"brenton_wisdom-of-solomon_9_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":5,"text":"for I thy servant and son of thine handmaid am a feeble person, and of a short time, and too young for the understanding of judgment and laws.","searchKeywords":["for","thy","servant","and","son","thine","handmaid","feeble","person","short","time","too","young","the","understanding","judgment","laws"]},{"verseId":"brenton_wisdom-of-solomon_9_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":6,"text":"For though a man be never so perfect among the children of men, yet if thy wisdom be not with him, he shall be nothing regarded.","searchKeywords":["for","though","man","never","perfect","among","the","children","men","yet","thy","wisdom","not","with","him","shall","nothing","regarded"]},{"verseId":"brenton_wisdom-of-solomon_9_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":7,"text":"Thou hast chosen me to be a king of thy people, and a judge of thy sons and daughters:","searchKeywords":["thou","hast","chosen","king","thy","people","and","judge","sons","daughters"]},{"verseId":"brenton_wisdom-of-solomon_9_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":8,"text":"thou hast commanded me to build a temple upon thy holy mount, and an altar in the city wherein thou dwellest, a resemblance of the holy tabernacle, which thou hast prepared from the beginning.","searchKeywords":["thou","hast","commanded","build","temple","upon","thy","holy","mount","and","altar","the","city","wherein","dwellest","resemblance","tabernacle","which","prepared","from","beginning"]},{"verseId":"brenton_wisdom-of-solomon_9_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":9,"text":"And wisdom was with thee: which knoweth thy works, and was present when thou madest the world, and knew what was acceptable in thy sight, and right in thy commandments.","searchKeywords":["and","wisdom","was","with","thee","which","knoweth","thy","works","present","when","thou","madest","the","world","knew","what","acceptable","sight","right","commandments"]},{"verseId":"brenton_wisdom-of-solomon_9_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":10,"text":"O send her out of thy holy heavens, and from the throne of thy glory, that being present she may labour with me, that I may know what is pleasing unto thee.","searchKeywords":["send","her","out","thy","holy","heavens","and","from","the","throne","glory","that","being","present","she","may","labour","with","know","what","pleasing","unto","thee"]},{"verseId":"brenton_wisdom-of-solomon_9_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":11,"text":"For she knoweth and understandeth all things, and she shall lead me soberly in my doings, and preserve me in her power.","searchKeywords":["for","she","knoweth","and","understandeth","all","things","shall","lead","soberly","doings","preserve","her","power"]},{"verseId":"brenton_wisdom-of-solomon_9_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":12,"text":"So shall my works be acceptable, and then shall I judge thy people righteously, and be worthy to sit in my father's seat.","searchKeywords":["shall","works","acceptable","and","then","judge","thy","people","righteously","worthy","sit","father","seat"]},{"verseId":"brenton_wisdom-of-solomon_9_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":13,"text":"For what man is he that can know the counsel of God? or who can think what the will of the Lord is?","searchKeywords":["for","what","man","that","can","know","the","counsel","god","who","think","will","lord"]},{"verseId":"brenton_wisdom-of-solomon_9_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":14,"text":"For the thoughts of mortal men are miserable, and our devices are but uncertain.","searchKeywords":["for","the","thoughts","mortal","men","are","miserable","and","our","devices","but","uncertain"]},{"verseId":"brenton_wisdom-of-solomon_9_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":15,"text":"For the corruptible body presseth down the soul, and the earthy tabernacle weigheth down the mind that museth upon many things.","searchKeywords":["for","the","corruptible","body","presseth","down","soul","and","earthy","tabernacle","weigheth","mind","that","museth","upon","many","things"]},{"verseId":"brenton_wisdom-of-solomon_9_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":16,"text":"And hardly do we guess aright at things that are upon earth, and with labour do we find the things that are before us: but the things that are in heaven who hath searched out?","searchKeywords":["and","hardly","guess","aright","things","that","are","upon","earth","with","labour","find","the","before","but","heaven","who","hath","searched","out"]},{"verseId":"brenton_wisdom-of-solomon_9_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":17,"text":"And thy counsel who hath known, except thou give wisdom, and send thy Holy Spirit from above?","searchKeywords":["and","thy","counsel","who","hath","known","except","thou","give","wisdom","send","holy","spirit","from","above"]},{"verseId":"brenton_wisdom-of-solomon_9_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":9,"verse":18,"text":"For so the ways of them which lived on the earth were reformed, and men were taught the things that are pleasing unto thee, and were saved through wisdom.","searchKeywords":["for","the","ways","them","which","lived","earth","were","reformed","and","men","taught","things","that","are","pleasing","unto","thee","saved","through","wisdom"]}]