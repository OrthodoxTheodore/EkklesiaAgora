[{"verseId":"brenton_wisdom-of-solomon_18_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":1,"text":"Nevertheless thy saints had a very great light, whose voice they hearing, and not seeing their shape, because they also had not suffered the same things, they counted them happy.","searchKeywords":["nevertheless","thy","saints","had","very","great","light","whose","voice","they","hearing","and","not","seeing","their","shape","because","also","suffered","the","same","things","counted","them","happy"]},{"verseId":"brenton_wisdom-of-solomon_18_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":2,"text":"But for that they did not hurt them , of whom they had been wronged before, they thanked them, and besought them pardon for that they had been enemies.","searchKeywords":["but","for","that","they","did","not","hurt","them","whom","had","been","wronged","before","thanked","and","besought","pardon","enemies"]},{"verseId":"brenton_wisdom-of-solomon_18_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":3,"text":"Instead whereof thou gavest them a burning pillar of fire, both to be a guide of the unknown journey, and a harmless sun to entertain them honourably.","searchKeywords":["instead","whereof","thou","gavest","them","burning","pillar","fire","both","guide","the","unknown","journey","and","harmless","sun","entertain","honourably"]},{"verseId":"brenton_wisdom-of-solomon_18_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":4,"text":"For they were worthy to be deprived of light, and imprisoned in darkness, who had kept thy sons shut up, by whom the uncorrupt light of the law was to be given unto the world.","searchKeywords":["for","they","were","worthy","deprived","light","and","imprisoned","darkness","who","had","kept","thy","sons","shut","whom","the","uncorrupt","law","was","given","unto","world"]},{"verseId":"brenton_wisdom-of-solomon_18_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":5,"text":"And when they had determined to slay the babes of the saints, one child being cast forth, and saved, to reprove them, thou tookest away the multitude of their children, and destroyedst them all together in a mighty water.","searchKeywords":["and","when","they","had","determined","slay","the","babes","saints","one","child","being","cast","forth","saved","reprove","them","thou","tookest","away","multitude","their","children","destroyedst","all","together","mighty","water"]},{"verseId":"brenton_wisdom-of-solomon_18_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":6,"text":"Of that night were our fathers certified afore, that assuredly knowing unto what oaths they had given credence, they might afterwards be of good cheer.","searchKeywords":["that","night","were","our","fathers","certified","afore","assuredly","knowing","unto","what","oaths","they","had","given","credence","might","afterwards","good","cheer"]},{"verseId":"brenton_wisdom-of-solomon_18_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":7,"text":"So of thy people was accepted both the salvation of the righteous, and destruction of the enemies.","searchKeywords":["thy","people","was","accepted","both","the","salvation","righteous","and","destruction","enemies"]},{"verseId":"brenton_wisdom-of-solomon_18_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":8,"text":"For wherewith thou didst punish our adversaries, by the same thou didst glorify us, whom thou hadst called.","searchKeywords":["for","wherewith","thou","didst","punish","our","adversaries","the","same","glorify","whom","hadst","called"]},{"verseId":"brenton_wisdom-of-solomon_18_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":9,"text":"For the righteous children of good men did sacrifice secretly, and with one consent made a holy law, that the saints should be like partakers of the same good and evil, the fathers now singing out the songs of praise.","searchKeywords":["for","the","righteous","children","good","men","did","sacrifice","secretly","and","with","one","consent","made","holy","law","that","saints","should","like","partakers","same","evil","fathers","now","singing","out","songs","praise"]},{"verseId":"brenton_wisdom-of-solomon_18_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":10,"text":"But on the other side there sounded an ill according cry of the enemies, and a lamentable noise was carried abroad for children that were bewailed.","searchKeywords":["but","the","other","side","there","sounded","ill","according","cry","enemies","and","lamentable","noise","was","carried","abroad","for","children","that","were","bewailed"]},{"verseId":"brenton_wisdom-of-solomon_18_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":11,"text":"The master and the servant were punished after one manner; and like as the king, so suffered the common person.","searchKeywords":["the","master","and","servant","were","punished","after","one","manner","like","king","suffered","common","person"]},{"verseId":"brenton_wisdom-of-solomon_18_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":12,"text":"So they all together had innumerable dead with one kind of death; neither were the living sufficient to bury them: for in one moment the noblest offspring of them was destroyed.","searchKeywords":["they","all","together","had","innumerable","dead","with","one","kind","death","neither","were","the","living","sufficient","bury","them","for","moment","noblest","offspring","was","destroyed"]},{"verseId":"brenton_wisdom-of-solomon_18_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":13,"text":"For whereas they would not believe any thing by reason of the enchantments; upon the destruction of the firstborn, they acknowledged this people to be the sons of God.","searchKeywords":["for","whereas","they","would","not","believe","any","thing","reason","the","enchantments","upon","destruction","firstborn","acknowledged","this","people","sons","god"]},{"verseId":"brenton_wisdom-of-solomon_18_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":14,"text":"For while all things were in quiet silence, and that night was in the midst of her swift course,","searchKeywords":["for","while","all","things","were","quiet","silence","and","that","night","was","the","midst","her","swift","course"]},{"verseId":"brenton_wisdom-of-solomon_18_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":15,"text":"thine Almighty word leaped from heaven out of thy royal throne, as a fierce man of war into the midst of a land of destruction,","searchKeywords":["thine","almighty","word","leaped","from","heaven","out","thy","royal","throne","fierce","man","war","into","the","midst","land","destruction"]},{"verseId":"brenton_wisdom-of-solomon_18_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":16,"text":"and brought thine unfeigned commandment as a sharp sword, and standing up filled all things with death; and it touched the heaven, but it stood upon the earth.","searchKeywords":["and","brought","thine","unfeigned","commandment","sharp","sword","standing","filled","all","things","with","death","touched","the","heaven","but","stood","upon","earth"]},{"verseId":"brenton_wisdom-of-solomon_18_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":17,"text":"Then suddenly visions of horrible dreams troubled them sore, and terrors came upon them unlooked for.","searchKeywords":["then","suddenly","visions","horrible","dreams","troubled","them","sore","and","terrors","came","upon","unlooked","for"]},{"verseId":"brenton_wisdom-of-solomon_18_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":18,"text":"And one thrown here, and another there, half dead, shewed the cause of his death.","searchKeywords":["and","one","thrown","here","another","there","half","dead","shewed","the","cause","his","death"]},{"verseId":"brenton_wisdom-of-solomon_18_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":19,"text":"For the dreams that troubled them did foreshew this, lest they should perish, and not know why they were afflicted.","searchKeywords":["for","the","dreams","that","troubled","them","did","foreshew","this","lest","they","should","perish","and","not","know","why","were","afflicted"]},{"verseId":"brenton_wisdom-of-solomon_18_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":20,"text":"Yea, the tasting of death touched the righteous also, and there was a destruction of the multitude in the wilderness: but the wrath endured not long.","searchKeywords":["yea","the","tasting","death","touched","righteous","also","and","there","was","destruction","multitude","wilderness","but","wrath","endured","not","long"]},{"verseId":"brenton_wisdom-of-solomon_18_21","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":21,"text":"For then the blameless man made haste, and stood forth to defend them; and bringing the shield of his proper ministry, even prayer, and the propitiation of incense, set himself against the wrath, and so brought the calamity to an end, declaring that he was thy servant.","searchKeywords":["for","then","the","blameless","man","made","haste","and","stood","forth","defend","them","bringing","shield","his","proper","ministry","even","prayer","propitiation","incense","set","himself","against","wrath","brought","calamity","end","declaring","that","was","thy","servant"]},{"verseId":"brenton_wisdom-of-solomon_18_22","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":22,"text":"So he overcame the destroyer, not with might of body, nor force of arms, but with a word subdued him that punished, alleging the oaths and covenants made with the fathers.","searchKeywords":["overcame","the","destroyer","not","with","might","body","nor","force","arms","but","word","subdued","him","that","punished","alleging","oaths","and","covenants","made","fathers"]},{"verseId":"brenton_wisdom-of-solomon_18_23","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":23,"text":"For when the dead were now fallen down by heaps one upon another, standing between, he stayed the wrath, and parted the way to the living.","searchKeywords":["for","when","the","dead","were","now","fallen","down","heaps","one","upon","another","standing","between","stayed","wrath","and","parted","way","living"]},{"verseId":"brenton_wisdom-of-solomon_18_24","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":24,"text":"For in the long garment was the whole world, and in the four rows of the stones was the glory of the fathers graven, and thy Majesty upon the diadem of his head.","searchKeywords":["for","the","long","garment","was","whole","world","and","four","rows","stones","glory","fathers","graven","thy","majesty","upon","diadem","his","head"]},{"verseId":"brenton_wisdom-of-solomon_18_25","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":18,"verse":25,"text":"Unto these the destroyer gave place, and they were afraid of them: for it was enough that they only tasted of the wrath.","searchKeywords":["unto","these","the","destroyer","gave","place","and","they","were","afraid","them","for","was","enough","that","only","tasted","wrath"]}]