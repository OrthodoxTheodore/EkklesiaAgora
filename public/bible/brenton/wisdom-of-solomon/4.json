[{"verseId":"brenton_wisdom-of-solomon_4_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":1,"text":"Better it is to have no children, and to have virtue: for the memorial thereof is immortal: because it is known with God, and with men.","searchKeywords":["better","have","children","and","virtue","for","the","memorial","thereof","immortal","because","known","with","god","men"]},{"verseId":"brenton_wisdom-of-solomon_4_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":2,"text":"When it is present, men take example at it; and when it is gone, they desire it: it weareth a crown, and triumpheth for ever, having gotten the victory, striving for undefiled rewards.","searchKeywords":["when","present","men","take","example","and","gone","they","desire","weareth","crown","triumpheth","for","ever","having","gotten","the","victory","striving","undefiled","rewards"]},{"verseId":"brenton_wisdom-of-solomon_4_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":3,"text":"But the multiplying brood of the ungodly shall not thrive, nor take deep rooting from bastard slips, nor lay any fast foundation.","searchKeywords":["but","the","multiplying","brood","ungodly","shall","not","thrive","nor","take","deep","rooting","from","bastard","slips","lay","any","fast","foundation"]},{"verseId":"brenton_wisdom-of-solomon_4_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":4,"text":"For though they flourish in branches for a time; yet standing not fast, they shall be shaken with the wind, and through the force of winds they shall be rooted out.","searchKeywords":["for","though","they","flourish","branches","time","yet","standing","not","fast","shall","shaken","with","the","wind","and","through","force","winds","rooted","out"]},{"verseId":"brenton_wisdom-of-solomon_4_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":5,"text":"The imperfect branches shall be broken off, their fruit unprofitable, not ripe to eat, yea, meet for nothing.","searchKeywords":["the","imperfect","branches","shall","broken","off","their","fruit","unprofitable","not","ripe","eat","yea","meet","for","nothing"]},{"verseId":"brenton_wisdom-of-solomon_4_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":6,"text":"For children begotten of unlawful beds are witnesses of wickedness against their parents in their trial.","searchKeywords":["for","children","begotten","unlawful","beds","are","witnesses","wickedness","against","their","parents","trial"]},{"verseId":"brenton_wisdom-of-solomon_4_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":7,"text":"But though the righteous be prevented with death, yet shall he be in rest.","searchKeywords":["but","though","the","righteous","prevented","with","death","yet","shall","rest"]},{"verseId":"brenton_wisdom-of-solomon_4_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":8,"text":"For honourable age is not that which standeth in length of time, nor that is measured by number of years.","searchKeywords":["for","honourable","age","not","that","which","standeth","length","time","nor","measured","number","years"]},{"verseId":"brenton_wisdom-of-solomon_4_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":9,"text":"But wisdom is the grey hair unto men, and an unspotted life is old age.","searchKeywords":["but","wisdom","the","grey","hair","unto","men","and","unspotted","life","old","age"]},{"verseId":"brenton_wisdom-of-solomon_4_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":10,"text":"He pleased God, and was beloved of him: so that living among sinners he was translated.","searchKeywords":["pleased","god","and","was","beloved","him","that","living","among","sinners","translated"]},{"verseId":"brenton_wisdom-of-solomon_4_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":11,"text":"Yea, speedily was he taken away, lest that wickedness should alter his understanding, or deceit beguile his soul.","searchKeywords":["yea","speedily","was","taken","away","lest","that","wickedness","should","alter","his","understanding","deceit","beguile","soul"]},{"verseId":"brenton_wisdom-of-solomon_4_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":12,"text":"For the bewitching of naughtiness doth obscure things that are honest; and the wandering of concupiscence doth undermine the simple mind.","searchKeywords":["for","the","bewitching","naughtiness","doth","obscure","things","that","are","honest","and","wandering","concupiscence","undermine","simple","mind"]},{"verseId":"brenton_wisdom-of-solomon_4_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":13,"text":"He, being made perfect in a short time, fulfilled a long time:","searchKeywords":["being","made","perfect","short","time","fulfilled","long"]},{"verseId":"brenton_wisdom-of-solomon_4_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":14,"text":"for his soul pleased the Lord: therefore hasted he from among the wicked.","searchKeywords":["for","his","soul","pleased","the","lord","therefore","hasted","from","among","wicked"]},{"verseId":"brenton_wisdom-of-solomon_4_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":15,"text":"This the people saw, and understood not, neither laid they up this in their minds, That his grace and mercy is with his saints, and that he hath respect unto his chosen.","searchKeywords":["this","the","people","saw","and","understood","not","neither","laid","they","their","minds","that","his","grace","mercy","with","saints","hath","respect","unto","chosen"]},{"verseId":"brenton_wisdom-of-solomon_4_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":16,"text":"Thus the righteous that is dead shall condemn the ungodly which are living; and youth that is soon perfected the many years and old age of the unrighteous.","searchKeywords":["thus","the","righteous","that","dead","shall","condemn","ungodly","which","are","living","and","youth","soon","perfected","many","years","old","age","unrighteous"]},{"verseId":"brenton_wisdom-of-solomon_4_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":17,"text":"For they shall see the end of the wise, and shall not understand what God in his counsel hath decreed of him, and to what end the Lord hath set him in safety.","searchKeywords":["for","they","shall","see","the","end","wise","and","not","understand","what","god","his","counsel","hath","decreed","him","lord","set","safety"]},{"verseId":"brenton_wisdom-of-solomon_4_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":18,"text":"They shall see him, and despise him; but God shall laugh them to scorn; and they shall hereafter be a vile carcase, and a reproach among the dead for evermore.","searchKeywords":["they","shall","see","him","and","despise","but","god","laugh","them","scorn","hereafter","vile","carcase","reproach","among","the","dead","for","evermore"]},{"verseId":"brenton_wisdom-of-solomon_4_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":19,"text":"For he shall rend them, and cast them down headlong, that they shall be speechless; and he shall shake them from the foundation; and they shall be utterly laid waste, and be in sorrow; and their memorial shall perish.","searchKeywords":["for","shall","rend","them","and","cast","down","headlong","that","they","speechless","shake","from","the","foundation","utterly","laid","waste","sorrow","their","memorial","perish"]},{"verseId":"brenton_wisdom-of-solomon_4_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":4,"verse":20,"text":"And when they cast up the account of their sins, they shall come with fear: and their own iniquities shall convince them to their face.","searchKeywords":["and","when","they","cast","the","account","their","sins","shall","come","with","fear","own","iniquities","convince","them","face"]}]