[{"verseId":"brenton_wisdom-of-solomon_12_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":1,"text":"For thine incorruptible Spirit is in all things.","searchKeywords":["for","thine","incorruptible","spirit","all","things"]},{"verseId":"brenton_wisdom-of-solomon_12_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":2,"text":"Therefore chastenest thou them by little and little that offend, and warnest them by putting them in remembrance wherein they have offended, that leaving their wickedness they may believe on thee, O Lord.","searchKeywords":["therefore","chastenest","thou","them","little","and","that","offend","warnest","putting","remembrance","wherein","they","have","offended","leaving","their","wickedness","may","believe","thee","lord"]},{"verseId":"brenton_wisdom-of-solomon_12_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":3,"text":"For it was thy will to destroy by the hands of our fathers both those old inhabitants of thy holy land,","searchKeywords":["for","was","thy","will","destroy","the","hands","our","fathers","both","those","old","inhabitants","holy","land"]},{"verseId":"brenton_wisdom-of-solomon_12_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":4,"text":"whom thou hatedst for doing most odious works of witchcrafts, and wicked sacrifices;","searchKeywords":["whom","thou","hatedst","for","doing","most","odious","works","witchcrafts","and","wicked","sacrifices"]},{"verseId":"brenton_wisdom-of-solomon_12_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":5,"text":"and also those merciless murderers of children, and devourers of man's flesh, and the feasts of blood,","searchKeywords":["and","also","those","merciless","murderers","children","devourers","man","flesh","the","feasts","blood"]},{"verseId":"brenton_wisdom-of-solomon_12_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":6,"text":"with their priests out of the midst of their idolatrous crew, and the parents, that killed with their own hands souls destitute of help:","searchKeywords":["with","their","priests","out","the","midst","idolatrous","crew","and","parents","that","killed","own","hands","souls","destitute","help"]},{"verseId":"brenton_wisdom-of-solomon_12_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":7,"text":"that the land, which thou esteemedst above all other, might receive a worthy colony of God's children.","searchKeywords":["that","the","land","which","thou","esteemedst","above","all","other","might","receive","worthy","colony","god","children"]},{"verseId":"brenton_wisdom-of-solomon_12_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":8,"text":"Nevertheless even those thou sparedst as men, and didst send wasps, forerunners of thine host, to destroy them by little and little.","searchKeywords":["nevertheless","even","those","thou","sparedst","men","and","didst","send","wasps","forerunners","thine","host","destroy","them","little"]},{"verseId":"brenton_wisdom-of-solomon_12_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":9,"text":"Not that thou wast unable to bring the ungodly under the hand of the righteous in battle, or to destroy them at once with cruel beasts, or with one rough word:","searchKeywords":["not","that","thou","wast","unable","bring","the","ungodly","under","hand","righteous","battle","destroy","them","once","with","cruel","beasts","one","rough","word"]},{"verseId":"brenton_wisdom-of-solomon_12_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":10,"text":"but executing thy judgments upon them by little and little, thou gavest them place of repentance, not being ignorant that they were a naughty generation, and that their malice was bred in them, and that their cogitation would never be changed.","searchKeywords":["but","executing","thy","judgments","upon","them","little","and","thou","gavest","place","repentance","not","being","ignorant","that","they","were","naughty","generation","their","malice","was","bred","cogitation","would","never","changed"]},{"verseId":"brenton_wisdom-of-solomon_12_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":11,"text":"For it was a cursed seed from the beginning; neither didst thou for fear of any man give them pardon for those things wherein they sinned.","searchKeywords":["for","was","cursed","seed","from","the","beginning","neither","didst","thou","fear","any","man","give","them","pardon","those","things","wherein","they","sinned"]},{"verseId":"brenton_wisdom-of-solomon_12_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":12,"text":"For who shall say, What hast thou done? or who shall withstand thy judgment? or who shall accuse thee for the nations that perish, whom thou hast made? or who shall come to stand against thee, to be revenged for the unrighteous men?","searchKeywords":["for","who","shall","say","what","hast","thou","done","withstand","thy","judgment","accuse","thee","the","nations","that","perish","whom","made","come","stand","against","revenged","unrighteous","men"]},{"verseId":"brenton_wisdom-of-solomon_12_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":13,"text":"For neither is there any God but thou that careth for all, to whom thou mightest shew that thy judgment is not unright.","searchKeywords":["for","neither","there","any","god","but","thou","that","careth","all","whom","mightest","shew","thy","judgment","not","unright"]},{"verseId":"brenton_wisdom-of-solomon_12_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":14,"text":"Neither shall king or tyrant be able to set his face against thee for any whom thou hast punished.","searchKeywords":["neither","shall","king","tyrant","able","set","his","face","against","thee","for","any","whom","thou","hast","punished"]},{"verseId":"brenton_wisdom-of-solomon_12_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":15,"text":"Forsomuch then as thou art righteous thyself, thou orderest all things righteously: thinking it not agreeable with thy power to condemn him that hath not deserved to be punished.","searchKeywords":["forsomuch","then","thou","art","righteous","thyself","orderest","all","things","righteously","thinking","not","agreeable","with","thy","power","condemn","him","that","hath","deserved","punished"]},{"verseId":"brenton_wisdom-of-solomon_12_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":16,"text":"For thy power is the beginning of righteousness, and because thou art the Lord of all, it maketh thee to be gracious unto all.","searchKeywords":["for","thy","power","the","beginning","righteousness","and","because","thou","art","lord","all","maketh","thee","gracious","unto"]},{"verseId":"brenton_wisdom-of-solomon_12_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":17,"text":"For when men will not believe that thou art of a full power, thou shewest thy strength, and among them that know it thou makest their boldness manifest.","searchKeywords":["for","when","men","will","not","believe","that","thou","art","full","power","shewest","thy","strength","and","among","them","know","makest","their","boldness","manifest"]},{"verseId":"brenton_wisdom-of-solomon_12_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":18,"text":"But thou, mastering thy power, judgest with equity, and orderest us with great favour: for thou mayest use power when thou wilt.","searchKeywords":["but","thou","mastering","thy","power","judgest","with","equity","and","orderest","great","favour","for","mayest","use","when","wilt"]},{"verseId":"brenton_wisdom-of-solomon_12_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":19,"text":"But by such works hast thou taught thy people that the just man should be merciful, and hast made thy children to be of a good hope that thou givest repentance for sins.","searchKeywords":["but","such","works","hast","thou","taught","thy","people","that","the","just","man","should","merciful","and","made","children","good","hope","givest","repentance","for","sins"]},{"verseId":"brenton_wisdom-of-solomon_12_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":20,"text":"For if thou didst punish the enemies of thy children, and the condemned to death, with such deliberation, giving them time and place whereby they might be delivered from their malice:","searchKeywords":["for","thou","didst","punish","the","enemies","thy","children","and","condemned","death","with","such","deliberation","giving","them","time","place","whereby","they","might","delivered","from","their","malice"]},{"verseId":"brenton_wisdom-of-solomon_12_21","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":21,"text":"with how great circumspection didst thou judge thine own sons, unto whose fathers thou hast sworn, and made covenants of good promises?","searchKeywords":["with","how","great","circumspection","didst","thou","judge","thine","own","sons","unto","whose","fathers","hast","sworn","and","made","covenants","good","promises"]},{"verseId":"brenton_wisdom-of-solomon_12_22","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":22,"text":"Therefore, whereas thou dost chasten us, thou scourgest our enemies a thousand times more, to the intent that, when we judge, we should carefully think of thy goodness, and when we ourselves are judged, we should look for mercy.","searchKeywords":["therefore","whereas","thou","dost","chasten","scourgest","our","enemies","thousand","times","more","the","intent","that","when","judge","should","carefully","think","thy","goodness","and","ourselves","are","judged","look","for","mercy"]},{"verseId":"brenton_wisdom-of-solomon_12_23","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":23,"text":"Wherefore, whereas men have lived dissolutely and unrighteously, thou hast tormented them with their own abominations.","searchKeywords":["wherefore","whereas","men","have","lived","dissolutely","and","unrighteously","thou","hast","tormented","them","with","their","own","abominations"]},{"verseId":"brenton_wisdom-of-solomon_12_24","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":24,"text":"For they went astray very far in the ways of error, and held them for gods, which even among the beasts of their enemies were despised, being deceived, as children of no understanding.","searchKeywords":["for","they","went","astray","very","far","the","ways","error","and","held","them","gods","which","even","among","beasts","their","enemies","were","despised","being","deceived","children","understanding"]},{"verseId":"brenton_wisdom-of-solomon_12_25","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":25,"text":"Therefore unto them, as to children without the use of reason, thou didst send a judgment to mock them.","searchKeywords":["therefore","unto","them","children","without","the","use","reason","thou","didst","send","judgment","mock"]},{"verseId":"brenton_wisdom-of-solomon_12_26","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":26,"text":"But they that would not be reformed by that correction, wherein he dallied with them, shall feel a judgment worthy of God.","searchKeywords":["but","they","that","would","not","reformed","correction","wherein","dallied","with","them","shall","feel","judgment","worthy","god"]},{"verseId":"brenton_wisdom-of-solomon_12_27","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":12,"verse":27,"text":"For, look, for what things they grudged, when they were punished, that is, for them whom they thought to be gods; [now] being punished in them, when they saw it, they acknowledged him to be the true God, whom before they denied to know; and therefore came extreme damnation upon them.","searchKeywords":["for","look","what","things","they","grudged","when","were","punished","that","them","whom","thought","gods","now","being","saw","acknowledged","him","the","true","god","before","denied","know","and","therefore","came","extreme","damnation","upon"]}]