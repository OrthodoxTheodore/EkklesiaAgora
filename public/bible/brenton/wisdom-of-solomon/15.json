[{"verseId":"brenton_wisdom-of-solomon_15_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":1,"text":"But thou, our God, art gracious and true, long-suffering, and in mercy ordering all things.","searchKeywords":["but","thou","our","god","art","gracious","and","true","long","suffering","mercy","ordering","all","things"]},{"verseId":"brenton_wisdom-of-solomon_15_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":2,"text":"For if we sin, we are thine, knowing thy power: but we will not sin, knowing that we are counted thine.","searchKeywords":["for","sin","are","thine","knowing","thy","power","but","will","not","that","counted"]},{"verseId":"brenton_wisdom-of-solomon_15_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":3,"text":"For to know thee is perfect righteousness: yea, to know thy power is the root of immortality.","searchKeywords":["for","know","thee","perfect","righteousness","yea","thy","power","the","root","immortality"]},{"verseId":"brenton_wisdom-of-solomon_15_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":4,"text":"For neither did the mischievous invention of men deceive us, nor an image spotted with divers colours, the painter's fruitless labour;","searchKeywords":["for","neither","did","the","mischievous","invention","men","deceive","nor","image","spotted","with","divers","colours","painter","fruitless","labour"]},{"verseId":"brenton_wisdom-of-solomon_15_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":5,"text":"the sight whereof enticeth fools to lust after it, and so they desire the form of a dead image, that hath no breath.","searchKeywords":["the","sight","whereof","enticeth","fools","lust","after","and","they","desire","form","dead","image","that","hath","breath"]},{"verseId":"brenton_wisdom-of-solomon_15_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":6,"text":"Both they that make them, they that desire them, and they that worship them, are lovers of evil things, and are worthy to have such things to trust upon.","searchKeywords":["both","they","that","make","them","desire","and","worship","are","lovers","evil","things","worthy","have","such","trust","upon"]},{"verseId":"brenton_wisdom-of-solomon_15_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":7,"text":"For the potter, tempering soft earth, fashioneth every vessel with much labour for our service: yea, of the same clay he maketh both the vessels that serve for clean uses, and likewise also all such as serve to the contrary: but what is the use of either sort, the potter himself is the judge.","searchKeywords":["for","the","potter","tempering","soft","earth","fashioneth","every","vessel","with","much","labour","our","service","yea","same","clay","maketh","both","vessels","that","serve","clean","uses","and","likewise","also","all","such","contrary","but","what","use","either","sort","himself","judge"]},{"verseId":"brenton_wisdom-of-solomon_15_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":8,"text":"And employing his labours lewdly, he maketh a vain god of the same clay, even he which a little before was made of earth himself, and within a little while after returneth to the same, out of the which he was taken, when his life which was lent him shall be demanded.","searchKeywords":["and","employing","his","labours","lewdly","maketh","vain","god","the","same","clay","even","which","little","before","was","made","earth","himself","within","while","after","returneth","out","taken","when","life","lent","him","shall","demanded"]},{"verseId":"brenton_wisdom-of-solomon_15_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":9,"text":"Notwithstanding his care is, not that he shall have much labour, nor that his life is short: but striveth to excel goldsmiths and silversmiths, and endeavoureth to do like the workers in brass, and counteth it his glory to make counterfeit things.","searchKeywords":["notwithstanding","his","care","not","that","shall","have","much","labour","nor","life","short","but","striveth","excel","goldsmiths","and","silversmiths","endeavoureth","like","the","workers","brass","counteth","glory","make","counterfeit","things"]},{"verseId":"brenton_wisdom-of-solomon_15_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":10,"text":"His heart is ashes, his hope is more vile than earth, and his life of less value than clay:","searchKeywords":["his","heart","ashes","hope","more","vile","than","earth","and","life","less","value","clay"]},{"verseId":"brenton_wisdom-of-solomon_15_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":11,"text":"forasmuch as he knew not his Maker, and him that inspired into him an active soul, and breathed in a living spirit.","searchKeywords":["forasmuch","knew","not","his","maker","and","him","that","inspired","into","active","soul","breathed","living","spirit"]},{"verseId":"brenton_wisdom-of-solomon_15_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":12,"text":"But they counted our life a pastime, and our time here a market for gain: for, say they, we must be getting every way, though it be by evil means.","searchKeywords":["but","they","counted","our","life","pastime","and","time","here","market","for","gain","say","must","getting","every","way","though","evil","means"]},{"verseId":"brenton_wisdom-of-solomon_15_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":13,"text":"For this man, that of earthly matter maketh brittle vessels and graven images, knoweth himself to offend above all others.","searchKeywords":["for","this","man","that","earthly","matter","maketh","brittle","vessels","and","graven","images","knoweth","himself","offend","above","all","others"]},{"verseId":"brenton_wisdom-of-solomon_15_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":14,"text":"And all the enemies of thy people, that hold them in subjection, are most foolish, and are more miserable than very babes.","searchKeywords":["and","all","the","enemies","thy","people","that","hold","them","subjection","are","most","foolish","more","miserable","than","very","babes"]},{"verseId":"brenton_wisdom-of-solomon_15_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":15,"text":"For they counted all the idols of the heathen to be gods: which neither have the use of eyes to see, nor noses to draw breath, nor ears to hear, nor fingers of hands to handle; and as for their feet, they are slow to go.","searchKeywords":["for","they","counted","all","the","idols","heathen","gods","which","neither","have","use","eyes","see","nor","noses","draw","breath","ears","hear","fingers","hands","handle","and","their","feet","are","slow"]},{"verseId":"brenton_wisdom-of-solomon_15_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":16,"text":"For man made them, and he that borrowed his own spirit fashioned them: but no man can make a god like unto himself.","searchKeywords":["for","man","made","them","and","that","borrowed","his","own","spirit","fashioned","but","can","make","god","like","unto","himself"]},{"verseId":"brenton_wisdom-of-solomon_15_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":17,"text":"For being mortal, he worketh a dead thing with wicked hands: for he himself is better than the things which he worshippeth: whereas lived once, but they never.","searchKeywords":["for","being","mortal","worketh","dead","thing","with","wicked","hands","himself","better","than","the","things","which","worshippeth","whereas","lived","once","but","they","never"]},{"verseId":"brenton_wisdom-of-solomon_15_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":18,"text":"Yea, they worshipped those beasts also that are most hateful: for being compared together, some are worse than others.","searchKeywords":["yea","they","worshipped","those","beasts","also","that","are","most","hateful","for","being","compared","together","some","worse","than","others"]},{"verseId":"brenton_wisdom-of-solomon_15_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":15,"verse":19,"text":"Neither are they beautiful, so much as to be desired in respect of beasts: but they went without the praise of God and his blessing.","searchKeywords":["neither","are","they","beautiful","much","desired","respect","beasts","but","went","without","the","praise","god","and","his","blessing"]}]