[{"verseId":"brenton_wisdom-of-solomon_8_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":1,"text":"reacheth from one end to another mightily; and sweetly doth she order all things.","searchKeywords":["reacheth","from","one","end","another","mightily","and","sweetly","doth","she","order","all","things"]},{"verseId":"brenton_wisdom-of-solomon_8_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":2,"text":"I loved her, and sought out from my youth, I desired to make my spouse, and I was a lover of her beauty.","searchKeywords":["loved","her","and","sought","out","from","youth","desired","make","spouse","was","lover","beauty"]},{"verseId":"brenton_wisdom-of-solomon_8_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":3,"text":"In that she is conversant with God, she magnifieth her nobility: yea, the Lord of all things himself loved her.","searchKeywords":["that","she","conversant","with","god","magnifieth","her","nobility","yea","the","lord","all","things","himself","loved"]},{"verseId":"brenton_wisdom-of-solomon_8_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":4,"text":"For she is privy to the mysteries of the knowledge of God, and a lover of his works.","searchKeywords":["for","she","privy","the","mysteries","knowledge","god","and","lover","his","works"]},{"verseId":"brenton_wisdom-of-solomon_8_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":5,"text":"If riches be a possession to be desired in this life; what is richer than wisdom, that worketh all things?","searchKeywords":["riches","possession","desired","this","life","what","richer","than","wisdom","that","worketh","all","things"]},{"verseId":"brenton_wisdom-of-solomon_8_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":6,"text":"And if prudence work; who of all that are is a more cunning workman than she?","searchKeywords":["and","prudence","work","who","all","that","are","more","cunning","workman","than","she"]},{"verseId":"brenton_wisdom-of-solomon_8_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":7,"text":"And if a man love righteousness, her labours are virtues: for she teacheth temperance and prudence, justice and fortitude: which are such things, as men can have nothing more profitable in their life.","searchKeywords":["and","man","love","righteousness","her","labours","are","virtues","for","she","teacheth","temperance","prudence","justice","fortitude","which","such","things","men","can","have","nothing","more","profitable","their","life"]},{"verseId":"brenton_wisdom-of-solomon_8_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":8,"text":"If a man desire much experience, she knoweth things of old, and conjectureth what is to come: she knoweth the subtilties of speeches, and can expound dark sentences: she foreseeth signs and wonders, and the events of seasons and times.","searchKeywords":["man","desire","much","experience","she","knoweth","things","old","and","conjectureth","what","come","the","subtilties","speeches","can","expound","dark","sentences","foreseeth","signs","wonders","events","seasons","times"]},{"verseId":"brenton_wisdom-of-solomon_8_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":9,"text":"Therefore I purposed to take her to me to live with me, knowing that she would be a counsellor of good things, and a comfort in cares and grief.","searchKeywords":["therefore","purposed","take","her","live","with","knowing","that","she","would","counsellor","good","things","and","comfort","cares","grief"]},{"verseId":"brenton_wisdom-of-solomon_8_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":10,"text":"For her sake I shall have estimation among the multitude, and honour with the elders, though I be young.","searchKeywords":["for","her","sake","shall","have","estimation","among","the","multitude","and","honour","with","elders","though","young"]},{"verseId":"brenton_wisdom-of-solomon_8_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":11,"text":"I shall be found of a quick conceit in judgment, and shall be admired in the sight of great men.","searchKeywords":["shall","found","quick","conceit","judgment","and","admired","the","sight","great","men"]},{"verseId":"brenton_wisdom-of-solomon_8_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":12,"text":"When I hold my tongue, they shall bide my leisure, and when I speak, they shall give good ear unto me: if I talk much, they shall lay their hands upon their mouth.","searchKeywords":["when","hold","tongue","they","shall","bide","leisure","and","speak","give","good","ear","unto","talk","much","lay","their","hands","upon","mouth"]},{"verseId":"brenton_wisdom-of-solomon_8_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":13,"text":"Moreover by the means of her I shall obtain immortality, and leave behind me an everlasting memorial to them that come after me.","searchKeywords":["moreover","the","means","her","shall","obtain","immortality","and","leave","behind","everlasting","memorial","them","that","come","after"]},{"verseId":"brenton_wisdom-of-solomon_8_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":14,"text":"I shall set the people in order, and the nations shall be subject unto me.","searchKeywords":["shall","set","the","people","order","and","nations","subject","unto"]},{"verseId":"brenton_wisdom-of-solomon_8_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":15,"text":"Horrible tyrants shall be afraid when they do but hear of me; I shall be found good among the multitude, and valiant in war.","searchKeywords":["horrible","tyrants","shall","afraid","when","they","but","hear","found","good","among","the","multitude","and","valiant","war"]},{"verseId":"brenton_wisdom-of-solomon_8_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":16,"text":"After I am come into mine house, I will repose myself with her: for her conversation hath no bitterness: and to live with her hath no sorrow, but mirth and joy.","searchKeywords":["after","come","into","mine","house","will","repose","myself","with","her","for","conversation","hath","bitterness","and","live","sorrow","but","mirth","joy"]},{"verseId":"brenton_wisdom-of-solomon_8_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":17,"text":"Now when I considered these things in myself, and pondered them in my heart, how that to be allied unto wisdom is immortality;","searchKeywords":["now","when","considered","these","things","myself","and","pondered","them","heart","how","that","allied","unto","wisdom","immortality"]},{"verseId":"brenton_wisdom-of-solomon_8_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":18,"text":"and great pleasure it is to have her friendship; and in the works of her hands are infinite riches; and in the exercise of conference with her, prudence; and in talking with her, a good report; I went about seeking how to take her to me.","searchKeywords":["and","great","pleasure","have","her","friendship","the","works","hands","are","infinite","riches","exercise","conference","with","prudence","talking","good","report","went","about","seeking","how","take"]},{"verseId":"brenton_wisdom-of-solomon_8_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":19,"text":"For I was a witty child, and had a good spirit.","searchKeywords":["for","was","witty","child","and","had","good","spirit"]},{"verseId":"brenton_wisdom-of-solomon_8_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":20,"text":"Yea rather, being good, I came into a body undefiled.","searchKeywords":["yea","rather","being","good","came","into","body","undefiled"]},{"verseId":"brenton_wisdom-of-solomon_8_21","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":8,"verse":21,"text":"Nevertheless, when I perceived that I could not otherwise obtain her, except God gave her me; and that was a point of wisdom also to know whose gift she was; I prayed unto the Lord, and besought him, and with my whole heart I said,","searchKeywords":["nevertheless","when","perceived","that","could","not","otherwise","obtain","her","except","god","gave","and","was","point","wisdom","also","know","whose","gift","she","prayed","unto","the","lord","besought","him","with","whole","heart","said"]}]