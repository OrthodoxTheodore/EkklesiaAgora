[{"verseId":"brenton_wisdom-of-solomon_2_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":1,"text":"For said, reasoning with themselves, not aright, Our life is short and tedious, and in the death of a man there is no remedy: neither was there any man known to have returned from the grave.","searchKeywords":["for","said","reasoning","with","themselves","not","aright","our","life","short","and","tedious","the","death","man","there","remedy","neither","was","any","known","have","returned","from","grave"]},{"verseId":"brenton_wisdom-of-solomon_2_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":2,"text":"For we are born at all adventure: and we shall be hereafter as though we had never been: for the breath in our nostrils is as smoke, and a little spark in the moving of our heart:","searchKeywords":["for","are","born","all","adventure","and","shall","hereafter","though","had","never","been","the","breath","our","nostrils","smoke","little","spark","moving","heart"]},{"verseId":"brenton_wisdom-of-solomon_2_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":3,"text":"which being extinguished, our body shall be turned to ashes, and our spirit shall vanish as the soft air,","searchKeywords":["which","being","extinguished","our","body","shall","turned","ashes","and","spirit","vanish","the","soft","air"]},{"verseId":"brenton_wisdom-of-solomon_2_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":4,"text":"and our name shall be forgotten in time, and no man shall have our works in remembrance, and our life shall pass away as the trace of a cloud, and shall be dispersed as a mist, that is driven away with the beams of the sun, and overcome with the heat thereof.","searchKeywords":["and","our","name","shall","forgotten","time","man","have","works","remembrance","life","pass","away","the","trace","cloud","dispersed","mist","that","driven","with","beams","sun","overcome","heat","thereof"]},{"verseId":"brenton_wisdom-of-solomon_2_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":5,"text":"For our time is a very shadow that passeth away; and after our end there is no returning: for it is fast sealed, so that no man cometh again.","searchKeywords":["for","our","time","very","shadow","that","passeth","away","and","after","end","there","returning","fast","sealed","man","cometh","again"]},{"verseId":"brenton_wisdom-of-solomon_2_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":6,"text":"Come on therefore, let us enjoy the good things that are present: and let us speedily use the creatures like as in youth.","searchKeywords":["come","therefore","let","enjoy","the","good","things","that","are","present","and","speedily","use","creatures","like","youth"]},{"verseId":"brenton_wisdom-of-solomon_2_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":7,"text":"Let us fill ourselves with costly wine and ointments: and let no flower of the spring pass by us.","searchKeywords":["let","fill","ourselves","with","costly","wine","and","ointments","flower","the","spring","pass"]},{"verseId":"brenton_wisdom-of-solomon_2_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":8,"text":"Let us crown ourselves with rosebuds, before they be withered:","searchKeywords":["let","crown","ourselves","with","rosebuds","before","they","withered"]},{"verseId":"brenton_wisdom-of-solomon_2_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":9,"text":"let none of us go without his part of our voluptuousness: let us leave tokens of our joyfulness in every place: for this is our portion, and our lot is this.","searchKeywords":["let","none","without","his","part","our","voluptuousness","leave","tokens","joyfulness","every","place","for","this","portion","and","lot"]},{"verseId":"brenton_wisdom-of-solomon_2_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":10,"text":"Let us oppress the poor righteous man, let us not spare the widow, nor reverence the ancient grey hairs of the aged.","searchKeywords":["let","oppress","the","poor","righteous","man","not","spare","widow","nor","reverence","ancient","grey","hairs","aged"]},{"verseId":"brenton_wisdom-of-solomon_2_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":11,"text":"Let our strength be the law of justice: for that which is feeble is found to be nothing worth.","searchKeywords":["let","our","strength","the","law","justice","for","that","which","feeble","found","nothing","worth"]},{"verseId":"brenton_wisdom-of-solomon_2_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":12,"text":"Therefore let us lie in wait for the righteous; because he is not for our turn, and he is clean contrary to our doings: he upbraideth us with our offending the law, and objecteth to our infamy the transgressings of our education.","searchKeywords":["therefore","let","lie","wait","for","the","righteous","because","not","our","turn","and","clean","contrary","doings","upbraideth","with","offending","law","objecteth","infamy","transgressings","education"]},{"verseId":"brenton_wisdom-of-solomon_2_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":13,"text":"He professeth to have the knowledge of God: and he calleth himself the child of the Lord.","searchKeywords":["professeth","have","the","knowledge","god","and","calleth","himself","child","lord"]},{"verseId":"brenton_wisdom-of-solomon_2_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":14,"text":"He was made to reprove our thoughts.","searchKeywords":["was","made","reprove","our","thoughts"]},{"verseId":"brenton_wisdom-of-solomon_2_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":15,"text":"He is grievous unto us even to behold: for his life is not like other men's, his ways are of another fashion.","searchKeywords":["grievous","unto","even","behold","for","his","life","not","like","other","men","ways","are","another","fashion"]},{"verseId":"brenton_wisdom-of-solomon_2_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":16,"text":"We are esteemed of him as counterfeits: he abstaineth from our ways as from filthiness: he pronounceth the end of the just to be blessed, and maketh his boast that God is his father.","searchKeywords":["are","esteemed","him","counterfeits","abstaineth","from","our","ways","filthiness","pronounceth","the","end","just","blessed","and","maketh","his","boast","that","god","father"]},{"verseId":"brenton_wisdom-of-solomon_2_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":17,"text":"Let us see if his words be true: and let us prove what shall happen in the end of him.","searchKeywords":["let","see","his","words","true","and","prove","what","shall","happen","the","end","him"]},{"verseId":"brenton_wisdom-of-solomon_2_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":18,"text":"For if the just man be the son of God, he will help him, and deliver him from the hand of his enemies.","searchKeywords":["for","the","just","man","son","god","will","help","him","and","deliver","from","hand","his","enemies"]},{"verseId":"brenton_wisdom-of-solomon_2_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":19,"text":"Let us examine him with despitefulness and torture, that we may know his meekness, and prove his patience.","searchKeywords":["let","examine","him","with","despitefulness","and","torture","that","may","know","his","meekness","prove","patience"]},{"verseId":"brenton_wisdom-of-solomon_2_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":20,"text":"Let us condemn him with a shameful death: for by his own saying he shall be respected.","searchKeywords":["let","condemn","him","with","shameful","death","for","his","own","saying","shall","respected"]},{"verseId":"brenton_wisdom-of-solomon_2_21","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":21,"text":"Such things they did imagine, and were deceived: for their own wickedness hath blinded them.","searchKeywords":["such","things","they","did","imagine","and","were","deceived","for","their","own","wickedness","hath","blinded","them"]},{"verseId":"brenton_wisdom-of-solomon_2_22","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":22,"text":"As for the mysteries of God, they knew them not: neither hoped they for the wages of righteousness, nor discerned a reward for blameless souls.","searchKeywords":["for","the","mysteries","god","they","knew","them","not","neither","hoped","wages","righteousness","nor","discerned","reward","blameless","souls"]},{"verseId":"brenton_wisdom-of-solomon_2_23","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":23,"text":"For God created man to be immortal, and made him to be an image of his own eternity.","searchKeywords":["for","god","created","man","immortal","and","made","him","image","his","own","eternity"]},{"verseId":"brenton_wisdom-of-solomon_2_24","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":2,"verse":24,"text":"Nevertheless through envy of the devil came death into the world: and they that are of his side do find it.","searchKeywords":["nevertheless","through","envy","the","devil","came","death","into","world","and","they","that","are","his","side","find"]}]