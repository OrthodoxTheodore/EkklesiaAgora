[{"verseId":"brenton_wisdom-of-solomon_3_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":1,"text":"But the souls of the righteous are in the hand of God, and there shall no torment touch them.","searchKeywords":["but","the","souls","righteous","are","hand","god","and","there","shall","torment","touch","them"]},{"verseId":"brenton_wisdom-of-solomon_3_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":2,"text":"In the sight of the unwise they seemed to die: and their departure is taken for misery,","searchKeywords":["the","sight","unwise","they","seemed","die","and","their","departure","taken","for","misery"]},{"verseId":"brenton_wisdom-of-solomon_3_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":3,"text":"and their going from us to be utter destruction: but they are in peace.","searchKeywords":["and","their","going","from","utter","destruction","but","they","are","peace"]},{"verseId":"brenton_wisdom-of-solomon_3_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":4,"text":"For though they be punished in the sight of men, yet is their hope full of immortality.","searchKeywords":["for","though","they","punished","the","sight","men","yet","their","hope","full","immortality"]},{"verseId":"brenton_wisdom-of-solomon_3_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":5,"text":"And having been a little chastised, they shall be greatly rewarded: for God proved them, and found them worthy for himself.","searchKeywords":["and","having","been","little","chastised","they","shall","greatly","rewarded","for","god","proved","them","found","worthy","himself"]},{"verseId":"brenton_wisdom-of-solomon_3_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":6,"text":"As gold in the furnace hath he tried them, and received them as a burnt offering.","searchKeywords":["gold","the","furnace","hath","tried","them","and","received","burnt","offering"]},{"verseId":"brenton_wisdom-of-solomon_3_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":7,"text":"And in the time of their visitation they shall shine, and run to and fro like sparks among the stubble.","searchKeywords":["and","the","time","their","visitation","they","shall","shine","run","fro","like","sparks","among","stubble"]},{"verseId":"brenton_wisdom-of-solomon_3_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":8,"text":"They shall judge the nations, and have dominion over the people, and their Lord shall reign for ever.","searchKeywords":["they","shall","judge","the","nations","and","have","dominion","over","people","their","lord","reign","for","ever"]},{"verseId":"brenton_wisdom-of-solomon_3_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":9,"text":"They that put their trust in him shall understand the truth: and such as be faithful in love shall abide with him: for grace and mercy is to his saints, and he hath care for his elect.","searchKeywords":["they","that","put","their","trust","him","shall","understand","the","truth","and","such","faithful","love","abide","with","for","grace","mercy","his","saints","hath","care","elect"]},{"verseId":"brenton_wisdom-of-solomon_3_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":10,"text":"But the ungodly shall be punished according to their own imaginations, which have neglected the righteous, and forsaken the Lord.","searchKeywords":["but","the","ungodly","shall","punished","according","their","own","imaginations","which","have","neglected","righteous","and","forsaken","lord"]},{"verseId":"brenton_wisdom-of-solomon_3_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":11,"text":"For whoso despiseth wisdom and nurture, he is miserable, and their hope is vain, their labours unfruitful, and their works unprofitable:","searchKeywords":["for","whoso","despiseth","wisdom","and","nurture","miserable","their","hope","vain","labours","unfruitful","works","unprofitable"]},{"verseId":"brenton_wisdom-of-solomon_3_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":12,"text":"their wives are foolish, and their children wicked:","searchKeywords":["their","wives","are","foolish","and","children","wicked"]},{"verseId":"brenton_wisdom-of-solomon_3_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":13,"text":"Their offspring is cursed. Wherefore blessed is the barren that is undefiled, which hath not known the sinful bed: she shall have fruit in the visitation of souls.","searchKeywords":["their","offspring","cursed","wherefore","blessed","the","barren","that","undefiled","which","hath","not","known","sinful","bed","she","shall","have","fruit","visitation","souls"]},{"verseId":"brenton_wisdom-of-solomon_3_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":14,"text":"And the eunuch, which with his hands hath wrought no iniquity, nor imagined wicked things against God: for unto him shall be given the special gift of faith, and an inheritance in the temple of the Lord more acceptable to his mind.","searchKeywords":["and","the","eunuch","which","with","his","hands","hath","wrought","iniquity","nor","imagined","wicked","things","against","god","for","unto","him","shall","given","special","gift","faith","inheritance","temple","lord","more","acceptable","mind"]},{"verseId":"brenton_wisdom-of-solomon_3_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":15,"text":"For glorious is the fruit of good labours: and the root of wisdom shall never fall away.","searchKeywords":["for","glorious","the","fruit","good","labours","and","root","wisdom","shall","never","fall","away"]},{"verseId":"brenton_wisdom-of-solomon_3_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":16,"text":"As for the children of adulterers, they shall not come to their perfection, and the seed of an unrighteous bed shall be rooted out.","searchKeywords":["for","the","children","adulterers","they","shall","not","come","their","perfection","and","seed","unrighteous","bed","rooted","out"]},{"verseId":"brenton_wisdom-of-solomon_3_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":17,"text":"For though they live long, yet shall they be nothing regarded: and their last age shall be without honour.","searchKeywords":["for","though","they","live","long","yet","shall","nothing","regarded","and","their","last","age","without","honour"]},{"verseId":"brenton_wisdom-of-solomon_3_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":18,"text":"Or, if they die quickly, they have no hope, neither comfort in the day of trial.","searchKeywords":["they","die","quickly","have","hope","neither","comfort","the","day","trial"]},{"verseId":"brenton_wisdom-of-solomon_3_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":3,"verse":19,"text":"For horrible is the end of the unrighteous generation.","searchKeywords":["for","horrible","the","end","unrighteous","generation"]}]