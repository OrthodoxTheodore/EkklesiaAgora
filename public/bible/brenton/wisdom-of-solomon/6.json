[{"verseId":"brenton_wisdom-of-solomon_6_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":1,"text":"Hear therefore, O ye kings, and understand; learn, ye that be judges of the ends of the earth.","searchKeywords":["hear","therefore","kings","and","understand","learn","that","judges","the","ends","earth"]},{"verseId":"brenton_wisdom-of-solomon_6_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":2,"text":"Give ear, ye that rule the people, and glory in the multitude of nations.","searchKeywords":["give","ear","that","rule","the","people","and","glory","multitude","nations"]},{"verseId":"brenton_wisdom-of-solomon_6_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":3,"text":"For power is given you of the Lord, and sovereignty from the Highest, who shall try your works, and search out your counsels.","searchKeywords":["for","power","given","you","the","lord","and","sovereignty","from","highest","who","shall","try","your","works","search","out","counsels"]},{"verseId":"brenton_wisdom-of-solomon_6_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":4,"text":"Because, being ministers of his kingdom, ye have not judged aright, nor kept the law, nor walked after the counsel of God;","searchKeywords":["because","being","ministers","his","kingdom","have","not","judged","aright","nor","kept","the","law","walked","after","counsel","god"]},{"verseId":"brenton_wisdom-of-solomon_6_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":5,"text":"horribly and speedily shall he come upon you: for a sharp judgment shall be to them that be in high places.","searchKeywords":["horribly","and","speedily","shall","come","upon","you","for","sharp","judgment","them","that","high","places"]},{"verseId":"brenton_wisdom-of-solomon_6_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":6,"text":"For mercy will soon pardon the meanest: but mighty men shall be mightily tormented.","searchKeywords":["for","mercy","will","soon","pardon","the","meanest","but","mighty","men","shall","mightily","tormented"]},{"verseId":"brenton_wisdom-of-solomon_6_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":7,"text":"For he which is Lord over all shall fear no man's person, neither shall he stand in awe of any man's greatness: for he hath made the small and great, and careth for all alike.","searchKeywords":["for","which","lord","over","all","shall","fear","man","person","neither","stand","awe","any","greatness","hath","made","the","small","and","great","careth","alike"]},{"verseId":"brenton_wisdom-of-solomon_6_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":8,"text":"But a sore trial shall come upon the mighty.","searchKeywords":["but","sore","trial","shall","come","upon","the","mighty"]},{"verseId":"brenton_wisdom-of-solomon_6_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":9,"text":"Unto you therefore, O kings, do I speak, that ye may learn wisdom, and not fall away.","searchKeywords":["unto","you","therefore","kings","speak","that","may","learn","wisdom","and","not","fall","away"]},{"verseId":"brenton_wisdom-of-solomon_6_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":10,"text":"For they that keep holiness holily shall be judged holy: and they that have learned such things shall find what to answer.","searchKeywords":["for","they","that","keep","holiness","holily","shall","judged","holy","and","have","learned","such","things","find","what","answer"]},{"verseId":"brenton_wisdom-of-solomon_6_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":11,"text":"Wherefore set your affection upon my words; desire them, and ye shall be instructed.","searchKeywords":["wherefore","set","your","affection","upon","words","desire","them","and","shall","instructed"]},{"verseId":"brenton_wisdom-of-solomon_6_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":12,"text":"Wisdom is glorious, and never fadeth away: yea, she is easily seen of them that love her, and found of such as seek her.","searchKeywords":["wisdom","glorious","and","never","fadeth","away","yea","she","easily","seen","them","that","love","her","found","such","seek"]},{"verseId":"brenton_wisdom-of-solomon_6_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":13,"text":"She preventeth them that desire her, in making herself first known unto them.","searchKeywords":["she","preventeth","them","that","desire","her","making","herself","first","known","unto"]},{"verseId":"brenton_wisdom-of-solomon_6_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":14,"text":"Whoso seeketh her early shall have no great travail: for he shall find her sitting at his doors.","searchKeywords":["whoso","seeketh","her","early","shall","have","great","travail","for","find","sitting","his","doors"]},{"verseId":"brenton_wisdom-of-solomon_6_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":15,"text":"To think therefore upon her is the perfection of wisdom: and whoso watcheth for her shall quickly be without care.","searchKeywords":["think","therefore","upon","her","the","perfection","wisdom","and","whoso","watcheth","for","shall","quickly","without","care"]},{"verseId":"brenton_wisdom-of-solomon_6_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":16,"text":"For she goeth about seeking such as are worthy of her, sheweth herself favourably unto them in the ways, and meeteth them in every thought.","searchKeywords":["for","she","goeth","about","seeking","such","are","worthy","her","sheweth","herself","favourably","unto","them","the","ways","and","meeteth","every","thought"]},{"verseId":"brenton_wisdom-of-solomon_6_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":17,"text":"For the very true beginning of her is the desire of discipline; and the care of discipline is love;","searchKeywords":["for","the","very","true","beginning","her","desire","discipline","and","care","love"]},{"verseId":"brenton_wisdom-of-solomon_6_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":18,"text":"and love is the keeping of her laws; and the giving heed unto her laws is the assurance of incorruption;","searchKeywords":["and","love","the","keeping","her","laws","giving","heed","unto","assurance","incorruption"]},{"verseId":"brenton_wisdom-of-solomon_6_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":19,"text":"and incorruption maketh us near unto God:","searchKeywords":["and","incorruption","maketh","near","unto","god"]},{"verseId":"brenton_wisdom-of-solomon_6_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":20,"text":"therefore the desire of wisdom bringeth to a kingdom.","searchKeywords":["therefore","the","desire","wisdom","bringeth","kingdom"]},{"verseId":"brenton_wisdom-of-solomon_6_21","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":21,"text":"If your delight be then in thrones and sceptres, O ye kings of the people, honour wisdom, that ye may reign for evermore.","searchKeywords":["your","delight","then","thrones","and","sceptres","kings","the","people","honour","wisdom","that","may","reign","for","evermore"]},{"verseId":"brenton_wisdom-of-solomon_6_22","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":22,"text":"As for wisdom, what she is, and how she came up, I will tell you, and will not hide mysteries from you: but will seek her out from the beginning of her nativity, and bring the knowledge of her into light, and will not pass over the truth.","searchKeywords":["for","wisdom","what","she","and","how","came","will","tell","you","not","hide","mysteries","from","but","seek","her","out","the","beginning","nativity","bring","knowledge","into","light","pass","over","truth"]},{"verseId":"brenton_wisdom-of-solomon_6_23","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":23,"text":"Neither will I go with consuming envy; for such a man shall have no fellowship with wisdom.","searchKeywords":["neither","will","with","consuming","envy","for","such","man","shall","have","fellowship","wisdom"]},{"verseId":"brenton_wisdom-of-solomon_6_24","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":24,"text":"But the multitude of the wise is the welfare of the world: and a wise king is the upholding of the people.","searchKeywords":["but","the","multitude","wise","welfare","world","and","king","upholding","people"]},{"verseId":"brenton_wisdom-of-solomon_6_25","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":6,"verse":25,"text":"Receive therefore instruction through my words, and it shall do you good.","searchKeywords":["receive","therefore","instruction","through","words","and","shall","you","good"]}]