[{"verseId":"brenton_wisdom-of-solomon_10_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":1,"text":"She preserved the first formed father of the world, that was created alone, and brought him out of his fall,","searchKeywords":["she","preserved","the","first","formed","father","world","that","was","created","alone","and","brought","him","out","his","fall"]},{"verseId":"brenton_wisdom-of-solomon_10_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":2,"text":"and gave him power to rule all things.","searchKeywords":["and","gave","him","power","rule","all","things"]},{"verseId":"brenton_wisdom-of-solomon_10_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":3,"text":"But when the unrighteous went away from her in his anger, he perished also in the fury wherewith he murdered his brother.","searchKeywords":["but","when","the","unrighteous","went","away","from","her","his","anger","perished","also","fury","wherewith","murdered","brother"]},{"verseId":"brenton_wisdom-of-solomon_10_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":4,"text":"For whose cause the earth being drowned with the flood, wisdom again preserved it, and directed the course of the righteous in a piece of wood of small value.","searchKeywords":["for","whose","cause","the","earth","being","drowned","with","flood","wisdom","again","preserved","and","directed","course","righteous","piece","wood","small","value"]},{"verseId":"brenton_wisdom-of-solomon_10_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":5,"text":"Moreover, the nations in their wicked conspiracy being confounded, she found out the righteous, and preserved him blameless unto God, and kept him strong against his tender compassion toward his son.","searchKeywords":["moreover","the","nations","their","wicked","conspiracy","being","confounded","she","found","out","righteous","and","preserved","him","blameless","unto","god","kept","strong","against","his","tender","compassion","toward","son"]},{"verseId":"brenton_wisdom-of-solomon_10_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":6,"text":"When the ungodly perished, she delivered the righteous man, who fled from the fire which fell down upon the five cities.","searchKeywords":["when","the","ungodly","perished","she","delivered","righteous","man","who","fled","from","fire","which","fell","down","upon","five","cities"]},{"verseId":"brenton_wisdom-of-solomon_10_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":7,"text":"Of whose wickedness, even to this day the waste land that smoketh is a testimony, and plants bearing fruit that never come to ripeness: and a standing pillar of salt is a monument of an unbelieving soul.","searchKeywords":["whose","wickedness","even","this","day","the","waste","land","that","smoketh","testimony","and","plants","bearing","fruit","never","come","ripeness","standing","pillar","salt","monument","unbelieving","soul"]},{"verseId":"brenton_wisdom-of-solomon_10_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":8,"text":"For regarding not wisdom, they gat not only this hurt, that they knew not the things which were good; but also left behind them to the world a memorial of their foolishness: so that in the things wherein they offended they could not so much as be hid.","searchKeywords":["for","regarding","not","wisdom","they","gat","only","this","hurt","that","knew","the","things","which","were","good","but","also","left","behind","them","world","memorial","their","foolishness","wherein","offended","could","much","hid"]},{"verseId":"brenton_wisdom-of-solomon_10_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":9,"text":"But wisdom delivered from pain those that attended upon her.","searchKeywords":["but","wisdom","delivered","from","pain","those","that","attended","upon","her"]},{"verseId":"brenton_wisdom-of-solomon_10_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":10,"text":"When the righteous fled from his brother's wrath, she guided him in right paths, shewed him the kingdom of God, and gave him knowledge of holy things, made him rich in his travels, and multiplied his labours.","searchKeywords":["when","the","righteous","fled","from","his","brother","wrath","she","guided","him","right","paths","shewed","kingdom","god","and","gave","knowledge","holy","things","made","rich","travels","multiplied","labours"]},{"verseId":"brenton_wisdom-of-solomon_10_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":11,"text":"In the covetousness of such as oppressed him she stood by him, and made him rich.","searchKeywords":["the","covetousness","such","oppressed","him","she","stood","and","made","rich"]},{"verseId":"brenton_wisdom-of-solomon_10_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":12,"text":"She defended him from his enemies, and kept him safe from those that lay in wait, and in a sore conflict she gave him the victory; that he might know that godliness is stronger than all.","searchKeywords":["she","defended","him","from","his","enemies","and","kept","safe","those","that","lay","wait","sore","conflict","gave","the","victory","might","know","godliness","stronger","than","all"]},{"verseId":"brenton_wisdom-of-solomon_10_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":13,"text":"When the righteous was sold, she forsook him not, but delivered him from sin: she went down with him into the pit,","searchKeywords":["when","the","righteous","was","sold","she","forsook","him","not","but","delivered","from","sin","went","down","with","into","pit"]},{"verseId":"brenton_wisdom-of-solomon_10_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":14,"text":"and left him not in bonds, till she brought him the sceptre of the kingdom, and power against those that oppressed him: as for them that had accused him, she shewed them to be liars, and gave him perpetual glory.","searchKeywords":["and","left","him","not","bonds","till","she","brought","the","sceptre","kingdom","power","against","those","that","oppressed","for","them","had","accused","shewed","liars","gave","perpetual","glory"]},{"verseId":"brenton_wisdom-of-solomon_10_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":15,"text":"She delivered the righteous people and blameless seed from the nation that oppressed them.","searchKeywords":["she","delivered","the","righteous","people","and","blameless","seed","from","nation","that","oppressed","them"]},{"verseId":"brenton_wisdom-of-solomon_10_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":16,"text":"She entered into the soul of the servant of the Lord, and withstood dreadful kings in wonders and signs;","searchKeywords":["she","entered","into","the","soul","servant","lord","and","withstood","dreadful","kings","wonders","signs"]},{"verseId":"brenton_wisdom-of-solomon_10_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":17,"text":"rendered to the righteous a reward of their labours, guided them in a marvellous way, and was unto them for a cover by day, and a light of stars in the night season;","searchKeywords":["rendered","the","righteous","reward","their","labours","guided","them","marvellous","way","and","was","unto","for","cover","day","light","stars","night","season"]},{"verseId":"brenton_wisdom-of-solomon_10_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":18,"text":"brought them through the Red sea, and led them through much water:","searchKeywords":["brought","them","through","the","red","sea","and","led","much","water"]},{"verseId":"brenton_wisdom-of-solomon_10_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":19,"text":"but she drowned their enemies, and cast them up out of the bottom of the deep.","searchKeywords":["but","she","drowned","their","enemies","and","cast","them","out","the","bottom","deep"]},{"verseId":"brenton_wisdom-of-solomon_10_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":20,"text":"Therefore the righteous spoiled the ungodly, and praised thy holy name, O Lord, and magnified with one accord thine hand, that fought for them.","searchKeywords":["therefore","the","righteous","spoiled","ungodly","and","praised","thy","holy","name","lord","magnified","with","one","accord","thine","hand","that","fought","for","them"]},{"verseId":"brenton_wisdom-of-solomon_10_21","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":10,"verse":21,"text":"For wisdom opened the mouth of the dumb, and made the tongues of them that cannot speak eloquent.","searchKeywords":["for","wisdom","opened","the","mouth","dumb","and","made","tongues","them","that","cannot","speak","eloquent"]}]