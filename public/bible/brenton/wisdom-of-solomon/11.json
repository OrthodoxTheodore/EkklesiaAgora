[{"verseId":"brenton_wisdom-of-solomon_11_1","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":1,"text":"She prospered their works in the hand of the holy prophet.","searchKeywords":["she","prospered","their","works","the","hand","holy","prophet"]},{"verseId":"brenton_wisdom-of-solomon_11_2","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":2,"text":"They went through the wilderness that was not inhabited, and pitched tents in places where there lay no way.","searchKeywords":["they","went","through","the","wilderness","that","was","not","inhabited","and","pitched","tents","places","where","there","lay","way"]},{"verseId":"brenton_wisdom-of-solomon_11_3","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":3,"text":"They stood against their enemies, and were avenged of their adversaries.","searchKeywords":["they","stood","against","their","enemies","and","were","avenged","adversaries"]},{"verseId":"brenton_wisdom-of-solomon_11_4","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":4,"text":"When they were thirsty, they called upon thee, and water was given them out of the flinty rock, and their thirst was quenched out of the hard stone.","searchKeywords":["when","they","were","thirsty","called","upon","thee","and","water","was","given","them","out","the","flinty","rock","their","thirst","quenched","hard","stone"]},{"verseId":"brenton_wisdom-of-solomon_11_5","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":5,"text":"For by what things their enemies were punished, by the same they in their need were benefited.","searchKeywords":["for","what","things","their","enemies","were","punished","the","same","they","need","benefited"]},{"verseId":"brenton_wisdom-of-solomon_11_6","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":6,"text":"For instead of a fountain of a perpetual running river troubled with foul blood,","searchKeywords":["for","instead","fountain","perpetual","running","river","troubled","with","foul","blood"]},{"verseId":"brenton_wisdom-of-solomon_11_7","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":7,"text":"for a manifest reproof of that commandment, whereby the infants were slain, thou gavest unto them abundance of water by a means which they hoped not for:","searchKeywords":["for","manifest","reproof","that","commandment","whereby","the","infants","were","slain","thou","gavest","unto","them","abundance","water","means","which","they","hoped","not"]},{"verseId":"brenton_wisdom-of-solomon_11_8","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":8,"text":"declaring by that thirst then how thou hadst punished their adversaries.","searchKeywords":["declaring","that","thirst","then","how","thou","hadst","punished","their","adversaries"]},{"verseId":"brenton_wisdom-of-solomon_11_9","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":9,"text":"For when they were tried, albeit but in mercy chastised, they knew how the ungodly were judged in wrath and tormented, thirsting in another manner than the just.","searchKeywords":["for","when","they","were","tried","albeit","but","mercy","chastised","knew","how","the","ungodly","judged","wrath","and","tormented","thirsting","another","manner","than","just"]},{"verseId":"brenton_wisdom-of-solomon_11_10","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":10,"text":"For these thou didst admonish and try, as a father: but the others, as a severe king, thou didst condemn and punish.","searchKeywords":["for","these","thou","didst","admonish","and","try","father","but","the","others","severe","king","condemn","punish"]},{"verseId":"brenton_wisdom-of-solomon_11_11","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":11,"text":"Whether they were absent or present, they were vexed alike.","searchKeywords":["whether","they","were","absent","present","vexed","alike"]},{"verseId":"brenton_wisdom-of-solomon_11_12","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":12,"text":"For a double grief came upon them, and a groaning for the remembrance of things past.","searchKeywords":["for","double","grief","came","upon","them","and","groaning","the","remembrance","things","past"]},{"verseId":"brenton_wisdom-of-solomon_11_13","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":13,"text":"For when they heard by their own punishments the other to be benefited, they had some feeling of the Lord.","searchKeywords":["for","when","they","heard","their","own","punishments","the","other","benefited","had","some","feeling","lord"]},{"verseId":"brenton_wisdom-of-solomon_11_14","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":14,"text":"For whom they rejected with scorn, when he was long before thrown out at the casting forth , him in the end, when they saw what came to pass, they admired.","searchKeywords":["for","whom","they","rejected","with","scorn","when","was","long","before","thrown","out","the","casting","forth","him","end","saw","what","came","pass","admired"]},{"verseId":"brenton_wisdom-of-solomon_11_15","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":15,"text":"But for the foolish devices of their wickedness, wherewith being deceived they worshipped serpents void of reason, and vile beasts, thou didst send a multitude of unreasonable beasts upon them for vengeance:","searchKeywords":["but","for","the","foolish","devices","their","wickedness","wherewith","being","deceived","they","worshipped","serpents","void","reason","and","vile","beasts","thou","didst","send","multitude","unreasonable","upon","them","vengeance"]},{"verseId":"brenton_wisdom-of-solomon_11_16","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":16,"text":"that they might know, that wherewithal a man sinneth, by the same shall he be punished.","searchKeywords":["that","they","might","know","wherewithal","man","sinneth","the","same","shall","punished"]},{"verseId":"brenton_wisdom-of-solomon_11_17","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":17,"text":"For thy Almighty hand, that made the world of matter without form, wanted not means to send among them a multitude of bears, or fierce lions,","searchKeywords":["for","thy","almighty","hand","that","made","the","world","matter","without","form","wanted","not","means","send","among","them","multitude","bears","fierce","lions"]},{"verseId":"brenton_wisdom-of-solomon_11_18","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":18,"text":"or unknown wild beasts, full of rage, newly created, breathing out either a fiery vapour, or filthy scents of scattered smoke, or shooting horrible sparkles out of their eyes:","searchKeywords":["unknown","wild","beasts","full","rage","newly","created","breathing","out","either","fiery","vapour","filthy","scents","scattered","smoke","shooting","horrible","sparkles","their","eyes"]},{"verseId":"brenton_wisdom-of-solomon_11_19","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":19,"text":"whereof not only the harm might dispatch them at once, but also the terrible sight utterly destroy them.","searchKeywords":["whereof","not","only","the","harm","might","dispatch","them","once","but","also","terrible","sight","utterly","destroy"]},{"verseId":"brenton_wisdom-of-solomon_11_20","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":20,"text":"Yea, and without these might they have fallen down with one blast, being persecuted of vengeance, and scattered abroad through the breath of thy power: but thou hast ordered all things in measure and number and weight.","searchKeywords":["yea","and","without","these","might","they","have","fallen","down","with","one","blast","being","persecuted","vengeance","scattered","abroad","through","the","breath","thy","power","but","thou","hast","ordered","all","things","measure","number","weight"]},{"verseId":"brenton_wisdom-of-solomon_11_21","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":21,"text":"For thou canst shew thy great strength at all times when thou wilt; and who may withstand the power of thine arm?","searchKeywords":["for","thou","canst","shew","thy","great","strength","all","times","when","wilt","and","who","may","withstand","the","power","thine","arm"]},{"verseId":"brenton_wisdom-of-solomon_11_22","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":22,"text":"For the whole world before thee is as a little grain of the balance, yea, as a drop of the morning dew that falleth down upon the earth.","searchKeywords":["for","the","whole","world","before","thee","little","grain","balance","yea","drop","morning","dew","that","falleth","down","upon","earth"]},{"verseId":"brenton_wisdom-of-solomon_11_23","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":23,"text":"But thou hast mercy upon all; for thou canst do all things, and winkest at the sins of men, because they should amend.","searchKeywords":["but","thou","hast","mercy","upon","all","for","canst","things","and","winkest","the","sins","men","because","they","should","amend"]},{"verseId":"brenton_wisdom-of-solomon_11_24","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":24,"text":"For thou lovest all the things that are, and abhorrest nothing which thou hast made: for never wouldest thou have made any thing, if thou hadst hated it.","searchKeywords":["for","thou","lovest","all","the","things","that","are","and","abhorrest","nothing","which","hast","made","never","wouldest","have","any","thing","hadst","hated"]},{"verseId":"brenton_wisdom-of-solomon_11_25","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":25,"text":"And how could any thing have endured, if it had not been thy will? or been preserved, if not called by thee?","searchKeywords":["and","how","could","any","thing","have","endured","had","not","been","thy","will","preserved","called","thee"]},{"verseId":"brenton_wisdom-of-solomon_11_26","translationId":"brenton","testament":"OT","bookIndex":30,"bookName":"Wisdom of Solomon","bookAbbrev":"wisdom-of-solomon","chapter":11,"verse":26,"text":"But thou sparest all: for they are thine, O Lord, thou lover of souls.","searchKeywords":["but","thou","sparest","all","for","they","are","thine","lord","lover","souls"]}]