[{"verseId":"brenton_nehemiah_11_1","translationId":"brenton","testament":"OT","bookIndex":17,"bookName":"Nehemiah","bookAbbrev":"nehemiah","chapter":11,"verse":1,"text":"And the chiefs of the people dwelt in Jerusalem: and the rest of the people cast lots, to bring one of ten to dwell in Jerusalem the holy city, and nine parts in the cities.","searchKeywords":["and","the","chiefs","people","dwelt","jerusalem","rest","cast","lots","bring","one","ten","dwell","holy","city","nine","parts","cities"]},{"verseId":"brenton_nehemiah_11_2","translationId":"brenton","testament":"OT","bookIndex":17,"bookName":"Nehemiah","bookAbbrev":"nehemiah","chapter":11,"verse":2,"text":"And the people blessed all the men that volunteered to dwell in Jerusalem.","searchKeywords":["and","the","people","blessed","all","men","that","volunteered","dwell","jerusalem"]},{"verseId":"brenton_nehemiah_11_3","translationId":"brenton","testament":"OT","bookIndex":17,"bookName":"Nehemiah","bookAbbrev":"nehemiah","chapter":11,"verse":3,"text":"Now these the chiefs of the province who dwelt in Jerusalem, and in the cities of Juda; man dwelt in his possession in their cities: Israel, the priests, and the Levites, and the Nathinim, and the children of the servants of Solomon.","searchKeywords":["now","these","the","chiefs","province","who","dwelt","jerusalem","and","cities","juda","man","his","possession","their","israel","priests","levites","nathinim","children","servants","solomon"]},{"verseId":"brenton_nehemiah_11_4","translationId":"brenton","testament":"OT","bookIndex":17,"bookName":"Nehemiah","bookAbbrev":"nehemiah","chapter":11,"verse":4,"text":"And there dwelt in Jerusalem of the children of Juda, and of the children of Benjamin. Of the children of Juda; Athaia son of Azia, the son of Zacharia, the son of Samaria, the son of Saphatia, the son of Maleleel, and of the sons of Phares;","searchKeywords":["and","there","dwelt","jerusalem","the","children","juda","benjamin","athaia","son","azia","zachar