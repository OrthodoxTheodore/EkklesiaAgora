[{"verseId":"brenton_leviticus_18_1","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":1,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_leviticus_18_2","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":2,"text":"Speak to the children of Israel, and thou shalt say to them, I the Lord your God.","searchKeywords":["speak","the","children","israel","and","thou","shalt","say","them","lord","your","god"]},{"verseId":"brenton_leviticus_18_3","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":3,"text":"Ye shall not do according to the devices of Egypt, in which ye dwelt: and according to the devices of the land of Chanaan, into which I bring you, ye shall not do; and ye shall not walk in their ordinances.","searchKeywords":["shall","not","according","the","devices","egypt","which","dwelt","and","land","chanaan","into","bring","you","walk","their","ordinances"]},{"verseId":"brenton_leviticus_18_4","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":4,"text":"Ye shall observe my judgments, and shall keep my ordinances, and shall walk in them: I the Lord your God.","searchKeywords":["shall","observe","judgments","and","keep","ordinances","walk","them","the","lord","your","god"]},{"verseId":"brenton_leviticus_18_5","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":5,"text":"So ye shall keep all my ordinances, and all my judgments, and do them; which if a man do, he shall live in them: I the Lord your God.","searchKeywords":["shall","keep","all","ordinances","and","judgments","them","which","man","live","the","lord","your","god"]},{"verseId":"brenton_leviticus_18_6","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":6,"text":"No man shall draw nigh to any of his near kindred to uncover their nakedness; I the Lord.","searchKeywords":["man","shall","draw","nigh","any","his","near","kindred","uncover","their","nakedness","the","lord"]},{"verseId":"brenton_leviticus_18_7","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":7,"text":"Thou shalt not uncover the nakedness of thy father, or the nakedness of thy mother, for she is thy mother; thou shalt not uncover her nakedness.","searchKeywords":["thou","shalt","not","uncover","the","nakedness","thy","father","mother","for","she","her"]},{"verseId":"brenton_leviticus_18_8","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":8,"text":"Thou shalt not uncover the nakedness of thy father's wife; it is thy father's nakedness.","searchKeywords":["thou","shalt","not","uncover","the","nakedness","thy","father","wife"]},{"verseId":"brenton_leviticus_18_9","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":9,"text":"The nakedness of thy sister by thy father or by thy mother, born at home or abroad, their nakedness thou shalt not uncover.","searchKeywords":["the","nakedness","thy","sister","father","mother","born","home","abroad","their","thou","shalt","not","uncover"]},{"verseId":"brenton_leviticus_18_10","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":10,"text":"The nakedness of thy son's daughter, or thy daughter's daughter, their nakedness thou shalt not uncover; because it is thy nakedness.","searchKeywords":["the","nakedness","thy","son","daughter","their","thou","shalt","not","uncover","because"]},{"verseId":"brenton_leviticus_18_11","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":11,"text":"Thou shalt not uncover the nakedness of the daughter of thy father's wife; she is thy sister by the same father: thou shalt not uncover her nakedness.","searchKeywords":["thou","shalt","not","uncover","the","nakedness","daughter","thy","father","wife","she","sister","same","her"]},{"verseId":"brenton_leviticus_18_12","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":12,"text":"Thou shalt not uncover the nakedness of thy father's sister, for she is near akin to thy father.","searchKeywords":["thou","shalt","not","uncover","the","nakedness","thy","father","sister","for","she","near","akin"]},{"verseId":"brenton_leviticus_18_13","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":13,"text":"Thou shalt not uncover the nakedness of thy mother's sister, for she is near akin to thy mother.","searchKeywords":["thou","shalt","not","uncover","the","nakedness","thy","mother","sister","for","she","near","akin"]},{"verseId":"brenton_leviticus_18_14","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":14,"text":"Thou shalt not uncover the nakedness of thy father's brother, and thou shalt not go in to his wife; for she is thy relation.","searchKeywords":["thou","shalt","not","uncover","the","nakedness","thy","father","brother","and","his","wife","for","she","relation"]},{"verseId":"brenton_leviticus_18_15","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":15,"text":"Thou shalt not uncover the nakedness of thy daughter-in-law, for she is thy son's wife, thou shalt not uncover her nakedness.","searchKeywords":["thou","shalt","not","uncover","the","nakedness","thy","daughter","law","for","she","son","wife","her"]},{"verseId":"brenton_leviticus_18_16","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":16,"text":"Thou shalt not uncover the nakedness of thy brother's wife: it is thy brother's nakedness.","searchKeywords":["thou","shalt","not","uncover","the","nakedness","thy","brother","wife"]},{"verseId":"brenton_leviticus_18_17","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":17,"text":"The nakedness of a woman and her daughter shalt thou not uncover; her son's daughter, and her daughter's daughter, shalt thou not take, to uncover their nakedness, for they are thy kinswomen: it is impiety.","searchKeywords":["the","nakedness","woman","and","her","daughter","shalt","thou","not","uncover","son","take","their","for","they","are","thy","kinswomen","impiety"]},{"verseId":"brenton_leviticus_18_18","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":18,"text":"Thou shalt not take a wife in addition to her sister, as a rival, to uncover her nakedness in opposition to her, while she is yet living.","searchKeywords":["thou","shalt","not","take","wife","addition","her","sister","rival","uncover","nakedness","opposition","while","she","yet","living"]},{"verseId":"brenton_leviticus_18_19","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":19,"text":"And thou shalt not go in to a woman under separation for her uncleanness, to uncover her nakedness.","searchKeywords":["and","thou","shalt","not","woman","under","separation","for","her","uncleanness","uncover","nakedness"]},{"verseId":"brenton_leviticus_18_20","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":20,"text":"And thou shalt not lie with thy neighbour's wife, to defile thyself with her.","searchKeywords":["and","thou","shalt","not","lie","with","thy","neighbour","wife","defile","thyself","her"]},{"verseId":"brenton_leviticus_18_21","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":21,"text":"And thou shalt not give of thy seed to serve a ruler; and thou shalt not profane my holy name; I the Lord.","searchKeywords":["and","thou","shalt","not","give","thy","seed","serve","ruler","profane","holy","name","the","lord"]},{"verseId":"brenton_leviticus_18_22","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":22,"text":"And thou shalt not lie with a man as with a woman, for it is an abomination.","searchKeywords":["and","thou","shalt","not","lie","with","man","woman","for","abomination"]},{"verseId":"brenton_leviticus_18_23","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":23,"text":"Neither shalt thou lie with any quadruped for copulation, to be polluted with it: neither shall a woman present herself before any quadruped to have connexion with it; for it is an abomination.","searchKeywords":["neither","shalt","thou","lie","with","any","quadruped","for","copulation","polluted","shall","woman","present","herself","before","have","connexion","abomination"]},{"verseId":"brenton_leviticus_18_24","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":24,"text":"Do not defile yourselves with any of these things; for in all these things the nations are defiled, which I drive out before you,","searchKeywords":["not","defile","yourselves","with","any","these","things","for","all","the","nations","are","defiled","which","drive","out","before","you"]},{"verseId":"brenton_leviticus_18_25","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":25,"text":"and the land is polluted; and I have recompensed their iniquity to them because of it, and the land is aggrieved with them that dwell upon it.","searchKeywords":["and","the","land","polluted","have","recompensed","their","iniquity","them","because","aggrieved","with","that","dwell","upon"]},{"verseId":"brenton_leviticus_18_26","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":26,"text":"And ye shall keep all my statutes and all my ordinances, and ye shall do none of these abominations; neither the native, nor the stranger that joins himself with you:","searchKeywords":["and","shall","keep","all","statutes","ordinances","none","these","abominations","neither","the","native","nor","stranger","that","joins","himself","with","you"]},{"verseId":"brenton_leviticus_18_27","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":27,"text":"(for all these abominations the men of the land did who were before you, and the land was defiled,)","searchKeywords":["for","all","these","abominations","the","men","land","did","who","were","before","you","and","was","defiled"]},{"verseId":"brenton_leviticus_18_28","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":28,"text":"and lest the land be aggrieved with you in your polluting it, as it was aggrieved with the nations before you.","searchKeywords":["and","lest","the","land","aggrieved","with","you","your","polluting","was","nations","before"]},{"verseId":"brenton_leviticus_18_29","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":29,"text":"For whosoever shall do any of these abominations, the souls that do them shall be destroyed from among their people.","searchKeywords":["for","whosoever","shall","any","these","abominations","the","souls","that","them","destroyed","from","among","their","people"]},{"verseId":"brenton_leviticus_18_30","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":18,"verse":30,"text":"And ye shall keep mine ordinances, that ye may not do any of the abominable practices, which have taken place before your time: and ye shall not be polluted in them; for I the Lord your God.","searchKeywords":["and","shall","keep","mine","ordinances","that","may","not","any","the","abominable","practices","which","have","taken","place","before","your","time","polluted","them","for","lord","god"]}]