[{"verseId":"brenton_leviticus_24_1","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":1,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_leviticus_24_2","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":2,"text":"Charge the children of Israel, and let them take for thee pure olive oil beaten for the light, to burn a lamp continually,","searchKeywords":["charge","the","children","israel","and","let","them","take","for","thee","pure","olive","oil","beaten","light","burn","lamp","continually"]},{"verseId":"brenton_leviticus_24_3","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":3,"text":"outside the veil in the tabernacle of witness; and Aaron and his sons shall burn it from evening until morning before the Lord continually, a perpetual statute throughout your generations.","searchKeywords":["outside","the","veil","tabernacle","witness","and","aaron","his","sons","shall","burn","from","evening","until","morning","before","lord","continually","perpetual","statute","throughout","your","generations"]},{"verseId":"brenton_leviticus_24_4","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":4,"text":"Ye shall burn the lamps on the pure lamp-stand before the Lord till the morrow.","searchKeywords":["shall","burn","the","lamps","pure","lamp","stand","before","lord","till","morrow"]},{"verseId":"brenton_leviticus_24_5","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":5,"text":"And ye shall take fine flour, and make of it twelve loaves; each loaf shall be of two tenth parts.","searchKeywords":["and","shall","take","fine","flour","make","twelve","loaves","each","loaf","two","tenth","parts"]},{"verseId":"brenton_leviticus_24_6","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":6,"text":"And ye shall put them two rows, each row six loaves, on the pure table before the Lord.","searchKeywords":["and","shall","put","them","two","rows","each","row","six","loaves","the","pure","table","before","lord"]},{"verseId":"brenton_leviticus_24_7","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":7,"text":"And ye shall put on row pure frankincense and salt; and shall be for loaves for a memorial, set forth before the Lord.","searchKeywords":["and","shall","put","row","pure","frankincense","salt","for","loaves","memorial","set","forth","before","the","lord"]},{"verseId":"brenton_leviticus_24_8","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":8,"text":"On the sabbath-day they shall be set forth before the Lord continually before the children of Israel, for an everlasting covenant.","searchKeywords":["the","sabbath","day","they","shall","set","forth","before","lord","continually","children","israel","for","everlasting","covenant"]},{"verseId":"brenton_leviticus_24_9","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":9,"text":"And they shall be for Aaron and his sons, and they shall eat them in the holy place: for this is their most holy portion of the offerings made to the Lord, a perpetual statute.","searchKeywords":["and","they","shall","for","aaron","his","sons","eat","them","the","holy","place","this","their","most","portion","offerings","made","lord","perpetual","statute"]},{"verseId":"brenton_leviticus_24_10","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":10,"text":"And there went forth a son of an Israelitish woman, and he was son of an Egyptian man among the sons of Israel; and they fought in the camp, the son of the Israelitish woman, and a man who was an Israelite.","searchKeywords":["and","there","went","forth","son","israelitish","woman","was","egyptian","man","among","the","sons","israel","they","fought","camp","who","israelite"]},{"verseId":"brenton_leviticus_24_11","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":11,"text":"And the son of the Israelitish woman named THE NAME and cursed; and they brought him to Moses: and his mother's name was Salomith, daughter of Dabri of the tribe of Dan.","searchKeywords":["and","the","son","israelitish","woman","named","name","cursed","they","brought","him","moses","his","mother","was","salomith","daughter","dabri","tribe","dan"]},{"verseId":"brenton_leviticus_24_12","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":12,"text":"And they put him in ward, to judge him by the command of the Lord.","searchKeywords":["and","they","put","him","ward","judge","the","command","lord"]},{"verseId":"brenton_leviticus_24_13","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":13,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_leviticus_24_14","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":14,"text":"Bring forth him that cursed outside the camp, and all who heard shall lay their hands upon his head, and all the congregation shall stone him.","searchKeywords":["bring","forth","him","that","cursed","outside","the","camp","and","all","who","heard","shall","lay","their","hands","upon","his","head","congregation","stone"]},{"verseId":"brenton_leviticus_24_15","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":15,"text":"And speak to the sons of Israel, and thou shalt say to them, Whosoever shall curse God shall bear his sin.","searchKeywords":["and","speak","the","sons","israel","thou","shalt","say","them","whosoever","shall","curse","god","bear","his","sin"]},{"verseId":"brenton_leviticus_24_16","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":16,"text":"And he that names the name of the Lord, let him die the death: let all the congregation of Israel stone him with stones; whether he be a stranger or a native, let him die for naming the name of the Lord.","searchKeywords":["and","that","names","the","name","lord","let","him","die","death","all","congregation","israel","stone","with","stones","whether","stranger","native","for","naming"]},{"verseId":"brenton_leviticus_24_17","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":17,"text":"And whosoever shall smite a man and he die, let him die the death.","searchKeywords":["and","whosoever","shall","smite","man","die","let","him","the","death"]},{"verseId":"brenton_leviticus_24_18","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":18,"text":"And whosoever shall smite a beast, and it shall die, let him render life for life.","searchKeywords":["and","whosoever","shall","smite","beast","die","let","him","render","life","for"]},{"verseId":"brenton_leviticus_24_19","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":19,"text":"And whosoever shall inflict a blemish on his neighbour, as he has done to him, so shall it be done to himself in return;","searchKeywords":["and","whosoever","shall","inflict","blemish","his","neighbour","has","done","him","himself","return"]},{"verseId":"brenton_leviticus_24_20","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":20,"text":"bruise for bruise, eye for eye, tooth for tooth: as any one may inflict a blemish on a man, so shall it be rendered to him.","searchKeywords":["bruise","for","eye","tooth","any","one","may","inflict","blemish","man","shall","rendered","him"]},{"verseId":"brenton_leviticus_24_21","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":21,"text":"Whosoever shall smite a man, and he shall die, let him die the death.","searchKeywords":["whosoever","shall","smite","man","and","die","let","him","the","death"]},{"verseId":"brenton_leviticus_24_22","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":22,"text":"There shall be one judgment for the stranger and the native, for I the Lord your God.","searchKeywords":["there","shall","one","judgment","for","the","stranger","and","native","lord","your","god"]},{"verseId":"brenton_leviticus_24_23","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":24,"verse":23,"text":"And Moses spoke to the children of Israel, and they brought him that had cursed out of the camp, and stoned him with stones: and the children of Israel did as the Lord commanded Moses.","searchKeywords":["and","moses","spoke","the","children","israel","they","brought","him","that","had","cursed","out","camp","stoned","with","stones","did","lord","commanded"]}]