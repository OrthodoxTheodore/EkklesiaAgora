[{"verseId":"brenton_leviticus_21_1","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":1,"text":"And the Lord spoke to Moses, saying, Speak to the priests the sons of Aaron, and thou shalt tell them they shall not defile themselves in their nation for the dead,","searchKeywords":["and","the","lord","spoke","moses","saying","speak","priests","sons","aaron","thou","shalt","tell","them","they","shall","not","defile","themselves","their","nation","for","dead"]},{"verseId":"brenton_leviticus_21_2","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":2,"text":"but for a relative who is very near to them, for a father and mother, and sons and daughters, for a brother,","searchKeywords":["but","for","relative","who","very","near","them","father","and","mother","sons","daughters","brother"]},{"verseId":"brenton_leviticus_21_3","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":3,"text":"and for a virgin sister that is near to one, that is not espoused to a man; for these one shall defile himself.","searchKeywords":["and","for","virgin","sister","that","near","one","not","espoused","man","these","shall","defile","himself"]},{"verseId":"brenton_leviticus_21_4","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":4,"text":"He shall not defile himself suddenly among his people to profane himself.","searchKeywords":["shall","not","defile","himself","suddenly","among","his","people","profane"]},{"verseId":"brenton_leviticus_21_5","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":5,"text":"And ye shall not shave your head for the dead with a baldness on the top; and they shall not shave their beard, neither shall they make gashes on their flesh.","searchKeywords":["and","shall","not","shave","your","head","for","the","dead","with","baldness","top","they","their","beard","neither","make","gashes","flesh"]},{"verseId":"brenton_leviticus_21_6","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":6,"text":"They shall be holy to their God, and they shall not profane the name of their God; for they offer the sacrifices of the Lord as the gifts of their God, and they shall be holy.","searchKeywords":["they","shall","holy","their","god","and","not","profane","the","name","for","offer","sacrifices","lord","gifts"]},{"verseId":"brenton_leviticus_21_7","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":7,"text":"They shall not take a woman who is a harlot and profaned, or a woman put away from her husband; for he is holy to the Lord his God.","searchKeywords":["they","shall","not","take","woman","who","harlot","and","profaned","put","away","from","her","husband","for","holy","the","lord","his","god"]},{"verseId":"brenton_leviticus_21_8","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":8,"text":"And thou shalt hallow him; he offers the gifts of the Lord your God: he shall be holy, for I the Lord that sanctify them holy.","searchKeywords":["and","thou","shalt","hallow","him","offers","the","gifts","lord","your","god","shall","holy","for","that","sanctify","them"]},{"verseId":"brenton_leviticus_21_9","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":9,"text":"And if the daughter of a priest should be profaned to go a whoring, she profanes the name of her father: she shall be burnt with fire.","searchKeywords":["and","the","daughter","priest","should","profaned","whoring","she","profanes","name","her","father","shall","burnt","with","fire"]},{"verseId":"brenton_leviticus_21_10","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":10,"text":"And the priest that is chief among his brethren, the oil having been poured upon the head of the anointed one, and he having been consecrated to put on the garments, shall not take the mitre off his head, and shall not rend his garments:","searchKeywords":["and","the","priest","that","chief","among","his","brethren","oil","having","been","poured","upon","head","anointed","one","consecrated","put","garments","shall","not","take","mitre","off","rend"]},{"verseId":"brenton_leviticus_21_11","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":11,"text":"neither shall he go in to any dead body, neither shall he defile himself for his father or his mother.","searchKeywords":["neither","shall","any","dead","body","defile","himself","for","his","father","mother"]},{"verseId":"brenton_leviticus_21_12","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":12,"text":"And he shall not go forth out of the sanctuary, and he shall not profane the sanctuary of his God, because the holy anointing oil of God upon him: I the Lord.","searchKeywords":["and","shall","not","forth","out","the","sanctuary","profane","his","god","because","holy","anointing","oil","upon","him","lord"]},{"verseId":"brenton_leviticus_21_13","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":13,"text":"He shall take for a wife a virgin of his own tribe.","searchKeywords":["shall","take","for","wife","virgin","his","own","tribe"]},{"verseId":"brenton_leviticus_21_14","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":14,"text":"But a widow, or one that is put away, or profaned, or a harlot, these he shall not take; but he shall take for a wife a virgin of his own people.","searchKeywords":["but","widow","one","that","put","away","profaned","harlot","these","shall","not","take","for","wife","virgin","his","own","people"]},{"verseId":"brenton_leviticus_21_15","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":15,"text":"And he shall not profane his seed among his people: I the Lord that sanctifies him.","searchKeywords":["and","shall","not","profane","his","seed","among","people","the","lord","that","sanctifies","him"]},{"verseId":"brenton_leviticus_21_16","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":16,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_leviticus_21_17","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":17,"text":"Say to Aaron, A man of thy tribe throughout your generations, who shall have a blemish on him, shall not draw nigh to offer the gifts of his God.","searchKeywords":["say","aaron","man","thy","tribe","throughout","your","generations","who","shall","have","blemish","him","not","draw","nigh","offer","the","gifts","his","god"]},{"verseId":"brenton_leviticus_21_18","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":18,"text":"No man who has a blemish on him shall draw nigh; a man lame, blind, with his nose disfigured, or his ears cut,","searchKeywords":["man","who","has","blemish","him","shall","draw","nigh","lame","blind","with","his","nose","disfigured","ears","cut"]},{"verseId":"brenton_leviticus_21_19","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":19,"text":"a man who has a broken hand or a broken foot,","searchKeywords":["man","who","has","broken","hand","foot"]},{"verseId":"brenton_leviticus_21_20","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":20,"text":"or hump-backed, or blear-eyed, or that has lost his eye-lashes, or a man who has a malignant ulcer, or tetter, or one that has lost a testicle.","searchKeywords":["hump","backed","blear","eyed","that","has","lost","his","eye","lashes","man","who","malignant","ulcer","tetter","one","testicle"]},{"verseId":"brenton_leviticus_21_21","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":21,"text":"Whoever of the seed of Aaron the priest has a blemish on him, shall not draw nigh to offer sacrifices to thy God, because he has a blemish on him; he shall not draw nigh to offer the gifts of God.","searchKeywords":["whoever","the","seed","aaron","priest","has","blemish","him","shall","not","draw","nigh","offer","sacrifices","thy","god","because","gifts"]},{"verseId":"brenton_leviticus_21_22","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":22,"text":"The gifts of God most holy, and he shall eat of the holy things.","searchKeywords":["the","gifts","god","most","holy","and","shall","eat","things"]},{"verseId":"brenton_leviticus_21_23","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":23,"text":"Only he shall not approach the veil, and he shall not draw nigh to the altar, because he has a blemish; and he shall not profane the sanctuary of his God, for I am the Lord that sanctifies them.","searchKeywords":["only","shall","not","approach","the","veil","and","draw","nigh","altar","because","has","blemish","profane","sanctuary","his","god","for","lord","that","sanctifies","them"]},{"verseId":"brenton_leviticus_21_24","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":21,"verse":24,"text":"And Moses spoke to Aaron and his sons, and to all the children of Israel.","searchKeywords":["and","moses","spoke","aaron","his","sons","all","the","children","israel"]}]