[{"verseId":"brenton_leviticus_19_1","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":1,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_leviticus_19_2","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":2,"text":"Speak to the congregation of the children of Israel, and thou shalt say to them, Ye shall be holy; for I the Lord your God holy.","searchKeywords":["speak","the","congregation","children","israel","and","thou","shalt","say","them","shall","holy","for","lord","your","god"]},{"verseId":"brenton_leviticus_19_3","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":3,"text":"Let every one of you reverence his father and his mother; and ye shall keep my sabbaths: I the Lord your God.","searchKeywords":["let","every","one","you","reverence","his","father","and","mother","shall","keep","sabbaths","the","lord","your","god"]},{"verseId":"brenton_leviticus_19_4","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":4,"text":"Ye shall not follow idols, and ye shall not make to yourselves molten gods: I the Lord your God.","searchKeywords":["shall","not","follow","idols","and","make","yourselves","molten","gods","the","lord","your","god"]},{"verseId":"brenton_leviticus_19_5","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":5,"text":"And if ye will sacrifice a peace-offering to the Lord, ye shall offer it acceptable from yourselves.","searchKeywords":["and","will","sacrifice","peace","offering","the","lord","shall","offer","acceptable","from","yourselves"]},{"verseId":"brenton_leviticus_19_6","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":6,"text":"In what day soever ye shall sacrifice it, it shall be eaten; and on the following day, and if any of it should be left till the third day, it shall be thoroughly burnt with fire.","searchKeywords":["what","day","soever","shall","sacrifice","eaten","and","the","following","any","should","left","till","third","thoroughly","burnt","with","fire"]},{"verseId":"brenton_leviticus_19_7","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":7,"text":"And if it should be at all eaten on the third day, it is unfit for sacrifice: it shall not be accepted.","searchKeywords":["and","should","all","eaten","the","third","day","unfit","for","sacrifice","shall","not","accepted"]},{"verseId":"brenton_leviticus_19_8","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":8,"text":"And he that eats it shall bear his iniquity, because he has profaned the holy things of the Lord; and the souls that eat it shall be destroyed from among their people.","searchKeywords":["and","that","eats","shall","bear","his","iniquity","because","has","profaned","the","holy","things","lord","souls","eat","destroyed","from","among","their","people"]},{"verseId":"brenton_leviticus_19_9","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":9,"text":"And when ye reap the harvest of your land, ye shall not complete the reaping of your field with exactness, and thou shalt not gather that which falls from thy reaping.","searchKeywords":["and","when","reap","the","harvest","your","land","shall","not","complete","reaping","field","with","exactness","thou","shalt","gather","that","which","falls","from","thy"]},{"verseId":"brenton_leviticus_19_10","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":10,"text":"And thou shalt not go over the gathering of thy vineyard, neither shalt thou gather the remaining grapes of thy vineyard: thou shalt leave them for the poor and the stranger: I am the Lord your God.","searchKeywords":["and","thou","shalt","not","over","the","gathering","thy","vineyard","neither","gather","remaining","grapes","leave","them","for","poor","stranger","lord","your","god"]},{"verseId":"brenton_leviticus_19_11","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":11,"text":"Ye shall not steal, ye shall not lie, neither shall one bear false witness as an informer against his neighbour.","searchKeywords":["shall","not","steal","lie","neither","one","bear","false","witness","informer","against","his","neighbour"]},{"verseId":"brenton_leviticus_19_12","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":12,"text":"And ye shall not swear unjustly by my name, and ye shall not profane the holy name of your God: I am the Lord your God.","searchKeywords":["and","shall","not","swear","unjustly","name","profane","the","holy","your","god","lord"]},{"verseId":"brenton_leviticus_19_13","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":13,"text":"Thou shalt not injure thy neighbour, neither do thou rob , neither shall the wages of thy hireling remain with thee until the morning.","searchKeywords":["thou","shalt","not","injure","thy","neighbour","neither","rob","shall","the","wages","hireling","remain","with","thee","until","morning"]},{"verseId":"brenton_leviticus_19_14","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":14,"text":"Thou shalt not revile the deaf, neither shalt thou put a stumbling-block in the way of the blind; and thou shalt fear the Lord thy God: I am the Lord your God.","searchKeywords":["thou","shalt","not","revile","the","deaf","neither","put","stumbling","block","way","blind","and","fear","lord","thy","god","your"]},{"verseId":"brenton_leviticus_19_15","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":15,"text":"Thou shalt not act unjustly in judgment: thou shalt not accept the person of the poor, nor admire the person of the mighty; with justice shalt thou judge thy neighbour.","searchKeywords":["thou","shalt","not","act","unjustly","judgment","accept","the","person","poor","nor","admire","mighty","with","justice","judge","thy","neighbour"]},{"verseId":"brenton_leviticus_19_16","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":16,"text":"Thou shalt not walk deceitfully among thy people; thou shalt not rise up against the blood of thy neighbour: I am the Lord your God.","searchKeywords":["thou","shalt","not","walk","deceitfully","among","thy","people","rise","against","the","blood","neighbour","lord","your","god"]},{"verseId":"brenton_leviticus_19_17","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":17,"text":"Thou shalt not hate thy brother in thine heart: thou shalt in any wise rebuke thy neighbour, so thou shalt not bear sin on his account.","searchKeywords":["thou","shalt","not","hate","thy","brother","thine","heart","any","wise","rebuke","neighbour","bear","sin","his","account"]},{"verseId":"brenton_leviticus_19_18","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":18,"text":"And thy hand shall not avenge thee; and thou shalt not be angry with the children of thy people; and thou shalt love thy neighbour as thyself; I am the Lord.","searchKeywords":["and","thy","hand","shall","not","avenge","thee","thou","shalt","angry","with","the","children","people","love","neighbour","thyself","lord"]},{"verseId":"brenton_leviticus_19_19","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":19,"text":"Ye shall observe my law: thou shalt not let thy cattle gender with one of a different kind, and thou shalt not sow thy vineyard with diverse seed; and thou shalt not put upon thyself a mingled garment woven of two .","searchKeywords":["shall","observe","law","thou","shalt","not","let","thy","cattle","gender","with","one","different","kind","and","sow","vineyard","diverse","seed","put","upon","thyself","mingled","garment","woven","two"]},{"verseId":"brenton_leviticus_19_20","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":20,"text":"And if any one lie carnally with a woman, and she should be a home-servant kept for a man, and she has not been ransomed, her freedom has not been given to her, they shall be visited ; but they shall not die, because she was not set at liberty.","searchKeywords":["and","any","one","lie","carnally","with","woman","she","should","home","servant","kept","for","man","has","not","been","ransomed","her","freedom","given","they","shall","visited","but","die","because","was","set","liberty"]},{"verseId":"brenton_leviticus_19_21","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":21,"text":"And he shall bring for his trespass to the Lord to the door of the tabernacle of witness, a ram for a trespass-offering.","searchKeywords":["and","shall","bring","for","his","trespass","the","lord","door","tabernacle","witness","ram","offering"]},{"verseId":"brenton_leviticus_19_22","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":22,"text":"And the priest shall make atonement for him with the ram of the trespass-offering, before the Lord, for the sin which he sinned; and the sin which he sinned shall be forgiven him.","searchKeywords":["and","the","priest","shall","make","atonement","for","him","with","ram","trespass","offering","before","lord","sin","which","sinned","forgiven"]},{"verseId":"brenton_leviticus_19_23","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":23,"text":"And whenever ye shall enter into the land which the Lord your God gives you, and shall plant any fruit-tree, then shall ye purge away its uncleanness; its fruit shall be three years uncleansed to you, it shall not be eaten.","searchKeywords":["and","whenever","shall","enter","into","the","land","which","lord","your","god","gives","you","plant","any","fruit","tree","then","purge","away","its","uncleanness","three","years","uncleansed","not","eaten"]},{"verseId":"brenton_leviticus_19_24","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":24,"text":"And in the fourth year all its fruit shall be holy, a subject of praise to the Lord.","searchKeywords":["and","the","fourth","year","all","its","fruit","shall","holy","subject","praise","lord"]},{"verseId":"brenton_leviticus_19_25","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":25,"text":"And in the fifth year ye shall eat the fruit, its produce is an increase to you. I am the Lord your God.","searchKeywords":["and","the","fifth","year","shall","eat","fruit","its","produce","increase","you","lord","your","god"]},{"verseId":"brenton_leviticus_19_26","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":26,"text":"Eat not on the mountains, nor shall ye employ auguries, nor divine by inspection of birds.","searchKeywords":["eat","not","the","mountains","nor","shall","employ","auguries","divine","inspection","birds"]},{"verseId":"brenton_leviticus_19_27","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":27,"text":"Ye shall not make a round cutting of the hair of your head, nor disfigure your beard.","searchKeywords":["shall","not","make","round","cutting","the","hair","your","head","nor","disfigure","beard"]},{"verseId":"brenton_leviticus_19_28","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":28,"text":"And ye shall not make cuttings in your body for a body, and ye shall not inscribe on yourselves any marks. I am the Lord your God.","searchKeywords":["and","shall","not","make","cuttings","your","body","for","inscribe","yourselves","any","marks","the","lord","god"]},{"verseId":"brenton_leviticus_19_29","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":29,"text":"Thou shalt not profane thy daughter to prostitute her; so the land shall not go a whoring, and the land be filled with iniquity.","searchKeywords":["thou","shalt","not","profane","thy","daughter","prostitute","her","the","land","shall","whoring","and","filled","with","iniquity"]},{"verseId":"brenton_leviticus_19_30","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":30,"text":"Ye shall keep my sabbaths, and reverence my sanctuaries: I am the Lord.","searchKeywords":["shall","keep","sabbaths","and","reverence","sanctuaries","the","lord"]},{"verseId":"brenton_leviticus_19_31","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":31,"text":"Ye shall not attend to those who have in them divining spirits, nor attach yourselves to enchanters, to pollute yourselves with them: I am the Lord your God.","searchKeywords":["shall","not","attend","those","who","have","them","divining","spirits","nor","attach","yourselves","enchanters","pollute","with","the","lord","your","god"]},{"verseId":"brenton_leviticus_19_32","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":32,"text":"Thou shalt rise up before the hoary head, and honour the face of the old man, and shalt fear thy God: I am the Lord your God.","searchKeywords":["thou","shalt","rise","before","the","hoary","head","and","honour","face","old","man","fear","thy","god","lord","your"]},{"verseId":"brenton_leviticus_19_33","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":33,"text":"And if there should come to you a stranger in your land, ye shall not afflict him.","searchKeywords":["and","there","should","come","you","stranger","your","land","shall","not","afflict","him"]},{"verseId":"brenton_leviticus_19_34","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":34,"text":"The stranger that comes to you shall be among you as the native, and thou shalt love him as thyself; for ye were strangers in the land of Egypt: I am the Lord your God.","searchKeywords":["the","stranger","that","comes","you","shall","among","native","and","thou","shalt","love","him","thyself","for","were","strangers","land","egypt","lord","your","god"]},{"verseId":"brenton_leviticus_19_35","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":35,"text":"Ye shall not act unrighteously in judgment, in measures and weights and scales.","searchKeywords":["shall","not","act","unrighteously","judgment","measures","and","weights","scales"]},{"verseId":"brenton_leviticus_19_36","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":36,"text":"There shall be among you just balances and just weights and a just liquid measure. I am the Lord your God, who brought you out of the land of Egypt.","searchKeywords":["there","shall","among","you","just","balances","and","weights","liquid","measure","the","lord","your","god","who","brought","out","land","egypt"]},{"verseId":"brenton_leviticus_19_37","translationId":"brenton","testament":"OT","bookIndex":3,"bookName":"Leviticus","bookAbbrev":"leviticus","chapter":19,"verse":37,"text":"And ye shall keep all my law and all my ordinances, and ye shall do them: I am the Lord your God.","searchKeywords":["and","shall","keep","all","law","ordinances","them","the","lord","your","god"]}]