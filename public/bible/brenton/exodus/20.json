[{"verseId":"brenton_exodus_20_1","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":1,"text":"And the Lord spoke all these words, saying:","searchKeywords":["and","the","lord","spoke","all","these","words","saying"]},{"verseId":"brenton_exodus_20_2","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":2,"text":"I am the Lord thy God, who brought thee out of the land of Egypt, out of the house of bondage.","searchKeywords":["the","lord","thy","god","who","brought","thee","out","land","egypt","house","bondage"]},{"verseId":"brenton_exodus_20_3","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":3,"text":"Thou shalt have no other gods beside me.","searchKeywords":["thou","shalt","have","other","gods","beside"]},{"verseId":"brenton_exodus_20_4","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":4,"text":"Thou shalt not make to thyself an idol, nor likeness of anything, whatever things are in the heaven above, and whatever are in the earth beneath, and whatever are in the waters under the earth.","searchKeywords":["thou","shalt","not","make","thyself","idol","nor","likeness","anything","whatever","things","are","the","heaven","above","and","earth","beneath","waters","under"]},{"verseId":"brenton_exodus_20_5","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":5,"text":"Thou shalt not bow down to them, nor serve them; for I am the Lord thy God, a jealous God, recompensing the sins of the fathers upon the children, to the third and fourth generation to them that hate me,","searchKeywords":["thou","shalt","not","bow","down","them","nor","serve","for","the","lord","thy","god","jealous","recompensing","sins","fathers","upon","children","third","and","fourth","generation","that","hate"]},{"verseId":"brenton_exodus_20_6","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":6,"text":"and bestowing mercy on them that love me to thousands , and on them that keep my commandments.","searchKeywords":["and","bestowing","mercy","them","that","love","thousands","keep","commandments"]},{"verseId":"brenton_exodus_20_7","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":7,"text":"Thou shalt not take the name of the Lord thy God in vain; for the Lord thy God will not acquit him that takes his name in vain.","searchKeywords":["thou","shalt","not","take","the","name","lord","thy","god","vain","for","will","acquit","him","that","takes","his"]},{"verseId":"brenton_exodus_20_8","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":8,"text":"Remember the sabbath day to keep it holy.","searchKeywords":["remember","the","sabbath","day","keep","holy"]},{"verseId":"brenton_exodus_20_9","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":9,"text":"Six days thou shalt labour, and shalt perform all thy work.","searchKeywords":["six","days","thou","shalt","labour","and","perform","all","thy","work"]},{"verseId":"brenton_exodus_20_10","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":10,"text":"But on the seventh day is the sabbath of the Lord thy God; on it thou shalt do no work, thou, nor thy son, nor thy daughter, thy servant nor thy maidservant, thine ox nor thine ass, nor any cattle of thine, nor the stranger that sojourns with thee.","searchKeywords":["but","the","seventh","day","sabbath","lord","thy","god","thou","shalt","work","nor","son","daughter","servant","maidservant","thine","ass","any","cattle","stranger","that","sojourns","with","thee"]},{"verseId":"brenton_exodus_20_11","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":11,"text":"For in six days the Lord made the heaven and the earth, and the sea and all things in them, and rested on the seventh day; therefore the Lord blessed the seventh day, and hallowed it.","searchKeywords":["for","six","days","the","lord","made","heaven","and","earth","sea","all","things","them","rested","seventh","day","therefore","blessed","hallowed"]},{"verseId":"brenton_exodus_20_12","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":12,"text":"Honour thy father and thy mother, that it may be well with thee, and that thou mayest live long on the good land, which the Lord thy God gives to thee.","searchKeywords":["honour","thy","father","and","mother","that","may","well","with","thee","thou","mayest","live","long","the","good","land","which","lord","god","gives"]},{"verseId":"brenton_exodus_20_13","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":13,"text":"Thou shalt not commit adultery.","searchKeywords":["thou","shalt","not","commit","adultery"]},{"verseId":"brenton_exodus_20_14","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":14,"text":"Thou shalt not steal.","searchKeywords":["thou","shalt","not","steal"]},{"verseId":"brenton_exodus_20_15","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":15,"text":"Thou shalt not kill.","searchKeywords":["thou","shalt","not","kill"]},{"verseId":"brenton_exodus_20_16","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":16,"text":"Thou shalt not bear false witness against thy neighbour.","searchKeywords":["thou","shalt","not","bear","false","witness","against","thy","neighbour"]},{"verseId":"brenton_exodus_20_17","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":17,"text":"Thou shalt not covet thy neighbour's wife; thou shalt not covet thy neighbour's house; nor his field, nor his servant, nor his maid, nor his ox, nor his ass, nor any of his cattle, nor whatever belongs to thy neighbour.","searchKeywords":["thou","shalt","not","covet","thy","neighbour","wife","house","nor","his","field","servant","maid","ass","any","cattle","whatever","belongs"]},{"verseId":"brenton_exodus_20_18","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":18,"text":"And all the people perceived the thundering, and the flashes, and the voice of the trumpet, and the mountain smoking; and all the people feared and stood afar off,","searchKeywords":["and","all","the","people","perceived","thundering","flashes","voice","trumpet","mountain","smoking","feared","stood","afar","off"]},{"verseId":"brenton_exodus_20_19","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":19,"text":"and said to Moses, Speak thou to us, and let not God speak to us, lest we die.","searchKeywords":["and","said","moses","speak","thou","let","not","god","lest","die"]},{"verseId":"brenton_exodus_20_20","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":20,"text":"And Moses says to them, Be of good courage, for God is come to you to try you, that his fear may be among you, that ye sin not.","searchKeywords":["and","moses","says","them","good","courage","for","god","come","you","try","that","his","fear","may","among","sin","not"]},{"verseId":"brenton_exodus_20_21","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":21,"text":"And the people stood afar off, and Moses went into the darkness where God was.","searchKeywords":["and","the","people","stood","afar","off","moses","went","into","darkness","where","god","was"]},{"verseId":"brenton_exodus_20_22","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":22,"text":"And the Lord said to Moses, Thus shalt thou say to the house of Jacob, and thou shalt report it to the children of Israel, Ye have seen that I have spoken to you from heaven.","searchKeywords":["and","the","lord","said","moses","thus","shalt","thou","say","house","jacob","report","children","israel","have","seen","that","spoken","you","from","heaven"]},{"verseId":"brenton_exodus_20_23","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":23,"text":"Ye shall not make to yourselves gods of silver, and gods of gold ye shall not make to yourselves.","searchKeywords":["shall","not","make","yourselves","gods","silver","and","gold"]},{"verseId":"brenton_exodus_20_24","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":24,"text":"Ye shall make to me an altar of earth; and upon it ye shall sacrifice your whole burnt-offerings, and your peace-offerings, and your sheep and your calves in every place, where I shall record my name; and I will come to thee and bless thee.","searchKeywords":["shall","make","altar","earth","and","upon","sacrifice","your","whole","burnt","offerings","peace","sheep","calves","every","place","where","record","name","will","come","thee","bless"]},{"verseId":"brenton_exodus_20_25","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":25,"text":"And if thou wilt make to me an altar of stones, thou shalt not build them hewn ; for thou hast lifted up thy tool upon them, and they are defiled.","searchKeywords":["and","thou","wilt","make","altar","stones","shalt","not","build","them","hewn","for","hast","lifted","thy","tool","upon","they","are","defiled"]},{"verseId":"brenton_exodus_20_26","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":20,"verse":26,"text":"Thou shalt not go up to my altar by steps, that thou mayest not uncover thy nakedness upon it.","searchKeywords":["thou","shalt","not","altar","steps","that","mayest","uncover","thy","nakedness","upon"]}]