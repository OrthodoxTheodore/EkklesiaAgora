[{"verseId":"brenton_exodus_40_1","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":1,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_exodus_40_2","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":2,"text":"On the first day of the first month, at the new moon, thou shalt set up the tabernacle of witness,","searchKeywords":["the","first","day","month","new","moon","thou","shalt","set","tabernacle","witness"]},{"verseId":"brenton_exodus_40_3","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":3,"text":"and thou shalt place the ark of the testimony, and shalt cover the ark with the veil,","searchKeywords":["and","thou","shalt","place","the","ark","testimony","cover","with","veil"]},{"verseId":"brenton_exodus_40_4","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":4,"text":"and thou shalt bring in the table and shalt set forth that which is to be set forth on it; and thou shalt bring in the candlestick and place its lamps on it.","searchKeywords":["and","thou","shalt","bring","the","table","set","forth","that","which","candlestick","place","its","lamps"]},{"verseId":"brenton_exodus_40_5","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":5,"text":"And thou shalt place the golden altar, to burn incense before the ark; and thou shalt put a covering of a veil on the door of the tabernacle of witness.","searchKeywords":["and","thou","shalt","place","the","golden","altar","burn","incense","before","ark","put","covering","veil","door","tabernacle","witness"]},{"verseId":"brenton_exodus_40_6","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":6,"text":"And thou shalt put the altar of burnt-offerings by the doors of the tabernacle of witness,","searchKeywords":["and","thou","shalt","put","the","altar","burnt","offerings","doors","tabernacle","witness"]},{"verseId":"brenton_exodus_40_8","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":8,"text":"and thou shalt set up the tabernacle round about, and thou shalt hallow all that belongs to it round about.","searchKeywords":["and","thou","shalt","set","the","tabernacle","round","about","hallow","all","that","belongs"]},{"verseId":"brenton_exodus_40_9","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":9,"text":"And thou shalt take the anointing oil, and shalt anoint the tabernacle, and all things in it; and shalt sanctify it, and all its furniture, and it shall be holy.","searchKeywords":["and","thou","shalt","take","the","anointing","oil","anoint","tabernacle","all","things","sanctify","its","furniture","shall","holy"]},{"verseId":"brenton_exodus_40_10","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":10,"text":"And thou shalt anoint the altar of burnt-offerings, and all its furniture; and thou shalt hallow the altar, and the altar shall be most holy.","searchKeywords":["and","thou","shalt","anoint","the","altar","burnt","offerings","all","its","furniture","hallow","shall","most","holy"]},{"verseId":"brenton_exodus_40_12","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":12,"text":"And thou shalt bring Aaron and his sons to the doors of the tabernacle of witness, and thou shalt wash them with water.","searchKeywords":["and","thou","shalt","bring","aaron","his","sons","the","doors","tabernacle","witness","wash","them","with","water"]},{"verseId":"brenton_exodus_40_13","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":13,"text":"And thou shalt put on Aaron the holy garments, and thou shalt anoint him, and thou shalt sanctify him, and he shall minister to me as priest.","searchKeywords":["and","thou","shalt","put","aaron","the","holy","garments","anoint","him","sanctify","shall","minister","priest"]},{"verseId":"brenton_exodus_40_14","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":14,"text":"And thou shalt bring up his sons, and shalt put garments on them.","searchKeywords":["and","thou","shalt","bring","his","sons","put","garments","them"]},{"verseId":"brenton_exodus_40_15","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":15,"text":"And thou shalt anoint them as thou didst anoint their father, and they shall minister to me as priests; and it shall be that they shall have an everlasting anointing of priesthood, throughout their generations.","searchKeywords":["and","thou","shalt","anoint","them","didst","their","father","they","shall","minister","priests","that","have","everlasting","anointing","priesthood","throughout","generations"]},{"verseId":"brenton_exodus_40_16","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":16,"text":"And Moses did all things whatsoever the Lord commanded him, so did he.","searchKeywords":["and","moses","did","all","things","whatsoever","the","lord","commanded","him"]},{"verseId":"brenton_exodus_40_17","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":17,"text":"And it came to pass in the first month, in the second year after their going forth out of Egypt, at the new moon, that the tabernacle was set up.","searchKeywords":["and","came","pass","the","first","month","second","year","after","their","going","forth","out","egypt","new","moon","that","tabernacle","was","set"]},{"verseId":"brenton_exodus_40_18","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":18,"text":"And Moses set up the tabernacle, and put on the chapiters, and put the bars into their places, and set up the posts.","searchKeywords":["and","moses","set","the","tabernacle","put","chapiters","bars","into","their","places","posts"]},{"verseId":"brenton_exodus_40_19","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":19,"text":"And he stretched out the curtains over the tabernacle, and put the veil of the tabernacle on it above as the Lord commanded Moses.","searchKeywords":["and","stretched","out","the","curtains","over","tabernacle","put","veil","above","lord","commanded","moses"]},{"verseId":"brenton_exodus_40_20","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":20,"text":"And he took the testimonies, and put them into the ark; and he put the staves by the sides of the ark.","searchKeywords":["and","took","the","testimonies","put","them","into","ark","staves","sides"]},{"verseId":"brenton_exodus_40_21","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":21,"text":"And he brought the ark into the tabernacle, and put on the covering of the veil, and covered the ark of the testimony, as the Lord commanded Moses.","searchKeywords":["and","brought","the","ark","into","tabernacle","put","covering","veil","covered","testimony","lord","commanded","moses"]},{"verseId":"brenton_exodus_40_22","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":22,"text":"And he put the table in the tabernacle of witness, on the north side without the veil of the tabernacle.","searchKeywords":["and","put","the","table","tabernacle","witness","north","side","without","veil"]},{"verseId":"brenton_exodus_40_23","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":23,"text":"And he put on it the shewbread before the Lord, as the Lord commanded Moses.","searchKeywords":["and","put","the","shewbread","before","lord","commanded","moses"]},{"verseId":"brenton_exodus_40_24","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":24,"text":"And he put the candlestick into the tabernacle of witness, on the side of the tabernacle toward the south.","searchKeywords":["and","put","the","candlestick","into","tabernacle","witness","side","toward","south"]},{"verseId":"brenton_exodus_40_25","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":25,"text":"And he put on it its lamps before the Lord, as the Lord had commanded Moses.","searchKeywords":["and","put","its","lamps","before","the","lord","had","commanded","moses"]},{"verseId":"brenton_exodus_40_26","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":26,"text":"And he put the golden altar in the tabernacle of witness before the veil;","searchKeywords":["and","put","the","golden","altar","tabernacle","witness","before","veil"]},{"verseId":"brenton_exodus_40_27","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":27,"text":"and he burnt on it incense of composition, as the Lord commanded Moses.","searchKeywords":["and","burnt","incense","composition","the","lord","commanded","moses"]},{"verseId":"brenton_exodus_40_29","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":29,"text":"And he put the altar of the burnt-offerings by the doors of the tabernacle.","searchKeywords":["and","put","the","altar","burnt","offerings","doors","tabernacle"]},{"verseId":"brenton_exodus_40_33","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":33,"text":"And he set up the court round about the tabernacle and the altar; and Moses accomplished all the works.","searchKeywords":["and","set","the","court","round","about","tabernacle","altar","moses","accomplished","all","works"]},{"verseId":"brenton_exodus_40_34","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":34,"text":"And the cloud covered the tabernacle of witness, and the tabernacle was filled with the glory of the Lord.","searchKeywords":["and","the","cloud","covered","tabernacle","witness","was","filled","with","glory","lord"]},{"verseId":"brenton_exodus_40_35","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":35,"text":"And Moses was not able to enter into the tabernacle of testimony, because the cloud overshadowed it, and the tabernacle was filled with the glory of the Lord.","searchKeywords":["and","moses","was","not","able","enter","into","the","tabernacle","testimony","because","cloud","overshadowed","filled","with","glory","lord"]},{"verseId":"brenton_exodus_40_36","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":36,"text":"And when the cloud went up from the tabernacle, the children of Israel prepared to depart with their baggage.","searchKeywords":["and","when","the","cloud","went","from","tabernacle","children","israel","prepared","depart","with","their","baggage"]},{"verseId":"brenton_exodus_40_37","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":37,"text":"And if the cloud went not up, they did not prepare to depart, till the day when the cloud went up.","searchKeywords":["and","the","cloud","went","not","they","did","prepare","depart","till","day","when"]},{"verseId":"brenton_exodus_40_38","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":40,"verse":38,"text":"For a cloud was on the tabernacle by day, and fire was on it by night before all Israel, in all their journeyings.","searchKeywords":["for","cloud","was","the","tabernacle","day","and","fire","night","before","all","israel","their","journeyings"]}]