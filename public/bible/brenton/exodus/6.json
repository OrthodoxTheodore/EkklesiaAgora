[{"verseId":"brenton_exodus_6_1","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":1,"text":"And the Lord said to Moses, Now thou shalt see what I will do to Pharao; for he shall send them forth with a mighty hand, and with a high arm shall he cast them out of his land.","searchKeywords":["and","the","lord","said","moses","now","thou","shalt","see","what","will","pharao","for","shall","send","them","forth","with","mighty","hand","high","arm","cast","out","his","land"]},{"verseId":"brenton_exodus_6_2","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":2,"text":"And God spoke to Moses and said to him, I the Lord.","searchKeywords":["and","god","spoke","moses","said","him","the","lord"]},{"verseId":"brenton_exodus_6_3","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":3,"text":"And I appeared to Abraam and Isaac and Jacob, being their God, but I did not manifest to them my name Lord.","searchKeywords":["and","appeared","abraam","isaac","jacob","being","their","god","but","did","not","manifest","them","name","lord"]},{"verseId":"brenton_exodus_6_4","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":4,"text":"And I established my covenant with them, to give them the land of the Chananites, the land wherein they sojourned, in which also they dwelt as strangers.","searchKeywords":["and","established","covenant","with","them","give","the","land","chananites","wherein","they","sojourned","which","also","dwelt","strangers"]},{"verseId":"brenton_exodus_6_5","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":5,"text":"And I hearkened to the groaning of the children of Israel (the affliction with which the Egyptians enslave them) and I remembered the covenant with you.","searchKeywords":["and","hearkened","the","groaning","children","israel","affliction","with","which","egyptians","enslave","them","remembered","covenant","you"]},{"verseId":"brenton_exodus_6_6","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":6,"text":"Go, speak to the children of Israel, saying, I the Lord; and I will lead you forth from the tyranny of the Egyptians, and I will deliver you from bondage, and I will ransom you with a high arm, and great judgment.","searchKeywords":["speak","the","children","israel","saying","lord","and","will","lead","you","forth","from","tyranny","egyptians","deliver","bondage","ransom","with","high","arm","great","judgment"]},{"verseId":"brenton_exodus_6_7","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":7,"text":"And I will take you to me a people for myself, and will be your God; and ye shall know that I am the Lord your God, who brought you out from the tyranny of the Egyptians.","searchKeywords":["and","will","take","you","people","for","myself","your","god","shall","know","that","the","lord","who","brought","out","from","tyranny","egyptians"]},{"verseId":"brenton_exodus_6_8","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":8,"text":"And I will bring you into the land concerning which I stretched out my hand to give it to Abraam and Isaac and Jacob, and I will give it you for an inheritance: I the Lord.","searchKeywords":["and","will","bring","you","into","the","land","concerning","which","stretched","out","hand","give","abraam","isaac","jacob","for","inheritance","lord"]},{"verseId":"brenton_exodus_6_9","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":9,"text":"And Moses spoke thus to the sons of Israel, and they hearkened not to Moses for faint-heartedness, and for their hard tasks.","searchKeywords":["and","moses","spoke","thus","the","sons","israel","they","hearkened","not","for","faint","heartedness","their","hard","tasks"]},{"verseId":"brenton_exodus_6_10","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":10,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_exodus_6_11","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":11,"text":"Go in, speak to Pharao king of Egypt, that he send forth the children of Israel out of his land.","searchKeywords":["speak","pharao","king","egypt","that","send","forth","the","children","israel","out","his","land"]},{"verseId":"brenton_exodus_6_12","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":12,"text":"And Moses spoke before the Lord, saying, Behold, the children of Israel hearkened not to me, and how shall Pharao hearken to me? and I am not eloquent.","searchKeywords":["and","moses","spoke","before","the","lord","saying","behold","children","israel","hearkened","not","how","shall","pharao","hearken","eloquent"]},{"verseId":"brenton_exodus_6_13","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":13,"text":"And the Lord spoke to Moses and Aaron, and gave them a charge to Pharao king of Egypt, that he should send forth the children of Israel out of the land of Egypt.","searchKeywords":["and","the","lord","spoke","moses","aaron","gave","them","charge","pharao","king","egypt","that","should","send","forth","children","israel","out","land"]},{"verseId":"brenton_exodus_6_14","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":14,"text":"And these are the heads of the houses of their families: the sons of Ruben the first-born of Israel; Enoch and Phallus, Asron, and Charmi, this is the kindred of Ruben.","searchKeywords":["and","these","are","the","heads","houses","their","families","sons","ruben","first","born","israel","enoch","phallus","asron","charmi","this","kindred"]},{"verseId":"brenton_exodus_6_15","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":15,"text":"And the sons of Symeon, Jemuel and Jamin, and Aod, and Jachin and Saar, and Saul the son of a Phœnician woman, these are the families of the sons of Symeon.","searchKeywords":["and","the","sons","symeon","jemuel","jamin","aod","jachin","saar","saul","son","nician","woman","these","are","families"]},{"verseId":"brenton_exodus_6_16","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":16,"text":"And these are the names of the sons of Levi according to their kindreds, Gedson, Caath, and Merari; and the years of the life of Levi were a hundred and thirty-seven.","searchKeywords":["and","these","are","the","names","sons","levi","according","their","kindreds","gedson","caath","merari","years","life","were","hundred","thirty","seven"]},{"verseId":"brenton_exodus_6_17","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":17,"text":"And these are the sons of Gedson, Lobeni and Semei, the houses of their family. And the sons of Caath,","searchKeywords":["and","these","are","the","sons","gedson","lobeni","semei","houses","their","family","caath"]},{"verseId":"brenton_exodus_6_18","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":18,"text":"Ambram and Issaar, Chebron, and Oziel; and the years of the life of Caath were a hundred and thirty-three years.","searchKeywords":["ambram","and","issaar","chebron","oziel","the","years","life","caath","were","hundred","thirty","three"]},{"verseId":"brenton_exodus_6_19","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":19,"text":"And the sons of Merari, Moöli, and Omusi, these are the houses of the families of Levi, according to their kindreds.","searchKeywords":["and","the","sons","merari","omusi","these","are","houses","families","levi","according","their","kindreds"]},{"verseId":"brenton_exodus_6_20","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":20,"text":"And Ambram took to wife Jochabed the daughter of his father's brother, and she bore to him both Aaron and Moses, and Mariam their sister: and the years of the life of Ambram were a hundred and thirty-two years.","searchKeywords":["and","ambram","took","wife","jochabed","the","daughter","his","father","brother","she","bore","him","both","aaron","moses","mariam","their","sister","years","life","were","hundred","thirty","two"]},{"verseId":"brenton_exodus_6_21","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":21,"text":"And the sons of Issaar, Core, and Naphec, and Zechri.","searchKeywords":["and","the","sons","issaar","core","naphec","zechri"]},{"verseId":"brenton_exodus_6_22","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":22,"text":"And the sons of Oziel, Misael, and Elisaphan, and Segri.","searchKeywords":["and","the","sons","oziel","misael","elisaphan","segri"]},{"verseId":"brenton_exodus_6_23","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":23,"text":"And Aaron took to himself to wife Elisabeth daughter of Aminadab sister of Naasson, and she bore to him both Nadab and Abiud, and Eleazar and Ithamar.","searchKeywords":["and","aaron","took","himself","wife","elisabeth","daughter","aminadab","sister","naasson","she","bore","him","both","nadab","abiud","eleazar","ithamar"]},{"verseId":"brenton_exodus_6_24","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":24,"text":"And the sons of Core, Asir, and Elkana, and Abiasar, these are the generations of Core.","searchKeywords":["and","the","sons","core","asir","elkana","abiasar","these","are","generations"]},{"verseId":"brenton_exodus_6_25","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":25,"text":"And Eleazar the son of Aaron took to himself for a wife of the daughters of Phutiel, and she bore to him Phinees. These are the heads of the family of the Levites, according to their generations.","searchKeywords":["and","eleazar","the","son","aaron","took","himself","for","wife","daughters","phutiel","she","bore","him","phinees","these","are","heads","family","levites","according","their","generations"]},{"verseId":"brenton_exodus_6_26","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":26,"text":"This is Aaron and Moses, whom God told to bring out the children of Israel out of the land of Egypt with their forces.","searchKeywords":["this","aaron","and","moses","whom","god","told","bring","out","the","children","israel","land","egypt","with","their","forces"]},{"verseId":"brenton_exodus_6_27","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":27,"text":"These are they that spoke with Pharao king of Egypt, and Aaron himself and Moses brought out the children of Israel from the land of Egypt,","searchKeywords":["these","are","they","that","spoke","with","pharao","king","egypt","and","aaron","himself","moses","brought","out","the","children","israel","from","land"]},{"verseId":"brenton_exodus_6_28","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":28,"text":"in the day in which the Lord spoke to Moses in the land of Egypt;","searchKeywords":["the","day","which","lord","spoke","moses","land","egypt"]},{"verseId":"brenton_exodus_6_29","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":29,"text":"then the Lord spoke to Moses, saying, I am the Lord: speak to Pharao king of Egypt whatsoever I say to thee.","searchKeywords":["then","the","lord","spoke","moses","saying","speak","pharao","king","egypt","whatsoever","say","thee"]},{"verseId":"brenton_exodus_6_30","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":6,"verse":30,"text":"And Moses said before the Lord, Behold, I am not able in speech, and how shall Pharao hearken to me?","searchKeywords":["and","moses","said","before","the","lord","behold","not","able","speech","how","shall","pharao","hearken"]}]