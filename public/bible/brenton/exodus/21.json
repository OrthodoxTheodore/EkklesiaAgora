[{"verseId":"brenton_exodus_21_1","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":1,"text":"And these the ordinances which thou shalt set before them.","searchKeywords":["and","these","the","ordinances","which","thou","shalt","set","before","them"]},{"verseId":"brenton_exodus_21_2","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":2,"text":"If thou buy a Hebrew servant, six years shall he serve thee, and in the seventh year he shall go forth free for nothing.","searchKeywords":["thou","buy","hebrew","servant","six","years","shall","serve","thee","and","the","seventh","year","forth","free","for","nothing"]},{"verseId":"brenton_exodus_21_3","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":3,"text":"If he should have come in alone, he shall also go forth alone; and if his wife should have gone in together with him, his wife also shall go out.","searchKeywords":["should","have","come","alone","shall","also","forth","and","his","wife","gone","together","with","him","out"]},{"verseId":"brenton_exodus_21_4","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":4,"text":"Moreover, if his master give him a wife, and she have him sons or daughters, the wife and the children shall be his master's; and he shall go forth alone.","searchKeywords":["moreover","his","master","give","him","wife","and","she","have","sons","daughters","the","children","shall","forth","alone"]},{"verseId":"brenton_exodus_21_5","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":5,"text":"And if the servant should answer and say, I love my master and wife and children, I will not go away free;","searchKeywords":["and","the","servant","should","answer","say","love","master","wife","children","will","not","away","free"]},{"verseId":"brenton_exodus_21_6","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":6,"text":"his master shall bring him to the judgment-seat of God, and then shall he bring him to the door,—to the door-post, and his master shall bore his ear through with an awl, and he shall serve him for ever.","searchKeywords":["his","master","shall","bring","him","the","judgment","seat","god","and","then","door","post","bore","ear","through","with","awl","serve","for","ever"]},{"verseId":"brenton_exodus_21_7","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":7,"text":"And if any one sell his daughter as a domestic, she shall not depart as the maid-servants depart.","searchKeywords":["and","any","one","sell","his","daughter","domestic","she","shall","not","depart","the","maid","servants"]},{"verseId":"brenton_exodus_21_8","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":8,"text":"If she be not pleasing to her master, after she has betrothed herself to him, he shall let her go free; but he is not at liberty to sell her to a foreign nation, because he has trifled with her.","searchKeywords":["she","not","pleasing","her","master","after","has","betrothed","herself","him","shall","let","free","but","liberty","sell","foreign","nation","because","trifled","with"]},{"verseId":"brenton_exodus_21_9","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":9,"text":"And if he should have betrothed her to his son, he shall do to her according to the right of daughters.","searchKeywords":["and","should","have","betrothed","her","his","son","shall","according","the","right","daughters"]},{"verseId":"brenton_exodus_21_10","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":10,"text":"And if he take another to himself, he shall not deprive her of necessaries and her apparel, and her companionship .","searchKeywords":["and","take","another","himself","shall","not","deprive","her","necessaries","apparel","companionship"]},{"verseId":"brenton_exodus_21_11","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":11,"text":"And if he will not do these three things to her, she shall go out free without money.","searchKeywords":["and","will","not","these","three","things","her","she","shall","out","free","without","money"]},{"verseId":"brenton_exodus_21_12","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":12,"text":"And if any man smite another and he die, let him be certainly put to death.","searchKeywords":["and","any","man","smite","another","die","let","him","certainly","put","death"]},{"verseId":"brenton_exodus_21_13","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":13,"text":"But as for him that did it not willingly, but God delivered him into his hands, I will give thee a place whither the slayer may flee.","searchKeywords":["but","for","him","that","did","not","willingly","god","delivered","into","his","hands","will","give","thee","place","whither","the","slayer","may","flee"]},{"verseId":"brenton_exodus_21_14","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":14,"text":"And if any one lie in wait for his neighbour to slay him by craft, and he go for refuge, thou shalt take him from my altar to put him to death.","searchKeywords":["and","any","one","lie","wait","for","his","neighbour","slay","him","craft","refuge","thou","shalt","take","from","altar","put","death"]},{"verseId":"brenton_exodus_21_15","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":15,"text":"Whoever smites his father or his mother, let him be certainly put to death.","searchKeywords":["whoever","smites","his","father","mother","let","him","certainly","put","death"]},{"verseId":"brenton_exodus_21_16","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":16,"text":"He that reviles his father or his mother shall surely die.","searchKeywords":["that","reviles","his","father","mother","shall","surely","die"]},{"verseId":"brenton_exodus_21_17","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":17,"text":"Whosoever shall steal one of the children of Israel, and prevail over him and sell him, and he be found with him, let him certainly die.","searchKeywords":["whosoever","shall","steal","one","the","children","israel","and","prevail","over","him","sell","found","with","let","certainly","die"]},{"verseId":"brenton_exodus_21_18","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":18,"text":"And if two men revile each other and smite the one the other with a stone or his fist, and he die not, but be laid upon his bed;","searchKeywords":["and","two","men","revile","each","other","smite","the","one","with","stone","his","fist","die","not","but","laid","upon","bed"]},{"verseId":"brenton_exodus_21_19","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":19,"text":"if the man arise and walk abroad on his staff, he that smote him shall be clear; only he shall pay for his loss of time, and for his healing.","searchKeywords":["the","man","arise","and","walk","abroad","his","staff","that","smote","him","shall","clear","only","pay","for","loss","time","healing"]},{"verseId":"brenton_exodus_21_20","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":20,"text":"And if a man smite his man-servant or his maid-servant, with a rod, and die under his hands, he shall be surely punished.","searchKeywords":["and","man","smite","his","servant","maid","with","rod","die","under","hands","shall","surely","punished"]},{"verseId":"brenton_exodus_21_21","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":21,"text":"But if continue to live a day or two, let not be punished; for he is his money.","searchKeywords":["but","continue","live","day","two","let","not","punished","for","his","money"]},{"verseId":"brenton_exodus_21_22","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":22,"text":"And if two men strive and smite a woman with child, and her child be born imperfectly formed, he shall be forced to pay a penalty: as the woman's husband may lay upon him, he shall pay with a valuation.","searchKeywords":["and","two","men","strive","smite","woman","with","child","her","born","imperfectly","formed","shall","forced","pay","penalty","the","husband","may","lay","upon","him","valuation"]},{"verseId":"brenton_exodus_21_23","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":23,"text":"But if it be perfectly formed, he shall give life for life,","searchKeywords":["but","perfectly","formed","shall","give","life","for"]},{"verseId":"brenton_exodus_21_24","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":24,"text":"eye for eye, tooth for tooth, hand for hand, foot for foot,","searchKeywords":["eye","for","tooth","hand","foot"]},{"verseId":"brenton_exodus_21_25","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":25,"text":"burning for burning, wound for wound, stripe for stripe.","searchKeywords":["burning","for","wound","stripe"]},{"verseId":"brenton_exodus_21_26","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":26,"text":"And if one smite the eye of his man-servant, or the eye of his maid-servant, and put it out, he shall let them go free for their eye's sake.","searchKeywords":["and","one","smite","the","eye","his","man","servant","maid","put","out","shall","let","them","free","for","their","sake"]},{"verseId":"brenton_exodus_21_27","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":27,"text":"And if he should smite out the tooth of his man-servant, or the tooth of his maid-servant, he shall send them away free for their tooth's sake.","searchKeywords":["and","should","smite","out","the","tooth","his","man","servant","maid","shall","send","them","away","free","for","their","sake"]},{"verseId":"brenton_exodus_21_28","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":28,"text":"And if a bull gore a man or woman and they die, the bull shall be stoned with stones, and his flesh shall not be eaten; but the owner of the bull shall be clear.","searchKeywords":["and","bull","gore","man","woman","they","die","the","shall","stoned","with","stones","his","flesh","not","eaten","but","owner","clear"]},{"verseId":"brenton_exodus_21_29","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":29,"text":"But if the bull should have been given to goring in former time, and men should have told his owner, and he have not removed him, but he should have slain a man or woman, the bull shall be stoned, and his owner shall die also.","searchKeywords":["but","the","bull","should","have","been","given","goring","former","time","and","men","told","his","owner","not","removed","him","slain","man","woman","shall","stoned","die","also"]},{"verseId":"brenton_exodus_21_30","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":30,"text":"And if a ransom should be imposed on him, he shall pay for the ransom of his soul as much as they shall lay upon him.","searchKeywords":["and","ransom","should","imposed","him","shall","pay","for","the","his","soul","much","they","lay","upon"]},{"verseId":"brenton_exodus_21_31","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":31,"text":"And if gore a son or daughter, let them do to him according to this ordinance.","searchKeywords":["and","gore","son","daughter","let","them","him","according","this","ordinance"]},{"verseId":"brenton_exodus_21_32","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":32,"text":"And if the bull gore a man-servant or maid-servant, he shall pay to their master thirty silver didrachms, and the bull shall be stoned.","searchKeywords":["and","the","bull","gore","man","servant","maid","shall","pay","their","master","thirty","silver","didrachms","stoned"]},{"verseId":"brenton_exodus_21_33","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":33,"text":"And if any one open a pit or dig a cavity in stone, and cover it not, and an ox or an ass fall in there,","searchKeywords":["and","any","one","open","pit","dig","cavity","stone","cover","not","ass","fall","there"]},{"verseId":"brenton_exodus_21_34","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":34,"text":"the owner of the pit shall make compensation; he shall give money to their owner, and the dead shall be his own.","searchKeywords":["the","owner","pit","shall","make","compensation","give","money","their","and","dead","his","own"]},{"verseId":"brenton_exodus_21_35","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":35,"text":"And if any man's bull gore the bull of his neighbour, and it die, they shall sell the living bull and divide the money, and they shall divide the dead bull.","searchKeywords":["and","any","man","bull","gore","the","his","neighbour","die","they","shall","sell","living","divide","money","dead"]},{"verseId":"brenton_exodus_21_36","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":36,"text":"But if the bull be known to have been given to goring in time past, and they have testified to his owner, and he have not removed him, he shall repay bull for bull, but the dead shall be his own.","searchKeywords":["but","the","bull","known","have","been","given","goring","time","past","and","they","testified","his","owner","not","removed","him","shall","repay","for","dead","own"]},{"verseId":"brenton_exodus_21_37","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":21,"verse":37,"text":"And if one steal an ox or a sheep, and kill it or sell it, he shall pay five calves for a calf, and four sheep for a sheep.","searchKeywords":["and","one","steal","sheep","kill","sell","shall","pay","five","calves","for","calf","four"]}]