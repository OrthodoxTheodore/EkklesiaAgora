[{"verseId":"brenton_exodus_1_1","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":1,"text":"are the names of the sons of Israel that came into Egypt together with Jacob their father; they came in each with their whole family.","searchKeywords":["are","the","names","sons","israel","that","came","into","egypt","together","with","jacob","their","father","they","each","whole","family"]},{"verseId":"brenton_exodus_1_2","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":2,"text":"Ruben, Simeon, Levi, Judas,","searchKeywords":["ruben","simeon","levi","judas"]},{"verseId":"brenton_exodus_1_3","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":3,"text":"Issachar, Zabulon, Benjamin,","searchKeywords":["issachar","zabulon","benjamin"]},{"verseId":"brenton_exodus_1_4","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":4,"text":"Dan and Nephthalim, Gad and Aser.","searchKeywords":["dan","and","nephthalim","gad","aser"]},{"verseId":"brenton_exodus_1_5","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":5,"text":"But Joseph was in Egypt. And all the souls of Jacob were seventy-five.","searchKeywords":["but","joseph","was","egypt","and","all","the","souls","jacob","were","seventy","five"]},{"verseId":"brenton_exodus_1_6","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":6,"text":"And Joseph died, and all his brethren, and all that generation.","searchKeywords":["and","joseph","died","all","his","brethren","that","generation"]},{"verseId":"brenton_exodus_1_7","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":7,"text":"And the children of Israel increased and multiplied, and became numerous and grew exceedingly strong, and the land multiplied them.","searchKeywords":["and","the","children","israel","increased","multiplied","became","numerous","grew","exceedingly","strong","land","them"]},{"verseId":"brenton_exodus_1_8","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":8,"text":"And there arose up another king over Egypt, who knew not Joseph.","searchKeywords":["and","there","arose","another","king","over","egypt","who","knew","not","joseph"]},{"verseId":"brenton_exodus_1_9","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":9,"text":"And he said to his nation, Behold, the race of the children of Israel is a great multitude, and is stronger than we:","searchKeywords":["and","said","his","nation","behold","the","race","children","israel","great","multitude","stronger","than"]},{"verseId":"brenton_exodus_1_10","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":10,"text":"come then, let us deal craftily with them, lest at any time they be increased, and whensoever war shall happen to us, these also shall be added to our enemies, and having prevailed against us in war, they will depart out of the land.","searchKeywords":["come","then","let","deal","craftily","with","them","lest","any","time","they","increased","and","whensoever","war","shall","happen","these","also","added","our","enemies","having","prevailed","against","will","depart","out","the","land"]},{"verseId":"brenton_exodus_1_11","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":11,"text":"And he set over them task-masters, who should afflict them in their works; and they built strong cities for Pharao, both Pitho, and Ramesses, and On, which is Heliopolis.","searchKeywords":["and","set","over","them","task","masters","who","should","afflict","their","works","they","built","strong","cities","for","pharao","both","pitho","ramesses","which","heliopolis"]},{"verseId":"brenton_exodus_1_12","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":12,"text":"But as they humbled them, by so much they multiplied, and grew exceedingly strong; and the Egyptians greatly abhorred the children of Israel.","searchKeywords":["but","they","humbled","them","much","multiplied","and","grew","exceedingly","strong","the","egyptians","greatly","abhorred","children","israel"]},{"verseId":"brenton_exodus_1_13","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":13,"text":"And the Egyptians tyrannised over the children of Israel by force.","searchKeywords":["and","the","egyptians","tyrannised","over","children","israel","force"]},{"verseId":"brenton_exodus_1_14","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":14,"text":"And they embittered their life by hard labours, in the clay and in brick-making, and all the works in the plains, according to all the works, wherein they caused them to serve with violence.","searchKeywords":["and","they","embittered","their","life","hard","labours","the","clay","brick","making","all","works","plains","according","wherein","caused","them","serve","with","violence"]},{"verseId":"brenton_exodus_1_15","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":15,"text":"And the king of the Egyptians spoke to the midwives of the Hebrews; the name of the one was, Sepphora; and the name of the second, Phua.","searchKeywords":["and","the","king","egyptians","spoke","midwives","hebrews","name","one","was","sepphora","second","phua"]},{"verseId":"brenton_exodus_1_16","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":16,"text":"And he said, When ye do the office of midwives to the Hebrew women, and they are about to be delivered, if it be a male, kill it; but if a female, save it.","searchKeywords":["and","said","when","the","office","midwives","hebrew","women","they","are","about","delivered","male","kill","but","female","save"]},{"verseId":"brenton_exodus_1_17","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":17,"text":"But the midwives feared God, and did not as the king of Egypt appointed them; and they saved the male children alive.","searchKeywords":["but","the","midwives","feared","god","and","did","not","king","egypt","appointed","them","they","saved","male","children","alive"]},{"verseId":"brenton_exodus_1_18","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":18,"text":"And the king of Egypt called the midwives, and said to them, Why is it that ye have done this thing, and saved the male children alive?","searchKeywords":["and","the","king","egypt","called","midwives","said","them","why","that","have","done","this","thing","saved","male","children","alive"]},{"verseId":"brenton_exodus_1_19","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":19,"text":"And the midwives said to Pharao, The Hebrew women are not as the women of Egypt, for they are delivered before the midwives go in to them. So they bore children.","searchKeywords":["and","the","midwives","said","pharao","hebrew","women","are","not","egypt","for","they","delivered","before","them","bore","children"]},{"verseId":"brenton_exodus_1_20","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":20,"text":"And God did well to the midwives, and the people multiplied, and grew very strong.","searchKeywords":["and","god","did","well","the","midwives","people","multiplied","grew","very","strong"]},{"verseId":"brenton_exodus_1_21","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":21,"text":"And as the midwives feared God, they established for themselves families.","searchKeywords":["and","the","midwives","feared","god","they","established","for","themselves","families"]},{"verseId":"brenton_exodus_1_22","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":1,"verse":22,"text":"And Pharao charged all his people, saying, Whatever male shall be born to the Hebrews, cast into the river; and every female, save it alive.","searchKeywords":["and","pharao","charged","all","his","people","saying","whatever","male","shall","born","the","hebrews","cast","into","river","every","female","save","alive"]}]