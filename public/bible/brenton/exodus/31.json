[{"verseId":"brenton_exodus_31_1","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":1,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_exodus_31_2","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":2,"text":"Behold, I have called by name Beseleel the son of Urias the son of Or, of the tribe of Juda.","searchKeywords":["behold","have","called","name","beseleel","the","son","urias","tribe","juda"]},{"verseId":"brenton_exodus_31_3","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":3,"text":"And I have filled him a divine spirit of wisdom, and understanding, and knowledge, to invent in every work,","searchKeywords":["and","have","filled","him","divine","spirit","wisdom","understanding","knowledge","invent","every","work"]},{"verseId":"brenton_exodus_31_4","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":4,"text":"and to frame works, to labour in gold, and silver, and brass, and blue, and purple, and spun scarlet,","searchKeywords":["and","frame","works","labour","gold","silver","brass","blue","purple","spun","scarlet"]},{"verseId":"brenton_exodus_31_5","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":5,"text":"and works in stone, and for artificers' work in wood, to work at all works.","searchKeywords":["and","works","stone","for","artificers","work","wood","all"]},{"verseId":"brenton_exodus_31_6","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":6,"text":"And I have appointed him and Eliab the of Achisamach of the tribe of Dan, and to every one understanding in heart I have given understanding; and they shall make all things as many as I have appointed thee,—","searchKeywords":["and","have","appointed","him","eliab","the","achisamach","tribe","dan","every","one","understanding","heart","given","they","shall","make","all","things","many","thee"]},{"verseId":"brenton_exodus_31_7","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":7,"text":"the tabernacle of witness, and the ark of the covenant, and the propitiatory that is upon it, and the furniture of the tabernacle,","searchKeywords":["the","tabernacle","witness","and","ark","covenant","propitiatory","that","upon","furniture"]},{"verseId":"brenton_exodus_31_8","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":8,"text":"and the altars, and the table and all its furniture,","searchKeywords":["and","the","altars","table","all","its","furniture"]},{"verseId":"brenton_exodus_31_9","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":9,"text":"and the pure candlestick and all its furniture, and the laver and its base,","searchKeywords":["and","the","pure","candlestick","all","its","furniture","laver","base"]},{"verseId":"brenton_exodus_31_10","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":10,"text":"and Aaron's robes of ministry, and the robes of his sons to minister to me as priests,","searchKeywords":["and","aaron","robes","ministry","the","his","sons","minister","priests"]},{"verseId":"brenton_exodus_31_11","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":11,"text":"and the anointing oil and the compound incense of the sanctuary; according to all that I have commanded thee shall they make them.","searchKeywords":["and","the","anointing","oil","compound","incense","sanctuary","according","all","that","have","commanded","thee","shall","they","make","them"]},{"verseId":"brenton_exodus_31_12","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":12,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_exodus_31_13","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":13,"text":"Do thou also charge the children of Israel, saying, Take heed and keep my sabbaths; they are a sign with me and among you throughout your generations, that ye may know that I am the Lord that sanctifies you.","searchKeywords":["thou","also","charge","the","children","israel","saying","take","heed","and","keep","sabbaths","they","are","sign","with","among","you","throughout","your","generations","that","may","know","lord","sanctifies"]},{"verseId":"brenton_exodus_31_14","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":14,"text":"And ye shall keep the sabbaths, because this is holy to the Lord for you; he that profanes it shall surely be put to death: every one who shall do a work on it, that soul shall be destroyed from the midst of his people.","searchKeywords":["and","shall","keep","the","sabbaths","because","this","holy","lord","for","you","that","profanes","surely","put","death","every","one","who","work","soul","destroyed","from","midst","his","people"]},{"verseId":"brenton_exodus_31_15","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":15,"text":"Six days thou shalt do works, but the seventh day is the sabbath, a holy rest to the Lord; every one who shall do a work on the seventh day shall be put to death.","searchKeywords":["six","days","thou","shalt","works","but","the","seventh","day","sabbath","holy","rest","lord","every","one","who","shall","work","put","death"]},{"verseId":"brenton_exodus_31_16","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":16,"text":"And the children of Israel shall keep the sabbaths, to observe them throughout their generations.","searchKeywords":["and","the","children","israel","shall","keep","sabbaths","observe","them","throughout","their","generations"]},{"verseId":"brenton_exodus_31_17","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":17,"text":"It is a perpetual covenant with me and the children of Israel, it is a perpetual sign with me; for in six days the Lord made the heaven and the earth, and on the seventh day he ceased, and rested.","searchKeywords":["perpetual","covenant","with","and","the","children","israel","sign","for","six","days","lord","made","heaven","earth","seventh","day","ceased","rested"]},{"verseId":"brenton_exodus_31_18","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":31,"verse":18,"text":"And he gave to Moses when he left off speaking to him in mount Sina the two tables of testimony, tables of stone written with the finger of God.","searchKeywords":["and","gave","moses","when","left","off","speaking","him","mount","sina","the","two","tables","testimony","stone","written","with","finger","god"]}]