[{"verseId":"brenton_exodus_35_1","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":35,"verse":1,"text":"And Moses gathered all the congregation of the children of Israel together, and said, These are the words which the Lord has spoken for to do them.","searchKeywords":["and","moses","gathered","all","the","congregation","children","israel","together","said","these","are","words","which","lord","has","spoken","for","them"]},{"verseId":"brenton_exodus_35_2","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":35,"verse":2,"text":"Six days shalt thou perform works, but on the seventh day rest—a holy sabbath—a rest for the Lord: every one that does work on it, let him die.","searchKeywords":["six","days","shalt","thou","perform","works","but","the","seventh","day","rest","holy","sabbath","for","lord","every","one","that","does","work","let","him","die"]},{"verseId":"brenton_exodus_35_3","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":35,"verse":3,"text":"Ye shall not burn a fire in any of your dwellings on the sabbath-day; I the Lord.","searchKeywords":["shall","not","burn","fire","any","your","dwellings","the","sabbath","day","lord"]},{"verseId":"brenton_exodus_35_4","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":35,"verse":4,"text":"And Moses spoke to all the congregation of the children of Israel, saying, This the thing which the Lord has appointed you, saying,","searchKeywords":["and","moses","spoke","all","the","congregation","children","israel","saying","this","thing","which","lord","has","appointed","you"]},{"verseId":"brenton_exodus_35_5","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":35,"verse":5,"text":"Take of yourselves an offering for the Lord: every one that engages in his heart shall bring the first-fruits to the Lord; gold, silver, brass,","searchKeywords":["take","yourselves","offering","for","the","lord","every","one","that","engages","his","heart","shall","bring","first","fruits","gold","silver","brass"]},{"verseId":"brenton_exodus_35_6","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":35,"verse":6,"text":"blue, purple, double scarlet spun, and fine linen spun, and goats' hair,","searchKeywords":["blue","purple","double","scarlet","spun","and","fine","linen","goats","hair"]},{"verseId":"brenton_exodus_35_7","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":35,"verse":7,"text":"and rams' skins dyed red, and skins blue, and incorruptible wood,","searchKeywords":["and","rams","skins","dyed","red","blue","incorruptible","wood"]},{"verseId":"brenton_exodus_35_9","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":35,"verse":9,"text":"and sardine stones, and stones for engraving for the shoulder-piece and full-length robe.","searchKeywords":["and","sardine","stones","for","engraving","the","shoulder","piece","full","length","robe"]},{"verseId":"brenton_exodus_35_10","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":35,"verse":10,"text":"And every man that is wise in heart among you, let him come and work all things whatsoever the Lord has commanded.","searchKeywords":["and","every","man","that","wise","heart","among","you","let","him","come","work","all","things","whatsoever","the","lord","has","commanded"]},{"verseId":"brenton_exodus_35_11","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":35,"verse":11,"text":"The tabernacle, and the cords, and the coverings, and the rings, and the bars, and the posts,","searchKeywords":["the","tab