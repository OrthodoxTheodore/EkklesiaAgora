[{"verseId":"brenton_exodus_22_1","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":1,"text":"And if the thief be found in the breach and be smitten and die, there shall not be blood shed for him.","searchKeywords":["and","the","thief","found","breach","smitten","die","there","shall","not","blood","shed","for","him"]},{"verseId":"brenton_exodus_22_2","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":2,"text":"But if the sun be risen upon him, he is guilty, he shall die instead; and if a thief have nothing, let him be sold in compensation for what he has stolen.","searchKeywords":["but","the","sun","risen","upon","him","guilty","shall","die","instead","and","thief","have","nothing","let","sold","compensation","for","what","has","stolen"]},{"verseId":"brenton_exodus_22_3","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":3,"text":"And if the thing stolen be left and be in his hand alive, whether ox or sheep, he shall restore them two-fold.","searchKeywords":["and","the","thing","stolen","left","his","hand","alive","whether","sheep","shall","restore","them","two","fold"]},{"verseId":"brenton_exodus_22_4","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":4,"text":"And if any one should feed down a field or a vineyard, and should send in his beast to feed down another field, he shall make compensation of his own field according to his produce; and if he shall have fed down the whole field, he shall pay for compensation the best of his own field and the best of his vineyard.","searchKeywords":["and","any","one","should","feed","down","field","vineyard","send","his","beast","another","shall","make","compensation","own","according","produce","have","fed","the","whole","pay","for","best"]},{"verseId":"brenton_exodus_22_5","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":5,"text":"And if fire have gone forth and caught thorns, and should also set on fire threshing-floors or ears of corn or a field, he that kindled the fire shall make compensation.","searchKeywords":["and","fire","have","gone","forth","caught","thorns","should","also","set","threshing","floors","ears","corn","field","that","kindled","the","shall","make","compensation"]},{"verseId":"brenton_exodus_22_6","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":6,"text":"And if any one give to his neighbour money or goods to keep, and they be stolen out of the man's house, if the thief be found, he shall repay double.","searchKeywords":["and","any","one","give","his","neighbour","money","goods","keep","they","stolen","out","the","man","house","thief","found","shall","repay","double"]},{"verseId":"brenton_exodus_22_7","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":7,"text":"But if the thief be not found, the master of the house shall come forward before God, and shall swear that surely he has not wrought wickedly in regard of any part of his neighbour's deposit,","searchKeywords":["but","the","thief","not","found","master","house","shall","come","forward","before","god","and","swear","that","surely","has","wrought","wickedly","regard","any","part","his","neighbour","deposit"]},{"verseId":"brenton_exodus_22_8","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":8,"text":"according to every injury alleged, both concerning a calf, and an ass, and a sheep, and a garment, and every alleged loss, whatsoever in fact it may be,—the judgment of both shall proceed before God, and he that is convicted by God shall repay to his neighbour double.","searchKeywords":["according","every","injury","alleged","both","concerning","calf","and","ass","sheep","garment","loss","whatsoever","fact","may","the","judgment","shall","proceed","before","god","that","convicted","repay","his","neighbour","double"]},{"verseId":"brenton_exodus_22_9","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":9,"text":"And if any one give to his neighbour to keep a calf or sheep or any beast, and it be wounded or die or be taken, and no one know,","searchKeywords":["and","any","one","give","his","neighbour","keep","calf","sheep","beast","wounded","die","taken","know"]},{"verseId":"brenton_exodus_22_10","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":10,"text":"an oath of God shall be between both, that he has surely not at all been guilty in the matter of his neighbour's deposit; and so his master shall hold him guiltless, and he shall not make compensation.","searchKeywords":["oath","god","shall","between","both","that","has","surely","not","all","been","guilty","the","matter","his","neighbour","deposit","and","master","hold","him","guiltless","make","compensation"]},{"verseId":"brenton_exodus_22_11","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":11,"text":"And if it be stolen from him, he shall make compensation to the owner.","searchKeywords":["and","stolen","from","him","shall","make","compensation","the","owner"]},{"verseId":"brenton_exodus_22_12","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":12,"text":"And if it be seized of beasts, he shall bring him to the prey, and he shall not make compensation.","searchKeywords":["and","seized","beasts","shall","bring","him","the","prey","not","make","compensation"]},{"verseId":"brenton_exodus_22_13","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":13,"text":"And if any one borrow of his neighbour, and it be wounded or die or be carried away, and the owner of it be not with it, he shall make compensation.","searchKeywords":["and","any","one","borrow","his","neighbour","wounded","die","carried","away","the","owner","not","with","shall","make","compensation"]},{"verseId":"brenton_exodus_22_14","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":14,"text":"But if the owner be with it, he shall not make compensation: but if it be a hired thing, there shall be to him instead of his hire.","searchKeywords":["but","the","owner","with","shall","not","make","compensation","hired","thing","there","him","instead","his","hire"]},{"verseId":"brenton_exodus_22_15","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":15,"text":"And if any one deceive a virgin that is not betrothed, and lie with her, he shall surely endow her for a wife to himself.","searchKeywords":["and","any","one","deceive","virgin","that","not","betrothed","lie","with","her","shall","surely","endow","for","wife","himself"]},{"verseId":"brenton_exodus_22_16","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":16,"text":"And if her father positively refuse, and will not consent to give her to him for a wife, he shall pay compensation to her father according to the amount of the dowry of virgins.","searchKeywords":["and","her","father","positively","refuse","will","not","consent","give","him","for","wife","shall","pay","compensation","according","the","amount","dowry","virgins"]},{"verseId":"brenton_exodus_22_17","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":17,"text":"Ye shall not save the lives of sorcerers.","searchKeywords":["shall","not","save","the","lives","sorcerers"]},{"verseId":"brenton_exodus_22_18","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":18,"text":"Every one that lies with a beast ye shall surely put to death.","searchKeywords":["every","one","that","lies","with","beast","shall","surely","put","death"]},{"verseId":"brenton_exodus_22_19","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":19,"text":"He that sacrifices to any gods but to the Lord alone, shall be destroyed by death.","searchKeywords":["that","sacrifices","any","gods","but","the","lord","alone","shall","destroyed","death"]},{"verseId":"brenton_exodus_22_20","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":20,"text":"And ye shall not hurt a stranger, nor afflict him; for ye were strangers in the land of Egypt.","searchKeywords":["and","shall","not","hurt","stranger","nor","afflict","him","for","were","strangers","the","land","egypt"]},{"verseId":"brenton_exodus_22_21","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":21,"text":"Ye shall hurt no widow or orphan.","searchKeywords":["shall","hurt","widow","orphan"]},{"verseId":"brenton_exodus_22_22","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":22,"text":"And if ye should afflict them by ill-treatment, and they should cry aloud to me, I will surely hear their voice.","searchKeywords":["and","should","afflict","them","ill","treatment","they","cry","aloud","will","surely","hear","their","voice"]},{"verseId":"brenton_exodus_22_23","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":23,"text":"And I will be very angry, and will slay you with the sword, and your wives shall be widows and your children orphans.","searchKeywords":["and","will","very","angry","slay","you","with","the","sword","your","wives","shall","widows","children","orphans"]},{"verseId":"brenton_exodus_22_24","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":24,"text":"And if thou shouldest lend money to thy poor brother who is by thee, thou shalt not be hard upon him, thou shalt not exact usury of him.","searchKeywords":["and","thou","shouldest","lend","money","thy","poor","brother","who","thee","shalt","not","hard","upon","him","exact","usury"]},{"verseId":"brenton_exodus_22_25","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":25,"text":"And if thou take thy neighbour's garment for a pledge, thou shalt restore it to him before sunset.","searchKeywords":["and","thou","take","thy","neighbour","garment","for","pledge","shalt","restore","him","before","sunset"]},{"verseId":"brenton_exodus_22_26","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":26,"text":"For this is his clothing, this is the only covering of his nakedness; wherein shall he sleep? If then he shall cry to me, I will hearken to him, for I am merciful.","searchKeywords":["for","this","his","clothing","the","only","covering","nakedness","wherein","shall","sleep","then","cry","will","hearken","him","merciful"]},{"verseId":"brenton_exodus_22_27","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":27,"text":"Thou shalt not revile the gods, nor speak ill of the ruler of thy people.","searchKeywords":["thou","shalt","not","revile","the","gods","nor","speak","ill","ruler","thy","people"]},{"verseId":"brenton_exodus_22_28","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":28,"text":"Thou shalt not keep back the first-fruits of thy threshing floor and press. The first-born of thy sons thou shalt give to me.","searchKeywords":["thou","shalt","not","keep","back","the","first","fruits","thy","threshing","floor","and","press","born","sons","give"]},{"verseId":"brenton_exodus_22_29","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":29,"text":"So shalt thou do with thy calf and thy sheep and thine ass; seven days shall it be under the mother, and the eighth day thou shalt give it to me.","searchKeywords":["shalt","thou","with","thy","calf","and","sheep","thine","ass","seven","days","shall","under","the","mother","eighth","day","give"]},{"verseId":"brenton_exodus_22_30","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":22,"verse":30,"text":"And ye shall be holy men to me; and ye shall not eat flesh taken of beasts, ye shall cast it to the dog.","searchKeywords":["and","shall","holy","men","not","eat","flesh","taken","beasts","cast","the","dog"]}]