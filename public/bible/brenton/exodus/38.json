[{"verseId":"brenton_exodus_38_1","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":1,"text":"And Beseleel made the ark,","searchKeywords":["and","beseleel","made","the","ark"]},{"verseId":"brenton_exodus_38_2","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":2,"text":"and overlaid it with pure gold within and without;","searchKeywords":["and","overlaid","with","pure","gold","within","without"]},{"verseId":"brenton_exodus_38_3","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":3,"text":"and he cast for it four golden rings, two on the one side, and two on the other,","searchKeywords":["and","cast","for","four","golden","rings","two","the","one","side","other"]},{"verseId":"brenton_exodus_38_4","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":4,"text":"wide for the staves, so that men should bear the ark with them.","searchKeywords":["wide","for","the","staves","that","men","should","bear","ark","with","them"]},{"verseId":"brenton_exodus_38_5","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":5,"text":"And he made the propitiatory over the ark of pure gold,","searchKeywords":["and","made","the","propitiatory","over","ark","pure","gold"]},{"verseId":"brenton_exodus_38_6","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":6,"text":"and the two cherubs of gold;","searchKeywords":["and","the","two","cherubs","gold"]},{"verseId":"brenton_exodus_38_7","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":7,"text":"one cherub on the one end of the propitiatory, and another cherub on the other end of the propitiatory,","searchKeywords":["one","cherub","the","end","propitiatory","and","another","other"]},{"verseId":"brenton_exodus_38_8","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":8,"text":"overshadowing the propitiatory with their wings.","searchKeywords":["overshadowing","the","propitiatory","with","their","wings"]},{"verseId":"brenton_exodus_38_9","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":9,"text":"And he made the set table of pure gold,","searchKeywords":["and","made","the","set","table","pure","gold"]},{"verseId":"brenton_exodus_38_10","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":10,"text":"and cast for it four rings: two on the one side and two on the other side, broad, so that should lift it with the staves in them.","searchKeywords":["and","cast","for","four","rings","two","the","one","side","other","broad","that","should","lift","with","staves","them"]},{"verseId":"brenton_exodus_38_11","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":11,"text":"And he made the staves of the ark and of the table, and gilded them with gold.","searchKeywords":["and","made","the","staves","ark","table","gilded","them","with","gold"]},{"verseId":"brenton_exodus_38_12","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":12,"text":"And he made the furniture of the table, both the dishes, and the censers, and the cups, and the bowls with which he should offer drink-offerings, of gold.","searchKeywords":["and","made","the","furniture","table","both","dishes","censers","cups","bowls","with","which","should","offer","drink","offerings","gold"]},{"verseId":"brenton_exodus_38_13","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":13,"text":"And he made the candlestick which gives light, of gold;","searchKeywords":["and","made","the","candlestick","which","gives","light","gold"]},{"verseId":"brenton_exodus_38_14","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":14,"text":"the stem solid, and the branches from both its sides;","searchKeywords":["the","stem","solid","and","branches","from","both","its","sides"]},{"verseId":"brenton_exodus_38_15","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":15,"text":"and blossoms proceeding from its branches, three on this side, and three on the other, made equal to each other.","searchKeywords":["and","blossoms","proceeding","from","its","branches","three","this","side","the","other","made","equal","each"]},{"verseId":"brenton_exodus_38_16","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":16,"text":"And their lamps, which are on the ends, knops from them; and sockets proceeding from them, that the lamps might be upon them; and the seventh socket, on the top of the candlestick, on the summit above, entirely of solid gold.","searchKeywords":["and","their","lamps","which","are","the","ends","knops","from","them","sockets","proceeding","that","might","upon","seventh","socket","top","candlestick","summit","above","entirely","solid","gold"]},{"verseId":"brenton_exodus_38_17","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":17,"text":"And on the candlestick seven golden lamps, and its snuffers gold, and its funnels gold.","searchKeywords":["and","the","candlestick","seven","golden","lamps","its","snuffers","gold","funnels"]},{"verseId":"brenton_exodus_38_18","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":18,"text":"He overlaid the posts , and cast for each post golden rings, and gilded the bars with gold; and he gilded the posts of the veil with gold, and made the hooks of gold.","searchKeywords":["overlaid","the","posts","and","cast","for","each","post","golden","rings","gilded","bars","with","gold","veil","made","hooks"]},{"verseId":"brenton_exodus_38_19","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":19,"text":"He made also the rings of the tabernacle of gold; and the rings of the court, and the rings for drawing out the veil above of brass.","searchKeywords":["made","also","the","rings","tabernacle","gold","and","court","for","drawing","out","veil","above","brass"]},{"verseId":"brenton_exodus_38_20","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":20,"text":"He cast the silver chapiters of the tabernacle, and the brazen chapiters of the door of the tabernacle, and the gate of the court; and he made silver hooks for the posts, he overlaid them with silver on the posts.","searchKeywords":["cast","the","silver","chapiters","tabernacle","and","brazen","door","gate","court","made","hooks","for","posts","overlaid","them","with"]},{"verseId":"brenton_exodus_38_21","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":21,"text":"He made the pins of the tabernacle and the pins of the court of brass.","searchKeywords":["made","the","pins","tabernacle","and","court","brass"]},{"verseId":"brenton_exodus_38_22","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":22,"text":"He made the brazen altar of the brazen censers, which belonged to the men engaged in sedition with the gathering of Core.","searchKeywords":["made","the","brazen","altar","censers","which","belonged","men","engaged","sedition","with","gathering","core"]},{"verseId":"brenton_exodus_38_23","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":23,"text":"He made all the vessels of the altar and its grate, and its base, and its bowls, and the brazen flesh-hooks.","searchKeywords":["made","all","the","vessels","altar","and","its","grate","base","bowls","brazen","flesh","hooks"]},{"verseId":"brenton_exodus_38_24","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":24,"text":"He made an appendage for the altar of network under the grate, beneath it as far as the middle of it; and he fastened to it four brazen rings on the four parts of the appendage of the altar, wide for the bars, so as to bear the altar with them.","searchKeywords":["made","appendage","for","the","altar","network","under","grate","beneath","far","middle","and","fastened","four","brazen","rings","parts","wide","bars","bear","with","them"]},{"verseId":"brenton_exodus_38_25","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":25,"text":"He made the holy anointing oil and the composition of the incense, the pure work of the perfumer.","searchKeywords":["made","the","holy","anointing","oil","and","composition","incense","pure","work","perfumer"]},{"verseId":"brenton_exodus_38_26","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":26,"text":"He made the brazen laver, and the brazen base of it of the mirrors of the women that fasted, who fasted by the doors of the tabernacle of witness, in the day in which he set it up.","searchKeywords":["made","the","brazen","laver","and","base","mirrors","women","that","fasted","who","doors","tabernacle","witness","day","which","set"]},{"verseId":"brenton_exodus_38_27","translationId":"brenton","testament":"OT","bookIndex":2,"bookName":"Exodus","bookAbbrev":"exodus","chapter":38,"verse":27,"text":"And he made the laver, that at it Moses and Aaron and his sons might wash their hands and their feet: when they went into the tabernacle of witness, or whensoever they should advance to the altar to do service, they washed at it, as the Lord commanded Moses.","searchKeywords":["and","made","the","laver","that","moses","aaron","his","sons","might","wash","their","hands","feet","when","they","went","into","tabernacle","witness","whensoever","should","advance","altar","service","washed","lord","commanded"]}]