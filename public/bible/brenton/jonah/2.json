[{"verseId":"brenton_jonah_2_1","translationId":"brenton","testament":"OT","bookIndex":38,"bookName":"Jonah","bookAbbrev":"jonah","chapter":2,"verse":1,"text":"Now the Lord had commanded a great whale to swallow up Jonas: and Jonas was in the belly of the whale three days and three nights.","searchKeywords":["now","the","lord","had","commanded","great","whale","swallow","jonas","and","was","belly","three","days","nights"]},{"verseId":"brenton_jonah_2_2","translationId":"brenton","testament":"OT","bookIndex":38,"bookName":"Jonah","bookAbbrev":"jonah","chapter":2,"verse":2,"text":"And Jonas prayed to the Lord his God out of the belly of the whale,","searchKeywords":["and","jonas","prayed","the","lord","his","god","out","belly","whale"]},{"verseId":"brenton_jonah_2_3","translationId":"brenton","testament":"OT","bookIndex":38,"bookName":"Jonah","bookAbbrev":"jonah","chapter":2,"verse":3,"text":"and said, to my cry out of the belly of hell: thou heardest my voice.","searchKeywords":["and","said","cry","out","the","belly","hell","thou","heardest","voice"]},{"verseId":"brenton_jonah_2_4","translationId":"brenton","testament":"OT","bookIndex":38,"bookName":"Jonah","bookAbbrev":"jonah","chapter":2,"verse":4,"text":"Thou didst cast me into the depths of the heart of the sea, and the floods compassed me: all thy billows and thy waves have passed upon me.","searchKeywords":["thou","didst","cast","into","the","depths","heart","sea","and","floods","compassed","all","thy","billows","waves","have","passed","upon"]},{"verseId":"brenton_jonah_2_5","translationId":"brenton","testament":"OT","bookIndex":38,"bookName":"Jonah","bookAbbrev":"jonah","chapter":2,"verse":5,"text":"And I said, I am cast out of thy presence: shall I indeed look again toward thy holy temple?","searchKeywords":["and","said","cast","out","thy","presence","shall","indeed","look","again","toward","holy","temple"]},{"verseId":"brenton_jonah_2_6","translationId":"brenton","testament":"OT","bookIndex":38,"bookName":"Jonah","bookAbbrev":"jonah","chapter":2,"verse":6,"text":"Water was poured around me to the soul: the lowest deep compassed me, my head went down","searchKeywords":["water","was","poured","around","the","soul","lowest","deep","compassed","head","went","down"]},{"verseId":"brenton_jonah_2_7","translationId":"brenton","testament":"OT","bookIndex":38,"bookName":"Jonah","bookAbbrev":"jonah","chapter":2,"verse":7,"text":"to the clefts of the mountains; I went down into the earth, whose bars are the everlasting barriers: yet, O Lord my God, let my ruined life be restored.","searchKeywords":["the","clefts","mountains","went","down","into","earth","whose","bars","are","everlasting","barriers","yet","lord","god","let","ruined","life","restored"]},{"verseId":"brenton_jonah_2_8","translationId":"brenton","testament":"OT","bookIndex":38,"bookName":"Jonah","bookAbbrev":"jonah","chapter":2,"verse":8,"text":"When my soul was failing me, I remembered the Lord; and may my prayer come to thee into thy holy temple.","searchKeywords":["when","soul","was","failing","remembered","the","lord","and","may","prayer","come","thee","into","thy","holy","temple"]},{"verseId":"brenton_jonah_2_9","translationId":"brenton","testament":"OT","bookIndex":38,"bookName":"Jonah","bookAbbrev":"jonah","chapter":2,"verse":9,"text":"They that observe vanities and lies have forsaken their own mercy.","searchKeywords":["they","that","observe","vanities","and","lies","have","forsaken","their","own","mercy"]},{"verseId":"brenton_jonah_2_10","translationId":"brenton","testament":"OT","bookIndex":38,"bookName":"Jonah","bookAbbrev":"jonah","chapter":2,"verse":10,"text":"But I will sacrifice to thee with the voice of praise and thanksgiving: all that I have vowed I will pay to thee, the Lord of salvation.","searchKeywords":["but","will","sacrifice","thee","with","the","voice","praise","and","thanksgiving","all","that","have","vowed","pay","lord","salvation"]},{"verseId":"brenton_jonah_2_11","translationId":"brenton",