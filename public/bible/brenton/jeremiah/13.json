[{"verseId":"brenton_jeremiah_13_1","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":1,"text":"Thus saith the Lord, Go and procure for thyself a linen girdle, and put it about thy loins, and let it not be put in water.","searchKeywords":["thus","saith","the","lord","and","procure","for","thyself","linen","girdle","put","about","thy","loins","let","not","water"]},{"verseId":"brenton_jeremiah_13_2","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":2,"text":"So I procured the girdle according to the word of the Lord, and put it about my loins.","searchKeywords":["procured","the","girdle","according","word","lord","and","put","about","loins"]},{"verseId":"brenton_jeremiah_13_3","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":3,"text":"And the word of the Lord came to me, saying,","searchKeywords":["and","the","word","lord","came","saying"]},{"verseId":"brenton_jeremiah_13_4","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":4,"text":"Take the girdle that is upon thy loins, and arise, and go to the Euphrates, and hide it there in a hole of the rock.","searchKeywords":["take","the","girdle","that","upon","thy","loins","and","arise","euphrates","hide","there","hole","rock"]},{"verseId":"brenton_jeremiah_13_5","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":5,"text":"So I went, and hid it by the Euphrates, as the Lord commanded me.","searchKeywords":["went","and","hid","the","euphrates","lord","commanded"]},{"verseId":"brenton_jeremiah_13_6","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":6,"text":"And it came to pass after many days, that the Lord said to me, Arise, go to the Euphrates, and take thence the girdle, which I commanded thee to hide there.","searchKeywords":["and","came","pass","after","many","days","that","the","lord","said","arise","euphrates","take","thence","girdle","which","commanded","thee","hide","there"]},{"verseId":"brenton_jeremiah_13_7","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":7,"text":"So I went to the river Euphrates, and dug, and took the girdle out of the place where I buried it: and, behold, it was rotten, utterly good for nothing.","searchKeywords":["went","the","river","euphrates","and","dug","took","girdle","out","place","where","buried","behold","was","rotten","utterly","good","for","nothing"]},{"verseId":"brenton_jeremiah_13_8","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":8,"text":"And the word of the Lord came to me, saying, Thus saith the Lord,","searchKeywords":["and","the","word","lord","came","saying","thus","saith"]},{"verseId":"brenton_jeremiah_13_9","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":9,"text":"Thus will I mar the pride of Juda, and the pride of Jerusalem;","searchKeywords":["thus","will","mar","the","pride","juda","and","jerusalem"]},{"verseId":"brenton_jeremiah_13_10","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":10,"text":"this great pride that will not hearken to my words, and have gone after strange gods, to serve them, and to worship them: and they shall be as this girdle, which can be used for nothing.","searchKeywords":["this","great","pride","that","will","not","hearken","words","and","have","gone","after","strange","gods","serve","them","worship","they","shall","girdle","which","can","used","for","nothing"]},{"verseId":"brenton_jeremiah_13_11","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":11,"text":"For as a girdle cleaves about the loins of a man, so have I caused to cleave to myself the house of Israel, and the whole house of Juda; that they might be to me a famous people, and a praise, and a glory: but they did not hearken to me.","searchKeywords":["for","girdle","cleaves","about","the","loins","man","have","caused","cleave","myself","house","israel","and","whole","juda","that","they","might","famous","people","praise","glory","but","did","not","hearken"]},{"verseId":"brenton_jeremiah_13_12","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":12,"text":"And thou shalt say to this people, Every bottle shall be filled with wine: and it shall come to pass, if they shall say to thee, Shall we not certainly know that every bottle shall be filled with wine? that thou shalt say to them,","searchKeywords":["and","thou","shalt","say","this","people","every","bottle","shall","filled","with","wine","come","pass","they","thee","not","certainly","know","that","them"]},{"verseId":"brenton_jeremiah_13_13","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":13,"text":"Thus saith the Lord, Behold, I fill the inhabitants of this land, and their kings the sons of David that sit upon their throne, and the priests, and the prophets, and Juda and all the dwellers in Jerusalem, with strong drink.","searchKeywords":["thus","saith","the","lord","behold","fill","inhabitants","this","land","and","their","kings","sons","david","that","sit","upon","throne","priests","prophets","juda","all","dwellers","jerusalem","with","strong","drink"]},{"verseId":"brenton_jeremiah_13_14","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":14,"text":"And I will scatter them a man and his brother, and their fathers and their sons together: I will not have compassion, saith the Lord, and I will not spare, neither will I pity from destruction.","searchKeywords":["and","will","scatter","them","man","his","brother","their","fathers","sons","together","not","have","compassion","saith","the","lord","spare","neither","pity","from","destruction"]},{"verseId":"brenton_jeremiah_13_15","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":15,"text":"Hear ye, and give ear, and be not proud: for the Lord has spoken.","searchKeywords":["hear","and","give","ear","not","proud","for","the","lord","has","spoken"]},{"verseId":"brenton_jeremiah_13_16","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":16,"text":"Give glory to the Lord your God, before he cause darkness, and before your feet stumble on the dark mountains, and ye shall wait for light, and behold the shadow of death, and they shall be brought into darkness.","searchKeywords":["give","glory","the","lord","your","god","before","cause","darkness","and","feet","stumble","dark","mountains","shall","wait","for","light","behold","shadow","death","they","brought","into"]},{"verseId":"brenton_jeremiah_13_17","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":17,"text":"But if ye will not hearken, your soul shall weep in secret because of pride, and your eyes shall pour down tears, because the Lord's flock is sorely bruised.","searchKeywords":["but","will","not","hearken","your","soul","shall","weep","secret","because","pride","and","eyes","pour","down","tears","the","lord","flock","sorely","bruised"]},{"verseId":"brenton_jeremiah_13_18","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":18,"text":"Say ye to the king and the princes, Humble yourselves, and sit down; for your crown of glory is removed from your head.","searchKeywords":["say","the","king","and","princes","humble","yourselves","sit","down","for","your","crown","glory","removed","from","head"]},{"verseId":"brenton_jeremiah_13_19","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":19,"text":"The cities toward the south were shut, and there was none to open : Juda is removed , they have suffered a complete removal.","searchKeywords":["the","cities","toward","south","were","shut","and","there","was","none","open","juda","removed","they","have","suffered","complete","removal"]},{"verseId":"brenton_jeremiah_13_20","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":20,"text":"Lift up thine eyes, O Jerusalem, and behold them that come from the north; where is the flock that was given thee, the sheep of thy glory?","searchKeywords":["lift","thine","eyes","jerusalem","and","behold","them","that","come","from","the","north","where","flock","was","given","thee","sheep","thy","glory"]},{"verseId":"brenton_jeremiah_13_21","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":21,"text":"What wilt thou say when they shall visit thee, for thou didst teach them lessons for rule against thyself; shall not pangs seize thee as a woman in travail?","searchKeywords":["what","wilt","thou","say","when","they","shall","visit","thee","for","didst","teach","them","lessons","rule","against","thyself","not","pangs","seize","woman","travail"]},{"verseId":"brenton_jeremiah_13_22","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":22,"text":"And if thou shouldest say in thine heart, Wherefore have these things happened to me? Because of the abundance of thine iniquity have thy skirts been discovered, that thine heels might be exposed.","searchKeywords":["and","thou","shouldest","say","thine","heart","wherefore","have","these","things","happened","because","the","abundance","iniquity","thy","skirts","been","discovered","that","heels","might","exposed"]},{"verseId":"brenton_jeremiah_13_23","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":23,"text":"If the Ethiopian shall change his skin, or the leopardess her spots, then shall ye be able to do good, having learnt evil.","searchKeywords":["the","ethiopian","shall","change","his","skin","leopardess","her","spots","then","able","good","having","learnt","evil"]},{"verseId":"brenton_jeremiah_13_24","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":24,"text":"So I scattered them as sticks carried by the wind into the wilderness.","searchKeywords":["scattered","them","sticks","carried","the","wind","into","wilderness"]},{"verseId":"brenton_jeremiah_13_25","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":25,"text":"Thus is thy lot, and the reward of your disobedience to me, saith the Lord; as thou didst forget me, and trust in lies,","searchKeywords":["thus","thy","lot","and","the","reward","your","disobedience","saith","lord","thou","didst","forget","trust","lies"]},{"verseId":"brenton_jeremiah_13_26","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":26,"text":"I also will expose thy skirts upon thy face, and thy shame shall be seen;","searchKeywords":["also","will","expose","thy","skirts","upon","face","and","shame","shall","seen"]},{"verseId":"brenton_jeremiah_13_27","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":13,"verse":27,"text":"thine adultery also, and thy neighing, and the looseness of thy fornication: on the hills and in the fields I have seen thine abominations. Woe to thee, O Jerusalem, for thou hast not been purified so as to follow me; how long yet ?","searchKeywords":["thine","adultery","also","and","thy","neighing","the","looseness","fornication","hills","fields","have","seen","abominations","woe","thee","jerusalem","for","thou","hast","not","been","purified","follow","how","long","yet"]}]