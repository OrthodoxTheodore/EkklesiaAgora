[{"verseId":"brenton_jeremiah_35_1","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":1,"text":"And it came to pass in the fourth year of Sedekias king of Juda, in the fifth month, Ananias the false prophet, the son of Azor, from Gabaon, spoke to me in the house of the Lord, in the sight of the priests and all the people, saying,","searchKeywords":["and","came","pass","the","fourth","year","sedekias","king","juda","fifth","month","ananias","false","prophet","son","azor","from","gabaon","spoke","house","lord","sight","priests","all","people","saying"]},{"verseId":"brenton_jeremiah_35_2","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":2,"text":"Thus saith the Lord; I have broken the yoke of the king of Babylon.","searchKeywords":["thus","saith","the","lord","have","broken","yoke","king","babylon"]},{"verseId":"brenton_jeremiah_35_3","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":3,"text":"Yet two full years, and I will return into this place the vessels of the house of the Lord,","searchKeywords":["yet","two","full","years","and","will","return","into","this","place","the","vessels","house","lord"]},{"verseId":"brenton_jeremiah_35_4","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":4,"text":"and Jechonias, and the captivity of Juda: for I will break the yoke of the king of Babylon.","searchKeywords":["and","jechonias","the","captivity","juda","for","will","break","yoke","king","babylon"]},{"verseId":"brenton_jeremiah_35_5","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":5,"text":"Then Jeremias spoke to Ananias in the sight of all the people, and in the sight of the priests that stood in the house of the Lord,","searchKeywords":["then","jeremias","spoke","ananias","the","sight","all","people","and","priests","that","stood","house","lord"]},{"verseId":"brenton_jeremiah_35_6","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":6,"text":"and Jeremias said, May the Lord indeed do thus; may he confirm thy word which thou dost prophesy, to return the vessels of the house of the Lord, and all the captivity, out of Babylon to this place.","searchKeywords":["and","jeremias","said","may","the","lord","indeed","thus","confirm","thy","word","which","thou","dost","prophesy","return","vessels","house","all","captivity","out","babylon","this","place"]},{"verseId":"brenton_jeremiah_35_7","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":7,"text":"Nevertheless hear ye the word of the Lord which I speak in your ears, and in the ears of all the people.","searchKeywords":["nevertheless","hear","the","word","lord","which","speak","your","ears","and","all","people"]},{"verseId":"brenton_jeremiah_35_8","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":8,"text":"The prophets that were before me and before you of old, also prophesied over much country, and against great kingdoms, concerning war.","searchKeywords":["the","prophets","that","were","before","and","you","old","also","prophesied","over","much","country","against","great","kingdoms","concerning","war"]},{"verseId":"brenton_jeremiah_35_9","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":9,"text":"the prophet that has prophesied for peace, when the word has come , they shall know the prophet whom the Lord has sent them in truth.","searchKeywords":["the","prophet","that","has","prophesied","for","peace","when","word","come","they","shall","know","whom","lord","sent","them","truth"]},{"verseId":"brenton_jeremiah_35_10","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":10,"text":"Then Ananias took the yokes from the neck of Jeremias in the sight of all the people, and broke them to pieces.","searchKeywords":["then","ananias","took","the","yokes","from","neck","jeremias","sight","all","people","and","broke","them","pieces"]},{"verseId":"brenton_jeremiah_35_11","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":11,"text":"And Ananias spoke in the presence of all the people, saying, Thus said the Lord; Thus will I break the yoke of the king of Babylon from the necks of all the nations. And Jeremias went his way.","searchKeywords":["and","ananias","spoke","the","presence","all","people","saying","thus","said","lord","will","break","yoke","king","babylon","from","necks","nations","jeremias","went","his","way"]},{"verseId":"brenton_jeremiah_35_12","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":12,"text":"And the word of the Lord came to Jeremias, after that Ananias had broken the yokes off his neck, saying,","searchKeywords":["and","the","word","lord","came","jeremias","after","that","ananias","had","broken","yokes","off","his","neck","saying"]},{"verseId":"brenton_jeremiah_35_13","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":13,"text":"Go and speak to Ananias, saying, Thus saith the Lord; Thou hast broken the yokes of wood; but I will make instead of them yokes of iron.","searchKeywords":["and","speak","ananias","saying","thus","saith","the","lord","thou","hast","broken","yokes","wood","but","will","make","instead","them","iron"]},{"verseId":"brenton_jeremiah_35_14","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":14,"text":"For thus said the Lord, I have put a yoke of iron on the neck of all the nations, that they may serve the king of Babylon.","searchKeywords":["for","thus","said","the","lord","have","put","yoke","iron","neck","all","nations","that","they","may","serve","king","babylon"]},{"verseId":"brenton_jeremiah_35_15","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":15,"text":"And Jeremias said to Ananias, The Lord has not sent thee; and thou hast caused this people to trust in unrighteousness.","searchKeywords":["and","jeremias","said","ananias","the","lord","has","not","sent","thee","thou","hast","caused","this","people","trust","unrighteousness"]},{"verseId":"brenton_jeremiah_35_16","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":16,"text":"Therefore thus said the Lord: Behold, I cast thee off from the face of the earth: this year thou shalt die.","searchKeywords":["therefore","thus","said","the","lord","behold","cast","thee","off","from","face","earth","this","year","thou","shalt","die"]},{"verseId":"brenton_jeremiah_35_17","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":35,"verse":17,"text":"So he died in the seventh month.","searchKeywords":["died","the","seventh","month"]}]