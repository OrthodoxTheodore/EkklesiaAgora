[{"verseId":"brenton_jeremiah_34_2","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":2,"text":"Thus said the Lord; Make to thyself bonds and yokes, and put about thy neck,","searchKeywords":["thus","said","the","lord","make","thyself","bonds","and","yokes","put","about","thy","neck"]},{"verseId":"brenton_jeremiah_34_3","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":3,"text":"and thou shalt send them to the king of Idumea, and to the king of Moab, and to the king of the children of Ammon, and to the king of Tyre, and to the king of Sidon, by the hands of their messengers that come to meet them at Jerusalem to Sedekias king of Juda.","searchKeywords":["and","thou","shalt","send","them","the","king","idumea","moab","children","ammon","tyre","sidon","hands","their","messengers","that","come","meet","jerusalem","sedekias","juda"]},{"verseId":"brenton_jeremiah_34_4","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":4,"text":"And thou shalt commission them to say to their lords, Thus said the Lord God of Israel; Thus shall ye say to your lords;","searchKeywords":["and","thou","shalt","commission","them","say","their","lords","thus","said","the","lord","god","israel","shall","your"]},{"verseId":"brenton_jeremiah_34_5","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":5,"text":"I have made the earth by my great power, and with my high arm, and I will give it to whomsoever it shall seem in mine eyes.","searchKeywords":["have","made","the","earth","great","power","and","with","high","arm","will","give","whomsoever","shall","seem","mine","eyes"]},{"verseId":"brenton_jeremiah_34_6","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":6,"text":"I gave the earth to Nabuchodonosor king of Babylon to serve him, and the wild beasts of the field to labour for him.","searchKeywords":["gave","the","earth","nabuchodonosor","king","babylon","serve","him","and","wild","beasts","field","labour","for"]},{"verseId":"brenton_jeremiah_34_8","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":8,"text":"And the nation and kingdom, all that shall not put their neck under the yoke of the king of Babylon, with sword and famine will I visit them, saith the Lord, until they are consumed by his hand.","searchKeywords":["and","the","nation","kingdom","all","that","shall","not","put","their","neck","under","yoke","king","babylon","with","sword","famine","will","visit","them","saith","lord","until","they","are","consumed","his","hand"]},{"verseId":"brenton_jeremiah_34_9","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":9,"text":"And hearken ye not to your false prophets, nor to them that divine to you, nor to them that foretel events by dreams to you, nor to your auguries, nor your sorcerers, that say, Ye shall by no means work for the king of Babylon:","searchKeywords":["and","hearken","not","your","false","prophets","nor","them","that","divine","you","foretel","events","dreams","auguries","sorcerers","say","shall","means","work","for","the","king","babylon"]},{"verseId":"brenton_jeremiah_34_10","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":10,"text":"for they prophesy lies to you, to remove you far from your land.","searchKeywords":["for","they","prophesy","lies","you","remove","far","from","your","land"]},{"verseId":"brenton_jeremiah_34_11","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":11,"text":"But the nation which shall put its neck under the yoke of the king of Babylon, and serve him, I will even leave it upon its land, and it shall serve him, and dwell in it.","searchKeywords":["but","the","nation","which","shall","put","its","neck","under","yoke","king","babylon","and","serve","him","will","even","leave","upon","land","dwell"]},{"verseId":"brenton_jeremiah_34_12","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":12,"text":"I spoke also to Sedekias king of Juda according to all these words, saying, Put your neck into ,","searchKeywords":["spoke","also","sedekias","king","juda","according","all","these","words","saying","put","your","neck","into"]},{"verseId":"brenton_jeremiah_34_14","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":14,"text":"and serve the king of Babylon. For they prophesy unrighteous to you,","searchKeywords":["and","serve","the","king","babylon","for","they","prophesy","unrighteous","you"]},{"verseId":"brenton_jeremiah_34_15","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":15,"text":"for I sent them not, saith the Lord; and they prophesy my name unjustly, that I might destroy you, and ye should perish, and your prophets, who unrighteously prophesy lies to you.","searchKeywords":["for","sent","them","not","saith","the","lord","and","they","prophesy","name","unjustly","that","might","destroy","you","should","perish","your","prophets","who","unrighteously","lies"]},{"verseId":"brenton_jeremiah_34_16","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":16,"text":"I spoke to you, and to all this people, and to the priests, saying, Thus said the Lord; Hearken not to the words of the prophets that prophesy to you, saying, Behold, the vessels of the Lord's house shall return from Babylon: for they prophesy to you unrighteous . I sent them not.","searchKeywords":["spoke","you","and","all","this","people","the","priests","saying","thus","said","lord","hearken","not","words","prophets","that","prophesy","behold","vessels","house","shall","return","from","babylon","for","they","unrighteous","sent","them"]},{"verseId":"brenton_jeremiah_34_18","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":18,"text":"If they are prophets, and if the word of the Lord is in them, let them meet me, for thus has the Lord said.","searchKeywords":["they","are","prophets","and","the","word","lord","them","let","meet","for","thus","has","said"]},{"verseId":"brenton_jeremiah_34_19","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":19,"text":"And as for the remaining vessels,","searchKeywords":["and","for","the","remaining","vessels"]},{"verseId":"brenton_jeremiah_34_20","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":20,"text":"which the king of Babylon took not, when he carried Jechonias prisoner out of Jerusalem,","searchKeywords":["which","the","king","babylon","took","not","when","carried","jechonias","prisoner","out","jerusalem"]},{"verseId":"brenton_jeremiah_34_22","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":34,"verse":22,"text":"they shall go into Babylon, saith the Lord.","searchKeywords":["they","shall","into","babylon","saith","the","lord"]}]