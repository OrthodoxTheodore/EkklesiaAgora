[{"verseId":"brenton_jeremiah_31_1","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":1,"text":"Thus has the Lord said concerning , Woe to Nabau! for it has perished: Cariathaim is taken: Amath and Agath are put to shame.","searchKeywords":["thus","has","the","lord","said","concerning","woe","nabau","for","perished","cariathaim","taken","amath","and","agath","are","put","shame"]},{"verseId":"brenton_jeremiah_31_2","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":2,"text":"There is no longer any healing for Moab, glorying in Esebon: he has devised evils against her: we have cut her off from a nation, and she shall be completely still: after thee shall go a sword;","searchKeywords":["there","longer","any","healing","for","moab","glorying","esebon","has","devised","evils","against","her","have","cut","off","from","nation","and","she","shall","completely","still","after","thee","sword"]},{"verseId":"brenton_jeremiah_31_3","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":3,"text":"for a voice of crying out of Oronaim, destruction and great ruin.","searchKeywords":["for","voice","crying","out","oronaim","destruction","and","great","ruin"]},{"verseId":"brenton_jeremiah_31_4","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":4,"text":"Moab is ruined, proclaim to Zogora:","searchKeywords":["moab","ruined","proclaim","zogora"]},{"verseId":"brenton_jeremiah_31_5","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":5,"text":"for Aloth is filled with weeping: one shall go up weeping by the way of Oronaim; ye have heard a cry of destruction.","searchKeywords":["for","aloth","filled","with","weeping","one","shall","the","way","oronaim","have","heard","cry","destruction"]},{"verseId":"brenton_jeremiah_31_6","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":6,"text":"Flee ye, and save your lives, and ye shall be as a wild ass in the desert.","searchKeywords":["flee","and","save","your","lives","shall","wild","ass","the","desert"]},{"verseId":"brenton_jeremiah_31_7","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":7,"text":"Since thou hast trusted in thy strong-hold, therefore thou shalt be taken: and Chamos shall go forth into captivity, and his priests, and his princes together.","searchKeywords":["since","thou","hast","trusted","thy","strong","hold","therefore","shalt","taken","and","chamos","shall","forth","into","captivity","his","priests","princes","together"]},{"verseId":"brenton_jeremiah_31_8","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":8,"text":"And destruction shall come upon every city, it shall by no means escape; the valley also shall perish, and the plain country shall be completely destroyed, as the Lord has said.","searchKeywords":["and","destruction","shall","come","upon","every","city","means","escape","the","valley","also","perish","plain","country","completely","destroyed","lord","has","said"]},{"verseId":"brenton_jeremiah_31_9","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":9,"text":"Set marks upon Moab, for she shall be touched with a plague-spot, and all her cities shall become desolate; whence an inhabitant for her?","searchKeywords":["set","marks","upon","moab","for","she","shall","touched","with","plague","spot","and","all","her","cities","become","desolate","whence","inhabitant"]},{"verseId":"brenton_jeremiah_31_10","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":10,"text":"Cursed is the man that does the works of the Lord carelessly, keeping back his sword from blood.","searchKeywords":["cursed","the","man","that","does","works","lord","carelessly","keeping","back","his","sword","from","blood"]},{"verseId":"brenton_jeremiah_31_11","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":11,"text":"Moab has been at ease from a child, and trusted in his glory; he has not poured out from vessel to vessel, and has not gone into banishment, therefore his taste remained in him, and his smell departed not.","searchKeywords":["moab","has","been","ease","from","child","and","trusted","his","glory","not","poured","out","vessel","gone","into","banishment","therefore","taste","remained","him","smell","departed"]},{"verseId":"brenton_jeremiah_31_12","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":12,"text":"Therefore, behold, his days come, saith the Lord, when I shall send upon him bad leaders, and they shall lead him astray, and they shall utterly break in pieces his possessions, and shall cut his horns asunder.","searchKeywords":["therefore","behold","his","days","come","saith","the","lord","when","shall","send","upon","him","bad","leaders","and","they","lead","astray","utterly","break","pieces","possessions","cut","horns","asunder"]},{"verseId":"brenton_jeremiah_31_13","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":13,"text":"And Moab shall be ashamed of Chamos, as the house of Israel was ashamed of Bæthel their hope, having trusted in them.","searchKeywords":["and","moab","shall","ashamed","chamos","the","house","israel","was","thel","their","hope","having","trusted","them"]},{"verseId":"brenton_jeremiah_31_14","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":14,"text":"How will ye say, We are strong, and men strong for war?","searchKeywords":["how","will","say","are","strong","and","men","for","war"]},{"verseId":"brenton_jeremiah_31_15","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":15,"text":"Moab is ruined, his city, and his choice young men have gone down to slaughter.","searchKeywords":["moab","ruined","his","city","and","choice","young","men","have","gone","down","slaughter"]},{"verseId":"brenton_jeremiah_31_16","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":16,"text":"The day of Moab is near at hand, and his iniquity moves swiftly .","searchKeywords":["the","day","moab","near","hand","and","his","iniquity","moves","swiftly"]},{"verseId":"brenton_jeremiah_31_17","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":17,"text":"Shake at him, all ye that are round about him; all utter his name; say ye, How is the glorious staff broken to pieces, the rod of magnificence!","searchKeywords":["shake","him","all","that","are","round","about","utter","his","name","say","how","the","glorious","staff","broken","pieces","rod","magnificence"]},{"verseId":"brenton_jeremiah_31_18","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":18,"text":"Come down from glory, and sit down in a damp place: Dæbon shall be broken, because Moab is destroyed: there has gone up against thee one to ravage thy strong-hold.","searchKeywords":["come","down","from","glory","and","sit","damp","place","bon","shall","broken","because","moab","destroyed","there","has","gone","against","thee","one","ravage","thy","strong","hold"]},{"verseId":"brenton_jeremiah_31_19","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":19,"text":"Stand by the way, and look, thou that dwellest in Arer; and ask him that is fleeing, and him that escapes, and say, What has happened?","searchKeywords":["stand","the","way","and","look","thou","that","dwellest","arer","ask","him","fleeing","escapes","say","what","has","happened"]},{"verseId":"brenton_jeremiah_31_20","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":20,"text":"Moab is put to shame, because he is broken: howl and cry; proclaim in Arnon, that Moab has perished.","searchKeywords":["moab","put","shame","because","broken","howl","and","cry","proclaim","arnon","that","has","perished"]},{"verseId":"brenton_jeremiah_31_21","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":21,"text":"And judgment is coming against the land of Misor, upon Chelon, and Rephas, and Mophas,","searchKeywords":["and","judgment","coming","against","the","land","misor","upon","chelon","rephas","mophas"]},{"verseId":"brenton_jeremiah_31_22","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":22,"text":"and upon Dæbon, and upon Nabau, and upon the house of Dæthlathaim,","searchKeywords":["and","upon","bon","nabau","the","house","thlathaim"]},{"verseId":"brenton_jeremiah_31_23","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":23,"text":"and upon Cariathaim, and upon the house of Gæmol, and upon the house of Maon,","searchKeywords":["and","upon","cariathaim","the","house","mol","maon"]},{"verseId":"brenton_jeremiah_31_24","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":24,"text":"and upon Carioth, and upon Bosor, and upon all the cities of Moab, far and near.","searchKeywords":["and","upon","carioth","bosor","all","the","cities","moab","far","near"]},{"verseId":"brenton_jeremiah_31_25","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":25,"text":"The horn of Moab is broken, and his arm is crushed.","searchKeywords":["the","horn","moab","broken","and","his","arm","crushed"]},{"verseId":"brenton_jeremiah_31_26","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":26,"text":"Make ye him drunk; for he has magnified himself against the Lord: and Moab shall clap with his hand, and shall be also himself a laughing-stock.","searchKeywords":["make","him","drunk","for","has","magnified","himself","against","the","lord","and","moab","shall","clap","with","his","hand","also","laughing","stock"]},{"verseId":"brenton_jeremiah_31_27","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":27,"text":"For surely Israel was to thee a laughing-stock, and was found among thy thefts, because thou didst fight against him.","searchKeywords":["for","surely","israel","was","thee","laughing","stock","and","found","among","thy","thefts","because","thou","didst","fight","against","him"]},{"verseId":"brenton_jeremiah_31_28","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":28,"text":"The inhabitants of Moab have left the cities, and dwelt in rocks; they have become as doves nestling in rocks, at the mouth of a cave.","searchKeywords":["the","inhabitants","moab","have","left","cities","and","dwelt","rocks","they","become","doves","nestling","mouth","cave"]},{"verseId":"brenton_jeremiah_31_29","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":29,"text":"And I have heard of the pride of Moab, he has greatly heightened his pride and his haughtiness, and his heart has been lifted up.","searchKeywords":["and","have","heard","the","pride","moab","has","greatly","heightened","his","haughtiness","heart","been","lifted"]},{"verseId":"brenton_jeremiah_31_30","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":30,"text":"But I know his works: is it not enough for him? has he not done thus?","searchKeywords":["but","know","his","works","not","enough","for","him","has","done","thus"]},{"verseId":"brenton_jeremiah_31_31","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":31,"text":"Therefore howl ye for Moab on all sides; cry out against the shorn men a gloomy place. I will weep for thee,","searchKeywords":["therefore","howl","for","moab","all","sides","cry","out","against","the","shorn","men","gloomy","place","will","weep","thee"]},{"verseId":"brenton_jeremiah_31_32","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":32,"text":"O vine of Aserema, as with the weeping of Jazer: thy branches are gone over the sea, they reached the cities of Jazer: destruction has come upon thy fruits, upon thy grape-gatherers.","searchKeywords":["vine","aserema","with","the","weeping","jazer","thy","branches","are","gone","over","sea","they","reached","cities","destruction","has","come","upon","fruits","grape","gatherers"]},{"verseId":"brenton_jeremiah_31_33","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":33,"text":"Joy and gladness have been utterly swept off the land of Moab: and there was wine in thy presses, in the morning they trod it not, neither in the evening did they raise the cry of joy.","searchKeywords":["joy","and","gladness","have","been","utterly","swept","off","the","land","moab","there","was","wine","thy","presses","morning","they","trod","not","neither","evening","did","raise","cry"]},{"verseId":"brenton_jeremiah_31_34","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":34,"text":"From the cry of Esebon even to Ætam their cities uttered their voice, from Zogor to Oronaim, and their tidings a heifer of three years old, for the water also of Nebrin shall be dried up.","searchKeywords":["from","the","cry","esebon","even","tam","their","cities","uttered","voice","zogor","oronaim","and","tidings","heifer","three","years","old","for","water","also","nebrin","shall","dried"]},{"verseId":"brenton_jeremiah_31_35","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":35,"text":"And I will destroy Moab, saith the Lord, as he comes up to the altar, and burns incense to his gods.","searchKeywords":["and","will","destroy","moab","saith","the","lord","comes","altar","burns","incense","his","gods"]},{"verseId":"brenton_jeremiah_31_36","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":36,"text":"Therefore the heart of Moab shall sound as pipes, my heart shall sound as a pipe for the shorn men; forasmuch as what man has gained has perished from him.","searchKeywords":["therefore","the","heart","moab","shall","sound","pipes","pipe","for","shorn","men","forasmuch","what","man","has","gained","perished","from","him"]},{"verseId":"brenton_jeremiah_31_37","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":37,"text":"They shall all have their heads shaved in every place, and every beard shall be shaved; and all hands shall beat , and on all loins shall be sackcloth.","searchKeywords":["they","shall","all","have","their","heads","shaved","every","place","and","beard","hands","beat","loins","sackcloth"]},{"verseId":"brenton_jeremiah_31_38","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":38,"text":"And on all the housetops of Moab, and in his streets : for I have broken , saith the Lord, as a vessel, which is useless.","searchKeywords":["and","all","the","housetops","moab","his","streets","for","have","broken","saith","lord","vessel","which","useless"]},{"verseId":"brenton_jeremiah_31_39","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":39,"text":"How has he changed! how has Moab turned back! Moab is put to shame, and become a laughing-stock, and an object of anger to all that are round about him.","searchKeywords":["how","has","changed","moab","turned","back","put","shame","and","become","laughing","stock","object","anger","all","that","are","round","about","him"]},{"verseId":"brenton_jeremiah_31_40","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":40,"text":"For thus said the Lord;","searchKeywords":["for","thus","said","the","lord"]},{"verseId":"brenton_jeremiah_31_41","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":41,"text":"Carioth is taken, and the strong-holds have been taken together.","searchKeywords":["carioth","taken","and","the","strong","holds","have","been","together"]},{"verseId":"brenton_jeremiah_31_42","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":42,"text":"And Moab shall perish from being a multitude, because he has magnified himself against the Lord.","searchKeywords":["and","moab","shall","perish","from","being","multitude","because","has","magnified","himself","against","the","lord"]},{"verseId":"brenton_jeremiah_31_43","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":43,"text":"A snare, and fear, and the pit, are upon thee, O inhabitant of Moab.","searchKeywords":["snare","and","fear","the","pit","are","upon","thee","inhabitant","moab"]},{"verseId":"brenton_jeremiah_31_44","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":31,"verse":44,"text":"He that flees from the terror shall fall into the pit, and he that comes up out of the pit shall even be taken in the snare: for I will bring these things upon Moab in the year of their visitation.","searchKeywords":["that","flees","from","the","terror","shall","fall","into","pit","and","comes","out","even","taken","snare","for","will","bring","these","things","upon","moab","year","their","visitation"]}]