[{"verseId":"brenton_jeremiah_18_1","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":1,"text":"The word that came from the Lord to","searchKeywords":["the","word","that","came","from","lord"]},{"verseId":"brenton_jeremiah_18_2","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":2,"text":"Jeremias, saying, Arise, and go down to the potter's house, and there thou shalt hear my words.","searchKeywords":["jeremias","saying","arise","and","down","the","potter","house","there","thou","shalt","hear","words"]},{"verseId":"brenton_jeremiah_18_3","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":3,"text":"So I went down to the potter's house, and behold, he was making a vessel on the stones.","searchKeywords":["went","down","the","potter","house","and","behold","was","making","vessel","stones"]},{"verseId":"brenton_jeremiah_18_4","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":4,"text":"And the vessel which he was making with his hands fell: so he made it again another vessel, as it seemed good to him to make .","searchKeywords":["and","the","vessel","which","was","making","with","his","hands","fell","made","again","another","seemed","good","him","make"]},{"verseId":"brenton_jeremiah_18_5","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":5,"text":"And the word of the Lord came to me, saying,","searchKeywords":["and","the","word","lord","came","saying"]},{"verseId":"brenton_jeremiah_18_6","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":6,"text":"Shall I not be able, O house of Israel, to do to you as this potter? behold, as the clay of the potter are ye in my hands.","searchKeywords":["shall","not","able","house","israel","you","this","potter","behold","the","clay","are","hands"]},{"verseId":"brenton_jeremiah_18_7","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":7,"text":"I shall pronounce a decree upon a nation, or upon a kingdom, to cut them off, and to destroy ;","searchKeywords":["shall","pronounce","decree","upon","nation","kingdom","cut","them","off","and","destroy"]},{"verseId":"brenton_jeremiah_18_8","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":8,"text":"and that nation turn from all their sins, then will I repent of the evils which I purposed to do to them.","searchKeywords":["and","that","nation","turn","from","all","their","sins","then","will","repent","the","evils","which","purposed","them"]},{"verseId":"brenton_jeremiah_18_9","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":9,"text":"And I shall pronounce a decree upon a nation and kingdom, to rebuild and to plant ;","searchKeywords":["and","shall","pronounce","decree","upon","nation","kingdom","rebuild","plant"]},{"verseId":"brenton_jeremiah_18_10","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":10,"text":"and they do evil before me, so as not to hearken to my voice, then will I repent of the good which I spoke of, to do it to them.","searchKeywords":["and","they","evil","before","not","hearken","voice","then","will","repent","the","good","which","spoke","them"]},{"verseId":"brenton_jeremiah_18_11","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":11,"text":"And now say to the men of Juda, and to the inhabitants of Jerusalem, Behold, I prepare evils against you, and devise a device against you: let every one turn now from his evil way, and amend your practices.","searchKeywords":["and","now","say","the","men","juda","inhabitants","jerusalem","behold","prepare","evils","against","you","devise","device","let","every","one","turn","from","his","evil","way","amend","your","practices"]},{"verseId":"brenton_jeremiah_18_12","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":12,"text":"And they said, We will quit ourselves like men, for we will pursue our perverse ways, and we will perform each the lusts of his evil heart.","searchKeywords":["and","they","said","will","quit","ourselves","like","men","for","pursue","our","perverse","ways","perform","each","the","lusts","his","evil","heart"]},{"verseId":"brenton_jeremiah_18_13","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":13,"text":"Therefore thus saith the Lord; Enquire now among the nations, who has heard such very horrible things as the virgin of Israel has done?","searchKeywords":["therefore","thus","saith","the","lord","enquire","now","among","nations","who","has","heard","such","very","horrible","things","virgin","israel","done"]},{"verseId":"brenton_jeremiah_18_14","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":14,"text":"Will fertilising streams fail from a rock, or snow from Libanus? will water violently impelled by the wind turn aside?","searchKeywords":["will","fertilising","streams","fail","from","rock","snow","libanus","water","violently","impelled","the","wind","turn","aside"]},{"verseId":"brenton_jeremiah_18_15","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":15,"text":"For my people have forgotten me, they have offered incense in vain, and they fail in their ways, the ancient tracks, to enter upon impassable paths;","searchKeywords":["for","people","have","forgotten","they","offered","incense","vain","and","fail","their","ways","the","ancient","tracks","enter","upon","impassable","paths"]},{"verseId":"brenton_jeremiah_18_16","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":16,"text":"to make their land a desolation, and a perpetual hissing; all that go through it shall be amazed, and shall shake their heads.","searchKeywords":["make","their","land","desolation","and","perpetual","hissing","all","that","through","shall","amazed","shake","heads"]},{"verseId":"brenton_jeremiah_18_17","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":17,"text":"I will scatter them before their enemies like an east wind; I will shew them the day of their destruction.","searchKeywords":["will","scatter","them","before","their","enemies","like","east","wind","shew","the","day","destruction"]},{"verseId":"brenton_jeremiah_18_18","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":18,"text":"Then they said, Come, and let us devise a device against Jeremias; for the law shall not perish from the priest, nor counsel from the wise, nor the word from the prophet. Come, and let us smite him with the tongue, and we will hear all his words.","searchKeywords":["then","they","said","come","and","let","devise","device","against","jeremias","for","the","law","shall","not","perish","from","priest","nor","counsel","wise","word","prophet","smite","him","with","tongue","will","hear","all","his","words"]},{"verseId":"brenton_jeremiah_18_19","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":19,"text":"Hear me, O Lord, and hear the voice of my pleading.","searchKeywords":["hear","lord","and","the","voice","pleading"]},{"verseId":"brenton_jeremiah_18_20","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":20,"text":"Forasmuch as evil is rewarded for good; for they have spoken words against my soul, and they have hidden the punishment they for me; remember that I stood before thy face, to speak good for them, to turn away thy wrath from them.","searchKeywords":["forasmuch","evil","rewarded","for","good","they","have","spoken","words","against","soul","and","hidden","the","punishment","remember","that","stood","before","thy","face","speak","them","turn","away","wrath","from"]},{"verseId":"brenton_jeremiah_18_21","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":21,"text":"Therefore do thou deliver their sons to famine, and gather them to the power of the sword: let their women be childless and widows; and let their men be cut off by death, and their young men fall by the sword in war.","searchKeywords":["therefore","thou","deliver","their","sons","famine","and","gather","them","the","power","sword","let","women","childless","widows","men","cut","off","death","young","fall","war"]},{"verseId":"brenton_jeremiah_18_22","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":22,"text":"Let there be a cry in their houses: thou shalt bring upon them robbers suddenly: for they have formed a plan to take me, and have hidden snares for me.","searchKeywords":["let","there","cry","their","houses","thou","shalt","bring","upon","them","robbers","suddenly","for","they","have","formed","plan","take","and","hidden","snares"]},{"verseId":"brenton_jeremiah_18_23","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":18,"verse":23,"text":"And thou, Lord, knowest all their deadly counsel against me: account not their iniquities guiltless, and blot not out their sins from before thee: let their weakness come before thee; deal with them in the time of thy wrath.","searchKeywords":["and","thou","lord","knowest","all","their","deadly","counsel","against","account","not","iniquities","guiltless","blot","out","sins","from","before","thee","let","weakness","come","deal","with","them","the","time","thy","wrath"]}]