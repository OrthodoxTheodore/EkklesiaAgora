[{"verseId":"brenton_jeremiah_36_1","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":1,"text":"And these are the words of the book which Jeremias sent from Jerusalem to the elders of the captivity, and to the priests, and to the false prophets, even an epistle to Babylon for the captivity, and to all the people;","searchKeywords":["and","these","are","the","words","book","which","jeremias","sent","from","jerusalem","elders","captivity","priests","false","prophets","even","epistle","babylon","for","all","people"]},{"verseId":"brenton_jeremiah_36_2","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":2,"text":"(after the departure of Jechonias the king and the queen, and the eunuchs, and every freeman, and bondman, and artificer, out of Jerusalem;)","searchKeywords":["after","the","departure","jechonias","king","and","queen","eunuchs","every","freeman","bondman","artificer","out","jerusalem"]},{"verseId":"brenton_jeremiah_36_3","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":3,"text":"by the hand of Eleasan son of Saphan, and Gamarias son of Chelcias, (whom Sedekias king of Juda sent to the king of Babylon to Babylon) saying,","searchKeywords":["the","hand","eleasan","son","saphan","and","gamarias","chelcias","whom","sedekias","king","juda","sent","babylon","saying"]},{"verseId":"brenton_jeremiah_36_4","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":4,"text":"Thus said the Lord God of Israel concerning the captivity which I caused to be carried away from Jerusalem;","searchKeywords":["thus","said","the","lord","god","israel","concerning","captivity","which","caused","carried","away","from","jerusalem"]},{"verseId":"brenton_jeremiah_36_5","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":5,"text":"Build ye houses, and inhabit ; and plant gardens, and eat the fruits thereof;","searchKeywords":["build","houses","and","inhabit","plant","gardens","eat","the","fruits","thereof"]},{"verseId":"brenton_jeremiah_36_6","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":6,"text":"and take ye wives, and beget sons and daughters; and take wives for your sons, and give your daughters to husbands, and be multiplied, and be not diminished.","searchKeywords":["and","take","wives","beget","sons","daughters","for","your","give","husbands","multiplied","not","diminished"]},{"verseId":"brenton_jeremiah_36_7","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":7,"text":"And seek the peace of the land into which I have carried you captive, and ye shall pray to the Lord for the people: for in its peace ye shall peace.","searchKeywords":["and","seek","the","peace","land","into","which","have","carried","you","captive","shall","pray","lord","for","people","its"]},{"verseId":"brenton_jeremiah_36_8","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":8,"text":"For thus saith the Lord; Let not the false prophets that are among you persuade you, and let not your diviners persuade you, and hearken not to your dreams which ye dream.","searchKeywords":["for","thus","saith","the","lord","let","not","false","prophets","that","are","among","you","persuade","and","your","diviners","hearken","dreams","which","dream"]},{"verseId":"brenton_jeremiah_36_9","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":9,"text":"For they prophesy to you unrighteous in my name; and I sent them not.","searchKeywords":["for","they","prophesy","you","unrighteous","name","and","sent","them","not"]},{"verseId":"brenton_jeremiah_36_10","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":10,"text":"For thus said the Lord; When seventy years shall be on the point of being accomplished at Babylon, I will visit you, and will confirm my words to you, to bring back your people to this place.","searchKeywords":["for","thus","said","the","lord","when","seventy","years","shall","point","being","accomplished","babylon","will","visit","you","and","confirm","words","bring","back","your","people","this","place"]},{"verseId":"brenton_jeremiah_36_11","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":11,"text":"And I will devise for you a device of peace, and not evil, to bestow upon you these .","searchKeywords":["and","will","devise","for","you","device","peace","not","evil","bestow","upon","these"]},{"verseId":"brenton_jeremiah_36_12","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":12,"text":"And do ye pray to me, and I will hearken to you: and do ye earnestly seek me, and ye shall find me;","searchKeywords":["and","pray","will","hearken","you","earnestly","seek","shall","find"]},{"verseId":"brenton_jeremiah_36_13","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":13,"text":"for ye shall seek me with your whole heart.","searchKeywords":["for","shall","seek","with","your","whole","heart"]},{"verseId":"brenton_jeremiah_36_14","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":14,"text":"And I will appear to you:","searchKeywords":["and","will","appear","you"]},{"verseId":"brenton_jeremiah_36_15","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":15,"text":"whereas ye said, The Lord has appointed for us prophets in Babylon:","searchKeywords":["whereas","said","the","lord","has","appointed","for","prophets","babylon"]},{"verseId":"brenton_jeremiah_36_21","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":21,"text":"Thus saith the Lord concerning Achiab, and concerning Sedekias; Behold, I deliver them into the hands of the king of Babylon; and he shall smite them in your sight.","searchKeywords":["thus","saith","the","lord","concerning","achiab","and","sedekias","behold","deliver","them","into","hands","king","babylon","shall","smite","your","sight"]},{"verseId":"brenton_jeremiah_36_22","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":22,"text":"And they shall make of them a curse in all the captivity of Juda in Babylon, saying, The Lord do to thee as he did to Sedekias, and as he did to Achiab, whom the king of Babylon fried in the fire;","searchKeywords":["and","they","shall","make","them","curse","all","the","captivity","juda","babylon","saying","lord","thee","did","sedekias","achiab","whom","king","fried","fire"]},{"verseId":"brenton_jeremiah_36_23","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":23,"text":"because of the iniquity which they wrought in Israel, and they committed adultery with the wives of their fellow-citizens, and spoke a word in my name, which I did not command them , and I am witness, saith the Lord.","searchKeywords":["because","the","iniquity","which","they","wrought","israel","and","committed","adultery","with","wives","their","fellow","citizens","spoke","word","name","did","not","command","them","witness","saith","lord"]},{"verseId":"brenton_jeremiah_36_24","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":24,"text":"And to Samæas the Ælamite thou shalt say,","searchKeywords":["and","sam","the","lamite","thou","shalt","say"]},{"verseId":"brenton_jeremiah_36_25","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":25,"text":"I sent thee not in my name: and to Sophonias the priest the son of Maasæas say thou,","searchKeywords":["sent","thee","not","name","and","sophonias","the","priest","son","maas","say","thou"]},{"verseId":"brenton_jeremiah_36_26","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":26,"text":"The Lord has made thee priest in the place of Jodae the priest, to be ruler in the house of the Lord over every prophet, and to every madman, and thou shalt put them in prison, and into the dungeon.","searchKeywords":["the","lord","has","made","thee","priest","place","jodae","ruler","house","over","every","prophet","and","madman","thou","shalt","put","them","prison","into","dungeon"]},{"verseId":"brenton_jeremiah_36_27","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":27,"text":"And now wherefore have ye reviled together Jeremias of Anathoth, who prophesied to you?","searchKeywords":["and","now","wherefore","have","reviled","together","jeremias","anathoth","who","prophesied","you"]},{"verseId":"brenton_jeremiah_36_28","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":28,"text":"Did he not send for this purpose? for in the course of this month he sent to you to Babylon, saying, It is far off: build ye houses, and inhabit ; and plant gardens, and eat the fruit of them.","searchKeywords":["did","not","send","for","this","purpose","the","course","month","sent","you","babylon","saying","far","off","build","houses","and","inhabit","plant","gardens","eat","fruit","them"]},{"verseId":"brenton_jeremiah_36_29","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":29,"text":"And Sophonias read the book in the ears of Jeremias.","searchKeywords":["and","sophonias","read","the","book","ears","jeremias"]},{"verseId":"brenton_jeremiah_36_30","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":30,"text":"Then the word of the Lord came to Jeremias, saying,","searchKeywords":["then","the","word","lord","came","jeremias","saying"]},{"verseId":"brenton_jeremiah_36_31","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":31,"text":"Send to the captivity, saying, Thus saith the Lord concerning Samæas the Ælamite, Since Samæas has prophesied to you, and I sent him not, and he has made you to trust in iniquity,","searchKeywords":["send","the","captivity","saying","thus","saith","lord","concerning","sam","lamite","since","has","prophesied","you","and","sent","him","not","made","trust","iniquity"]},{"verseId":"brenton_jeremiah_36_32","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":36,"verse":32,"text":"therefore thus saith the Lord; Behold, I will visit Samæas, and his family: and there shall not be a man of them in the midst of you to see the good which I will do to you: they shall not see .","searchKeywords":["therefore","thus","saith","the","lord","behold","will","visit","sam","and","his","family","there","shall","not","man","them","midst","you","see","good","which","they"]}]