[{"verseId":"brenton_jeremiah_44_1","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":1,"text":"And Sedekias the son of Josias reigned instead of Joakim, whom Nabuchodonosor appointed to reign over Juda.","searchKeywords":["and","sedekias","the","son","josias","reigned","instead","joakim","whom","nabuchodonosor","appointed","reign","over","juda"]},{"verseId":"brenton_jeremiah_44_2","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":2,"text":"And he and his servants and the people of the land hearkened not to the words of the Lord, which he spoke by Jeremias.","searchKeywords":["and","his","servants","the","people","land","hearkened","not","words","lord","which","spoke","jeremias"]},{"verseId":"brenton_jeremiah_44_3","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":3,"text":"And king Sedekias sent Joachal son of Selemias and Sophonias the priest son of Maasæas to Jeremias, saying, Pray now for us to the Lord.","searchKeywords":["and","king","sedekias","sent","joachal","son","selemias","sophonias","the","priest","maas","jeremias","saying","pray","now","for","lord"]},{"verseId":"brenton_jeremiah_44_4","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":4,"text":"Now Jeremias came and went through the midst of the city: for they not put him into the house of the prison.","searchKeywords":["now","jeremias","came","and","went","through","the","midst","city","for","they","not","put","him","into","house","prison"]},{"verseId":"brenton_jeremiah_44_5","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":5,"text":"And the host of Pharao was come forth out of Egypt; and the Chaldeans heard the report of them, and they went up from Jerusalem.","searchKeywords":["and","the","host","pharao","was","come","forth","out","egypt","chaldeans","heard","report","them","they","went","from","jerusalem"]},{"verseId":"brenton_jeremiah_44_6","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":6,"text":"And the word of the Lord came to Jeremias, saying,","searchKeywords":["and","the","word","lord","came","jeremias","saying"]},{"verseId":"brenton_jeremiah_44_7","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":7,"text":"Thus said the Lord; Thus shalt thou say to the king of Juda who sent to thee, to seek me; Behold, the army of Pharao which is come forth to help you: they shall return to the land of Egypt:","searchKeywords":["thus","said","the","lord","shalt","thou","say","king","juda","who","sent","thee","seek","behold","army","pharao","which","come","forth","help","you","they","shall","return","land","egypt"]},{"verseId":"brenton_jeremiah_44_8","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":8,"text":"and the Chaldeans themselves shall turn again, and fight against this city, and take it, and burn it with fire.","searchKeywords":["and","the","chaldeans","themselves","shall","turn","again","fight","against","this","city","take","burn","with","fire"]},{"verseId":"brenton_jeremiah_44_9","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":9,"text":"For thus saith the Lord; Suppose not in your hearts, saying, The Chaldeans will certainly depart from us: for they shall not depart.","searchKeywords":["for","thus","saith","the","lord","suppose","not","your","hearts","saying","chaldeans","will","certainly","depart","from","they","shall"]},{"verseId":"brenton_jeremiah_44_10","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":10,"text":"And though ye should smite the whole host of the Chaldeans that fight against you, and there should be left a few wounded , these should rise up each in his place, and burn this city with fire.","searchKeywords":["and","though","should","smite","the","whole","host","chaldeans","that","fight","against","you","there","left","few","wounded","these","rise","each","his","place","burn","this","city","with","fire"]},{"verseId":"brenton_jeremiah_44_11","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":11,"text":"And it came to pass, when the host of the Chaldeans had gone up from Jerusalem for fear of the host of Pharao,","searchKeywords":["and","came","pass","when","the","host","chaldeans","had","gone","from","jerusalem","for","fear","pharao"]},{"verseId":"brenton_jeremiah_44_12","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":12,"text":"that Jeremias went forth from Jerusalem to go into the land of Benjamin, to buy thence in the midst of the people.","searchKeywords":["that","jeremias","went","forth","from","jerusalem","into","the","land","benjamin","buy","thence","midst","people"]},{"verseId":"brenton_jeremiah_44_13","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":13,"text":"And he was in the gate of Benjamin, and there a man with whom he lodged, Saruia the son of Selemias, the son of Ananias; and he caught Jeremias, saying, Thou art fleeing to the Chaldeans.","searchKeywords":["and","was","the","gate","benjamin","there","man","with","whom","lodged","saruia","son","selemias","ananias","caught","jeremias","saying","thou","art","fleeing","chaldeans"]},{"verseId":"brenton_jeremiah_44_14","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":14,"text":"And he said, false; I do not flee to the Chaldeans. But he hearkened not to him; and Saruia caught Jeremias, and brought him to the princes.","searchKeywords":["and","said","false","not","flee","the","chaldeans","but","hearkened","him","saruia","caught","jeremias","brought","princes"]},{"verseId":"brenton_jeremiah_44_15","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":15,"text":"And the princes were very angry with Jeremias, and smote him, and sent him into the house of Jonathan the scribe: for they had made this a prison.","searchKeywords":["and","the","princes","were","very","angry","with","jeremias","smote","him","sent","into","house","jonathan","scribe","for","they","had","made","this","prison"]},{"verseId":"brenton_jeremiah_44_16","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":16,"text":"So Jeremias came into the dungeon, and into the cells, and he remained there many days.","searchKeywords":["jeremias","came","into","the","dungeon","and","cells","remained","there","many","days"]},{"verseId":"brenton_jeremiah_44_17","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":17,"text":"Then Sedekias sent, and called him; and the king asked him secretly, saying, Is there a word from the Lord? and he said, There is: thou shalt be delivered into the hands of the king of Babylon.","searchKeywords":["then","sedekias","sent","and","called","him","the","king","asked","secretly","saying","there","word","from","lord","said","thou","shalt","delivered","into","hands","babylon"]},{"verseId":"brenton_jeremiah_44_18","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":18,"text":"And Jeremias said to the king, Wherein have I wronged thee, or thy servants, or this people, that thou puttest me in prison?","searchKeywords":["and","jeremias","said","the","king","wherein","have","wronged","thee","thy","servants","this","people","that","thou","puttest","prison"]},{"verseId":"brenton_jeremiah_44_19","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":19,"text":"And where are your prophets who prophesied to you saying, The king of Babylon shall not come against this land?","searchKeywords":["and","where","are","your","prophets","who","prophesied","you","saying","the","king","babylon","shall","not","come","against","this","land"]},{"verseId":"brenton_jeremiah_44_20","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":20,"text":"Now therefore, my lord the king, let my supplication come before thy face: and why dost thou send me back to the house of Jonathan the scribe? and let me not on any account die there.","searchKeywords":["now","therefore","lord","the","king","let","supplication","come","before","thy","face","and","why","dost","thou","send","back","house","jonathan","scribe","not","any","account","die","there"]},{"verseId":"brenton_jeremiah_44_21","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":44,"verse":21,"text":"Then the king commanded, and they cast him into the prison, and gave him a loaf a day out of the place where they bake, until the bread failed out of the city. So Jeremias continued in the court of the prison.","searchKeywords":["then","the","king","commanded","and","they","cast","him","into","prison","gave","loaf","day","out","place","where","bake","until","bread","failed","city","jeremias","continued","court"]}]