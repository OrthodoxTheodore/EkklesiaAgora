[{"verseId":"brenton_jeremiah_25_1","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":1,"text":"concerning all the people of Juda in the fourth year of Joakim, son of Josias, king of Juda;","searchKeywords":["concerning","all","the","people","juda","fourth","year","joakim","son","josias","king"]},{"verseId":"brenton_jeremiah_25_2","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":2,"text":"which he spoke to all the people of Juda, and to the inhabitants of Jerusalem, saying,","searchKeywords":["which","spoke","all","the","people","juda","and","inhabitants","jerusalem","saying"]},{"verseId":"brenton_jeremiah_25_3","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":3,"text":"In the thirteenth year of Josias, son of Amos, king of Juda, even until this day for three and twenty years, I have both spoken to you, rising early and speaking,","searchKeywords":["the","thirteenth","year","josias","son","amos","king","juda","even","until","this","day","for","three","and","twenty","years","have","both","spoken","you","rising","early","speaking"]},{"verseId":"brenton_jeremiah_25_4","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":4,"text":"and I sent to you my servants the prophets, sending them early; (but ye hearkened not, and listened not with your ears;) saying,","searchKeywords":["and","sent","you","servants","the","prophets","sending","them","early","but","hearkened","not","listened","with","your","ears","saying"]},{"verseId":"brenton_jeremiah_25_5","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":5,"text":"Turn ye every one from his evil way, and from your evil practices, and ye shall dwell in the land which I gave to you and your fathers, of old and for ever.","searchKeywords":["turn","every","one","from","his","evil","way","and","your","practices","shall","dwell","the","land","which","gave","you","fathers","old","for","ever"]},{"verseId":"brenton_jeremiah_25_6","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":6,"text":"Go ye not after strange gods, to serve them, and to worship them, that ye provoke me not by the works of your hands, to do you hurt.","searchKeywords":["not","after","strange","gods","serve","them","and","worship","that","provoke","the","works","your","hands","you","hurt"]},{"verseId":"brenton_jeremiah_25_7","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":7,"text":"But ye hearkened not to me.","searchKeywords":["but","hearkened","not"]},{"verseId":"brenton_jeremiah_25_8","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":8,"text":"Therefore thus saith the Lord; Since ye believed not my words,","searchKeywords":["therefore","thus","saith","the","lord","since","believed","not","words"]},{"verseId":"brenton_jeremiah_25_9","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":9,"text":"behold, I send and take a family from the north, and will bring them against this land, and against the inhabitants of it, and against all the nations round about it, and I will make them utterly waste, and make them a desolation, and a hissing, and an everlasting reproach.","searchKeywords":["behold","send","and","take","family","from","the","north","will","bring","them","against","this","land","inhabitants","all","nations","round","about","make","utterly","waste","desolation","hissing","everlasting","reproach"]},{"verseId":"brenton_jeremiah_25_10","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":10,"text":"And I will destroy from them the voice of joy, and the voice of gladness, the voice of the bridegroom, and the voice of the bride, the scent of ointment, and the light of a candle.","searchKeywords":["and","will","destroy","from","them","the","voice","joy","gladness","bridegroom","bride","scent","ointment","light","candle"]},{"verseId":"brenton_jeremiah_25_11","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":11,"text":"And all the land shall be a desolation; and they shall serve among the Gentiles seventy years.","searchKeywords":["and","all","the","land","shall","desolation","they","serve","among","gentiles","seventy","years"]},{"verseId":"brenton_jeremiah_25_12","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":12,"text":"And when the seventy years are fulfilled, I will take vengeance on that nation, and will make them a perpetual desolation.","searchKeywords":["and","when","the","seventy","years","are","fulfilled","will","take","vengeance","that","nation","make","them","perpetual","desolation"]},{"verseId":"brenton_jeremiah_25_13","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":13,"text":"And I will bring upon that land all my words which I have spoken against it, all things that are written in this book.","searchKeywords":["and","will","bring","upon","that","land","all","words","which","have","spoken","against","things","are","written","this","book"]},{"verseId":"brenton_jeremiah_25_15","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":15,"text":"Thus saith the Lord, The bow of Ælam is broken, the chief of their power.","searchKeywords":["thus","saith","the","lord","bow","lam","broken","chief","their","power"]},{"verseId":"brenton_jeremiah_25_16","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":16,"text":"And I will bring upon Ælam the four winds from the four corners of heaven, and I will disperse them toward all these winds; and there shall be no nation which they shall not come— the outcasts of Ælam.","searchKeywords":["and","will","bring","upon","lam","the","four","winds","from","corners","heaven","disperse","them","toward","all","these","there","shall","nation","which","they","not","come","outcasts"]},{"verseId":"brenton_jeremiah_25_17","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":17,"text":"And I will put them in fear before their enemies that seek their life; and I will bring evils upon them according to my great anger; and I will send forth my sword after them, until I have utterly destroyed them.","searchKeywords":["and","will","put","them","fear","before","their","enemies","that","seek","life","bring","evils","upon","according","great","anger","send","forth","sword","after","until","have","utterly","destroyed"]},{"verseId":"brenton_jeremiah_25_18","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":18,"text":"And I will set my throne in Ælam, and will send forth thence king and rulers.","searchKeywords":["and","will","set","throne","lam","send","forth","thence","king","rulers"]},{"verseId":"brenton_jeremiah_25_19","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":19,"text":"But it shall come to pass at the end of days, that I will turn the captivity of Ælam, saith the Lord.","searchKeywords":["but","shall","come","pass","the","end","days","that","will","turn","captivity","lam","saith","lord"]},{"verseId":"brenton_jeremiah_25_20","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":25,"verse":20,"text":"In the beginning of the reign of king Sedekias, there came this word concerning Ælam.","searchKeywords":["the","beginning","reign","king","sedekias","there","came","this","word","concerning","lam"]}]