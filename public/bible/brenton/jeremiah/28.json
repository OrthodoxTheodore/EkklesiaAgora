[{"verseId":"brenton_jeremiah_28_1","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":1,"text":"Thus saith the Lord; Behold, I stir up against Babylon, and against the Chaldeans dwelling therein, a deadly burning wind.","searchKeywords":["thus","saith","the","lord","behold","stir","against","babylon","and","chaldeans","dwelling","therein","deadly","burning","wind"]},{"verseId":"brenton_jeremiah_28_2","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":2,"text":"And I will send forth against Babylon spoilers, and they shall spoil her, and shall ravage her land. Woe to Babylon round about in the day of her affliction.","searchKeywords":["and","will","send","forth","against","babylon","spoilers","they","shall","spoil","her","ravage","land","woe","round","about","the","day","affliction"]},{"verseId":"brenton_jeremiah_28_3","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":3,"text":"Let the archer bend his bow, and him that has armour put it on: and spare ye not her young men, but destroy ye all her host.","searchKeywords":["let","the","archer","bend","his","bow","and","him","that","has","armour","put","spare","not","her","young","men","but","destroy","all","host"]},{"verseId":"brenton_jeremiah_28_4","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":4,"text":"And slain men shall fall in the land of the Chaldeans, and pierced through shall fall without it.","searchKeywords":["and","slain","men","shall","fall","the","land","chaldeans","pierced","through","without"]},{"verseId":"brenton_jeremiah_28_5","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":5,"text":"For Israel and Juda have not been forsaken of their God, of the Lord Almighty; whereas their land was filled with iniquity against the holy things of Israel.","searchKeywords":["for","israel","and","juda","have","not","been","forsaken","their","god","the","lord","almighty","whereas","land","was","filled","with","iniquity","against","holy","things"]},{"verseId":"brenton_jeremiah_28_6","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":6,"text":"Flee ye out of the midst of Babylon, and deliver every one his soul: and be not overthrown in her iniquity; for it is the time of her retribution from the Lord; he is rendering to her a recompence.","searchKeywords":["flee","out","the","midst","babylon","and","deliver","every","one","his","soul","not","overthrown","her","iniquity","for","time","retribution","from","lord","rendering","recompence"]},{"verseId":"brenton_jeremiah_28_7","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":7,"text":"Babylon has been a golden cup in the Lord's hand, causing all the earth to be drunken: the nations have drunk of her wine; therefore they were shaken.","searchKeywords":["babylon","has","been","golden","cup","the","lord","hand","causing","all","earth","drunken","nations","have","drunk","her","wine","therefore","they","were","shaken"]},{"verseId":"brenton_jeremiah_28_8","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":8,"text":"And Babylon is fallen suddenly, and is broken to pieces: lament for her; take balm for her deadly wound, if by any means she may be healed.","searchKeywords":["and","babylon","fallen","suddenly","broken","pieces","lament","for","her","take","balm","deadly","wound","any","means","she","may","healed"]},{"verseId":"brenton_jeremiah_28_9","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":9,"text":"We tried to heal Babylon, but she was not healed: let us forsake her, and depart every one to his own country: for her judgment has reached to the heaven, it has mounted up to the stars.","searchKeywords":["tried","heal","babylon","but","she","was","not","healed","let","forsake","her","and","depart","every","one","his","own","country","for","judgment","has","reached","the","heaven","mounted","stars"]},{"verseId":"brenton_jeremiah_28_10","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":10,"text":"The Lord has brought forth his judgment: come, and let us declare in Sion the works of the Lord our God.","searchKeywords":["the","lord","has","brought","forth","his","judgment","come","and","let","declare","sion","works","our","god"]},{"verseId":"brenton_jeremiah_28_11","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":11,"text":"Prepare the arrows; fill the quivers: the Lord has stirred up the spirit of the king of the Medes: for his wrath is against Babylon, to destroy it utterly; for it is the Lord's vengeance, it is the vengeance of his people.","searchKeywords":["prepare","the","arrows","fill","quivers","lord","has","stirred","spirit","king","medes","for","his","wrath","against","babylon","destroy","utterly","vengeance","people"]},{"verseId":"brenton_jeremiah_28_12","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":12,"text":"Lift up a standard on the walls of Babylon, prepare the quivers, rouse the guards, prepare the weapons: for the Lord has taken in hand, and will execute what he has spoken against the inhabitants of Babylon,","searchKeywords":["lift","standard","the","walls","babylon","prepare","quivers","rouse","guards","weapons","for","lord","has","taken","hand","and","will","execute","what","spoken","against","inhabitants"]},{"verseId":"brenton_jeremiah_28_13","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":13,"text":"dwelling on many waters, and amidst the abundance of her treasures; thine end is come verily into thy bowels.","searchKeywords":["dwelling","many","waters","and","amidst","the","abundance","her","treasures","thine","end","come","verily","into","thy","bowels"]},{"verseId":"brenton_jeremiah_28_14","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":14,"text":"For the Lord has sworn by his arm, , I will fill thee with men as with locusts; and they that come down shall cry against thee.","searchKeywords":["for","the","lord","has","sworn","his","arm","will","fill","thee","with","men","locusts","and","they","that","come","down","shall","cry","against"]},{"verseId":"brenton_jeremiah_28_15","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":15,"text":"The Lord made the earth by his power, preparing the world by his wisdom, by his understanding he stretched out the heaven.","searchKeywords":["the","lord","made","earth","his","power","preparing","world","wisdom","understanding","stretched","out","heaven"]},{"verseId":"brenton_jeremiah_28_16","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":16,"text":"At voice he makes a sound of water in the heaven, and brings up clouds from the extremity of the earth; he makes lightnings for rain, and brings light out of his treasures.","searchKeywords":["voice","makes","sound","water","the","heaven","and","brings","clouds","from","extremity","earth","lightnings","for","rain","light","out","his","treasures"]},{"verseId":"brenton_jeremiah_28_17","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":17,"text":"Every man has completely lost understanding; every goldsmith is confounded because of his graven : for they have cast false , there is no breath in them.","searchKeywords":["every","man","has","completely","lost","understanding","goldsmith","confounded","because","his","graven","for","they","have","cast","false","there","breath","them"]},{"verseId":"brenton_jeremiah_28_18","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":18,"text":"They are vain works, objects of scorn; in the time of their visitation they shall perish.","searchKeywords":["they","are","vain","works","objects","scorn","the","time","their","visitation","shall","perish"]},{"verseId":"brenton_jeremiah_28_19","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":19,"text":"Not such is Jacob's portion; for he that formed all things, he is his inheritance; the Lord is his name.","searchKeywords":["not","such","jacob","portion","for","that","formed","all","things","his","inheritance","the","lord","name"]},{"verseId":"brenton_jeremiah_28_20","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":20,"text":"Thou scatterest for me the weapons of war: and I will scatter nations by thee, and will destroy kings by means of thee.","searchKeywords":["thou","scatterest","for","the","weapons","war","and","will","scatter","nations","thee","destroy","kings","means"]},{"verseId":"brenton_jeremiah_28_21","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":21,"text":"And by thee I will scatter the horse and his rider; and by thee I will scatter chariots and them that ride in them.","searchKeywords":["and","thee","will","scatter","the","horse","his","rider","chariots","them","that","ride"]},{"verseId":"brenton_jeremiah_28_22","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":22,"text":"And by thee I will scatter youth and maid; and by thee I will scatter man and woman.","searchKeywords":["and","thee","will","scatter","youth","maid","man","woman"]},{"verseId":"brenton_jeremiah_28_23","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":23,"text":"And by thee I will scatter the shepherd and his flock; and by thee I will scatter the husbandman and his husbandry; and by thee I will scatter leaders and the captains.","searchKeywords":["and","thee","will","scatter","the","shepherd","his","flock","husbandman","husbandry","leaders","captains"]},{"verseId":"brenton_jeremiah_28_24","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":24,"text":"And I will recompense to Babylon and to all the Chaldeans that dwell all their mischiefs that they have done to Sion before your eyes, saith the Lord.","searchKeywords":["and","will","recompense","babylon","all","the","chaldeans","that","dwell","their","mischiefs","they","have","done","sion","before","your","eyes","saith","lord"]},{"verseId":"brenton_jeremiah_28_25","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":25,"text":"Behold, I am against thee, the ruined mountain, that destroys the whole earth; and I will stretch out mine hand upon thee, and will roll thee down upon the rocks, and will make thee as a burnt mountain.","searchKeywords":["behold","against","thee","the","ruined","mountain","that","destroys","whole","earth","and","will","stretch","out","mine","hand","upon","roll","down","rocks","make","burnt"]},{"verseId":"brenton_jeremiah_28_26","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":26,"text":"And they shall not take from thee a stone for a corner, nor a stone for a foundation: for thou shalt be a desolation for ever, saith the Lord.","searchKeywords":["and","they","shall","not","take","from","thee","stone","for","corner","nor","foundation","thou","shalt","desolation","ever","saith","the","lord"]},{"verseId":"brenton_jeremiah_28_27","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":27,"text":"Lift up a standard in the land, sound the trumpet among the nations, consecrate the nations against her, raise up kings against her by me, and for the people of Achanaz; set against her engines of war; bring up against her horses as a multitude of locusts.","searchKeywords":["lift","standard","the","land","sound","trumpet","among","nations","consecrate","against","her","raise","kings","and","for","people","achanaz","set","engines","war","bring","horses","multitude","locusts"]},{"verseId":"brenton_jeremiah_28_28","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":28,"text":"Bring up nations against her, the king of the Medes and of the whole earth, his rulers, and all his captains.","searchKeywords":["bring","nations","against","her","the","king","medes","and","whole","earth","his","rulers","all","captains"]},{"verseId":"brenton_jeremiah_28_29","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":29,"text":"The earth has quaked and been troubled, because the purpose of the Lord has risen up against Babylon, to make the land of Babylon a desolation, and uninhabitable.","searchKeywords":["the","earth","has","quaked","and","been","troubled","because","purpose","lord","risen","against","babylon","make","land","desolation","uninhabitable"]},{"verseId":"brenton_jeremiah_28_30","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":30,"text":"The warrior of Babylon has failed to fight; they shall sit there in the siege; their power is broken; they are become like women; her tabernacles have been set on fire; her bars are broken.","searchKeywords":["the","warrior","babylon","has","failed","fight","they","shall","sit","there","siege","their","power","broken","are","become","like","women","her","tabernacles","have","been","set","fire","bars"]},{"verseId":"brenton_jeremiah_28_31","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":31,"text":"One shall rush, running to meet runner, and one with tidings to meet with tidings, to bring tidings to the king of Babylon, that his city is taken.","searchKeywords":["one","shall","rush","running","meet","runner","and","with","tidings","bring","the","king","babylon","that","his","city","taken"]},{"verseId":"brenton_jeremiah_28_32","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":32,"text":"At the end of his passages they were taken, and his cisterns they have burnt with fire, and his warriors are going forth.","searchKeywords":["the","end","his","passages","they","were","taken","and","cisterns","have","burnt","with","fire","warriors","are","going","forth"]},{"verseId":"brenton_jeremiah_28_33","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":33,"text":"For thus saith the Lord, The houses of the king of Babylon shall be threshed as a floor in the season; yet a little while, and her harvest shall come.","searchKeywords":["for","thus","saith","the","lord","houses","king","babylon","shall","threshed","floor","season","yet","little","while","and","her","harvest","come"]},{"verseId":"brenton_jeremiah_28_34","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":34,"text":"He has devoured me, he has torn me asunder, airy darkness has come upon me; Nabuchodonosor king of Babylon has swallowed me up, as a dragon has he filled his belly with my delicacies.","searchKeywords":["has","devoured","torn","asunder","airy","darkness","come","upon","nabuchodonosor","king","babylon","swallowed","dragon","filled","his","belly","with","delicacies"]},{"verseId":"brenton_jeremiah_28_35","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":35,"text":"My troubles and my distresses have driven me out into Babylon, shall she that dwells in Sion say; and my blood upon the Chaldeans dwelling , shall Jerusalem say.","searchKeywords":["troubles","and","distresses","have","driven","out","into","babylon","shall","she","that","dwells","sion","say","blood","upon","the","chaldeans","dwelling","jerusalem"]},{"verseId":"brenton_jeremiah_28_36","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":36,"text":"Therefore thus saith the Lord, Behold, I will judge thine adversary, and I will execute vengeance for thee; and I will waste her sea, and dry up her fountain.","searchKeywords":["therefore","thus","saith","the","lord","behold","will","judge","thine","adversary","and","execute","vengeance","for","thee","waste","her","sea","dry","fountain"]},{"verseId":"brenton_jeremiah_28_37","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":37,"text":"And Babylon shall be a desolation, and shall not be inhabited.","searchKeywords":["and","babylon","shall","desolation","not","inhabited"]},{"verseId":"brenton_jeremiah_28_38","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":38,"text":"For they rose up together as lions, and as lions' whelps.","searchKeywords":["for","they","rose","together","lions","and","whelps"]},{"verseId":"brenton_jeremiah_28_39","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":39,"text":"In their heat I will give them a draught, and make them drunk, that they may be stupified, and sleep an everlasting sleep, and not awake, saith the Lord.","searchKeywords":["their","heat","will","give","them","draught","and","make","drunk","that","they","may","stupified","sleep","everlasting","not","awake","saith","the","lord"]},{"verseId":"brenton_jeremiah_28_40","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":40,"text":"And bring thou them down as lambs to the slaughter, and rams with kids.","searchKeywords":["and","bring","thou","them","down","lambs","the","slaughter","rams","with","kids"]},{"verseId":"brenton_jeremiah_28_41","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":41,"text":"How has the boast of all the earth been taken and caught in a snare! how has Babylon become a desolation among the nations!","searchKeywords":["how","has","the","boast","all","earth","been","taken","and","caught","snare","babylon","become","desolation","among","nations"]},{"verseId":"brenton_jeremiah_28_42","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":42,"text":"The sea has come up upon Babylon with the sound of its waves, and she is covered.","searchKeywords":["the","sea","has","come","upon","babylon","with","sound","its","waves","and","she","covered"]},{"verseId":"brenton_jeremiah_28_43","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":43,"text":"Her cities are become like a dry and trackless land; not so much as one shall dwell in it, neither shall a son of man lodge in it.","searchKeywords":["her","cities","are","become","like","dry","and","trackless","land","not","much","one","shall","dwell","neither","son","man","lodge"]},{"verseId":"brenton_jeremiah_28_44","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":44,"text":"And I will take vengeance on Babylon, and bring forth out of her mouth what she has swallowed down, and the nations shall no more be gathered to her:","searchKeywords":["and","will","take","vengeance","babylon","bring","forth","out","her","mouth","what","she","has","swallowed","down","the","nations","shall","more","gathered"]},{"verseId":"brenton_jeremiah_28_49","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":49,"text":"and in Babylon the slain men of all the earth shall fall.","searchKeywords":["and","babylon","the","slain","men","all","earth","shall","fall"]},{"verseId":"brenton_jeremiah_28_50","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":50,"text":"Go forth of the land, ye that escape, and stay not; ye that are afar off, remember the Lord, and let Jerusalem come into your mind.","searchKeywords":["forth","the","land","that","escape","and","stay","not","are","afar","off","remember","lord","let","jerusalem","come","into","your","mind"]},{"verseId":"brenton_jeremiah_28_51","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":51,"text":"We are ashamed, because we have heard our reproach; disgrace has covered our face; aliens are come into our sanctuary, into the house of the Lord.","searchKeywords":["are","ashamed","because","have","heard","our","reproach","disgrace","has","covered","face","aliens","come","into","sanctuary","the","house","lord"]},{"verseId":"brenton_jeremiah_28_52","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":52,"text":"Therefore, behold, the days come, saith the Lord, when I will take vengeance upon her graven : and slain men shall fall in all her land.","searchKeywords":["therefore","behold","the","days","come","saith","lord","when","will","take","vengeance","upon","her","graven","and","slain","men","shall","fall","all","land"]},{"verseId":"brenton_jeremiah_28_53","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":53,"text":"For though Babylon should go up as the heaven, and though she should strengthen her walls with her power, from me shall come they that shall destroy her, saith the Lord.","searchKeywords":["for","though","babylon","should","the","heaven","and","she","strengthen","her","walls","with","power","from","shall","come","they","that","destroy","saith","lord"]},{"verseId":"brenton_jeremiah_28_54","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":54,"text":"A sound of a cry in Babylon, and great destruction in the land of the Chaldeans:","searchKeywords":["sound","cry","babylon","and","great","destruction","the","land","chaldeans"]},{"verseId":"brenton_jeremiah_28_55","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":55,"text":"for the Lord has utterly destroyed Babylon, and cut off from her the great voice sounding as many waters: he has consigned her voice to destruction.","searchKeywords":["for","the","lord","has","utterly","destroyed","babylon","and","cut","off","from","her","great","voice","sounding","many","waters","consigned","destruction"]},{"verseId":"brenton_jeremiah_28_56","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":56,"text":"For distress has come upon Babylon, her warriors are taken, their bows are useless: for God recompenses them.","searchKeywords":["for","distress","has","come","upon","babylon","her","warriors","are","taken","their","bows","useless","god","recompenses","them"]},{"verseId":"brenton_jeremiah_28_57","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":57,"text":"The Lord recompenses, and will make her leaders and her wise men and her captains completely drunk, saith the King, the Lord Almighty is his name.","searchKeywords":["the","lord","recompenses","and","will","make","her","leaders","wise","men","captains","completely","drunk","saith","king","almighty","his","name"]},{"verseId":"brenton_jeremiah_28_58","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":58,"text":"Thus saith the Lord, The wall of Babylon was made broad, but it shall be completely broken down, and her high gates shall be burnt with fire; and the peoples shall not labour in vain, nor the nations fail in rule.","searchKeywords":["thus","saith","the","lord","wall","babylon","was","made","broad","but","shall","completely","broken","down","and","her","high","gates","burnt","with","fire","peoples","not","labour","vain","nor","nations","fail","rule"]},{"verseId":"brenton_jeremiah_28_59","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":59,"text":"to say to Saræas son of Nerias, son of Maasæas, when he went from Sedekias king of Juda to Babylon, in the fourth year of his reign. And Saræas was over the bounties.","searchKeywords":["say","sar","son","nerias","maas","when","went","from","sedekias","king","juda","babylon","the","fourth","year","his","reign","and","was","over","bounties"]},{"verseId":"brenton_jeremiah_28_60","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":60,"text":"And Jeremias wrote in a book all the evils which should come upon Babylon, all these words that are written against Babylon.","searchKeywords":["and","jeremias","wrote","book","all","the","evils","which","should","come","upon","babylon","these","words","that","are","written","against"]},{"verseId":"brenton_jeremiah_28_61","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":61,"text":"And Jeremias said to Saræas, When thou art come to Babylon, and shalt see and read all these words;","searchKeywords":["and","jeremias","said","sar","when","thou","art","come","babylon","shalt","see","read","all","these","words"]},{"verseId":"brenton_jeremiah_28_62","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":62,"text":"then thou shalt say, O Lord God, thou hast spoken against this place, to destroy it, and that there should be none to dwell in it, neither man nor beast; for it shall be a desolation for ever.","searchKeywords":["then","thou","shalt","say","lord","god","hast","spoken","against","this","place","destroy","and","that","there","should","none","dwell","neither","man","nor","beast","for","shall","desolation","ever"]},{"verseId":"brenton_jeremiah_28_63","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":63,"text":"And it shall come to pass, when thou shalt cease from reading this book, that thou shalt bind a stone upon it, and cast it into the midst of Euphrates;","searchKeywords":["and","shall","come","pass","when","thou","shalt","cease","from","reading","this","book","that","bind","stone","upon","cast","into","the","midst","euphrates"]},{"verseId":"brenton_jeremiah_28_64","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":28,"verse":64,"text":"and shalt say, Thus shall Babylon sink, and not rise, because of the evils which I bring upon it.","searchKeywords":["and","shalt","say","thus","shall","babylon","sink","not","rise","because","the","evils","which","bring","upon"]}]