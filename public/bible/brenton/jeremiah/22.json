[{"verseId":"brenton_jeremiah_22_1","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":1,"text":"Thus saith the Lord; Go thou, and go down to the house of the king of Juda, and thou shalt speak there this word,","searchKeywords":["thus","saith","the","lord","thou","and","down","house","king","juda","shalt","speak","there","this","word"]},{"verseId":"brenton_jeremiah_22_2","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":2,"text":"and thou shalt say,","searchKeywords":["and","thou","shalt","say"]},{"verseId":"brenton_jeremiah_22_3","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":3,"text":"thus saith the Lord; Execute ye judgment and justice, and rescue the spoiled out of the hand of him that wrongs him: and oppress not the stranger, and orphan, and widow, and sin not, and shed no innocent blood in this place.","searchKeywords":["thus","saith","the","lord","execute","judgment","and","justice","rescue","spoiled","out","hand","him","that","wrongs","oppress","not","stranger","orphan","widow","sin","shed","innocent","blood","this","place"]},{"verseId":"brenton_jeremiah_22_4","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":4,"text":"For if ye will indeed perform this word, then shall there enter in by the gates of this house kings sitting upon the throne of David, and riding on chariots and horses, they, and their servants, and their people.","searchKeywords":["for","will","indeed","perform","this","word","then","shall","there","enter","the","gates","house","kings","sitting","upon","throne","david","and","riding","chariots","horses","they","their","servants","people"]},{"verseId":"brenton_jeremiah_22_5","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":5,"text":"But if ye will not perform these words, by myself have I sworn, saith the Lord, that this house shall be to desolation.","searchKeywords":["but","will","not","perform","these","words","myself","have","sworn","saith","the","lord","that","this","house","shall","desolation"]},{"verseId":"brenton_jeremiah_22_6","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":6,"text":"For thus saith the Lord concerning the house of the king of Juda; Thou art Galaad to me, the head of Libanus: surely I will make thee a desert, cities that shall not be inhabited:","searchKeywords":["for","thus","saith","the","lord","concerning","house","king","juda","thou","art","galaad","head","libanus","surely","will","make","thee","desert","cities","that","shall","not","inhabited"]},{"verseId":"brenton_jeremiah_22_7","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":7,"text":"and I will bring upon thee a destroying man, and his axe: and they shall cut down thy choice cedars, and cast into the fire.","searchKeywords":["and","will","bring","upon","thee","destroying","man","his","axe","they","shall","cut","down","thy","choice","cedars","cast","into","the","fire"]},{"verseId":"brenton_jeremiah_22_8","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":8,"text":"And nations shall pass through this city, and each shall say to his neighbour, Why has the Lord done thus to this great city?","searchKeywords":["and","nations","shall","pass","through","this","city","each","say","his","neighbour","why","has","the","lord","done","thus","great"]},{"verseId":"brenton_jeremiah_22_9","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":9,"text":"And they shall say, Because they forsook the covenant of the Lord their God, and worshipped strange gods, and served them.","searchKeywords":["and","they","shall","say","because","forsook","the","covenant","lord","their","god","worshipped","strange","gods","served","them"]},{"verseId":"brenton_jeremiah_22_10","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":10,"text":"Weep not for the dead, nor lament for him: weep bitterly for him that goes away: for he shall return no more, nor see his native land.","searchKeywords":["weep","not","for","the","dead","nor","lament","him","bitterly","that","goes","away","shall","return","more","see","his","native","land"]},{"verseId":"brenton_jeremiah_22_11","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":11,"text":"For thus saith the Lord concerning Sellem the son of Josias, who reigns in the place of Josias his father, who has gone forth out of this place; He shall not return thither any more:","searchKeywords":["for","thus","saith","the","lord","concerning","sellem","son","josias","who","reigns","place","his","father","has","gone","forth","out","this","shall","not","return","thither","any","more"]},{"verseId":"brenton_jeremiah_22_12","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":12,"text":"but in that place whither I have carried him captive, there shall he die, and shall see this land no more.","searchKeywords":["but","that","place","whither","have","carried","him","captive","there","shall","die","and","see","this","land","more"]},{"verseId":"brenton_jeremiah_22_13","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":13,"text":"He that builds his house not with justice, and his upper chambers not with judgment, who works by means of his neighbour for nothing, and will by no means give him his reward.","searchKeywords":["that","builds","his","house","not","with","justice","and","upper","chambers","judgment","who","works","means","neighbour","for","nothing","will","give","him","reward"]},{"verseId":"brenton_jeremiah_22_14","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":14,"text":"Thou hast built for thyself a well-proportioned house, airy chambers, fitted with windows, and wainscoted with cedar, and painted with vermilion.","searchKeywords":["thou","hast","built","for","thyself","well","proportioned","house","airy","chambers","fitted","with","windows","and","wainscoted","cedar","painted","vermilion"]},{"verseId":"brenton_jeremiah_22_15","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":15,"text":"Shalt thou reign, because thou art provoked with thy father Achaz? they shall not eat, and they shall not drink: it is better for thee to execute judgment and justice.","searchKeywords":["shalt","thou","reign","because","art","provoked","with","thy","father","achaz","they","shall","not","eat","and","drink","better","for","thee","execute","judgment","justice"]},{"verseId":"brenton_jeremiah_22_16","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":16,"text":"They understood not, they judged not the cause of the afflicted, nor the cause of the poor: is not this thy not knowing me? saith the Lord.","searchKeywords":["they","understood","not","judged","the","cause","afflicted","nor","poor","this","thy","knowing","saith","lord"]},{"verseId":"brenton_jeremiah_22_17","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":17,"text":"Behold, thine eyes are not good, nor thine heart, but after thy covetousness, and after the innocent blood to shed it, and after acts of injustice and slaughter, to commit them.","searchKeywords":["behold","thine","eyes","are","not","good","nor","heart","but","after","thy","covetousness","and","the","innocent","blood","shed","acts","injustice","slaughter","commit","them"]},{"verseId":"brenton_jeremiah_22_18","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":18,"text":"Therefore thus saith the Lord concerning Joakim son of Josias, king of Juda, even concerning this man; they shall not bewail him, , Ah brother! neither shall they at all weep for him, , Alas Lord.","searchKeywords":["therefore","thus","saith","the","lord","concerning","joakim","son","josias","king","juda","even","this","man","they","shall","not","bewail","him","brother","neither","all","weep","for","alas"]},{"verseId":"brenton_jeremiah_22_19","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":19,"text":"He shall be buried with the burial of an ass; he shall be dragged roughly along and cast outside the gate of Jerusalem.","searchKeywords":["shall","buried","with","the","burial","ass","dragged","roughly","along","and","cast","outside","gate","jerusalem"]},{"verseId":"brenton_jeremiah_22_20","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":20,"text":"Go up to Libanus, and cry; and utter thy voice to Basan, and cry aloud to the extremity of the sea: for all thy lovers are destroyed.","searchKeywords":["libanus","and","cry","utter","thy","voice","basan","aloud","the","extremity","sea","for","all","lovers","are","destroyed"]},{"verseId":"brenton_jeremiah_22_21","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":21,"text":"I spoke to thee on thy trespass, but thou saidst, I will not hearken. This thy way from thy youth, thou hast not hearkened to my voice.","searchKeywords":["spoke","thee","thy","trespass","but","thou","saidst","will","not","hearken","this","way","from","youth","hast","hearkened","voice"]},{"verseId":"brenton_jeremiah_22_22","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":22,"text":"The wind shall tend all thy shepherds, and thy lovers shall go into captivity; for then shalt thou be ashamed and disgraced because of all thy lovers.","searchKeywords":["the","wind","shall","tend","all","thy","shepherds","and","lovers","into","captivity","for","then","shalt","thou","ashamed","disgraced","because"]},{"verseId":"brenton_jeremiah_22_23","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":23,"text":"O thou that dwellest in Libanus, making thy nest in the cedars, thou shalt groan heavily, when pangs as of a travailing woman are come upon thee.","searchKeywords":["thou","that","dwellest","libanus","making","thy","nest","the","cedars","shalt","groan","heavily","when","pangs","travailing","woman","are","come","upon","thee"]},{"verseId":"brenton_jeremiah_22_24","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":24,"text":"I live, saith the Lord, though Jechonias son of Joakim king of Juda were indeed the seal upon my right hand, thence would I pluck thee;","searchKeywords":["live","saith","the","lord","though","jechonias","son","joakim","king","juda","were","indeed","seal","upon","right","hand","thence","would","pluck","thee"]},{"verseId":"brenton_jeremiah_22_25","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":25,"text":"and I will deliver thee into the hands of them that seek thy life, before whom thou art afraid, into the hands of the Chaldeans.","searchKeywords":["and","will","deliver","thee","into","the","hands","them","that","seek","thy","life","before","whom","thou","art","afraid","chaldeans"]},{"verseId":"brenton_jeremiah_22_26","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":26,"text":"And I will cast forth thee, and thy mother that bore thee, into a land where thou wast not born; and there ye shall die.","searchKeywords":["and","will","cast","forth","thee","thy","mother","that","bore","into","land","where","thou","wast","not","born","there","shall","die"]},{"verseId":"brenton_jeremiah_22_27","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":27,"text":"But they shall by no means return to the land which they long for in their souls.","searchKeywords":["but","they","shall","means","return","the","land","which","long","for","their","souls"]},{"verseId":"brenton_jeremiah_22_28","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":28,"text":"Jechonias is dishonoured as a good-for-nothing vessel; for he is thrown out and cast forth into a land which he knew not.","searchKeywords":["jechonias","dishonoured","good","for","nothing","vessel","thrown","out","and","cast","forth","into","land","which","knew","not"]},{"verseId":"brenton_jeremiah_22_29","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":29,"text":"Land, land, hear the word of the Lord.","searchKeywords":["land","hear","the","word","lord"]},{"verseId":"brenton_jeremiah_22_30","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":22,"verse":30,"text":"Write ye this man an outcast: for there shall none of his seed at all grow up to sit on the throne of David, a prince yet in Juda.","searchKeywords":["write","this","man","outcast","for","there","shall","none","his","seed","all","grow","sit","the","throne","david","prince","yet","juda"]}]