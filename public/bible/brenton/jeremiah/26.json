[{"verseId":"brenton_jeremiah_26_2","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":2,"text":"who was by the river Euphrates in Charmis, whom Nabuchodonosor king of Babylon smote in the fourth year of Joakim king of Juda.","searchKeywords":["who","was","the","river","euphrates","charmis","whom","nabuchodonosor","king","babylon","smote","fourth","year","joakim","juda"]},{"verseId":"brenton_jeremiah_26_3","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":3,"text":"Take up arms and spears, and draw nigh to battle;","searchKeywords":["take","arms","and","spears","draw","nigh","battle"]},{"verseId":"brenton_jeremiah_26_4","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":4,"text":"and harness the horses: mount, ye horsemen, and stand ready in your helmets; advance the spears, and put on your breast-plates.","searchKeywords":["and","harness","the","horses","mount","horsemen","stand","ready","your","helmets","advance","spears","put","breast","plates"]},{"verseId":"brenton_jeremiah_26_5","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":5,"text":"Why do they fear, and turn back? even because their mighty men shall be slain: they have utterly fled, and being hemmed in they have not rallied, saith the Lord.","searchKeywords":["why","they","fear","and","turn","back","even","because","their","mighty","men","shall","slain","have","utterly","fled","being","hemmed","not","rallied","saith","the","lord"]},{"verseId":"brenton_jeremiah_26_6","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":6,"text":"Let not the swift flee, and let not the mighty man escape to the north: the at Euphrates are become feeble, and they have fallen.","searchKeywords":["let","not","the","swift","flee","and","mighty","man","escape","north","euphrates","are","become","feeble","they","have","fallen"]},{"verseId":"brenton_jeremiah_26_7","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":7,"text":"Who is this shall come up as a river, and as rivers roll waves?","searchKeywords":["who","this","shall","come","river","and","rivers","roll","waves"]},{"verseId":"brenton_jeremiah_26_8","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":8,"text":"The waters of Egypt shall come up like a river: and he said, I will go up, and will cover the earth, and will destroy the dwellers in it.","searchKeywords":["the","waters","egypt","shall","come","like","river","and","said","will","cover","earth","destroy","dwellers"]},{"verseId":"brenton_jeremiah_26_9","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":9,"text":"Mount ye the horses, prepare the chariots; go forth, ye warriors of the Ethiopians, and Libyans armed with shields; and mount, ye Lydians, bend the bow.","searchKeywords":["mount","the","horses","prepare","chariots","forth","warriors","ethiopians","and","libyans","armed","with","shields","lydians","bend","bow"]},{"verseId":"brenton_jeremiah_26_10","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":10,"text":"And that day to the Lord our God a day of vengeance, to take vengeance on his enemies: and the sword of the Lord shall devour, and be glutted, and be drunken with their blood: for the Lord a sacrifice from the land of the north at the river Euphrates.","searchKeywords":["and","that","day","the","lord","our","god","vengeance","take","his","enemies","sword","shall","devour","glutted","drunken","with","their","blood","for","sacrifice","from","land","north","river","euphrates"]},{"verseId":"brenton_jeremiah_26_11","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":11,"text":"Go up to Galaad, and take balm for the virgin daughter of Egypt: in vain hast thou multiplied thy medicines; there is no help in thee.","searchKeywords":["galaad","and","take","balm","for","the","virgin","daughter","egypt","vain","hast","thou","multiplied","thy","medicines","there","help","thee"]},{"verseId":"brenton_jeremiah_26_12","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":12,"text":"The nations have heard thy voice, and the land has been filled with thy cry: for the warriors have fainted fighting one against another, both are fallen together.","searchKeywords":["the","nations","have","heard","thy","voice","and","land","has","been","filled","with","cry","for","warriors","fainted","fighting","one","against","another","both","are","fallen","together"]},{"verseId":"brenton_jeremiah_26_13","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":13,"text":"by Jeremias, concerning the coming of the king of Babylon to smite the land of Egypt.","searchKeywords":["jeremias","concerning","the","coming","king","babylon","smite","land","egypt"]},{"verseId":"brenton_jeremiah_26_14","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":14,"text":"Proclaim at Magdol, and declare at Memphis: say ye, Stand up, and prepare; for the sword has devoured thy yew-tree.","searchKeywords":["proclaim","magdol","and","declare","memphis","say","stand","prepare","for","the","sword","has","devoured","thy","yew","tree"]},{"verseId":"brenton_jeremiah_26_15","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":15,"text":"Wherefore has Apis fled from thee? thy choice calf has not remained; for the Lord has utterly weakened him.","searchKeywords":["wherefore","has","apis","fled","from","thee","thy","choice","calf","not","remained","for","the","lord","utterly","weakened","him"]},{"verseId":"brenton_jeremiah_26_16","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":16,"text":"And thy multitude has fainted and fallen; and each one said to his neighbour, Let us arise, and return into our country to our people, from the Grecian sword.","searchKeywords":["and","thy","multitude","has","fainted","fallen","each","one","said","his","neighbour","let","arise","return","into","our","country","people","from","the","grecian","sword"]},{"verseId":"brenton_jeremiah_26_17","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":17,"text":"Call ye the name of Pharao Nechao king of Egypt, Saon esbeie moed.","searchKeywords":["call","the","name","pharao","nechao","king","egypt","saon","esbeie","moed"]},{"verseId":"brenton_jeremiah_26_18","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":18,"text":"I live, saith the Lord God, he shall come as Itabyrion among the mountains, and as Carmel that is on the sea.","searchKeywords":["live","saith","the","lord","god","shall","come","itabyrion","among","mountains","and","carmel","that","sea"]},{"verseId":"brenton_jeremiah_26_19","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":19,"text":"O daughter of Egypt dwelling , prepare thee stuff for removing: for Memphis shall be utterly desolate, and shall be called Woe, because there are no inhabitants in it.","searchKeywords":["daughter","egypt","dwelling","prepare","thee","stuff","for","removing","memphis","shall","utterly","desolate","and","called","woe","because","there","are","inhabitants"]},{"verseId":"brenton_jeremiah_26_20","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":20,"text":"Egypt is a fair heifer, destruction from the north is come upon her.","searchKeywords":["egypt","fair","heifer","destruction","from","the","north","come","upon","her"]},{"verseId":"brenton_jeremiah_26_21","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":21,"text":"Also her hired in the midst of her are as fatted calves fed in her; for they also have turned, and fled with one accord: they stood not, for the day of destruction was come upon them, and the time of their retribution.","searchKeywords":["also","her","hired","the","midst","are","fatted","calves","fed","for","they","have","turned","and","fled","with","one","accord","stood","not","day","destruction","was","come","upon","them","time","their","retribution"]},{"verseId":"brenton_jeremiah_26_22","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":22,"text":"Their voice is as of a hissing serpent, for they go upon the sand; they shall come upon Egypt with axes, as men that cut wood.","searchKeywords":["their","voice","hissing","serpent","for","they","upon","the","sand","shall","come","egypt","with","axes","men","that","cut","wood"]},{"verseId":"brenton_jeremiah_26_23","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":23,"text":"They shall cut down her forest, saith the Lord, for cannot at all be conjectured, for it exceeds the locust in multitude, and they are innumerable.","searchKeywords":["they","shall","cut","down","her","forest","saith","the","lord","for","cannot","all","conjectured","exceeds","locust","multitude","and","are","innumerable"]},{"verseId":"brenton_jeremiah_26_24","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":24,"text":"The daughter of Egypt is confounded; she is delivered into the hands of a people from the north.","searchKeywords":["the","daughter","egypt","confounded","she","delivered","into","hands","people","from","north"]},{"verseId":"brenton_jeremiah_26_25","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":25,"text":"Behold, I avenge Ammon her son upon Pharao, and upon them that trust in him.","searchKeywords":["behold","avenge","ammon","her","son","upon","pharao","and","them","that","trust","him"]},{"verseId":"brenton_jeremiah_26_27","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":27,"text":"But fear not thou, my servant Jacob, neither be thou alarmed, Israel: for, behold, I will save thee from afar, and thy seed from their captivity; and Jacob shall return, and be at ease, and sleep, and there shall be no one to trouble him.","searchKeywords":["but","fear","not","thou","servant","jacob","neither","alarmed","israel","for","behold","will","save","thee","from","afar","and","thy","seed","their","captivity","shall","return","ease","sleep","there","one","trouble","him"]},{"verseId":"brenton_jeremiah_26_28","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":26,"verse":28,"text":"Fear not thou, my servant Jacob, saith the Lord; for I am with thee: she without fear and in luxury, has been delivered up: for I will make a full end of every nation among whom I have thrust thee forth; but I will not cause thee to fail: yet will I chastise thee in the way of judgment, and will not hold thee entirely guiltless.","searchKeywords":["fear","not","thou","servant","jacob","saith","the","lord","for","with","thee","she","without","and","luxury","has","been","delivered","will","make","full","end","every","nation","among","whom","have","thrust","forth","but","cause","fail","yet","chastise","way","judgment","hold","entirely","guiltless"]}]