[{"verseId":"brenton_jeremiah_48_1","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":48,"verse":1,"text":"Now it came to pass in the seventh month that Ismael the son of Nathanias the son of Eleasa of the seed royal, came, and ten men with him, to Godolias to Massepha: and they ate bread there together.","searchKeywords":["now","came","pass","the","seventh","month","that","ismael","son","nathanias","eleasa","seed","royal","and","ten","men","with","him","godolias","massepha","they","ate","bread","there","together"]},{"verseId":"brenton_jeremiah_48_2","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":48,"verse":2,"text":"And Ismael rose up, and the ten men that were with him, and smote Godolias, whom the king of Babylon had appointed over the land,","searchKeywords":["and","ismael","rose","the","ten","men","that","were","with","him","smote","godolias","whom","king","babylon","had","appointed","over","land"]},{"verseId":"brenton_jeremiah_48_3","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":48,"verse":3,"text":"and all the Jews that were with him in Massepha, and all the Chaldeans that were found there.","searchKeywords":["and","all","the","jews","that","were","with","him","massepha","chaldeans","found","there"]},{"verseId":"brenton_jeremiah_48_4","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":48,"verse":4,"text":"And it came to pass on the second day after he had smitten Godolias, and no man knew ,","searchKeywords":["and","came","pass","the","second","day","after","had","smitten","godolias","man","knew"]},{"verseId":"brenton_jeremiah_48_5","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":48,"verse":5,"text":"that there came men from Sychem, and from Salem, and from Samaria, eighty men, having their beards shaven, and their clothes rent, and beating their breasts, and manna and frankincense in their hands, to bring into the house of the Lord.","searchKeywords":["that","there","came","men","from","sychem","and","salem","samaria","eighty","having","their","beards","shaven","clothes","rent","beating","breasts","manna","frankincense","hands","bring","into","the","house","lord"]},{"verseId":"brenton_jeremiah_48_6","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":48,"verse":6,"text":"And Ismael went out to meet them; they went on and wept: and he said to them, Come in to Godolias.","searchKeywords":["and","ismael","went","out","meet","them","they","wept","said","come","godolias"]},{"verseId":"brenton_jeremiah_48_7","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":48,"verse":7,"text":"And it came to pass, when they had entered into the midst of the city, he slew them into a pit.","searchKeywords":["and","came","pass","when","they","had","entered","into","the","midst","city","slew","them","pit"]},{"verseId":"brenton_jeremiah_48_8","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":48,"verse":8,"text":"But ten men were found there, and they said to Ismael, Slay us not: for we have treasures in the field, wheat and barley, honey and oil. So he passed by, and slew them not in the midst of their brethren.","searchKeywords":["but","ten","men","were","found","there","and","they","said","ismael","slay","not","for","have","treasures","the","field","wheat","barley","honey","oil","passed","slew","them","midst","their","brethren"]},{"verseId":"brenton_jeremiah_48_9","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":48,"verse":9,"text":"Now the pit into which Ismael cast all whom he smote, is the great pit, which king Asa had made for fear of Baasa king of Israel: this Ismael filled with slain men.","searchKeywords":["now","the","pit","into","which","ismael","cast","all","whom","smote","great","king","asa","had","made","for","fear","baasa","israel","this","filled","with","slain","men"]},{"verseId":"brenton_jeremiah_48_10","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":48,"verse":10,"text":"And Ismael brought back all the people that were left in Massepha, and the king's daughter, whom the captain of the guard had committed in charge to Godolias the son of Achicam: and he went away beyond the children of Ammon.","searchKeywords":["and","ismael","brought","back","all","the","people","that","were","left","massepha","king","daughter","whom","captain","guard","had","committed","charge","godolias","son","achicam","went","away","beyond","children","ammon"]},{"verseId":"brenton_jeremiah_48_11","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":48,"verse":11,"text":"And Joanan the son of Careë, and all the leaders of the host that were with him, heard of all the evil deeds which Ismael had done.","searchKeywords":["and","joanan","the","son","care","all","leaders","host","that","were","with","him","heard","evil","deeds","which","ismael","had","done"]},{"verseId":"brenton_jeremiah_48_12","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":48,"verse":12,"text":"And they brought all their army, and went to fight against him, and found him near much water in Gabaon.","searchKeywords":["and","they","brought","all","their","army","went","fight","against","him","found","near","much","water","gabaon"]},{"verseId":"brenton_jeremiah_48_13","translationId":"brenton","testament":"OT","bookIndex":46,"bookName":"Jeremiah","bookAbbrev":"jeremiah","chapter":48,"verse":13,"t