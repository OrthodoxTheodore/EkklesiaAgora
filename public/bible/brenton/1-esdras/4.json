[{"verseId":"brenton_1-esdras_4_1","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":1,"text":"Then the second, that had spoken of the strength of the king, began to say,","searchKeywords":["then","the","second","that","had","spoken","strength","king","began","say"]},{"verseId":"brenton_1-esdras_4_2","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":2,"text":"O ye men, do not men excel in strength, that bear rule over sea and land, and all things in them?","searchKeywords":["men","not","excel","strength","that","bear","rule","over","sea","and","land","all","things","them"]},{"verseId":"brenton_1-esdras_4_3","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":3,"text":"But yet the king is more mighty: for he is lord of all these things, and hath dominion over them; and whatsoever he commandeth them they do.","searchKeywords":["but","yet","the","king","more","mighty","for","lord","all","these","things","and","hath","dominion","over","them","whatsoever","commandeth","they"]},{"verseId":"brenton_1-esdras_4_4","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":4,"text":"If he bid them make war the one against the other, they do it: if he send them out against the enemies, they go, and break down mountains, walls, and towers.","searchKeywords":["bid","them","make","war","the","one","against","other","they","send","out","enemies","and","break","down","mountains","walls","towers"]},{"verseId":"brenton_1-esdras_4_5","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":5,"text":"They slay and are slain, and transgress not the king's commandment: if they get the victory, they bring all to the king, as well the spoil, as all things else.","searchKeywords":["they","slay","and","are","slain","transgress","not","the","king","commandment","get","victory","bring","all","well","spoil","things","else"]},{"verseId":"brenton_1-esdras_4_6","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":6,"text":"Likewise for those that are no soldiers, and have not to do with wars, but use husbandry, when they have reaped again that which they had sown, they bring it to the king, and compel one another to pay tribute unto the king.","searchKeywords":["likewise","for","those","that","are","soldiers","and","have","not","with","wars","but","use","husbandry","when","they","reaped","again","which","had","sown","bring","the","king","compel","one","another","pay","tribute","unto"]},{"verseId":"brenton_1-esdras_4_7","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":7,"text":"And yet he is but one man: if he command to kill, they kill; if he command to spare, they spare;","searchKeywords":["and","yet","but","one","man","command","kill","they","spare"]},{"verseId":"brenton_1-esdras_4_8","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":8,"text":"if he command to smite, they smite; if he command to make desolate, they make desolate; if he command to build, they build;","searchKeywords":["command","smite","they","make","desolate","build"]},{"verseId":"brenton_1-esdras_4_9","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":9,"text":"if he command to cut down, they cut down; if he command to plant, they plant.","searchKeywords":["command","cut","down","they","plant"]},{"verseId":"brenton_1-esdras_4_10","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":10,"text":"So all his people and his armies obey him: furthermore he lieth down, he eateth and drinketh, and taketh his rest:","searchKeywords":["all","his","people","and","armies","obey","him","furthermore","lieth","down","eateth","drinketh","taketh","rest"]},{"verseId":"brenton_1-esdras_4_11","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":11,"text":"and these keep watch round about him, neither may any one depart, and do his own business, neither disobey they him in any thing.","searchKeywords":["and","these","keep","watch","round","about","him","neither","may","any","one","depart","his","own","business","disobey","they","thing"]},{"verseId":"brenton_1-esdras_4_12","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":12,"text":"O ye men, how should not the king be mightiest, when in such sort he is obeyed? And he held his tongue.","searchKeywords":["men","how","should","not","the","king","mightiest","when","such","sort","obeyed","and","held","his","tongue"]},{"verseId":"brenton_1-esdras_4_13","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":13,"text":"Then the third, who had spoken of women, and of the truth, (this was Zorobabel) began to speak.","searchKeywords":["then","the","third","who","had","spoken","women","and","truth","this","was","zorobabel","began","speak"]},{"verseId":"brenton_1-esdras_4_14","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":14,"text":"O ye men, it is not the great king, nor the multitude of men, neither is it wine, that excelleth: who is it then that ruleth them, or hath the lordship over them? are they not women?","searchKeywords":["men","not","the","great","king","nor","multitude","neither","wine","that","excelleth","who","then","ruleth","them","hath","lordship","over","are","they","women"]},{"verseId":"brenton_1-esdras_4_15","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":15,"text":"Women have borne the king and all the people that bear rule by sea and land.","searchKeywords":["women","have","borne","the","king","and","all","people","that","bear","rule","sea","land"]},{"verseId":"brenton_1-esdras_4_16","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":16,"text":"Even of them came they: and they nourished them up that planted the vineyards, from whence the wine cometh.","searchKeywords":["even","them","came","they","and","nourished","that","planted","the","vineyards","from","whence","wine","cometh"]},{"verseId":"brenton_1-esdras_4_17","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":17,"text":"These also make garments for men; these bring glory unto men; and without women cannot men be.","searchKeywords":["these","also","make","garments","for","men","bring","glory","unto","and","without","women","cannot"]},{"verseId":"brenton_1-esdras_4_18","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":18,"text":"Yea, and if men have gathered together gold and silver, or any other goodly thing, do they not love a woman which is comely in favour and beauty?","searchKeywords":["yea","and","men","have","gathered","together","gold","silver","any","other","goodly","thing","they","not","love","woman","which","comely","favour","beauty"]},{"verseId":"brenton_1-esdras_4_19","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":19,"text":"And letting all those things go, do they not gape, and even with open mouth fix their eyes fast on her; and have not all men more desire unto her than unto silver or gold, or any goodly thing whatsoever?","searchKeywords":["and","letting","all","those","things","they","not","gape","even","with","open","mouth","fix","their","eyes","fast","her","have","men","more","desire","unto","than","silver","gold","any","goodly","thing","whatsoever"]},{"verseId":"brenton_1-esdras_4_20","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":20,"text":"A man leaveth his own father that brought him up, and his own country, and cleaveth unto his wife.","searchKeywords":["man","leaveth","his","own","father","that","brought","him","and","country","cleaveth","unto","wife"]},{"verseId":"brenton_1-esdras_4_21","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":21,"text":"He sticketh not to spend his life with his wife, and remembereth neither father, nor mother, nor country.","searchKeywords":["sticketh","not","spend","his","life","with","wife","and","remembereth","neither","father","nor","mother","country"]},{"verseId":"brenton_1-esdras_4_22","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":22,"text":"By this also ye must know that women have dominion over you: do ye not labour and toil, and give and bring all to the woman?","searchKeywords":["this","also","must","know","that","women","have","dominion","over","you","not","labour","and","toil","give","bring","all","the","woman"]},{"verseId":"brenton_1-esdras_4_23","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":23,"text":"Yea, a man taketh his sword, and goeth his way to rob and to steal, to sail upon the sea and upon rivers;","searchKeywords":["yea","man","taketh","his","sword","and","goeth","way","rob","steal","sail","upon","the","sea","rivers"]},{"verseId":"brenton_1-esdras_4_24","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":24,"text":"and looketh upon a lion, and goeth in the darkness; and when he hath stolen, spoiled, and robbed, he bringeth it to his love.","searchKeywords":["and","looketh","upon","lion","goeth","the","darkness","when","hath","stolen","spoiled","robbed","bringeth","his","love"]},{"verseId":"brenton_1-esdras_4_25","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":25,"text":"Wherefore a man loveth his wife better than father or mother.","searchKeywords":["wherefore","man","loveth","his","wife","better","than","father","mother"]},{"verseId":"brenton_1-esdras_4_26","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":26,"text":"Yea, many there be that have run out of their wits for women, and become servants for their sakes.","searchKeywords":["yea","many","there","that","have","run","out","their","wits","for","women","and","become","servants","sakes"]},{"verseId":"brenton_1-esdras_4_27","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":27,"text":"Many also have perished, have erred, and sinned, for women.","searchKeywords":["many","also","have","perished","erred","and","sinned","for","women"]},{"verseId":"brenton_1-esdras_4_28","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":28,"text":"And now do ye not believe me? is not the king great in his power? do not all regions fear to touch him?","searchKeywords":["and","now","not","believe","the","king","great","his","power","all","regions","fear","touch","him"]},{"verseId":"brenton_1-esdras_4_29","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":29,"text":"Yet did I see him and Apame the king's concubine, the daughter of the admirable Bartacus, sitting at the right hand of the king,","searchKeywords":["yet","did","see","him","and","apame","the","king","concubine","daughter","admirable","bartacus","sitting","right","hand"]},{"verseId":"brenton_1-esdras_4_30","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":30,"text":"and taking the crown from the king's head, and setting it upon her own head; she also struck the king with her left hand.","searchKeywords":["and","taking","the","crown","from","king","head","setting","upon","her","own","she","also","struck","with","left","hand"]},{"verseId":"brenton_1-esdras_4_31","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":31,"text":"And yet for all this the king gaped and gazed upon her with open mouth: if she laughed upon him, he laughed also: but if she took any displeasure at him, the king was fain to flatter, that she might be reconciled to him again.","searchKeywords":["and","yet","for","all","this","the","king","gaped","gazed","upon","her","with","open","mouth","she","laughed","him","also","but","took","any","displeasure","was","fain","flatter","that","might","reconciled","again"]},{"verseId":"brenton_1-esdras_4_32","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":32,"text":"O ye men, how can it be but women should be strong, seeing they do thus?","searchKeywords":["men","how","can","but","women","should","strong","seeing","they","thus"]},{"verseId":"brenton_1-esdras_4_33","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":33,"text":"Then the king and the princes looked one upon another: so he began to speak of the truth.","searchKeywords":["then","the","king","and","princes","looked","one","upon","another","began","speak","truth"]},{"verseId":"brenton_1-esdras_4_34","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":34,"text":"O ye men, are not women strong? great is the earth, high is the heaven, swift is the sun in his course, for he compasseth the heavens round about, and fetcheth his course again to his own place in one day.","searchKeywords":["men","are","not","women","strong","great","the","earth","high","heaven","swift","sun","his","course","for","compasseth","heavens","round","about","and","fetcheth","again","own","place","one","day"]},{"verseId":"brenton_1-esdras_4_35","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":35,"text":"Is he not great that maketh these things? therefore great is the truth, and stronger than all things.","searchKeywords":["not","great","that","maketh","these","things","therefore","the","truth","and","stronger","than","all"]},{"verseId":"brenton_1-esdras_4_36","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":36,"text":"All the earth calleth upon the truth, and the heaven blesseth it: all works shake and tremble at it, and with it is no unrighteous thing.","searchKeywords":["all","the","earth","calleth","upon","truth","and","heaven","blesseth","works","shake","tremble","with","unrighteous","thing"]},{"verseId":"brenton_1-esdras_4_37","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":37,"text":"Wine is wicked, the king is wicked, women are wicked, all the children of men are wicked; and such are all their wicked works, and there is no truth in them; in their unrighteousness also they shall perish.","searchKeywords":["wine","wicked","the","king","women","are","all","children","men","and","such","their","works","there","truth","them","unrighteousness","also","they","shall","perish"]},{"verseId":"brenton_1-esdras_4_38","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":38,"text":"As for the truth, it endureth, and is always strong; it liveth and conquereth for evermore.","searchKeywords":["for","the","truth","endureth","and","always","strong","liveth","conquereth","evermore"]},{"verseId":"brenton_1-esdras_4_39","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":39,"text":"With her there is no accepting of persons or rewards: but she doeth the things that are just, and refraineth from all unjust and wicked things; and all men do well like of her works.","searchKeywords":["with","her","there","accepting","persons","rewards","but","she","doeth","the","things","that","are","just","and","refraineth","from","all","unjust","wicked","men","well","like","works"]},{"verseId":"brenton_1-esdras_4_40","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":40,"text":"Neither in her judgment is any unrighteousness; and she is the strength, kingdom, power, and majesty of all ages. Blessed be the God of truth.","searchKeywords":["neither","her","judgment","any","unrighteousness","and","she","the","strength","kingdom","power","majesty","all","ages","blessed","god","truth"]},{"verseId":"brenton_1-esdras_4_41","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":41,"text":"And with that he held his peace. And all the people then shouted, and said, Great is Truth, and mighty above all things.","searchKeywords":["and","with","that","held","his","peace","all","the","people","then","shouted","said","great","truth","mighty","above","things"]},{"verseId":"brenton_1-esdras_4_42","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":42,"text":"Then said the king unto him, Ask what thou wilt more than is appointed in the writings, and we will give it thee, because thou art found wisest; and thou shalt sit next me, and shalt be called my cousin.","searchKeywords":["then","said","the","king","unto","him","ask","what","thou","wilt","more","than","appointed","writings","and","will","give","thee","because","art","found","wisest","shalt","sit","next","called","cousin"]},{"verseId":"brenton_1-esdras_4_43","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":43,"text":"Then said he unto the king, Remember thy vow, which thou hast vowed to build Jerusalem, in the day when thou camest to thy kingdom,","searchKeywords":["then","said","unto","the","king","remember","thy","vow","which","thou","hast","vowed","build","jerusalem","day","when","camest","kingdom"]},{"verseId":"brenton_1-esdras_4_44","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":44,"text":"and to send away all the vessels that were taken away out of Jerusalem, which Cyrus set apart, when he vowed to destroy Babylon, and to send them again thither.","searchKeywords":["and","send","away","all","the","vessels","that","were","taken","out","jerusalem","which","cyrus","set","apart","when","vowed","destroy","babylon","them","again","thither"]},{"verseId":"brenton_1-esdras_4_45","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":45,"text":"Thou also hast vowed to build up the temple, which the Edomites burned when Judea was made desolate by the Chaldees.","searchKeywords":["thou","also","hast","vowed","build","the","temple","which","edomites","burned","when","judea","was","made","desolate","chaldees"]},{"verseId":"brenton_1-esdras_4_46","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":46,"text":"And now, O lord the king, this is that which I require, and which I desire of thee, and this is the princely liberality proceeding from thyself: I desire therefore that thou make good the vow, the performance whereof with thine own mouth thou hast vowed to the King of heaven.","searchKeywords":["and","now","lord","the","king","this","that","which","require","desire","thee","princely","liberality","proceeding","from","thyself","therefore","thou","make","good","vow","performance","whereof","with","thine","own","mouth","hast","vowed","heaven"]},{"verseId":"brenton_1-esdras_4_47","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":47,"text":"Then Darius the king stood up, and kissed him, and wrote letters for him unto all the treasurers and lieutenants and captains and governors, that they should safely convey on their way both him, and all those that go up with him to build Jerusalem.","searchKeywords":["then","darius","the","king","stood","and","kissed","him","wrote","letters","for","unto","all","treasurers","lieutenants","captains","governors","that","they","should","safely","convey","their","way","both","those","with","build","jerusalem"]},{"verseId":"brenton_1-esdras_4_48","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":48,"text":"He wrote letters also unto the lieutenants that were in Celosyria and Phenice, and unto them in Libanus, that they should bring cedar wood from Libanus unto Jerusalem, and that they should build the city with him.","searchKeywords":["wrote","letters","also","unto","the","lieutenants","that","were","celosyria","and","phenice","them","libanus","they","should","bring","cedar","wood","from","jerusalem","build","city","with","him"]},{"verseId":"brenton_1-esdras_4_49","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":49,"text":"Moreover he wrote for all the Jews that went out of his realm up into Jewry, concerning their freedom, that no officer, no ruler, no lieutenant, nor treasurer, should forcibly enter into their doors;","searchKeywords":["moreover","wrote","for","all","the","jews","that","went","out","his","realm","into","jewry","concerning","their","freedom","officer","ruler","lieutenant","nor","treasurer","should","forcibly","enter","doors"]},{"verseId":"brenton_1-esdras_4_50","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":50,"text":"and that all the country which they hold should be free without tribute; and that the Edomites should give over the villages of the Jews which then they held:","searchKeywords":["and","that","all","the","country","which","they","hold","should","free","without","tribute","edomites","give","over","villages","jews","then","held"]},{"verseId":"brenton_1-esdras_4_51","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":51,"text":"yea, that there should be yearly given twenty talents to the building of the temple, until the time that it were built;","searchKeywords":["yea","that","there","should","yearly","given","twenty","talents","the","building","temple","until","time","were","built"]},{"verseId":"brenton_1-esdras_4_52","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":52,"text":"and other ten talents yearly, to maintain the burnt offerings upon the altar every day, as they had a commandment to offer seventeen:","searchKeywords":["and","other","ten","talents","yearly","maintain","the","burnt","offerings","upon","altar","every","day","they","had","commandment","offer","seventeen"]},{"verseId":"brenton_1-esdras_4_53","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":53,"text":"and that all they that went from Babylon to build the city should have free liberty, as well they as their posterity, and all the priests that went away.","searchKeywords":["and","that","all","they","went","from","babylon","build","the","city","should","have","free","liberty","well","their","posterity","priests","away"]},{"verseId":"brenton_1-esdras_4_54","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":54,"text":"He wrote also concerning the charges, and the priests' vestments wherein they minister;","searchKeywords":["wrote","also","concerning","the","charges","and","priests","vestments","wherein","they","minister"]},{"verseId":"brenton_1-esdras_4_55","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":55,"text":"and likewise for the charges of the Levites, to be given them until the day that the house were finished, and Jerusalem builded up.","searchKeywords":["and","likewise","for","the","charges","levites","given","them","until","day","that","house","were","finished","jerusalem","builded"]},{"verseId":"brenton_1-esdras_4_56","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":56,"text":"And he commanded to give to all that kept the city pensions and wages.","searchKeywords":["and","commanded","give","all","that","kept","the","city","pensions","wages"]},{"verseId":"brenton_1-esdras_4_57","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":57,"text":"He sent away also all the vessels from Babylon, that Cyrus had set apart; and all that Cyrus had given in commandment, the same charged he also to be done, and sent unto Jerusalem.","searchKeywords":["sent","away","also","all","the","vessels","from","babylon","that","cyrus","had","set","apart","and","given","commandment","same","charged","done","unto","jerusalem"]},{"verseId":"brenton_1-esdras_4_58","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":58,"text":"Now when this young man was gone forth, he lifted up his face to heaven toward Jerusalem, and praised the King of heaven,","searchKeywords":["now","when","this","young","man","was","gone","forth","lifted","his","face","heaven","toward","jerusalem","and","praised","the","king"]},{"verseId":"brenton_1-esdras_4_59","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":59,"text":"and said, From thee cometh victory, from thee cometh wisdom, and thine is the glory, and I am thy servant.","searchKeywords":["and","said","from","thee","cometh","victory","wisdom","thine","the","glory","thy","servant"]},{"verseId":"brenton_1-esdras_4_60","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":60,"text":"Blessed art thou, who hast given me wisdom: and to thee I give thanks, O Lord of our fathers.","searchKeywords":["blessed","art","thou","who","hast","given","wisdom","and","thee","give","thanks","lord","our","fathers"]},{"verseId":"brenton_1-esdras_4_61","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":61,"text":"And so he took the letters, and went out, and came unto Babylon, and told it all his brethren.","searchKeywords":["and","took","the","letters","went","out","came","unto","babylon","told","all","his","brethren"]},{"verseId":"brenton_1-esdras_4_62","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":62,"text":"And they praised the God of their fathers, because he had given them freedom and liberty","searchKeywords":["and","they","praised","the","god","their","fathers","because","had","given","them","freedom","liberty"]},{"verseId":"brenton_1-esdras_4_63","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":4,"verse":63,"text":"to go up, and to build Jerusalem, and the temple which is called by his name: and they feasted with instruments of musick and gladness seven days.","searchKeywords":["and","build","jerusalem","the","temple","which","called","his","name","they","feasted","with","instruments","musick","gladness","seven","days"]}]