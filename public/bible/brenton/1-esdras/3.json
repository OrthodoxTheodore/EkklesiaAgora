[{"verseId":"brenton_1-esdras_3_1","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":1,"text":"Now when Darius reigned, he made a great feast unto all his subjects, and unto all his household, and unto all the princes of Media and Persia,","searchKeywords":["now","when","darius","reigned","made","great","feast","unto","all","his","subjects","and","household","the","princes","media","persia"]},{"verseId":"brenton_1-esdras_3_2","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":2,"text":"and to all the governors and captains and lieutenants that were under him, from India unto Ethiopia, in the hundred twenty and seven provinces.","searchKeywords":["and","all","the","governors","captains","lieutenants","that","were","under","him","from","india","unto","ethiopia","hundred","twenty","seven","provinces"]},{"verseId":"brenton_1-esdras_3_3","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":3,"text":"And when they had eaten and drunken, and being satisfied were gone home, then Darius the king went into his bedchamber, and slept, and soon after awaked.","searchKeywords":["and","when","they","had","eaten","drunken","being","satisfied","were","gone","home","then","darius","the","king","went","into","his","bedchamber","slept","soon","after","awaked"]},{"verseId":"brenton_1-esdras_3_4","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":4,"text":"Then three young men, that were of the guard that kept the king's body, spake one to another;","searchKeywords":["then","three","young","men","that","were","the","guard","kept","king","body","spake","one","another"]},{"verseId":"brenton_1-esdras_3_5","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":5,"text":"Let every one of us speak a sentence: he that shall overcome, and whose sentence shall seem wiser than the others, unto him shall the king Darius give great gifts, and great things in token of victory:","searchKeywords":["let","every","one","speak","sentence","that","shall","overcome","and","whose","seem","wiser","than","the","others","unto","him","king","darius","give","great","gifts","things","token","victory"]},{"verseId":"brenton_1-esdras_3_6","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":6,"text":"as to be clothed in purple, to drink in gold, and to sleep upon gold, and a chariot with bridles of gold, and an headtire of fine linen, and a chain about his neck:","searchKeywords":["clothed","purple","drink","gold","and","sleep","upon","chariot","with","bridles","headtire","fine","linen","chain","about","his","neck"]},{"verseId":"brenton_1-esdras_3_7","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":7,"text":"and he shall sit next to Darius because of his wisdom, and shall be called Darius's cousin.","searchKeywords":["and","shall","sit","next","darius","because","his","wisdom","called","cousin"]},{"verseId":"brenton_1-esdras_3_8","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":8,"text":"And then every one wrote his sentence, sealed it, and laid it under the pillow of king Darius;","searchKeywords":["and","then","every","one","wrote","his","sentence","sealed","laid","under","the","pillow","king","darius"]},{"verseId":"brenton_1-esdras_3_9","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":9,"text":"and said that, when the king is risen, will give him the writing; and of whose side the king and the three princes of Persia shall judge that his sentence is the wisest, to him shall the victory be given, as was appointed.","searchKeywords":["and","said","that","when","the","king","risen","will","give","him","writing","whose","side","three","princes","persia","shall","judge","his","sentence","wisest","victory","given","was","appointed"]},{"verseId":"brenton_1-esdras_3_10","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":10,"text":"The first wrote, Wine is the strongest.","searchKeywords":["the","first","wrote","wine","strongest"]},{"verseId":"brenton_1-esdras_3_11","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":11,"text":"The second wrote, The king is strongest.","searchKeywords":["the","second","wrote","king","strongest"]},{"verseId":"brenton_1-esdras_3_12","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":12,"text":"The third wrote, Women are strongest: but above all things Truth beareth away the victory.","searchKeywords":["the","third","wrote","women","are","strongest","but","above","all","things","truth","beareth","away","victory"]},{"verseId":"brenton_1-esdras_3_13","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":13,"text":"Now when the king was risen up, they took their writings, and delivered unto him, and he read :","searchKeywords":["now","when","the","king","was","risen","they","took","their","writings","and","delivered","unto","him","read"]},{"verseId":"brenton_1-esdras_3_14","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":14,"text":"and sending forth he called all the princes of Persia and Media, and the governors, and the captains, and the lieutenants, and the chief officers;","searchKeywords":["and","sending","forth","called","all","the","princes","persia","media","governors","captains","lieutenants","chief","officers"]},{"verseId":"brenton_1-esdras_3_15","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":15,"text":"and sat him down in the royal seat of judgment; and the writing was read before them.","searchKeywords":["and","sat","him","down","the","royal","seat","judgment","writing","was","read","before","them"]},{"verseId":"brenton_1-esdras_3_16","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":16,"text":"And he said, Call the young men, and they shall declare their own sentences. So they were called, and came in.","searchKeywords":["and","said","call","the","young","men","they","shall","declare","their","own","sentences","were","called","came"]},{"verseId":"brenton_1-esdras_3_17","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":17,"text":"And he said unto them, Declare unto us your mind concerning the writings.","searchKeywords":["and","said","unto","them","declare","your","mind","concerning","the","writings"]},{"verseId":"brenton_1-esdras_3_18","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":18,"text":"and he said thus, O ye men, how exceeding strong is wine! it causeth all men to err that drink it:","searchKeywords":["and","said","thus","men","how","exceeding","strong","wine","causeth","all","err","that","drink"]},{"verseId":"brenton_1-esdras_3_19","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":19,"text":"it maketh the mind of the king and of the fatherless child to be all one; of the bondman and of the freeman, of the poor man and of the rich:","searchKeywords":["maketh","the","mind","king","and","fatherless","child","all","one","bondman","freeman","poor","man","rich"]},{"verseId":"brenton_1-esdras_3_20","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":20,"text":"it turneth also every thought into jollity and mirth, so that a man remembereth neither sorrow nor debt:","searchKeywords":["turneth","also","every","thought","into","jollity","and","mirth","that","man","remembereth","neither","sorrow","nor","debt"]},{"verseId":"brenton_1-esdras_3_21","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":21,"text":"and it maketh every heart rich, so that a man remembereth neither king nor governor; and it maketh to speak all things by talents:","searchKeywords":["and","maketh","every","heart","rich","that","man","remembereth","neither","king","nor","governor","speak","all","things","talents"]},{"verseId":"brenton_1-esdras_3_22","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":22,"text":"and when they are in their cups, they forget their love both to friends and brethren, and a little after draw out swords:","searchKeywords":["and","when","they","are","their","cups","forget","love","both","friends","brethren","little","after","draw","out","swords"]},{"verseId":"brenton_1-esdras_3_23","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":23,"text":"but when they are from the wine, they remember not what they have done.","searchKeywords":["but","when","they","are","from","the","wine","remember","not","what","have","done"]},{"verseId":"brenton_1-esdras_3_24","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":3,"verse":24,"text":"O ye men, is not wine the strongest, that enforceth to do thus? And when he had so spoken, he held his peace.","searchKeywords":["men","not","wine","the","strongest","that","enforceth","thus","and","when","had","spoken","held","his","peace"]}]