[{"verseId":"brenton_1-esdras_7_1","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":1,"text":"Then Sisinnes the governor of Celosyria and Phenice, and Sathrabuzanes, with their companions, following the commandments of king Darius,","searchKeywords":["then","sisinnes","the","governor","celosyria","and","phenice","sathrabuzanes","with","their","companions","following","commandments","king","darius"]},{"verseId":"brenton_1-esdras_7_2","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":2,"text":"did very carefully oversee the holy works, assisting the ancients of the Jews and governors of the temple.","searchKeywords":["did","very","carefully","oversee","the","holy","works","assisting","ancients","jews","and","governors","temple"]},{"verseId":"brenton_1-esdras_7_3","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":3,"text":"And so the holy works prospered, when Aggeus and Zacharias the prophets prophesied.","searchKeywords":["and","the","holy","works","prospered","when","aggeus","zacharias","prophets","prophesied"]},{"verseId":"brenton_1-esdras_7_4","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":4,"text":"And they finished these things by the commandment of the Lord God of Israel; and with the consent of Cyrus, Darius, and Artaxerxes, kings of Persia,","searchKeywords":["and","they","finished","these","things","the","commandment","lord","god","israel","with","consent","cyrus","darius","artaxerxes","kings","persia"]},{"verseId":"brenton_1-esdras_7_5","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":5,"text":"the holy house was finished in the three and twentieth day of the month Adar, in the sixth year of king Darius.","searchKeywords":["the","holy","house","was","finished","three","and","twentieth","day","month","adar","sixth","year","king","darius"]},{"verseId":"brenton_1-esdras_7_6","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":6,"text":"And the children of Israel, the priests, and the Levites, and others that were of the captivity, that were added unto them, did according to the things in the book of Moses.","searchKeywords":["and","the","children","israel","priests","levites","others","that","were","captivity","added","unto","them","did","according","things","book","moses"]},{"verseId":"brenton_1-esdras_7_7","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":7,"text":"And to the dedication of the temple of the Lord they offered an hundred bullocks, two hundred rams, four hundred lambs;","searchKeywords":["and","the","dedication","temple","lord","they","offered","hundred","bullocks","two","rams","four","lambs"]},{"verseId":"brenton_1-esdras_7_8","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":8,"text":"and twelve goats for the sin of all Israel, according to the number of the chief of the tribes of Israel.","searchKeywords":["and","twelve","goats","for","the","sin","all","israel","according","number","chief","tribes"]},{"verseId":"brenton_1-esdras_7_9","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":9,"text":"The priests also and the Levites stood arrayed in their vestments, according to their kindreds, in the service of the Lord God of Israel, according to the book of Moses: and the porters at every gate.","searchKeywords":["the","priests","also","and","levites","stood","arrayed","their","vestments","according","kindreds","service","lord","god","israel","book","moses","porters","every","gate"]},{"verseId":"brenton_1-esdras_7_10","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":10,"text":"And the children of Israel that were of the captivity held the passover the fourteenth day of the first month, after that the priests and the Levites were sanctified,","searchKeywords":["and","the","children","israel","that","were","captivity","held","passover","fourteenth","day","first","month","after","priests","levites","sanctified"]},{"verseId":"brenton_1-esdras_7_11","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":11,"text":"together with all the children of the captivity; for they were sanctified, because the Levites were all sanctified together.","searchKeywords":["together","with","all","the","children","captivity","for","they","were","sanctified","because","levites"]},{"verseId":"brenton_1-esdras_7_12","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":12,"text":"And so they offered the passover for all them of the captivity, and for their brethren the priests, and for themselves.","searchKeywords":["and","they","offered","the","passover","for","all","them","captivity","their","brethren","priests","themselves"]},{"verseId":"brenton_1-esdras_7_13","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":13,"text":"And the children of Israel that came out of the captivity did eat, even all they that had separated themselves from the abominations of the people of the land, and sought the Lord.","searchKeywords":["and","the","children","israel","that","came","out","captivity","did","eat","even","all","they","had","separated","themselves","from","abominations","people","land","sought","lord"]},{"verseId":"brenton_1-esdras_7_14","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":14,"text":"And they kept the feast of unleavened bread seven days, making merry before the Lord,","searchKeywords":["and","they","kept","the","feast","unleavened","bread","seven","days","making","merry","before","lord"]},{"verseId":"brenton_1-esdras_7_15","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":7,"verse":15,"text":"for that he had turned the counsel of the king of Assyria toward them, to strengthen their hands in the works of the Lord God of Israel.","searchKeywords":["for","that","had","turned","the","counsel","king","assyria","toward","them","strengthen","their","hands","works","lord","god","israel"]}]