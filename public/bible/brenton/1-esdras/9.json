[{"verseId":"brenton_1-esdras_9_1","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":1,"text":"Then Esdras rising from the court of the temple went to the chamber of Joanan the son of Eliasib,","searchKeywords":["then","esdras","rising","from","the","court","temple","went","chamber","joanan","son","eliasib"]},{"verseId":"brenton_1-esdras_9_2","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":2,"text":"and remained there, and did eat no meat nor drink water, mourning for the great iniquities of the multitude.","searchKeywords":["and","remained","there","did","eat","meat","nor","drink","water","mourning","for","the","great","iniquities","multitude"]},{"verseId":"brenton_1-esdras_9_3","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":3,"text":"And there was a proclamation in all Jewry and Jerusalem to all them that were of the captivity, that they should be gathered together at Jerusalem:","searchKeywords":["and","there","was","proclamation","all","jewry","jerusalem","them","that","were","the","captivity","they","should","gathered","together"]},{"verseId":"brenton_1-esdras_9_4","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":4,"text":"and that whosoever met not there within two or three days, according as the elders that bare rule appointed, their cattle should be seized to the use of the temple, and himself cast out from them that were of the captivity.","searchKeywords":["and","that","whosoever","met","not","there","within","two","three","days","according","the","elders","bare","rule","appointed","their","cattle","should","seized","use","temple","himself","cast","out","from","them","were","captivity"]},{"verseId":"brenton_1-esdras_9_5","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":5,"text":"And in three days were all they of the tribe of Juda and Benjamin gathered together at Jerusalem the twentieth day of the ninth month.","searchKeywords":["and","three","days","were","all","they","the","tribe","juda","benjamin","gathered","together","jerusalem","twentieth","day","ninth","month"]},{"verseId":"brenton_1-esdras_9_6","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":6,"text":"And all the multitude sat in the broad court of the temple, trembling because of the present foul weather.","searchKeywords":["and","all","the","multitude","sat","broad","court","temple","trembling","because","present","foul","weather"]},{"verseId":"brenton_1-esdras_9_7","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":7,"text":"So Esdras arose up, and said unto them, Ye have transgressed the law in marrying strange wives, thereby to increase the sins of Israel.","searchKeywords":["esdras","arose","and","said","unto","them","have","transgressed","the","law","marrying","strange","wives","thereby","increase","sins","israel"]},{"verseId":"brenton_1-esdras_9_8","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":8,"text":"And now by confessing give glory unto the Lord God of our fathers,","searchKeywords":["and","now","confessing","give","glory","unto","the","lord","god","our","fathers"]},{"verseId":"brenton_1-esdras_9_9","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":9,"text":"and do his will, and separate yourselves from the heathen of the land, and from the strange women.","searchKeywords":["and","his","will","separate","yourselves","from","the","heathen","land","strange","women"]},{"verseId":"brenton_1-esdras_9_10","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":10,"text":"Then cried the whole multitude, and said with a loud voice, Like as thou hast spoken, so will we do.","searchKeywords":["then","cried","the","whole","multitude","and","said","with","loud","voice","like","thou","hast","spoken","will"]},{"verseId":"brenton_1-esdras_9_11","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":11,"text":"But forasmuch as the people are many, and it is foul weather, so that we cannot stand without, and this is not a work of a day or two, seeing our sin in these things is spread far:","searchKeywords":["but","forasmuch","the","people","are","many","and","foul","weather","that","cannot","stand","without","this","not","work","day","two","seeing","our","sin","these","things","spread","far"]},{"verseId":"brenton_1-esdras_9_12","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":12,"text":"therefore let the rulers of the multitude stay, and let all them of our habitations that have strange wives come at the time appointed,","searchKeywords":["therefore","let","the","rulers","multitude","stay","and","all","them","our","habitations","that","have","strange","wives","come","time","appointed"]},{"verseId":"brenton_1-esdras_9_13","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":13,"text":"and with them the rulers and judges of every place, till we turn away the wrath of the Lord from us for this matter.","searchKeywords":["and","with","them","the","rulers","judges","every","place","till","turn","away","wrath","lord","from","for","this","matter"]},{"verseId":"brenton_1-esdras_9_14","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":14,"text":"Jonathan of Azael and Ezechias of Theocanus accordingly took this matter upon them: and Mosollam and Levis and Sabbatheus helped them.","searchKeywords":["jonathan","azael","and","ezechias","theocanus","accordingly","took","this","matter","upon","them","mosollam","levis","sabbatheus","helped"]},{"verseId":"brenton_1-esdras_9_15","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":15,"text":"And they that were of the captivity did according to all these things.","searchKeywords":["and","they","that","were","the","captivity","did","according","all","these","things"]},{"verseId":"brenton_1-esdras_9_16","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":16,"text":"And Esdras the priest chose unto him the principal men of their families, all by name: and in the first day of the tenth month they sat together to examine the matter.","searchKeywords":["and","esdras","the","priest","chose","unto","him","principal","men","their","families","all","name","first","day","tenth","month","they","sat","together","examine","matter"]},{"verseId":"brenton_1-esdras_9_17","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":17,"text":"So their cause that held strange wives was brought to an end in the first day of the first month.","searchKeywords":["their","cause","that","held","strange","wives","was","brought","end","the","first","day","month"]},{"verseId":"brenton_1-esdras_9_18","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":18,"text":"And of the priests that were come together, and had strange wives, there were found;","searchKeywords":["and","the","priests","that","were","come","together","had","strange","wives","there","found"]},{"verseId":"brenton_1-esdras_9_19","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":19,"text":"of the sons of Jesus the of Josedec, and his brethren; Matthelas, and Eleazar, and Joribus, and Joadanus.","searchKeywords":["the","sons","jesus","josedec","and","his","brethren","matthelas","eleazar","joribus","joadanus"]},{"verseId":"brenton_1-esdras_9_20","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":20,"text":"And they gave their hands to put away their wives, and to offer rams to make reconcilement for their errors.","searchKeywords":["and","they","gave","their","hands","put","away","wives","offer","rams","make","reconcilement","for","errors"]},{"verseId":"brenton_1-esdras_9_21","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":21,"text":"And of the sons of Emmer: Ananias, and Zabdeus, and Manes, and Samæus, and Hiereel, and Azarias.","searchKeywords":["and","the","sons","emmer","ananias","zabdeus","manes","sam","hiereel","azarias"]},{"verseId":"brenton_1-esdras_9_22","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":22,"text":"And of the sons of Phaisur; Elionais, Massias, Ismael, and Nathanael, and Ocodelus, and Saloas.","searchKeywords":["and","the","sons","phaisur","elionais","massias","ismael","nathanael","ocodelus","saloas"]},{"verseId":"brenton_1-esdras_9_23","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":23,"text":"And of the Levites; Jozabad, and Semis, and Coïus, who was called Calitas, and Patheus, and Judas, and Jonas.","searchKeywords":["and","the","levites","jozabad","semis","who","was","called","calitas","patheus","judas","jonas"]},{"verseId":"brenton_1-esdras_9_24","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":24,"text":"Of the holy singers: Eleasabus, Bacchurus.","searchKeywords":["the","holy","singers","eleasabus","bacchurus"]},{"verseId":"brenton_1-esdras_9_25","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":25,"text":"Of the porters; Salumus, and Tolbanes.","searchKeywords":["the","porters","salumus","and","tolbanes"]},{"verseId":"brenton_1-esdras_9_26","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":26,"text":"Of them of Israel, of the sons of Phoros; Hiermas, and Jezias, and Melchias, and Maelus, and Eleazar, and Asebias, and Banæas.","searchKeywords":["them","israel","the","sons","phoros","hiermas","and","jezias","melchias","maelus","eleazar","asebias","ban"]},{"verseId":"brenton_1-esdras_9_27","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":27,"text":"Of the sons of Ela; Matthanias, Zacharias, and Jezrielus, and Joabdius, and Hieremoth, and Aïdias.","searchKeywords":["the","sons","ela","matthanias","zacharias","and","jezrielus","joabdius","hieremoth","dias"]},{"verseId":"brenton_1-esdras_9_28","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":28,"text":"And of the sons of Zamoth; Eliadas, Eliasimus, Othonias, Jarimoth, and Sabatus, and Zeralias.","searchKeywords":["and","the","sons","zamoth","eliadas","eliasimus","othonias","jarimoth","sabatus","zeralias"]},{"verseId":"brenton_1-esdras_9_29","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":29,"text":"Of the sons of Bebai; Joannes, and Ananias, and Josabad, and Amatheis.","searchKeywords":["the","sons","bebai","joannes","and","ananias","josabad","amatheis"]},{"verseId":"brenton_1-esdras_9_30","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":30,"text":"Of the sons of Mani; Olamus, Mamuchus, Jedeus, Jasubus, Jasael, and Hieremoth.","searchKeywords":["the","sons","mani","olamus","mamuchus","jedeus","jasubus","jasael","and","hieremoth"]},{"verseId":"brenton_1-esdras_9_31","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":31,"text":"And of the sons of Addi; Naathus, and Moosias, Lacunus, and Naidus, Matthanias, and Sesthel, Balnuus, and Manasseas.","searchKeywords":["and","the","sons","addi","naathus","moosias","lacunus","naidus","matthanias","sesthel","balnuus","manasseas"]},{"verseId":"brenton_1-esdras_9_32","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":32,"text":"And of the sons of Annas; Elionas, and Asaias, and Melchias, and Sabbeus, and Simon Chosameus.","searchKeywords":["and","the","sons","annas","elionas","asaias","melchias","sabbeus","simon","chosameus"]},{"verseId":"brenton_1-esdras_9_33","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":33,"text":"And of the sons of Asom; Altaneus, and Mattathias, and Sabanneus, Eliphalat, and Manasses, and Semei.","searchKeywords":["and","the","sons","asom","altaneus","mattathias","sabanneus","eliphalat","manasses","semei"]},{"verseId":"brenton_1-esdras_9_34","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":34,"text":"And of the sons of Baani: Jeremias, Momdis, Ismaerus, Juel, Mabdai, and Pedias, and Anos, Rabasion, and Enasibus, and Mamnitanaimus, Eliasis, Bannus, Eliali, Samis, Selemias, Nathanias: and of the sons of Ezora; Sesis, Esril, Azaelus, Samatus, Zambri, Josephus.","searchKeywords":["and","the","sons","baani","jeremias","momdis","ismaerus","juel","mabdai","pedias","anos","rabasion","enasibus","mamnitanaimus","eliasis","bannus","eliali","samis","selemias","nathanias","ezora","sesis","esril","azaelus","samatus","zambri","josephus"]},{"verseId":"brenton_1-esdras_9_35","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":35,"text":"And of the sons of Ethma; Mazitias, Zabadaias, Edaïs, Juel, Banaias.","searchKeywords":["and","the","sons","ethma","mazitias","zabadaias","eda","juel","banaias"]},{"verseId":"brenton_1-esdras_9_36","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":36,"text":"All these had taken strange wives, and they put them away with their children.","searchKeywords":["all","these","had","taken","strange","wives","and","they","put","them","away","with","their","children"]},{"verseId":"brenton_1-esdras_9_37","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":37,"text":"And the priests and Levites, and they that were of Israel, dwelt in Jerusalem, and in the country, in the first day of the seventh month: so the children of Israel were in their habitations.","searchKeywords":["and","the","priests","levites","they","that","were","israel","dwelt","jerusalem","country","first","day","seventh","month","children","their","habitations"]},{"verseId":"brenton_1-esdras_9_38","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":38,"text":"And the whole multitude came together with one accord into the broad place of the holy porch toward the east:","searchKeywords":["and","the","whole","multitude","came","together","with","one","accord","into","broad","place","holy","porch","toward","east"]},{"verseId":"brenton_1-esdras_9_39","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":39,"text":"and they spake unto Esdras the priest and reader, that he would bring the law of Moses, that was given of the Lord God of Israel.","searchKeywords":["and","they","spake","unto","esdras","the","priest","reader","that","would","bring","law","moses","was","given","lord","god","israel"]},{"verseId":"brenton_1-esdras_9_40","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":40,"text":"So Esdras the chief priest brought the law to the whole multitude from man to woman, and to all the priests, to hear the law in the first day of the seventh month.","searchKeywords":["esdras","the","chief","priest","brought","law","whole","multitude","from","man","woman","and","all","priests","hear","first","day","seventh","month"]},{"verseId":"brenton_1-esdras_9_41","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":41,"text":"And he read in the broad court before the holy porch from morning unto midday, before both men and women; and all the multitude gave heed unto the law.","searchKeywords":["and","read","the","broad","court","before","holy","porch","from","morning","unto","midday","both","men","women","all","multitude","gave","heed","law"]},{"verseId":"brenton_1-esdras_9_42","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":42,"text":"And Esdras the priest and reader of the law stood up upon a pulpit of wood which was made .","searchKeywords":["and","esdras","the","priest","reader","law","stood","upon","pulpit","wood","which","was","made"]},{"verseId":"brenton_1-esdras_9_43","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":43,"text":"And there stood up by him Mattathias, Sammus, Ananias, Azarias, Urias, Ezecias, Baalsamus, upon the right hand:","searchKeywords":["and","there","stood","him","mattathias","sammus","ananias","azarias","urias","ezecias","baalsamus","upon","the","right","hand"]},{"verseId":"brenton_1-esdras_9_44","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":44,"text":"and upon his left hand Phaldaius, and Misael, Melchias, Lothasubus, Nabarias, Zacharias.","searchKeywords":["and","upon","his","left","hand","phaldaius","misael","melchias","lothasubus","nabarias","zacharias"]},{"verseId":"brenton_1-esdras_9_45","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":45,"text":"Then took Esdras the book of the law before the multitude: for he sat honourably in the first place in the sight of them all.","searchKeywords":["then","took","esdras","the","book","law","before","multitude","for","sat","honourably","first","place","sight","them","all"]},{"verseId":"brenton_1-esdras_9_46","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":46,"text":"And when he opened the law, they stood all straight up. So Esdras blessed the Lord God most High, the God of hosts, Almighty.","searchKeywords":["and","when","opened","the","law","they","stood","all","straight","esdras","blessed","lord","god","most","high","hosts","almighty"]},{"verseId":"brenton_1-esdras_9_47","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":47,"text":"And all the people answered, Amen; and lifting up their hands they fell to the ground, and worshipped the Lord.","searchKeywords":["and","all","the","people","answered","amen","lifting","their","hands","they","fell","ground","worshipped","lord"]},{"verseId":"brenton_1-esdras_9_48","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":48,"text":"Also Jesus, Anniuth, Sarabias, Adinus, Jacubus, Sabateas, Auteas, Maiannas, and Calitas, Azarias, and Joazabdus, and Ananias, Phalias, the Levites, taught the law of the Lord, and read the law of the Lord to the multitude, making them withal to understand it.","searchKeywords":["also","jesus","anniuth","sarabias","adinus","jacubus","sabateas","auteas","maiannas","and","calitas","azarias","joazabdus","ananias","phalias","the","levites","taught","law","lord","read","multitude","making","them","withal","understand"]},{"verseId":"brenton_1-esdras_9_49","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":49,"text":"Then spake Attharates unto Esdras the chief priest and reader, and to the Levites that taught the multitude, even to all, saying,","searchKeywords":["then","spake","attharates","unto","esdras","the","chief","priest","and","reader","levites","that","taught","multitude","even","all","saying"]},{"verseId":"brenton_1-esdras_9_50","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":50,"text":"This day is holy unto the Lord; (for they all wept when they heard the law:)","searchKeywords":["this","day","holy","unto","the","lord","for","they","all","wept","when","heard","law"]},{"verseId":"brenton_1-esdras_9_51","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":51,"text":"go then, and eat the fat, and drink the sweet, and send part to them that have nothing:","searchKeywords":["then","and","eat","the","fat","drink","sweet","send","part","them","that","have","nothing"]},{"verseId":"brenton_1-esdras_9_52","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":52,"text":"for this day is holy unto the Lord: and be not sorrowful; for the Lord will bring you to honour.","searchKeywords":["for","this","day","holy","unto","the","lord","and","not","sorrowful","will","bring","you","honour"]},{"verseId":"brenton_1-esdras_9_53","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":53,"text":"So the Levites published all things to the people, saying, This day is holy to the Lord; be not sorrowful.","searchKeywords":["the","levites","published","all","things","people","saying","this","day","holy","lord","not","sorrowful"]},{"verseId":"brenton_1-esdras_9_54","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":54,"text":"Then went they their way, every one to eat and drink and make merry, and to give part to them that had nothing, and to make great cheer;","searchKeywords":["then","went","they","their","way","every","one","eat","and","drink","make","merry","give","part","them","that","had","nothing","great","cheer"]},{"verseId":"brenton_1-esdras_9_55","translationId":"brenton","testament":"OT","bookIndex":15,"bookName":"1 Esdras","bookAbbrev":"1-esdras","chapter":9,"verse":55,"text":"because they understood the words wherein they were instructed, and for the which they had been assembled.","searchKeywords":["because","they","understood","the","words","wherein","were","instructed","and","for","which","had","been","assembled"]}]