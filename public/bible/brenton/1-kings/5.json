,"him","and","there","was","peace","between","chiram","solomon","they","made","covenant","them"]},{"verseId":"brenton_1-kings_5_27","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":5,"verse":27,"text":"a levy out of all Israel, and the levy was thirty thousand men.","searchKeywords":["levy","out","all","israel","and","the","was","thirty","thousand","men"]},{"verseId":"brenton_1-kings_5_28","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":5,"verse":28,"text":"over the levy.","searchKeywords":["over","the","levy"]},{"verseId":"brenton_1-kings_5_30","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":5,"verse":30,"text":"three thousand six hundred masters who wrought in the works.","searchKeywords":["three","thousand","six","hundred","masters","who","wrought","the","works"]},{"verseId":"brenton_1-kings_5_32","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":5,"verse":32,"text":"three years.","searchKeywords":["three","years"]}]