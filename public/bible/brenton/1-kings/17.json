[{"verseId":"brenton_1-kings_17_1","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":1,"text":"And Eliu the prophet, the Thesbite of Thesbæ of Galaad, said to Achaab, As the Lord God of hosts, the God of Israel, lives, before whom I stand, there shall not be these years dew nor rain, except by the word of my mouth.","searchKeywords":["and","eliu","the","prophet","thesbite","thesb","galaad","said","achaab","lord","god","hosts","israel","lives","before","whom","stand","there","shall","not","these","years","dew","nor","rain","except","word","mouth"]},{"verseId":"brenton_1-kings_17_2","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":2,"text":"And the word of the Lord came to Eliu, ,","searchKeywords":["and","the","word","lord","came","eliu"]},{"verseId":"brenton_1-kings_17_3","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":3,"text":"Depart hence eastward, and hide thee by the brook of Chorrath, that is before Jordan.","searchKeywords":["depart","hence","eastward","and","hide","thee","the","brook","chorrath","that","before","jordan"]},{"verseId":"brenton_1-kings_17_4","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":4,"text":"And it shall be thou shalt drink water of the brook, and I will charge the ravens to feed thee there.","searchKeywords":["and","shall","thou","shalt","drink","water","the","brook","will","charge","ravens","feed","thee","there"]},{"verseId":"brenton_1-kings_17_5","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":5,"text":"And Eliu did according to the word of the Lord, and he sat by the brook of Chorrath before Jordan.","searchKeywords":["and","eliu","did","according","the","word","lord","sat","brook","chorrath","before","jordan"]},{"verseId":"brenton_1-kings_17_6","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":6,"text":"And the ravens brought him loaves in the morning, and flesh in the evening, and he drank water of the brook.","searchKeywords":["and","the","ravens","brought","him","loaves","morning","flesh","evening","drank","water","brook"]},{"verseId":"brenton_1-kings_17_7","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":7,"text":"And it came to pass after some time, that the brook was dried up, because there had been no rain upon the earth.","searchKeywords":["and","came","pass","after","some","time","that","the","brook","was","dried","because","there","had","been","rain","upon","earth"]},{"verseId":"brenton_1-kings_17_8","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":8,"text":"And the word of the Lord came to Eliu, ,","searchKeywords":["and","the","word","lord","came","eliu"]},{"verseId":"brenton_1-kings_17_9","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":9,"text":"Arise, and go to Sarepta of the Sidonian : behold, I have there commanded a widow-woman to maintain thee.","searchKeywords":["arise","and","sarepta","the","sidonian","behold","have","there","commanded","widow","woman","maintain","thee"]},{"verseId":"brenton_1-kings_17_10","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":10,"text":"And he arose and went to Sarepta, and came to the gate of the city: and, behold, a widow-woman was there gathering sticks; and Eliu cried after her, and said to her, Fetch me, I pray thee, a little water in a vessel, that I may drink.","searchKeywords":["and","arose","went","sarepta","came","the","gate","city","behold","widow","woman","was","there","gathering","sticks","eliu","cried","after","her","said","fetch","pray","thee","little","water","vessel","that","may","drink"]},{"verseId":"brenton_1-kings_17_11","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":11,"text":"And she went to fetch it; and Eliu cried after her, and said, Bring me, I pray thee, a morsel of the bread that is in thy hand.","searchKeywords":["and","she","went","fetch","eliu","cried","after","her","said","bring","pray","thee","morsel","the","bread","that","thy","hand"]},{"verseId":"brenton_1-kings_17_12","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":12,"text":"And the woman said, the Lord thy God lives, I have not a cake, but only a handful of meal in the pitcher, and a little oil in a cruse, and, behold, I am going to gather two sticks, and I shall go in and dress it for myself and my children, and we shall eat it and die.","searchKeywords":["and","the","woman","said","lord","thy","god","lives","have","not","cake","but","only","handful","meal","pitcher","little","oil","cruse","behold","going","gather","two","sticks","shall","dress","for","myself","children","eat","die"]},{"verseId":"brenton_1-kings_17_13","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":13,"text":"And Eliu said to her, Be of good courage, go in and do according to thy word: but make me thereof a little cake, and thou shalt bring out to me first, and thou shalt make for thyself and thy children last.","searchKeywords":["and","eliu","said","her","good","courage","according","thy","word","but","make","thereof","little","cake","thou","shalt","bring","out","first","for","thyself","children","last"]},{"verseId":"brenton_1-kings_17_14","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":14,"text":"For thus saith the Lord, The pitcher of meal shall not fail, and the cruse of oil shall not diminish, until the day that the Lord gives rain upon the earth.","searchKeywords":["for","thus","saith","the","lord","pitcher","meal","shall","not","fail","and","cruse","oil","diminish","until","day","that","gives","rain","upon","earth"]},{"verseId":"brenton_1-kings_17_15","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":15,"text":"And the woman went and did , and did eat, she, and he, and her children.","searchKeywords":["and","the","woman","went","did","eat","she","her","children"]},{"verseId":"brenton_1-kings_17_16","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":16,"text":"And the pitcher of meal failed not, and the cruse of oil was not diminished, according to the word of the Lord which he spoke by the hand of Eliu.","searchKeywords":["and","the","pitcher","meal","failed","not","cruse","oil","was","diminished","according","word","lord","which","spoke","hand","eliu"]},{"verseId":"brenton_1-kings_17_17","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":17,"text":"And it came to pass afterward, that the son of the woman the mistress of the house was sick; and his sickness was very severe, until there was no breath left in him.","searchKeywords":["and","came","pass","afterward","that","the","son","woman","mistress","house","was","sick","his","sickness","very","severe","until","there","breath","left","him"]},{"verseId":"brenton_1-kings_17_18","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":18,"text":"And she said to Eliu, What have I to do with thee, O man of God? hast thou come in to me to bring my sins to remembrance, and to slay my son?","searchKeywords":["and","she","said","eliu","what","have","with","thee","man","god","hast","thou","come","bring","sins","remembrance","slay","son"]},{"verseId":"brenton_1-kings_17_19","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":19,"text":"And Eliu said to the woman, Give me thy son. And he took him out of her bosom, and took him up to the chamber in which he himself lodged, and laid him on the bed.","searchKeywords":["and","eliu","said","the","woman","give","thy","son","took","him","out","her","bosom","chamber","which","himself","lodged","laid","bed"]},{"verseId":"brenton_1-kings_17_20","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":20,"text":"And Eliu cried aloud, and said, Alas, O Lord, the witness of the widow with whom I sojourn, thou hast wrought evil in slaying her son.","searchKeywords":["and","eliu","cried","aloud","said","alas","lord","the","witness","widow","with","whom","sojourn","thou","hast","wrought","evil","slaying","her","son"]},{"verseId":"brenton_1-kings_17_21","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":21,"text":"And he breathed on the child thrice, and called on the Lord, and said, O Lord my God, let, I pray thee, the soul of this child return to him.","searchKeywords":["and","breathed","the","child","thrice","called","lord","said","god","let","pray","thee","soul","this","return","him"]},{"verseId":"brenton_1-kings_17_22","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":22,"text":"And it was so, and the child cried out,","searchKeywords":["and","was","the","child","cried","out"]},{"verseId":"brenton_1-kings_17_23","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":23,"text":"and he brought him down from the upper chamber into the house, and gave him to his mother; and Eliu said, See, thy son lives.","searchKeywords":["and","brought","him","down","from","the","upper","chamber","into","house","gave","his","mother","eliu","said","see","thy","son","lives"]},{"verseId":"brenton_1-kings_17_24","translationId":"brenton","testament":"OT","bookIndex":11,"bookName":"1 Kings","bookAbbrev":"1-kings","chapter":17,"verse":24,"text":"And the woman said to Eliu, Behold, I know that thou a man of God, and the word of the Lord in thy mouth true.","searchKeywords":["and","the","woman","said","eliu","behold","know","that","thou","man","god","word","lord","thy","mouth","true"]}]