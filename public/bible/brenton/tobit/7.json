[{"verseId":"brenton_tobit_7_1","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":1,"text":"And he came to the house of Raguel; and Sara met him: and saluted him, and he them; and she brought them into the house.","searchKeywords":["and","came","the","house","raguel","sara","met","him","saluted","them","she","brought","into"]},{"verseId":"brenton_tobit_7_2","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":2,"text":"Then said Raguel to Edna his wife, How like is this young man to Tobit my cousin!","searchKeywords":["then","said","raguel","edna","his","wife","how","like","this","young","man","tobit","cousin"]},{"verseId":"brenton_tobit_7_3","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":3,"text":"And Raguel asked them, From whence are ye, brethren? To whom they said, We are of the sons of Nephthali, which are captives in Nineve.","searchKeywords":["and","raguel","asked","them","from","whence","are","brethren","whom","they","said","the","sons","nephthali","which","captives","nineve"]},{"verseId":"brenton_tobit_7_4","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":4,"text":"Then he said to them, Do ye know Tobit our kinsman? And they said, We know him. Then said he, Is he in good health?","searchKeywords":["then","said","them","know","tobit","our","kinsman","and","they","him","good","health"]},{"verseId":"brenton_tobit_7_5","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":5,"text":"And they said, He is both alive, and in good health: and Tobias said, He is my father.","searchKeywords":["and","they","said","both","alive","good","health","tobias","father"]},{"verseId":"brenton_tobit_7_6","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":6,"text":"Then Raguel leaped up, and kissed him, and wept,","searchKeywords":["then","raguel","leaped","and","kissed","him","wept"]},{"verseId":"brenton_tobit_7_7","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":7,"text":"and blessed him, and said unto him, the son of an honest and good man. But when he had heard that Tobit was blind, he was sorrowful, and wept.","searchKeywords":["and","blessed","him","said","unto","the","son","honest","good","man","but","when","had","heard","that","tobit","was","blind","sorrowful","wept"]},{"verseId":"brenton_tobit_7_8","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":8,"text":"And likewise Edna his wife and Sara his daughter wept. Moreover they entertained them cheerfully; and after that they had killed a ram of the flock, they set store of meat on the table. Then said Tobias to Raphael, Brother Azarias, speak of those things of which thou didst talk in the way, and let this business be dispatched.","searchKeywords":["and","likewise","edna","his","wife","sara","daughter","wept","moreover","they","entertained","them","cheerfully","after","that","had","killed","ram","the","flock","set","store","meat","table","then","said","tobias","raphael","brother","azarias","speak","those","things","which","thou","didst","talk","way","let","this","business","dispatched"]},{"verseId":"brenton_tobit_7_9","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":9,"text":"So he communicated the matter with Raguel: and Raguel said to Tobias, Eat and drink, and make merry:","searchKeywords":["communicated","the","matter","with","raguel","and","said","tobias","eat","drink","make","merry"]},{"verseId":"brenton_tobit_7_10","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":10,"text":"for it is meet that thou shouldest marry my daughter: nevertheless I will declare unto thee the truth.","searchKeywords":["for","meet","that","thou","shouldest","marry","daughter","nevertheless","will","declare","unto","thee","the","truth"]},{"verseId":"brenton_tobit_7_11","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":11,"text":"I have given my daughter in marriage to seven men, who died that night they came in unto her: nevertheless for the present be merry. But Tobias said, I will eat nothing here, till we agree and swear one to another.","searchKeywords":["have","given","daughter","marriage","seven","men","who","died","that","night","they","came","unto","her","nevertheless","for","the","present","merry","but","tobias","said","will","eat","nothing","here","till","agree","and","swear","one","another"]},{"verseId":"brenton_tobit_7_12","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":12,"text":"And Raguel said, Then take her from henceforth according to the manner, for thou art her cousin, and she is thine, and the merciful God give you good success in all things.","searchKeywords":["and","raguel","said","then","take","her","from","henceforth","according","the","manner","for","thou","art","cousin","she","thine","merciful","god","give","you","good","success","all","things"]},{"verseId":"brenton_tobit_7_13","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":13,"text":"Then he called his daughter Sara, and she came to her father, and he took her by the hand, and gave her to be wife to Tobias, saying, Behold, take her after the law of Moses, and lead her away to thy father. And he blessed them;","searchKeywords":["then","called","his","daughter","sara","and","she","came","her","father","took","the","hand","gave","wife","tobias","saying","behold","take","after","law","moses","lead","away","thy","blessed","them"]},{"verseId":"brenton_tobit_7_14","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":14,"text":"and called Edna his wife, and took paper, and did write an instrument , and sealed it.","searchKeywords":["and","called","edna","his","wife","took","paper","did","write","instrument","sealed"]},{"verseId":"brenton_tobit_7_15","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":15,"text":"Then they began to eat.","searchKeywords":["then","they","began","eat"]},{"verseId":"brenton_tobit_7_16","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":16,"text":"After Raguel called his wife Edna, and said unto her, Sister, prepare another chamber, and bring her in thither.","searchKeywords":["after","raguel","called","his","wife","edna","and","said","unto","her","sister","prepare","another","chamber","bring","thither"]},{"verseId":"brenton_tobit_7_17","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":17,"text":"Which when she had done as he had bidden her, she brought her thither: and she wept, and she received the tears of her daughter, and said unto her,","searchKeywords":["which","when","she","had","done","bidden","her","brought","thither","and","wept","received","the","tears","daughter","said","unto"]},{"verseId":"brenton_tobit_7_18","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":7,"verse":18,"text":"Be of good comfort, my daughter; the Lord of heaven and earth give thee joy for this thy sorrow: be of good comfort, my daughter.","searchKeywords":["good","comfort","daughter","the","lord","heaven","and","earth","give","thee","joy","for","this","thy","sorrow"]}]