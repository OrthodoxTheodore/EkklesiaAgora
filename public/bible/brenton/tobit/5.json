[{"verseId":"brenton_tobit_5_1","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":1,"text":"Tobias then answered and said, Father, I will do all things which thou hast commanded me:","searchKeywords":["tobias","then","answered","and","said","father","will","all","things","which","thou","hast","commanded"]},{"verseId":"brenton_tobit_5_2","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":2,"text":"but how can I receive the money, seeing I know him not?","searchKeywords":["but","how","can","receive","the","money","seeing","know","him","not"]},{"verseId":"brenton_tobit_5_3","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":3,"text":"Then he gave him the handwriting, and said unto him, Seek thee a man which may go with thee, and I will give him wages whiles I yet live: and go and receive the money.","searchKeywords":["then","gave","him","the","handwriting","and","said","unto","seek","thee","man","which","may","with","will","give","wages","whiles","yet","live","receive","money"]},{"verseId":"brenton_tobit_5_4","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":4,"text":"Therefore when he went to seek a man, he found Raphael that was an angel.","searchKeywords":["therefore","when","went","seek","man","found","raphael","that","was","angel"]},{"verseId":"brenton_tobit_5_5","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":5,"text":"But he knew not; and he said unto him, Canst thou go with me to Rages? and knowest thou those places well?","searchKeywords":["but","knew","not","and","said","unto","him","canst","thou","with","rages","knowest","those","places","well"]},{"verseId":"brenton_tobit_5_6","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":6,"text":"To whom the angel said, I will go with thee, and I know the way well: for I have lodged with our brother Gabael.","searchKeywords":["whom","the","angel","said","will","with","thee","and","know","way","well","for","have","lodged","our","brother","gabael"]},{"verseId":"brenton_tobit_5_7","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":7,"text":"Then Tobias said unto him, Tarry for me, till I tell my father.","searchKeywords":["then","tobias","said","unto","him","tarry","for","till","tell","father"]},{"verseId":"brenton_tobit_5_8","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":8,"text":"Then he said unto him, Go, and tarry not. So he went in and said to his father, Behold, I have found one which will go with me. Then he said, Call him unto me, that I may know of what tribe he is, and whether he be a trusty man to go with thee.","searchKeywords":["then","said","unto","him","and","tarry","not","went","his","father","behold","have","found","one","which","will","with","call","that","may","know","what","tribe","whether","trusty","man","thee"]},{"verseId":"brenton_tobit_5_9","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":9,"text":"So he called him, and he came in, and they saluted one another.","searchKeywords":["called","him","and","came","they","saluted","one","another"]},{"verseId":"brenton_tobit_5_10","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":10,"text":"Then Tobit said unto him, Brother, shew me of what tribe and family thou art.","searchKeywords":["then","tobit","said","unto","him","brother","shew","what","tribe","and","family","thou","art"]},{"verseId":"brenton_tobit_5_11","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":11,"text":"To whom he said, Dost thou seek for a tribe or family, or an hired man to go with thy son? Then Tobit said unto him, I would know, brother, thy kindred and name.","searchKeywords":["whom","said","dost","thou","seek","for","tribe","family","hired","man","with","thy","son","then","tobit","unto","him","would","know","brother","kindred","and","name"]},{"verseId":"brenton_tobit_5_12","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":12,"text":"Then he said, I am Azarias, of Ananias the great, and of thy brethren.","searchKeywords":["then","said","azarias","ananias","the","great","and","thy","brethren"]},{"verseId":"brenton_tobit_5_13","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":13,"text":"Then Tobit said, Thou art welcome, brother; be not now angry with me, because I have enquired to know thy tribe and thy family; for thou art my brother, of an honest and good stock: for I know Ananias and Jonathas, sons of that great Samaias, as we went together to Jerusalem to worship, and offered the firstborn, and the tenths of the fruits; and they were not seduced with the error of our brethren: my brother, thou art of a good stock.","searchKeywords":["then","tobit","said","thou","art","welcome","brother","not","now","angry","with","because","have","enquired","know","thy","tribe","and","family","for","honest","good","stock","ananias","jonathas","sons","that","great","samaias","went","together","jerusalem","worship","offered","the","firstborn","tenths","fruits","they","were","seduced","error","our","brethren"]},{"verseId":"brenton_tobit_5_14","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":14,"text":"But tell me, what wages shall I give thee? a drachm a day, and things necessary, as to mine own son?","searchKeywords":["but","tell","what","wages","shall","give","thee","drachm","day","and","things","necessary","mine","own","son"]},{"verseId":"brenton_tobit_5_15","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":15,"text":"Yea, moreover, if ye return safe, I will add something to thy wages.","searchKeywords":["yea","moreover","return","safe","will","add","something","thy","wages"]},{"verseId":"brenton_tobit_5_16","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":16,"text":"So they were well pleased. Then said he to Tobias, Prepare thyself for the journey, and God send you a good journey. And when his son had prepared all things for the journey, his father said, Go thou with this man, and God, which dwelleth in heaven, prosper your journey, and the angel of God keep you company. So they went forth both, and the young man's dog with them.","searchKeywords":["they","were","well","pleased","then","said","tobias","prepare","thyself","for","the","journey","and","god","send","you","good","when","his","son","had","prepared","all","things","father","thou","with","this","man","which","dwelleth","heaven","prosper","your","angel","keep","company","went","forth","both","young","dog","them"]},{"verseId":"brenton_tobit_5_17","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":17,"text":"But Anna his mother wept, and said to Tobit, Why hast thou sent away our son? is he not the staff of our hand, in going in and out before us?","searchKeywords":["but","anna","his","mother","wept","and","said","tobit","why","hast","thou","sent","away","our","son","not","the","staff","hand","going","out","before"]},{"verseId":"brenton_tobit_5_18","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":18,"text":"Be not greedy to add money to money: but let it be as refuse in respect of our child.","searchKeywords":["not","greedy","add","money","but","let","refuse","respect","our","child"]},{"verseId":"brenton_tobit_5_19","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":19,"text":"For that which the Lord hath given us to live with doth suffice us.","searchKeywords":["for","that","which","the","lord","hath","given","live","with","doth","suffice"]},{"verseId":"brenton_tobit_5_20","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":20,"text":"Then said Tobit to her, Take no care, my sister; he shall return in safety, and thine eyes shall see him.","searchKeywords":["then","said","tobit","her","take","care","sister","shall","return","safety","and","thine","eyes","see","him"]},{"verseId":"brenton_tobit_5_21","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":21,"text":"For the good angel will keep him company, and his journey shall be prosperous, and he shall return safe.","searchKeywords":["for","the","good","angel","will","keep","him","company","and","his","journey","shall","prosperous","return","safe"]},{"verseId":"brenton_tobit_5_22","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":5,"verse":22,"text":"Then she made an end of weeping.","searchKeywords":["then","she","made","end","weeping"]}]