[{"verseId":"brenton_tobit_9_1","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":9,"verse":1,"text":"Then Tobias called Raphael, and said unto him,","searchKeywords":["then","tobias","called","raphael","and","said","unto","him"]},{"verseId":"brenton_tobit_9_2","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":9,"verse":2,"text":"Brother Azarias, take with thee a servant, and two camels, and go to Rages of Media to Gabael, and bring me the money, and bring him to the wedding.","searchKeywords":["brother","azarias","take","with","thee","servant","and","two","camels","rages","media","gabael","bring","the","money","him","wedding"]},{"verseId":"brenton_tobit_9_3","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":9,"verse":3,"text":"For Raguel hath sworn that I shall not depart.","searchKeywords":["for","raguel","hath","sworn","that","shall","not","depart"]},{"verseId":"brenton_tobit_9_4","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":9,"verse":4,"text":"But my father counteth the days; and if I tarry long, he will be very sorry.","searchKeywords":["but","father","counteth","the","days","and","tarry","long","will","very","sorry"]},{"verseId":"brenton_tobit_9_5","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":9,"verse":5,"text":"So Raphael went out, and lodged with Gabael, and gave him the handwriting: who brought forth bags which were sealed up, and gave them to him.","searchKeywords":["raphael","went","out","and","lodged","with","gabael","gave","him","the","handwriting","who","brought","forth","bags","which","were","sealed","them"]},{"verseId":"brenton_tobit_9_6","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":9,"verse":6,"text":"And early in the morning they went forth both together, and came to the wedding: and Tobias blessed his wife.","searchKeywords":["and","early","the","morning","they","went","forth","both","together","came","wedding","tobias","blessed","his","wife"]}]