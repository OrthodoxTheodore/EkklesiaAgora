[{"verseId":"brenton_tobit_8_1","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":1,"text":"And when they had supped, they brought Tobias in unto her.","searchKeywords":["and","when","they","had","supped","brought","tobias","unto","her"]},{"verseId":"brenton_tobit_8_2","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":2,"text":"And as he went, he remembered the words of Raphael, and took the ashes of the perfumes, and put the heart and the liver of the fish thereupon, and made a smoke .","searchKeywords":["and","went","remembered","the","words","raphael","took","ashes","perfumes","put","heart","liver","fish","thereupon","made","smoke"]},{"verseId":"brenton_tobit_8_3","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":3,"text":"The which smell when the evil spirit had smelled, he fled into the utmost parts of Egypt, and the angel bound him.","searchKeywords":["the","which","smell","when","evil","spirit","had","smelled","fled","into","utmost","parts","egypt","and","angel","bound","him"]},{"verseId":"brenton_tobit_8_4","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":4,"text":"And after that they were both shut in together, Tobias rose out of the bed, and said, Sister, arise, and let us pray that God would have pity on us.","searchKeywords":["and","after","that","they","were","both","shut","together","tobias","rose","out","the","bed","said","sister","arise","let","pray","god","would","have","pity"]},{"verseId":"brenton_tobit_8_5","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":5,"text":"Then began Tobias to say, Blessed art thou, O God of our fathers, and blessed thy holy and glorious name for ever; let the heavens bless thee, and all thy creatures.","searchKeywords":["then","began","tobias","say","blessed","art","thou","god","our","fathers","and","thy","holy","glorious","name","for","ever","let","the","heavens","bless","thee","all","creatures"]},{"verseId":"brenton_tobit_8_6","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":6,"text":"Thou madest Adam, and gavest him Eve his wife for an helper and stay: of them came mankind: thou hast said, It is not good that man should be alone; let us make unto him an aid like unto himself.","searchKeywords":["thou","madest","adam","and","gavest","him","eve","his","wife","for","helper","stay","them","came","mankind","hast","said","not","good","that","man","should","alone","let","make","unto","aid","like","himself"]},{"verseId":"brenton_tobit_8_7","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":7,"text":"And now, O Lord, I take not this my sister for lust, but uprightly: mercifully ordain that we may become aged together.","searchKeywords":["and","now","lord","take","not","this","sister","for","lust","but","uprightly","mercifully","ordain","that","may","become","aged","together"]},{"verseId":"brenton_tobit_8_8","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":8,"text":"And she said with him, Amen.","searchKeywords":["and","she","said","with","him","amen"]},{"verseId":"brenton_tobit_8_9","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":9,"text":"So they slept both that night. And Raguel arose, and went and made a grave,","searchKeywords":["they","slept","both","that","night","and","raguel","arose","went","made","grave"]},{"verseId":"brenton_tobit_8_10","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":10,"text":"saying, lest he also be dead.","searchKeywords":["saying","lest","also","dead"]},{"verseId":"brenton_tobit_8_11","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":11,"text":"But when Raguel was come into his house,","searchKeywords":["but","when","raguel","was","come","into","his","house"]},{"verseId":"brenton_tobit_8_12","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":12,"text":"he said unto his wife Edna, Send one of the maids, and let her see whether he be alive: if not, that we may bury him, and no man know it.","searchKeywords":["said","unto","his","wife","edna","send","one","the","maids","and","let","her","see","whether","alive","not","that","may","bury","him","man","know"]},{"verseId":"brenton_tobit_8_13","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":13,"text":"So the maid opened the door, and went in, and found them both asleep,","searchKeywords":["the","maid","opened","door","and","went","found","them","both","asleep"]},{"verseId":"brenton_tobit_8_14","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":14,"text":"and came forth, and told them that he was alive.","searchKeywords":["and","came","forth","told","them","that","was","alive"]},{"verseId":"brenton_tobit_8_15","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":15,"text":"Then Raguel praised God, and said, O God, thou art worthy to be praised with all pure and holy praise: therefore let thy saints praise thee with all thy creatures: and let all thine angels and thine elect praise thee for ever.","searchKeywords":["then","raguel","praised","god","and","said","thou","art","worthy","with","all","pure","holy","praise","therefore","let","thy","saints","thee","creatures","thine","angels","elect","for","ever"]},{"verseId":"brenton_tobit_8_16","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":16,"text":"Thou art to be praised, for thou hast made me joyful; and that is not come to me which I suspected; but thou hast dealt with us according to thy great mercy.","searchKeywords":["thou","art","praised","for","hast","made","joyful","and","that","not","come","which","suspected","but","dealt","with","according","thy","great","mercy"]},{"verseId":"brenton_tobit_8_17","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":17,"text":"Thou art to be praised, because thou hast had mercy of two that were the only begotten children of their fathers: grant them mercy, O Lord, and finish their life in health with joy and mercy.","searchKeywords":["thou","art","praised","because","hast","had","mercy","two","that","were","the","only","begotten","children","their","fathers","grant","them","lord","and","finish","life","health","with","joy"]},{"verseId":"brenton_tobit_8_18","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":18,"text":"Then Raguel bade his servants to fill the grave.","searchKeywords":["then","raguel","bade","his","servants","fill","the","grave"]},{"verseId":"brenton_tobit_8_19","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":19,"text":"And he kept the wedding feast fourteen days.","searchKeywords":["and","kept","the","wedding","feast","fourteen","days"]},{"verseId":"brenton_tobit_8_20","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":20,"text":"For before the days of the marriage were finished, Raguel had said unto him by an oath, that he should not depart till the fourteen days of the marriage were expired;","searchKeywords":["for","before","the","days","marriage","were","finished","raguel","had","said","unto","him","oath","that","should","not","depart","till","fourteen","expired"]},{"verseId":"brenton_tobit_8_21","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":8,"verse":21,"text":"and then he should take the half of his goods, and go in safety to his father; and should have the rest when I and my wife be dead.","searchKeywords":["and","then","should","take","the","half","his","goods","safety","father","have","rest","when","wife","dead"]}]