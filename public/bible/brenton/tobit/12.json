[{"verseId":"brenton_tobit_12_1","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":1,"text":"Then Tobit called his son Tobias, and said unto him, My son, see that the man have his wages, which went with thee, and thou must give him more.","searchKeywords":["then","tobit","called","his","son","tobias","and","said","unto","him","see","that","the","man","have","wages","which","went","with","thee","thou","must","give","more"]},{"verseId":"brenton_tobit_12_2","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":2,"text":"And Tobias said unto him, O father, it is no harm to me to give him half of those things which I have brought:","searchKeywords":["and","tobias","said","unto","him","father","harm","give","half","those","things","which","have","brought"]},{"verseId":"brenton_tobit_12_3","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":3,"text":"for he hath brought me again to thee in safety, and made whole my wife, and brought me the money, and likewise healed thee.","searchKeywords":["for","hath","brought","again","thee","safety","and","made","whole","wife","the","money","likewise","healed"]},{"verseId":"brenton_tobit_12_4","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":4,"text":"Then the old man said, It is due unto him.","searchKeywords":["then","the","old","man","said","due","unto","him"]},{"verseId":"brenton_tobit_12_5","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":5,"text":"So he called the angel, and he said unto him, Take half of all that ye have brought, and go away in safety.","searchKeywords":["called","the","angel","and","said","unto","him","take","half","all","that","have","brought","away","safety"]},{"verseId":"brenton_tobit_12_6","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":6,"text":"Then he took them both apart, and said unto them, Bless God, praise him, and magnify him, and praise him for the things which he hath done unto you in the sight of all that live. It is good to praise God, and exalt his name, and honourably to shew forth the works of God; therefore be not slack to praise him.","searchKeywords":["then","took","them","both","apart","and","said","unto","bless","god","praise","him","magnify","for","the","things","which","hath","done","you","sight","all","that","live","good","exalt","his","name","honourably","shew","forth","works","therefore","not","slack"]},{"verseId":"brenton_tobit_12_7","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":7,"text":"It is good to keep close the secret of a king, but it is honourable to reveal the works of God. Do that which is good, and no evil shall touch you.","searchKeywords":["good","keep","close","the","secret","king","but","honourable","reveal","works","god","that","which","and","evil","shall","touch","you"]},{"verseId":"brenton_tobit_12_8","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":8,"text":"Prayer is good with fasting and alms and righteousness. A little with righteousness is better than much with unrighteousness. It is better to give alms than to lay up gold:","searchKeywords":["prayer","good","with","fasting","and","alms","righteousness","little","better","than","much","unrighteousness","give","lay","gold"]},{"verseId":"brenton_tobit_12_9","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":9,"text":"for alms doth deliver from death, and shall purge away all sin. Those that exercise alms and righteousness shall be filled with life:","searchKeywords":["for","alms","doth","deliver","from","death","and","shall","purge","away","all","sin","those","that","exercise","righteousness","filled","with","life"]},{"verseId":"brenton_tobit_12_10","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":10,"text":"but they that sin are enemies to their own life.","searchKeywords":["but","they","that","sin","are","enemies","their","own","life"]},{"verseId":"brenton_tobit_12_11","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":11,"text":"Surely I will keep close nothing from you. For I said, It was good to keep close the secret of a king, but that it was honourable to reveal the works of God.","searchKeywords":["surely","will","keep","close","nothing","from","you","for","said","was","good","the","secret","king","but","that","honourable","reveal","works","god"]},{"verseId":"brenton_tobit_12_12","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":12,"text":"Now therefore, when thou didst pray, and Sara thy daughter in law, I did bring the remembrance of your prayers before the Holy One: and when thou didst bury the dead, I was with thee likewise.","searchKeywords":["now","therefore","when","thou","didst","pray","and","sara","thy","daughter","law","did","bring","the","remembrance","your","prayers","before","holy","one","bury","dead","was","with","thee","likewise"]},{"verseId":"brenton_tobit_12_13","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":13,"text":"And when thou didst not delay to rise up, and leave thy dinner, to go and cover the dead, thy good deed was not hid from me: but I was with thee.","searchKeywords":["and","when","thou","didst","not","delay","rise","leave","thy","dinner","cover","the","dead","good","deed","was","hid","from","but","with","thee"]},{"verseId":"brenton_tobit_12_14","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":14,"text":"And now God hath sent me to heal thee and Sara thy daughter in law.","searchKeywords":["and","now","god","hath","sent","heal","thee","sara","thy","daughter","law"]},{"verseId":"brenton_tobit_12_15","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":15,"text":"I am Raphael, one of the seven holy angels, which present the prayers of the saints, and which go in and out before the glory of the Holy One.","searchKeywords":["raphael","one","the","seven","holy","angels","which","present","prayers","saints","and","out","before","glory"]},{"verseId":"brenton_tobit_12_16","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":16,"text":"Then they were both troubled, and fell upon their faces: for they feared.","searchKeywords":["then","they","were","both","troubled","and","fell","upon","their","faces","for","feared"]},{"verseId":"brenton_tobit_12_17","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":17,"text":"But he said unto them, Fear not, for it shall go well with you; praise God therefore.","searchKeywords":["but","said","unto","them","fear","not","for","shall","well","with","you","praise","god","therefore"]},{"verseId":"brenton_tobit_12_18","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":18,"text":"For not of any favour of mine, but by the will of our God I came; wherefore praise him for ever.","searchKeywords":["for","not","any","favour","mine","but","the","will","our","god","came","wherefore","praise","him","ever"]},{"verseId":"brenton_tobit_12_19","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":19,"text":"All these days I did appear unto you; but I did neither eat nor drink, but ye did see a vision.","searchKeywords":["all","these","days","did","appear","unto","you","but","neither","eat","nor","drink","see","vision"]},{"verseId":"brenton_tobit_12_20","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":20,"text":"Now therefore give God thanks: for I go up to him that sent me; but write all things which are done in a book.","searchKeywords":["now","therefore","give","god","thanks","for","him","that","sent","but","write","all","things","which","are","done","book"]},{"verseId":"brenton_tobit_12_21","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":21,"text":"And when they arose, they saw him no more.","searchKeywords":["and","when","they","arose","saw","him","more"]},{"verseId":"brenton_tobit_12_22","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":12,"verse":22,"text":"Then they confessed the great and wonderful works of God, and how the angel of the Lord had appeared unto them.","searchKeywords":["then","they","confessed","the","great","and","wonderful","works","god","how","angel","lord","had","appeared","unto","them"]}]