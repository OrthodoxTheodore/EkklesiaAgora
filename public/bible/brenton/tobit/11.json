[{"verseId":"brenton_tobit_11_1","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":1,"text":"After these things Tobias went his way, praising God that he had given him a prosperous journey, and blessed Raguel and Edna his wife, and went on his way till they drew near unto Nineve.","searchKeywords":["after","these","things","tobias","went","his","way","praising","god","that","had","given","him","prosperous","journey","and","blessed","raguel","edna","wife","till","they","drew","near","unto","nineve"]},{"verseId":"brenton_tobit_11_2","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":2,"text":"Then Raphael said to Tobias, Dost thou not know, brother, how thou didst leave thy father?","searchKeywords":["then","raphael","said","tobias","dost","thou","not","know","brother","how","didst","leave","thy","father"]},{"verseId":"brenton_tobit_11_3","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":3,"text":"let us haste before thy wife, and prepare the house;","searchKeywords":["let","haste","before","thy","wife","and","prepare","the","house"]},{"verseId":"brenton_tobit_11_4","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":4,"text":"and take in thine hand the gall of the fish. So they went their way, and the dog went after them.","searchKeywords":["and","take","thine","hand","the","gall","fish","they","went","their","way","dog","after","them"]},{"verseId":"brenton_tobit_11_5","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":5,"text":"Now Anna sat looking about toward the way for her son.","searchKeywords":["now","anna","sat","looking","about","toward","the","way","for","her","son"]},{"verseId":"brenton_tobit_11_6","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":6,"text":"And when she espied him coming, she said to his father, Behold, thy son cometh, and the man that went with him.","searchKeywords":["and","when","she","espied","him","coming","said","his","father","behold","thy","son","cometh","the","man","that","went","with"]},{"verseId":"brenton_tobit_11_7","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":7,"text":"Then said Raphael, I know, Tobias, that thy father will open his eyes.","searchKeywords":["then","said","raphael","know","tobias","that","thy","father","will","open","his","eyes"]},{"verseId":"brenton_tobit_11_8","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":8,"text":"Therefore anoint thou his eyes with the gall, and being pricked therewith, he shall rub, and the whiteness shall fall away, and he shall see thee.","searchKeywords":["therefore","anoint","thou","his","eyes","with","the","gall","and","being","pricked","therewith","shall","rub","whiteness","fall","away","see","thee"]},{"verseId":"brenton_tobit_11_9","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":9,"text":"Then Anna ran forth, and fell upon the neck of her son, and said unto him, Seeing I have seen thee, my son, from henceforth I am content to die. And they wept both.","searchKeywords":["then","anna","ran","forth","and","fell","upon","the","neck","her","son","said","unto","him","seeing","have","seen","thee","from","henceforth","content","die","they","wept","both"]},{"verseId":"brenton_tobit_11_10","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":10,"text":"Tobit also went forth toward the door, and stumbled: but his son ran unto him,","searchKeywords":["tobit","also","went","forth","toward","the","door","and","stumbled","but","his","son","ran","unto","him"]},{"verseId":"brenton_tobit_11_11","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":11,"text":"and took hold of his father: and he strake of the gall on his father's eyes, saying, Be of good hope, my father.","searchKeywords":["and","took","hold","his","father","strake","the","gall","eyes","saying","good","hope"]},{"verseId":"brenton_tobit_11_12","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":12,"text":"And when his eyes began to smart, he rubbed them;","searchKeywords":["and","when","his","eyes","began","smart","rubbed","them"]},{"verseId":"brenton_tobit_11_13","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":13,"text":"and the whiteness pilled away from the corners of his eyes: and when he saw his son, he fell upon his neck.","searchKeywords":["and","the","whiteness","pilled","away","from","corners","his","eyes","when","saw","son","fell","upon","neck"]},{"verseId":"brenton_tobit_11_14","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":14,"text":"And he wept, and said, Blessed art thou, O God, and blessed is thy name for ever; and blessed are all thine holy angels:","searchKeywords":["and","wept","said","blessed","art","thou","god","thy","name","for","ever","are","all","thine","holy","angels"]},{"verseId":"brenton_tobit_11_15","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":15,"text":"for thou hast scourged, and hast taken pity : for, behold, I see my son Tobias. And his son went in rejoicing, and told his father the great things that had happened to him in Media.","searchKeywords":["for","thou","hast","scourged","and","taken","pity","behold","see","son","tobias","his","went","rejoicing","told","father","the","great","things","that","had","happened","him","media"]},{"verseId":"brenton_tobit_11_16","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":16,"text":"Then Tobit went out to meet his daughter in law at the gate of Nineve, rejoicing, and praising God: and they which saw him go marvelled, because he had received his sight.","searchKeywords":["then","tobit","went","out","meet","his","daughter","law","the","gate","nineve","rejoicing","and","praising","god","they","which","saw","him","marvelled","because","had","received","sight"]},{"verseId":"brenton_tobit_11_17","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":17,"text":"But Tobit gave thanks before them, because God had mercy on him. And when he came near to Sara his daughter in law, he blessed her, saying, Thou art welcome, daughter: God be blessed, which hath brought thee unto us, and thy father and thy mother. And there was joy among all his brethren which were at Nineve.","searchKeywords":["but","tobit","gave","thanks","before","them","because","god","had","mercy","him","and","when","came","near","sara","his","daughter","law","blessed","her","saying","thou","art","welcome","which","hath","brought","thee","unto","thy","father","mother","there","was","joy","among","all","brethren","were","nineve"]},{"verseId":"brenton_tobit_11_18","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":18,"text":"And Achiacharus, and Nasbas his brother's son, came:","searchKeywords":["and","achiacharus","nasbas","his","brother","son","came"]},{"verseId":"brenton_tobit_11_19","translationId":"brenton","testament":"OT","bookIndex":18,"bookName":"Tobit","bookAbbrev":"tobit","chapter":11,"verse":19,"text":"and Tobias' wedding was kept seven days with great joy.","searchKeywords":["and","tobias","wedding","was","kept","seven","days","with","great","joy"]}]