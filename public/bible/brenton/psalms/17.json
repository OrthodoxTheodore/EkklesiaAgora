[{"verseId":"brenton_psalms_17_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":1,"text":"For the end, of David the servant of the Lord; which he spoke to the Lord, the words of this Song, in the day in which the Lord delivered him out of the hand of all his enemies, and out of the hand of Saul: and he said:","searchKeywords":["for","the","end","david","servant","lord","which","spoke","words","this","song","day","delivered","him","out","hand","all","his","enemies","and","saul","said"]},{"verseId":"brenton_psalms_17_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":2,"text":"I will love thee, O Lord, my strength.","searchKeywords":["will","love","thee","lord","strength"]},{"verseId":"brenton_psalms_17_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":3,"text":"The Lord is my firm support, and my refuge, and my deliverer; my God is my helper, I will hope in him; my defender, and the horn of my salvation, and my helper.","searchKeywords":["the","lord","firm","support","and","refuge","deliverer","god","helper","will","hope","him","defender","horn","salvation"]},{"verseId":"brenton_psalms_17_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":4,"text":"I will call upon the Lord with praises, and I shall be saved from mine enemies.","searchKeywords":["will","call","upon","the","lord","with","praises","and","shall","saved","from","mine","enemies"]},{"verseId":"brenton_psalms_17_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":5,"text":"The pangs of death compassed me, and the torrents of ungodliness troubled me exceedingly.","searchKeywords":["the","pangs","death","compassed","and","torrents","ungodliness","troubled","exceedingly"]},{"verseId":"brenton_psalms_17_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":6,"text":"The pangs of hell came round about me: the snares of death prevented me.","searchKeywords":["the","pangs","hell","came","round","about","snares","death","prevented"]},{"verseId":"brenton_psalms_17_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":7,"text":"And when I was afflicted I called upon the Lord, and cried to my God: he heard my voice out of his holy temple, and my cry shall enter before him, into his ears.","searchKeywords":["and","when","was","afflicted","called","upon","the","lord","cried","god","heard","voice","out","his","holy","temple","cry","shall","enter","before","him","into","ears"]},{"verseId":"brenton_psalms_17_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":8,"text":"Then the earth shook and quaked, and the foundations of the mountains were disturbed, and were shaken, because God was angry with them.","searchKeywords":["then","the","earth","shook","and","quaked","foundations","mountains","were","disturbed","shaken","because","god","was","angry","with","them"]},{"verseId":"brenton_psalms_17_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":9,"text":"There went up a smoke in his wrath, and fire burst into a flame at his presence: coals were kindled at it.","searchKeywords":["there","went","smoke","his","wrath","and","fire","burst","into","flame","presence","coals","were","kindled"]},{"verseId":"brenton_psalms_17_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":10,"text":"And he bowed the heaven, and came down: and thick darkness was under his feet.","searchKeywords":["and","bowed","the","heaven","came","down","thick","darkness","was","under","his","feet"]},{"verseId":"brenton_psalms_17_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":11,"text":"And he mounted on cherubs and flew: he flew on the wings of winds.","searchKeywords":["and","mounted","cherubs","flew","the","wings","winds"]},{"verseId":"brenton_psalms_17_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":12,"text":"And he made darkness his secret place: round about him was his tabernacle, dark water in the clouds of the air.","searchKeywords":["and","made","darkness","his","secret","place","round","about","him","was","tabernacle","dark","water","the","clouds","air"]},{"verseId":"brenton_psalms_17_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":13,"text":"At the brightness before him the clouds passed, hail and coals of fire.","searchKeywords":["the","brightness","before","him","clouds","passed","hail","and","coals","fire"]},{"verseId":"brenton_psalms_17_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":14,"text":"The Lord also thundered from heaven, and the Highest uttered his voice.","searchKeywords":["the","lord","also","thundered","from","heaven","and","highest","uttered","his","voice"]},{"verseId":"brenton_psalms_17_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":15,"text":"And he sent forth weapons, and scattered them; and multiplied lightnings, and routed them.","searchKeywords":["and","sent","forth","weapons","scattered","them","multiplied","lightnings","routed"]},{"verseId":"brenton_psalms_17_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":16,"text":"And the springs of waters appeared, and the foundations of the world were exposed, at thy rebuke, O Lord, at the blasting of the breath of thy wrath.","searchKeywords":["and","the","springs","waters","appeared","foundations","world","were","exposed","thy","rebuke","lord","blasting","breath","wrath"]},{"verseId":"brenton_psalms_17_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":17,"text":"He sent from on high and took me, he drew me to himself out of many waters.","searchKeywords":["sent","from","high","and","took","drew","himself","out","many","waters"]},{"verseId":"brenton_psalms_17_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":18,"text":"He will deliver me from my mighty enemies, and from them that hate me; for they are stronger than I.","searchKeywords":["will","deliver","from","mighty","enemies","and","them","that","hate","for","they","are","stronger","than"]},{"verseId":"brenton_psalms_17_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":19,"text":"They prevented me in the day of mine affliction: but the Lord was my stay against .","searchKeywords":["they","prevented","the","day","mine","affliction","but","lord","was","stay","against"]},{"verseId":"brenton_psalms_17_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":20,"text":"And he brought me out into a wide place: he will deliver me, because he has pleasure in me.","searchKeywords":["and","brought","out","into","wide","place","will","deliver","because","has","pleasure"]},{"verseId":"brenton_psalms_17_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":21,"text":"And the Lord will recompense me according to my righteousness; even according to the purity of my hands will he recompense me.","searchKeywords":["and","the","lord","will","recompense","according","righteousness","even","purity","hands"]},{"verseId":"brenton_psalms_17_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":22,"text":"For I have kept the ways of the Lord and have not wickedly departed from my God.","searchKeywords":["for","have","kept","the","ways","lord","and","not","wickedly","departed","from","god"]},{"verseId":"brenton_psalms_17_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":23,"text":"For all his judgments were before me, and his ordinances departed not from me.","searchKeywords":["for","all","his","judgments","were","before","and","ordinances","departed","not","from"]},{"verseId":"brenton_psalms_17_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":24,"text":"And I shall be blameless with him, and shall keep myself from mine iniquity.","searchKeywords":["and","shall","blameless","with","him","keep","myself","from","mine","iniquity"]},{"verseId":"brenton_psalms_17_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":25,"text":"And the Lord shall recompense me according to my righteousness, and according to the purity of my hands before his eyes.","searchKeywords":["and","the","lord","shall","recompense","according","righteousness","purity","hands","before","his","eyes"]},{"verseId":"brenton_psalms_17_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":26,"text":"With the holy thou wilt be holy; and with the innocent man thou wilt be innocent.","searchKeywords":["with","the","holy","thou","wilt","and","innocent","man"]},{"verseId":"brenton_psalms_17_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":27,"text":"And with the excellent thou wilt be excellent; and with the perverse thou wilt shew frowardness.","searchKeywords":["and","with","the","excellent","thou","wilt","perverse","shew","frowardness"]},{"verseId":"brenton_psalms_17_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":28,"text":"For thou wilt save the lowly people, and wilt humble the eyes of the proud.","searchKeywords":["for","thou","wilt","save","the","lowly","people","and","humble","eyes","proud"]},{"verseId":"brenton_psalms_17_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":29,"text":"For thou, O Lord, wilt light my lamp: my God, thou wilt lighten my darkness.","searchKeywords":["for","thou","lord","wilt","light","lamp","god","lighten","darkness"]},{"verseId":"brenton_psalms_17_30","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":30,"text":"For by thee shall I be delivered from a troop; and by my God I will pass over a wall.","searchKeywords":["for","thee","shall","delivered","from","troop","and","god","will","pass","over","wall"]},{"verseId":"brenton_psalms_17_31","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":31,"text":"my God, his way is perfect: the oracles of the Lord are tried in the fire; he is a protector of all them that hope in him.","searchKeywords":["god","his","way","perfect","the","oracles","lord","are","tried","fire","protector","all","them","that","hope","him"]},{"verseId":"brenton_psalms_17_32","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":32,"text":"For who is God but the Lord? and who is a God except our God?","searchKeywords":["for","who","god","but","the","lord","and","except","our"]},{"verseId":"brenton_psalms_17_33","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":33,"text":"God that girds me with strength, and has made my way blameless:","searchKeywords":["god","that","girds","with","strength","and","has","made","way","blameless"]},{"verseId":"brenton_psalms_17_34","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":34,"text":"who strengthens my feet as hart's feet, and sets me upon high places.","searchKeywords":["who","strengthens","feet","hart","and","sets","upon","high","places"]},{"verseId":"brenton_psalms_17_35","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":35,"text":"He instructs my hands for war; and thou hast made my arms a brazen bow.","searchKeywords":["instructs","hands","for","war","and","thou","hast","made","arms","brazen","bow"]},{"verseId":"brenton_psalms_17_36","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":36,"text":"And thou hast made me secure in my salvation: and thy right hand has helped me, and thy correction has upheld me to the end; yea, thy correction itself shall instruct me.","searchKeywords":["and","thou","hast","made","secure","salvation","thy","right","hand","has","helped","correction","upheld","the","end","yea","itself","shall","instruct"]},{"verseId":"brenton_psalms_17_37","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":37,"text":"Thou hast made room for my goings under me, and my footsteps did not fail.","searchKeywords":["thou","hast","made","room","for","goings","under","and","footsteps","did","not","fail"]},{"verseId":"brenton_psalms_17_38","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":38,"text":"I will pursue mine enemies, and overtake them; and I will not turn back until they are consumed.","searchKeywords":["will","pursue","mine","enemies","and","overtake","them","not","turn","back","until","they","are","consumed"]},{"verseId":"brenton_psalms_17_39","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":39,"text":"I will dash them to pieces and they shall not be able to stand: they shall fall under my feet.","searchKeywords":["will","dash","them","pieces","and","they","shall","not","able","stand","fall","under","feet"]},{"verseId":"brenton_psalms_17_40","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":40,"text":"For thou hast girded me with strength for war: thou hast beaten down under me all that rose up against me.","searchKeywords":["for","thou","hast","girded","with","strength","war","beaten","down","under","all","that","rose","against"]},{"verseId":"brenton_psalms_17_41","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":41,"text":"And thou hast made mine enemies turn their backs before me; and thou hast destroyed them that hated me.","searchKeywords":["and","thou","hast","made","mine","enemies","turn","their","backs","before","destroyed","them","that","hated"]},{"verseId":"brenton_psalms_17_42","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":42,"text":"They cried, but there was no deliverer: to the Lord, but he hearkened not to them.","searchKeywords":["they","cried","but","there","was","deliverer","the","lord","hearkened","not","them"]},{"verseId":"brenton_psalms_17_43","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":43,"text":"I will grind them as the mud of the streets: and I will beat them small as dust before the wind.","searchKeywords":["will","grind","them","the","mud","streets","and","beat","small","dust","before","wind"]},{"verseId":"brenton_psalms_17_44","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":44,"text":"Deliver me from the gainsayings of the people: thou shalt make me head of the Gentiles: a people whom I knew not served me,","searchKeywords":["deliver","from","the","gainsayings","people","thou","shalt","make","head","gentiles","whom","knew","not","served"]},{"verseId":"brenton_psalms_17_45","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":45,"text":"at the hearing of the ear they obeyed me: the strange children lied to me.","searchKeywords":["the","hearing","ear","they","obeyed","strange","children","lied"]},{"verseId":"brenton_psalms_17_46","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":46,"text":"The strange children waxed old, and fell away from their paths through lameness.","searchKeywords":["the","strange","children","waxed","old","and","fell","away","from","their","paths","through","lameness"]},{"verseId":"brenton_psalms_17_47","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":47,"text":"The Lord lives; and blessed my God; and let the God of my salvation be exalted.","searchKeywords":["the","lord","lives","and","blessed","god","let","salvation","exalted"]},{"verseId":"brenton_psalms_17_48","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":48,"text":"God that avenges me, and has subdued the nations under me;","searchKeywords":["god","that","avenges","and","has","subdued","the","nations","under"]},{"verseId":"brenton_psalms_17_49","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":49,"text":"my deliverer from angry enemies: thou shalt set me on high above them that rise up against me: thou shalt deliver me from the unrighteous man.","searchKeywords":["deliverer","from","angry","enemies","thou","shalt","set","high","above","them","that","rise","against","deliver","the","unrighteous","man"]},{"verseId":"brenton_psalms_17_50","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":50,"text":"Therefore will I confess to thee, O Lord, among the Gentiles, and sing to thy name.","searchKeywords":["therefore","will","confess","thee","lord","among","the","gentiles","and","sing","thy","name"]},{"verseId":"brenton_psalms_17_51","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":17,"verse":51,"text":"magnifies the deliverances of his king; and deals mercifully with David his anointed, and his seed, for ever.","searchKeywords":["magnifies","the","deliverances","his","king","and","deals","mercifully","with","david","anointed","seed","for","ever"]}]