[{"verseId":"brenton_psalms_74_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":74,"verse":1,"text":"For the end, Destroy not, a Psalm of a Song for Asaph.","searchKeywords":["for","the","end","destroy","not","psalm","song","asaph"]},{"verseId":"brenton_psalms_74_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":74,"verse":2,"text":"We will give thanks to thee, O God, we will give thanks, and call upon thy name: I will declare all thy wonderful works.","searchKeywords":["will","give","thanks","thee","god","and","call","upon","thy","name","declare","all","wonderful","works"]},{"verseId":"brenton_psalms_74_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":74,"verse":3,"text":"When I shall take a set time, I will judge righteously.","searchKeywords":["when","shall","take","set","time","will","judge","righteously"]},{"verseId":"brenton_psalms_74_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":74,"verse":4,"text":"The earth is dissolved, and all that dwell in it: I have strengthened its pillars. Pause.","searchKeywords":["the","earth","dissolved","and","all","that","dwell","have","strengthened","its","pillars","pause"]},{"verseId":"brenton_psalms_74_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":74,"verse":5,"text":"I said unto the transgressors, Do not transgress; and to the sinners, Lift not up the horn.","searchKeywords":["said","unto","the","transgressors","not","transgress","and","sinners","lift","horn"]},{"verseId":"brenton_psalms_74_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":74,"verse":6,"text":"Lift not up your horn on high; speak not unrighteousness against God.","searchKeywords":["lift","not","your","horn","high","speak","unrighteousness","against","god"]},{"verseId":"brenton_psalms_74_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":74,"verse":7,"text":"For neither from the east, nor from the west, nor from the desert mountains.","searchKeywords":["for","neither","from","the","east","nor","west","desert","mountains"]},{"verseId":"brenton_psalms_74_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":74,"verse":8,"text":"For God is the judge; he puts down one, and raises up another.","searchKeywords":["for","god","the","judge","puts","down","one","and","raises","another"]},{"verseId":"brenton_psalms_74_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":74,"verse":9,"text":"For a cup in the hand of the Lord, full of unmingled wine; and he has turned from side to side, but its dregs have not been wholly poured out; all the sinners of the earth shall drink .","searchKeywords":["for","cup","the","hand","lord","full","unmingled","wine","and","has","turned","from","side","but","its","dregs","have","not","been","wholly","poured","out","all","sinners","earth","shall","drink"]},{"verseId":"brenton_psalms_74_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":74,"verse":10,"text":"But I will exult for ever: I will sing praises to the God of Jacob.","searchKeywords":["but","will","exult","for","ever","sing","praises","the","god","jacob"]},{"verseId":"brenton_psalms_74_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":74,"verse":11,"text":"And I will break all the horns of sinners; but the horns of the righteous one shall be exalted.","searchKeywords":["and","will","break","all","the","horns","sinners","but","righteous","one","shall","exalted"]}]