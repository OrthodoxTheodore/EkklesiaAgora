[{"verseId":"brenton_psalms_73_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":1,"text":"of instruction for Asaph. , O God, for ever? is thy wrath kindled against the sheep of thy pasture?","searchKeywords":["instruction","for","asaph","god","ever","thy","wrath","kindled","against","the","sheep","pasture"]},{"verseId":"brenton_psalms_73_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":2,"text":"Remember thy congregation which thou hast purchased from the beginning; thou didst ransom the rod of thine inheritance; this mount Sion wherein thou hast dwelt.","searchKeywords":["remember","thy","congregation","which","thou","hast","purchased","from","the","beginning","didst","ransom","rod","thine","inheritance","this","mount","sion","wherein","dwelt"]},{"verseId":"brenton_psalms_73_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":3,"text":"Lift up thine hands against their pride continually; all that the enemy has done wickedly in thy holy places.","searchKeywords":["lift","thine","hands","against","their","pride","continually","all","that","the","enemy","has","done","wickedly","thy","holy","places"]},{"verseId":"brenton_psalms_73_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":4,"text":"And they that hate thee have boasted in the midst of thy feast; they have set up their standards for signs,","searchKeywords":["and","they","that","hate","thee","have","boasted","the","midst","thy","feast","set","their","standards","for","signs"]},{"verseId":"brenton_psalms_73_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":5,"text":"ignorantly as it were in the entrance above;","searchKeywords":["ignorantly","were","the","entrance","above"]},{"verseId":"brenton_psalms_73_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":6,"text":"they cut down its doors at once with axes as in a wood of trees; they have broken it down with hatchet and stone cutter.","searchKeywords":["they","cut","down","its","doors","once","with","axes","wood","trees","have","broken","hatchet","and","stone","cutter"]},{"verseId":"brenton_psalms_73_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":7,"text":"They have burnt thy sanctuary with fire to the ground; they have profaned the habitation of thy name.","searchKeywords":["they","have","burnt","thy","sanctuary","with","fire","the","ground","profaned","habitation","name"]},{"verseId":"brenton_psalms_73_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":8,"text":"They have said in their heart, all their kindred together, Come, let us abolish the feasts of the Lord from the earth.","searchKeywords":["they","have","said","their","heart","all","kindred","together","come","let","abolish","the","feasts","lord","from","earth"]},{"verseId":"brenton_psalms_73_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":9,"text":"We have not seen our signs; there is no longer a prophet; and will not know us any more.","searchKeywords":["have","not","seen","our","signs","there","longer","prophet","and","will","know","any","more"]},{"verseId":"brenton_psalms_73_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":10,"text":"How long, O God, shall the enemy reproach? shall the enemy provoke thy name for ever?","searchKeywords":["how","long","god","shall","the","enemy","reproach","provoke","thy","name","for","ever"]},{"verseId":"brenton_psalms_73_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":11,"text":"Wherefore turnest thou away thine hand, and thy right hand from the midst of thy bosom for ever?","searchKeywords":["wherefore","turnest","thou","away","thine","hand","and","thy","right","from","the","midst","bosom","for","ever"]},{"verseId":"brenton_psalms_73_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":12,"text":"But God is our King of old; he has wrought salvation in the midst of the earth.","searchKeywords":["but","god","our","king","old","has","wrought","salvation","the","midst","earth"]},{"verseId":"brenton_psalms_73_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":13,"text":"Thou didst establish the sea, in thy might, thou didst break to pieces the heads of the dragons in the water.","searchKeywords":["thou","didst","establish","the","sea","thy","might","break","pieces","heads","dragons","water"]},{"verseId":"brenton_psalms_73_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":14,"text":"Thou didst break to pieces the heads of the dragon; thou didst give him meat to the Ethiopian nations.","searchKeywords":["thou","didst","break","pieces","the","heads","dragon","give","him","meat","ethiopian","nations"]},{"verseId":"brenton_psalms_73_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":15,"text":"Thou didst cleave fountains and torrents; thou driedst up mighty rivers.","searchKeywords":["thou","didst","cleave","fountains","and","torrents","driedst","mighty","rivers"]},{"verseId":"brenton_psalms_73_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":16,"text":"The day is thine, and the night is thine; thou hast prepared the sun and the moon.","searchKeywords":["the","day","thine","and","night","thou","hast","prepared","sun","moon"]},{"verseId":"brenton_psalms_73_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":17,"text":"Thou hast made all the borders of the earth; thou hast made summer and spring.","searchKeywords":["thou","hast","made","all","the","borders","earth","summer","and","spring"]},{"verseId":"brenton_psalms_73_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":18,"text":"Remember this thy creation: an enemy has reproached the Lord, and a foolish people has provoked thy name.","searchKeywords":["remember","this","thy","creation","enemy","has","reproached","the","lord","and","foolish","people","provoked","name"]},{"verseId":"brenton_psalms_73_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":19,"text":"Deliver not to the wild beasts a soul that gives praise to thee: forget not for ever the souls of thy poor.","searchKeywords":["deliver","not","the","wild","beasts","soul","that","gives","praise","thee","forget","for","ever","souls","thy","poor"]},{"verseId":"brenton_psalms_73_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":20,"text":"Look upon thy covenant: for the dark of the earth are filled with the habitations of iniquity.","searchKeywords":["look","upon","thy","covenant","for","the","dark","earth","are","filled","with","habitations","iniquity"]},{"verseId":"brenton_psalms_73_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":21,"text":"Let not the afflicted and shamed one be rejected: the poor and needy shall praise thy name.","searchKeywords":["let","not","the","afflicted","and","shamed","one","rejected","poor","needy","shall","praise","thy","name"]},{"verseId":"brenton_psalms_73_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":22,"text":"Arise, O God, plead thy cause: remember thy reproaches that come from the foolish one all the day.","searchKeywords":["arise","god","plead","thy","cause","remember","reproaches","that","come","from","the","foolish","one","all","day"]},{"verseId":"brenton_psalms_73_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":73,"verse":23,"text":"Forget not the voice of thy suppliants: let the pride of them that hate thee continually ascend before thee.","searchKeywords":["forget","not","the","voice","thy","suppliants","let","pride","them","that","hate","thee","continually","ascend","before"]}]