[{"verseId":"brenton_psalms_54_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":1,"text":"For the end, among Hymns of instruction by David.","searchKeywords":["for","the","end","among","hymns","instruction","david"]},{"verseId":"brenton_psalms_54_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":2,"text":"Hearken, O God, to my prayer; and disregard not my supplication.","searchKeywords":["hearken","god","prayer","and","disregard","not","supplication"]},{"verseId":"brenton_psalms_54_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":3,"text":"Attend to me, and hearken to me: I was grieved in my meditation, and troubled;","searchKeywords":["attend","and","hearken","was","grieved","meditation","troubled"]},{"verseId":"brenton_psalms_54_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":4,"text":"because of the voice of the enemy, and because of the oppression of the sinner: for they brought iniquity against me, and were wrathfully angry with me.","searchKeywords":["because","the","voice","enemy","and","oppression","sinner","for","they","brought","iniquity","against","were","wrathfully","angry","with"]},{"verseId":"brenton_psalms_54_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":5,"text":"My heart was troubled within me; and the fear of death fell upon me.","searchKeywords":["heart","was","troubled","within","and","the","fear","death","fell","upon"]},{"verseId":"brenton_psalms_54_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":6,"text":"Fear and trembling came upon me, and darkness covered me.","searchKeywords":["fear","and","trembling","came","upon","darkness","covered"]},{"verseId":"brenton_psalms_54_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":7,"text":"And I said, O that I had wings as of a dove! then would I flee away, and be at rest.","searchKeywords":["and","said","that","had","wings","dove","then","would","flee","away","rest"]},{"verseId":"brenton_psalms_54_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":8,"text":"Lo! I have fled afar off, and lodged in the wilderness. Pause.","searchKeywords":["have","fled","afar","off","and","lodged","the","wilderness","pause"]},{"verseId":"brenton_psalms_54_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":9,"text":"I waited for him that should deliver me from distress of spirit and tempest.","searchKeywords":["waited","for","him","that","should","deliver","from","distress","spirit","and","tempest"]},{"verseId":"brenton_psalms_54_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":10,"text":"Destroy, O Lord, and divide their tongues: for I have seen iniquity and gainsaying in the city.","searchKeywords":["destroy","lord","and","divide","their","tongues","for","have","seen","iniquity","gainsaying","the","city"]},{"verseId":"brenton_psalms_54_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":11,"text":"Day and night he shall go round about it upon its walls: iniquity and sorrow and unrighteousness in the midst of it;","searchKeywords":["day","and","night","shall","round","about","upon","its","walls","iniquity","sorrow","unrighteousness","the","midst"]},{"verseId":"brenton_psalms_54_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":12,"text":"and usury and craft have not failed from its streets.","searchKeywords":["and","usury","craft","have","not","failed","from","its","streets"]},{"verseId":"brenton_psalms_54_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":13,"text":"For if an enemy had reproached me, I would have endured it; and if one who hated had spoken vauntingly against me, I would have hid myself from him.","searchKeywords":["for","enemy","had","reproached","would","have","endured","and","one","who","hated","spoken","vauntingly","against","hid","myself","from","him"]},{"verseId":"brenton_psalms_54_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":14,"text":"But thou, O man likeminded, my guide, and my acquaintance,","searchKeywords":["but","thou","man","likeminded","guide","and","acquaintance"]},{"verseId":"brenton_psalms_54_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":15,"text":"who in companionship with me sweetened food: we walked in the house of God in concord.","searchKeywords":["who","companionship","with","sweetened","food","walked","the","house","god","concord"]},{"verseId":"brenton_psalms_54_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":16,"text":"Let death come upon them, and let them go down alive into Hades, for iniquity is in their dwellings, in the midst of them.","searchKeywords":["let","death","come","upon","them","and","down","alive","into","hades","for","iniquity","their","dwellings","the","midst"]},{"verseId":"brenton_psalms_54_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":17,"text":"I cried to God, and the Lord hearkened to me.","searchKeywords":["cried","god","and","the","lord","hearkened"]},{"verseId":"brenton_psalms_54_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":18,"text":"Evening, and morning, and at noon I will declare and make known : and he shall hear my voice.","searchKeywords":["evening","and","morning","noon","will","declare","make","known","shall","hear","voice"]},{"verseId":"brenton_psalms_54_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":19,"text":"He shall deliver my soul in peace from them that draw nigh to me: for they were with me in many .","searchKeywords":["shall","deliver","soul","peace","from","them","that","draw","nigh","for","they","were","with","many"]},{"verseId":"brenton_psalms_54_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":20,"text":"God shall hear, and bring them low, he that has existed from eternity. Pause. For they suffer no reverse, and they have not feared God.","searchKeywords":["god","shall","hear","and","bring","them","low","that","has","existed","from","eternity","pause","for","they","suffer","reverse","have","not","feared"]},{"verseId":"brenton_psalms_54_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":21,"text":"He has reached forth his hand for retribution; they have profaned his covenant.","searchKeywords":["has","reached","forth","his","hand","for","retribution","they","have","profaned","covenant"]},{"verseId":"brenton_psalms_54_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":22,"text":"They were scattered at the anger of his countenance, and his heart drew nigh them. His words were smoother than oil, yet are they darts.","searchKeywords":["they","were","scattered","the","anger","his","countenance","and","heart","drew","nigh","them","words","smoother","than","oil","yet","are","darts"]},{"verseId":"brenton_psalms_54_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":23,"text":"Cast thy care upon the Lord, and he shall sustain thee; he shall never suffer the righteous to be moved.","searchKeywords":["cast","thy","care","upon","the","lord","and","shall","sustain","thee","never","suffer","righteous","moved"]},{"verseId":"brenton_psalms_54_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":54,"verse":24,"text":"But thou, O God, shalt bring them down to the pit of destruction; bloody and crafty men shall not live out half their days; but I will hope in thee, O Lord.","searchKeywords":["but","thou","god","shalt","bring","them","down","the","pit","destruction","bloody","and","crafty","men","shall","not","live","out","half","their","days","will","hope","thee","lord"]}]