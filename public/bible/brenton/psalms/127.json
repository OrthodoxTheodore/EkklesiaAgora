[{"verseId":"brenton_psalms_127_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":127,"verse":1,"text":"A Song of Degrees.","searchKeywords":["song","degrees"]},{"verseId":"brenton_psalms_127_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":127,"verse":2,"text":"Thou shalt eat the labours of thy hands: blessed art thou, and it shall be well with thee.","searchKeywords":["thou","shalt","eat","the","labours","thy","hands","blessed","art","and","shall","well","with","thee"]},{"verseId":"brenton_psalms_127_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":127,"verse":3,"text":"Thy wife shall be as a fruitful vine on the sides of thy house: thy children as young olive-plants round about thy table.","searchKeywords":["thy","wife","shall","fruitful","vine","the","sides","house","children","young","olive","plants","round","about","table"]},{"verseId":"brenton_psalms_127_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":127,"verse":4,"text":"Behold, thus shall the man be blessed that fears the Lord.","searchKeywords":["behold","thus","shall","the","man","blessed","that","fears","lord"]},{"verseId":"brenton_psalms_127_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":127,"verse":5,"text":"May the Lord bless thee out of Sion; and mayest thou see the prosperity of Jerusalem all the days of thy life.","searchKeywords":["may","the","lord","bless","thee","out","sion","and","mayest","thou","see","prosperity","jerusalem","all","days","thy","life"]},{"verseId":"brenton_psalms_127_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":127,"verse":6,"text":"And mayest thou see thy children's children. Peace be upon Israel.","searchKeywords":["and","mayest","thou","see","thy","children","peace","upon","israel"]}]