[{"verseId":"brenton_psalms_70_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":1,"text":"By David, the sons of Jonadab, and the first that were taken captive.","searchKeywords":["david","the","sons","jonadab","and","first","that","were","taken","captive"]},{"verseId":"brenton_psalms_70_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":2,"text":"In thy righteousness deliver me and rescue me: incline thine ear to me, and save me.","searchKeywords":["thy","righteousness","deliver","and","rescue","incline","thine","ear","save"]},{"verseId":"brenton_psalms_70_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":3,"text":"Be to me a protecting God, and a strong hold to save me: for thou art my fortress and my refuge.","searchKeywords":["protecting","god","and","strong","hold","save","for","thou","art","fortress","refuge"]},{"verseId":"brenton_psalms_70_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":4,"text":"Deliver me, O my God, from the hand of the sinner, from the hand of the transgressor and unjust man.","searchKeywords":["deliver","god","from","the","hand","sinner","transgressor","and","unjust","man"]},{"verseId":"brenton_psalms_70_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":5,"text":"For thou art my support, O Lord; O Lord, my hope from my youth.","searchKeywords":["for","thou","art","support","lord","hope","from","youth"]},{"verseId":"brenton_psalms_70_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":6,"text":"On thee have I been stayed from the womb: from the belly of my mother thou art my protector: of thee is my praise continually.","searchKeywords":["thee","have","been","stayed","from","the","womb","belly","mother","thou","art","protector","praise","continually"]},{"verseId":"brenton_psalms_70_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":7,"text":"I am become as it were a wonder to many; but thou art strong helper.","searchKeywords":["become","were","wonder","many","but","thou","art","strong","helper"]},{"verseId":"brenton_psalms_70_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":8,"text":"Let my mouth be filled with praise, that I may hymn thy glory, thy majesty all the day.","searchKeywords":["let","mouth","filled","with","praise","that","may","hymn","thy","glory","majesty","all","the","day"]},{"verseId":"brenton_psalms_70_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":9,"text":"Cast me not off at the time of old age; forsake me not when my strength fails.","searchKeywords":["cast","not","off","the","time","old","age","forsake","when","strength","fails"]},{"verseId":"brenton_psalms_70_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":10,"text":"For mine enemies have spoken against me; and they that lay wait for my soul have taken counsel together,","searchKeywords":["for","mine","enemies","have","spoken","against","and","they","that","lay","wait","soul","taken","counsel","together"]},{"verseId":"brenton_psalms_70_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":11,"text":"saying, God has forsaken him: persecute ye and take him; for there is none to deliver .","searchKeywords":["saying","god","has","forsaken","him","persecute","and","take","for","there","none","deliver"]},{"verseId":"brenton_psalms_70_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":12,"text":"O God, go not far from me, O my God, draw nigh to my help.","searchKeywords":["god","not","far","from","draw","nigh","help"]},{"verseId":"brenton_psalms_70_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":13,"text":"Let those that plot against my soul be ashamed and utterly fail: let those that seek my hurt be clothed with shame and dishonour.","searchKeywords":["let","those","that","plot","against","soul","ashamed","and","utterly","fail","seek","hurt","clothed","with","shame","dishonour"]},{"verseId":"brenton_psalms_70_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":14,"text":"But I will hope continually, and will praise thee more and more.","searchKeywords":["but","will","hope","continually","and","praise","thee","more"]},{"verseId":"brenton_psalms_70_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":15,"text":"My mouth shall declare thy righteousness openly, thy salvation all the day; for I am not acquainted with the affairs .","searchKeywords":["mouth","shall","declare","thy","righteousness","openly","salvation","all","the","day","for","not","acquainted","with","affairs"]},{"verseId":"brenton_psalms_70_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":16,"text":"I will go on in the might of the Lord: O Lord, I will make mention of thy righteousness only.","searchKeywords":["will","the","might","lord","make","mention","thy","righteousness","only"]},{"verseId":"brenton_psalms_70_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":17,"text":"O God, thou hast taught me from my youth, and until now will I declare thy wonders;","searchKeywords":["god","thou","hast","taught","from","youth","and","until","now","will","declare","thy","wonders"]},{"verseId":"brenton_psalms_70_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":18,"text":"even until I am old and advanced in years. O God, forsake me not; until I shall have declared thine arm to all the generation that is to come:","searchKeywords":["even","until","old","and","advanced","years","god","forsake","not","shall","have","declared","thine","arm","all","the","generation","that","come"]},{"verseId":"brenton_psalms_70_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":19,"text":"even thy power and thy righteousness, O God, up to the highest the mighty works which thou hast done: O God, who is like to thee?","searchKeywords":["even","thy","power","and","righteousness","god","the","highest","mighty","works","which","thou","hast","done","who","like","thee"]},{"verseId":"brenton_psalms_70_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":20,"text":"What afflictions many and sore hast thou shewed me! yet thou didst turn and quicken me, and broughtest me again from the depths of the earth.","searchKeywords":["what","afflictions","many","and","sore","hast","thou","shewed","yet","didst","turn","quicken","broughtest","again","from","the","depths","earth"]},{"verseId":"brenton_psalms_70_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":21,"text":"Thou didst multiply thy righteousness, and didst turn and comfort me, and broughtest me again out of the depths of the earth.","searchKeywords":["thou","didst","multiply","thy","righteousness","and","turn","comfort","broughtest","again","out","the","depths","earth"]},{"verseId":"brenton_psalms_70_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":22,"text":"I will also therefore give thanks to thee, O God, thy truth, on an instrument of psalmody: I will sing psalms to thee on the harp, O Holy One of Israel.","searchKeywords":["will","also","therefore","give","thanks","thee","god","thy","truth","instrument","psalmody","sing","psalms","the","harp","holy","one","israel"]},{"verseId":"brenton_psalms_70_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":23,"text":"My lips shall rejoice when I sing to thee; and my soul, which thou hast redeemed.","searchKeywords":["lips","shall","rejoice","when","sing","thee","and","soul","which","thou","hast","redeemed"]},{"verseId":"brenton_psalms_70_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":70,"verse":24,"text":"Moreover also my tongue shall dwell all the day upon thy righteousness; when they shall be ashamed and confounded that seek my hurt.","searchKeywords":["moreover","also","tongue","shall","dwell","all","the","day","upon","thy","righteousness","when","they","ashamed","and","confounded","that","seek","hurt"]}]