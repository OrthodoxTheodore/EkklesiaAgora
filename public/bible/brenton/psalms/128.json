[{"verseId":"brenton_psalms_128_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":128,"verse":1,"text":"A Song of Degrees.","searchKeywords":["song","degrees"]},{"verseId":"brenton_psalms_128_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":128,"verse":2,"text":"Many a time have they warred against me from my youth: and yet they prevailed not against me.","searchKeywords":["many","time","have","they","warred","against","from","youth","and","yet","prevailed","not"]},{"verseId":"brenton_psalms_128_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":128,"verse":3,"text":"The sinners wrought upon my back: they prolonged their iniquity.","searchKeywords":["the","sinners","wrought","upon","back","they","prolonged","their","iniquity"]},{"verseId":"brenton_psalms_128_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":128,"verse":4,"text":"The righteous Lord has cut asunder the necks of sinners.","searchKeywords":["the","righteous","lord","has","cut","asunder","necks","sinners"]},{"verseId":"brenton_psalms_128_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":128,"verse":5,"text":"Let all that hate Sion be put to shame and turned back.","searchKeywords":["let","all","that","hate","sion","put","shame","and","turned","back"]},{"verseId":"brenton_psalms_128_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":128,"verse":6,"text":"Let them be as the grass of the house-tops, which withers before it is plucked up.","searchKeywords":["let","them","the","grass","house","tops","which","withers","before","plucked"]},{"verseId":"brenton_psalms_128_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":128,"verse":7,"text":"Wherewith the reaper fills not his hand, nor he that makes up the sheaves, his bosom.","searchKeywords":["wherewith","the","reaper","fills","not","his","hand","nor","that","makes","sheaves","bosom"]},{"verseId":"brenton_psalms_128_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":128,"verse":8,"text":"Neither do they that go by say, The blessing of the Lord be upon you: we have blessed you in the name of the Lord.","searchKeywords":["neither","they","that","say","the","blessing","lord","upon","you","have","blessed","name"]}]