[{"verseId":"brenton_psalms_25_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":25,"verse":1,"text":"of David.","searchKeywords":["david"]},{"verseId":"brenton_psalms_25_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":25,"verse":2,"text":"Prove me, O Lord, and try me; purify as with fire my reins and my heart.","searchKeywords":["prove","lord","and","try","purify","with","fire","reins","heart"]},{"verseId":"brenton_psalms_25_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":25,"verse":3,"text":"For thy mercy is before mine eyes: and I am well pleased with thy truth.","searchKeywords":["for","thy","mercy","before","mine","eyes","and","well","pleased","with","truth"]},{"verseId":"brenton_psalms_25_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":25,"verse":4,"text":"I have not sat with the council of vanity, and will in nowise enter in with transgressors.","searchKeywords":["have","not","sat","with","the","council","vanity","and","will","nowise","enter","transgressors"]},{"verseId":"brenton_psalms_25_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":25,"verse":5,"text":"I have hated the assembly of wicked doers; and will not sit with ungodly .","searchKeywords":["have","hated","the","assembly","wicked","doers","and","will","not","sit","with","ungodly"]},{"verseId":"brenton_psalms_25_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":25,"verse":6,"text":"I will wash my hands in innocency, and compass thine altar, O Lord:","searchKeywords":["will","wash","hands","innocency","and","compass","thine","altar","lord"]},{"verseId":"brenton_psalms_25_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":25,"verse":7,"text":"to hear the voice of praise, and to declare all thy wonderful works.","searchKeywords":["hear","the","voice","praise","and","declare","all","thy","wonderful","works"]},{"verseId":"brenton_psalms_25_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":25,"verse":8,"text":"O Lord, I have loved the beauty of thy house, and the place of the tabernacle of thy glory.","searchKeywords":["lord","have","loved","the","beauty","thy","house","and","place","tabernacle","glory"]},{"verseId":"brenton_psalms_25_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":25,"verse":9,"text":"Destroy not my soul together with the ungodly, nor my life with bloody men:","searchKeywords":["destroy","not","soul","together","with","the","ungodly","nor","life","bloody","men"]},{"verseId":"brenton_psalms_25_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":25,"verse":10,"text":"in whose hands iniquities, their right hand is filled with bribes.","searchKeywords":["whose","hands","iniquities","their","right","hand","filled","with","bribes"]},{"verseId":"brenton_psalms_25_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":25,"verse":11,"text":"But I have walked in my innocence: redeem me, and have mercy upon me.","searchKeywords":["but","have","walked","innocence","redeem","and","mercy","upon"]},{"verseId":"brenton_psalms_25_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":25,"verse":12,"text":"My foot stands in an even place: in the congregations will I bless thee, O Lord.","searchKeywords":["foot","stands","even","place","the","congregations","will","bless","thee","lord"]}]