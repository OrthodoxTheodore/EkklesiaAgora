[{"verseId":"brenton_psalms_137_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":137,"verse":1,"text":"A Psalm for David, of Aggæus and Zacharias.","searchKeywords":["psalm","for","david","agg","and","zacharias"]},{"verseId":"brenton_psalms_137_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":137,"verse":2,"text":"I will worship toward thy holy temple, and give thanks to thy name, on account of thy mercy and thy truth; for thou hast magnified thy holy name above every thing.","searchKeywords":["will","worship","toward","thy","holy","temple","and","give","thanks","name","account","mercy","truth","for","thou","hast","magnified","above","every","thing"]},{"verseId":"brenton_psalms_137_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":137,"verse":3,"text":"In whatsoever day I shall call upon thee, hear me speedily; thou shalt abundantly provide me with thy power in my soul.","searchKeywords":["whatsoever","day","shall","call","upon","thee","hear","speedily","thou","shalt","abundantly","provide","with","thy","power","soul"]},{"verseId":"brenton_psalms_137_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":137,"verse":4,"text":"Let all the kings of the earth, O Lord, give thanks unto thee; for they have heard all the words of thy mouth.","searchKeywords":["let","all","the","kings","earth","lord","give","thanks","unto","thee","for","they","have","heard","words","thy","mouth"]},{"verseId":"brenton_psalms_137_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":137,"verse":5,"text":"And let them sing in the ways of the Lord; for great is the glory of the Lord.","searchKeywords":["and","let","them","sing","the","ways","lord","for","great","glory"]},{"verseId":"brenton_psalms_137_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":137,"verse":6,"text":"For the Lord is high, and regards the lowly; and he knows high things from afar off.","searchKeywords":["for","the","lord","high","and","regards","lowly","knows","things","from","afar","off"]},{"verseId":"brenton_psalms_137_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":137,"verse":7,"text":"Though I should walk in the midst of affliction, thou wilt quicken me; thou hast stretched forth thine hands against the wrath of mine enemies, and thy right hand has saved me.","searchKeywords":["though","should","walk","the","midst","affliction","thou","wilt","quicken","hast","stretched","forth","thine","hands","against","wrath","mine","enemies","and","thy","right","hand","has","saved"]},{"verseId":"brenton_psalms_137_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":137,"verse":8,"text":"O Lord, thou shalt recompense on my behalf: thy mercy, O Lord, for ever: overlook not the works of thine hands.","searchKeywords":["lord","thou","shalt","recompense","behalf","thy","mercy","for","ever","overlook","not","the","works","thine","hands"]}]