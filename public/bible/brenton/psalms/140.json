[{"verseId":"brenton_psalms_140_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":140,"verse":1,"text":"A Psalm of David.","searchKeywords":["psalm","david"]},{"verseId":"brenton_psalms_140_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":140,"verse":2,"text":"Let my prayer be set forth before thee as incense; the lifting up of my hands an evening sacrifice.","searchKeywords":["let","prayer","set","forth","before","thee","incense","the","lifting","hands","evening","sacrifice"]},{"verseId":"brenton_psalms_140_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":140,"verse":3,"text":"Set a watch, O Lord, on my mouth, and a strong door about my lips.","searchKeywords":["set","watch","lord","mouth","and","strong","door","about","lips"]},{"verseId":"brenton_psalms_140_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":140,"verse":4,"text":"Incline not my heart to evil things, to employ pretexts for sins, with men who work iniquity: and let me not unite with their choice ones.","searchKeywords":["incline","not","heart","evil","things","employ","pretexts","for","sins","with","men","who","work","iniquity","and","let","unite","their","choice","ones"]},{"verseId":"brenton_psalms_140_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":140,"verse":5,"text":"The righteous shall chasten me with mercy, and reprove me: but let not the oil of the sinner anoint my head: for yet shall my prayer also be in their pleasures.","searchKeywords":["the","righteous","shall","chasten","with","mercy","and","reprove","but","let","not","oil","sinner","anoint","head","for","yet","prayer","also","their","pleasures"]},{"verseId":"brenton_psalms_140_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":140,"verse":6,"text":"Their mighty ones have been swallowed up near the rock: they shall hear my words, for they are sweet.","searchKeywords":["their","mighty","ones","have","been","swallowed","near","the","rock","they","shall","hear","words","for","are","sweet"]},{"verseId":"brenton_psalms_140_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":140,"verse":7,"text":"As a lump of earth is crushed upon the ground, our bones have been scattered by the the grave.","searchKeywords":["lump","earth","crushed","upon","the","ground","our","bones","have","been","scattered","grave"]},{"verseId":"brenton_psalms_140_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":140,"verse":8,"text":"For mine eyes are to thee, O Lord God: I have hoped in thee; take not away my life.","searchKeywords":["for","mine","eyes","are","thee","lord","god","have","hoped","take","not","away","life"]},{"verseId":"brenton_psalms_140_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":140,"verse":9,"text":"Keep me from the snare which they have set for me, and from the stumbling-blocks of them that work iniquity.","searchKeywords":["keep","from","the","snare","which","they","have","set","for","and","stumbling","blocks","them","that","work","iniquity"]},{"verseId":"brenton_psalms_140_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":140,"verse":10,"text":"Sinners shall fall by their own net: I am alone until I shall escape.","searchKeywords":["sinners","shall","fall","their","own","net","alone","until","escape"]}]