[{"verseId":"brenton_psalms_109_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":109,"verse":1,"text":"A Psalm of David. The Lord said to my Lord, Sit thou on my right hand, until I make thine enemies thy footstool.","searchKeywords":["psalm","david","the","lord","said","sit","thou","right","hand","until","make","thine","enemies","thy","footstool"]},{"verseId":"brenton_psalms_109_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":109,"verse":2,"text":"The Lord shall send out a rod of power for thee out of Sion: rule thou in the midst of thine enemies.","searchKeywords":["the","lord","shall","send","out","rod","power","for","thee","sion","rule","thou","midst","thine","enemies"]},{"verseId":"brenton_psalms_109_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":109,"verse":3,"text":"With thee is dominion in the day of thy power, in the splendours of thy saints: I have begotten thee from the womb before the morning.","searchKeywords":["with","thee","dominion","the","day","thy","power","splendours","saints","have","begotten","from","womb","before","morning"]},{"verseId":"brenton_psalms_109_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":109,"verse":4,"text":"The Lord sware, and will not repent, Thou art a priest for ever, after the order of Melchisedec.","searchKeywords":["the","lord","sware","and","will","not","repent","thou","art","priest","for","ever","after","order","melchisedec"]},{"verseId":"brenton_psalms_109_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":109,"verse":5,"text":"The Lord at thy right hand has dashed in pieces kings in the day of his wrath.","searchKeywords":["the","lord","thy","right","hand","has","dashed","pieces","kings","day","his","wrath"]},{"verseId":"brenton_psalms_109_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":109,"verse":6,"text":"He shall judge among the nations, he shall fill up corpses, he shall crush the heads of many on the earth.","searchKeywords":["shall","judge","among","the","nations","fill","corpses","crush","heads","many","earth"]},{"verseId":"brenton_psalms_109_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":109,"verse":7,"text":"He shall drink of the brook in the way; therefore shall he lift up the head.","searchKeywords":["shall","drink","the","brook","way","therefore","lift","head"]}]