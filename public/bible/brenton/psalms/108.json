[{"verseId":"brenton_psalms_108_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":1,"text":"For the end, a Psalm of David.","searchKeywords":["for","the","end","psalm","david"]},{"verseId":"brenton_psalms_108_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":2,"text":"for the mouth of the sinner and the mouth of the crafty have been opened against me: they have spoken against me with a crafty tongue.","searchKeywords":["for","the","mouth","sinner","and","crafty","have","been","opened","against","they","spoken","with","tongue"]},{"verseId":"brenton_psalms_108_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":3,"text":"And they have compassed me with words of hatred; and fought against me without a cause.","searchKeywords":["and","they","have","compassed","with","words","hatred","fought","against","without","cause"]},{"verseId":"brenton_psalms_108_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":4,"text":"Instead of loving me, they falsely accused me: but I continued to pray.","searchKeywords":["instead","loving","they","falsely","accused","but","continued","pray"]},{"verseId":"brenton_psalms_108_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":5,"text":"And they rewarded me evil for good, and hatred for my love.","searchKeywords":["and","they","rewarded","evil","for","good","hatred","love"]},{"verseId":"brenton_psalms_108_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":6,"text":"Set thou a sinner against him; and let the devil stand at his right hand.","searchKeywords":["set","thou","sinner","against","him","and","let","the","devil","stand","his","right","hand"]},{"verseId":"brenton_psalms_108_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":7,"text":"When he is judged, let him go forth condemned: and let his prayer become sin.","searchKeywords":["when","judged","let","him","forth","condemned","and","his","prayer","become","sin"]},{"verseId":"brenton_psalms_108_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":8,"text":"Let his days be few: and let another take his office of overseer.","searchKeywords":["let","his","days","few","and","another","take","office","overseer"]},{"verseId":"brenton_psalms_108_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":9,"text":"Let his children be orphans, and his wife a widow.","searchKeywords":["let","his","children","orphans","and","wife","widow"]},{"verseId":"brenton_psalms_108_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":10,"text":"Let his children wander without a dwelling-place, and beg: let them be cast out of their habitations.","searchKeywords":["let","his","children","wander","without","dwelling","place","and","beg","them","cast","out","their","habitations"]},{"verseId":"brenton_psalms_108_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":11,"text":"Let creditor exact all that belongs to him: and let strangers spoil his labours.","searchKeywords":["let","creditor","exact","all","that","belongs","him","and","strangers","spoil","his","labours"]},{"verseId":"brenton_psalms_108_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":12,"text":"Let him have no helper; neither let there be any one to have compassion on his fatherless children.","searchKeywords":["let","him","have","helper","neither","there","any","one","compassion","his","fatherless","children"]},{"verseId":"brenton_psalms_108_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":13,"text":"Let his children be to utter destruction: in one generation let his name be blotted out.","searchKeywords":["let","his","children","utter","destruction","one","generation","name","blotted","out"]},{"verseId":"brenton_psalms_108_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":14,"text":"Let the iniquity of his fathers be remembered before the Lord; and let not the sin of his mother be blotted out.","searchKeywords":["let","the","iniquity","his","fathers","remembered","before","lord","and","not","sin","mother","blotted","out"]},{"verseId":"brenton_psalms_108_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":15,"text":"Let them be before the Lord continually; and let their memorial be blotted out from the earth.","searchKeywords":["let","them","before","the","lord","continually","and","their","memorial","blotted","out","from","earth"]},{"verseId":"brenton_psalms_108_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":16,"text":"Because he remembered not to shew mercy, but persecuted the needy and poor man, and to slay him that was pricked in the heart.","searchKeywords":["because","remembered","not","shew","mercy","but","persecuted","the","needy","and","poor","man","slay","him","that","was","pricked","heart"]},{"verseId":"brenton_psalms_108_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":17,"text":"He loved cursing also, and it shall come upon him; and he took not pleasure in blessing, so it shall be removed far from him.","searchKeywords":["loved","cursing","also","and","shall","come","upon","him","took","not","pleasure","blessing","removed","far","from"]},{"verseId":"brenton_psalms_108_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":18,"text":"Yea, he put on cursing as a garment, and it is come as water into his bowels, and as oil into his bones.","searchKeywords":["yea","put","cursing","garment","and","come","water","into","his","bowels","oil","bones"]},{"verseId":"brenton_psalms_108_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":19,"text":"Let it be to him as a garment which he puts on, and as a girdle with which he girds himself continually.","searchKeywords":["let","him","garment","which","puts","and","girdle","with","girds","himself","continually"]},{"verseId":"brenton_psalms_108_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":20,"text":"This is the dealing of the Lord with those who falsely accuse me, and of them that speak evil against my soul.","searchKeywords":["this","the","dealing","lord","with","those","who","falsely","accuse","and","them","that","speak","evil","against","soul"]},{"verseId":"brenton_psalms_108_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":21,"text":"But thou, O Lord, Lord, deal with me, for thy name's sake: for thy mercy is good.","searchKeywords":["but","thou","lord","deal","with","for","thy","name","sake","mercy","good"]},{"verseId":"brenton_psalms_108_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":22,"text":"Deliver me, for I am poor and needy; and my heart is troubled within me.","searchKeywords":["deliver","for","poor","and","needy","heart","troubled","within"]},{"verseId":"brenton_psalms_108_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":23,"text":"I am removed as a shadow in its going down: I am tossed up and down like locusts.","searchKeywords":["removed","shadow","its","going","down","tossed","and","like","locusts"]},{"verseId":"brenton_psalms_108_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":24,"text":"My knees are weakened through fasting, and my flesh is changed by reason of oil.","searchKeywords":["knees","are","weakened","through","fasting","and","flesh","changed","reason","oil"]},{"verseId":"brenton_psalms_108_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":25,"text":"I became also a reproach to them: they saw me they shook their heads.","searchKeywords":["became","also","reproach","them","they","saw","shook","their","heads"]},{"verseId":"brenton_psalms_108_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":26,"text":"Help me, O Lord my God; and save me according to thy mercy.","searchKeywords":["help","lord","god","and","save","according","thy","mercy"]},{"verseId":"brenton_psalms_108_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":27,"text":"And let them know that this is thy hand; and thou, Lord, hast wrought it.","searchKeywords":["and","let","them","know","that","this","thy","hand","thou","lord","hast","wrought"]},{"verseId":"brenton_psalms_108_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":28,"text":"Let them curse, but thou shalt bless: let them that rise up against me be ashamed, but let thy servant rejoice.","searchKeywords":["let","them","curse","but","thou","shalt","bless","that","rise","against","ashamed","thy","servant","rejoice"]},{"verseId":"brenton_psalms_108_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":29,"text":"Let those that falsely accuse me be clothed with shame, and let them cover themselves with their shame as with a mantle.","searchKeywords":["let","those","that","falsely","accuse","clothed","with","shame","and","them","cover","themselves","their","mantle"]},{"verseId":"brenton_psalms_108_30","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":30,"text":"I will give thanks to the Lord abundantly with my mouth; and in the midst of many I will praise him.","searchKeywords":["will","give","thanks","the","lord","abundantly","with","mouth","and","midst","many","praise","him"]},{"verseId":"brenton_psalms_108_31","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":108,"verse":31,"text":"For he stood on the right hand of the poor, to save from them that persecute my soul.","searchKeywords":["for","stood","the","right","hand","poor","save","from","them","that","persecute","soul"]}]