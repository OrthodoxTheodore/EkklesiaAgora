[{"verseId":"brenton_psalms_90_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":1,"text":"Praise of a Song, by David.","searchKeywords":["praise","song","david"]},{"verseId":"brenton_psalms_90_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":2,"text":"He shall say to the Lord, Thou art my helper and my refuge: my God; I will hope in him.","searchKeywords":["shall","say","the","lord","thou","art","helper","and","refuge","god","will","hope","him"]},{"verseId":"brenton_psalms_90_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":3,"text":"For he shall deliver thee from the snare of the hunters, from troublesome matter.","searchKeywords":["for","shall","deliver","thee","from","the","snare","hunters","troublesome","matter"]},{"verseId":"brenton_psalms_90_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":4,"text":"He shall overshadow thee with his shoulders, and thou shalt trust under his wings: his truth shall cover thee with a shield.","searchKeywords":["shall","overshadow","thee","with","his","shoulders","and","thou","shalt","trust","under","wings","truth","cover","shield"]},{"verseId":"brenton_psalms_90_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":5,"text":"Thou shalt not be afraid of terror by night; nor of the arrow flying by day;","searchKeywords":["thou","shalt","not","afraid","terror","night","nor","the","arrow","flying","day"]},{"verseId":"brenton_psalms_90_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":6,"text":"of the thing that walks in darkness; of calamity, and the evil spirit at noon-day.","searchKeywords":["the","thing","that","walks","darkness","calamity","and","evil","spirit","noon","day"]},{"verseId":"brenton_psalms_90_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":7,"text":"A thousand shall fall at thy side, and ten thousand at thy right hand; but it shall not come nigh thee.","searchKeywords":["thousand","shall","fall","thy","side","and","ten","right","hand","but","not","come","nigh","thee"]},{"verseId":"brenton_psalms_90_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":8,"text":"Only with thine eyes shalt thou observe and see the reward of sinners.","searchKeywords":["only","with","thine","eyes","shalt","thou","observe","and","see","the","reward","sinners"]},{"verseId":"brenton_psalms_90_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":9,"text":"For thou, O Lord, art my hope: thou, my soul, hast made the Most High thy refuge.","searchKeywords":["for","thou","lord","art","hope","soul","hast","made","the","most","high","thy","refuge"]},{"verseId":"brenton_psalms_90_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":10,"text":"No evils shall come upon thee, and no scourge shall draw nigh to thy dwelling.","searchKeywords":["evils","shall","come","upon","thee","and","scourge","draw","nigh","thy","dwelling"]},{"verseId":"brenton_psalms_90_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":11,"text":"For he shall give his angels charge concerning thee, to keep thee in all thy ways.","searchKeywords":["for","shall","give","his","angels","charge","concerning","thee","keep","all","thy","ways"]},{"verseId":"brenton_psalms_90_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":12,"text":"They shall bear thee up on their hands, lest at any time thou dash thy foot against a stone.","searchKeywords":["they","shall","bear","thee","their","hands","lest","any","time","thou","dash","thy","foot","against","stone"]},{"verseId":"brenton_psalms_90_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":13,"text":"Thou shalt tread on the asp and basilisk: and thou shalt trample on the lion and dragon.","searchKeywords":["thou","shalt","tread","the","asp","and","basilisk","trample","lion","dragon"]},{"verseId":"brenton_psalms_90_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":14,"text":"For he has hoped in me, and I will deliver him: I will protect him, because he has known my name.","searchKeywords":["for","has","hoped","and","will","deliver","him","protect","because","known","name"]},{"verseId":"brenton_psalms_90_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":15,"text":"He shall call upon me, and I will hearken to him: I am with him in affliction; and I will deliver him, and glorify him.","searchKeywords":["shall","call","upon","and","will","hearken","him","with","affliction","deliver","glorify"]},{"verseId":"brenton_psalms_90_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":90,"verse":16,"text":"I will satisfy him with length of days, and shew him my salvation.","searchKeywords":["will","satisfy","him","with","length","days","and","shew","salvation"]}]