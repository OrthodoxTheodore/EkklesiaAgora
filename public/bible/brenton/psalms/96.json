[{"verseId":"brenton_psalms_96_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":96,"verse":1,"text":"For David, when his land is established.","searchKeywords":["for","david","when","his","land","established"]},{"verseId":"brenton_psalms_96_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":96,"verse":2,"text":"Cloud and darkness are round about him; righteousness and judgment are the establishment of his throne.","searchKeywords":["cloud","and","darkness","are","round","about","him","righteousness","judgment","the","establishment","his","throne"]},{"verseId":"brenton_psalms_96_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":96,"verse":3,"text":"Fire shall go before him, and burn up his enemies round about.","searchKeywords":["fire","shall","before","him","and","burn","his","enemies","round","about"]},{"verseId":"brenton_psalms_96_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":96,"verse":4,"text":"His lightnings appeared to the world; the earth saw, and trembled.","searchKeywords":["his","lightnings","appeared","the","world","earth","saw","and","trembled"]},{"verseId":"brenton_psalms_96_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":96,"verse":5,"text":"The mountains melted like wax at the presence of the Lord, at the presence of the Lord of the whole earth.","searchKeywords":["the","mountains","melted","like","wax","presence","lord","whole","earth"]},{"verseId":"brenton_psalms_96_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":96,"verse":6,"text":"The heavens have declared his righteousness, and all the people have seen his glory.","searchKeywords":["the","heavens","have","declared","his","righteousness","and","all","people","seen","glory"]},{"verseId":"brenton_psalms_96_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":96,"verse":7,"text":"Let all that worship graven images be ashamed, who boast of their idols; worship him, all ye his angels.","searchKeywords":["let","all","that","worship","graven","images","ashamed","who","boast","their","idols","him","his","angels"]},{"verseId":"brenton_psalms_96_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":96,"verse":8,"text":"Sion heard and rejoiced; and the daughters of Judea exulted, because of thy judgments, O Lord.","searchKeywords":["sion","heard","and","rejoiced","the","daughters","judea","exulted","because","thy","judgments","lord"]},{"verseId":"brenton_psalms_96_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":96,"verse":9,"text":"For thou art Lord most high over all the earth; thou art greatly exalted above all gods.","searchKeywords":["for","thou","art","lord","most","high","over","all","the","earth","greatly","exalted","above","gods"]},{"verseId":"brenton_psalms_96_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":96,"verse":10,"text":"Ye that love the Lord, hate evil; the Lord preserves the souls of his saints; he shall deliver them from the hand of sinners.","searchKeywords":["that","love","the","lord","hate","evil","preserves","souls","his","saints","shall","deliver","them","from","hand","sinners"]},{"verseId":"brenton_psalms_96_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":96,"verse":11,"text":"Light is sprung up for the righteous, and gladness for the upright in heart.","searchKeywords":["light","sprung","for","the","righteous","and","gladness","upright","heart"]},{"verseId":"brenton_psalms_96_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":96,"verse":12,"text":"Rejoice in the Lord, ye righteous; and give thanks for a remembrance of his holiness.","searchKeywords":["rejoice","the","lord","righteous","and","give","thanks","for","remembrance","his","holiness"]}]