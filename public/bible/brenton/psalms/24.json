[{"verseId":"brenton_psalms_24_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":1,"text":"A Psalm of David.","searchKeywords":["psalm","david"]},{"verseId":"brenton_psalms_24_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":2,"text":"O my God, I have trusted in thee: let me not be confounded, neither let mine enemies laugh me to scorn.","searchKeywords":["god","have","trusted","thee","let","not","confounded","neither","mine","enemies","laugh","scorn"]},{"verseId":"brenton_psalms_24_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":3,"text":"For none of them that wait on thee shall in any wise be ashamed: let them be ashamed that transgress without cause.","searchKeywords":["for","none","them","that","wait","thee","shall","any","wise","ashamed","let","transgress","without","cause"]},{"verseId":"brenton_psalms_24_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":4,"text":"Shew me thy ways, O Lord; and teach me thy paths.","searchKeywords":["shew","thy","ways","lord","and","teach","paths"]},{"verseId":"brenton_psalms_24_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":5,"text":"Lead me in thy truth, and teach me: for thou art God my Saviour: and I have waited on thee all the day.","searchKeywords":["lead","thy","truth","and","teach","for","thou","art","god","saviour","have","waited","thee","all","the","day"]},{"verseId":"brenton_psalms_24_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":6,"text":"Remember thy compassions, O Lord, and thy mercies, for they are from everlasting.","searchKeywords":["remember","thy","compassions","lord","and","mercies","for","they","are","from","everlasting"]},{"verseId":"brenton_psalms_24_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":7,"text":"Remember not the sins of my youth, nor of ignorance: remember me according to thy mercy, for thy goodness' sake, O Lord.","searchKeywords":["remember","not","the","sins","youth","nor","ignorance","according","thy","mercy","for","goodness","sake","lord"]},{"verseId":"brenton_psalms_24_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":8,"text":"Good and upright is the Lord: therefore will he instruct sinners in way.","searchKeywords":["good","and","upright","the","lord","therefore","will","instruct","sinners","way"]},{"verseId":"brenton_psalms_24_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":9,"text":"The meek will he guide in judgment: the meek will he teach his ways.","searchKeywords":["the","meek","will","guide","judgment","teach","his","ways"]},{"verseId":"brenton_psalms_24_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":10,"text":"All the ways of the Lord are mercy and truth to them that seek his covenant and his testimonies.","searchKeywords":["all","the","ways","lord","are","mercy","and","truth","them","that","seek","his","covenant","testimonies"]},{"verseId":"brenton_psalms_24_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":11,"text":"For thy name's sake, O Lord, do thou also be merciful to my sin; for it is great.","searchKeywords":["for","thy","name","sake","lord","thou","also","merciful","sin","great"]},{"verseId":"brenton_psalms_24_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":12,"text":"Who is the man that fears the Lord? he shall instruct him in the way which he has chosen.","searchKeywords":["who","the","man","that","fears","lord","shall","instruct","him","way","which","has","chosen"]},{"verseId":"brenton_psalms_24_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":13,"text":"His soul shall dwell in prosperity; and his seed shall inherit the earth.","searchKeywords":["his","soul","shall","dwell","prosperity","and","seed","inherit","the","earth"]},{"verseId":"brenton_psalms_24_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":14,"text":"The Lord is the strength of them that fear him; and his covenant is to manifest to them.","searchKeywords":["the","lord","strength","them","that","fear","him","and","his","covenant","manifest"]},{"verseId":"brenton_psalms_24_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":15,"text":"Mine eyes are continually to the Lord; for he shall draw my feet out of the snare.","searchKeywords":["mine","eyes","are","continually","the","lord","for","shall","draw","feet","out","snare"]},{"verseId":"brenton_psalms_24_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":16,"text":"Look upon me, and have mercy upon me; for I am an only child and poor.","searchKeywords":["look","upon","and","have","mercy","for","only","child","poor"]},{"verseId":"brenton_psalms_24_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":17,"text":"The afflictions of my heart have been multiplied; deliver me from my distresses.","searchKeywords":["the","afflictions","heart","have","been","multiplied","deliver","from","distresses"]},{"verseId":"brenton_psalms_24_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":18,"text":"Look upon mine affliction and my trouble; and forgive all my sins.","searchKeywords":["look","upon","mine","affliction","and","trouble","forgive","all","sins"]},{"verseId":"brenton_psalms_24_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":19,"text":"Look upon mine enemies; for they have been multiplied; and they have hated me with unjust hatred.","searchKeywords":["look","upon","mine","enemies","for","they","have","been","multiplied","and","hated","with","unjust","hatred"]},{"verseId":"brenton_psalms_24_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":20,"text":"Keep my soul, and deliver me: let me not be ashamed; for I have hoped in thee.","searchKeywords":["keep","soul","and","deliver","let","not","ashamed","for","have","hoped","thee"]},{"verseId":"brenton_psalms_24_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":21,"text":"The harmless and upright joined themselves to me: for I waited for thee, O Lord.","searchKeywords":["the","harmless","and","upright","joined","themselves","for","waited","thee","lord"]},{"verseId":"brenton_psalms_24_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":24,"verse":22,"text":"Deliver Israel, O God, out of all his afflictions.","searchKeywords":["deliver","israel","god","out","all","his","afflictions"]}]