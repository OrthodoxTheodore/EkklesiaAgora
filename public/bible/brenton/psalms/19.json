[{"verseId":"brenton_psalms_19_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":19,"verse":1,"text":"For the end, a Psalm of David.","searchKeywords":["for","the","end","psalm","david"]},{"verseId":"brenton_psalms_19_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":19,"verse":2,"text":"The Lord hear thee in the day of trouble; the name of the God of Jacob defend thee.","searchKeywords":["the","lord","hear","thee","day","trouble","name","god","jacob","defend"]},{"verseId":"brenton_psalms_19_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":19,"verse":3,"text":"Send thee help from the sanctuary, and aid thee out of Sion.","searchKeywords":["send","thee","help","from","the","sanctuary","and","aid","out","sion"]},{"verseId":"brenton_psalms_19_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":19,"verse":4,"text":"Remember all thy sacrifice, and enrich thy whole-burnt-offering. Pause.","searchKeywords":["remember","all","thy","sacrifice","and","enrich","whole","burnt","offering","pause"]},{"verseId":"brenton_psalms_19_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":19,"verse":5,"text":"Grant thee according to thy heart, and fulfil all thy desire.","searchKeywords":["grant","thee","according","thy","heart","and","fulfil","all","desire"]},{"verseId":"brenton_psalms_19_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":19,"verse":6,"text":"We will exult in thy salvation, and in the name of our God shall we be magnified: the Lord fulfil all thy petitions.","searchKeywords":["will","exult","thy","salvation","and","the","name","our","god","shall","magnified","lord","fulfil","all","petitions"]},{"verseId":"brenton_psalms_19_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":19,"verse":7,"text":"Now I know that the Lord has saved his Christ: he shall hear him from his holy heaven: the salvation of his right hand is mighty.","searchKeywords":["now","know","that","the","lord","has","saved","his","christ","shall","hear","him","from","holy","heaven","salvation","right","hand","mighty"]},{"verseId":"brenton_psalms_19_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":19,"verse":8,"text":"Some in chariots, and some in horses: but we will glory in the name of the Lord our God.","searchKeywords":["some","chariots","and","horses","but","will","glory","the","name","lord","our","god"]},{"verseId":"brenton_psalms_19_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":19,"verse":9,"text":"They are overthrown and fallen: but we are risen, and have been set upright.","searchKeywords":["they","are","overthrown","and","fallen","but","risen","have","been","set","upright"]},{"verseId":"brenton_psalms_19_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":19,"verse":10,"text":"O Lord, save the king: and hear us in whatever day we call upon thee.","searchKeywords":["lord","save","the","king","and","hear","whatever","day","call","upon","thee"]}]