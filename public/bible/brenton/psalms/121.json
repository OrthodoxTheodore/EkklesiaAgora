[{"verseId":"brenton_psalms_121_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":121,"verse":1,"text":"A Song of Degrees.","searchKeywords":["song","degrees"]},{"verseId":"brenton_psalms_121_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":121,"verse":2,"text":"Our feet stood in thy courts, O Jerusalem.","searchKeywords":["our","feet","stood","thy","courts","jerusalem"]},{"verseId":"brenton_psalms_121_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":121,"verse":3,"text":"Jerusalem is built as a city whose fellowship is complete.","searchKeywords":["jerusalem","built","city","whose","fellowship","complete"]},{"verseId":"brenton_psalms_121_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":121,"verse":4,"text":"For thither the tribes went up, the tribes of the Lord, as a testimony for Israel, to give thanks unto the name of the Lord.","searchKeywords":["for","thither","the","tribes","went","lord","testimony","israel","give","thanks","unto","name"]},{"verseId":"brenton_psalms_121_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":121,"verse":5,"text":"For there are set thrones for judgment, thrones for the house of David.","searchKeywords":["for","there","are","set","thrones","judgment","the","house","david"]},{"verseId":"brenton_psalms_121_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":121,"verse":6,"text":"Pray now for the peace of Jerusalem: and prosperity to them that love thee.","searchKeywords":["pray","now","for","the","peace","jerusalem","and","prosperity","them","that","love","thee"]},{"verseId":"brenton_psalms_121_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":121,"verse":7,"text":"Let peace, I pray, be within thine host, and prosperity in thy palaces.","searchKeywords":["let","peace","pray","within","thine","host","and","prosperity","thy","palaces"]},{"verseId":"brenton_psalms_121_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":121,"verse":8,"text":"For the sake of my brethren and my neighbours, I have indeed spoken peace concerning thee.","searchKeywords":["for","the","sake","brethren","and","neighbours","have","indeed","spoken","peace","concerning","thee"]},{"verseId":"brenton_psalms_121_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":121,"verse":9,"text":"Because of the house of the Lord our God, I have diligently sought thy good.","searchKeywords":["because","the","house","lord","our","god","have","diligently","sought","thy","good"]}]