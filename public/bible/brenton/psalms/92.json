[{"verseId":"brenton_psalms_92_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":92,"verse":1,"text":"For the day before the Sabbath, when the land was inhabited, the praise of a Song by David.","searchKeywords":["for","the","day","before","sabbath","when","land","was","inhabited","praise","song","david"]},{"verseId":"brenton_psalms_92_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":92,"verse":2,"text":"Thy throne is prepared of old: thou art from everlasting.","searchKeywords":["thy","throne","prepared","old","thou","art","from","everlasting"]},{"verseId":"brenton_psalms_92_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":92,"verse":3,"text":"The rivers have lifted up, O Lord, the rivers have lifted up their voices,","searchKeywords":["the","rivers","have","lifted","lord","their","voices"]},{"verseId":"brenton_psalms_92_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":92,"verse":4,"text":"at the voices of many waters: the billows of the sea are wonderful: the Lord is wonderful in high places.","searchKeywords":["the","voices","many","waters","billows","sea","are","wonderful","lord","high","places"]},{"verseId":"brenton_psalms_92_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":92,"verse":5,"text":"Thy testimonies are made very sure: holiness becomes thine house, O Lord, for ever.","searchKeywords":["thy","testimonies","are","made","very","sure","holiness","becomes","thine","house","lord","for","ever"]}]