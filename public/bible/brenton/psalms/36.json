[{"verseId":"brenton_psalms_36_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":1,"text":"of David.","searchKeywords":["david"]},{"verseId":"brenton_psalms_36_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":2,"text":"For they shall soon be withered as the grass, and shall soon fall away as the green herbs.","searchKeywords":["for","they","shall","soon","withered","the","grass","and","fall","away","green","herbs"]},{"verseId":"brenton_psalms_36_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":3,"text":"Hope in the Lord, and do good; and dwell on the land, and thou shalt be fed with the wealth of it.","searchKeywords":["hope","the","lord","and","good","dwell","land","thou","shalt","fed","with","wealth"]},{"verseId":"brenton_psalms_36_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":4,"text":"Delight in the Lord; and he shall grant thee the requests of thine heart.","searchKeywords":["delight","the","lord","and","shall","grant","thee","requests","thine","heart"]},{"verseId":"brenton_psalms_36_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":5,"text":"Disclose thy way to the Lord, and hope in him; and he shall bring to pass.","searchKeywords":["disclose","thy","way","the","lord","and","hope","him","shall","bring","pass"]},{"verseId":"brenton_psalms_36_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":6,"text":"And he shall bring forth thy righteousness as the light, and thy judgment as the noon-day.","searchKeywords":["and","shall","bring","forth","thy","righteousness","the","light","judgment","noon","day"]},{"verseId":"brenton_psalms_36_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":7,"text":"Submit thyself to the Lord, and supplicate him: fret not thyself because of him that prospers in his way, at the man that does unlawful deeds.","searchKeywords":["submit","thyself","the","lord","and","supplicate","him","fret","not","because","that","prospers","his","way","man","does","unlawful","deeds"]},{"verseId":"brenton_psalms_36_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":8,"text":"Cease from anger, and forsake wrath: fret not thyself so as to do evil.","searchKeywords":["cease","from","anger","and","forsake","wrath","fret","not","thyself","evil"]},{"verseId":"brenton_psalms_36_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":9,"text":"For evil-doers shall be destroyed: but they that wait on the Lord, they shall inherit the land.","searchKeywords":["for","evil","doers","shall","destroyed","but","they","that","wait","the","lord","inherit","land"]},{"verseId":"brenton_psalms_36_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":10,"text":"And yet a little while, and the sinner shall not be, and thou shalt seek for his place, and shalt not find .","searchKeywords":["and","yet","little","while","the","sinner","shall","not","thou","shalt","seek","for","his","place","find"]},{"verseId":"brenton_psalms_36_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":11,"text":"But the meek shall inherit the earth; and shall delight in the abundance of peace.","searchKeywords":["but","the","meek","shall","inherit","earth","and","delight","abundance","peace"]},{"verseId":"brenton_psalms_36_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":12,"text":"The sinner will watch for the righteous, and gnash his teeth upon him.","searchKeywords":["the","sinner","will","watch","for","righteous","and","gnash","his","teeth","upon","him"]},{"verseId":"brenton_psalms_36_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":13,"text":"But the Lord shall laugh at him: for he foresees that his day will come.","searchKeywords":["but","the","lord","shall","laugh","him","for","foresees","that","his","day","will","come"]},{"verseId":"brenton_psalms_36_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":14,"text":"Sinners have drawn their swords, they have bent their bow, to cast down the poor and needy one, to slay the upright in heart.","searchKeywords":["sinners","have","drawn","their","swords","they","bent","bow","cast","down","the","poor","and","needy","one","slay","upright","heart"]},{"verseId":"brenton_psalms_36_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":15,"text":"Let their sword enter into their heart, and their bows be broken.","searchKeywords":["let","their","sword","enter","into","heart","and","bows","broken"]},{"verseId":"brenton_psalms_36_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":16,"text":"A little is better to the righteous than abundant wealth of sinners.","searchKeywords":["little","better","the","righteous","than","abundant","wealth","sinners"]},{"verseId":"brenton_psalms_36_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":17,"text":"For the arms of sinners shall be broken; but the Lord supports the righteous.","searchKeywords":["for","the","arms","sinners","shall","broken","but","lord","supports","righteous"]},{"verseId":"brenton_psalms_36_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":18,"text":"The Lord knows the ways of the perfect; and their inheritance shall be for ever.","searchKeywords":["the","lord","knows","ways","perfect","and","their","inheritance","shall","for","ever"]},{"verseId":"brenton_psalms_36_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":19,"text":"They shall not be ashamed in an evil time; and in days of famine they shall be satisfied.","searchKeywords":["they","shall","not","ashamed","evil","time","and","days","famine","satisfied"]},{"verseId":"brenton_psalms_36_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":20,"text":"For the sinners shall perish; and the enemies of the Lord at the moment of their being honoured and exalted have utterly vanished like smoke.","searchKeywords":["for","the","sinners","shall","perish","and","enemies","lord","moment","their","being","honoured","exalted","have","utterly","vanished","like","smoke"]},{"verseId":"brenton_psalms_36_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":21,"text":"The sinner borrows, and will not pay again: but the righteous has compassion, and gives.","searchKeywords":["the","sinner","borrows","and","will","not","pay","again","but","righteous","has","compassion","gives"]},{"verseId":"brenton_psalms_36_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":22,"text":"For they that bless him shall inherit the earth; and they that curse him shall be utterly destroyed.","searchKeywords":["for","they","that","bless","him","shall","inherit","the","earth","and","curse","utterly","destroyed"]},{"verseId":"brenton_psalms_36_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":23,"text":"The steps of a man are rightly ordered by the Lord: and he will take pleasure in his way.","searchKeywords":["the","steps","man","are","rightly","ordered","lord","and","will","take","pleasure","his","way"]},{"verseId":"brenton_psalms_36_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":24,"text":"When he falls, he shall not be ruined: for the Lord supports his hand.","searchKeywords":["when","falls","shall","not","ruined","for","the","lord","supports","his","hand"]},{"verseId":"brenton_psalms_36_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":25,"text":"I was young, indeed I am now old; yet I have not seen the righteous forsaken, nor his seed seeking bread.","searchKeywords":["was","young","indeed","now","old","yet","have","not","seen","the","righteous","forsaken","nor","his","seed","seeking","bread"]},{"verseId":"brenton_psalms_36_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":26,"text":"He is merciful, and lends continually; and his seed shall be blessed.","searchKeywords":["merciful","and","lends","continually","his","seed","shall","blessed"]},{"verseId":"brenton_psalms_36_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":27,"text":"Turn aside from evil, and do good; and dwell for ever.","searchKeywords":["turn","aside","from","evil","and","good","dwell","for","ever"]},{"verseId":"brenton_psalms_36_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":28,"text":"For the Lord loves judgment, and will not forsake his saints; they shall be preserved for ever: the blameless shall be avenged, but the seed of the ungodly shall be utterly destroyed.","searchKeywords":["for","the","lord","loves","judgment","and","will","not","forsake","his","saints","they","shall","preserved","ever","blameless","avenged","but","seed","ungodly","utterly","destroyed"]},{"verseId":"brenton_psalms_36_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":29,"text":"But the righteous shall inherit the earth, and dwell upon it for ever.","searchKeywords":["but","the","righteous","shall","inherit","earth","and","dwell","upon","for","ever"]},{"verseId":"brenton_psalms_36_30","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":30,"text":"The mouth of the righteous will meditate wisdom, and his tongue will speak of judgment.","searchKeywords":["the","mouth","righteous","will","meditate","wisdom","and","his","tongue","speak","judgment"]},{"verseId":"brenton_psalms_36_31","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":31,"text":"The law of his God is in his heart; and his steps shall not slide.","searchKeywords":["the","law","his","god","heart","and","steps","shall","not","slide"]},{"verseId":"brenton_psalms_36_32","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":32,"text":"The sinner watches the righteous, and seeks to slay him.","searchKeywords":["the","sinner","watches","righteous","and","seeks","slay","him"]},{"verseId":"brenton_psalms_36_33","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":33,"text":"But the Lord will not leave him in his hands, nor by any means condemn him when he is judged.","searchKeywords":["but","the","lord","will","not","leave","him","his","hands","nor","any","means","condemn","when","judged"]},{"verseId":"brenton_psalms_36_34","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":34,"text":"Wait on the Lord, and keep his way, and he shall exalt thee to inherit the land: when the wicked are destroyed, thou shalt see .","searchKeywords":["wait","the","lord","and","keep","his","way","shall","exalt","thee","inherit","land","when","wicked","are","destroyed","thou","shalt","see"]},{"verseId":"brenton_psalms_36_35","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":35,"text":"I saw the ungodly very highly exalting himself, and lifting himself up like the cedars of Libanus.","searchKeywords":["saw","the","ungodly","very","highly","exalting","himself","and","lifting","like","cedars","libanus"]},{"verseId":"brenton_psalms_36_36","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":36,"text":"Yet I passed by, and lo! he was not: and I sought him, but his place was not found.","searchKeywords":["yet","passed","and","was","not","sought","him","but","his","place","found"]},{"verseId":"brenton_psalms_36_37","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":37,"text":"Maintain innocence, and behold uprightness: for there is a remnant to the peaceable man.","searchKeywords":["maintain","innocence","and","behold","uprightness","for","there","remnant","the","peaceable","man"]},{"verseId":"brenton_psalms_36_38","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":38,"text":"But the transgressors shall be utterly destroyed together: the remnants of the ungodly shall be utterly destroyed.","searchKeywords":["but","the","transgressors","shall","utterly","destroyed","together","remnants","ungodly"]},{"verseId":"brenton_psalms_36_39","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":39,"text":"But the salvation of the righteous is of the Lord; and he is their defender in the time of affliction.","searchKeywords":["but","the","salvation","righteous","lord","and","their","defender","time","affliction"]},{"verseId":"brenton_psalms_36_40","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":36,"verse":40,"text":"And the Lord shall help them, and deliver them: and he shall rescue them from sinners, and save them, because they have hoped in him.","searchKeywords":["and","the","lord","shall","help","them","deliver","rescue","from","sinners","save","because","they","have","hoped","him"]}]