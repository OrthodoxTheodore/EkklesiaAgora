[{"verseId":"brenton_psalms_104_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":1,"text":"Alleluia.","searchKeywords":["alleluia"]},{"verseId":"brenton_psalms_104_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":2,"text":"Sing to him, yea, sing praises to him: tell forth all his wonderful works.","searchKeywords":["sing","him","yea","praises","tell","forth","all","his","wonderful","works"]},{"verseId":"brenton_psalms_104_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":3,"text":"Glory in his holy name: let the heart of them that seek the Lord rejoice.","searchKeywords":["glory","his","holy","name","let","the","heart","them","that","seek","lord","rejoice"]},{"verseId":"brenton_psalms_104_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":4,"text":"Seek ye the Lord, and be strengthened; seek his face continually.","searchKeywords":["seek","the","lord","and","strengthened","his","face","continually"]},{"verseId":"brenton_psalms_104_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":5,"text":"Remember his wonderful works that he has done; his wonders, and the judgments of his mouth;","searchKeywords":["remember","his","wonderful","works","that","has","done","wonders","and","the","judgments","mouth"]},{"verseId":"brenton_psalms_104_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":6,"text":"seed of Abraam, his servants, children of Jacob, his chosen ones.","searchKeywords":["seed","abraam","his","servants","children","jacob","chosen","ones"]},{"verseId":"brenton_psalms_104_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":7,"text":"He is the Lord our God; his judgments are in all the earth.","searchKeywords":["the","lord","our","god","his","judgments","are","all","earth"]},{"verseId":"brenton_psalms_104_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":8,"text":"He has remembered his covenant for ever, the word which he commanded for a thousand generations:","searchKeywords":["has","remembered","his","covenant","for","ever","the","word","which","commanded","thousand","generations"]},{"verseId":"brenton_psalms_104_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":9,"text":"which he established as a covenant to Abraam, and his oath to Isaac.","searchKeywords":["which","established","covenant","abraam","and","his","oath","isaac"]},{"verseId":"brenton_psalms_104_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":10,"text":"And he established it to Jacob for an ordinance, and to Israel for an everlasting covenant;","searchKeywords":["and","established","jacob","for","ordinance","israel","everlasting","covenant"]},{"verseId":"brenton_psalms_104_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":11,"text":"saying, To thee will I give the land of Chanaan, the line of your inheritance:","searchKeywords":["saying","thee","will","give","the","land","chanaan","line","your","inheritance"]},{"verseId":"brenton_psalms_104_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":12,"text":"when they were few in number, very few, and sojourners in it.","searchKeywords":["when","they","were","few","number","very","and","sojourners"]},{"verseId":"brenton_psalms_104_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":13,"text":"And they went from nation to nation, and from kingdom to another people.","searchKeywords":["and","they","went","from","nation","kingdom","another","people"]},{"verseId":"brenton_psalms_104_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":14,"text":"He suffered no man to wrong them; and he rebuked kings for their sakes:","searchKeywords":["suffered","man","wrong","them","and","rebuked","kings","for","their","sakes"]},{"verseId":"brenton_psalms_104_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":15,"text":", Touch not my anointed ones; and do my prophets no harm.","searchKeywords":["touch","not","anointed","ones","and","prophets","harm"]},{"verseId":"brenton_psalms_104_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":16,"text":"Moreover he called for a famine upon the land; he broke the whole support of bread.","searchKeywords":["moreover","called","for","famine","upon","the","land","broke","whole","support","bread"]},{"verseId":"brenton_psalms_104_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":17,"text":"He sent a man before them; Joseph was sold for a slave.","searchKeywords":["sent","man","before","them","joseph","was","sold","for","slave"]},{"verseId":"brenton_psalms_104_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":18,"text":"They hurt his feet with fetters; his soul passed into iron,","searchKeywords":["they","hurt","his","feet","with","fetters","soul","passed","into","iron"]},{"verseId":"brenton_psalms_104_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":19,"text":"until the time that his cause came on; the word of the Lord tried him as fire.","searchKeywords":["until","the","time","that","his","cause","came","word","lord","tried","him","fire"]},{"verseId":"brenton_psalms_104_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":20,"text":"The king sent and loosed him; the prince of the people, and let him go free.","searchKeywords":["the","king","sent","and","loosed","him","prince","people","let","free"]},{"verseId":"brenton_psalms_104_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":21,"text":"He made him lord over his house, and ruler of all his substance;","searchKeywords":["made","him","lord","over","his","house","and","ruler","all","substance"]},{"verseId":"brenton_psalms_104_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":22,"text":"to chastise his rulers at his pleasure, and to teach his elders wisdom.","searchKeywords":["chastise","his","rulers","pleasure","and","teach","elders","wisdom"]},{"verseId":"brenton_psalms_104_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":23,"text":"Israel also came into Egypt, and Jacob sojourned in the land of Cham.","searchKeywords":["israel","also","came","into","egypt","and","jacob","sojourned","the","land","cham"]},{"verseId":"brenton_psalms_104_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":24,"text":"And he increased his people greatly, and made them stronger than their enemies.","searchKeywords":["and","increased","his","people","greatly","made","them","stronger","than","their","enemies"]},{"verseId":"brenton_psalms_104_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":25,"text":"And he turned their heart to hate his people, to deal craftily with his servants.","searchKeywords":["and","turned","their","heart","hate","his","people","deal","craftily","with","servants"]},{"verseId":"brenton_psalms_104_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":26,"text":"He sent forth Moses his servant, Aaron whom he had chosen.","searchKeywords":["sent","forth","moses","his","servant","aaron","whom","had","chosen"]},{"verseId":"brenton_psalms_104_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":27,"text":"He established among them his signs, and wonders in the land of Cham.","searchKeywords":["established","among","them","his","signs","and","wonders","the","land","cham"]},{"verseId":"brenton_psalms_104_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":28,"text":"He sent forth darkness, and made it dark; yet they rebelled against his words.","searchKeywords":["sent","forth","darkness","and","made","dark","yet","they","rebelled","against","his","words"]},{"verseId":"brenton_psalms_104_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":29,"text":"He turned their waters into blood, and slew their fish.","searchKeywords":["turned","their","waters","into","blood","and","slew","fish"]},{"verseId":"brenton_psalms_104_30","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":30,"text":"Their land produced frogs abundantly, in the chambers of their kings.","searchKeywords":["their","land","produced","frogs","abundantly","the","chambers","kings"]},{"verseId":"brenton_psalms_104_31","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":31,"text":"He spoke, and the dog-fly came, and lice in all their coasts.","searchKeywords":["spoke","and","the","dog","fly","came","lice","all","their","coasts"]},{"verseId":"brenton_psalms_104_32","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":32,"text":"He turned their rain into hail, flaming fire in their land.","searchKeywords":["turned","their","rain","into","hail","flaming","fire","land"]},{"verseId":"brenton_psalms_104_33","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":33,"text":"And he smote their vines and their fig-trees; and broke every tree of their coast.","searchKeywords":["and","smote","their","vines","fig","trees","broke","every","tree","coast"]},{"verseId":"brenton_psalms_104_34","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":34,"text":"He spoke, and the locust came, and caterpillars innumerable,","searchKeywords":["spoke","and","the","locust","came","caterpillars","innumerable"]},{"verseId":"brenton_psalms_104_35","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":35,"text":"and devoured all the grass in their land, and devoured the fruit of their ground.","searchKeywords":["and","devoured","all","the","grass","their","land","fruit","ground"]},{"verseId":"brenton_psalms_104_36","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":36,"text":"He smote also every first-born of their land, the first-fruits of all their labour.","searchKeywords":["smote","also","every","first","born","their","land","the","fruits","all","labour"]},{"verseId":"brenton_psalms_104_37","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":37,"text":"And he brought them out with silver and gold; and there was not a feeble one among their tribes.","searchKeywords":["and","brought","them","out","with","silver","gold","there","was","not","feeble","one","among","their","tribes"]},{"verseId":"brenton_psalms_104_38","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":38,"text":"Egypt rejoiced at their departing; for the fear of them fell upon them.","searchKeywords":["egypt","rejoiced","their","departing","for","the","fear","them","fell","upon"]},{"verseId":"brenton_psalms_104_39","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":39,"text":"He spread out a cloud for a covering to them, and fire to give them light by night.","searchKeywords":["spread","out","cloud","for","covering","them","and","fire","give","light","night"]},{"verseId":"brenton_psalms_104_40","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":40,"text":"They asked, and the quail came, and he satisfied them with the bread of heaven.","searchKeywords":["they","asked","and","the","quail","came","satisfied","them","with","bread","heaven"]},{"verseId":"brenton_psalms_104_41","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":41,"text":"He clave the rock, and the waters flowed; rivers ran in dry places.","searchKeywords":["clave","the","rock","and","waters","flowed","rivers","ran","dry","places"]},{"verseId":"brenton_psalms_104_42","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":42,"text":"For he remembered his holy word, which to Abraam his servant.","searchKeywords":["for","remembered","his","holy","word","which","abraam","servant"]},{"verseId":"brenton_psalms_104_43","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":43,"text":"And he brought out his people with exultation, and his chosen with joy;","searchKeywords":["and","brought","out","his","people","with","exultation","chosen","joy"]},{"verseId":"brenton_psalms_104_44","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":44,"text":"and gave them the lands of the heathen; and they inherited the labours of the people;","searchKeywords":["and","gave","them","the","lands","heathen","they","inherited","labours","people"]},{"verseId":"brenton_psalms_104_45","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":104,"verse":45,"text":"that they might keep his ordinances, and diligently seek his law.","searchKeywords":["that","they","might","keep","his","ordinances","and","diligently","seek","law"]}]