[{"verseId":"brenton_psalms_124_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":124,"verse":1,"text":"A Song of Degrees. as mount Sion: he that dwells in Jerusalem shall never be moved.","searchKeywords":["song","degrees","mount","sion","that","dwells","jerusalem","shall","never","moved"]},{"verseId":"brenton_psalms_124_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":124,"verse":2,"text":"The mountains are round about her, and the Lord is round about his people, from henceforth and even for ever.","searchKeywords":["the","mountains","are","round","about","her","and","lord","his","people","from","henceforth","even","for","ever"]},{"verseId":"brenton_psalms_124_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":124,"verse":3,"text":"For the Lord will not allow the rod of sinners to be upon the lot of the righteous; lest the righteous should stretch forth their hands to iniquity.","searchKeywords":["for","the","lord","will","not","allow","rod","sinners","upon","lot","righteous","lest","should","stretch","forth","their","hands","iniquity"]},{"verseId":"brenton_psalms_124_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":124,"verse":4,"text":"Do good, O Lord, to them good, and to them upright in heart.","searchKeywords":["good","lord","them","and","upright","heart"]},{"verseId":"brenton_psalms_124_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":124,"verse":5,"text":"But them that turn aside to crooked ways the Lord will lead away with the workers of iniquity: peace upon Israel.","searchKeywords":["but","them","that","turn","aside","crooked","ways","the","lord","will","lead","away","with","workers","iniquity","peace","upon","israel"]}]