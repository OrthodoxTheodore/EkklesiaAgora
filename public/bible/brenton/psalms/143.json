[{"verseId":"brenton_psalms_143_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":1,"text":"of David concerning Goliad. the Lord my God, who instructs my hands for battle, my fingers for war.","searchKeywords":["david","concerning","goliad","the","lord","god","who","instructs","hands","for","battle","fingers","war"]},{"verseId":"brenton_psalms_143_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":2,"text":"My mercy, and my refuge; my helper, and my deliverer; my protector, in whom I have trusted; who subdues my people under me.","searchKeywords":["mercy","and","refuge","helper","deliverer","protector","whom","have","trusted","who","subdues","people","under"]},{"verseId":"brenton_psalms_143_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":3,"text":"Lord, what is man, that thou art made known to him? or the son of man, that thou takest account of him?","searchKeywords":["lord","what","man","that","thou","art","made","known","him","the","son","takest","account"]},{"verseId":"brenton_psalms_143_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":4,"text":"Man is like to vanity: his days pass as a shadow.","searchKeywords":["man","like","vanity","his","days","pass","shadow"]},{"verseId":"brenton_psalms_143_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":5,"text":"O Lord, bow thy heavens, and come down: touch the mountains, and they shall smoke.","searchKeywords":["lord","bow","thy","heavens","and","come","down","touch","the","mountains","they","shall","smoke"]},{"verseId":"brenton_psalms_143_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":6,"text":"Send lightning, and thou shalt scatter them: send forth thine arrows, and thou shalt discomfit them.","searchKeywords":["send","lightning","and","thou","shalt","scatter","them","forth","thine","arrows","discomfit"]},{"verseId":"brenton_psalms_143_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":7,"text":"Send forth thine hand from on high; rescue me, and deliver me out of great waters, out of the hand of strange children;","searchKeywords":["send","forth","thine","hand","from","high","rescue","and","deliver","out","great","waters","the","strange","children"]},{"verseId":"brenton_psalms_143_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":8,"text":"whose mouth has spoken vanity, and their right hand is a right hand of iniquity.","searchKeywords":["whose","mouth","has","spoken","vanity","and","their","right","hand","iniquity"]},{"verseId":"brenton_psalms_143_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":9,"text":"O God, I will sing a new song to thee: I will play to thee on a psaltery of ten strings.","searchKeywords":["god","will","sing","new","song","thee","play","psaltery","ten","strings"]},{"verseId":"brenton_psalms_143_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":10,"text":"to him who gives salvation to kings: who redeems his servant David from the hurtful sword.","searchKeywords":["him","who","gives","salvation","kings","redeems","his","servant","david","from","the","hurtful","sword"]},{"verseId":"brenton_psalms_143_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":11,"text":"Deliver me, and rescue me from the hand of strange children, whose mouth has spoken vanity, and their right hand is a right hand of iniquity;","searchKeywords":["deliver","and","rescue","from","the","hand","strange","children","whose","mouth","has","spoken","vanity","their","right","iniquity"]},{"verseId":"brenton_psalms_143_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":12,"text":"whose children are as plants, strengthened in their youth: their daughters are beautiful, sumptuously adorned after the similitude of a temple.","searchKeywords":["whose","children","are","plants","strengthened","their","youth","daughters","beautiful","sumptuously","adorned","after","the","similitude","temple"]},{"verseId":"brenton_psalms_143_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":13,"text":"Their garners are full, and bursting with one kind of store after another; their sheep are prolific, multiplying in their streets.","searchKeywords":["their","garners","are","full","and","bursting","with","one","kind","store","after","another","sheep","prolific","multiplying","streets"]},{"verseId":"brenton_psalms_143_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":14,"text":"Their oxen are fat: there is no falling down of a hedge, nor going out, nor cry in their folds.","searchKeywords":["their","oxen","are","fat","there","falling","down","hedge","nor","going","out","cry","folds"]},{"verseId":"brenton_psalms_143_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":143,"verse":15,"text":"Men bless the people to whom this lot belongs, blessed is the people whose God is the Lord.","searchKeywords":["men","bless","the","people","whom","this","lot","belongs","blessed","whose","god","lord"]}]