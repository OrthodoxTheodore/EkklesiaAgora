[{"verseId":"brenton_psalms_142_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":142,"verse":1,"text":"A Psalm of David, when his son pursued him.","searchKeywords":["psalm","david","when","his","son","pursued","him"]},{"verseId":"brenton_psalms_142_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":142,"verse":2,"text":"And enter not into judgment with thy servant, for in thy sight shall no living be justified.","searchKeywords":["and","enter","not","into","judgment","with","thy","servant","for","sight","shall","living","justified"]},{"verseId":"brenton_psalms_142_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":142,"verse":3,"text":"For the enemy has persecuted my soul; he has brought my life down to the ground; he has made me to dwell in a dark , as those that have been long dead.","searchKeywords":["for","the","enemy","has","persecuted","soul","brought","life","down","ground","made","dwell","dark","those","that","have","been","long","dead"]},{"verseId":"brenton_psalms_142_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":142,"verse":4,"text":"Therefore my spirit was grieved in me; my heart was troubled within me.","searchKeywords":["therefore","spirit","was","grieved","heart","troubled","within"]},{"verseId":"brenton_psalms_142_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":142,"verse":5,"text":"I remembered the days of old; and I meditated on all thy doings: , I meditated on the works of thine hands.","searchKeywords":["remembered","the","days","old","and","meditated","all","thy","doings","works","thine","hands"]},{"verseId":"brenton_psalms_142_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":142,"verse":6,"text":"I spread forth my hands to thee; my soul for thee, as a dry land. Pause.","searchKeywords":["spread","forth","hands","thee","soul","for","dry","land","pause"]},{"verseId":"brenton_psalms_142_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":142,"verse":7,"text":"Hear me speedily, O Lord; my spirit has failed; turn not away thy face from me, else I shall be like to them that go down to the pit.","searchKeywords":["hear","speedily","lord","spirit","has","failed","turn","not","away","thy","face","from","else","shall","like","them","that","down","the","pit"]},{"verseId":"brenton_psalms_142_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":142,"verse":8,"text":"Cause me to hear thy mercy in the morning; for I have hoped in thee; make known to me, O Lord, the way wherein I should walk; for I have lifted up my soul to thee.","searchKeywords":["cause","hear","thy","mercy","the","morning","for","have","hoped","thee","make","known","lord","way","wherein","should","walk","lifted","soul"]},{"verseId":"brenton_psalms_142_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":142,"verse":9,"text":"Deliver me from mine enemies, O Lord; for I have fled to thee for refuge.","searchKeywords":["deliver","from","mine","enemies","lord","for","have","fled","thee","refuge"]},{"verseId":"brenton_psalms_142_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":142,"verse":10,"text":"Teach me to do thy will; for thou art my God; thy good Spirit shall guide me in the straight .","searchKeywords":["teach","thy","will","for","thou","art","god","good","spirit","shall","guide","the","straight"]},{"verseId":"brenton_psalms_142_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":142,"verse":11,"text":"Thou shalt quicken me, O Lord, for thy name's sake; in thy righteousness thou shalt bring my soul out of affliction.","searchKeywords":["thou","shalt","quicken","lord","for","thy","name","sake","righteousness","bring","soul","out","affliction"]},{"verseId":"brenton_psalms_142_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":142,"verse":12,"text":"And in thy mercy thou wilt destroy mine enemies, and wilt destroy all those that afflict my soul; for I am thy servant.","searchKeywords":["and","thy","mercy","thou","wilt","destroy","mine","enemies","all","those","that","afflict","soul","for","servant"]}]