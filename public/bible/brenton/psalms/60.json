[{"verseId":"brenton_psalms_60_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":60,"verse":1,"text":"For the end, among the Hymns of David.","searchKeywords":["for","the","end","among","hymns","david"]},{"verseId":"brenton_psalms_60_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":60,"verse":2,"text":"O God, hearken to my petition; attend to my prayer.","searchKeywords":["god","hearken","petition","attend","prayer"]},{"verseId":"brenton_psalms_60_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":60,"verse":3,"text":"From the ends of the earth have I cried to thee, when my heart was in trouble: thou liftedst me up on a rock, thou didst guide me:","searchKeywords":["from","the","ends","earth","have","cried","thee","when","heart","was","trouble","thou","liftedst","rock","didst","guide"]},{"verseId":"brenton_psalms_60_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":60,"verse":4,"text":"because thou wert my hope, a tower of strength from the face of the enemy.","searchKeywords":["because","thou","wert","hope","tower","strength","from","the","face","enemy"]},{"verseId":"brenton_psalms_60_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":60,"verse":5,"text":"I will dwell in thy tabernacle for ever; I will shelter myself under the shadow of thy wings. Pause.","searchKeywords":["will","dwell","thy","tabernacle","for","ever","shelter","myself","under","the","shadow","wings","pause"]},{"verseId":"brenton_psalms_60_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":60,"verse":6,"text":"For thou, O God, hast heard my prayers; thou hast given an inheritance to them that fear thy name.","searchKeywords":["for","thou","god","hast","heard","prayers","given","inheritance","them","that","fear","thy","name"]},{"verseId":"brenton_psalms_60_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":60,"verse":7,"text":"Thou shalt add days to the days of the king; his years to all generations.","searchKeywords":["thou","shalt","add","days","the","king","his","years","all","generations"]},{"verseId":"brenton_psalms_60_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":60,"verse":8,"text":"He shall endure for ever before God: which of them will seek out his mercy and truth?","searchKeywords":["shall","endure","for","ever","before","god","which","them","will","seek","out","his","mercy","and","truth"]},{"verseId":"brenton_psalms_60_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":60,"verse":9,"text":"So will I sing to thy name for ever and ever, that I may daily perform my vows.","searchKeywords":["will","sing","thy","name","for","ever","and","that","may","daily","perform","vows"]}]