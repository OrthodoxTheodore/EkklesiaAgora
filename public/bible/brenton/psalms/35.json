[{"verseId":"brenton_psalms_35_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":35,"verse":1,"text":"For the end, by David the servant of the Lord.","searchKeywords":["for","the","end","david","servant","lord"]},{"verseId":"brenton_psalms_35_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":35,"verse":2,"text":"The transgressor, that he may sin, says within himself, there is no fear of God before his eyes.","searchKeywords":["the","transgressor","that","may","sin","says","within","himself","there","fear","god","before","his","eyes"]},{"verseId":"brenton_psalms_35_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":35,"verse":3,"text":"For he has dealt craftily before him, to discover his iniquity and hate it.","searchKeywords":["for","has","dealt","craftily","before","him","discover","his","iniquity","and","hate"]},{"verseId":"brenton_psalms_35_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":35,"verse":4,"text":"The words of his mouth are transgression and deceit: he is not inclined to understand to do good.","searchKeywords":["the","words","his","mouth","are","transgression","and","deceit","not","inclined","understand","good"]},{"verseId":"brenton_psalms_35_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":35,"verse":5,"text":"He devises iniquity on his bed; he gives himself to every evil way; and does not abhor evil.","searchKeywords":["devises","iniquity","his","bed","gives","himself","every","evil","way","and","does","not","abhor"]},{"verseId":"brenton_psalms_35_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":35,"verse":6,"text":"O Lord, thy mercy is in the heaven; and thy truth to the clouds.","searchKeywords":["lord","thy","mercy","the","heaven","and","truth","clouds"]},{"verseId":"brenton_psalms_35_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":35,"verse":7,"text":"Thy righteousness is as the mountains of God, thy judgments are as a great deep: O Lord, thou wilt preserve men and beasts.","searchKeywords":["thy","righteousness","the","mountains","god","judgments","are","great","deep","lord","thou","wilt","preserve","men","and","beasts"]},{"verseId":"brenton_psalms_35_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":35,"verse":8,"text":"How hast thou multiplied thy mercy, O God! so the children of men shall trust in the shelter of thy wings.","searchKeywords":["how","hast","thou","multiplied","thy","mercy","god","the","children","men","shall","trust","shelter","wings"]},{"verseId":"brenton_psalms_35_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":35,"verse":9,"text":"They shall be fully satisfied with the fatness of thine house; and thou shalt cause them to drink of the full stream of thy delights.","searchKeywords":["they","shall","fully","satisfied","with","the","fatness","thine","house","and","thou","shalt","cause","them","drink","full","stream","thy","delights"]},{"verseId":"brenton_psalms_35_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":35,"verse":10,"text":"For with thee is the fountain of life: in thy light we shall see light.","searchKeywords":["for","with","thee","the","fountain","life","thy","light","shall","see"]},{"verseId":"brenton_psalms_35_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":35,"verse":11,"text":"Extend thy mercy to them that know thee; and thy righteousness to the upright in heart.","searchKeywords":["extend","thy","mercy","them","that","know","thee","and","righteousness","the","upright","heart"]},{"verseId":"brenton_psalms_35_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":35,"verse":12,"text":"Let not the foot of pride come against me, and let not the hand of sinners move me.","searchKeywords":["let","not","the","foot","pride","come","against","and","hand","sinners","move"]},{"verseId":"brenton_psalms_35_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":35,"verse":13,"text":"There have all the workers of iniquity fallen: they are cast out, and shall not be able to stand.","searchKeywords":["there","have","all","the","workers","iniquity","fallen","they","are","cast","out","and","shall","not","able","stand"]}]