[{"verseId":"brenton_psalms_44_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":1,"text":"For the end, for alternate by the sons of Core; for instruction, a Song concerning the beloved.","searchKeywords":["for","the","end","alternate","sons","core","instruction","song","concerning","beloved"]},{"verseId":"brenton_psalms_44_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":2,"text":"My heart has uttered a good matter: I declare my works to the king: my tongue is the pen of a quick writer.","searchKeywords":["heart","has","uttered","good","matter","declare","works","the","king","tongue","pen","quick","writer"]},{"verseId":"brenton_psalms_44_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":3,"text":"Thou art more beautiful than the sons of men: grace has been shed forth on thy lips: therefore God has blessed thee for ever.","searchKeywords":["thou","art","more","beautiful","than","the","sons","men","grace","has","been","shed","forth","thy","lips","therefore","god","blessed","thee","for","ever"]},{"verseId":"brenton_psalms_44_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":4,"text":"Gird thy sword upon thy thigh, O Mighty One, in thy comeliness, and in thy beauty;","searchKeywords":["gird","thy","sword","upon","thigh","mighty","one","comeliness","and","beauty"]},{"verseId":"brenton_psalms_44_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":5,"text":"and bend , and prosper, and reign, because of truth and meekness and righteousness; and thy right hand shall guide thee wonderfully.","searchKeywords":["and","bend","prosper","reign","because","truth","meekness","righteousness","thy","right","hand","shall","guide","thee","wonderfully"]},{"verseId":"brenton_psalms_44_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":6,"text":"Thy weapons are sharpened, Mighty One, (the nations shall fall under thee) in the heart of the king's enemies.","searchKeywords":["thy","weapons","are","sharpened","mighty","one","the","nations","shall","fall","under","thee","heart","king","enemies"]},{"verseId":"brenton_psalms_44_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":7,"text":"Thy throne, O God, is for ever and ever: the sceptre of thy kingdom is a sceptre of righteousness.","searchKeywords":["thy","throne","god","for","ever","and","the","sceptre","kingdom","righteousness"]},{"verseId":"brenton_psalms_44_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":8,"text":"Thou hast loved righteousness, and hated iniquity: therefore God, thy God, has anointed thee with the oil of gladness beyond thy fellows.","searchKeywords":["thou","hast","loved","righteousness","and","hated","iniquity","therefore","god","thy","has","anointed","thee","with","the","oil","gladness","beyond","fellows"]},{"verseId":"brenton_psalms_44_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":9,"text":"Myrrh, and stacte, and cassia from thy garments, out of the ivory palaces,","searchKeywords":["myrrh","and","stacte","cassia","from","thy","garments","out","the","ivory","palaces"]},{"verseId":"brenton_psalms_44_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":10,"text":"with which kings' daughters have gladdened thee for thine honour: the queen stood by on thy right hand, clothed in vesture wrought with gold, arrayed in divers colours.","searchKeywords":["with","which","kings","daughters","have","gladdened","thee","for","thine","honour","the","queen","stood","thy","right","hand","clothed","vesture","wrought","gold","arrayed","divers","colours"]},{"verseId":"brenton_psalms_44_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":11,"text":"Hear, O daughter, and see, and incline thine ear; forget also thy people, and thy father's house.","searchKeywords":["hear","daughter","and","see","incline","thine","ear","forget","also","thy","people","father","house"]},{"verseId":"brenton_psalms_44_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":12,"text":"Because the king has desired thy beauty; for he is thy Lord.","searchKeywords":["because","the","king","has","desired","thy","beauty","for","lord"]},{"verseId":"brenton_psalms_44_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":13,"text":"And the daughter of Tyre shall adore him with gifts; the rich of the people of the land shall supplicate thy favour.","searchKeywords":["and","the","daughter","tyre","shall","adore","him","with","gifts","rich","people","land","supplicate","thy","favour"]},{"verseId":"brenton_psalms_44_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":14,"text":"All her glory of the daughter of the king of Esebon, robed in golden fringed garments,","searchKeywords":["all","her","glory","the","daughter","king","esebon","robed","golden","fringed","garments"]},{"verseId":"brenton_psalms_44_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":15,"text":"in embroidered : virgins shall be brought to the king after her: her fellows shall be brought to thee.","searchKeywords":["embroidered","virgins","shall","brought","the","king","after","her","fellows","thee"]},{"verseId":"brenton_psalms_44_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":16,"text":"They shall be brought with gladness and exultation: they shall be led into the king's temple.","searchKeywords":["they","shall","brought","with","gladness","and","exultation","led","into","the","king","temple"]},{"verseId":"brenton_psalms_44_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":17,"text":"Instead of thy fathers children are born to thee: thou shalt make them princes over all the earth.","searchKeywords":["instead","thy","fathers","children","are","born","thee","thou","shalt","make","them","princes","over","all","the","earth"]},{"verseId":"brenton_psalms_44_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":44,"verse":18,"text":"They shall make mention of thy name from generation to generation: therefore shall the nations give thanks to thee for ever, even for ever and ever.","searchKeywords":["they","shall","make","mention","thy","name","from","generation","therefore","the","nations","give","thanks","thee","for","ever","even","and"]}]