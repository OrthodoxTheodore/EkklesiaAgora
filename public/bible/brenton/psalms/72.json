[{"verseId":"brenton_psalms_72_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":1,"text":"A Psalm for Asaph.","searchKeywords":["psalm","for","asaph"]},{"verseId":"brenton_psalms_72_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":2,"text":"But my feet were almost overthrown; my goings very nearly slipped.","searchKeywords":["but","feet","were","almost","overthrown","goings","very","nearly","slipped"]},{"verseId":"brenton_psalms_72_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":3,"text":"For I was jealous of the transgressors, beholding the tranquillity of sinners.","searchKeywords":["for","was","jealous","the","transgressors","beholding","tranquillity","sinners"]},{"verseId":"brenton_psalms_72_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":4,"text":"For there is no sign of reluctance in their death: and firmness under their affliction.","searchKeywords":["for","there","sign","reluctance","their","death","and","firmness","under","affliction"]},{"verseId":"brenton_psalms_72_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":5,"text":"They are not in the troubles of men; and they shall not be scourged with men.","searchKeywords":["they","are","not","the","troubles","men","and","shall","scourged","with"]},{"verseId":"brenton_psalms_72_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":6,"text":"Therefore pride has possessed them; they have clothed themselves with their injustice and ungodliness.","searchKeywords":["therefore","pride","has","possessed","them","they","have","clothed","themselves","with","their","injustice","and","ungodliness"]},{"verseId":"brenton_psalms_72_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":7,"text":"Their injustice shall go forth as out of fatness: they have fulfilled their intention.","searchKeywords":["their","injustice","shall","forth","out","fatness","they","have","fulfilled","intention"]},{"verseId":"brenton_psalms_72_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":8,"text":"They have taken counsel and spoken in wickedness: they have uttered unrighteousness loftily.","searchKeywords":["they","have","taken","counsel","and","spoken","wickedness","uttered","unrighteousness","loftily"]},{"verseId":"brenton_psalms_72_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":9,"text":"They have set their mouth against heaven, and their tongue has gone through upon the earth.","searchKeywords":["they","have","set","their","mouth","against","heaven","and","tongue","has","gone","through","upon","the","earth"]},{"verseId":"brenton_psalms_72_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":10,"text":"Therefore shall my people return hither: and full days shall be found with them.","searchKeywords":["therefore","shall","people","return","hither","and","full","days","found","with","them"]},{"verseId":"brenton_psalms_72_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":11,"text":"And they said, How does God know? and is there knowledge in the Most High?","searchKeywords":["and","they","said","how","does","god","know","there","knowledge","the","most","high"]},{"verseId":"brenton_psalms_72_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":12,"text":"Behold, these the sinners, and they that prosper always: they have possessed wealth.","searchKeywords":["behold","these","the","sinners","and","they","that","prosper","always","have","possessed","wealth"]},{"verseId":"brenton_psalms_72_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":13,"text":"And I said, Verily in vain have I justified my heart, and washed my hands in innocency.","searchKeywords":["and","said","verily","vain","have","justified","heart","washed","hands","innocency"]},{"verseId":"brenton_psalms_72_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":14,"text":"For I was plagued all the day, and my reproof every morning.","searchKeywords":["for","was","plagued","all","the","day","and","reproof","every","morning"]},{"verseId":"brenton_psalms_72_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":15,"text":"If I said, I will speak thus; behold, I have broken covenant with the generation of thy children.","searchKeywords":["said","will","speak","thus","behold","have","broken","covenant","with","the","generation","thy","children"]},{"verseId":"brenton_psalms_72_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":16,"text":"And I undertook to understand this, it is too hard for me,","searchKeywords":["and","undertook","understand","this","too","hard","for"]},{"verseId":"brenton_psalms_72_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":17,"text":"until I go into the sanctuary of God; understand the latter end.","searchKeywords":["until","into","the","sanctuary","god","understand","latter","end"]},{"verseId":"brenton_psalms_72_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":18,"text":"Surely thou hast appointed to them because of their crafty dealings: thou hast cast them down when they were lifted up.","searchKeywords":["surely","thou","hast","appointed","them","because","their","crafty","dealings","cast","down","when","they","were","lifted"]},{"verseId":"brenton_psalms_72_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":19,"text":"How have they become desolate! suddenly they have failed: they have perished because of their iniquity.","searchKeywords":["how","have","they","become","desolate","suddenly","failed","perished","because","their","iniquity"]},{"verseId":"brenton_psalms_72_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":20,"text":"As the dream of one awakening, O Lord, in thy city thou wilt despise their image.","searchKeywords":["the","dream","one","awakening","lord","thy","city","thou","wilt","despise","their","image"]},{"verseId":"brenton_psalms_72_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":21,"text":"For my heart has rejoiced, and my reins have been gladdened.","searchKeywords":["for","heart","has","rejoiced","and","reins","have","been","gladdened"]},{"verseId":"brenton_psalms_72_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":22,"text":"But I vile and knew not: I became brutish before thee.","searchKeywords":["but","vile","and","knew","not","became","brutish","before","thee"]},{"verseId":"brenton_psalms_72_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":23,"text":"Yet I am continually with thee: thou hast holden my right hand.","searchKeywords":["yet","continually","with","thee","thou","hast","holden","right","hand"]},{"verseId":"brenton_psalms_72_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":24,"text":"Thou hast guided me by thy counsel, and thou hast taken me to thyself with glory.","searchKeywords":["thou","hast","guided","thy","counsel","and","taken","thyself","with","glory"]},{"verseId":"brenton_psalms_72_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":25,"text":"For what have I in heaven ? and what have I desired upon the earth beside thee?","searchKeywords":["for","what","have","heaven","and","desired","upon","the","earth","beside","thee"]},{"verseId":"brenton_psalms_72_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":26,"text":"My heart and my flesh have failed: God of my heart, and God is my portion for ever.","searchKeywords":["heart","and","flesh","have","failed","god","portion","for","ever"]},{"verseId":"brenton_psalms_72_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":27,"text":"For, behold, they that remove themselves far from thee shall perish: thou hast destroyed every one that goes a whoring from thee.","searchKeywords":["for","behold","they","that","remove","themselves","far","from","thee","shall","perish","thou","hast","destroyed","every","one","goes","whoring"]},{"verseId":"brenton_psalms_72_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":72,"verse":28,"text":"But it is good for me to cleave close to God, to put my trust in the Lord; that I may proclaim all thy praises in the gates of the daughter of Sion.","searchKeywords":["but","good","for","cleave","close","god","put","trust","the","lord","that","may","proclaim","all","thy","praises","gates","daughter","sion"]}]