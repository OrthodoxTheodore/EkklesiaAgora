[{"verseId":"brenton_psalms_106_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":1,"text":"Alleluia. for ever.","searchKeywords":["alleluia","for","ever"]},{"verseId":"brenton_psalms_106_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":2,"text":"Let them say who have been redeemed by the Lord, whom he has redeemed from the hand of the enemy;","searchKeywords":["let","them","say","who","have","been","redeemed","the","lord","whom","has","from","hand","enemy"]},{"verseId":"brenton_psalms_106_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":3,"text":"and gathered them out of the countries, from the east, and west, and north, and south.","searchKeywords":["and","gathered","them","out","the","countries","from","east","west","north","south"]},{"verseId":"brenton_psalms_106_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":4,"text":"They wandered in the wilderness in a dry land; they found no way to a city of habitation.","searchKeywords":["they","wandered","the","wilderness","dry","land","found","way","city","habitation"]},{"verseId":"brenton_psalms_106_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":5,"text":"Hungry and thirsty, their soul fainted in them.","searchKeywords":["hungry","and","thirsty","their","soul","fainted","them"]},{"verseId":"brenton_psalms_106_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":6,"text":"Then they cried to the Lord in their affliction, and he delivered them out of their distresses.","searchKeywords":["then","they","cried","the","lord","their","affliction","and","delivered","them","out","distresses"]},{"verseId":"brenton_psalms_106_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":7,"text":"And he guided them into a straight path, that they might go to a city of habitation.","searchKeywords":["and","guided","them","into","straight","path","that","they","might","city","habitation"]},{"verseId":"brenton_psalms_106_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":8,"text":"Let them acknowledge to the Lord his mercies, and his wonderful works to the children of men.","searchKeywords":["let","them","acknowledge","the","lord","his","mercies","and","wonderful","works","children","men"]},{"verseId":"brenton_psalms_106_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":9,"text":"For he satisfies the empty soul, and fills the hungry with good things,","searchKeywords":["for","satisfies","the","empty","soul","and","fills","hungry","with","good","things"]},{"verseId":"brenton_psalms_106_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":10,"text":"them that sit in darkness and the shadow of death, fettered in poverty and iron;","searchKeywords":["them","that","sit","darkness","and","the","shadow","death","fettered","poverty","iron"]},{"verseId":"brenton_psalms_106_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":11,"text":"because they rebelled against the words of God, and provoked the counsel of the Most High.","searchKeywords":["because","they","rebelled","against","the","words","god","and","provoked","counsel","most","high"]},{"verseId":"brenton_psalms_106_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":12,"text":"So their heart was brought low with troubles; they were weak, and there was no helper.","searchKeywords":["their","heart","was","brought","low","with","troubles","they","were","weak","and","there","helper"]},{"verseId":"brenton_psalms_106_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":13,"text":"Then they cried to the Lord in their affliction, and he saved them out of their distresses.","searchKeywords":["then","they","cried","the","lord","their","affliction","and","saved","them","out","distresses"]},{"verseId":"brenton_psalms_106_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":14,"text":"And he brought them out of darkness and the shadow of death, and broke their bonds asunder.","searchKeywords":["and","brought","them","out","darkness","the","shadow","death","broke","their","bonds","asunder"]},{"verseId":"brenton_psalms_106_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":15,"text":"Let them acknowledge to the Lord his mercies, and his wonders to the children of men.","searchKeywords":["let","them","acknowledge","the","lord","his","mercies","and","wonders","children","men"]},{"verseId":"brenton_psalms_106_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":16,"text":"For he broke to pieces the brazen gates, and crushed the iron bars.","searchKeywords":["for","broke","pieces","the","brazen","gates","and","crushed","iron","bars"]},{"verseId":"brenton_psalms_106_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":17,"text":"He helped them out of the way of their iniquity; for they were brought low because of their iniquities.","searchKeywords":["helped","them","out","the","way","their","iniquity","for","they","were","brought","low","because","iniquities"]},{"verseId":"brenton_psalms_106_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":18,"text":"Their soul abhorred all meat; and they drew near to the gates of death.","searchKeywords":["their","soul","abhorred","all","meat","and","they","drew","near","the","gates","death"]},{"verseId":"brenton_psalms_106_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":19,"text":"Then they cried to the Lord in their affliction, and he saved them out of their distresses.","searchKeywords":["then","they","cried","the","lord","their","affliction","and","saved","them","out","distresses"]},{"verseId":"brenton_psalms_106_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":20,"text":"He sent his word, and healed them, and delivered them out of their destructions.","searchKeywords":["sent","his","word","and","healed","them","delivered","out","their","destructions"]},{"verseId":"brenton_psalms_106_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":21,"text":"Let them acknowledge to the Lord his mercies, and his wonderful works to the children of men.","searchKeywords":["let","them","acknowledge","the","lord","his","mercies","and","wonderful","works","children","men"]},{"verseId":"brenton_psalms_106_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":22,"text":"And let them offer to him the sacrifice of praise, and proclaim his works with exultation.","searchKeywords":["and","let","them","offer","him","the","sacrifice","praise","proclaim","his","works","with","exultation"]},{"verseId":"brenton_psalms_106_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":23,"text":"They that go down to the sea in ships, doing business in many waters;","searchKeywords":["they","that","down","the","sea","ships","doing","business","many","waters"]},{"verseId":"brenton_psalms_106_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":24,"text":"these have seen the works of the Lord, and his wonders in the deep.","searchKeywords":["these","have","seen","the","works","lord","and","his","wonders","deep"]},{"verseId":"brenton_psalms_106_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":25,"text":"He speaks, and the stormy wind arises, and its waves are lifted up.","searchKeywords":["speaks","and","the","stormy","wind","arises","its","waves","are","lifted"]},{"verseId":"brenton_psalms_106_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":26,"text":"They go up to the heavens, and go down to the depths; their soul melts because of troubles.","searchKeywords":["they","the","heavens","and","down","depths","their","soul","melts","because","troubles"]},{"verseId":"brenton_psalms_106_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":27,"text":"They are troubled, they stagger as a drunkard, and all their wisdom is swallowed up.","searchKeywords":["they","are","troubled","stagger","drunkard","and","all","their","wisdom","swallowed"]},{"verseId":"brenton_psalms_106_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":28,"text":"Then they cry to the Lord in their affliction, and he brings them out of their distresses.","searchKeywords":["then","they","cry","the","lord","their","affliction","and","brings","them","out","distresses"]},{"verseId":"brenton_psalms_106_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":29,"text":"And he commands the storm, and it is calmed into a gentle breeze, and its waves are still.","searchKeywords":["and","commands","the","storm","calmed","into","gentle","breeze","its","waves","are","still"]},{"verseId":"brenton_psalms_106_30","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":30,"text":"And they are glad, because they are quiet; and he guides them to their desired haven.","searchKeywords":["and","they","are","glad","because","quiet","guides","them","their","desired","haven"]},{"verseId":"brenton_psalms_106_31","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":31,"text":"Let them acknowledge to the Lord his mercies, and his wonderful works to the children of men.","searchKeywords":["let","them","acknowledge","the","lord","his","mercies","and","wonderful","works","children","men"]},{"verseId":"brenton_psalms_106_32","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":32,"text":"Let them exalt him in the congregation of the people, and praise him in the seat of the elders.","searchKeywords":["let","them","exalt","him","the","congregation","people","and","praise","seat","elders"]},{"verseId":"brenton_psalms_106_33","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":33,"text":"He turns rivers into a desert, and streams of water into a dry land;","searchKeywords":["turns","rivers","into","desert","and","streams","water","dry","land"]},{"verseId":"brenton_psalms_106_34","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":34,"text":"a fruitful land into saltness, for the wickedness of them that dwell in it.","searchKeywords":["fruitful","land","into","saltness","for","the","wickedness","them","that","dwell"]},{"verseId":"brenton_psalms_106_35","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":35,"text":"He turns a wilderness into pools of water, and a dry land into streams of water.","searchKeywords":["turns","wilderness","into","pools","water","and","dry","land","streams"]},{"verseId":"brenton_psalms_106_36","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":36,"text":"And there he causes the hungry to dwell, and they establish for themselves cities of habitation.","searchKeywords":["and","there","causes","the","hungry","dwell","they","establish","for","themselves","cities","habitation"]},{"verseId":"brenton_psalms_106_37","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":37,"text":"And they sow fields, and plant vineyards, and they yield fruit of increase.","searchKeywords":["and","they","sow","fields","plant","vineyards","yield","fruit","increase"]},{"verseId":"brenton_psalms_106_38","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":38,"text":"And he blesses them, and they multiply exceedingly, and he diminishes not the number of their cattle.","searchKeywords":["and","blesses","them","they","multiply","exceedingly","diminishes","not","the","number","their","cattle"]},{"verseId":"brenton_psalms_106_39","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":39,"text":"Again they become few, and are brought low, by the pressure of evils and pain.","searchKeywords":["again","they","become","few","and","are","brought","low","the","pressure","evils","pain"]},{"verseId":"brenton_psalms_106_40","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":40,"text":"Contempt is poured upon their princes, and he causes them to wander in a desert and trackless land.","searchKeywords":["contempt","poured","upon","their","princes","and","causes","them","wander","desert","trackless","land"]},{"verseId":"brenton_psalms_106_41","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":41,"text":"But he helps the poor out of poverty, and makes families as a flock.","searchKeywords":["but","helps","the","poor","out","poverty","and","makes","families","flock"]},{"verseId":"brenton_psalms_106_42","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":42,"text":"The upright shall see and rejoice; and all iniquity shall stop her mouth.","searchKeywords":["the","upright","shall","see","and","rejoice","all","iniquity","stop","her","mouth"]},{"verseId":"brenton_psalms_106_43","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":106,"verse":43,"text":"Who is wise, and will observe these things, and understand the mercies of the Lord?","searchKeywords":["who","wise","and","will","observe","these","things","understand","the","mercies","lord"]}]