[{"verseId":"brenton_psalms_11_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":11,"verse":1,"text":"For the end, a Psalm of David, upon the eighth.","searchKeywords":["for","the","end","psalm","david","upon","eighth"]},{"verseId":"brenton_psalms_11_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":11,"verse":2,"text":"Save me, O Lord; for the godly man has failed; for truth is diminished from among the children of men.","searchKeywords":["save","lord","for","the","godly","man","has","failed","truth","diminished","from","among","children","men"]},{"verseId":"brenton_psalms_11_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":11,"verse":3,"text":"Every one has spoken vanity to his neighbour: their lips are deceitful, they have spoken with a double heart.","searchKeywords":["every","one","has","spoken","vanity","his","neighbour","their","lips","are","deceitful","they","have","with","double","heart"]},{"verseId":"brenton_psalms_11_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":11,"verse":4,"text":"Let the Lord destroy all the deceitful lips, and the tongue that speaks great words:","searchKeywords":["let","the","lord","destroy","all","deceitful","lips","and","tongue","that","speaks","great","words"]},{"verseId":"brenton_psalms_11_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":11,"verse":5,"text":"who have said, We will magnify our tongue; our lips are our own: who is Lord of us?","searchKeywords":["who","have","said","will","magnify","our","tongue","lips","are","own","lord"]},{"verseId":"brenton_psalms_11_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":11,"verse":6,"text":"Because of the misery of the poor, and because of the sighing of the needy, now will I arise, saith the Lord, I will set in safety; I will speak thereof openly.","searchKeywords":["because","the","misery","poor","and","sighing","needy","now","will","arise","saith","lord","set","safety","speak","thereof","openly"]},{"verseId":"brenton_psalms_11_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":11,"verse":7,"text":"The oracles of the Lord are pure oracles; as silver tried in the fire, proved a furnace of earth, purified seven times.","searchKeywords":["the","oracles","lord","are","pure","silver","tried","fire","proved","furnace","earth","purified","seven","times"]},{"verseId":"brenton_psalms_11_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":11,"verse":8,"text":"Thou, O Lord, shalt keep us, and shalt preserve us, from this generation, and for ever.","searchKeywords":["thou","lord","shalt","keep","and","preserve","from","this","generation","for","ever"]},{"verseId":"brenton_psalms_11_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":11,"verse":9,"text":"The ungodly walk around: according to thy greatness thou hast greatly exalted the sons of men.","searchKeywords":["the","ungodly","walk","around","according","thy","greatness","thou","hast","greatly","exalted","sons","men"]}]