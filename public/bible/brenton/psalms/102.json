[{"verseId":"brenton_psalms_102_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":1,"text":"of David. within me, his holy name.","searchKeywords":["david","within","his","holy","name"]},{"verseId":"brenton_psalms_102_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":2,"text":"Bless the Lord, O my soul, and forget not all his praises:","searchKeywords":["bless","the","lord","soul","and","forget","not","all","his","praises"]},{"verseId":"brenton_psalms_102_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":3,"text":"who forgives all thy transgressions, who heals all thy diseases;","searchKeywords":["who","forgives","all","thy","transgressions","heals","diseases"]},{"verseId":"brenton_psalms_102_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":4,"text":"who redeems thy life from corruption; who crowns thee with mercy and compassion;","searchKeywords":["who","redeems","thy","life","from","corruption","crowns","thee","with","mercy","and","compassion"]},{"verseId":"brenton_psalms_102_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":5,"text":"who satisfies thy desire with good things: thy youth shall be renewed like of the eagle.","searchKeywords":["who","satisfies","thy","desire","with","good","things","youth","shall","renewed","like","the","eagle"]},{"verseId":"brenton_psalms_102_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":6,"text":"The Lord executes mercy and judgment for all that are injured.","searchKeywords":["the","lord","executes","mercy","and","judgment","for","all","that","are","injured"]},{"verseId":"brenton_psalms_102_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":7,"text":"He made known his ways to Moses, his will to the children of Israel.","searchKeywords":["made","known","his","ways","moses","will","the","children","israel"]},{"verseId":"brenton_psalms_102_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":8,"text":"The Lord is compassionate and pitiful, long-suffering, and full of mercy.","searchKeywords":["the","lord","compassionate","and","pitiful","long","suffering","full","mercy"]},{"verseId":"brenton_psalms_102_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":9,"text":"He will not be always angry; neither will he be wrathful for ever.","searchKeywords":["will","not","always","angry","neither","wrathful","for","ever"]},{"verseId":"brenton_psalms_102_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":10,"text":"He has not dealt with us according to our sins, nor recompensed us according to our iniquities.","searchKeywords":["has","not","dealt","with","according","our","sins","nor","recompensed","iniquities"]},{"verseId":"brenton_psalms_102_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":11,"text":"For as the heaven is high above the earth, the Lord has increased his mercy toward them that fear him.","searchKeywords":["for","the","heaven","high","above","earth","lord","has","increased","his","mercy","toward","them","that","fear","him"]},{"verseId":"brenton_psalms_102_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":12,"text":"As far as the east is from the west, has he removed our transgressions from us.","searchKeywords":["far","the","east","from","west","has","removed","our","transgressions"]},{"verseId":"brenton_psalms_102_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":13,"text":"As a father pities children, the Lord pities them that fear him.","searchKeywords":["father","pities","children","the","lord","them","that","fear","him"]},{"verseId":"brenton_psalms_102_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":14,"text":"For he knows our frame: remember that we are dust.","searchKeywords":["for","knows","our","frame","remember","that","are","dust"]},{"verseId":"brenton_psalms_102_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":15,"text":"man, his days are as grass; as a flower of the field, so shall he flourish.","searchKeywords":["man","his","days","are","grass","flower","the","field","shall","flourish"]},{"verseId":"brenton_psalms_102_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":16,"text":"For the wind passes over it, and it shall not be; and it shall know its place no more.","searchKeywords":["for","the","wind","passes","over","and","shall","not","know","its","place","more"]},{"verseId":"brenton_psalms_102_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":17,"text":"But the mercy of the Lord is from generation to generation upon them that fear him, and his righteousness to children's children;","searchKeywords":["but","the","mercy","lord","from","generation","upon","them","that","fear","him","and","his","righteousness","children"]},{"verseId":"brenton_psalms_102_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":18,"text":"to them that keep his covenant, and remember his commandments to do them.","searchKeywords":["them","that","keep","his","covenant","and","remember","commandments"]},{"verseId":"brenton_psalms_102_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":19,"text":"The Lord has prepared his throne in the heaven; and his kingdom rules over all.","searchKeywords":["the","lord","has","prepared","his","throne","heaven","and","kingdom","rules","over","all"]},{"verseId":"brenton_psalms_102_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":20,"text":"Bless the Lord, all ye his angels, mighty in strength, who perform his bidding, to hearken to the voice of his words.","searchKeywords":["bless","the","lord","all","his","angels","mighty","strength","who","perform","bidding","hearken","voice","words"]},{"verseId":"brenton_psalms_102_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":21,"text":"Bless the Lord, all ye his hosts; ministers of his that do his will.","searchKeywords":["bless","the","lord","all","his","hosts","ministers","that","will"]},{"verseId":"brenton_psalms_102_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":102,"verse":22,"text":"Bless the Lord, all his works, in every place of his dominion: bless the Lord, O my soul.","searchKeywords":["bless","the","lord","all","his","works","every","place","dominion","soul"]}]