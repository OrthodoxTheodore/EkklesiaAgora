:"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":135,"verse":26,"text":"Give thanks to the God of heaven; for his mercy for ever.","searchKeywords":["give","thanks","the","god","heaven","for","his","mercy","ever"]}]