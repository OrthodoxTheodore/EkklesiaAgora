[{"verseId":"brenton_psalms_66_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":66,"verse":1,"text":"For the end, a Psalm of David among the Hymns.","searchKeywords":["for","the","end","psalm","david","among","hymns"]},{"verseId":"brenton_psalms_66_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":66,"verse":2,"text":"God be merciful to us, and bless us; cause his face to shine upon us. Pause.","searchKeywords":["god","merciful","and","bless","cause","his","face","shine","upon","pause"]},{"verseId":"brenton_psalms_66_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":66,"verse":3,"text":"That may know thy way on the earth, thy salvation among all nations.","searchKeywords":["that","may","know","thy","way","the","earth","salvation","among","all","nations"]},{"verseId":"brenton_psalms_66_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":66,"verse":4,"text":"Let the nations, O God, give thanks to thee; let all the nations give thanks to thee.","searchKeywords":["let","the","nations","god","give","thanks","thee","all"]},{"verseId":"brenton_psalms_66_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":66,"verse":5,"text":"Let the nations rejoice and exult, for thou shalt judge the peoples in equity, and shalt guide the nations on the earth. Pause.","searchKeywords":["let","the","nations","rejoice","and","exult","for","thou","shalt","judge","peoples","equity","guide","earth","pause"]},{"verseId":"brenton_psalms_66_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":66,"verse":6,"text":"Let the peoples, O God, give thanks to thee; let all the peoples give thanks to thee.","searchKeywords":["let","the","peoples","god","give","thanks","thee","all"]},{"verseId":"brenton_psalms_66_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":66,"verse":7,"text":"The earth has yielded her fruit; let God, our God, bless us.","searchKeywords":["the","earth","has","yielded","her","fruit","let","god","our","bless"]},{"verseId":"brenton_psalms_66_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":66,"verse":8,"text":"Let God bless us; and let all the ends of the earth fear him.","searchKeywords":["let","god","bless","and","all","the","ends","earth","fear","him"]}]