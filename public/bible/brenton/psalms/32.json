[{"verseId":"brenton_psalms_32_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":1,"text":"of David.","searchKeywords":["david"]},{"verseId":"brenton_psalms_32_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":2,"text":"Praise the Lord on the harp; play to him on a psaltery of ten strings.","searchKeywords":["praise","the","lord","harp","play","him","psaltery","ten","strings"]},{"verseId":"brenton_psalms_32_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":3,"text":"Sing to him a new song; play skilfully with a loud noise.","searchKeywords":["sing","him","new","song","play","skilfully","with","loud","noise"]},{"verseId":"brenton_psalms_32_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":4,"text":"For the word of the Lord is right; and all his works are faithful.","searchKeywords":["for","the","word","lord","right","and","all","his","works","are","faithful"]},{"verseId":"brenton_psalms_32_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":5,"text":"He loves mercy and judgment; the earth is full of the mercy of the Lord.","searchKeywords":["loves","mercy","and","judgment","the","earth","full","lord"]},{"verseId":"brenton_psalms_32_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":6,"text":"By the word of the Lord the heavens were established; and all the host of them by the breath of his .","searchKeywords":["the","word","lord","heavens","were","established","and","all","host","them","breath","his"]},{"verseId":"brenton_psalms_32_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":7,"text":"Who gathers the waters of the sea as a bottle; who lays up the deeps in treasuries.","searchKeywords":["who","gathers","the","waters","sea","bottle","lays","deeps","treasuries"]},{"verseId":"brenton_psalms_32_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":8,"text":"Let all the earth fear the Lord; and let all that dwell in the world be moved because of him.","searchKeywords":["let","all","the","earth","fear","lord","and","that","dwell","world","moved","because","him"]},{"verseId":"brenton_psalms_32_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":9,"text":"For he spoke, and they were made; he commanded, and they were created.","searchKeywords":["for","spoke","and","they","were","made","commanded","created"]},{"verseId":"brenton_psalms_32_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":10,"text":"The Lord frustrates the counsels of the nations; he brings to nought also the reasonings of the peoples, and brings to nought the counsels of princes.","searchKeywords":["the","lord","frustrates","counsels","nations","brings","nought","also","reasonings","peoples","and","princes"]},{"verseId":"brenton_psalms_32_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":11,"text":"But the counsel of the Lord endures for ever, the thoughts of his heart from generation to generation.","searchKeywords":["but","the","counsel","lord","endures","for","ever","thoughts","his","heart","from","generation"]},{"verseId":"brenton_psalms_32_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":12,"text":"Blessed is the nation whose God is the Lord; the people whom he has chosen for his own inheritance.","searchKeywords":["blessed","the","nation","whose","god","lord","people","whom","has","chosen","for","his","own","inheritance"]},{"verseId":"brenton_psalms_32_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":13,"text":"The Lord looks out of heaven; he beholds all the sons of men.","searchKeywords":["the","lord","looks","out","heaven","beholds","all","sons","men"]},{"verseId":"brenton_psalms_32_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":14,"text":"He looks from his prepared habitation on all the dwellers on the earth;","searchKeywords":["looks","from","his","prepared","habitation","all","the","dwellers","earth"]},{"verseId":"brenton_psalms_32_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":15,"text":"who fashioned their hearts alone; who understands all their works.","searchKeywords":["who","fashioned","their","hearts","alone","understands","all","works"]},{"verseId":"brenton_psalms_32_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":16,"text":"A king is not saved by reason of a great host; and a giant shall not be delivered by the greatness of his strength.","searchKeywords":["king","not","saved","reason","great","host","and","giant","shall","delivered","the","greatness","his","strength"]},{"verseId":"brenton_psalms_32_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":17,"text":"A horse is vain for safety; neither shall he be delivered by the greatness of his power.","searchKeywords":["horse","vain","for","safety","neither","shall","delivered","the","greatness","his","power"]},{"verseId":"brenton_psalms_32_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":18,"text":"Behold, the eyes of the Lord are on them that fear him, those that hope in his mercy;","searchKeywords":["behold","the","eyes","lord","are","them","that","fear","him","those","hope","his","mercy"]},{"verseId":"brenton_psalms_32_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":19,"text":"to deliver their souls from death, and to keep them alive in famine.","searchKeywords":["deliver","their","souls","from","death","and","keep","them","alive","famine"]},{"verseId":"brenton_psalms_32_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":20,"text":"Our soul waits on the Lord; for he is our helper and defender.","searchKeywords":["our","soul","waits","the","lord","for","helper","and","defender"]},{"verseId":"brenton_psalms_32_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":21,"text":"For our heart shall rejoice in him, and we have hoped in his holy name.","searchKeywords":["for","our","heart","shall","rejoice","him","and","have","hoped","his","holy","name"]},{"verseId":"brenton_psalms_32_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":32,"verse":22,"text":"Let thy mercy, O Lord, be upon us, according as we have hoped in thee.","searchKeywords":["let","thy","mercy","lord","upon","according","have","hoped","thee"]}]