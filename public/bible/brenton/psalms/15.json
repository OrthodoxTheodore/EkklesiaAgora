[{"verseId":"brenton_psalms_15_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":15,"verse":1,"text":"A writing of David.","searchKeywords":["writing","david"]},{"verseId":"brenton_psalms_15_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":15,"verse":2,"text":"I said to the Lord, Thou art my Lord; for thou hast no need of my goodness.","searchKeywords":["said","the","lord","thou","art","for","hast","need","goodness"]},{"verseId":"brenton_psalms_15_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":15,"verse":3,"text":"On behalf of the saints that are in his land, he has magnified all his pleasure in them.","searchKeywords":["behalf","the","saints","that","are","his","land","has","magnified","all","pleasure","them"]},{"verseId":"brenton_psalms_15_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":15,"verse":4,"text":"Their weaknesses have been multiplied; afterward they hasted. I will by no means assemble their bloody meetings, neither will I make mention of their names with my lips.","searchKeywords":["their","weaknesses","have","been","multiplied","afterward","they","hasted","will","means","assemble","bloody","meetings","neither","make","mention","names","with","lips"]},{"verseId":"brenton_psalms_15_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":15,"verse":5,"text":"The Lord is the portion of mine inheritance and of my cup: thou art he that restores my inheritance to me.","searchKeywords":["the","lord","portion","mine","inheritance","and","cup","thou","art","that","restores"]},{"verseId":"brenton_psalms_15_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":15,"verse":6,"text":"The lines have fallen to me in the best places, yea, I have a most excellent heritage.","searchKeywords":["the","lines","have","fallen","best","places","yea","most","excellent","heritage"]},{"verseId":"brenton_psalms_15_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":15,"verse":7,"text":"I will bless the Lord who has instructed me; my reins too have chastened me even till night.","searchKeywords":["will","bless","the","lord","who","has","instructed","reins","too","have","chastened","even","till","night"]},{"verseId":"brenton_psalms_15_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":15,"verse":8,"text":"I foresaw the Lord always before my face; for he is on my right hand, that I should not be moved.","searchKeywords":["foresaw","the","lord","always","before","face","for","right","hand","that","should","not","moved"]},{"verseId":"brenton_psalms_15_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":15,"verse":9,"text":"Therefore my heart rejoiced and my tongue exulted; moreover also my flesh shall rest in hope:","searchKeywords":["therefore","heart","rejoiced","and","tongue","exulted","moreover","also","flesh","shall","rest","hope"]},{"verseId":"brenton_psalms_15_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":15,"verse":10,"text":"because thou wilt not leave my soul in hell, neither wilt thou suffer thine Holy One to see corruption.","searchKeywords":["because","thou","wilt","not","leave","soul","hell","neither","suffer","thine","holy","one","see","corruption"]},{"verseId":"brenton_psalms_15_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":15,"verse":11,"text":"Thou hast made known to me the ways of life; thou wilt fill me with joy with thy countenance: at thy right hand delights for ever.","searchKeywords":["thou","hast","made","known","the","ways","life","wilt","fill","with","joy","thy","countenance","right","hand","delights","for","ever"]}]