[{"verseId":"brenton_psalms_46_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":46,"verse":1,"text":"For the end, a Psalm for the sons of Core.","searchKeywords":["for","the","end","psalm","sons","core"]},{"verseId":"brenton_psalms_46_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":46,"verse":2,"text":"Clap your hands, all ye nations; shout to God with a voice of exultation.","searchKeywords":["clap","your","hands","all","nations","shout","god","with","voice","exultation"]},{"verseId":"brenton_psalms_46_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":46,"verse":3,"text":"For the Lord most high is terrible; a great king over all the earth.","searchKeywords":["for","the","lord","most","high","terrible","great","king","over","all","earth"]},{"verseId":"brenton_psalms_46_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":46,"verse":4,"text":"He has subdued the peoples under us, and the nations under our feet.","searchKeywords":["has","subdued","the","peoples","under","and","nations","our","feet"]},{"verseId":"brenton_psalms_46_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":46,"verse":5,"text":"He has chosen out his inheritance for us, the beauty of Jacob which he loved. Pause.","searchKeywords":["has","chosen","out","his","inheritance","for","the","beauty","jacob","which","loved","pause"]},{"verseId":"brenton_psalms_46_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":46,"verse":6,"text":"God is gone up with a shout, the Lord with a sound of a trumpet.","searchKeywords":["god","gone","with","shout","the","lord","sound","trumpet"]},{"verseId":"brenton_psalms_46_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":46,"verse":7,"text":"Sing praises to our God, sing praises: sing praises to our King, sing praises.","searchKeywords":["sing","praises","our","god","king"]},{"verseId":"brenton_psalms_46_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":46,"verse":8,"text":"For God is king of all the earth: sing praises with understanding.","searchKeywords":["for","god","king","all","the","earth","sing","praises","with","understanding"]},{"verseId":"brenton_psalms_46_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":46,"verse":9,"text":"God reigns over the nations: God sits upon the throne of his holiness.","searchKeywords":["god","reigns","over","the","nations","sits","upon","throne","his","holiness"]},{"verseId":"brenton_psalms_46_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":46,"verse":10,"text":"The rulers of the people are assembled with the God of Abraam: for God's mighty ones of the earth have been greatly exalted.","searchKeywords":["the","rulers","people","are","assembled","with","god","abraam","for","mighty","ones","earth","have","been","greatly","exalted"]}]