[{"verseId":"brenton_psalms_68_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":1,"text":"For the end, of David, for alternate .","searchKeywords":["for","the","end","david","alternate"]},{"verseId":"brenton_psalms_68_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":2,"text":"Save me, O God; for the waters have come in to my soul.","searchKeywords":["save","god","for","the","waters","have","come","soul"]},{"verseId":"brenton_psalms_68_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":3,"text":"I am stuck fast in deep mire, and there is no standing: I am come in to the depths of the sea, and a storm has overwhelmed me.","searchKeywords":["stuck","fast","deep","mire","and","there","standing","come","the","depths","sea","storm","has","overwhelmed"]},{"verseId":"brenton_psalms_68_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":4,"text":"I am weary crying, my throat has become hoarse; mine eyes have failed by my waiting on my God.","searchKeywords":["weary","crying","throat","has","become","hoarse","mine","eyes","have","failed","waiting","god"]},{"verseId":"brenton_psalms_68_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":5,"text":"They that hate me without a cause are more than the hairs of my head: my enemies that persecute me unrighteously are strengthened: then I restored that which I took not away.","searchKeywords":["they","that","hate","without","cause","are","more","than","the","hairs","head","enemies","persecute","unrighteously","strengthened","then","restored","which","took","not","away"]},{"verseId":"brenton_psalms_68_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":6,"text":"O God, thou knowest my foolishness; and my transgressions are not hidden from thee.","searchKeywords":["god","thou","knowest","foolishness","and","transgressions","are","not","hidden","from","thee"]},{"verseId":"brenton_psalms_68_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":7,"text":"Let not them that wait on thee, O Lord of hosts, be ashamed on my account: let not them that seek thee, be ashamed on my account, O God of Israel.","searchKeywords":["let","not","them","that","wait","thee","lord","hosts","ashamed","account","seek","god","israel"]},{"verseId":"brenton_psalms_68_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":8,"text":"For I have suffered reproach for thy sake; shame has covered my face.","searchKeywords":["for","have","suffered","reproach","thy","sake","shame","has","covered","face"]},{"verseId":"brenton_psalms_68_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":9,"text":"I became strange to my brethren, and a stranger to my mother's children.","searchKeywords":["became","strange","brethren","and","stranger","mother","children"]},{"verseId":"brenton_psalms_68_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":10,"text":"For the zeal of thine house has eaten me up; and the reproaches of them that reproached thee are fallen upon me.","searchKeywords":["for","the","zeal","thine","house","has","eaten","and","reproaches","them","that","reproached","thee","are","fallen","upon"]},{"verseId":"brenton_psalms_68_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":11,"text":"And I bowed down my soul with fasting, and that was made my reproach.","searchKeywords":["and","bowed","down","soul","with","fasting","that","was","made","reproach"]},{"verseId":"brenton_psalms_68_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":12,"text":"And I put on sackcloth for my covering; and I became a proverb to them.","searchKeywords":["and","put","sackcloth","for","covering","became","proverb","them"]},{"verseId":"brenton_psalms_68_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":13,"text":"They that sit in the gate talked against me, and they that drank wine sang against me.","searchKeywords":["they","that","sit","the","gate","talked","against","and","drank","wine","sang"]},{"verseId":"brenton_psalms_68_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":14,"text":"But I to thee, O Lord, in my prayer; O God, it is a propitious time: in the multitude of thy mercy hear me, in the truth of thy salvation.","searchKeywords":["but","thee","lord","prayer","god","propitious","time","the","multitude","thy","mercy","hear","truth","salvation"]},{"verseId":"brenton_psalms_68_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":15,"text":"Save me from the mire, that I stick not : let me be delivered from them that hate me, and from the deep waters.","searchKeywords":["save","from","the","mire","that","stick","not","let","delivered","them","hate","and","deep","waters"]},{"verseId":"brenton_psalms_68_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":16,"text":"Let not the waterflood drown me, nor let the deep swallow me up; neither let the well shut its mouth upon me.","searchKeywords":["let","not","the","waterflood","drown","nor","deep","swallow","neither","well","shut","its","mouth","upon"]},{"verseId":"brenton_psalms_68_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":17,"text":"Hear me, O Lord; for thy mercy is good: according to the multitude of thy compassions look upon me.","searchKeywords":["hear","lord","for","thy","mercy","good","according","the","multitude","compassions","look","upon"]},{"verseId":"brenton_psalms_68_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":18,"text":"And turn not away thy face from thy servant; for I am afflicted: hear me speedily.","searchKeywords":["and","turn","not","away","thy","face","from","servant","for","afflicted","hear","speedily"]},{"verseId":"brenton_psalms_68_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":19,"text":"Draw nigh to my soul and redeem it: deliver me because of mine enemies.","searchKeywords":["draw","nigh","soul","and","redeem","deliver","because","mine","enemies"]},{"verseId":"brenton_psalms_68_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":20,"text":"For thou knowest my reproach, and my shame, and my confusion; all that afflict me are before thee.","searchKeywords":["for","thou","knowest","reproach","and","shame","confusion","all","that","afflict","are","before","thee"]},{"verseId":"brenton_psalms_68_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":21,"text":"My soul has waited for reproach and misery; and I waited for one to grieve with me, but there was none; and for one to comfort me, but I found none.","searchKeywords":["soul","has","waited","for","reproach","and","misery","one","grieve","with","but","there","was","none","comfort","found"]},{"verseId":"brenton_psalms_68_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":22,"text":"They gave also gall for my food, and made me drink vinegar for my thirst.","searchKeywords":["they","gave","also","gall","for","food","and","made","drink","vinegar","thirst"]},{"verseId":"brenton_psalms_68_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":23,"text":"Let their table before them be for a snare, and for a recompence, and for a stumbling-block.","searchKeywords":["let","their","table","before","them","for","snare","and","recompence","stumbling","block"]},{"verseId":"brenton_psalms_68_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":24,"text":"Let their eyes be darkened that they should not see; and bow down their back continually.","searchKeywords":["let","their","eyes","darkened","that","they","should","not","see","and","bow","down","back","continually"]},{"verseId":"brenton_psalms_68_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":25,"text":"Pour out thy wrath upon them, and let the fury of thine anger take hold on them.","searchKeywords":["pour","out","thy","wrath","upon","them","and","let","the","fury","thine","anger","take","hold"]},{"verseId":"brenton_psalms_68_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":26,"text":"Let their habitation be made desolate; and let there be no inhabitant in their tents:","searchKeywords":["let","their","habitation","made","desolate","and","there","inhabitant","tents"]},{"verseId":"brenton_psalms_68_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":27,"text":"because they persecuted him whom thou hast smitten; and they have added to the grief of my wounds.","searchKeywords":["because","they","persecuted","him","whom","thou","hast","smitten","and","have","added","the","grief","wounds"]},{"verseId":"brenton_psalms_68_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":28,"text":"Add iniquity to their iniquity; and let them not come into thy righteousness.","searchKeywords":["add","iniquity","their","and","let","them","not","come","into","thy","righteousness"]},{"verseId":"brenton_psalms_68_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":29,"text":"Let them be blotted out of the book of the living, and let them not be written with the righteous.","searchKeywords":["let","them","blotted","out","the","book","living","and","not","written","with","righteous"]},{"verseId":"brenton_psalms_68_30","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":30,"text":"I am poor and sorrowful; but the salvation of thy countenance has helped me.","searchKeywords":["poor","and","sorrowful","but","the","salvation","thy","countenance","has","helped"]},{"verseId":"brenton_psalms_68_31","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":31,"text":"I will praise the name of my God with a song, I will magnify him with praise;","searchKeywords":["will","praise","the","name","god","with","song","magnify","him"]},{"verseId":"brenton_psalms_68_32","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":32,"text":"and shall please God more than a young calf having horns and hoofs.","searchKeywords":["and","shall","please","god","more","than","young","calf","having","horns","hoofs"]},{"verseId":"brenton_psalms_68_33","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":33,"text":"Let the poor see and rejoice; seek the Lord diligently, and ye shall live.","searchKeywords":["let","the","poor","see","and","rejoice","seek","lord","diligently","shall","live"]},{"verseId":"brenton_psalms_68_34","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":34,"text":"For the Lord hears the poor, and does not set at nought his fettered ones.","searchKeywords":["for","the","lord","hears","poor","and","does","not","set","nought","his","fettered","ones"]},{"verseId":"brenton_psalms_68_35","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":35,"text":"Let the heavens and the earth praise him, the sea, and all things moving in them.","searchKeywords":["let","the","heavens","and","earth","praise","him","sea","all","things","moving","them"]},{"verseId":"brenton_psalms_68_36","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":36,"text":"For God will save Sion, and the cities of Judea shall be built; and shall dwell there, and inherit it.","searchKeywords":["for","god","will","save","sion","and","the","cities","judea","shall","built","dwell","there","inherit"]},{"verseId":"brenton_psalms_68_37","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":68,"verse":37,"text":"And the seed of his servants shall possess it, and they that love his name shall dwell therein.","searchKeywords":["and","the","seed","his","servants","shall","possess","they","that","love","name","dwell","therein"]}]