[{"verseId":"brenton_psalms_69_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":69,"verse":1,"text":"For the end, by David for a remembrance, that the Lord may save me.","searchKeywords":["for","the","end","david","remembrance","that","lord","may","save"]},{"verseId":"brenton_psalms_69_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":69,"verse":2,"text":"Draw nigh, O God, to my help.","searchKeywords":["draw","nigh","god","help"]},{"verseId":"brenton_psalms_69_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":69,"verse":3,"text":"Let them be ashamed and confounded that seek my soul: let them be turned backward and put to shame, that wish me evil.","searchKeywords":["let","them","ashamed","and","confounded","that","seek","soul","turned","backward","put","shame","wish","evil"]},{"verseId":"brenton_psalms_69_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":69,"verse":4,"text":"Let them that say to me, Aha, aha, be turned back and put to shame immediately.","searchKeywords":["let","them","that","say","aha","turned","back","and","put","shame","immediately"]},{"verseId":"brenton_psalms_69_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":69,"verse":5,"text":"Let all that seek thee exult and be glad in thee: and let those that love thy salvation say continually, Let God be magnified.","searchKeywords":["let","all","that","seek","thee","exult","and","glad","those","love","thy","salvation","say","continually","god","magnified"]},{"verseId":"brenton_psalms_69_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":69,"verse":6,"text":"But I am poor and needy; O God, help me: thou art my helper and deliverer,