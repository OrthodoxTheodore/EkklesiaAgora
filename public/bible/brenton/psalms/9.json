[{"verseId":"brenton_psalms_9_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":1,"text":"For the end, a Psalm of David, concerning the secrets of the Son.","searchKeywords":["for","the","end","psalm","david","concerning","secrets","son"]},{"verseId":"brenton_psalms_9_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":2,"text":"I will give thanks to thee, O Lord, with my whole heart; I will recount all thy wonderful works.","searchKeywords":["will","give","thanks","thee","lord","with","whole","heart","recount","all","thy","wonderful","works"]},{"verseId":"brenton_psalms_9_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":3,"text":"I will be glad and exult in thee: I will sing to thy name, O thou Most High.","searchKeywords":["will","glad","and","exult","thee","sing","thy","name","thou","most","high"]},{"verseId":"brenton_psalms_9_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":4,"text":"When mine enemies are turned back, they shall be feeble and perish at thy presence.","searchKeywords":["when","mine","enemies","are","turned","back","they","shall","feeble","and","perish","thy","presence"]},{"verseId":"brenton_psalms_9_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":5,"text":"For thou hast maintained my cause and my right; thou satest on the throne, that judgest righteousness.","searchKeywords":["for","thou","hast","maintained","cause","and","right","satest","the","throne","that","judgest","righteousness"]},{"verseId":"brenton_psalms_9_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":6,"text":"Thou hast rebuked the nations, and the ungodly one has perished; thou hast blotted out their name for ever, even for ever and ever.","searchKeywords":["thou","hast","rebuked","the","nations","and","ungodly","one","has","perished","blotted","out","their","name","for","ever","even"]},{"verseId":"brenton_psalms_9_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":7,"text":"The swords of the enemy have failed utterly; and thou hast destroyed cities: their memorial has been destroyed with a noise,","searchKeywords":["the","swords","enemy","have","failed","utterly","and","thou","hast","destroyed","cities","their","memorial","has","been","with","noise"]},{"verseId":"brenton_psalms_9_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":8,"text":"but the Lord endures for ever: he has prepared his throne for judgment.","searchKeywords":["but","the","lord","endures","for","ever","has","prepared","his","throne","judgment"]},{"verseId":"brenton_psalms_9_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":9,"text":"And he will judge the world in righteousness, he will judge the nations in uprightness.","searchKeywords":["and","will","judge","the","world","righteousness","nations","uprightness"]},{"verseId":"brenton_psalms_9_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":10,"text":"The Lord also is become a refuge for the poor, a seasonable help, in affliction.","searchKeywords":["the","lord","also","become","refuge","for","poor","seasonable","help","affliction"]},{"verseId":"brenton_psalms_9_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":11,"text":"And let them that know thy name hope in thee: for thou, O Lord, hast not failed them that diligently seek thee.","searchKeywords":["and","let","them","that","know","thy","name","hope","thee","for","thou","lord","hast","not","failed","diligently","seek"]},{"verseId":"brenton_psalms_9_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":12,"text":"Sing praises to the Lord, who dwells in Sion: declare his dealings among the nations.","searchKeywords":["sing","praises","the","lord","who","dwells","sion","declare","his","dealings","among","nations"]},{"verseId":"brenton_psalms_9_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":13,"text":"For he remembered them, making inquisition for blood: he has not forgotten the supplication of the poor.","searchKeywords":["for","remembered","them","making","inquisition","blood","has","not","forgotten","the","supplication","poor"]},{"verseId":"brenton_psalms_9_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":14,"text":"Have mercy upon me, O Lord; look upon my affliction of mine enemies, thou that liftest me up from the gates of death:","searchKeywords":["have","mercy","upon","lord","look","affliction","mine","enemies","thou","that","liftest","from","the","gates","death"]},{"verseId":"brenton_psalms_9_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":15,"text":"that I may declare all thy praises in the gates of the daughter of Sion: I will exult in thy salvation.","searchKeywords":["that","may","declare","all","thy","praises","the","gates","daughter","sion","will","exult","salvation"]},{"verseId":"brenton_psalms_9_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":16,"text":"The heathen are caught in the destruction which they planned: in the very snare which they hid is their foot taken.","searchKeywords":["the","heathen","are","caught","destruction","which","they","planned","very","snare","hid","their","foot","taken"]},{"verseId":"brenton_psalms_9_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":17,"text":"The Lord is known as executing judgments: the sinner is taken in the works of his hands. A song of Pause.","searchKeywords":["the","lord","known","executing","judgments","sinner","taken","works","his","hands","song","pause"]},{"verseId":"brenton_psalms_9_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":18,"text":"Let sinners be driven away into Hades, all the nations that forget God.","searchKeywords":["let","sinners","driven","away","into","hades","all","the","nations","that","forget","god"]},{"verseId":"brenton_psalms_9_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":19,"text":"For the poor shall not be forgotten for ever: the patience of the needy ones shall not perish for ever.","searchKeywords":["for","the","poor","shall","not","forgotten","ever","patience","needy","ones","perish"]},{"verseId":"brenton_psalms_9_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":20,"text":"Arise, O Lord, let not man prevail: let the heathen be judged before thee.","searchKeywords":["arise","lord","let","not","man","prevail","the","heathen","judged","before","thee"]},{"verseId":"brenton_psalms_9_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":21,"text":"Appoint, O Lord, a lawgiver over them: let the heathen know that they are men. Pause.","searchKeywords":["appoint","lord","lawgiver","over","them","let","the","heathen","know","that","they","are","men","pause"]},{"verseId":"brenton_psalms_9_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":22,"text":"Why standest thou afar off, O Lord? dost thou overlook in times of need, in affliction?","searchKeywords":["why","standest","thou","afar","off","lord","dost","overlook","times","need","affliction"]},{"verseId":"brenton_psalms_9_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":23,"text":"While the ungodly one acts proudly, the poor is hotly pursued: are taken in the crafty counsels which they imagine.","searchKeywords":["while","the","ungodly","one","acts","proudly","poor","hotly","pursued","are","taken","crafty","counsels","which","they","imagine"]},{"verseId":"brenton_psalms_9_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":24,"text":"Because the sinner praises himself for the desires of his heart; and the unjust one blesses himself.","searchKeywords":["because","the","sinner","praises","himself","for","desires","his","heart","and","unjust","one","blesses"]},{"verseId":"brenton_psalms_9_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":25,"text":"The sinner has provoked the Lord: according to the abundance of his pride he will not seek after : God is not before him.","searchKeywords":["the","sinner","has","provoked","lord","according","abundance","his","pride","will","not","seek","after","god","before","him"]},{"verseId":"brenton_psalms_9_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":26,"text":"His ways are profane at all times; thy judgments are removed from before him: he will gain the mastery over all his enemies.","searchKeywords":["his","ways","are","profane","all","times","thy","judgments","removed","from","before","him","will","gain","the","mastery","over","enemies"]},{"verseId":"brenton_psalms_9_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":27,"text":"For he has said in his heart, I shall not be moved, without evil from generation to generation.","searchKeywords":["for","has","said","his","heart","shall","not","moved","without","evil","from","generation"]},{"verseId":"brenton_psalms_9_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":28,"text":"Whose mouth is full of cursing, and bitterness, and fraud: under his tongue are trouble and pain.","searchKeywords":["whose","mouth","full","cursing","and","bitterness","fraud","under","his","tongue","are","trouble","pain"]},{"verseId":"brenton_psalms_9_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":29,"text":"He lies in wait with rich in secret places, in order to slay the innocent: his eyes are set against the poor.","searchKeywords":["lies","wait","with","rich","secret","places","order","slay","the","innocent","his","eyes","are","set","against","poor"]},{"verseId":"brenton_psalms_9_30","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":30,"text":"He lies in wait in secret as a lion in his den: he lies in wait to ravish the poor, to ravish the poor when he draws him : he will bring him down in his snare.","searchKeywords":["lies","wait","secret","lion","his","den","ravish","the","poor","when","draws","him","will","bring","down","snare"]},{"verseId":"brenton_psalms_9_31","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":31,"text":"He will bow down and fall when he has mastered the poor.","searchKeywords":["will","bow","down","and","fall","when","has","mastered","the","poor"]},{"verseId":"brenton_psalms_9_32","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":32,"text":"For he has said in his heart, God has forgotten: he has turned away his face so as never to look.","searchKeywords":["for","has","said","his","heart","god","forgotten","turned","away","face","never","look"]},{"verseId":"brenton_psalms_9_33","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":33,"text":"Arise, O Lord God; let thy hand be lifted up: forget not the poor.","searchKeywords":["arise","lord","god","let","thy","hand","lifted","forget","not","the","poor"]},{"verseId":"brenton_psalms_9_34","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":34,"text":"Wherefore has the wicked provoked God? for he has said in his heart, He will not require .","searchKeywords":["wherefore","has","the","wicked","provoked","god","for","said","his","heart","will","not","require"]},{"verseId":"brenton_psalms_9_35","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":35,"text":"Thou seest ; for thou dost observe trouble and wrath, to deliver them into thy hands: the poor has been left to thee; thou wast a helper to the orphan.","searchKeywords":["thou","seest","for","dost","observe","trouble","and","wrath","deliver","them","into","thy","hands","the","poor","has","been","left","thee","wast","helper","orphan"]},{"verseId":"brenton_psalms_9_36","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":36,"text":"Break thou the arm of the sinner and wicked man: his sin shall be sought for, and shall not be found.","searchKeywords":["break","thou","the","arm","sinner","and","wicked","man","his","sin","shall","sought","for","not","found"]},{"verseId":"brenton_psalms_9_37","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":37,"text":"The Lord shall reign for ever, even for ever and ever: ye Gentiles shall perish out of his land.","searchKeywords":["the","lord","shall","reign","for","ever","even","and","gentiles","perish","out","his","land"]},{"verseId":"brenton_psalms_9_38","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":38,"text":"The Lord has heard the desire of the poor: thine ear has inclined to the preparation of their heart;","searchKeywords":["the","lord","has","heard","desire","poor","thine","ear","inclined","preparation","their","heart"]},{"verseId":"brenton_psalms_9_39","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":9,"verse":39,"text":"to plead for the orphan and afflicted, that man may no more boast upon the earth.","searchKeywords":["plead","for","the","orphan","and","afflicted","that","man","may","more","boast","upon","earth"]}]