[{"verseId":"brenton_psalms_138_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":1,"text":"For the end, a Psalm of David.","searchKeywords":["for","the","end","psalm","david"]},{"verseId":"brenton_psalms_138_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":2,"text":"Thou knowest my down-sitting and mine up-rising: thou understandest my thoughts long before.","searchKeywords":["thou","knowest","down","sitting","and","mine","rising","understandest","thoughts","long","before"]},{"verseId":"brenton_psalms_138_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":3,"text":"Thou hast traced my path and my bed, and hast foreseen all my ways.","searchKeywords":["thou","hast","traced","path","and","bed","foreseen","all","ways"]},{"verseId":"brenton_psalms_138_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":4,"text":"For there is no unrighteous word in my tongue: behold, O Lord, thou hast known all things,","searchKeywords":["for","there","unrighteous","word","tongue","behold","lord","thou","hast","known","all","things"]},{"verseId":"brenton_psalms_138_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":5,"text":"the last and the first: thou hast fashioned me, and laid thine hand upon me.","searchKeywords":["the","last","and","first","thou","hast","fashioned","laid","thine","hand","upon"]},{"verseId":"brenton_psalms_138_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":6,"text":"The knowledge of thee is too wonderful for me; it is very difficult, I cannot to it.","searchKeywords":["the","knowledge","thee","too","wonderful","for","very","difficult","cannot"]},{"verseId":"brenton_psalms_138_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":7,"text":"Whither shall I go from thy Spirit? and whither shall I flee from thy presence?","searchKeywords":["whither","shall","from","thy","spirit","and","flee","presence"]},{"verseId":"brenton_psalms_138_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":8,"text":"If I should go up to heaven, thou art there: if I should go down to hell, thou art present.","searchKeywords":["should","heaven","thou","art","there","down","hell","present"]},{"verseId":"brenton_psalms_138_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":9,"text":"If I should spread my wings straight forward, and sojourn at the extremity of the sea, ,","searchKeywords":["should","spread","wings","straight","forward","and","sojourn","the","extremity","sea"]},{"verseId":"brenton_psalms_138_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":10,"text":"for even there thy hand would guide me, and thy right hand would hold me.","searchKeywords":["for","even","there","thy","hand","would","guide","and","right","hold"]},{"verseId":"brenton_psalms_138_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":11,"text":"When I said, Surely the darkness will cover me; even the night light in my luxury.","searchKeywords":["when","said","surely","the","darkness","will","cover","even","night","light","luxury"]},{"verseId":"brenton_psalms_138_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":12,"text":"For darkness will not be darkness with thee; but night will be light as day: as its darkness, so shall its light .","searchKeywords":["for","darkness","will","not","with","thee","but","night","light","day","its","shall"]},{"verseId":"brenton_psalms_138_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":13,"text":"For thou, O Lord, hast possessed my reins; thou hast helped me from my mother's womb.","searchKeywords":["for","thou","lord","hast","possessed","reins","helped","from","mother","womb"]},{"verseId":"brenton_psalms_138_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":14,"text":"I will give thee thanks; for thou art fearfully wondrous; wondrous are thy works; and my soul knows well.","searchKeywords":["will","give","thee","thanks","for","thou","art","fearfully","wondrous","are","thy","works","and","soul","knows","well"]},{"verseId":"brenton_psalms_138_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":15,"text":"My bones which thou madest in secret were not hidden from thee, nor my substance, in the lowest parts of the earth.","searchKeywords":["bones","which","thou","madest","secret","were","not","hidden","from","thee","nor","substance","the","lowest","parts","earth"]},{"verseId":"brenton_psalms_138_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":16,"text":"Thine eyes saw my unwrought , and all shall be written in thy book; they shall be formed by day, though be no one among them.","searchKeywords":["thine","eyes","saw","unwrought","and","all","shall","written","thy","book","they","formed","day","though","one","among","them"]},{"verseId":"brenton_psalms_138_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":17,"text":"But thy friends, O God, have been greatly honoured by me; their rule has been greatly strengthened.","searchKeywords":["but","thy","friends","god","have","been","greatly","honoured","their","rule","has","strengthened"]},{"verseId":"brenton_psalms_138_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":18,"text":"I will number them, and they shall be multiplied beyond the sand; I awake, and am still with thee.","searchKeywords":["will","number","them","and","they","shall","multiplied","beyond","the","sand","awake","still","with","thee"]},{"verseId":"brenton_psalms_138_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":19,"text":"Oh that thou wouldest slay the wicked, O God; depart from me, ye men of blood.","searchKeywords":["that","thou","wouldest","slay","the","wicked","god","depart","from","men","blood"]},{"verseId":"brenton_psalms_138_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":20,"text":"For thou wilt say concerning thought, they shall take thy cities in vain.","searchKeywords":["for","thou","wilt","say","concerning","thought","they","shall","take","thy","cities","vain"]},{"verseId":"brenton_psalms_138_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":21,"text":"Have I not hated them, O Lord, that hate thee? and wasted away because of thine enemies?","searchKeywords":["have","not","hated","them","lord","that","hate","thee","and","wasted","away","because","thine","enemies"]},{"verseId":"brenton_psalms_138_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":22,"text":"I have hated them with perfect hatred; they were counted my enemies.","searchKeywords":["have","hated","them","with","perfect","hatred","they","were","counted","enemies"]},{"verseId":"brenton_psalms_138_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":23,"text":"Prove me, O God, and know my heart; examine me, and know my paths;","searchKeywords":["prove","god","and","know","heart","examine","paths"]},{"verseId":"brenton_psalms_138_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":138,"verse":24,"text":"and see if way of iniquity in me, and lead me in an everlasting way.","searchKeywords":["and","see","way","iniquity","lead","everlasting"]}]