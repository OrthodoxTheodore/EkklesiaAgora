[{"verseId":"brenton_psalms_37_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":1,"text":"A Psalm of David for remembrance concerning the Sabbath-day.","searchKeywords":["psalm","david","for","remembrance","concerning","the","sabbath","day"]},{"verseId":"brenton_psalms_37_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":2,"text":"O Lord, rebuke me not in thy wrath, neither chasten me in thine anger.","searchKeywords":["lord","rebuke","not","thy","wrath","neither","chasten","thine","anger"]},{"verseId":"brenton_psalms_37_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":3,"text":"For thy weapons are fixed in me, and thou hast pressed thy hand heavily upon me.","searchKeywords":["for","thy","weapons","are","fixed","and","thou","hast","pressed","hand","heavily","upon"]},{"verseId":"brenton_psalms_37_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":4,"text":"For there is no health in my flesh because of thine anger; there is no peace to my bones because of my sins.","searchKeywords":["for","there","health","flesh","because","thine","anger","peace","bones","sins"]},{"verseId":"brenton_psalms_37_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":5,"text":"For my transgressions have gone over mine head: they have pressed heavily upon me like a weighty burden.","searchKeywords":["for","transgressions","have","gone","over","mine","head","they","pressed","heavily","upon","like","weighty","burden"]},{"verseId":"brenton_psalms_37_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":6,"text":"My bruises have become noisome and corrupt, because of my foolishness.","searchKeywords":["bruises","have","become","noisome","and","corrupt","because","foolishness"]},{"verseId":"brenton_psalms_37_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":7,"text":"I have been wretched and bowed down continually: I went with a mourning countenance all the day.","searchKeywords":["have","been","wretched","and","bowed","down","continually","went","with","mourning","countenance","all","the","day"]},{"verseId":"brenton_psalms_37_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":8,"text":"For my soul is filled with mockings; and there is no health in my flesh.","searchKeywords":["for","soul","filled","with","mockings","and","there","health","flesh"]},{"verseId":"brenton_psalms_37_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":9,"text":"I have been afflicted and brought down exceedingly: I have roared for the groaning of my heart.","searchKeywords":["have","been","afflicted","and","brought","down","exceedingly","roared","for","the","groaning","heart"]},{"verseId":"brenton_psalms_37_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":10,"text":"But all my desire is before thee; and my groaning is not hidden from thee.","searchKeywords":["but","all","desire","before","thee","and","groaning","not","hidden","from"]},{"verseId":"brenton_psalms_37_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":11,"text":"My heart is troubled, my strength has failed me; and the light of mine eyes is not with me.","searchKeywords":["heart","troubled","strength","has","failed","and","the","light","mine","eyes","not","with"]},{"verseId":"brenton_psalms_37_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":12,"text":"My friends and my neighbours drew near before me, and stood still; and my nearest of kin stood afar off.","searchKeywords":["friends","and","neighbours","drew","near","before","stood","still","nearest","kin","afar","off"]},{"verseId":"brenton_psalms_37_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":13,"text":"While they pressed hard upon me that sought my soul: and they that sought my hurt spoke vanities, and devised deceits all the day.","searchKeywords":["while","they","pressed","hard","upon","that","sought","soul","and","hurt","spoke","vanities","devised","deceits","all","the","day"]},{"verseId":"brenton_psalms_37_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":14,"text":"But I, as a deaf man, heard not; and was as a dumb man not opening his mouth.","searchKeywords":["but","deaf","man","heard","not","and","was","dumb","opening","his","mouth"]},{"verseId":"brenton_psalms_37_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":15,"text":"And I was as a man that hears not, and who has no reproofs in his mouth.","searchKeywords":["and","was","man","that","hears","not","who","has","reproofs","his","mouth"]},{"verseId":"brenton_psalms_37_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":16,"text":"For I hoped in thee, O Lord: thou wilt hear, O Lord my God.","searchKeywords":["for","hoped","thee","lord","thou","wilt","hear","god"]},{"verseId":"brenton_psalms_37_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":17,"text":"For I said, Lest mine enemies rejoice against me: for when my feet were moved, they spoke boastingly against me.","searchKeywords":["for","said","lest","mine","enemies","rejoice","against","when","feet","were","moved","they","spoke","boastingly"]},{"verseId":"brenton_psalms_37_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":18,"text":"For I am ready for plagues, and my grief is continually before me.","searchKeywords":["for","ready","plagues","and","grief","continually","before"]},{"verseId":"brenton_psalms_37_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":19,"text":"For I will declare mine iniquity, and be distressed for my sin.","searchKeywords":["for","will","declare","mine","iniquity","and","distressed","sin"]},{"verseId":"brenton_psalms_37_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":20,"text":"But mine enemies live, and are mightier than I: and they that hate me unjustly are multiplied.","searchKeywords":["but","mine","enemies","live","and","are","mightier","than","they","that","hate","unjustly","multiplied"]},{"verseId":"brenton_psalms_37_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":21,"text":"They that reward evil for good slandered me; because I followed righteousness.","searchKeywords":["they","that","reward","evil","for","good","slandered","because","followed","righteousness"]},{"verseId":"brenton_psalms_37_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":22,"text":"Forsake me not, O Lord my God: depart not from me.","searchKeywords":["forsake","not","lord","god","depart","from"]},{"verseId":"brenton_psalms_37_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":37,"verse":23,"text":"Draw nigh to my help, O Lord of my salvation.","searchKeywords":["draw","nigh","help","lord","salvation"]}]