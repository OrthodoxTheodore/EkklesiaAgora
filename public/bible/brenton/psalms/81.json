[{"verseId":"brenton_psalms_81_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":81,"verse":1,"text":"A Psalm for Asaph. will judge gods.","searchKeywords":["psalm","for","asaph","will","judge","gods"]},{"verseId":"brenton_psalms_81_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":81,"verse":2,"text":"How long will ye judge unrighteously, and accept the persons of sinners? Pause.","searchKeywords":["how","long","will","judge","unrighteously","and","accept","the","persons","sinners","pause"]},{"verseId":"brenton_psalms_81_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":81,"verse":3,"text":"Judge the orphan and poor: do justice to the low and needy.","searchKeywords":["judge","the","orphan","and","poor","justice","low","needy"]},{"verseId":"brenton_psalms_81_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":81,"verse":4,"text":"Rescue the needy, and deliver the poor out of the hand of the sinner.","searchKeywords":["rescue","the","needy","and","deliver","poor","out","hand","sinner"]},{"verseId":"brenton_psalms_81_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":81,"verse":5,"text":"They know not, nor understand; they walk on in darkness: all the foundations of the earth shall be shaken.","searchKeywords":["they","know","not","nor","understand","walk","darkness","all","the","foundations","earth","shall","shaken"]},{"verseId":"brenton_psalms_81_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":81,"verse":6,"text":"I have said, Ye are gods; and all children of the Most High.","searchKeywords":["have","said","are","gods","and","all","children","the","most","high"]},{"verseId":"brenton_psalms_81_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":81,"verse":7,"text":"But ye die as men, and fall as one of the princes.","searchKeywords":["but","die","men","and","fall","one","the","princes"]},{"verseId":"brenton_psalms_81_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":81,"verse":8,"text":"Arise, O God, judge the earth: for thou shalt inherit all nations.","searchKeywords":["arise","god","judge","the","earth","for","thou","shalt","inherit","all","nations"]}]