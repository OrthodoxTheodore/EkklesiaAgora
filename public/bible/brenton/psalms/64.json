[{"verseId":"brenton_psalms_64_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":1,"text":"For the end, a Psalm Song of David.","searchKeywords":["for","the","end","psalm","song","david"]},{"verseId":"brenton_psalms_64_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":2,"text":"Praise becomes thee, O God, in Sion; and to thee shall the vow be performed.","searchKeywords":["praise","becomes","thee","god","sion","and","shall","the","vow","performed"]},{"verseId":"brenton_psalms_64_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":3,"text":"Hear my prayer; to thee all flesh shall come.","searchKeywords":["hear","prayer","thee","all","flesh","shall","come"]},{"verseId":"brenton_psalms_64_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":4,"text":"The words of transgressors have overpowered us; but do thou pardon our sins.","searchKeywords":["the","words","transgressors","have","overpowered","but","thou","pardon","our","sins"]},{"verseId":"brenton_psalms_64_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":5,"text":"Blessed whom thou hast chosen and adopted; he shall dwell in thy courts; we shall be filled with the good things of thy house; thy temple is holy.","searchKeywords":["blessed","whom","thou","hast","chosen","and","adopted","shall","dwell","thy","courts","filled","with","the","good","things","house","temple","holy"]},{"verseId":"brenton_psalms_64_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":6,"text":"wonderful in righteousness. Hearken to us, O God our Saviour; the hope of all the ends of the earth, and of them on the sea afar off:","searchKeywords":["wonderful","righteousness","hearken","god","our","saviour","the","hope","all","ends","earth","and","them","sea","afar","off"]},{"verseId":"brenton_psalms_64_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":7,"text":"who dost establish the mountains in thy strength, being girded about with power;","searchKeywords":["who","dost","establish","the","mountains","thy","strength","being","girded","about","with","power"]},{"verseId":"brenton_psalms_64_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":8,"text":"who troublest the depth of the sea, the sounds of its waves.","searchKeywords":["who","troublest","the","depth","sea","sounds","its","waves"]},{"verseId":"brenton_psalms_64_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":9,"text":"The nations shall be troubled, and they that inhabit the ends shall be afraid of thy signs; thou wilt cause the outgoings of morning and evening to rejoice.","searchKeywords":["the","nations","shall","troubled","and","they","that","inhabit","ends","afraid","thy","signs","thou","wilt","cause","outgoings","morning","evening","rejoice"]},{"verseId":"brenton_psalms_64_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":10,"text":"Thou hast visited the earth, and saturated it; thou hast abundantly enriched it. The river of God is filled with water; thou hast prepared their food, for thus is the preparation .","searchKeywords":["thou","hast","visited","the","earth","and","saturated","abundantly","enriched","river","god","filled","with","water","prepared","their","food","for","thus","preparation"]},{"verseId":"brenton_psalms_64_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":11,"text":"Saturate her furrows, multiply her fruits; springing up shall rejoice in its drops.","searchKeywords":["saturate","her","furrows","multiply","fruits","springing","shall","rejoice","its","drops"]},{"verseId":"brenton_psalms_64_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":12,"text":"Thou wilt bless the crown of the year of thy goodness; and thy plains shall be filled with fatness.","searchKeywords":["thou","wilt","bless","the","crown","year","thy","goodness","and","plains","shall","filled","with","fatness"]},{"verseId":"brenton_psalms_64_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":13,"text":"The mountains of the wilderness shall be enriched; and the hills shall gird themselves with joy.","searchKeywords":["the","mountains","wilderness","shall","enriched","and","hills","gird","themselves","with","joy"]},{"verseId":"brenton_psalms_64_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":64,"verse":14,"text":"The rams of the flock are clothed , and the valleys shall abound in corn; they shall cry aloud, yea they shall sing hymns.","searchKeywords":["the","rams","flock","are","clothed","and","valleys","shall","abound","corn","they","cry","aloud","yea","sing","hymns"]}]