[{"verseId":"brenton_psalms_14_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":14,"verse":1,"text":"A Psalm of David.","searchKeywords":["psalm","david"]},{"verseId":"brenton_psalms_14_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":14,"verse":2,"text":"He that walks blameless, and works righteousness, who speaks truth in his heart.","searchKeywords":["that","walks","blameless","and","works","righteousness","who","speaks","truth","his","heart"]},{"verseId":"brenton_psalms_14_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":14,"verse":3,"text":"Who has not spoken craftily with his tongue, neither has done evil to his neighbour, nor taken up a reproach against them that dwelt nearest to him.","searchKeywords":["who","has","not","spoken","craftily","with","his","tongue","neither","done","evil","neighbour","nor","taken","reproach","against","them","that","dwelt","nearest","him"]},{"verseId":"brenton_psalms_14_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":14,"verse":4,"text":"In his sight an evil-worker is set at nought, but he honours them that fear the Lord. He swears to his neighbour, and disappoints not.","searchKeywords":["his","sight","evil","worker","set","nought","but","honours","them","that","fear","the","lord","swears","neighbour","and","disappoints","not"]},{"verseId":"brenton_psalms_14_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":14,"verse":5,"text":"He has not lent his money on usury, and has not received bribes against the innocent. He that does these things shall never be moved.","searchKeywords":["has","not","lent","his","money","usury","and","received","bribes","against","the","innocent","that","does","these","things","shall","never","moved"]}]