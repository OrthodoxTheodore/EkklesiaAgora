[{"verseId":"brenton_psalms_101_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":1,"text":"A Prayer for the Poor; when he is deeply afflicted, and pours out his supplication before the Lord.","searchKeywords":["prayer","for","the","poor","when","deeply","afflicted","and","pours","out","his","supplication","before","lord"]},{"verseId":"brenton_psalms_101_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":2,"text":"Hear my prayer, O Lord, and let my cry come to thee.","searchKeywords":["hear","prayer","lord","and","let","cry","come","thee"]},{"verseId":"brenton_psalms_101_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":3,"text":"Turn not away thy face from me: in the day I am afflicted, incline thine ear to me: in the day I shall call upon thee, speedily hear me.","searchKeywords":["turn","not","away","thy","face","from","the","day","afflicted","incline","thine","ear","shall","call","upon","thee","speedily","hear"]},{"verseId":"brenton_psalms_101_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":4,"text":"For my days have vanished like smoke, and my bones have been parched like a stick.","searchKeywords":["for","days","have","vanished","like","smoke","and","bones","been","parched","stick"]},{"verseId":"brenton_psalms_101_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":5,"text":"I am blighted like grass, and my heart is dried up; for I have forgotten to eat my bread.","searchKeywords":["blighted","like","grass","and","heart","dried","for","have","forgotten","eat","bread"]},{"verseId":"brenton_psalms_101_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":6,"text":"By reason of the voice of my groaning, my bone has cleaved to my flesh.","searchKeywords":["reason","the","voice","groaning","bone","has","cleaved","flesh"]},{"verseId":"brenton_psalms_101_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":7,"text":"I have become like a pelican of the wilderness;","searchKeywords":["have","become","like","pelican","the","wilderness"]},{"verseId":"brenton_psalms_101_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":8,"text":"I have become like an owl in a ruined house. I have watched, and am become as a sparrow dwelling alone on a roof.","searchKeywords":["have","become","like","owl","ruined","house","watched","and","sparrow","dwelling","alone","roof"]},{"verseId":"brenton_psalms_101_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":9,"text":"All the day long mine enemies have reproached me; and they that praised me have sworn against me.","searchKeywords":["all","the","day","long","mine","enemies","have","reproached","and","they","that","praised","sworn","against"]},{"verseId":"brenton_psalms_101_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":10,"text":"For I have eaten ashes as it were bread, and mingled my drink with weeping;","searchKeywords":["for","have","eaten","ashes","were","bread","and","mingled","drink","with","weeping"]},{"verseId":"brenton_psalms_101_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":11,"text":"because of thine anger and thy wrath: for thou hast lifted me up, and dashed me down.","searchKeywords":["because","thine","anger","and","thy","wrath","for","thou","hast","lifted","dashed","down"]},{"verseId":"brenton_psalms_101_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":12,"text":"My days have declined like a shadow; and I am withered like grass.","searchKeywords":["days","have","declined","like","shadow","and","withered","grass"]},{"verseId":"brenton_psalms_101_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":13,"text":"But thou, Lord, endurest for ever, and thy memorial to generation and generation.","searchKeywords":["but","thou","lord","endurest","for","ever","and","thy","memorial","generation"]},{"verseId":"brenton_psalms_101_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":14,"text":"Thou shalt arise, and have mercy upon Sion: for time to have mercy upon her, for the set time is come.","searchKeywords":["thou","shalt","arise","and","have","mercy","upon","sion","for","time","her","the","set","come"]},{"verseId":"brenton_psalms_101_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":15,"text":"For thy servants have taken pleasure in her stones, and they shall pity her dust.","searchKeywords":["for","thy","servants","have","taken","pleasure","her","stones","and","they","shall","pity","dust"]},{"verseId":"brenton_psalms_101_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":16,"text":"So the nations shall fear thy name, O Lord, and all kings thy glory.","searchKeywords":["the","nations","shall","fear","thy","name","lord","and","all","kings","glory"]},{"verseId":"brenton_psalms_101_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":17,"text":"For the Lord shall build up Sion, and shall appear in his glory.","searchKeywords":["for","the","lord","shall","build","sion","and","appear","his","glory"]},{"verseId":"brenton_psalms_101_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":18,"text":"He has had regard to the prayer of the lowly, and has not despised their petition.","searchKeywords":["has","had","regard","the","prayer","lowly","and","not","despised","their","petition"]},{"verseId":"brenton_psalms_101_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":19,"text":"Let this be written for another generation; and the people that shall be created shall praise the Lord.","searchKeywords":["let","this","written","for","another","generation","and","the","people","that","shall","created","praise","lord"]},{"verseId":"brenton_psalms_101_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":20,"text":"For he has looked out from the height of his sanctuary; the Lord looked upon the earth from heaven;","searchKeywords":["for","has","looked","out","from","the","height","his","sanctuary","lord","upon","earth","heaven"]},{"verseId":"brenton_psalms_101_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":21,"text":"to hear the groaning of the fettered ones, to loosen the sons of the slain;","searchKeywords":["hear","the","groaning","fettered","ones","loosen","sons","slain"]},{"verseId":"brenton_psalms_101_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":22,"text":"to proclaim the name of the Lord in Sion, and his praise in Jerusalem;","searchKeywords":["proclaim","the","name","lord","sion","and","his","praise","jerusalem"]},{"verseId":"brenton_psalms_101_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":23,"text":"when the people are gathered together, and the kings, to serve the Lord.","searchKeywords":["when","the","people","are","gathered","together","and","kings","serve","lord"]},{"verseId":"brenton_psalms_101_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":24,"text":"He answered him in the way of his strength: tell me the fewness of my days.","searchKeywords":["answered","him","the","way","his","strength","tell","fewness","days"]},{"verseId":"brenton_psalms_101_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":25,"text":"Take me not away in the midst of my days: thy years through all generations.","searchKeywords":["take","not","away","the","midst","days","thy","years","through","all","generations"]},{"verseId":"brenton_psalms_101_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":26,"text":"In the beginning thou, O Lord, didst lay the foundation of the earth; and the heavens are the works of thine hands.","searchKeywords":["the","beginning","thou","lord","didst","lay","foundation","earth","and","heavens","are","works","thine","hands"]},{"verseId":"brenton_psalms_101_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":27,"text":"They shall perish, but thou remainest: and shall wax old as a garment; and as a vesture shalt thou fold them, and they shall be changed.","searchKeywords":["they","shall","perish","but","thou","remainest","and","wax","old","garment","vesture","shalt","fold","them","changed"]},{"verseId":"brenton_psalms_101_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":28,"text":"But thou art the same, and thy years shall not fail.","searchKeywords":["but","thou","art","the","same","and","thy","years","shall","not","fail"]},{"verseId":"brenton_psalms_101_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":101,"verse":29,"text":"The children of thy servants shall dwell , and their seed shall prosper for ever.","searchKeywords":["the","children","thy","servants","shall","dwell","and","their","seed","prosper","for","ever"]}]