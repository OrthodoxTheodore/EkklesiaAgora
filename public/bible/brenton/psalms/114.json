[{"verseId":"brenton_psalms_114_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":114,"verse":1,"text":"Alleluia.","searchKeywords":["alleluia"]},{"verseId":"brenton_psalms_114_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":114,"verse":2,"text":"Because he has inclined his ear to me, therefore will I call upon him while I live.","searchKeywords":["because","has","inclined","his","ear","therefore","will","call","upon","him","while","live"]},{"verseId":"brenton_psalms_114_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":114,"verse":3,"text":"The pangs of death compassed me; the dangers of hell found me: I found affliction and sorrow.","searchKeywords":["the","pangs","death","compassed","dangers","hell","found","affliction","and","sorrow"]},{"verseId":"brenton_psalms_114_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":114,"verse":4,"text":"Then I called on the name of the Lord: O Lord, deliver my soul.","searchKeywords":["then","called","the","name","lord","deliver","soul"]},{"verseId":"brenton_psalms_114_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":114,"verse":5,"text":"The Lord is merciful and righteous; yea, our God has pity.","searchKeywords":["the","lord","merciful","and","righteous","yea","our","god","has","pity"]},{"verseId":"brenton_psalms_114_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":114,"verse":6,"text":"The Lord preserves the simple: I was brought low, and he delivered me.","searchKeywords":["the","lord","preserves","simple","was","brought","low","and","delivered"]},{"verseId":"brenton_psalms_114_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":114,"verse":7,"text":"Return to thy rest, O my soul; for the Lord has dealt bountifully with thee.","searchKeywords":["return","thy","rest","soul","for","the","lord","has","dealt","bountifully","with","thee"]},{"verseId":"brenton_psalms_114_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":114,"verse":8,"text":"For he has delivered my soul from death, mine eyes from tears, and my feet from falling.","searchKeywords":["for","has","delivered","soul","from","death","mine","eyes","tears","and","feet","falling"]},{"verseId":"brenton_psalms_114_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":114,"verse":9,"text":"I shall be well-pleasing before the Lord in the land of the living.","searchKeywords":["shall","well","pleasing","before","the","lord","land","living"]}]