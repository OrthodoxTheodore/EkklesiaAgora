[{"verseId":"brenton_psalms_16_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":1,"text":"A Prayer of David. of my righteousness, attend to my petition; give ear to my prayer not with deceitful lips.","searchKeywords":["prayer","david","righteousness","attend","petition","give","ear","not","with","deceitful","lips"]},{"verseId":"brenton_psalms_16_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":2,"text":"Let my judgment come forth from thy presence; let mine eyes behold righteousness.","searchKeywords":["let","judgment","come","forth","from","thy","presence","mine","eyes","behold","righteousness"]},{"verseId":"brenton_psalms_16_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":3,"text":"Thou hast proved mine heart; thou hast visited by night; thou hast tried me as with fire, and unrighteousness has not been found in me: that my mouth shall not speak .","searchKeywords":["thou","hast","proved","mine","heart","visited","night","tried","with","fire","and","unrighteousness","has","not","been","found","that","mouth","shall","speak"]},{"verseId":"brenton_psalms_16_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":4,"text":"As for the works of men, by the words of thy lips I have guarded hard ways.","searchKeywords":["for","the","works","men","words","thy","lips","have","guarded","hard","ways"]},{"verseId":"brenton_psalms_16_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":5,"text":"Direct my steps in thy paths, that my steps slip not.","searchKeywords":["direct","steps","thy","paths","that","slip","not"]},{"verseId":"brenton_psalms_16_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":6,"text":"I have cried, for thou heardest me, O God: incline thine ear to me, and hearken to my words.","searchKeywords":["have","cried","for","thou","heardest","god","incline","thine","ear","and","hearken","words"]},{"verseId":"brenton_psalms_16_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":7,"text":"Shew the marvels of thy mercies, thou that savest them that hope in thee.","searchKeywords":["shew","the","marvels","thy","mercies","thou","that","savest","them","hope","thee"]},{"verseId":"brenton_psalms_16_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":8,"text":"Keep me as the apple of the eye from those that resist thy right hand: thou shalt screen me by the covering of thy wings,","searchKeywords":["keep","the","apple","eye","from","those","that","resist","thy","right","hand","thou","shalt","screen","covering","wings"]},{"verseId":"brenton_psalms_16_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":9,"text":"from the face of the ungodly that have afflicted me: mine enemies have compassed about my soul.","searchKeywords":["from","the","face","ungodly","that","have","afflicted","mine","enemies","compassed","about","soul"]},{"verseId":"brenton_psalms_16_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":10,"text":"They have enclosed their own fat: their mouth has spoken pride.","searchKeywords":["they","have","enclosed","their","own","fat","mouth","has","spoken","pride"]},{"verseId":"brenton_psalms_16_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":11,"text":"They have now cast me out and compassed me round about: they have set their eyes to bow them down to the ground.","searchKeywords":["they","have","now","cast","out","and","compassed","round","about","set","their","eyes","bow","them","down","the","ground"]},{"verseId":"brenton_psalms_16_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":12,"text":"They laid wait for me as a lion ready for prey, and like a lion's whelp dwelling in secret .","searchKeywords":["they","laid","wait","for","lion","ready","prey","and","like","whelp","dwelling","secret"]},{"verseId":"brenton_psalms_16_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":13,"text":"Arise, O Lord, prevent them, and cast them down: deliver my soul from the ungodly: thy sword,","searchKeywords":["arise","lord","prevent","them","and","cast","down","deliver","soul","from","the","ungodly","thy","sword"]},{"verseId":"brenton_psalms_16_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":14,"text":"because of the enemies of thine hand: O Lord, destroy them from the earth; scatter them in their life, though their belly has been filled with thy hidden : they have been satisfied with uncleanness, and have left the remnant to their babes.","searchKeywords":["because","the","enemies","thine","hand","lord","destroy","them","from","earth","scatter","their","life","though","belly","has","been","filled","with","thy","hidden","they","have","satisfied","uncleanness","and","left","remnant","babes"]},{"verseId":"brenton_psalms_16_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":16,"verse":15,"text":"But I shall appear in righteousness before thy face: I shall be satisfied when thy glory appears.","searchKeywords":["but","shall","appear","righteousness","before","thy","face","satisfied","when","glory","appears"]}]