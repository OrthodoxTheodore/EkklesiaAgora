[{"verseId":"brenton_psalms_126_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":126,"verse":1,"text":"A Song of Degrees.","searchKeywords":["song","degrees"]},{"verseId":"brenton_psalms_126_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":126,"verse":2,"text":"It is vain for you to rise early: ye rise up after resting, ye that eat the bread of grief; while he gives sleep to his beloved.","searchKeywords":["vain","for","you","rise","early","after","resting","that","eat","the","bread","grief","while","gives","sleep","his","beloved"]},{"verseId":"brenton_psalms_126_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":126,"verse":3,"text":"Behold, the inheritance of the Lord, children, the reward of the fruit of the womb.","searchKeywords":["behold","the","inheritance","lord","children","reward","fruit","womb"]},{"verseId":"brenton_psalms_126_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":126,"verse":4,"text":"As arrows in the hand of a mighty man; so are the children of those who were outcasts.","searchKeywords":["arrows","the","hand","mighty","man","are","children","those","who","were","outcasts"]},{"verseId":"brenton_psalms_126_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":126,"verse":5,"text":"Blessed is the man who shall satisfy his desire with them: they shall not be ashamed when they shall speak to their enemies in the gates.","searchKeywords":["blessed","the","man","who","shall","satisfy","his","desire","with","them","they","not","ashamed","when","speak","their","enemies","gates"]}]