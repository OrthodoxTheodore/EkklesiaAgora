[{"verseId":"brenton_psalms_79_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":1,"text":"For the end, for alternate , a testimony for Asaph, a Psalm concerning the Assyrian.","searchKeywords":["for","the","end","alternate","testimony","asaph","psalm","concerning","assyrian"]},{"verseId":"brenton_psalms_79_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":2,"text":"Attend, O Shepherd of Israel, who guidest Joseph like a flock; thou who sittest upon the cherubs, manifest thyself;","searchKeywords":["attend","shepherd","israel","who","guidest","joseph","like","flock","thou","sittest","upon","the","cherubs","manifest","thyself"]},{"verseId":"brenton_psalms_79_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":3,"text":"before Ephraim and Benjamin and Manasse, stir up thy power, and come to deliver us.","searchKeywords":["before","ephraim","and","benjamin","manasse","stir","thy","power","come","deliver"]},{"verseId":"brenton_psalms_79_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":4,"text":"Turn us, O God, and cause thy face to shine; and we shall be delivered.","searchKeywords":["turn","god","and","cause","thy","face","shine","shall","delivered"]},{"verseId":"brenton_psalms_79_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":5,"text":"O Lord God of hosts, how long art thou angry with the prayer of thy servant?","searchKeywords":["lord","god","hosts","how","long","art","thou","angry","with","the","prayer","thy","servant"]},{"verseId":"brenton_psalms_79_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":6,"text":"Thou wilt feed us with bread of tears; and wilt cause us to drink tears by measure.","searchKeywords":["thou","wilt","feed","with","bread","tears","and","cause","drink","measure"]},{"verseId":"brenton_psalms_79_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":7,"text":"Thou hast made us a strife to our neighbours; and our enemies have mocked at us.","searchKeywords":["thou","hast","made","strife","our","neighbours","and","enemies","have","mocked"]},{"verseId":"brenton_psalms_79_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":8,"text":"Turn us, O Lord God of hosts, and cause thy face to shine; and we shall be saved. Pause.","searchKeywords":["turn","lord","god","hosts","and","cause","thy","face","shine","shall","saved","pause"]},{"verseId":"brenton_psalms_79_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":9,"text":"Thou hast transplanted a vine out of Egypt: thou hast cast out the heathen, and planted it.","searchKeywords":["thou","hast","transplanted","vine","out","egypt","cast","the","heathen","and","planted"]},{"verseId":"brenton_psalms_79_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":10,"text":"Thou madest a way before it, and didst cause its roots to strike, and the land was filled .","searchKeywords":["thou","madest","way","before","and","didst","cause","its","roots","strike","the","land","was","filled"]},{"verseId":"brenton_psalms_79_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":11,"text":"Its shadow covered the mountains, and its shoots the goodly cedars.","searchKeywords":["its","shadow","covered","the","mountains","and","shoots","goodly","cedars"]},{"verseId":"brenton_psalms_79_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":12,"text":"It sent forth its branches to the sea, and its shoots to the river.","searchKeywords":["sent","forth","its","branches","the","sea","and","shoots","river"]},{"verseId":"brenton_psalms_79_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":13,"text":"Wherefore hast thou broken down its hedge, while all that pass by the way pluck it?","searchKeywords":["wherefore","hast","thou","broken","down","its","hedge","while","all","that","pass","the","way","pluck"]},{"verseId":"brenton_psalms_79_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":14,"text":"The boar out of the wood has laid it waste, and the wild beast has devoured it.","searchKeywords":["the","boar","out","wood","has","laid","waste","and","wild","beast","devoured"]},{"verseId":"brenton_psalms_79_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":15,"text":"O God of hosts, turn, we pray thee: look on from heaven, and behold and visit this vine;","searchKeywords":["god","hosts","turn","pray","thee","look","from","heaven","and","behold","visit","this","vine"]},{"verseId":"brenton_psalms_79_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":16,"text":"and restore that which thy right hand has planted: and look on the son of man whom thou didst strengthen for thyself.","searchKeywords":["and","restore","that","which","thy","right","hand","has","planted","look","the","son","man","whom","thou","didst","strengthen","for","thyself"]},{"verseId":"brenton_psalms_79_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":17,"text":"burnt with fire and dug up: they shall perish at the rebuke of thy presence.","searchKeywords":["burnt","with","fire","and","dug","they","shall","perish","the","rebuke","thy","presence"]},{"verseId":"brenton_psalms_79_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":18,"text":"Let thy hand be upon the man of thy right hand, and upon the son of man whom thou didst strengthen for thyself.","searchKeywords":["let","thy","hand","upon","the","man","right","and","son","whom","thou","didst","strengthen","for","thyself"]},{"verseId":"brenton_psalms_79_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":19,"text":"So will we not depart from thee: thou shalt quicken us, and we will call upon thy name.","searchKeywords":["will","not","depart","from","thee","thou","shalt","quicken","and","call","upon","thy","name"]},{"verseId":"brenton_psalms_79_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":79,"verse":20,"text":"Turn us, O Lord God of hosts, and make thy face to shine; and we shall be saved.","searchKeywords":["turn","lord","god","hosts","and","make","thy","face","shine","shall","saved"]}]