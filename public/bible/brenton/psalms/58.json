[{"verseId":"brenton_psalms_58_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":1,"text":"For the end. Destroy not: by David for a memorial, when Saul sent, and watched his house to kill him.","searchKeywords":["for","the","end","destroy","not","david","memorial","when","saul","sent","and","watched","his","house","kill","him"]},{"verseId":"brenton_psalms_58_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":2,"text":"Deliver me from mine enemies, O God; and ransom me from those that rise up against me.","searchKeywords":["deliver","from","mine","enemies","god","and","ransom","those","that","rise","against"]},{"verseId":"brenton_psalms_58_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":3,"text":"Deliver me from the workers of iniquity, and save me from bloody men.","searchKeywords":["deliver","from","the","workers","iniquity","and","save","bloody","men"]},{"verseId":"brenton_psalms_58_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":4,"text":"For, behold, they have hunted after my soul; violent men have set upon me: neither my iniquity, nor my sin, O Lord.","searchKeywords":["for","behold","they","have","hunted","after","soul","violent","men","set","upon","neither","iniquity","nor","sin","lord"]},{"verseId":"brenton_psalms_58_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":5,"text":"Without iniquity I ran and directed : awake to help me, and behold.","searchKeywords":["without","iniquity","ran","and","directed","awake","help","behold"]},{"verseId":"brenton_psalms_58_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":6,"text":"And thou, Lord God of hosts, the God of Israel, draw nigh to visit all the heathen; pity not any that work iniquity. Pause.","searchKeywords":["and","thou","lord","god","hosts","the","israel","draw","nigh","visit","all","heathen","pity","not","any","that","work","iniquity","pause"]},{"verseId":"brenton_psalms_58_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":7,"text":"They shall return at evening, and hunger like a dog, and go round about the city.","searchKeywords":["they","shall","return","evening","and","hunger","like","dog","round","about","the","city"]},{"verseId":"brenton_psalms_58_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":8,"text":"Behold, they shall utter a voice with their mouth, and a sword is in their lips; for who, , has heard?","searchKeywords":["behold","they","shall","utter","voice","with","their","mouth","and","sword","lips","for","who","has","heard"]},{"verseId":"brenton_psalms_58_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":9,"text":"But thou, Lord, wilt laugh them to scorn; thou wilt utterly set at nought all the heathen.","searchKeywords":["but","thou","lord","wilt","laugh","them","scorn","utterly","set","nought","all","the","heathen"]},{"verseId":"brenton_psalms_58_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":10,"text":"I will keep my strength, to thee; for thou, O God, art my helper.","searchKeywords":["will","keep","strength","thee","for","thou","god","art","helper"]},{"verseId":"brenton_psalms_58_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":11,"text":"my God, his mercy shall go before me: my God will shew me on mine enemies.","searchKeywords":["god","his","mercy","shall","before","will","shew","mine","enemies"]},{"verseId":"brenton_psalms_58_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":12,"text":"Slay them not, lest they forget thy law; scatter them by thy power; and bring them down, O Lord, my defender.","searchKeywords":["slay","them","not","lest","they","forget","thy","law","scatter","power","and","bring","down","lord","defender"]},{"verseId":"brenton_psalms_58_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":13,"text":"the sin of their mouth, the word of their lips, let them be even taken in their pride.","searchKeywords":["the","sin","their","mouth","word","lips","let","them","even","taken","pride"]},{"verseId":"brenton_psalms_58_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":14,"text":"And for cursing and falsehood shall utter destruction be denounced: by the wrath of utter destruction, and shall not be; so shall they know that the God of Jacob is Lord of the ends of the earth. Pause.","searchKeywords":["and","for","cursing","falsehood","shall","utter","destruction","denounced","the","wrath","not","they","know","that","god","jacob","lord","ends","earth","pause"]},{"verseId":"brenton_psalms_58_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":15,"text":"They shall return at evening, and be hungry as a dog, and go round about the city.","searchKeywords":["they","shall","return","evening","and","hungry","dog","round","about","the","city"]},{"verseId":"brenton_psalms_58_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":16,"text":"They shall be scattered hither and thither for meat; and if they be not satisfied, they shall even murmur.","searchKeywords":["they","shall","scattered","hither","and","thither","for","meat","not","satisfied","even","murmur"]},{"verseId":"brenton_psalms_58_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":17,"text":"But I will sing to thy strength, and in the morning will I exult thy mercy; for thou hast been my supporter, and my refuge in the day of mine affliction.","searchKeywords":["but","will","sing","thy","strength","and","the","morning","exult","mercy","for","thou","hast","been","supporter","refuge","day","mine","affliction"]},{"verseId":"brenton_psalms_58_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":58,"verse":18,"text":"my helper; to thee, my God, will I sing; thou art my supporter, O my God, my mercy.","searchKeywords":["helper","thee","god","will","sing","thou","art","supporter","mercy"]}]