ton_psalms_136_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":136,"verse":7,"text":"Remember, O Lord, the children of Edom in the day of Jerusalem; who said, Rase , rase , even to its foundations.","searchKeywords":["remember","lord","the","children","edom","day","jerusalem","who","said","rase","even","its","foundations"]},{"verseId":"brenton_psalms_136_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":136,"verse":8,"text":"Wretched daughter of Babylon! blessed who shall reward thee as thou hast rewarded us.","searchKeywords":["wretched","daughter","babylon","blessed","who","shall","reward","thee","thou","hast","rewarded"]},{"verseId":"brenton_psalms_136_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":136,"verse":9,"text":"Blessed who shall seize and dash thine infants against the rock.","searchKeywords":["blessed","who","shall","seize","and","dash","thine","infants","against","the","rock"]}]