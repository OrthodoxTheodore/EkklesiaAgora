[{"verseId":"brenton_psalms_80_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":1,"text":"For the end, a Psalm for Asaph, concerning the wine-presses.","searchKeywords":["for","the","end","psalm","asaph","concerning","wine","presses"]},{"verseId":"brenton_psalms_80_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":2,"text":"Rejoice ye in God our helper; shout aloud to the God of Jacob.","searchKeywords":["rejoice","god","our","helper","shout","aloud","the","jacob"]},{"verseId":"brenton_psalms_80_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":3,"text":"Take a psalm, and produce the timbrel, the pleasant psaltery with the harp.","searchKeywords":["take","psalm","and","produce","the","timbrel","pleasant","psaltery","with","harp"]},{"verseId":"brenton_psalms_80_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":4,"text":"Blow the trumpet at the new moon, in the glorious day of your feast.","searchKeywords":["blow","the","trumpet","new","moon","glorious","day","your","feast"]},{"verseId":"brenton_psalms_80_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":5,"text":"For is an ordinance for Israel, and a statute of the God of Jacob.","searchKeywords":["for","ordinance","israel","and","statute","the","god","jacob"]},{"verseId":"brenton_psalms_80_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":6,"text":"He made it a testimony in Joseph, when he came forth out of the land of Egypt: he heard a language which he understood not.","searchKeywords":["made","testimony","joseph","when","came","forth","out","the","land","egypt","heard","language","which","understood","not"]},{"verseId":"brenton_psalms_80_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":7,"text":"He removed his back from burdens: his hands slaved in making the baskets.","searchKeywords":["removed","his","back","from","burdens","hands","slaved","making","the","baskets"]},{"verseId":"brenton_psalms_80_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":8,"text":"Thou didst call upon me in trouble, and I delivered thee; I heard thee in the secret place of the storm: I proved thee at the water of Strife. Pause.","searchKeywords":["thou","didst","call","upon","trouble","and","delivered","thee","heard","the","secret","place","storm","proved","water","strife","pause"]},{"verseId":"brenton_psalms_80_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":9,"text":"Hear, my people, and I will speak to thee, O Israel; and I will testify to thee: if thou wilt hearken to me;","searchKeywords":["hear","people","and","will","speak","thee","israel","testify","thou","wilt","hearken"]},{"verseId":"brenton_psalms_80_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":10,"text":"there shall be no new god in thee; neither shalt thou worship a strange god.","searchKeywords":["there","shall","new","god","thee","neither","shalt","thou","worship","strange"]},{"verseId":"brenton_psalms_80_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":11,"text":"For I am the Lord thy God, that brought thee out of the land of Egypt: open thy mouth wide, and I will fill it.","searchKeywords":["for","the","lord","thy","god","that","brought","thee","out","land","egypt","open","mouth","wide","and","will","fill"]},{"verseId":"brenton_psalms_80_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":12,"text":"But my people hearkened not to my voice; and Israel gave no heed to me.","searchKeywords":["but","people","hearkened","not","voice","and","israel","gave","heed"]},{"verseId":"brenton_psalms_80_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":13,"text":"So I let them go after the ways of their own hearts: they will go on in their own ways.","searchKeywords":["let","them","after","the","ways","their","own","hearts","they","will"]},{"verseId":"brenton_psalms_80_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":14,"text":"If my people had hearkened to me, if Israel had walked in my ways,","searchKeywords":["people","had","hearkened","israel","walked","ways"]},{"verseId":"brenton_psalms_80_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":15,"text":"I should have put down their enemies very quickly, and should have laid my hand upon those that afflicted them.","searchKeywords":["should","have","put","down","their","enemies","very","quickly","and","laid","hand","upon","those","that","afflicted","them"]},{"verseId":"brenton_psalms_80_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":16,"text":"The Lord's enemies lied to him: but their time shall be for ever.","searchKeywords":["the","lord","enemies","lied","him","but","their","time","shall","for","ever"]},{"verseId":"brenton_psalms_80_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":80,"verse":17,"text":"And he fed them with the fat of wheat; and satisfied them with honey out of the rock.","searchKeywords":["and","fed","them","with","the","fat","wheat","satisfied","honey","out","rock"]}]