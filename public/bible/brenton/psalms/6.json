[{"verseId":"brenton_psalms_6_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":6,"verse":1,"text":"For the end, a Psalm of David among the Hymns for the eighth.","searchKeywords":["for","the","end","psalm","david","among","hymns","eighth"]},{"verseId":"brenton_psalms_6_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":6,"verse":2,"text":"O Lord, rebuke me not in thy wrath, neither chasten me in thine anger.","searchKeywords":["lord","rebuke","not","thy","wrath","neither","chasten","thine","anger"]},{"verseId":"brenton_psalms_6_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":6,"verse":3,"text":"Pity me, O Lord; for I am weak: heal me, O Lord; for my bones are vexed.","searchKeywords":["pity","lord","for","weak","heal","bones","are","vexed"]},{"verseId":"brenton_psalms_6_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":6,"verse":4,"text":"My soul also is grievously vexed: but thou, O Lord, how long?","searchKeywords":["soul","also","grievously","vexed","but","thou","lord","how","long"]},{"verseId":"brenton_psalms_6_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":6,"verse":5,"text":"Return, O Lord, deliver my soul: save me for thy mercy's sake.","searchKeywords":["return","lord","deliver","soul","save","for","thy","mercy","sake"]},{"verseId":"brenton_psalms_6_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":6,"verse":6,"text":"For in death no man remembers thee: and who will give thee thanks in Hades?","searchKeywords":["for","death","man","remembers","thee","and","who","will","give","thanks","hades"]},{"verseId":"brenton_psalms_6_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":6,"verse":7,"text":"I am wearied with my groaning; I shall wash my bed every night; I shall water my couch with my tears.","searchKeywords":["wearied","with","groaning","shall","wash","bed","every","night","water","couch","tears"]},{"verseId":"brenton_psalms_6_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":6,"verse":8,"text":"Mine eye is troubled because of my wrath; I am worn out because of all my enemies.","searchKeywords":["mine","eye","troubled","because","wrath","worn","out","all","enemies"]},{"verseId":"brenton_psalms_6_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":6,"verse":9,"text":"Depart from me, all ye that work iniquity; for the Lord has heard the voice of my weeping.","searchKeywords":["depart","from","all","that","work","iniquity","for","the","lord","has","heard","voice","weeping"]},{"verseId":"brenton_psalms_6_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":6,"verse":10,"text":"The Lord has hearkened to my petition; the Lord has accepted my prayer.","searchKeywords":["the","lord","has","hearkened","petition","accepted","prayer"]},{"verseId":"brenton_psalms_6_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":6,"verse":11,"text":"Let all mine enemies be put to shame and sore troubled: let them be turned back and grievously put to shame speedily.","searchKeywords":["let","all","mine","enemies","put","shame","and","sore","troubled","them","turned","back","grievously","speedily"]}]