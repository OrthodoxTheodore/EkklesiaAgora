[{"verseId":"brenton_psalms_111_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":111,"verse":1,"text":"Alleluia.","searchKeywords":["alleluia"]},{"verseId":"brenton_psalms_111_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":111,"verse":2,"text":"His seed shall be mighty in the earth: the generation of the upright shall be blessed.","searchKeywords":["his","seed","shall","mighty","the","earth","generation","upright","blessed"]},{"verseId":"brenton_psalms_111_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":111,"verse":3,"text":"Glory and riches shall be in his house; and his righteousness endures for evermore.","searchKeywords":["glory","and","riches","shall","his","house","righteousness","endures","for","evermore"]},{"verseId":"brenton_psalms_111_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":111,"verse":4,"text":"To the upright light has sprung up in darkness: he is pitiful, and merciful, and righteous.","searchKeywords":["the","upright","light","has","sprung","darkness","pitiful","and","merciful","righteous"]},{"verseId":"brenton_psalms_111_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":111,"verse":5,"text":"The good man is he that pities and lends: he will direct his affairs with judgment.","searchKeywords":["the","good","man","that","pities","and","lends","will","direct","his","affairs","with","judgment"]},{"verseId":"brenton_psalms_111_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":111,"verse":6,"text":"For he shall not be moved for ever; the righteous shall be in everlasting remembrance.","searchKeywords":["for","shall","not","moved","ever","the","righteous","everlasting","remembrance"]},{"verseId":"brenton_psalms_111_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":111,"verse":7,"text":"He shall not be afraid of evil report: his heart is ready to trust in the Lord.","searchKeywords":["shall","not","afraid","evil","report","his","heart","ready","trust","the","lord"]},{"verseId":"brenton_psalms_111_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":111,"verse":8,"text":"His heart is established, he shall not fear, till he shall see upon his enemies.","searchKeywords":["his","heart","established","shall","not","fear","till","see","upon","enemies"]},{"verseId":"brenton_psalms_111_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":111,"verse":9,"text":"He has dispersed abroad; he has given to the poor; his righteousness endures for evermore: his horn shall be exalted with honour.","searchKeywords":["has","dispersed","abroad","given","the","poor","his","righteousness","endures","for","evermore","horn","shall","exalted","with","honour"]},{"verseId":"brenton_psalms_111_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":111,"verse":10,"text":"The sinner shall see and be angry, he shall gnash his teeth, and consume away: the desire of the sinner shall perish.","searchKeywords":["the","sinner","shall","see","and","angry","gnash","his","teeth","consume","away","desire","perish"]}]