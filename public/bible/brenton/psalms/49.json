[{"verseId":"brenton_psalms_49_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":1,"text":"A Psalm for Asaph. .","searchKeywords":["psalm","for","asaph"]},{"verseId":"brenton_psalms_49_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":2,"text":"Out of Sion the excellence of his beauty.","searchKeywords":["out","sion","the","excellence","his","beauty"]},{"verseId":"brenton_psalms_49_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":3,"text":"God, our God, shall come manifestly, and shall not keep silence: a fire shall be kindled before him, and round about him there shall be a very great tempest.","searchKeywords":["god","our","shall","come","manifestly","and","not","keep","silence","fire","kindled","before","him","round","about","there","very","great","tempest"]},{"verseId":"brenton_psalms_49_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":4,"text":"He shall summon the heaven above, and the earth, that he may judge his people.","searchKeywords":["shall","summon","the","heaven","above","and","earth","that","may","judge","his","people"]},{"verseId":"brenton_psalms_49_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":5,"text":"Assemble ye his saints to him, those that have engaged in a covenant with him upon sacrifices.","searchKeywords":["assemble","his","saints","him","those","that","have","engaged","covenant","with","upon","sacrifices"]},{"verseId":"brenton_psalms_49_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":6,"text":"And the heavens shall declare his righteousness: for God is judge. Pause.","searchKeywords":["and","the","heavens","shall","declare","his","righteousness","for","god","judge","pause"]},{"verseId":"brenton_psalms_49_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":7,"text":"Hear, my people, and I will speak to thee, O Israel: and I will testify to thee: I am God, thy God.","searchKeywords":["hear","people","and","will","speak","thee","israel","testify","god","thy"]},{"verseId":"brenton_psalms_49_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":8,"text":"I will not reprove thee on account of thy sacrifices; for thy whole-burnt-offerings are before me continually.","searchKeywords":["will","not","reprove","thee","account","thy","sacrifices","for","whole","burnt","offerings","are","before","continually"]},{"verseId":"brenton_psalms_49_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":9,"text":"I will take no bullocks out of thine house, nor he-goats out of thy flocks.","searchKeywords":["will","take","bullocks","out","thine","house","nor","goats","thy","flocks"]},{"verseId":"brenton_psalms_49_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":10,"text":"For all the wild beasts of the thicket are mine, the cattle on the mountains, and oxen.","searchKeywords":["for","all","the","wild","beasts","thicket","are","mine","cattle","mountains","and","oxen"]},{"verseId":"brenton_psalms_49_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":11,"text":"I know all the birds of the sky; and the beauty of the field is mine.","searchKeywords":["know","all","the","birds","sky","and","beauty","field","mine"]},{"verseId":"brenton_psalms_49_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":12,"text":"If I should be hungry, I will not tell thee: for the world is mine, and the fulness of it.","searchKeywords":["should","hungry","will","not","tell","thee","for","the","world","mine","and","fulness"]},{"verseId":"brenton_psalms_49_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":13,"text":"Will I eat the flesh of bulls, or drink the blood of goats?","searchKeywords":["will","eat","the","flesh","bulls","drink","blood","goats"]},{"verseId":"brenton_psalms_49_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":14,"text":"Offer to God the sacrifice of praise; and pay thy vows to the Most High.","searchKeywords":["offer","god","the","sacrifice","praise","and","pay","thy","vows","most","high"]},{"verseId":"brenton_psalms_49_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":15,"text":"And call upon me in the day of affliction; and I will deliver thee, and thou shalt glorify me. Pause.","searchKeywords":["and","call","upon","the","day","affliction","will","deliver","thee","thou","shalt","glorify","pause"]},{"verseId":"brenton_psalms_49_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":16,"text":"But to the sinner God has said, Why dost thou declare my ordinances, and take up my covenant in thy mouth?","searchKeywords":["but","the","sinner","god","has","said","why","dost","thou","declare","ordinances","and","take","covenant","thy","mouth"]},{"verseId":"brenton_psalms_49_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":17,"text":"Whereas thou hast hated instruction, and hast cast my words behind .","searchKeywords":["whereas","thou","hast","hated","instruction","and","cast","words","behind"]},{"verseId":"brenton_psalms_49_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":18,"text":"If thou sawest a thief, thou rannest along with him, and hast cast in thy lot with adulterers.","searchKeywords":["thou","sawest","thief","rannest","along","with","him","and","hast","cast","thy","lot","adulterers"]},{"verseId":"brenton_psalms_49_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":19,"text":"Thy mouth has multiplied wickedness, and thy tongue has framed deceit.","searchKeywords":["thy","mouth","has","multiplied","wickedness","and","tongue","framed","deceit"]},{"verseId":"brenton_psalms_49_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":20,"text":"Thou didst sit and speak against thy brother, and didst scandalise thy mother's son.","searchKeywords":["thou","didst","sit","and","speak","against","thy","brother","scandalise","mother","son"]},{"verseId":"brenton_psalms_49_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":21,"text":"These things thou didst, and I kept silence: thou thoughtest wickedly that I should be like thee; I will reprove thee, and set before thee.","searchKeywords":["these","things","thou","didst","and","kept","silence","thoughtest","wickedly","that","should","like","thee","will","reprove","set","before"]},{"verseId":"brenton_psalms_49_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":22,"text":"Now consider these things, ye that forget God, lest he rend , and there be no deliverer.","searchKeywords":["now","consider","these","things","that","forget","god","lest","rend","and","there","deliverer"]},{"verseId":"brenton_psalms_49_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":49,"verse":23,"text":"The sacrifice of praise will glorify me: and that is the way wherein I will shew to him the salvation of God.","searchKeywords":["the","sacrifice","praise","will","glorify","and","that","way","wherein","shew","him","salvation","god"]}]