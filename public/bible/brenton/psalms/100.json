[{"verseId":"brenton_psalms_100_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":100,"verse":1,"text":"A Psalm of David.","searchKeywords":["psalm","david"]},{"verseId":"brenton_psalms_100_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":100,"verse":2,"text":"and I will be wise in a blameless way. When wilt thou come to me? I walked in the innocence of my heart, in the midst of my house.","searchKeywords":["and","will","wise","blameless","way","when","wilt","thou","come","walked","the","innocence","heart","midst","house"]},{"verseId":"brenton_psalms_100_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":100,"verse":3,"text":"I have not set before mine eyes any unlawful thing; I have hated transgressors.","searchKeywords":["have","not","set","before","mine","eyes","any","unlawful","thing","hated","transgressors"]},{"verseId":"brenton_psalms_100_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":100,"verse":4,"text":"A perverse heart has not cleaved to me; I have not known an evil man, forasmuch as he turns away from me.","searchKeywords":["perverse","heart","has","not","cleaved","have","known","evil","man","forasmuch","turns","away","from"]},{"verseId":"brenton_psalms_100_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":100,"verse":5,"text":"Him that privily speaks against his neighbour, him have I driven from : he that is proud in look and insatiable in heart,—with him I have not eaten.","searchKeywords":["him","that","privily","speaks","against","his","neighbour","have","driven","from","proud","look","and","insatiable","heart","with","not","eaten"]},{"verseId":"brenton_psalms_100_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":100,"verse":6,"text":"Mine eyes upon the faithful of the land, that they may dwell with me: he that walked in a perfect way, the same ministered to me.","searchKeywords":["mine","eyes","upon","the","faithful","land","that","they","may","dwell","with","walked","perfect","way","same","ministered"]},{"verseId":"brenton_psalms_100_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":100,"verse":7,"text":"The proud doer dwelt not in the midst of my house; the unjust speaker prospered not in my sight.","searchKeywords":["the","proud","doer","dwelt","not","midst","house","unjust","speaker","prospered","sight"]},{"verseId":"brenton_psalms_100_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":100,"verse":8,"text":"Early did I slay all the sinners of the land, that I might destroy out of the city of the Lord all that work iniquity.","searchKeywords":["early","did","slay","all","the","sinners","land","that","might","destroy","out","city","lord","work","iniquity"]}]