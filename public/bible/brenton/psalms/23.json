[{"verseId":"brenton_psalms_23_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":23,"verse":1,"text":"A Psalm for David on the first day of the week.","searchKeywords":["psalm","for","david","the","first","day","week"]},{"verseId":"brenton_psalms_23_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":23,"verse":2,"text":"He has founded it upon the seas, and prepared it upon the rivers.","searchKeywords":["has","founded","upon","the","seas","and","prepared","rivers"]},{"verseId":"brenton_psalms_23_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":23,"verse":3,"text":"Who shall go up to the mountain of the Lord, and who shall stand in his holy place?","searchKeywords":["who","shall","the","mountain","lord","and","stand","his","holy","place"]},{"verseId":"brenton_psalms_23_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":23,"verse":4,"text":"He that is innocent in his hands and pure in his heart; who has not lifted up his soul to vanity, nor sworn deceitfully to his neighbour.","searchKeywords":["that","innocent","his","hands","and","pure","heart","who","has","not","lifted","soul","vanity","nor","sworn","deceitfully","neighbour"]},{"verseId":"brenton_psalms_23_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":23,"verse":5,"text":"He shall receive a blessing from the Lord, and mercy from God his Saviour.","searchKeywords":["shall","receive","blessing","from","the","lord","and","mercy","god","his","saviour"]},{"verseId":"brenton_psalms_23_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":23,"verse":6,"text":"This is the generation of them that seek him, that seek the face of the God of Jacob. Pause.","searchKeywords":["this","the","generation","them","that","seek","him","face","god","jacob","pause"]},{"verseId":"brenton_psalms_23_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":23,"verse":7,"text":"Lift up your gates, ye princes, and be ye lifted up, ye everlasting doors; and the king of glory shall come in.","searchKeywords":["lift","your","gates","princes","and","lifted","everlasting","doors","the","king","glory","shall","come"]},{"verseId":"brenton_psalms_23_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":23,"verse":8,"text":"Who is this king of glory? the Lord strong and mighty, the Lord mighty in battle.","searchKeywords":["who","this","king","glory","the","lord","strong","and","mighty","battle"]},{"verseId":"brenton_psalms_23_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":23,"verse":9,"text":"Lift up your gates, ye princes; and be ye lift up, ye everlasting doors; and the king of glory shall come in.","searchKeywords":["lift","your","gates","princes","and","everlasting","doors","the","king","glory","shall","come"]},{"verseId":"brenton_psalms_23_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":23,"verse":10,"text":"Who is this king of glory? The Lord of hosts, he is this king of glory.","searchKeywords":["who","this","king","glory","the","lord","hosts"]}]