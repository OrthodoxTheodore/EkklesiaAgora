[{"verseId":"brenton_psalms_43_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":1,"text":"For the end, a Psalm for instruction, for the sons of Core.","searchKeywords":["for","the","end","psalm","instruction","sons","core"]},{"verseId":"brenton_psalms_43_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":2,"text":"O God, we have heard with our ears, our fathers have told us, the work which thou wroughtest in their days, in the days of old.","searchKeywords":["god","have","heard","with","our","ears","fathers","told","the","work","which","thou","wroughtest","their","days","old"]},{"verseId":"brenton_psalms_43_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":3,"text":"Thine hand utterly destroyed the heathen, and thou didst plant them: thou didst afflict the nations, and cast them out.","searchKeywords":["thine","hand","utterly","destroyed","the","heathen","and","thou","didst","plant","them","afflict","nations","cast","out"]},{"verseId":"brenton_psalms_43_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":4,"text":"For they inherited not the land by their sword, and their arm did not deliver them; but thy right hand, and thine arm, and the light of thy countenance, because thou wert well pleased in them.","searchKeywords":["for","they","inherited","not","the","land","their","sword","and","arm","did","deliver","them","but","thy","right","hand","thine","light","countenance","because","thou","wert","well","pleased"]},{"verseId":"brenton_psalms_43_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":5,"text":"Thou art indeed my King and my God, who commandest deliverances for Jacob.","searchKeywords":["thou","art","indeed","king","and","god","who","commandest","deliverances","for","jacob"]},{"verseId":"brenton_psalms_43_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":6,"text":"In thee will we push down our enemies, and in thy name will we bring to nought them that rise up against us.","searchKeywords":["thee","will","push","down","our","enemies","and","thy","name","bring","nought","them","that","rise","against"]},{"verseId":"brenton_psalms_43_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":7,"text":"For I will not trust in my bow, and my sword shall not save me.","searchKeywords":["for","will","not","trust","bow","and","sword","shall","save"]},{"verseId":"brenton_psalms_43_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":8,"text":"For thou hast saved us from them that afflicted us, and hast put to shame them that hated us.","searchKeywords":["for","thou","hast","saved","from","them","that","afflicted","and","put","shame","hated"]},{"verseId":"brenton_psalms_43_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":9,"text":"In God will we make our boast all the day, and to thy name will we give thanks for ever. Pause.","searchKeywords":["god","will","make","our","boast","all","the","day","and","thy","name","give","thanks","for","ever","pause"]},{"verseId":"brenton_psalms_43_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":10,"text":"But now thou hast cast off, and put us to shame; and thou wilt not go forth with our hosts.","searchKeywords":["but","now","thou","hast","cast","off","and","put","shame","wilt","not","forth","with","our","hosts"]},{"verseId":"brenton_psalms_43_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":11,"text":"Thou hast turned us back before our enemies; and they that hated us spoiled for themselves.","searchKeywords":["thou","hast","turned","back","before","our","enemies","and","they","that","hated","spoiled","for","themselves"]},{"verseId":"brenton_psalms_43_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":12,"text":"Thou madest us as sheep for meat; and thou scatteredst us among the nations.","searchKeywords":["thou","madest","sheep","for","meat","and","scatteredst","among","the","nations"]},{"verseId":"brenton_psalms_43_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":13,"text":"Thou hast sold thy people without price, and there was no profit by their exchange.","searchKeywords":["thou","hast","sold","thy","people","without","price","and","there","was","profit","their","exchange"]},{"verseId":"brenton_psalms_43_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":14,"text":"Thou hast made us a reproach to our neighbours, a scorn and derision to them that are round about us.","searchKeywords":["thou","hast","made","reproach","our","neighbours","scorn","and","derision","them","that","are","round","about"]},{"verseId":"brenton_psalms_43_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":15,"text":"Thou hast made us a proverb among the Gentiles, a shaking of the head among the nations.","searchKeywords":["thou","hast","made","proverb","among","the","gentiles","shaking","head","nations"]},{"verseId":"brenton_psalms_43_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":16,"text":"All the day my shame is before me, and the confusion of my face has covered me,","searchKeywords":["all","the","day","shame","before","and","confusion","face","has","covered"]},{"verseId":"brenton_psalms_43_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":17,"text":"because of the voice of the slanderer and reviler; because of the enemy and avenger.","searchKeywords":["because","the","voice","slanderer","and","reviler","enemy","avenger"]},{"verseId":"brenton_psalms_43_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":18,"text":"All these things are come upon us: but we have not forgotten thee, neither have we dealt unrighteously in thy covenant.","searchKeywords":["all","these","things","are","come","upon","but","have","not","forgotten","thee","neither","dealt","unrighteously","thy","covenant"]},{"verseId":"brenton_psalms_43_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":19,"text":"And our heart has not gone back; but thou hast turned aside our paths from thy way.","searchKeywords":["and","our","heart","has","not","gone","back","but","thou","hast","turned","aside","paths","from","thy","way"]},{"verseId":"brenton_psalms_43_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":20,"text":"For thou hast laid us low in a place of affliction, and the shadow of death has covered us.","searchKeywords":["for","thou","hast","laid","low","place","affliction","and","the","shadow","death","has","covered"]},{"verseId":"brenton_psalms_43_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":21,"text":"If we have forgotten the name of our God, and if we have spread out our hands to a strange god; shall not God search these things out?","searchKeywords":["have","forgotten","the","name","our","god","and","spread","out","hands","strange","shall","not","search","these","things"]},{"verseId":"brenton_psalms_43_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":22,"text":"for he knows the secrets of the heart.","searchKeywords":["for","knows","the","secrets","heart"]},{"verseId":"brenton_psalms_43_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":23,"text":"For, for thy sake we are killed all the day long; we are counted as sheep for slaughter.","searchKeywords":["for","thy","sake","are","killed","all","the","day","long","counted","sheep","slaughter"]},{"verseId":"brenton_psalms_43_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":24,"text":"Awake, wherefore sleepest thou, O Lord? arise, and do not cast off for ever.","searchKeywords":["awake","wherefore","sleepest","thou","lord","arise","and","not","cast","off","for","ever"]},{"verseId":"brenton_psalms_43_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":25,"text":"Wherefore turnest thou thy face away, forgettest our poverty and our affliction?","searchKeywords":["wherefore","turnest","thou","thy","face","away","forgettest","our","poverty","and","affliction"]},{"verseId":"brenton_psalms_43_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":26,"text":"For our soul has been brought down to the dust; our belly has cleaved to the earth.","searchKeywords":["for","our","soul","has","been","brought","down","the","dust","belly","cleaved","earth"]},{"verseId":"brenton_psalms_43_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":43,"verse":27,"text":"Arise, O Lord, help us, and redeem us for thy name's sake.","searchKeywords":["arise","lord","help","and","redeem","for","thy","name","sake"]}]