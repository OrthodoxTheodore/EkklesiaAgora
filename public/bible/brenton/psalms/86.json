[{"verseId":"brenton_psalms_86_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":86,"verse":1,"text":"A Psalm of a Song for the sons of Core.","searchKeywords":["psalm","song","for","the","sons","core"]},{"verseId":"brenton_psalms_86_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":86,"verse":2,"text":"The Lord loves the gates of Sion, more than all the tabernacles of Jacob.","searchKeywords":["the","lord","loves","gates","sion","more","than","all","tabernacles","jacob"]},{"verseId":"brenton_psalms_86_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":86,"verse":3,"text":"Glorious things have been spoken of thee, O city of God. Pause.","searchKeywords":["glorious","things","have","been","spoken","thee","city","god","pause"]},{"verseId":"brenton_psalms_86_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":86,"verse":4,"text":"I will make mention of Raab and Babylon to them that know me: behold also the Philistines, and Tyre, and the people of the Ethiopians: these were born there.","searchKeywords":["will","make","mention","raab","and","babylon","them","that","know","behold","also","the","philistines","tyre","people","ethiopians","these","were","born","there"]},{"verseId":"brenton_psalms_86_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":86,"verse":5,"text":"A man shall say, Sion mother; and a man was born in her; and the Highest himself has founded her.","searchKeywords":["man","shall","say","sion","mother","and","was","born","her","the","highest","himself","has","founded"]},{"verseId":"brenton_psalms_86_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":86,"verse":6,"text":"The Lord shall recount in the writing of the people, and of these princes that were born in her. Pause.","searchKeywords":["the","lord","shall","recount","writing","people","and","these","princes","that","were","born","her","pause"]},{"verseId":"brenton_psalms_86_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":86,"verse":7,"text":"The dwelling of all within thee is as of those that rejoice.","searchKeywords":["the","dwelling","all","within","thee","those","that","rejoice"]}]