[{"verseId":"brenton_psalms_107_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":1,"text":"Song of a Psalm by David.","searchKeywords":["song","psalm","david"]},{"verseId":"brenton_psalms_107_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":2,"text":"O God, my heart is ready, my heart is ready; I will sing and sing psalms with my glory.","searchKeywords":["god","heart","ready","will","sing","and","psalms","with","glory"]},{"verseId":"brenton_psalms_107_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":3,"text":"Awake, psaltery and harp; I will awake early.","searchKeywords":["awake","psaltery","and","harp","will","early"]},{"verseId":"brenton_psalms_107_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":4,"text":"I will give thanks to thee, O Lord, among the people; I will sing praise to thee among the Gentiles.","searchKeywords":["will","give","thanks","thee","lord","among","the","people","sing","praise","gentiles"]},{"verseId":"brenton_psalms_107_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":5,"text":"For thy mercy is great above the heavens, and thy truth to the clouds.","searchKeywords":["for","thy","mercy","great","above","the","heavens","and","truth","clouds"]},{"verseId":"brenton_psalms_107_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":6,"text":"Be thou exalted, O God, above the heavens; and thy glory above all the earth.","searchKeywords":["thou","exalted","god","above","the","heavens","and","thy","glory","all","earth"]},{"verseId":"brenton_psalms_107_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":7,"text":"That thy beloved may be delivered, save with thy right hand, and hear me. God has spoken in his sanctuary;","searchKeywords":["that","thy","beloved","may","delivered","save","with","right","hand","and","hear","god","has","spoken","his","sanctuary"]},{"verseId":"brenton_psalms_107_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":8,"text":"I will be exalted, and will divide Sicima, and will measure out the valley of tents.","searchKeywords":["will","exalted","and","divide","sicima","measure","out","the","valley","tents"]},{"verseId":"brenton_psalms_107_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":9,"text":"Galaad is mine; and Manasses is mine; and Ephraim is the help of mine head; Judas is my king;","searchKeywords":["galaad","mine","and","manasses","ephraim","the","help","head","judas","king"]},{"verseId":"brenton_psalms_107_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":10,"text":"Moab is the caldron of my hope; over Idumea will I cast my sandal; the Philistines are made subject to me.","searchKeywords":["moab","the","caldron","hope","over","idumea","will","cast","sandal","philistines","are","made","subject"]},{"verseId":"brenton_psalms_107_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":11,"text":"Who will bring me into the fortified city? or who will guide me to Idumea?","searchKeywords":["who","will","bring","into","the","fortified","city","guide","idumea"]},{"verseId":"brenton_psalms_107_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":12,"text":"Wilt not thou, O God, who hast rejected us? and wilt not thou, O God, go forth with our hosts?","searchKeywords":["wilt","not","thou","god","who","hast","rejected","and","forth","with","our","hosts"]},{"verseId":"brenton_psalms_107_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":13,"text":"Give us help from tribulation: for vain is the help of man.","searchKeywords":["give","help","from","tribulation","for","vain","the","man"]},{"verseId":"brenton_psalms_107_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":107,"verse":14,"text":"Through God we shall do valiantly; and he will bring to nought our enemies.","searchKeywords":["through","god","shall","valiantly","and","will","bring","nought","our","enemies"]}]