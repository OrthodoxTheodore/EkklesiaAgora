[{"verseId":"brenton_psalms_94_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":94,"verse":1,"text":"The praise of a Song by David. in the Lord; let us make a joyful noise to God our Saviour.","searchKeywords":["the","praise","song","david","lord","let","make","joyful","noise","god","our","saviour"]},{"verseId":"brenton_psalms_94_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":94,"verse":2,"text":"Let us come before his presence with thanksgiving, and make a joyful noise to him with psalms.","searchKeywords":["let","come","before","his","presence","with","thanksgiving","and","make","joyful","noise","him","psalms"]},{"verseId":"brenton_psalms_94_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":94,"verse":3,"text":"For the Lord is a great God, and a great king over all gods: for the Lord will not cast off his people.","searchKeywords":["for","the","lord","great","god","and","king","over","all","gods","will","not","cast","off","his","people"]},{"verseId":"brenton_psalms_94_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":94,"verse":4,"text":"For the ends of the earth are in his hands; and the heights of the mountains are his.","searchKeywords":["for","the","ends","earth","are","his","hands","and","heights","mountains"]},{"verseId":"brenton_psalms_94_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":94,"verse":5,"text":"For the sea is his, and he made it: and his hands formed the dry land.","searchKeywords":["for","the","sea","his","and","made","hands","formed","dry","land"]},{"verseId":"brenton_psalms_94_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":94,"verse":6,"text":"Come, let us worshi