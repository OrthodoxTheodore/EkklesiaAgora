[{"verseId":"brenton_psalms_141_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":141,"verse":1,"text":"of instruction for David, when he was in the cave,—a Prayer.","searchKeywords":["instruction","for","david","when","was","the","cave","prayer"]},{"verseId":"brenton_psalms_141_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":141,"verse":2,"text":"I cried to the Lord with my voice; with my voice I made supplication to the Lord.","searchKeywords":["cried","the","lord","with","voice","made","supplication"]},{"verseId":"brenton_psalms_141_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":141,"verse":3,"text":"I will pour out before him my supplication: I will declare before him mine affliction.","searchKeywords":["will","pour","out","before","him","supplication","declare","mine","affliction"]},{"verseId":"brenton_psalms_141_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":141,"verse":4,"text":"When my spirit was fainting within me, then thou knewest my paths; in the very way wherein I was walking, they hid a snare for me.","searchKeywords":["when","spirit","was","fainting","within","then","thou","knewest","paths","the","very","way","wherein","walking","they","hid","snare","for"]},{"verseId":"brenton_psalms_141_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":141,"verse":5,"text":"I looked on right hand, and behold, for there was none that noticed me; refuge failed me; and there was none that cared for my soul.","searchKeywords":["looked","right","hand","and","behold","for","there","was","none","that","noticed","refuge","failed","cared","soul"]},{"verseId":"brenton_psalms_141_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":141,"verse":6,"text":"I cried unto thee, O Lord, and said, Thou art my hope, my portion in the land of the living.","searchKeywords":["cried","unto","thee","lord","and","said","thou","art","hope","portion","the","land","living"]},{"verseId":"brenton_psalms_141_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":141,"verse":7,"text":"Attend to my supplication, for I am brought very low; deliver me from them that persecute me; for they are stronger than I.","searchKeywords":["attend","supplication","for","brought","very","low","deliver","from","them","that","persecute","they","are","stronger","than"]},{"verseId":"brenton_psalms_141_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":141,"verse":8,"text":"Bring my soul out of prison, that I may give thanks to thy name, O Lord; the righteous shall wait for me, until thou recompense me.","searchKeywords":["bring","soul","out","prison","that","may","give","thanks","thy","name","lord","the","righteous","shall","wait","for","until","thou","recompense"]}]