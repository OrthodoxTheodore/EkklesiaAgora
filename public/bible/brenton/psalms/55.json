[{"verseId":"brenton_psalms_55_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":1,"text":"For the end, concerning the people that were removed from the sanctuary, by David for a memorial, when the Philistines caught him in Geth.","searchKeywords":["for","the","end","concerning","people","that","were","removed","from","sanctuary","david","memorial","when","philistines","caught","him","geth"]},{"verseId":"brenton_psalms_55_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":2,"text":"Have mercy upon me, O God; for man has trodden me down; all the day long he warring has afflicted me.","searchKeywords":["have","mercy","upon","god","for","man","has","trodden","down","all","the","day","long","warring","afflicted"]},{"verseId":"brenton_psalms_55_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":3,"text":"Mine enemies have trodden me down all the day from the dawning of the day; for there are many warring against me.","searchKeywords":["mine","enemies","have","trodden","down","all","the","day","from","dawning","for","there","are","many","warring","against"]},{"verseId":"brenton_psalms_55_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":4,"text":"They shall be afraid, but I will trust in thee.","searchKeywords":["they","shall","afraid","but","will","trust","thee"]},{"verseId":"brenton_psalms_55_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":5,"text":"In God I will praise my words; all the day have I hoped in God; I will not fear what flesh shall do to me.","searchKeywords":["god","will","praise","words","all","the","day","have","hoped","not","fear","what","flesh","shall"]},{"verseId":"brenton_psalms_55_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":6,"text":"All the day long they have abominated my words; all their devices against me for evil.","searchKeywords":["all","the","day","long","they","have","abominated","words","their","devices","against","for","evil"]},{"verseId":"brenton_psalms_55_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":7,"text":"They will dwell near and hide ; they will watch my steps, accordingly as I have waited patiently in my soul.","searchKeywords":["they","will","dwell","near","and","hide","watch","steps","accordingly","have","waited","patiently","soul"]},{"verseId":"brenton_psalms_55_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":8,"text":"Thou wilt on no account save them; thou wilt bring down the people in wrath.","searchKeywords":["thou","wilt","account","save","them","bring","down","the","people","wrath"]},{"verseId":"brenton_psalms_55_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":9,"text":"O God, I have declared my life to thee; thou hast set my tears before thee, even according to thy promise.","searchKeywords":["god","have","declared","life","thee","thou","hast","set","tears","before","even","according","thy","promise"]},{"verseId":"brenton_psalms_55_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":10,"text":"Mine enemies shall be turned back, in the day wherein I shall call upon thee; behold, I know that thou art my God.","searchKeywords":["mine","enemies","shall","turned","back","the","day","wherein","call","upon","thee","behold","know","that","thou","art","god"]},{"verseId":"brenton_psalms_55_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":11,"text":"In God will I praise word; in the Lord will I praise saying.","searchKeywords":["god","will","praise","word","the","lord","saying"]},{"verseId":"brenton_psalms_55_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":12,"text":"I have hoped in God; I will not be afraid of what man shall do to me.","searchKeywords":["have","hoped","god","will","not","afraid","what","man","shall"]},{"verseId":"brenton_psalms_55_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":13,"text":"The vows of thy praise, O God, which I will pay, are upon me.","searchKeywords":["the","vows","thy","praise","god","which","will","pay","are","upon"]},{"verseId":"brenton_psalms_55_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":55,"verse":14,"text":"For thou hast delivered my soul from death, and my feet from sliding, that I should be well-pleasing before God in the land of the living.","searchKeywords":["for","thou","hast","delivered","soul","from","death","and","feet","sliding","that","should","well","pleasing","before","god","the","land","living"]}]