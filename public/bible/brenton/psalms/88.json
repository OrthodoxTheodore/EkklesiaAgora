[{"verseId":"brenton_psalms_88_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":1,"text":"of instruction for Ætham the Israelite.","searchKeywords":["instruction","for","tham","the","israelite"]},{"verseId":"brenton_psalms_88_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":2,"text":"I will sing of thy mercies, O Lord, for ever: I will declare thy truth with my mouth to all generations.","searchKeywords":["will","sing","thy","mercies","lord","for","ever","declare","truth","with","mouth","all","generations"]},{"verseId":"brenton_psalms_88_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":3,"text":"For thou hast said, Mercy shall be built up for ever: thy truth shall be established in the heavens.","searchKeywords":["for","thou","hast","said","mercy","shall","built","ever","thy","truth","established","the","heavens"]},{"verseId":"brenton_psalms_88_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":4,"text":"I made a covenant with my chosen ones, I sware unto David my servant.","searchKeywords":["made","covenant","with","chosen","ones","sware","unto","david","servant"]},{"verseId":"brenton_psalms_88_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":5,"text":"I will establish thy seed for ever, and build up thy throne to all generations. Pause.","searchKeywords":["will","establish","thy","seed","for","ever","and","build","throne","all","generations","pause"]},{"verseId":"brenton_psalms_88_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":6,"text":"The heavens shall declare thy wonders, O Lord; and thy truth in the assembly of the saints.","searchKeywords":["the","heavens","shall","declare","thy","wonders","lord","and","truth","assembly","saints"]},{"verseId":"brenton_psalms_88_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":7,"text":"For who in the heavens shall be compared to the Lord? and who shall be likened to the Lord among the sons of God?","searchKeywords":["for","who","the","heavens","shall","compared","lord","and","likened","among","sons","god"]},{"verseId":"brenton_psalms_88_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":8,"text":"God is glorified in the council of the saints; great and terrible toward all that are round about him.","searchKeywords":["god","glorified","the","council","saints","great","and","terrible","toward","all","that","are","round","about","him"]},{"verseId":"brenton_psalms_88_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":9,"text":"O Lord God of hosts, who is like to thee? thou art mighty, O Lord, and thy truth is round about thee.","searchKeywords":["lord","god","hosts","who","like","thee","thou","art","mighty","and","thy","truth","round","about"]},{"verseId":"brenton_psalms_88_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":10,"text":"Thou rulest the power of the sea; and thou calmest the tumult of its waves.","searchKeywords":["thou","rulest","the","power","sea","and","calmest","tumult","its","waves"]},{"verseId":"brenton_psalms_88_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":11,"text":"Thou hast brought down the proud as one that is slain; and with the arm of thy power thou hast scattered thine enemies.","searchKeywords":["thou","hast","brought","down","the","proud","one","that","slain","and","with","arm","thy","power","scattered","thine","enemies"]},{"verseId":"brenton_psalms_88_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":12,"text":"The heavens are thine, and the earth is thine: thou hast founded the world, and the fulness of it.","searchKeywords":["the","heavens","are","thine","and","earth","thou","hast","founded","world","fulness"]},{"verseId":"brenton_psalms_88_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":13,"text":"Thou hast created the north and the west: Thabor and Hermon shall rejoice in thy name.","searchKeywords":["thou","hast","created","the","north","and","west","thabor","hermon","shall","rejoice","thy","name"]},{"verseId":"brenton_psalms_88_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":14,"text":"Thine is the mighty arm: let thy hand be strengthened, let thy right hand be exalted.","searchKeywords":["thine","the","mighty","arm","let","thy","hand","strengthened","right","exalted"]},{"verseId":"brenton_psalms_88_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":15,"text":"Justice and judgment are the establishment of thy throne: mercy and truth shall go before thy face.","searchKeywords":["justice","and","judgment","are","the","establishment","thy","throne","mercy","truth","shall","before","face"]},{"verseId":"brenton_psalms_88_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":16,"text":"Blessed is the people that knows the joyful sound: they shall walk, O Lord, in the light of thy countenance.","searchKeywords":["blessed","the","people","that","knows","joyful","sound","they","shall","walk","lord","light","thy","countenance"]},{"verseId":"brenton_psalms_88_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":17,"text":"And in thy name shall they rejoice all the day: and in thy righteousness shall they be exalted.","searchKeywords":["and","thy","name","shall","they","rejoice","all","the","day","righteousness","exalted"]},{"verseId":"brenton_psalms_88_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":18,"text":"For thou art the boast of their strength; and in thy good pleasure shall our horn be exalted,","searchKeywords":["for","thou","art","the","boast","their","strength","and","thy","good","pleasure","shall","our","horn","exalted"]},{"verseId":"brenton_psalms_88_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":19,"text":"for help is of the Lord; and of the Holy One of Israel, our king.","searchKeywords":["for","help","the","lord","and","holy","one","israel","our","king"]},{"verseId":"brenton_psalms_88_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":20,"text":"Then thou spokest in vision to thy children, and saidst, I have laid help on a mighty one; I have exalted one chosen out of my people.","searchKeywords":["then","thou","spokest","vision","thy","children","and","saidst","have","laid","help","mighty","one","exalted","chosen","out","people"]},{"verseId":"brenton_psalms_88_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":21,"text":"I have found David my servant; I have anointed him by holy mercy.","searchKeywords":["have","found","david","servant","anointed","him","holy","mercy"]},{"verseId":"brenton_psalms_88_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":22,"text":"For my hand shall support him; and mine arm shall strengthen him.","searchKeywords":["for","hand","shall","support","him","and","mine","arm","strengthen"]},{"verseId":"brenton_psalms_88_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":23,"text":"The enemy shall have no advantage against him; and the son of transgression shall not hurt him again.","searchKeywords":["the","enemy","shall","have","advantage","against","him","and","son","transgression","not","hurt","again"]},{"verseId":"brenton_psalms_88_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":24,"text":"And I will hew down his foes before him, and put to flight those that hate him.","searchKeywords":["and","will","hew","down","his","foes","before","him","put","flight","those","that","hate"]},{"verseId":"brenton_psalms_88_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":25,"text":"But my truth and my mercy shall be with him; and in my name shall his horn be exalted.","searchKeywords":["but","truth","and","mercy","shall","with","him","name","his","horn","exalted"]},{"verseId":"brenton_psalms_88_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":26,"text":"And I will set his hand in the sea, and his right hand in the rivers.","searchKeywords":["and","will","set","his","hand","the","sea","right","rivers"]},{"verseId":"brenton_psalms_88_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":27,"text":"He shall call upon me, , Thou art my Father, my God, and the helper of my salvation.","searchKeywords":["shall","call","upon","thou","art","father","god","and","the","helper","salvation"]},{"verseId":"brenton_psalms_88_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":28,"text":"And I will make him first-born, higher than the kings of the earth.","searchKeywords":["and","will","make","him","first","born","higher","than","the","kings","earth"]},{"verseId":"brenton_psalms_88_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":29,"text":"I will keep my mercy for him for ever, and my covenant firm with him.","searchKeywords":["will","keep","mercy","for","him","ever","and","covenant","firm","with"]},{"verseId":"brenton_psalms_88_30","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":30,"text":"And I will establish his seed for ever and ever, and his throne as the days of heaven.","searchKeywords":["and","will","establish","his","seed","for","ever","throne","the","days","heaven"]},{"verseId":"brenton_psalms_88_31","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":31,"text":"If his children should forsake my law, and walk not in my judgments;","searchKeywords":["his","children","should","forsake","law","and","walk","not","judgments"]},{"verseId":"brenton_psalms_88_32","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":32,"text":"if they should profane my ordinances, and not keep my commandments;","searchKeywords":["they","should","profane","ordinances","and","not","keep","commandments"]},{"verseId":"brenton_psalms_88_33","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":33,"text":"I will visit their transgressions with a rod, and their sins with scourges.","searchKeywords":["will","visit","their","transgressions","with","rod","and","sins","scourges"]},{"verseId":"brenton_psalms_88_34","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":34,"text":"But my mercy I will not utterly remove from him, nor wrong my truth.","searchKeywords":["but","mercy","will","not","utterly","remove","from","him","nor","wrong","truth"]},{"verseId":"brenton_psalms_88_35","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":35,"text":"Neither will I by any means profane my covenant; and I will not make void the things that proceed out of my lips.","searchKeywords":["neither","will","any","means","profane","covenant","and","not","make","void","the","things","that","proceed","out","lips"]},{"verseId":"brenton_psalms_88_36","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":36,"text":"Once have I sworn by my holiness, that I will not lie to David.","searchKeywords":["once","have","sworn","holiness","that","will","not","lie","david"]},{"verseId":"brenton_psalms_88_37","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":37,"text":"His seed shall endure for ever, and his throne as the sun before me;","searchKeywords":["his","seed","shall","endure","for","ever","and","throne","the","sun","before"]},{"verseId":"brenton_psalms_88_38","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":38,"text":"and as the moon established for ever, and as the faithful witness in heaven. Pause.","searchKeywords":["and","the","moon","established","for","ever","faithful","witness","heaven","pause"]},{"verseId":"brenton_psalms_88_39","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":39,"text":"But thou hast cast off and set at nought, thou hast rejected thine anointed.","searchKeywords":["but","thou","hast","cast","off","and","set","nought","rejected","thine","anointed"]},{"verseId":"brenton_psalms_88_40","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":40,"text":"Thou hast overthrown the covenant of thy servant; thou hast profaned his sanctuary, to the ground.","searchKeywords":["thou","hast","overthrown","the","covenant","thy","servant","profaned","his","sanctuary","ground"]},{"verseId":"brenton_psalms_88_41","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":41,"text":"Thou hast broken down all his hedges; thou hast made his strong holds a terror.","searchKeywords":["thou","hast","broken","down","all","his","hedges","made","strong","holds","terror"]},{"verseId":"brenton_psalms_88_42","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":42,"text":"All that go by the way have spoiled him: he is become a reproach to his neighbours.","searchKeywords":["all","that","the","way","have","spoiled","him","become","reproach","his","neighbours"]},{"verseId":"brenton_psalms_88_43","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":43,"text":"Thou hast exalted the right hand of his enemies; thou hast made all his enemies to rejoice.","searchKeywords":["thou","hast","exalted","the","right","hand","his","enemies","made","all","rejoice"]},{"verseId":"brenton_psalms_88_44","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":44,"text":"Thou hast turned back the help of his sword, and hast not helped him in the battle.","searchKeywords":["thou","hast","turned","back","the","help","his","sword","and","not","helped","him","battle"]},{"verseId":"brenton_psalms_88_45","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":45,"text":"Thou hast deprived him of glory: thou hast broken down his throne to the ground.","searchKeywords":["thou","hast","deprived","him","glory","broken","down","his","throne","the","ground"]},{"verseId":"brenton_psalms_88_46","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":46,"text":"Thou hast shortened the days of his throne: thou hast poured shame upon him. Pause.","searchKeywords":["thou","hast","shortened","the","days","his","throne","poured","shame","upon","him","pause"]},{"verseId":"brenton_psalms_88_47","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":47,"text":"How long, O Lord, wilt thou turn away, for ever? shall thine anger flame out as fire?","searchKeywords":["how","long","lord","wilt","thou","turn","away","for","ever","shall","thine","anger","flame","out","fire"]},{"verseId":"brenton_psalms_88_48","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":48,"text":"Remember what my being is: for hast thou created all the sons of men in vain?","searchKeywords":["remember","what","being","for","hast","thou","created","all","the","sons","men","vain"]},{"verseId":"brenton_psalms_88_49","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":49,"text":"What man is there who shall live, and not see death? shall deliver his soul from the hand of Hades? Pause.","searchKeywords":["what","man","there","who","shall","live","and","not","see","death","deliver","his","soul","from","the","hand","hades","pause"]},{"verseId":"brenton_psalms_88_50","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":50,"text":"Where are thine ancient mercies, O Lord, which thou swarest to David in thy truth?","searchKeywords":["where","are","thine","ancient","mercies","lord","which","thou","swarest","david","thy","truth"]},{"verseId":"brenton_psalms_88_51","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":51,"text":"Remember, O Lord, the reproach of thy servants, which I have borne in my bosom, of many nations;","searchKeywords":["remember","lord","the","reproach","thy","servants","which","have","borne","bosom","many","nations"]},{"verseId":"brenton_psalms_88_52","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":52,"text":"wherewith thine enemies have reviled, O Lord: wherewith they have reviled the recompence of thine anointed.","searchKeywords":["wherewith","thine","enemies","have","reviled","lord","they","the","recompence","anointed"]},{"verseId":"brenton_psalms_88_53","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":88,"verse":53,"text":"Blessed be the Lord for ever. So be it, so be it.","searchKeywords":["blessed","the","lord","for","ever"]}]