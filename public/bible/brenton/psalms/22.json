[{"verseId":"brenton_psalms_22_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":22,"verse":1,"text":"A Psalm of David.","searchKeywords":["psalm","david"]},{"verseId":"brenton_psalms_22_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":22,"verse":2,"text":"In a place of green grass, there he has made me dwell: he has nourished me by the water of rest.","searchKeywords":["place","green","grass","there","has","made","dwell","nourished","the","water","rest"]},{"verseId":"brenton_psalms_22_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":22,"verse":3,"text":"He has restored my soul: he has guided me into the paths of righteousness, for his name's sake.","searchKeywords":["has","restored","soul","guided","into","the","paths","righteousness","for","his","name","sake"]},{"verseId":"brenton_psalms_22_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":22,"verse":4,"text":"Yea, even if I should walk in the midst of the shadow of death, I will not be afraid of evils: for thou art with me; thy rod and thy staff, these have comforted me.","searchKeywords":["yea","even","should","walk","the","midst","shadow","death","will","not","afraid","evils","for","thou","art","with","thy","rod","and","staff","these","have","comforted"]},{"verseId":"brenton_psalms_22_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":22,"verse":5,"text":"Thou hast prepared a table before me in presence of them that afflict me: thou hast thoroughly anointed my head with oil; and thy cup cheers me like the best .","searchKeywords":["thou","hast","prepared","table","before","presence","them","that","afflict","thoroughly","anointed","head","with","oil","and","thy","cup","cheers","like","the","best"]},{"verseId":"brenton_psalms_22_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":22,"verse":6,"text":"Thy mercy also shall follow me all the days of my life: and my dwelling in the house of the Lord for a very long time.","searchKeywords":["thy","mercy","also","shall","follow","all","the","days","life","and","dwelling","house","lord","for","very","long","time"]}]