[{"verseId":"brenton_psalms_85_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":1,"text":"A Prayer of David.","searchKeywords":["prayer","david"]},{"verseId":"brenton_psalms_85_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":2,"text":"Preserve my soul, for I am holy; save thy servant, O God, who hopes in thee.","searchKeywords":["preserve","soul","for","holy","save","thy","servant","god","who","hopes","thee"]},{"verseId":"brenton_psalms_85_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":3,"text":"Pity me, O Lord: for to thee will I cry all the day.","searchKeywords":["pity","lord","for","thee","will","cry","all","the","day"]},{"verseId":"brenton_psalms_85_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":4,"text":"Rejoice the soul of thy servant: for to thee, O Lord, have I lifted up my soul.","searchKeywords":["rejoice","the","soul","thy","servant","for","thee","lord","have","lifted"]},{"verseId":"brenton_psalms_85_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":5,"text":"For thou, O Lord, art kind, and gentle; and plenteous in mercy to all that call upon thee.","searchKeywords":["for","thou","lord","art","kind","and","gentle","plenteous","mercy","all","that","call","upon","thee"]},{"verseId":"brenton_psalms_85_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":6,"text":"Give ear to my prayer, O Lord; and attend to the voice of my supplication.","searchKeywords":["give","ear","prayer","lord","and","attend","the","voice","supplication"]},{"verseId":"brenton_psalms_85_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":7,"text":"In the day of my trouble I cried to thee: for thou didst hear me.","searchKeywords":["the","day","trouble","cried","thee","for","thou","didst","hear"]},{"verseId":"brenton_psalms_85_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":8,"text":"There is none like to thee, O Lord, among the gods; and there are no like to thy works.","searchKeywords":["there","none","like","thee","lord","among","the","gods","and","are","thy","works"]},{"verseId":"brenton_psalms_85_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":9,"text":"All nations whom thou hast made shall come, and shall worship before thee, O Lord; and shall glorify thy name.","searchKeywords":["all","nations","whom","thou","hast","made","shall","come","and","worship","before","thee","lord","glorify","thy","name"]},{"verseId":"brenton_psalms_85_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":10,"text":"For thou art great, and doest wonders: thou art the only the great God.","searchKeywords":["for","thou","art","great","and","doest","wonders","the","only","god"]},{"verseId":"brenton_psalms_85_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":11,"text":"Guide me, O Lord, in thy way, and I will walk in thy truth: let my heart rejoice, that I may fear thy name.","searchKeywords":["guide","lord","thy","way","and","will","walk","truth","let","heart","rejoice","that","may","fear","name"]},{"verseId":"brenton_psalms_85_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":12,"text":"I will give thee thanks, O Lord my God, with all my heart; and I will glorify thy name for ever.","searchKeywords":["will","give","thee","thanks","lord","god","with","all","heart","and","glorify","thy","name","for","ever"]},{"verseId":"brenton_psalms_85_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":13,"text":"For thy mercy is great toward me; and thou hast delivered my soul from the lowest hell.","searchKeywords":["for","thy","mercy","great","toward","and","thou","hast","delivered","soul","from","the","lowest","hell"]},{"verseId":"brenton_psalms_85_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":14,"text":"O God, transgressors have risen up against me, and an assembly of violent have sought my life; and have not set thee before them.","searchKeywords":["god","transgressors","have","risen","against","and","assembly","violent","sought","life","not","set","thee","before","them"]},{"verseId":"brenton_psalms_85_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":15,"text":"But thou, O Lord God, art compassionate and merciful, long-suffering, and abundant in mercy and true.","searchKeywords":["but","thou","lord","god","art","compassionate","and","merciful","long","suffering","abundant","mercy","true"]},{"verseId":"brenton_psalms_85_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":16,"text":"Look thou upon me, and have mercy upon me: give thy strength to thy servant, and save the son of thine handmaid.","searchKeywords":["look","thou","upon","and","have","mercy","give","thy","strength","servant","save","the","son","thine","handmaid"]},{"verseId":"brenton_psalms_85_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":85,"verse":17,"text":"Establish with me a token for good; and let them that hate me see and be ashamed; because thou, O Lord, hast helped me, and comforted me.","searchKeywords":["establish","with","token","for","good","and","let","them","that","hate","see","ashamed","because","thou","lord","hast","helped","comforted"]}]