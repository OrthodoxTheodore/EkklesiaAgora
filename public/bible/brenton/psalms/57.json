[{"verseId":"brenton_psalms_57_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":57,"verse":1,"text":"For the end. Destroy not: by David, for a memorial.","searchKeywords":["for","the","end","destroy","not","david","memorial"]},{"verseId":"brenton_psalms_57_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":57,"verse":2,"text":"If ye do indeed speak righteousness, do ye judge rightly, ye sons of men.","searchKeywords":["indeed","speak","righteousness","judge","rightly","sons","men"]},{"verseId":"brenton_psalms_57_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":57,"verse":3,"text":"For ye work iniquities in hearts in the earth: your hands plot unrighteousness.","searchKeywords":["for","work","iniquities","hearts","the","earth","your","hands","plot","unrighteousness"]},{"verseId":"brenton_psalms_57_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":57,"verse":4,"text":"Sinners have gone astray from the womb: they go astray from the belly: they speak lies.","searchKeywords":["sinners","have","gone","astray","from","the","womb","they","belly","speak","lies"]},{"verseId":"brenton_psalms_57_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":57,"verse":5,"text":"Their venom is like of a serpent; as of a deaf asp, and that stops her ears;","searchKeywords":["their","venom","like","serpent","deaf","asp","and","that","stops","her","ears"]},{"verseId":"brenton_psalms_57_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":57,"verse":6,"text":"which will not hear the voice of charmers, nor the charm prepared skilfully by the wise.","searchKeywords":["which","will","not","hear","the","voice","charmers","nor","charm","prepared","skilfully","wise"]},{"verseId":"brenton_psalms_57_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":57,"verse":7,"text":"God has crushed their teeth in their mouth: God has broken the cheek-teeth of the lions.","searchKeywords":["god","has","crushed","their","teeth","mouth","broken","the","cheek","lions"]},{"verseId":"brenton_psalms_57_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":57,"verse":8,"text":"They shall utterly pass away like water running through: he shall bend his bow till they shall fail.","searchKeywords":["they","shall","utterly","pass","away","like","water","running","through","bend","his","bow","till","fail"]},{"verseId":"brenton_psalms_57_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":57,"verse":9,"text":"They shall be destroyed as melted wax: the fire has fallen and they have not seen the sun.","searchKeywords":["they","shall","destroyed","melted","wax","the","fire","has","fallen","and","have","not","seen","sun"]},{"verseId":"brenton_psalms_57_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":57,"verse":10,"text":"Before your thorns feel the white thorn, he shall swallow you up as living, as in his wrath.","searchKeywords":["before","your","thorns","feel","the","white","thorn","shall","swallow","you","living","his","wrath"]},{"verseId":"brenton_psalms_57_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":57,"verse":11,"text":"The righteous shall rejoice when he sees the vengeance of the ungodly: he shall wash his hands in the blood of the sinner.","searchKeywords":["the","righteous","shall","rejoice","when","sees","vengeance","ungodly","wash","his","hands","blood","sinner"]},{"verseId":"brenton_psalms_57_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":57,"verse":12,"text":"And a man shall say, Verily then there is a reward for the righteous: verily there is a God that judges them in the earth.","searchKeywords":["and","man","shall","say","verily","then","there","reward","for","the","righteous","god","that","judges","them","earth"]}]