[{"verseId":"brenton_psalms_18_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":1,"text":"For the end, a Psalm of David.","searchKeywords":["for","the","end","psalm","david"]},{"verseId":"brenton_psalms_18_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":2,"text":"The heavens declare the glory of God; and the firmament proclaims the work of his hands.","searchKeywords":["the","heavens","declare","glory","god","and","firmament","proclaims","work","his","hands"]},{"verseId":"brenton_psalms_18_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":3,"text":"Day to day utters speech, and night to night proclaims knowledge.","searchKeywords":["day","utters","speech","and","night","proclaims","knowledge"]},{"verseId":"brenton_psalms_18_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":4,"text":"There are no speeches or words, in which their voices are not heard.","searchKeywords":["there","are","speeches","words","which","their","voices","not","heard"]},{"verseId":"brenton_psalms_18_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":5,"text":"Their voice is gone out into all the earth, and their words to the ends of the world.","searchKeywords":["their","voice","gone","out","into","all","the","earth","and","words","ends","world"]},{"verseId":"brenton_psalms_18_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":6,"text":"In the sun he has set his tabernacle; and he comes forth as a bridegroom out of his chamber: he will exult as a giant to run his course.","searchKeywords":["the","sun","has","set","his","tabernacle","and","comes","forth","bridegroom","out","chamber","will","exult","giant","run","course"]},{"verseId":"brenton_psalms_18_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":7,"text":"His going forth is from the extremity of heaven, and his circuit to the end of heaven: and no one shall be hidden from his heat.","searchKeywords":["his","going","forth","from","the","extremity","heaven","and","circuit","end","one","shall","hidden","heat"]},{"verseId":"brenton_psalms_18_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":8,"text":"The law of the Lord is perfect, converting souls: the testimony of the Lord is faithful, instructing babes.","searchKeywords":["the","law","lord","perfect","converting","souls","testimony","faithful","instructing","babes"]},{"verseId":"brenton_psalms_18_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":9,"text":"The ordinances of the Lord are right, rejoicing the heart: the commandment of the Lord is bright, enlightening the eyes.","searchKeywords":["the","ordinances","lord","are","right","rejoicing","heart","commandment","bright","enlightening","eyes"]},{"verseId":"brenton_psalms_18_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":10,"text":"The fear of the Lord is pure, enduring for ever and ever: the judgments of the Lord are true, justified altogether.","searchKeywords":["the","fear","lord","pure","enduring","for","ever","and","judgments","are","true","justified","altogether"]},{"verseId":"brenton_psalms_18_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":11,"text":"To be desired more than gold, and much precious stone: sweeter also than honey and the honey-comb.","searchKeywords":["desired","more","than","gold","and","much","precious","stone","sweeter","also","honey","the","comb"]},{"verseId":"brenton_psalms_18_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":12,"text":"For thy servant keeps to them: in the keeping of them great reward.","searchKeywords":["for","thy","servant","keeps","them","the","keeping","great","reward"]},{"verseId":"brenton_psalms_18_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":13,"text":"Who will understand transgressions? purge thou me from my secret .","searchKeywords":["who","will","understand","transgressions","purge","thou","from","secret"]},{"verseId":"brenton_psalms_18_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":14,"text":"And spare thy servant of strangers: if they do not gain the dominion over me, then shall I be blameless, and I shall be clear from great sin.","searchKeywords":["and","spare","thy","servant","strangers","they","not","gain","the","dominion","over","then","shall","blameless","clear","from","great","sin"]},{"verseId":"brenton_psalms_18_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":18,"verse":15,"text":"So shall the sayings of my mouth, and the meditation of my heart, be pleasing continually before thee, O Lord my helper, and my redeemer.","searchKeywords":["shall","the","sayings","mouth","and","meditation","heart","pleasing","continually","before","thee","lord","helper","redeemer"]}]