[{"verseId":"brenton_psalms_93_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":1,"text":"A Psalm of David for the fourth of the week. has declared himself.","searchKeywords":["psalm","david","for","the","fourth","week","has","declared","himself"]},{"verseId":"brenton_psalms_93_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":2,"text":"Be thou exalted, thou that judgest the earth: render a reward to the proud.","searchKeywords":["thou","exalted","that","judgest","the","earth","render","reward","proud"]},{"verseId":"brenton_psalms_93_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":3,"text":"How long shall sinners, O Lord, how long shall sinners boast?","searchKeywords":["how","long","shall","sinners","lord","boast"]},{"verseId":"brenton_psalms_93_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":4,"text":"They will utter and speak unrighteousness; all the workers of iniquity will speak .","searchKeywords":["they","will","utter","and","speak","unrighteousness","all","the","workers","iniquity"]},{"verseId":"brenton_psalms_93_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":5,"text":"They have afflicted thy people, O Lord, and hurt thine heritage.","searchKeywords":["they","have","afflicted","thy","people","lord","and","hurt","thine","heritage"]},{"verseId":"brenton_psalms_93_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":6,"text":"They have slain the widow and fatherless, and murdered the stranger.","searchKeywords":["they","have","slain","the","widow","and","fatherless","murdered","stranger"]},{"verseId":"brenton_psalms_93_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":7,"text":"And they said, The Lord shall not see, neither shall the God of Jacob understand.","searchKeywords":["and","they","said","the","lord","shall","not","see","neither","god","jacob","understand"]},{"verseId":"brenton_psalms_93_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":8,"text":"Understand now, ye simple among the people; and ye fools, at length be wise.","searchKeywords":["understand","now","simple","among","the","people","and","fools","length","wise"]},{"verseId":"brenton_psalms_93_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":9,"text":"He that planted the ear, does he not hear? or he that formed the eye, does not he perceive?","searchKeywords":["that","planted","the","ear","does","not","hear","formed","eye","perceive"]},{"verseId":"brenton_psalms_93_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":10,"text":"He that chastises the heathen, shall not he punish, he that teaches man knowledge?","searchKeywords":["that","chastises","the","heathen","shall","not","punish","teaches","man","knowledge"]},{"verseId":"brenton_psalms_93_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":11,"text":"The Lord knows the thoughts of men, that they are vain.","searchKeywords":["the","lord","knows","thoughts","men","that","they","are","vain"]},{"verseId":"brenton_psalms_93_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":12,"text":"Blessed is the man whomsoever thou shalt chasten, O Lord, and shalt teach him out of thy law;","searchKeywords":["blessed","the","man","whomsoever","thou","shalt","chasten","lord","and","teach","him","out","thy","law"]},{"verseId":"brenton_psalms_93_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":13,"text":"to give him rest from evil days, until a pit be digged for the sinful one.","searchKeywords":["give","him","rest","from","evil","days","until","pit","digged","for","the","sinful","one"]},{"verseId":"brenton_psalms_93_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":14,"text":"For the Lord will not cast off his people, neither will he forsake his inheritance;","searchKeywords":["for","the","lord","will","not","cast","off","his","people","neither","forsake","inheritance"]},{"verseId":"brenton_psalms_93_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":15,"text":"until righteousness return to judgment, and all the upright in heart shall follow it. Pause.","searchKeywords":["until","righteousness","return","judgment","and","all","the","upright","heart","shall","follow","pause"]},{"verseId":"brenton_psalms_93_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":16,"text":"Who will rise up for me against the transgressors? or who will stand up with me against the workers of iniquity?","searchKeywords":["who","will","rise","for","against","the","transgressors","stand","with","workers","iniquity"]},{"verseId":"brenton_psalms_93_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":17,"text":"If the Lord had not helped me, my soul had almost sojourned in Hades.","searchKeywords":["the","lord","had","not","helped","soul","almost","sojourned","hades"]},{"verseId":"brenton_psalms_93_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":18,"text":"If I said, My foot has been moved;","searchKeywords":["said","foot","has","been","moved"]},{"verseId":"brenton_psalms_93_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":19,"text":"thy mercy, O Lord, helped me. O Lord, according to the multitude of my griefs within my heart, thy consolations have soothed my soul.","searchKeywords":["thy","mercy","lord","helped","according","the","multitude","griefs","within","heart","consolations","have","soothed","soul"]},{"verseId":"brenton_psalms_93_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":20,"text":"Shall the throne of iniquity have fellowship with thee, which frames mischief by an ordinance?","searchKeywords":["shall","the","throne","iniquity","have","fellowship","with","thee","which","frames","mischief","ordinance"]},{"verseId":"brenton_psalms_93_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":21,"text":"They will hunt for the soul of the righteous, and condemn innocent blood.","searchKeywords":["they","will","hunt","for","the","soul","righteous","and","condemn","innocent","blood"]},{"verseId":"brenton_psalms_93_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":22,"text":"But the Lord was my refuge; and my God the helper of my hope.","searchKeywords":["but","the","lord","was","refuge","and","god","helper","hope"]},{"verseId":"brenton_psalms_93_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":93,"verse":23,"text":"And he will recompense to them their iniquity and their wickedness: the Lord our God shall utterly destroy them.","searchKeywords":["and","will","recompense","them","their","iniquity","wickedness","the","lord","our","god","shall","utterly","destroy"]}]