[{"verseId":"brenton_psalms_110_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":110,"verse":1,"text":"Alleluia. the congregation.","searchKeywords":["alleluia","the","congregation"]},{"verseId":"brenton_psalms_110_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":110,"verse":2,"text":"The works of the Lord are great, sought out according to all his will.","searchKeywords":["the","works","lord","are","great","sought","out","according","all","his","will"]},{"verseId":"brenton_psalms_110_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":110,"verse":3,"text":"His work is thanksgiving and honour: and his righteousness endures for ever and ever.","searchKeywords":["his","work","thanksgiving","and","honour","righteousness","endures","for","ever"]},{"verseId":"brenton_psalms_110_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":110,"verse":4,"text":"He has caused his wonderful works to be remembered: the Lord is merciful and compassionate.","searchKeywords":["has","caused","his","wonderful","works","remembered","the","lord","merciful","and","compassionate"]},{"verseId":"brenton_psalms_110_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":110,"verse":5,"text":"He has given food to them that fear him: he will remember his covenant for ever.","searchKeywords":["has","given","food","them","that","fear","him","will","remember","his","covenant","for","ever"]},{"verseId":"brenton_psalms_110_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":110,"verse":6,"text":"He has declared to his people the power of his works, to give them the inheritance of the heathen.","searchKeywords":["has","declared","his","people","the","power","works","give","them","inheritance","heathen"]},{"verseId":"brenton_psalms_110_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":110,"verse":7,"text":"The works of his hands are truth and judgment: all his commandments are sure:","searchKeywords":["the","works","his","hands","are","truth","and","judgment","all","commandments","sure"]},{"verseId":"brenton_psalms_110_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":110,"verse":8,"text":"established for ever and ever, done in truth and uprightness.","searchKeywords":["established","for","ever","and","done","truth","uprightness"]},{"verseId":"brenton_psalms_110_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":110,"verse":9,"text":"He sent redemption to his people: he commanded his covenant for ever: holy and fearful is his name.","searchKeywords":["sent","redemption","his","people","commanded","covenant","for","ever","holy","and","fearful","name"]},{"verseId":"brenton_psalms_110_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":110,"verse":10,"text":"The fear of the Lord is the beginning of wisdom, and all that act accordingly have a good understanding; his praise endures for ever and ever.","searchKeywords":["the","fear","lord","beginning","wisdom","and","all","that","act","accordingly","have","good","understanding","his","praise","endures","for","ever"]}]