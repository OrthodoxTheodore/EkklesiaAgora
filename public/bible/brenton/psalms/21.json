[{"verseId":"brenton_psalms_21_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":1,"text":"For the end, concerning the morning aid, a Psalm of David.","searchKeywords":["for","the","end","concerning","morning","aid","psalm","david"]},{"verseId":"brenton_psalms_21_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":2,"text":"O God, my God, attend to me: why hast thou forsaken me? the account of my transgressions is far from my salvation.","searchKeywords":["god","attend","why","hast","thou","forsaken","the","account","transgressions","far","from","salvation"]},{"verseId":"brenton_psalms_21_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":3,"text":"O my God, I will cry to thee by day, but thou wilt not hear: and by night, and not for folly to me.","searchKeywords":["god","will","cry","thee","day","but","thou","wilt","not","hear","and","night","for","folly"]},{"verseId":"brenton_psalms_21_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":4,"text":"But thou, the praise of Israel, dwellest in a sanctuary.","searchKeywords":["but","thou","the","praise","israel","dwellest","sanctuary"]},{"verseId":"brenton_psalms_21_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":5,"text":"Our fathers hoped in thee; they hoped, and thou didst deliver them.","searchKeywords":["our","fathers","hoped","thee","they","and","thou","didst","deliver","them"]},{"verseId":"brenton_psalms_21_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":6,"text":"They cried to thee, and were saved: they hoped in thee, and were not ashamed.","searchKeywords":["they","cried","thee","and","were","saved","hoped","not","ashamed"]},{"verseId":"brenton_psalms_21_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":7,"text":"But I am a worm, and not a man; a reproach of men, and scorn of the people.","searchKeywords":["but","worm","and","not","man","reproach","men","scorn","the","people"]},{"verseId":"brenton_psalms_21_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":8,"text":"All that saw me mocked me: they spoke with lips, they shook the head, ,","searchKeywords":["all","that","saw","mocked","they","spoke","with","lips","shook","the","head"]},{"verseId":"brenton_psalms_21_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":9,"text":"He hoped in the Lord: let him deliver him, let him save him, because he takes pleasure in him.","searchKeywords":["hoped","the","lord","let","him","deliver","save","because","takes","pleasure"]},{"verseId":"brenton_psalms_21_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":10,"text":"For thou art he that drew me out of the womb; my hope from my mother's breasts.","searchKeywords":["for","thou","art","that","drew","out","the","womb","hope","from","mother","breasts"]},{"verseId":"brenton_psalms_21_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":11,"text":"I was cast on thee from the womb: thou art my God from my mother's belly.","searchKeywords":["was","cast","thee","from","the","womb","thou","art","god","mother","belly"]},{"verseId":"brenton_psalms_21_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":12,"text":"Stand not aloof from me; for affliction is near; for there is no helper.","searchKeywords":["stand","not","aloof","from","for","affliction","near","there","helper"]},{"verseId":"brenton_psalms_21_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":13,"text":"Many bullocks have compassed me: fat bulls have beset me round.","searchKeywords":["many","bullocks","have","compassed","fat","bulls","beset","round"]},{"verseId":"brenton_psalms_21_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":14,"text":"They have opened their mouth against me, as a ravening and roaring lion.","searchKeywords":["they","have","opened","their","mouth","against","ravening","and","roaring","lion"]},{"verseId":"brenton_psalms_21_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":15,"text":"I am poured out like water, and all my bones are loosened: my heart in the midst of my belly is become like melting wax.","searchKeywords":["poured","out","like","water","and","all","bones","are","loosened","heart","the","midst","belly","become","melting","wax"]},{"verseId":"brenton_psalms_21_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":16,"text":"My strength is dried up like a potsherd; and my tongue is glued to my throat; and thou hast brought me down to the dust of death.","searchKeywords":["strength","dried","like","potsherd","and","tongue","glued","throat","thou","hast","brought","down","the","dust","death"]},{"verseId":"brenton_psalms_21_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":17,"text":"For many dogs have compassed me: the assembly of the wicked doers has beset me round: they pierced my hands and my feet.","searchKeywords":["for","many","dogs","have","compassed","the","assembly","wicked","doers","has","beset","round","they","pierced","hands","and","feet"]},{"verseId":"brenton_psalms_21_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":18,"text":"They counted all my bones; and they observed and looked upon me.","searchKeywords":["they","counted","all","bones","and","observed","looked","upon"]},{"verseId":"brenton_psalms_21_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":19,"text":"They parted my garments themselves, and cast lots upon my raiment.","searchKeywords":["they","parted","garments","themselves","and","cast","lots","upon","raiment"]},{"verseId":"brenton_psalms_21_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":20,"text":"But thou, O Lord, remove not my help afar off: be ready for mine aid.","searchKeywords":["but","thou","lord","remove","not","help","afar","off","ready","for","mine","aid"]},{"verseId":"brenton_psalms_21_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":21,"text":"Deliver my soul from the sword; my only-begotten one from the power of the dog.","searchKeywords":["deliver","soul","from","the","sword","only","begotten","one","power","dog"]},{"verseId":"brenton_psalms_21_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":22,"text":"Save me from the lion's mouth; and my lowliness from the horns of the unicorns.","searchKeywords":["save","from","the","lion","mouth","and","lowliness","horns","unicorns"]},{"verseId":"brenton_psalms_21_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":23,"text":"I will declare thy name to my brethren: in the midst of the church will I sing praise to thee.","searchKeywords":["will","declare","thy","name","brethren","the","midst","church","sing","praise","thee"]},{"verseId":"brenton_psalms_21_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":24,"text":"Ye that fear the Lord, praise him; all ye seed of Jacob, glorify him: let all the seed of Israel fear him.","searchKeywords":["that","fear","the","lord","praise","him","all","seed","jacob","glorify","let","israel"]},{"verseId":"brenton_psalms_21_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":25,"text":"For he has not despised nor been angry at the supplication of the poor; nor turned away his face from me; but when I cried to him, he heard me.","searchKeywords":["for","has","not","despised","nor","been","angry","the","supplication","poor","turned","away","his","face","from","but","when","cried","him","heard"]},{"verseId":"brenton_psalms_21_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":26,"text":"My praise is of thee in the great congregation: I will pay my vows before them that fear him.","searchKeywords":["praise","thee","the","great","congregation","will","pay","vows","before","them","that","fear","him"]},{"verseId":"brenton_psalms_21_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":27,"text":"The poor shall eat and be satisfied; and they shall praise the Lord that seek him: their heart shall live for ever.","searchKeywords":["the","poor","shall","eat","and","satisfied","they","praise","lord","that","seek","him","their","heart","live","for","ever"]},{"verseId":"brenton_psalms_21_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":28,"text":"All the ends of the earth shall remember and turn to the Lord: and all the kindreds of the nations shall worship before him.","searchKeywords":["all","the","ends","earth","shall","remember","and","turn","lord","kindreds","nations","worship","before","him"]},{"verseId":"brenton_psalms_21_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":29,"text":"For the kingdom is the Lord's; and he is the governor of the nations.","searchKeywords":["for","the","kingdom","lord","and","governor","nations"]},{"verseId":"brenton_psalms_21_30","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":30,"text":"All the fat ones of the earth have eaten and worshipped: all that go down to the earth shall fall down before him: my soul also lives to him.","searchKeywords":["all","the","fat","ones","earth","have","eaten","and","worshipped","that","down","shall","fall","before","him","soul","also","lives"]},{"verseId":"brenton_psalms_21_31","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":31,"text":"And my seed shall serve him: the generation that is coming shall be reported to the Lord.","searchKeywords":["and","seed","shall","serve","him","the","generation","that","coming","reported","lord"]},{"verseId":"brenton_psalms_21_32","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":21,"verse":32,"text":"And they shall report his righteousness to the people that shall be born, whom the Lord has made.","searchKeywords":["and","they","shall","report","his","righteousness","the","people","that","born","whom","lord","has","made"]}]