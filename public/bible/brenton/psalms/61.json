[{"verseId":"brenton_psalms_61_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":61,"verse":1,"text":"For the end, a Psalm of David for Idithun.","searchKeywords":["for","the","end","psalm","david","idithun"]},{"verseId":"brenton_psalms_61_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":61,"verse":2,"text":"Shall not my soul be subjected to God? for of him is my salvation.","searchKeywords":["shall","not","soul","subjected","god","for","him","salvation"]},{"verseId":"brenton_psalms_61_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":61,"verse":3,"text":"For he is my God and my Saviour; my helper, I shall not be moved very much.","searchKeywords":["for","god","and","saviour","helper","shall","not","moved","very","much"]},{"verseId":"brenton_psalms_61_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":61,"verse":4,"text":"How long will ye assault a man? ye are all slaughtering as with a bowed wall and a broken hedge.","searchKeywords":["how","long","will","assault","man","are","all","slaughtering","with","bowed","wall","and","broken","hedge"]},{"verseId":"brenton_psalms_61_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":61,"verse":5,"text":"They only took counsel to set at nought mine honour: I ran in thirst: with their mouth they blessed, but with their heart they cursed. Pause.","searchKeywords":["they","only","took","counsel","set","nought","mine","honour","ran","thirst","with","their","mouth","blessed","but","heart","cursed","pause"]},{"verseId":"brenton_psalms_61_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":61,"verse":6,"text":"Nevertheless do thou, my soul, be subjected to God; for of him my patient hope.","searchKeywords":["nevertheless","thou","soul","subjected","god","for","him","patient","hope"]},{"verseId":"brenton_psalms_61_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":61,"verse":7,"text":"For he my God and my Saviour; my helper, I shall not be moved.","searchKeywords":["for","god","and","saviour","helper","shall","not","moved"]},{"verseId":"brenton_psalms_61_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":61,"verse":8,"text":"In God my salvation and my glory: the God of my help, and my hope is in God.","searchKeywords":["god","salvation","and","glory","the","help","hope"]},{"verseId":"brenton_psalms_61_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":61,"verse":9,"text":"Hope in him, all ye congregation of the people; pour out your hearts before him, for God is our helper. Pause.","searchKeywords":["hope","him","all","congregation","the","people","pour","out","your","hearts","before","for","god","our","helper","pause"]},{"verseId":"brenton_psalms_61_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":61,"verse":10,"text":"But the sons of men are vain; the sons of men are false, so as to be deceitful in the balances; they are all alike out of vanity.","searchKeywords":["but","the","sons","men","are","vain","false","deceitful","balances","they","all","alike","out","vanity"]},{"verseId":"brenton_psalms_61_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":61,"verse":11,"text":"Trust not in unrighteousness, and lust not after robberies: if wealth should flow in, set not your heart upon it.","searchKeywords":["trust","not","unrighteousness","and","lust","after","robberies","wealth","should","flow","set","your","heart","upon"]},{"verseId":"brenton_psalms_61_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":61,"verse":12,"text":"God has spoken once, I have heard these two things, that power is of God;","searchKeywords":["god","has","spoken","once","have","heard","these","two","things","that","power"]},{"verseId":"brenton_psalms_61_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":61,"verse":13,"text":"and mercy is thine, O Lord; for thou wilt recompense every one according to his works.","searchKeywords":["and","mercy","thine","lord","for","thou","wilt","recompense","every","one","according","his","works"]}]