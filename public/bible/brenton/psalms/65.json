[{"verseId":"brenton_psalms_65_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":1,"text":"For the end, a Song of a Psalm of resurrection.","searchKeywords":["for","the","end","song","psalm","resurrection"]},{"verseId":"brenton_psalms_65_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":2,"text":"O sing praises to his name; give glory to his praise.","searchKeywords":["sing","praises","his","name","give","glory","praise"]},{"verseId":"brenton_psalms_65_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":3,"text":"Say unto God, How awful are thy works! through the greatness of thy power thine enemies shall lie to thee.","searchKeywords":["say","unto","god","how","awful","are","thy","works","through","the","greatness","power","thine","enemies","shall","lie","thee"]},{"verseId":"brenton_psalms_65_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":4,"text":"Let all the earth worship thee, and sing to thee; let them sing to thy name. Pause.","searchKeywords":["let","all","the","earth","worship","thee","and","sing","them","thy","name","pause"]},{"verseId":"brenton_psalms_65_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":5,"text":"Come and behold the works of God; terrible in counsels beyond the children of men.","searchKeywords":["come","and","behold","the","works","god","terrible","counsels","beyond","children","men"]},{"verseId":"brenton_psalms_65_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":6,"text":"Who turns the sea into dry land; they shall go through the river on foot; there shall we rejoice in him,","searchKeywords":["who","turns","the","sea","into","dry","land","they","shall","through","river","foot","there","rejoice","him"]},{"verseId":"brenton_psalms_65_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":7,"text":"who by his power is Lord over the age, his eyes look upon the nations; let not them that provoke be exalted in themselves. Pause.","searchKeywords":["who","his","power","lord","over","the","age","eyes","look","upon","nations","let","not","them","that","provoke","exalted","themselves","pause"]},{"verseId":"brenton_psalms_65_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":8,"text":"Bless our God, ye Gentiles, and make the voice of his praise to be heard;","searchKeywords":["bless","our","god","gentiles","and","make","the","voice","his","praise","heard"]},{"verseId":"brenton_psalms_65_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":9,"text":"who quickens my soul in life, and does not suffer my feet to be moved.","searchKeywords":["who","quickens","soul","life","and","does","not","suffer","feet","moved"]},{"verseId":"brenton_psalms_65_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":10,"text":"For thou, O God, hast proved us; thou hast tried us with fire as silver is tried.","searchKeywords":["for","thou","god","hast","proved","tried","with","fire","silver"]},{"verseId":"brenton_psalms_65_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":11,"text":"Thou broughtest us into the snare; thou laidest afflictions on our back.","searchKeywords":["thou","broughtest","into","the","snare","laidest","afflictions","our","back"]},{"verseId":"brenton_psalms_65_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":12,"text":"Thou didst mount men upon our heads; we went through fire and water; but thou broughtest us out into refreshment.","searchKeywords":["thou","didst","mount","men","upon","our","heads","went","through","fire","and","water","but","broughtest","out","into","refreshment"]},{"verseId":"brenton_psalms_65_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":13,"text":"I will go into thine house with whole-burnt-offerings; I will pay thee my vows,","searchKeywords":["will","into","thine","house","with","whole","burnt","offerings","pay","thee","vows"]},{"verseId":"brenton_psalms_65_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":14,"text":"which my lips framed, and my mouth uttered in my affliction.","searchKeywords":["which","lips","framed","and","mouth","uttered","affliction"]},{"verseId":"brenton_psalms_65_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":15,"text":"I will offer to thee whole-burnt-sacrifices full of marrow, with incense and rams; I will sacrifice to thee oxen with goats. Pause.","searchKeywords":["will","offer","thee","whole","burnt","sacrifices","full","marrow","with","incense","and","rams","sacrifice","oxen","goats","pause"]},{"verseId":"brenton_psalms_65_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":16,"text":"Come, hear, and I will tell, all ye that fear God, how great things he has done for my soul.","searchKeywords":["come","hear","and","will","tell","all","that","fear","god","how","great","things","has","done","for","soul"]},{"verseId":"brenton_psalms_65_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":17,"text":"I cried to him with my mouth, and exalted him with my tongue.","searchKeywords":["cried","him","with","mouth","and","exalted","tongue"]},{"verseId":"brenton_psalms_65_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":18,"text":"If I have regarded iniquity in my heart, let not the Lord hearken .","searchKeywords":["have","regarded","iniquity","heart","let","not","the","lord","hearken"]},{"verseId":"brenton_psalms_65_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":19,"text":"Therefore God has hearkened to me; he has attended to the voice of my prayer.","searchKeywords":["therefore","god","has","hearkened","attended","the","voice","prayer"]},{"verseId":"brenton_psalms_65_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":65,"verse":20,"text":"Blessed be God, who has not turned away my prayer, nor his mercy from me.","searchKeywords":["blessed","god","who","has","not","turned","away","prayer","nor","his","mercy","from"]}]