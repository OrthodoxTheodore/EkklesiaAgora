[{"verseId":"brenton_psalms_147_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":147,"verse":1,"text":"Alleluia, of Aggæus and Zacharias.","searchKeywords":["alleluia","agg","and","zacharias"]},{"verseId":"brenton_psalms_147_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":147,"verse":2,"text":"For he has strengthened the bars of thy gates; he has blessed thy children within thee.","searchKeywords":["for","has","strengthened","the","bars","thy","gates","blessed","children","within","thee"]},{"verseId":"brenton_psalms_147_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":147,"verse":3,"text":"He makes thy borders peaceful, and fills thee with the flour of wheat.","searchKeywords":["makes","thy","borders","peaceful","and","fills","thee","with","the","flour","wheat"]},{"verseId":"brenton_psalms_147_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":147,"verse":4,"text":"He sends his oracle to the earth: his word will run swiftly.","searchKeywords":["sends","his","oracle","the","earth","word","will","run","swiftly"]},{"verseId":"brenton_psalms_147_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":147,"verse":5,"text":"He gives snow like wool: he scatters the mist like ashes.","searchKeywords":["gives","snow","like","wool","scatters","the","mist","ashes"]},{"verseId":"brenton_psalms_147_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":147,"verse":6,"text":"Casting his ice like morsels: who shall stand before his cold?","searchKeywords":["casting","his","ice","like","morsels","who","shall","stand","before","cold"]},{"verseId":"brenton_psalms_147_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":147,"verse":7,"text":"He shall send out his word, and melt them: he shall blow his wind, and the waters shall flow.","searchKeywords":["shall","send","out","his","word","and","melt","them","blow","wind","the","waters","flow"]},{"verseId":"brenton_psalms_147_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":147,"verse":8,"text":"He sends his word to Jacob, his ordinances and judgments to Israel.","searchKeywords":["sends","his","word","jacob","ordinances","and","judgments","israel"]},{"verseId":"brenton_psalms_147_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":147,"verse":9,"text":"He has not done so to any nation; and he has not shewn them his judgments.","searchKeywords":["has","not","done","any","nation","and","shewn","them","his","judgments"]}]