[{"verseId":"brenton_psalms_29_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":29,"verse":1,"text":"For the end, a Psalm and Song at the dedication of the house of David.","searchKeywords":["for","the","end","psalm","and","song","dedication","house","david"]},{"verseId":"brenton_psalms_29_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":29,"verse":2,"text":"I will exalt thee, O Lord; for thou hast lifted me up, and not caused mine enemies to rejoice over me.","searchKeywords":["will","exalt","thee","lord","for","thou","hast","lifted","and","not","caused","mine","enemies","rejoice","over"]},{"verseId":"brenton_psalms_29_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":29,"verse":3,"text":"O Lord my God, I cried to thee, and thou didst heal me.","searchKeywords":["lord","god","cried","thee","and","thou","didst","heal"]},{"verseId":"brenton_psalms_29_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":29,"verse":4,"text":"O Lord, thou hast brought up my soul from Hades, thou hast delivered me from them that go down to the pit.","searchKeywords":["lord","thou","hast","brought","soul","from","hades","delivered","them","that","down","the","pit"]},{"verseId":"brenton_psalms_29_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":29,"verse":5,"text":"Sing to the Lord, ye his saints, and give thanks for the remembrance of his holiness.","searchKeywords":["sing","the","lord","his","saints","and","give","thanks","for","remembrance","holiness"]},{"verseId":"brenton_psalms_29_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":29,"verse":6,"text":"For anger is in his wrath, but life in his favour: weeping shall tarry for the evening, but joy shall be in the morning.","searchKeywords":["for","anger","his","wrath","but","life","favour","weeping","shall","tarry","the","evening","joy","morning"]},{"verseId":"brenton_psalms_29_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":29,"verse":7,"text":"And I said in my prosperity, I shall never be moved.","searchKeywords":["and","said","prosperity","shall","never","moved"]},{"verseId":"brenton_psalms_29_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":29,"verse":8,"text":"O Lord, in thy good pleasure thou didst add strength to my beauty: but thou didst turn away thy face, and I was troubled.","searchKeywords":["lord","thy","good","pleasure","thou","didst","add","strength","beauty","but","turn","away","face","and","was","troubled"]},{"verseId":"brenton_psalms_29_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":29,"verse":9,"text":"To thee, O Lord, will I cry; and to my God will I make supplication.","searchKeywords":["thee","lord","will","cry","and","god","make","supplication"]},{"verseId":"brenton_psalms_29_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":29,"verse":10,"text":"What profit is there in my blood, when I go down to destruction? Shall the dust give praise to thee? or shall it declare thy truth?","searchKeywords":["what","profit","there","blood","when","down","destruction","shall","the","dust","give","praise","thee","declare","thy","truth"]},{"verseId":"brenton_psalms_29_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":29,"verse":11,"text":"The Lord heard, and had compassion upon me; the Lord is become my helper.","searchKeywords":["the","lord","heard","and","had","compassion","upon","become","helper"]},{"verseId":"brenton_psalms_29_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":29,"verse":12,"text":"Thou hast turned my mourning into joy for me: thou hast rent off my sackcloth, and girded me with gladness;","searchKeywords":["thou","hast","turned","mourning","into","joy","for","rent","off","sackcloth","and","girded","with","gladness"]},{"verseId":"brenton_psalms_29_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":29,"verse":13,"text":"that my glory may sing praise to thee, and I may not be pierced . O Lord my God, I will give thanks to thee for ever.","searchKeywords":["that","glory","may","sing","praise","thee","and","not","pierced","lord","god","will","give","thanks","for","ever"]}]