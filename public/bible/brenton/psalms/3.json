[{"verseId":"brenton_psalms_3_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":3,"verse":1,"text":"A Psalm of David, when he fled from the presence of his son Abessalom.","searchKeywords":["psalm","david","when","fled","from","the","presence","his","son","abessalom"]},{"verseId":"brenton_psalms_3_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":3,"verse":2,"text":"O Lord, why are they that afflict me multiplied? many rise up against me.","searchKeywords":["lord","why","are","they","that","afflict","multiplied","many","rise","against"]},{"verseId":"brenton_psalms_3_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":3,"verse":3,"text":"Many say concerning my soul, There is no deliverance for him in his God. Pause.","searchKeywords":["many","say","concerning","soul","there","deliverance","for","him","his","god","pause"]},{"verseId":"brenton_psalms_3_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":3,"verse":4,"text":"But thou, O Lord, art my helper: my glory, and the one that lifts up my head.","searchKeywords":["but","thou","lord","art","helper","glory","and","the","one","that","lifts","head"]},{"verseId":"brenton_psalms_3_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":3,"verse":5,"text":"I cried to the Lord with my voice, and he heard me out of his holy mountain. Pause.","searchKeywords":["cried","the","lord","with","voice","and","heard","out","his","holy","mountain","pause"]},{"verseId":"brenton_psalms_3_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":3,"verse":6,"text":"I lay down and slept; I awaked; for the Lord will help me.","searchKeywords":["lay","down","and","slept","awaked","for","the","lord","will","help"]},{"verseId":"brenton_psalms_3_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":3,"verse":7,"text":"I will not be afraid of ten thousands of people, who beset me round about.","searchKeywords":["will","not","afraid","ten","thousands","people","who","beset","round","about"]},{"verseId":"brenton_psalms_3_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":3,"verse":8,"text":"Arise, Lord; deliver me, my God: for thou hast smitten all who were without cause mine enemies; thou hast broken the teeth of sinners.","searchKeywords":["arise","lord","deliver","god","for","thou","hast","smitten","all","who","were","without","cause","mine","enemies","broken","the","teeth","sinners"]},{"verseId":"brenton_psalms_3_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":3,"verse":9,"text":"Deliverance is the Lord's, and thy blessing is upon thy people.","searchKeywords":["deliverance","the","lord","and","thy","blessing","upon","people"]}]