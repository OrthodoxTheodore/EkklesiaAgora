[{"verseId":"brenton_psalms_95_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":95,"verse":1,"text":"When the house was built after the Captivity, a Song by David.","searchKeywords":["when","the","house","was","built","after","captivity","song","david"]},{"verseId":"brenton_psalms_95_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":95,"verse":2,"text":"Sing to the Lord, bless his name: proclaim his salvation from day to day.","searchKeywords":["sing","the","lord","bless","his","name","proclaim","salvation","from","day"]},{"verseId":"brenton_psalms_95_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":95,"verse":3,"text":"Publish his glory among the Gentiles, his wonderful works among all people.","searchKeywords":["publish","his","glory","among","the","gentiles","wonderful","works","all","people"]},{"verseId":"brenton_psalms_95_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":95,"verse":4,"text":"For the Lord is great, and greatly to be praised: he is terrible above all gods.","searchKeywords":["for","the","lord","great","and","greatly","praised","terrible","above","all","gods"]},{"verseId":"brenton_psalms_95_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":95,"verse":5,"text":"For all the gods of the heathen are devils: but the Lord made the heavens.","searchKeywords":["for","all","the","gods","heathen","are","devils","but","lord","made","heavens"]},{"verseId":"brenton_psalms_95_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":95,"verse":6,"text":"Thanksgiving and beauty are before him: holiness and majesty are in his sanctuary.","searchKeywords":["thanksgiving","and","beauty","are","before","him","holiness","majesty","his","sanctuary"]},{"verseId":"brenton_psalms_95_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":95,"verse":7,"text":"Bring to the Lord, ye families of the Gentiles, bring to the Lord glory and honour.","searchKeywords":["bring","the","lord","families","gentiles","glory","and","honour"]},{"verseId":"brenton_psalms_95_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":95,"verse":8,"text":"Bring to the Lord the glory his name: take offerings, and go into his courts.","searchKeywords":["bring","the","lord","glory","his","name","take","offerings","and","into","courts"]},{"verseId":"brenton_psalms_95_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":95,"verse":9,"text":"Worship the Lord in his holy court: let all the earth tremble before him.","searchKeywords":["worship","the","lord","his","holy","court","let","all","earth","tremble","before","him"]},{"verseId":"brenton_psalms_95_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":95,"verse":10,"text":"Say among the heathen, The Lord reigns: for he has established the world so that it shall not be moved: he shall judge the people in righteousness.","searchKeywords":["say","among","the","heathen","lord","reigns","for","has","established","world","that","shall","not","moved","judge","people","righteousness"]},{"verseId":"brenton_psalms_95_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":95,"verse":11,"text":"Let the heavens rejoice, and the earth exult; let the sea be moved, and the fulness of it.","searchKeywords":["let","the","heavens","rejoice","and","earth","exult","sea","moved","fulness"]},{"verseId":"brenton_psalms_95_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":95,"verse":12,"text":"The plains shall rejoice, and all things in them: then shall all the trees of the wood exult before the presence of the Lord:","searchKeywords":["the","plains","shall","rejoice","and","all","things","them","then","trees","wood","exult","before","presence","lord"]},{"verseId":"brenton_psalms_95_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":95,"verse":13,"text":"for he comes, for he comes to judge the earth; he shall judge the world in righteousness, and the people with his truth.","searchKeywords":["for","comes","judge","the","earth","shall","world","righteousness","and","people","with","his","truth"]}]