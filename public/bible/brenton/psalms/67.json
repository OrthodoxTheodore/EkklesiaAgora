[{"verseId":"brenton_psalms_67_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":1,"text":"For the end, a Psalm of a Song by David.","searchKeywords":["for","the","end","psalm","song","david"]},{"verseId":"brenton_psalms_67_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":2,"text":"Let God arise, and let his enemies be scattered; and let them that hate him flee from before him.","searchKeywords":["let","god","arise","and","his","enemies","scattered","them","that","hate","him","flee","from","before"]},{"verseId":"brenton_psalms_67_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":3,"text":"As smoke vanishes, let them vanish: as wax melts before the fire, so let the sinners perish from before God.","searchKeywords":["smoke","vanishes","let","them","vanish","wax","melts","before","the","fire","sinners","perish","from","god"]},{"verseId":"brenton_psalms_67_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":4,"text":"But let the righteous rejoice; let them exult before God: let them be delighted with joy.","searchKeywords":["but","let","the","righteous","rejoice","them","exult","before","god","delighted","with","joy"]},{"verseId":"brenton_psalms_67_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":5,"text":"Sing to God, sing praises to his name: make a way for him that rides upon the west (the Lord is his name) and exult before him. They shall be troubled before the face of him,","searchKeywords":["sing","god","praises","his","name","make","way","for","him","that","rides","upon","the","west","lord","and","exult","before","they","shall","troubled","face"]},{"verseId":"brenton_psalms_67_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":6,"text":"the father of the orphans, and judge of the widows: God in his holy place.","searchKeywords":["the","father","orphans","and","judge","widows","god","his","holy","place"]},{"verseId":"brenton_psalms_67_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":7,"text":"God settles the solitary in a house; leading forth prisoners mightily, also them that act provokingly, them that dwell in tombs.","searchKeywords":["god","settles","the","solitary","house","leading","forth","prisoners","mightily","also","them","that","act","provokingly","dwell","tombs"]},{"verseId":"brenton_psalms_67_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":8,"text":"O God, when thou wentest forth before thy people, when thou wentest through the wilderness; Pause:","searchKeywords":["god","when","thou","wentest","forth","before","thy","people","through","the","wilderness","pause"]},{"verseId":"brenton_psalms_67_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":9,"text":"the earth quaked, yea, the heavens dropped at the presence of the God of Sina, at the presence of the God of Israel.","searchKeywords":["the","earth","quaked","yea","heavens","dropped","presence","god","sina","israel"]},{"verseId":"brenton_psalms_67_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":10,"text":"O God, thou wilt grant to thine inheritance a gracious rain; for it was weary, but thou didst refresh it.","searchKeywords":["god","thou","wilt","grant","thine","inheritance","gracious","rain","for","was","weary","but","didst","refresh"]},{"verseId":"brenton_psalms_67_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":11,"text":"Thy creatures dwell in it: thou hast in thy goodness prepared for the poor.","searchKeywords":["thy","creatures","dwell","thou","hast","goodness","prepared","for","the","poor"]},{"verseId":"brenton_psalms_67_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":12,"text":"The Lord God will give a word to them that preach in a great company.","searchKeywords":["the","lord","god","will","give","word","them","that","preach","great","company"]},{"verseId":"brenton_psalms_67_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":13,"text":"The king of the forces of the beloved, of the beloved, even for the beauty of the house to divide the spoils.","searchKeywords":["the","king","forces","beloved","even","for","beauty","house","divide","spoils"]},{"verseId":"brenton_psalms_67_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":14,"text":"Even if ye should lie among the lots, the wings of a dove covered with silver, and her breast with yellow gold.","searchKeywords":["even","should","lie","among","the","lots","wings","dove","covered","with","silver","and","her","breast","yellow","gold"]},{"verseId":"brenton_psalms_67_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":15,"text":"When the heavenly One scatters kings upon it, they shall be made snow-white in Selmon.","searchKeywords":["when","the","heavenly","one","scatters","kings","upon","they","shall","made","snow","white","selmon"]},{"verseId":"brenton_psalms_67_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":16,"text":"The mountain of God is a rich mountain; a swelling mountain, a rich mountain.","searchKeywords":["the","mountain","god","rich","swelling"]},{"verseId":"brenton_psalms_67_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":17,"text":"Wherefore do ye conceive , ye swelling mountains? the mountain which God has delighted to dwell in; yea, the Lord will dwell for ever.","searchKeywords":["wherefore","conceive","swelling","mountains","the","mountain","which","god","has","delighted","dwell","yea","lord","will","for","ever"]},{"verseId":"brenton_psalms_67_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":18,"text":"The chariots of God are ten thousand fold, thousands of rejoicing ones: the Lord is among them, in Sina, in the holy place.","searchKeywords":["the","chariots","god","are","ten","thousand","fold","thousands","rejoicing","ones","lord","among","them","sina","holy","place"]},{"verseId":"brenton_psalms_67_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":19,"text":"Thou art gone up on high, thou hast led captivity captive, thou hast received gifts for man, yea, for rebellious, that thou mightest dwell among them.","searchKeywords":["thou","art","gone","high","hast","led","captivity","captive","received","gifts","for","man","yea","rebellious","that","mightest","dwell","among","them"]},{"verseId":"brenton_psalms_67_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":20,"text":"Blessed be the Lord God, blessed be the Lord daily; and the God of our salvation shall prosper us. Pause.","searchKeywords":["blessed","the","lord","god","daily","and","our","salvation","shall","prosper","pause"]},{"verseId":"brenton_psalms_67_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":21,"text":"Our God is the God of salvation; and to the Lord belong the issues from death.","searchKeywords":["our","god","the","salvation","and","lord","belong","issues","from","death"]},{"verseId":"brenton_psalms_67_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":22,"text":"But God shall crush the heads of his enemies; the hairy crown of them that go on in their trespasses.","searchKeywords":["but","god","shall","crush","the","heads","his","enemies","hairy","crown","them","that","their","trespasses"]},{"verseId":"brenton_psalms_67_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":23,"text":"The Lord said, I will bring again from Basan, I will bring again through the depths of the sea.","searchKeywords":["the","lord","said","will","bring","again","from","basan","through","depths","sea"]},{"verseId":"brenton_psalms_67_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":24,"text":"That thy foot may be dipped in blood, the tongue of thy dogs with that of enemies.","searchKeywords":["that","thy","foot","may","dipped","blood","the","tongue","dogs","with","enemies"]},{"verseId":"brenton_psalms_67_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":25,"text":"Thy goings, O God, have been seen; the goings of my God, the king, in the sanctuary.","searchKeywords":["thy","goings","god","have","been","seen","the","king","sanctuary"]},{"verseId":"brenton_psalms_67_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":26,"text":"The princes went first, next before the players on instruments, in the midst of damsels playing on timbrels.","searchKeywords":["the","princes","went","first","next","before","players","instruments","midst","damsels","playing","timbrels"]},{"verseId":"brenton_psalms_67_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":27,"text":"Praise God in the congregations, the Lord from the fountains of Israel.","searchKeywords":["praise","god","the","congregations","lord","from","fountains","israel"]},{"verseId":"brenton_psalms_67_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":28,"text":"There is Benjamin the younger in ecstasy, the princes of Juda their rulers, the princes of Zabulon, the princes of Nephthali.","searchKeywords":["there","benjamin","the","younger","ecstasy","princes","juda","their","rulers","zabulon","nephthali"]},{"verseId":"brenton_psalms_67_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":29,"text":"O God, command thou thy strength: strengthen, O God, this which thou hast wrought in us.","searchKeywords":["god","command","thou","thy","strength","strengthen","this","which","hast","wrought"]},{"verseId":"brenton_psalms_67_30","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":30,"text":"Because of thy temple at Jerusalem shall kings bring presents to thee.","searchKeywords":["because","thy","temple","jerusalem","shall","kings","bring","presents","thee"]},{"verseId":"brenton_psalms_67_31","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":31,"text":"Rebuke the wild beasts of the reed: let the crowd of bulls with the heifers of the nations , so that they who have been proved with silver may not be shut out: scatter thou the nations that wish for wars.","searchKeywords":["rebuke","the","wild","beasts","reed","let","crowd","bulls","with","heifers","nations","that","they","who","have","been","proved","silver","may","not","shut","out","scatter","thou","wish","for","wars"]},{"verseId":"brenton_psalms_67_32","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":32,"text":"Ambassadors shall arrive out of Egypt; Ethiopia shall hasten her hand readily to God.","searchKeywords":["ambassadors","shall","arrive","out","egypt","ethiopia","hasten","her","hand","readily","god"]},{"verseId":"brenton_psalms_67_33","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":33,"text":"Sing to God, ye kingdoms of the earth; sing psalms to the Lord. Pause.","searchKeywords":["sing","god","kingdoms","the","earth","psalms","lord","pause"]},{"verseId":"brenton_psalms_67_34","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":34,"text":"Sing to God that rides on the heaven of heaven, eastward: lo, he will utter a mighty sound with his voice.","searchKeywords":["sing","god","that","rides","the","heaven","eastward","will","utter","mighty","sound","with","his","voice"]},{"verseId":"brenton_psalms_67_35","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":35,"text":"Give ye glory to God: his excellency is over Israel, and his power is in the clouds.","searchKeywords":["give","glory","god","his","excellency","over","israel","and","power","the","clouds"]},{"verseId":"brenton_psalms_67_36","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":67,"verse":36,"text":"God is wonderful in his holy , the God of Israel: he will give power and strength to his people: blessed be God.","searchKeywords":["god","wonderful","his","holy","the","israel","will","give","power","and","strength","people","blessed"]}]