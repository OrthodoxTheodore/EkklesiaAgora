[{"verseId":"brenton_psalms_117_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":1,"text":"Alleluia. good: for his mercy for ever.","searchKeywords":["alleluia","good","for","his","mercy","ever"]},{"verseId":"brenton_psalms_117_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":2,"text":"Let now the house of Israel say, that good: for his mercy for ever.","searchKeywords":["let","now","the","house","israel","say","that","good","for","his","mercy","ever"]},{"verseId":"brenton_psalms_117_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":3,"text":"Let now the house of Aaron say, that good: for his mercy for ever.","searchKeywords":["let","now","the","house","aaron","say","that","good","for","his","mercy","ever"]},{"verseId":"brenton_psalms_117_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":4,"text":"Let now all that fear the Lord say, that good: for his mercy for ever.","searchKeywords":["let","now","all","that","fear","the","lord","say","good","for","his","mercy","ever"]},{"verseId":"brenton_psalms_117_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":5,"text":"I called on the Lord out of affliction: and he hearkened to me, into a wide place.","searchKeywords":["called","the","lord","out","affliction","and","hearkened","into","wide","place"]},{"verseId":"brenton_psalms_117_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":6,"text":"The Lord is my helper; and I will not fear what man shall do to me.","searchKeywords":["the","lord","helper","and","will","not","fear","what","man","shall"]},{"verseId":"brenton_psalms_117_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":7,"text":"The Lord is my helper; and I shall see upon mine enemies.","searchKeywords":["the","lord","helper","and","shall","see","upon","mine","enemies"]},{"verseId":"brenton_psalms_117_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":8,"text":"better to trust in the Lord than to trust in man.","searchKeywords":["better","trust","the","lord","than","man"]},{"verseId":"brenton_psalms_117_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":9,"text":"better to hope in the Lord, than to hope in princes.","searchKeywords":["better","hope","the","lord","than","princes"]},{"verseId":"brenton_psalms_117_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":10,"text":"All nations compassed me about: but in the name of the Lord I repulsed them.","searchKeywords":["all","nations","compassed","about","but","the","name","lord","repulsed","them"]},{"verseId":"brenton_psalms_117_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":11,"text":"They completely compassed me about: but in the name of the Lord I repulsed them.","searchKeywords":["they","completely","compassed","about","but","the","name","lord","repulsed","them"]},{"verseId":"brenton_psalms_117_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":12,"text":"They compassed me about as bees a honeycomb, and they burst into flame as fire among thorns: but in the name of the Lord I repulsed them.","searchKeywords":["they","compassed","about","bees","honeycomb","and","burst","into","flame","fire","among","thorns","but","the","name","lord","repulsed","them"]},{"verseId":"brenton_psalms_117_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":13,"text":"I was thrust, and sorely shaken, that I might fall: but the Lord helped me.","searchKeywords":["was","thrust","and","sorely","shaken","that","might","fall","but","the","lord","helped"]},{"verseId":"brenton_psalms_117_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":14,"text":"The Lord is my strength and my song, and is become my salvation.","searchKeywords":["the","lord","strength","and","song","become","salvation"]},{"verseId":"brenton_psalms_117_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":15,"text":"The voice of exultation and salvation is in the tabernacles of the righteous: the right hand of the Lord has wrought mightily.","searchKeywords":["the","voice","exultation","and","salvation","tabernacles","righteous","right","hand","lord","has","wrought","mightily"]},{"verseId":"brenton_psalms_117_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":16,"text":"The right hand of the Lord has exalted me: the right hand of the Lord has wrought powerfully.","searchKeywords":["the","right","hand","lord","has","exalted","wrought","powerfully"]},{"verseId":"brenton_psalms_117_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":17,"text":"I shall not die, but live, and recount the works of the Lord.","searchKeywords":["shall","not","die","but","live","and","recount","the","works","lord"]},{"verseId":"brenton_psalms_117_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":18,"text":"The Lord has chastened me sore: but he has not given me up to death.","searchKeywords":["the","lord","has","chastened","sore","but","not","given","death"]},{"verseId":"brenton_psalms_117_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":19,"text":"Open to me the gates of righteousness: I will go into them, and give praise to the Lord.","searchKeywords":["open","the","gates","righteousness","will","into","them","and","give","praise","lord"]},{"verseId":"brenton_psalms_117_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":20,"text":"This is the gate of the Lord: the righteous shall enter by it.","searchKeywords":["this","the","gate","lord","righteous","shall","enter"]},{"verseId":"brenton_psalms_117_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":21,"text":"I will give thanks to thee; because thou hast heard me, and art become my salvation.","searchKeywords":["will","give","thanks","thee","because","thou","hast","heard","and","art","become","salvation"]},{"verseId":"brenton_psalms_117_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":22,"text":"The stone which the builders rejected, the same is become the head of the corner.","searchKeywords":["the","stone","which","builders","rejected","same","become","head","corner"]},{"verseId":"brenton_psalms_117_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":23,"text":"This has been done of the Lord; and it is wonderful in our eyes.","searchKeywords":["this","has","been","done","the","lord","and","wonderful","our","eyes"]},{"verseId":"brenton_psalms_117_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":24,"text":"This is the day which the Lord has made: let us exult and rejoice in it.","searchKeywords":["this","the","day","which","lord","has","made","let","exult","and","rejoice"]},{"verseId":"brenton_psalms_117_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":25,"text":"O Lord, save now: O Lord, send now prosperity.","searchKeywords":["lord","save","now","send","prosperity"]},{"verseId":"brenton_psalms_117_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":26,"text":"Blessed is he that comes in the name of the Lord: we have blessed you out of the house of the Lord.","searchKeywords":["blessed","that","comes","the","name","lord","have","you","out","house"]},{"verseId":"brenton_psalms_117_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":27,"text":"God is the Lord, and he has shined upon us: celebrate the feast with thick even to the horns of the altar.","searchKeywords":["god","the","lord","and","has","shined","upon","celebrate","feast","with","thick","even","horns","altar"]},{"verseId":"brenton_psalms_117_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":28,"text":"Thou art my God, and I will give thee thanks: thou art my God, and I will exalt thee. I will give thanks to thee, for thou hast heard me, and art become my salvation.","searchKeywords":["thou","art","god","and","will","give","thee","thanks","exalt","for","hast","heard","become","salvation"]},{"verseId":"brenton_psalms_117_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":117,"verse":29,"text":"Give thanks to the Lord; for he is good: for his mercy for ever.","searchKeywords":["give","thanks","the","lord","for","good","his","mercy","ever"]}]