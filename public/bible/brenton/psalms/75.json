[{"verseId":"brenton_psalms_75_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":75,"verse":1,"text":"For the end, among the Hymns, a Psalm for Asaph; a Song for the Assyrian.","searchKeywords":["for","the","end","among","hymns","psalm","asaph","song","assyrian"]},{"verseId":"brenton_psalms_75_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":75,"verse":2,"text":"God is known in Judea; his name is great in Israel.","searchKeywords":["god","known","judea","his","name","great","israel"]},{"verseId":"brenton_psalms_75_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":75,"verse":3,"text":"And his place has been in peace, and his dwelling-place in Sion.","searchKeywords":["and","his","place","has","been","peace","dwelling","sion"]},{"verseId":"brenton_psalms_75_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":75,"verse":4,"text":"There he broke the power of the bows, the shield, and the sword, and the battle. Pause.","searchKeywords":["there","broke","the","power","bows","shield","and","sword","battle","pause"]},{"verseId":"brenton_psalms_75_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":75,"verse":5,"text":"Thou dost wonderfully shine forth from the everlasting mountains.","searchKeywords":["thou","dost","wonderfully","shine","forth","from","the","everlasting","mountains"]},{"verseId":"brenton_psalms_75_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":75,"verse":6,"text":"All the simple ones in heart were troubled; all the men of wealth have slept their sleep, and have found nothing in their hands.","searchKeywords":["all","the","simple","ones","heart","were","troubled","men","wealth","have","slept","their","sleep","and","found","nothing","hands"]},{"verseId":"brenton_psalms_75_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":75,"verse":7,"text":"At thy rebuke, O God of Jacob, the riders on horses slumbered.","searchKeywords":["thy","rebuke","god","jacob","the","riders","horses","slumbered"]},{"verseId":"brenton_psalms_75_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":75,"verse":8,"text":"Thou art terrible; and who shall withstand thee, because of thine anger?","searchKeywords":["thou","art","terrible","and","who","shall","withstand","thee","because","thine","anger"]},{"verseId":"brenton_psalms_75_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":75,"verse":9,"text":"Thou didst cause judgment to be heard from heaven; the earth feared, and was still,","searchKeywords":["thou","didst","cause","judgment","heard","from","heaven","the","earth","feared","and","was","still"]},{"verseId":"brenton_psalms_75_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":75,"verse":10,"text":"when God arose to judgment, to save all the meek in heart. Pause.","searchKeywords":["when","god","arose","judgment","save","all","the","meek","heart","pause"]},{"verseId":"brenton_psalms_75_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":75,"verse":11,"text":"For the inward thought of man shall give thanks to thee: and the memorial of his inward thought shall keep a feast to thee.","searchKeywords":["for","the","inward","thought","man","shall","give","thanks","thee","and","memorial","his","keep","feast"]},{"verseId":"brenton_psalms_75_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":75,"verse":12,"text":"Vow, and pay to the Lord our God; all that are round about him shall bring gifts, to him that is terrible,","searchKeywords":["vow","and","pay","the","lord","our","god","all","that","are","round","about","him","shall","bring","gifts","terrible"]},{"verseId":"brenton_psalms_75_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":75,"verse":13,"text":"and that takes away the spirits of princes; to him that is terrible among the kings of the earth.","searchKeywords":["and","that","takes","away","the","spirits","princes","him","terrible","among","kings","earth"]}]