[{"verseId":"brenton_psalms_146_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":146,"verse":1,"text":"Alleluia, of Aggæus and Zacharias.","searchKeywords":["alleluia","agg","and","zacharias"]},{"verseId":"brenton_psalms_146_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":146,"verse":2,"text":"The Lord builds up Jerusalem; and he will gather together the dispersed of Israel.","searchKeywords":["the","lord","builds","jerusalem","and","will","gather","together","dispersed","israel"]},{"verseId":"brenton_psalms_146_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":146,"verse":3,"text":"He heals the broken in heart, and binds up their wounds.","searchKeywords":["heals","the","broken","heart","and","binds","their","wounds"]},{"verseId":"brenton_psalms_146_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":146,"verse":4,"text":"He numbers the multitudes of stars; and calls them all by names.","searchKeywords":["numbers","the","multitudes","stars","and","calls","them","all","names"]},{"verseId":"brenton_psalms_146_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":146,"verse":5,"text":"Great is our Lord, and great is his strength; and his understanding is infinite.","searchKeywords":["great","our","lord","and","his","strength","understanding","infinite"]},{"verseId":"brenton_psalms_146_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":146,"verse":6,"text":"The Lord lifts up the meek; but brings sinners down to the ground.","searchKeywords":["the","lord","lifts","meek","but","brings","sinners","down","ground"]},{"verseId":"brenton_psalms_146_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":146,"verse":7,"text":"Begin with thanksgiving to the Lord; sing praises on the harp to our God:","searchKeywords":["begin","with","thanksgiving","the","lord","sing","praises","harp","our","god"]},{"verseId":"brenton_psalms_146_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":146,"verse":8,"text":"who covers the heaven with clouds, who prepares rain for the earth, who causes grass to spring up on the mountains, [and green herb for the service of men;]","searchKeywords":["who","covers","the","heaven","with","clouds","prepares","rain","for","earth","causes","grass","spring","mountains","and","green","herb","service","men"]},{"verseId":"brenton_psalms_146_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":146,"verse":9,"text":"and gives to cattle their food, and to the young ravens that call upon him.","searchKeywords":["and","gives","cattle","their","food","the","young","ravens","that","call","upon","him"]},{"verseId":"brenton_psalms_146_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":146,"verse":10,"text":"He will not take pleasure in the strength of a horse; neither is he well-pleased with the legs of a man.","searchKeywords":["will","not","take","pleasure","the","strength","horse","neither","well","pleased","with","legs","man"]},{"verseId":"brenton_psalms_146_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":146,"verse":11,"text":"The Lord takes pleasure in them that fear him, and in all that hope in his mercy.","searchKeywords":["the","lord","takes","pleasure","them","that","fear","him","and","all","hope","his","mercy"]}]