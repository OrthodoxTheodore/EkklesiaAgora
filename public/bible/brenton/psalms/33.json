[{"verseId":"brenton_psalms_33_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":1,"text":"of David, when he changed his countenance before Abimelech; and he let him go, and he departed.","searchKeywords":["david","when","changed","his","countenance","before","abimelech","and","let","him","departed"]},{"verseId":"brenton_psalms_33_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":2,"text":"I will bless the Lord at all times: his praise shall be continually in my mouth.","searchKeywords":["will","bless","the","lord","all","times","his","praise","shall","continually","mouth"]},{"verseId":"brenton_psalms_33_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":3,"text":"My soul shall boast herself in the Lord: let the meek hear, and rejoice.","searchKeywords":["soul","shall","boast","herself","the","lord","let","meek","hear","and","rejoice"]},{"verseId":"brenton_psalms_33_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":4,"text":"Magnify ye the Lord with me, and let us exalt his name together.","searchKeywords":["magnify","the","lord","with","and","let","exalt","his","name","together"]},{"verseId":"brenton_psalms_33_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":5,"text":"I sought the Lord diligently, and he hearkened to me, and delivered me from all my sojournings.","searchKeywords":["sought","the","lord","diligently","and","hearkened","delivered","from","all","sojournings"]},{"verseId":"brenton_psalms_33_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":6,"text":"Draw near to him, and be enlightened: and your faces shall not be ashamed.","searchKeywords":["draw","near","him","and","enlightened","your","faces","shall","not","ashamed"]},{"verseId":"brenton_psalms_33_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":7,"text":"This poor man cried, and the Lord hearkened to him, and delivered him out of all his afflictions.","searchKeywords":["this","poor","man","cried","and","the","lord","hearkened","him","delivered","out","all","his","afflictions"]},{"verseId":"brenton_psalms_33_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":8,"text":"The angel of the Lord will encamp round about them that fear him, and will deliver them.","searchKeywords":["the","angel","lord","will","encamp","round","about","them","that","fear","him","and","deliver"]},{"verseId":"brenton_psalms_33_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":9,"text":"Taste and see that the Lord is good: blessed is the man who hopes in him.","searchKeywords":["taste","and","see","that","the","lord","good","blessed","man","who","hopes","him"]},{"verseId":"brenton_psalms_33_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":10,"text":"Fear the Lord, all ye his saints: for there is no want to them that fear him.","searchKeywords":["fear","the","lord","all","his","saints","for","there","want","them","that","him"]},{"verseId":"brenton_psalms_33_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":11,"text":"The rich have become poor and hungry: but they that seek the Lord diligently shall not want any good thing. Pause.","searchKeywords":["the","rich","have","become","poor","and","hungry","but","they","that","seek","lord","diligently","shall","not","want","any","good","thing","pause"]},{"verseId":"brenton_psalms_33_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":12,"text":"Come, ye children, hear me: I will teach you the fear of the Lord.","searchKeywords":["come","children","hear","will","teach","you","the","fear","lord"]},{"verseId":"brenton_psalms_33_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":13,"text":"What man is there that desires life, loving to see good days?","searchKeywords":["what","man","there","that","desires","life","loving","see","good","days"]},{"verseId":"brenton_psalms_33_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":14,"text":"Keep thy tongue from evil, and thy lips from speaking guile.","searchKeywords":["keep","thy","tongue","from","evil","and","lips","speaking","guile"]},{"verseId":"brenton_psalms_33_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":15,"text":"Turn away from evil, and do good; seek peace, and pursue it.","searchKeywords":["turn","away","from","evil","and","good","seek","peace","pursue"]},{"verseId":"brenton_psalms_33_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":16,"text":"The eyes of the Lord are over the righteous, and his ears to their prayer:","searchKeywords":["the","eyes","lord","are","over","righteous","and","his","ears","their","prayer"]},{"verseId":"brenton_psalms_33_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":17,"text":"but the face of the Lord is against them that do evil, to destroy their memorial from the earth. The righteous cried, and the Lord hearkened to them,","searchKeywords":["but","the","face","lord","against","them","that","evil","destroy","their","memorial","from","earth","righteous","cried","and","hearkened"]},{"verseId":"brenton_psalms_33_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":18,"text":"and delivered them out of all their afflictions.","searchKeywords":["and","delivered","them","out","all","their","afflictions"]},{"verseId":"brenton_psalms_33_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":19,"text":"The Lord is near to them that are of a contrite heart; and will save the lowly in spirit.","searchKeywords":["the","lord","near","them","that","are","contrite","heart","and","will","save","lowly","spirit"]},{"verseId":"brenton_psalms_33_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":20,"text":"Many are the afflictions of the righteous: but out of them all the Lord will deliver them.","searchKeywords":["many","are","the","afflictions","righteous","but","out","them","all","lord","will","deliver"]},{"verseId":"brenton_psalms_33_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":21,"text":"He keeps all their bones: not one of them shall be broken.","searchKeywords":["keeps","all","their","bones","not","one","them","shall","broken"]},{"verseId":"brenton_psalms_33_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":22,"text":"The death of sinners is evil: and they that hate righteousness will go wrong.","searchKeywords":["the","death","sinners","evil","and","they","that","hate","righteousness","will","wrong"]},{"verseId":"brenton_psalms_33_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":33,"verse":23,"text":"The Lord will redeem the souls of his servants: and none of those that hope in him shall go wrong.","searchKeywords":["the","lord","will","redeem","souls","his","servants","and","none","those","that","hope","him","shall","wrong"]}]