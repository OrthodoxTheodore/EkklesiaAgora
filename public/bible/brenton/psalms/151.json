[{"verseId":"brenton_psalms_151_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":151,"verse":1,"text":"This Psalm is a genuine one of David, though supernumerary, when he fought in single combat with Goliad.","searchKeywords":["this","psalm","genuine","one","david","though","supernumerary","when","fought","single","combat","with","goliad"]},{"verseId":"brenton_psalms_151_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":151,"verse":2,"text":"My hands formed a musical instrument, and my fingers tuned a psaltery.","searchKeywords":["hands","formed","musical","instrument","and","fingers","tuned","psaltery"]},{"verseId":"brenton_psalms_151_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":151,"verse":3,"text":"And who shall tell my Lord? the Lord himself, he himself hears.","searchKeywords":["and","who","shall","tell","lord","the","himself","hears"]},{"verseId":"brenton_psalms_151_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":151,"verse":4,"text":"He sent forth his angel, and took me from my father's sheep, and he anointed me with the oil of his anointing.","searchKeywords":["sent","forth","his","angel","and","took","from","father","sheep","anointed","with","the","oil","anointing"]},{"verseId":"brenton_psalms_151_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":151,"verse":5,"text":"My brothers were handsome and tall; but the Lord did not take pleasure in them.","searchKeywords":["brothers","were","handsome","and","tall","but","the","lord","did","not","take","pleasure","them"]},{"verseId":"brenton_psalms_151_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":151,"verse":6,"text":"I went forth to meet the Philistine; and he cursed me by his idols.","searchKeywords":["went","forth","meet","the","philistine","and","cursed","his","idols"]},{"verseId":"brenton_psalms_151_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":151,"verse":7,"text":"But I drew his own sword, and beheaded him, and removed reproach from the children of Israel.","searchKeywords":["but","drew","his","own","sword","and","beheaded","him","removed","reproach","from","the","children","israel"]}]