[{"verseId":"brenton_psalms_76_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":1,"text":"For the end, for Idithun, a Psalm of Asaph.","searchKeywords":["for","the","end","idithun","psalm","asaph"]},{"verseId":"brenton_psalms_76_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":2,"text":"I cried to the Lord with my voice, yea, my voice to God; and he gave heed to me.","searchKeywords":["cried","the","lord","with","voice","yea","god","and","gave","heed"]},{"verseId":"brenton_psalms_76_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":3,"text":"In the day of mine affliction I earnestly sought the Lord; with my hands by night before him, and I was not deceived; my soul refused to be comforted.","searchKeywords":["the","day","mine","affliction","earnestly","sought","lord","with","hands","night","before","him","and","was","not","deceived","soul","refused","comforted"]},{"verseId":"brenton_psalms_76_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":4,"text":"I remembered God, and rejoiced; I poured out my complaint, and my soul fainted. Pause.","searchKeywords":["remembered","god","and","rejoiced","poured","out","complaint","soul","fainted","pause"]},{"verseId":"brenton_psalms_76_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":5,"text":"All mine enemies set a watch : I was troubled, and spoke not.","searchKeywords":["all","mine","enemies","set","watch","was","troubled","and","spoke","not"]},{"verseId":"brenton_psalms_76_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":6,"text":"I considered the days of old, and remembered ancient years.","searchKeywords":["considered","the","days","old","and","remembered","ancient","years"]},{"verseId":"brenton_psalms_76_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":7,"text":"And I meditated; I communed with my heart by night, and diligently searched my spirit, ,","searchKeywords":["and","meditated","communed","with","heart","night","diligently","searched","spirit"]},{"verseId":"brenton_psalms_76_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":8,"text":"Will the Lord cast off for ever? and will he be well pleased no more?","searchKeywords":["will","the","lord","cast","off","for","ever","and","well","pleased","more"]},{"verseId":"brenton_psalms_76_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":9,"text":"Will he cut off his mercy for ever, even for ever and ever?","searchKeywords":["will","cut","off","his","mercy","for","ever","even","and"]},{"verseId":"brenton_psalms_76_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":10,"text":"Will God forget to pity? or will he shut up his compassions in his wrath? Pause.","searchKeywords":["will","god","forget","pity","shut","his","compassions","wrath","pause"]},{"verseId":"brenton_psalms_76_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":11,"text":"And I said, Now I have begun; this is the change of the right hand of the Most High.","searchKeywords":["and","said","now","have","begun","this","the","change","right","hand","most","high"]},{"verseId":"brenton_psalms_76_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":12,"text":"I remembered the works of the Lord; for I will remember thy wonders from the beginning.","searchKeywords":["remembered","the","works","lord","for","will","remember","thy","wonders","from","beginning"]},{"verseId":"brenton_psalms_76_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":13,"text":"And I will meditate on all thy works, and will consider thy doings.","searchKeywords":["and","will","meditate","all","thy","works","consider","doings"]},{"verseId":"brenton_psalms_76_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":14,"text":"O God, thy way is in the sanctuary; who is a great God as our God?","searchKeywords":["god","thy","way","the","sanctuary","who","great","our"]},{"verseId":"brenton_psalms_76_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":15,"text":"Thou art the God that doest wonders; thou hast made known thy power among the nations.","searchKeywords":["thou","art","the","god","that","doest","wonders","hast","made","known","thy","power","among","nations"]},{"verseId":"brenton_psalms_76_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":16,"text":"Thou hast with thine arm redeemed thy people, the sons of Jacob and Joseph. Pause.","searchKeywords":["thou","hast","with","thine","arm","redeemed","thy","people","the","sons","jacob","and","joseph","pause"]},{"verseId":"brenton_psalms_76_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":17,"text":"The waters saw thee, O God, the waters saw thee, and feared; and the depths were troubled.","searchKeywords":["the","waters","saw","thee","god","and","feared","depths","were","troubled"]},{"verseId":"brenton_psalms_76_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":18,"text":"an abundant sound of waters: the clouds uttered a voice; for thine arrows went abroad.","searchKeywords":["abundant","sound","waters","the","clouds","uttered","voice","for","thine","arrows","went","abroad"]},{"verseId":"brenton_psalms_76_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":19,"text":"The voice of thy thunder was abroad, and around thy lightnings appeared to the world; the earth trembled and quaked.","searchKeywords":["the","voice","thy","thunder","was","abroad","and","around","lightnings","appeared","world","earth","trembled","quaked"]},{"verseId":"brenton_psalms_76_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":20,"text":"Thy way is in the sea, and thy paths in many waters, and thy footsteps cannot be known.","searchKeywords":["thy","way","the","sea","and","paths","many","waters","footsteps","cannot","known"]},{"verseId":"brenton_psalms_76_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":76,"verse":21,"text":"Thou didst guide thy people as sheep by the hand of Moses and Aaron.","searchKeywords":["thou","didst","guide","thy","people","sheep","the","hand","moses","and","aaron"]}]