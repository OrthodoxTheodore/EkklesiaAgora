[{"verseId":"brenton_psalms_34_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":1,"text":"of David.","searchKeywords":["david"]},{"verseId":"brenton_psalms_34_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":2,"text":"Take hold of shield and buckler, and arise for my help.","searchKeywords":["take","hold","shield","and","buckler","arise","for","help"]},{"verseId":"brenton_psalms_34_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":3,"text":"Bring forth a sword, and stop against them that persecute me: say to my soul, I am thy salvation.","searchKeywords":["bring","forth","sword","and","stop","against","them","that","persecute","say","soul","thy","salvation"]},{"verseId":"brenton_psalms_34_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":4,"text":"Let them that seek my soul be ashamed and confounded: let them that devise evils against me be turned back and put to shame.","searchKeywords":["let","them","that","seek","soul","ashamed","and","confounded","devise","evils","against","turned","back","put","shame"]},{"verseId":"brenton_psalms_34_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":5,"text":"Let them be as dust before the wind, and an angel of the Lord afflicting them.","searchKeywords":["let","them","dust","before","the","wind","and","angel","lord","afflicting"]},{"verseId":"brenton_psalms_34_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":6,"text":"Let their way be dark and slippery, and an angel of the Lord persecuting them.","searchKeywords":["let","their","way","dark","and","slippery","angel","the","lord","persecuting","them"]},{"verseId":"brenton_psalms_34_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":7,"text":"For without cause they have hid for me their destructive snare: without a cause they have reproached my soul.","searchKeywords":["for","without","cause","they","have","hid","their","destructive","snare","reproached","soul"]},{"verseId":"brenton_psalms_34_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":8,"text":"Let a snare which they know not come upon them: and the gin which they hid take them; and let them fall into the very same snare.","searchKeywords":["let","snare","which","they","know","not","come","upon","them","and","the","gin","hid","take","fall","into","very","same"]},{"verseId":"brenton_psalms_34_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":9,"text":"But my soul shall exult in the Lord: it shall delight in his salvation.","searchKeywords":["but","soul","shall","exult","the","lord","delight","his","salvation"]},{"verseId":"brenton_psalms_34_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":10,"text":"All my bones shall say, O Lord, who is like to thee? delivering the poor out of the hand of them that are stronger than he, yea, the poor and needy one from them that spoil him.","searchKeywords":["all","bones","shall","say","lord","who","like","thee","delivering","the","poor","out","hand","them","that","are","stronger","than","yea","and","needy","one","from","spoil","him"]},{"verseId":"brenton_psalms_34_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":11,"text":"Unjust witnesses arose, and asked me of things I knew not.","searchKeywords":["unjust","witnesses","arose","and","asked","things","knew","not"]},{"verseId":"brenton_psalms_34_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":12,"text":"They rewarded me evil for good, and bereavement to my soul.","searchKeywords":["they","rewarded","evil","for","good","and","bereavement","soul"]},{"verseId":"brenton_psalms_34_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":13,"text":"But I, when they troubled me, put on sackcloth, and humbled my soul with fasting: and my prayer shall return to my bosom.","searchKeywords":["but","when","they","troubled","put","sackcloth","and","humbled","soul","with","fasting","prayer","shall","return","bosom"]},{"verseId":"brenton_psalms_34_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":14,"text":"I behaved agreeably towards them as our neighbour brother: I humbled myself as one mourning and sad of countenance.","searchKeywords":["behaved","agreeably","towards","them","our","neighbour","brother","humbled","myself","one","mourning","and","sad","countenance"]},{"verseId":"brenton_psalms_34_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":15,"text":"Yet they rejoiced against me, and plagues were plentifully brought against me, and I knew not: they were scattered, but repented not.","searchKeywords":["yet","they","rejoiced","against","and","plagues","were","plentifully","brought","knew","not","scattered","but","repented"]},{"verseId":"brenton_psalms_34_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":16,"text":"They tempted me, they sneered at me most contemptuously, they gnashed their teeth upon me.","searchKeywords":["they","tempted","sneered","most","contemptuously","gnashed","their","teeth","upon"]},{"verseId":"brenton_psalms_34_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":17,"text":"O Lord, when wilt thou look upon me? Deliver my soul from their mischief, mine only-begotten one from the lions.","searchKeywords":["lord","when","wilt","thou","look","upon","deliver","soul","from","their","mischief","mine","only","begotten","one","the","lions"]},{"verseId":"brenton_psalms_34_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":18,"text":"I will give thanks to thee even in a great congregation: in an abundant people I will praise thee.","searchKeywords":["will","give","thanks","thee","even","great","congregation","abundant","people","praise"]},{"verseId":"brenton_psalms_34_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":19,"text":"Let not them that are mine enemies without a cause rejoice against me; who hate me for nothing, and wink with their eyes.","searchKeywords":["let","not","them","that","are","mine","enemies","without","cause","rejoice","against","who","hate","for","nothing","and","wink","with","their","eyes"]},{"verseId":"brenton_psalms_34_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":20,"text":"For to me they spoke peaceably, but imagined deceits in anger.","searchKeywords":["for","they","spoke","peaceably","but","imagined","deceits","anger"]},{"verseId":"brenton_psalms_34_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":21,"text":"And they opened wide their mouth upon me; they said, Aha, aha, our eyes have seen .","searchKeywords":["and","they","opened","wide","their","mouth","upon","said","aha","our","eyes","have","seen"]},{"verseId":"brenton_psalms_34_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":22,"text":"Thou hast seen , O Lord: keep not silence: O Lord, withdraw not from me.","searchKeywords":["thou","hast","seen","lord","keep","not","silence","withdraw","from"]},{"verseId":"brenton_psalms_34_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":23,"text":"Awake, O Lord, and attend to my judgment, to my cause, my God and my Lord.","searchKeywords":["awake","lord","and","attend","judgment","cause","god"]},{"verseId":"brenton_psalms_34_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":24,"text":"Judge me, O Lord, according to thy righteousness, O Lord my God; and let them not rejoice against me.","searchKeywords":["judge","lord","according","thy","righteousness","god","and","let","them","not","rejoice","against"]},{"verseId":"brenton_psalms_34_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":25,"text":"Let them not say in their hearts, Aha, aha, to our soul: neither let them say, We have devoured him.","searchKeywords":["let","them","not","say","their","hearts","aha","our","soul","neither","have","devoured","him"]},{"verseId":"brenton_psalms_34_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":26,"text":"Let them be confounded and ashamed together that rejoice at my afflictions: let them be clothed with shame and confusion that speak great swelling words against me.","searchKeywords":["let","them","confounded","and","ashamed","together","that","rejoice","afflictions","clothed","with","shame","confusion","speak","great","swelling","words","against"]},{"verseId":"brenton_psalms_34_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":27,"text":"Let them that rejoice in my righteousness exult and be glad: and let them say continually, The Lord be magnified, who desire the peace of his servant.","searchKeywords":["let","them","that","rejoice","righteousness","exult","and","glad","say","continually","the","lord","magnified","who","desire","peace","his","servant"]},{"verseId":"brenton_psalms_34_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":34,"verse":28,"text":"And my tongue shall meditate on thy righteousness, on thy praise all the day.","searchKeywords":["and","tongue","shall","meditate","thy","righteousness","praise","all","the","day"]}]