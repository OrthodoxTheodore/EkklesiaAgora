[{"verseId":"brenton_psalms_82_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":1,"text":"A Song of a Psalm for Asaph.","searchKeywords":["song","psalm","for","asaph"]},{"verseId":"brenton_psalms_82_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":2,"text":"O God, who shall be compared to thee? be not silent, neither be still, O God.","searchKeywords":["god","who","shall","compared","thee","not","silent","neither","still"]},{"verseId":"brenton_psalms_82_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":3,"text":"For behold, thine enemies have made a noise; and they that hate thee have lifted up the head.","searchKeywords":["for","behold","thine","enemies","have","made","noise","and","they","that","hate","thee","lifted","the","head"]},{"verseId":"brenton_psalms_82_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":4,"text":"Against thy people they have craftily imagined a device, and have taken counsel against thy saints.","searchKeywords":["against","thy","people","they","have","craftily","imagined","device","and","taken","counsel","saints"]},{"verseId":"brenton_psalms_82_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":5,"text":"They have said, Come, and let us utterly destroy them out of the nation; and let the name of Israel be remembered no more at all.","searchKeywords":["they","have","said","come","and","let","utterly","destroy","them","out","the","nation","name","israel","remembered","more","all"]},{"verseId":"brenton_psalms_82_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":6,"text":"For they have taken counsel together with one consent: they have made a confederacy against thee;","searchKeywords":["for","they","have","taken","counsel","together","with","one","consent","made","confederacy","against","thee"]},{"verseId":"brenton_psalms_82_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":7,"text":"even the tents of the Idumeans, and the Ismaelites; Moab, and the Agarenes;","searchKeywords":["even","the","tents","idumeans","and","ismaelites","moab","agarenes"]},{"verseId":"brenton_psalms_82_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":8,"text":"Gebal, and Ammon, and Amalec; the Philistines also, with them that dwell at Tyre.","searchKeywords":["gebal","and","ammon","amalec","the","philistines","also","with","them","that","dwell","tyre"]},{"verseId":"brenton_psalms_82_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":9,"text":"Yea, Assur too is come with them: they have become a help to the children of Lot. Pause.","searchKeywords":["yea","assur","too","come","with","them","they","have","become","help","the","children","lot","pause"]},{"verseId":"brenton_psalms_82_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":10,"text":"Do thou to them as to Madiam, and to Sisera; as to Jabin at the brook of Kison.","searchKeywords":["thou","them","madiam","and","sisera","jabin","the","brook","kison"]},{"verseId":"brenton_psalms_82_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":11,"text":"They were utterly destroyed at Aendor: they became as dung for the earth.","searchKeywords":["they","were","utterly","destroyed","aendor","became","dung","for","the","earth"]},{"verseId":"brenton_psalms_82_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":12,"text":"Make their princes as Oreb and Zeb, and Zebee and Salmana; all their princes:","searchKeywords":["make","their","princes","oreb","and","zeb","zebee","salmana","all"]},{"verseId":"brenton_psalms_82_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":13,"text":"who said, Let us take to ourselves the altar of God as an inheritance.","searchKeywords":["who","said","let","take","ourselves","the","altar","god","inheritance"]},{"verseId":"brenton_psalms_82_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":14,"text":"O my God, make them as a wheel; as stubble before the face of the wind.","searchKeywords":["god","make","them","wheel","stubble","before","the","face","wind"]},{"verseId":"brenton_psalms_82_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":15,"text":"As fire which shall burn up a wood, as the flame may consume the mountains;","searchKeywords":["fire","which","shall","burn","wood","the","flame","may","consume","mountains"]},{"verseId":"brenton_psalms_82_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":16,"text":"so shalt thou persecute them with thy tempest, and trouble them in thine anger.","searchKeywords":["shalt","thou","persecute","them","with","thy","tempest","and","trouble","thine","anger"]},{"verseId":"brenton_psalms_82_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":17,"text":"Fill their faces with dishonour; so shall they seek thy name, O Lord.","searchKeywords":["fill","their","faces","with","dishonour","shall","they","seek","thy","name","lord"]},{"verseId":"brenton_psalms_82_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":18,"text":"Let them be ashamed and troubled for evermore; yea, let them be confounded and destroyed.","searchKeywords":["let","them","ashamed","and","troubled","for","evermore","yea","confounded","destroyed"]},{"verseId":"brenton_psalms_82_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":82,"verse":19,"text":"And let them know that thy name is Lord; that thou alone art Most High over all the earth.","searchKeywords":["and","let","them","know","that","thy","name","lord","thou","alone","art","most","high","over","all","the","earth"]}]