[{"verseId":"brenton_psalms_4_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":4,"verse":1,"text":"For the end, a Song of David among Psalms.","searchKeywords":["for","the","end","song","david","among","psalms"]},{"verseId":"brenton_psalms_4_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":4,"verse":2,"text":"When I called upon , the God of my righteousness heard me: thou hast made room for me in tribulation; pity me, and hearken to my prayer.","searchKeywords":["when","called","upon","the","god","righteousness","heard","thou","hast","made","room","for","tribulation","pity","and","hearken","prayer"]},{"verseId":"brenton_psalms_4_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":4,"verse":3,"text":"O ye sons of men, how long slow of heart? wherefore do ye love vanity, and seek falsehood? Pause.","searchKeywords":["sons","men","how","long","slow","heart","wherefore","love","vanity","and","seek","falsehood","pause"]},{"verseId":"brenton_psalms_4_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":4,"verse":4,"text":"But know ye that the Lord has done wondrous things for his holy one: the Lord will hear me when I cry to him.","searchKeywords":["but","know","that","the","lord","has","done","wondrous","things","for","his","holy","one","will","hear","when","cry","him"]},{"verseId":"brenton_psalms_4_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":4,"verse":5,"text":"Be ye angry, and sin not; feel compunction upon your beds for what ye say in your hearts. Pause.","searchKeywords":["angry","and","sin","not","feel","compunction","upon","your","beds","for","what","say","hearts","pause"]},{"verseId":"brenton_psalms_4_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":4,"verse":6,"text":"Offer the sacrifice of righteousness, and trust in the Lord.","searchKeywords":["offer","the","sacrifice","righteousness","and","trust","lord"]},{"verseId":"brenton_psalms_4_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":4,"verse":7,"text":"Many say, Who will shew us good things? the light of thy countenance, O Lord, has been manifested towards us.","searchKeywords":["many","say","who","will","shew","good","things","the","light","thy","countenance","lord","has","been","manifested","towards"]},{"verseId":"brenton_psalms_4_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":4,"verse":8,"text":"Thou hast put gladness into my heart: they have been satisfied with the fruit of their corn and wine and oil.","searchKeywords":["thou","hast","put","gladness","into","heart","they","have","been","satisfied","with","the","fruit","their","corn","and","wine","oil"]},{"verseId":"brenton_psalms_4_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":4,"verse":9,"text":"I will both lie down in peace and sleep: for thou, Lord, only hast caused me to dwell securely.","searchKeywords":["will","both","lie","down","peace","and","sleep","for","thou","lord","only","hast","caused","dwell","securely"]}]