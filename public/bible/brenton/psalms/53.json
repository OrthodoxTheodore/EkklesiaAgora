[{"verseId":"brenton_psalms_53_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":53,"verse":1,"text":"For the end, among the Hymns of instruction by David,","searchKeywords":["for","the","end","among","hymns","instruction","david"]},{"verseId":"brenton_psalms_53_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":53,"verse":2,"text":"when the Ziphites came and said to Saul, Lo, is not David hid with us?","searchKeywords":["when","the","ziphites","came","and","said","saul","not","david","hid","with"]},{"verseId":"brenton_psalms_53_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":53,"verse":3,"text":"Save me, O God, by thy name, and judge me by thy might.","searchKeywords":["save","god","thy","name","and","judge","might"]},{"verseId":"brenton_psalms_53_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":53,"verse":4,"text":"O God, hear my prayer; hearken to the words of my mouth.","searchKeywords":["god","hear","prayer","hearken","the","words","mouth"]},{"verseId":"brenton_psalms_53_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":53,"verse":5,"text":"For strangers have risen up against me, and mighty men have sought my life: they have not set God before them. Pause.","searchKeywords":["for","strangers","have","risen","against","and","mighty","men","sought","life","they","not","set","god","before","them","pause"]},{"verseId":"brenton_psalms_53_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":53,"verse":6,"text":"For lo! God assists me; and the Lord is the helper of my soul.","searchKeywords":["for","god","assists","and","the","lord","helper","soul"]},{"verseId":"brenton_psalms_53_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":53,"verse":7,"text":"He shall return evil to mine enemies; utterly destroy them in thy truth.","searchKeywords":["shall","return","evil","mine","enemies","utterly","destroy","them","thy","truth"]},{"verseId":"brenton_psalms_53_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":53,"verse":8,"text":"I will willingly sacrifice to thee: I will give thanks to thy name, O Lord; for good.","searchKeywords":["will","willingly","sacrifice","thee","give","thanks","thy","name","lord","for","good"]},{"verseId":"brenton_psalms_53_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":53,"verse":9,"text":"For thou hast delivered me out of all affliction, and mine eye has seen upon mine enemies.","searchKeywords":["for","thou","hast","delivered","out","all","affliction","and","mine","eye","has","seen","upon","enemies"]}]