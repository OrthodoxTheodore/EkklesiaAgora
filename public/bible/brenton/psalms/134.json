[{"verseId":"brenton_psalms_134_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":1,"text":"Alleluia. servants,","searchKeywords":["alleluia","servants"]},{"verseId":"brenton_psalms_134_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":2,"text":"who stand in the house of the Lord, in the courts of the house of our God.","searchKeywords":["who","stand","the","house","lord","courts","our","god"]},{"verseId":"brenton_psalms_134_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":3,"text":"Praise ye the Lord; for the Lord is good: sing praises to his name; for good.","searchKeywords":["praise","the","lord","for","good","sing","praises","his","name"]},{"verseId":"brenton_psalms_134_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":4,"text":"For the Lord has chosen Jacob for himself, Israel for his peculiar treasure.","searchKeywords":["for","the","lord","has","chosen","jacob","himself","israel","his","peculiar","treasure"]},{"verseId":"brenton_psalms_134_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":5,"text":"For I know that the Lord is great, and our Lord is above all gods;","searchKeywords":["for","know","that","the","lord","great","and","our","above","all","gods"]},{"verseId":"brenton_psalms_134_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":6,"text":"all that the Lord willed, he did in heaven, and on the earth, in the sea, and in all deeps.","searchKeywords":["all","that","the","lord","willed","did","heaven","and","earth","sea","deeps"]},{"verseId":"brenton_psalms_134_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":7,"text":"Who brings up clouds from the extremity of the earth: he has made lightnings for the rain: he brings winds out of his treasures.","searchKeywords":["who","brings","clouds","from","the","extremity","earth","has","made","lightnings","for","rain","winds","out","his","treasures"]},{"verseId":"brenton_psalms_134_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":8,"text":"Who smote the first-born of Egypt, both of man and beast.","searchKeywords":["who","smote","the","first","born","egypt","both","man","and","beast"]},{"verseId":"brenton_psalms_134_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":9,"text":"He sent signs and wonders into the midst of thee, O Egypt, on Pharao, and on all his servants.","searchKeywords":["sent","signs","and","wonders","into","the","midst","thee","egypt","pharao","all","his","servants"]},{"verseId":"brenton_psalms_134_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":10,"text":"Who smote many nations, and slew mighty kings;","searchKeywords":["who","smote","many","nations","and","slew","mighty","kings"]},{"verseId":"brenton_psalms_134_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":11,"text":"Seon king of the Amorites, and Og king of Basan, and all the kingdoms of Chanaan:","searchKeywords":["seon","king","the","amorites","and","basan","all","kingdoms","chanaan"]},{"verseId":"brenton_psalms_134_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":12,"text":"and gave their land an inheritance, an inheritance to Israel his people.","searchKeywords":["and","gave","their","land","inheritance","israel","his","people"]},{"verseId":"brenton_psalms_134_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":13,"text":"O Lord, thy name for ever, and thy memorial to all generations.","searchKeywords":["lord","thy","name","for","ever","and","memorial","all","generations"]},{"verseId":"brenton_psalms_134_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":14,"text":"For the Lord shall judge his people, and comfort himself concerning his servants.","searchKeywords":["for","the","lord","shall","judge","his","people","and","comfort","himself","concerning","servants"]},{"verseId":"brenton_psalms_134_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":15,"text":"The idols of the heathen are silver and gold, the works of men's hands.","searchKeywords":["the","idols","heathen","are","silver","and","gold","works","men","hands"]},{"verseId":"brenton_psalms_134_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":16,"text":"They have a mouth, but they cannot speak; they have eyes, but they cannot see;","searchKeywords":["they","have","mouth","but","cannot","speak","eyes","see"]},{"verseId":"brenton_psalms_134_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":17,"text":"they have ears, but they cannot hear; for there is no breath in their mouth.","searchKeywords":["they","have","ears","but","cannot","hear","for","there","breath","their","mouth"]},{"verseId":"brenton_psalms_134_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":18,"text":"Let those who make them be made like to them; and all those who trust in them.","searchKeywords":["let","those","who","make","them","made","like","and","all","trust"]},{"verseId":"brenton_psalms_134_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":19,"text":"O house of Israel, bless ye the Lord: O house of Aaron, bless ye the Lord:","searchKeywords":["house","israel","bless","the","lord","aaron"]},{"verseId":"brenton_psalms_134_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":20,"text":"O house of Levi, bless ye the Lord: ye that fear the Lord, bless the Lord.","searchKeywords":["house","levi","bless","the","lord","that","fear"]},{"verseId":"brenton_psalms_134_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":134,"verse":21,"text":"Blessed in Sion be the Lord, who dwells in Jerusalem.","searchKeywords":["blessed","sion","the","lord","who","dwells","jerusalem"]}]