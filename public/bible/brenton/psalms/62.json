[{"verseId":"brenton_psalms_62_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":62,"verse":1,"text":"A Psalm of David, when he was in the wilderness of Idumea.","searchKeywords":["psalm","david","when","was","the","wilderness","idumea"]},{"verseId":"brenton_psalms_62_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":62,"verse":2,"text":"O God, my God, I cry to thee early; my soul has thirsted for thee: how often has my flesh after thee, in a barren and trackless and dry land!","searchKeywords":["god","cry","thee","early","soul","has","thirsted","for","how","often","flesh","after","barren","and","trackless","dry","land"]},{"verseId":"brenton_psalms_62_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":62,"verse":3,"text":"Thus have I appeared before thee in the sanctuary, that I might see thy power and thy glory.","searchKeywords":["thus","have","appeared","before","thee","the","sanctuary","that","might","see","thy","power","and","glory"]},{"verseId":"brenton_psalms_62_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":62,"verse":4,"text":"For thy mercy is better than life: my lips shall praise thee.","searchKeywords":["for","thy","mercy","better","than","life","lips","shall","praise","thee"]},{"verseId":"brenton_psalms_62_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":62,"verse":5,"text":"Thus will I bless thee during my life: I will lift up my hands in thy name.","searchKeywords":["thus","will","bless","thee","during","life","lift","hands","thy","name"]},{"verseId":"brenton_psalms_62_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":62,"verse":6,"text":"Let my soul be filled as with marrow and fatness; and joyful lips shall praise thy name.","searchKeywords":["let","soul","filled","with","marrow","and","fatness","joyful","lips","shall","praise","thy","name"]},{"verseId":"brenton_psalms_62_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":62,"verse":7,"text":"Forasmuch as I have remembered thee on my bed: in the early seasons I have meditated on thee.","searchKeywords":["forasmuch","have","remembered","thee","bed","the","early","seasons","meditated"]},{"verseId":"brenton_psalms_62_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":62,"verse":8,"text":"For thou hast been my helper, and in the shelter of thy wings will I rejoice.","searchKeywords":["for","thou","hast","been","helper","and","the","shelter","thy","wings","will","rejoice"]},{"verseId":"brenton_psalms_62_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":62,"verse":9,"text":"My soul has kept very close behind thee: thy right hand has upheld me.","searchKeywords":["soul","has","kept","very","close","behind","thee","thy","right","hand","upheld"]},{"verseId":"brenton_psalms_62_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":62,"verse":10,"text":"But they vainly sought after my soul; they shall go into the lowest parts of the earth.","searchKeywords":["but","they","vainly","sought","after","soul","shall","into","the","lowest","parts","earth"]},{"verseId":"brenton_psalms_62_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":62,"verse":11,"text":"They shall be delivered up to the power of the sword; they shall be portions for foxes.","searchKeywords":["they","shall","delivered","the","power","sword","portions","for","foxes"]},{"verseId":"brenton_psalms_62_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":62,"verse":12,"text":"But the king shall rejoice in God; every one that swears by him shall be praised; for the mouth of them that speak unjust things has been stopped.","searchKeywords":["but","the","king","shall","rejoice","god","every","one","that","swears","him","praised","for","mouth","them","speak","unjust","things","has","been","stopped"]}]