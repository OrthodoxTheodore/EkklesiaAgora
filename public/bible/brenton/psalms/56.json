[{"verseId":"brenton_psalms_56_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":56,"verse":1,"text":"For the end. Destroy not: by David, for a memorial, when he fled from the presence of Saul to the cave.","searchKeywords":["for","the","end","destroy","not","david","memorial","when","fled","from","presence","saul","cave"]},{"verseId":"brenton_psalms_56_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":56,"verse":2,"text":"Have mercy, upon me, O God, have mercy upon me: for my soul has trusted in thee: and in the shadow of thy wings will I hope, until the iniquity have passed away.","searchKeywords":["have","mercy","upon","god","for","soul","has","trusted","thee","and","the","shadow","thy","wings","will","hope","until","iniquity","passed","away"]},{"verseId":"brenton_psalms_56_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":56,"verse":3,"text":"I will cry to God most high; the God who has benefited me. Pause.","searchKeywords":["will","cry","god","most","high","the","who","has","benefited","pause"]},{"verseId":"brenton_psalms_56_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":56,"verse":4,"text":"He sent from heaven and saved me; he gave to reproach them that trampled on me: God has sent forth his mercy and his truth;","searchKeywords":["sent","from","heaven","and","saved","gave","reproach","them","that","trampled","god","has","forth","his","mercy","truth"]},{"verseId":"brenton_psalms_56_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":56,"verse":5,"text":"and he has delivered my soul from the midst of whelps: I lay down to sleep, troubled. the sons of men, their teeth are arms and weapons, and their tongue a sharp sword.","searchKeywords":["and","has","delivered","soul","from","the","midst","whelps","lay","down","sleep","troubled","sons","men","their","teeth","are","arms","weapons","tongue","sharp","sword"]},{"verseId":"brenton_psalms_56_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":56,"verse":6,"text":"Be thou exalted, O God, above the heavens; and thy glory above all the earth.","searchKeywords":["thou","exalted","god","above","the","heavens","and","thy","glory","all","earth"]},{"verseId":"brenton_psalms_56_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":56,"verse":7,"text":"They have prepared snares for my feet, and have bowed down my soul: they have dug a pit before my face, and fallen into it . Pause.","searchKeywords":["they","have","prepared","snares","for","feet","and","bowed","down","soul","dug","pit","before","face","fallen","into","pause"]},{"verseId":"brenton_psalms_56_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":56,"verse":8,"text":"My heart, O God, ready, my heart ready: I will sing, yea will sing psalms.","searchKeywords":["heart","god","ready","will","sing","yea","psalms"]},{"verseId":"brenton_psalms_56_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":56,"verse":9,"text":"Awake, my glory; awake, psaltery and harp: I will awake early.","searchKeywords":["awake","glory","psaltery","and","harp","will","early"]},{"verseId":"brenton_psalms_56_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":56,"verse":10,"text":"O Lord, I will give thanks to thee among the nations: I will sing to thee among the Gentiles.","searchKeywords":["lord","will","give","thanks","thee","among","the","nations","sing","gentiles"]},{"verseId":"brenton_psalms_56_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":56,"verse":11,"text":"For thy mercy has been magnified even to the heavens, and thy truth to the clouds.","searchKeywords":["for","thy","mercy","has","been","magnified","even","the","heavens","and","truth","clouds"]},{"verseId":"brenton_psalms_56_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":56,"verse":12,"text":"Be thou exalted, O God, above the heavens; and thy glory above all the earth.","searchKeywords":["thou","exalted","god","above","the","heavens","and","thy","glory","all","earth"]}]