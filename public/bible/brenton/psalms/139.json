[{"verseId":"brenton_psalms_139_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":1,"text":"For the end, a Psalm of David.","searchKeywords":["for","the","end","psalm","david"]},{"verseId":"brenton_psalms_139_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":2,"text":"Rescue me, O Lord, from the evil man; deliver me from the unjust man.","searchKeywords":["rescue","lord","from","the","evil","man","deliver","unjust"]},{"verseId":"brenton_psalms_139_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":3,"text":"Who have devised injustice in their hearts; all the day they prepared war.","searchKeywords":["who","have","devised","injustice","their","hearts","all","the","day","they","prepared","war"]},{"verseId":"brenton_psalms_139_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":4,"text":"They have sharpened their tongue as of a serpent; the poison of asps is under their lips. Pause.","searchKeywords":["they","have","sharpened","their","tongue","serpent","the","poison","asps","under","lips","pause"]},{"verseId":"brenton_psalms_139_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":5,"text":"Keep me, O Lord, from the hand of the sinner; rescue me from unjust men; who have purposed to overthrow my goings.","searchKeywords":["keep","lord","from","the","hand","sinner","rescue","unjust","men","who","have","purposed","overthrow","goings"]},{"verseId":"brenton_psalms_139_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":6,"text":"The proud have hid a snare for me, and have stretched out ropes snares for my feet; they set a stumbling-block for me near the path. Pause.","searchKeywords":["the","proud","have","hid","snare","for","and","stretched","out","ropes","snares","feet","they","set","stumbling","block","near","path","pause"]},{"verseId":"brenton_psalms_139_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":7,"text":"I said to the Lord, Thou art my God; hearken, O Lord, to the voice of my supplication.","searchKeywords":["said","the","lord","thou","art","god","hearken","voice","supplication"]},{"verseId":"brenton_psalms_139_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":8,"text":"O Lord God, the strength of my salvation; thou hast screened my head in the day of battle.","searchKeywords":["lord","god","the","strength","salvation","thou","hast","screened","head","day","battle"]},{"verseId":"brenton_psalms_139_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":9,"text":"Deliver me not, O Lord, to the sinner, according to my desire: they have devised against me; forsake me not, lest they should be exalted. Pause.","searchKeywords":["deliver","not","lord","the","sinner","according","desire","they","have","devised","against","forsake","lest","should","exalted","pause"]},{"verseId":"brenton_psalms_139_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":10,"text":"the head of them that compass me, the mischief of their lips shall cover them.","searchKeywords":["the","head","them","that","compass","mischief","their","lips","shall","cover"]},{"verseId":"brenton_psalms_139_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":11,"text":"Coals of fire shall fall upon them on the earth; and thou shalt cast them down in afflictions: they shall not bear up .","searchKeywords":["coals","fire","shall","fall","upon","them","the","earth","and","thou","shalt","cast","down","afflictions","they","not","bear"]},{"verseId":"brenton_psalms_139_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":12,"text":"A talkative man shall not prosper on the earth: evils shall hunt the unrighteous man to destruction.","searchKeywords":["talkative","man","shall","not","prosper","the","earth","evils","hunt","unrighteous","destruction"]},{"verseId":"brenton_psalms_139_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":13,"text":"I know that the Lord will maintain the cause of the poor, and the right of the needy ones.","searchKeywords":["know","that","the","lord","will","maintain","cause","poor","and","right","needy","ones"]},{"verseId":"brenton_psalms_139_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":139,"verse":14,"text":"Surely the righteous shall give thanks to thy name: the upright shall dwell in thy presence.","searchKeywords":["surely","the","righteous","shall","give","thanks","thy","name","upright","dwell","presence"]}]