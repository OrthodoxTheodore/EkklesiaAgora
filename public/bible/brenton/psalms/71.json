[{"verseId":"brenton_psalms_71_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":1,"text":"For Solomon.","searchKeywords":["for","solomon"]},{"verseId":"brenton_psalms_71_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":2,"text":"judge thy people with righteousness, and thy poor with judgment.","searchKeywords":["judge","thy","people","with","righteousness","and","poor","judgment"]},{"verseId":"brenton_psalms_71_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":3,"text":"Let the mountains and the hills raise peace to thy people:","searchKeywords":["let","the","mountains","and","hills","raise","peace","thy","people"]},{"verseId":"brenton_psalms_71_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":4,"text":"he shall judge the poor of the people in righteousness, and save the children of the needy; and shall bring low the false accuser.","searchKeywords":["shall","judge","the","poor","people","righteousness","and","save","children","needy","bring","low","false","accuser"]},{"verseId":"brenton_psalms_71_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":5,"text":"And he shall continue as long as the sun, and before the moon for ever.","searchKeywords":["and","shall","continue","long","the","sun","before","moon","for","ever"]},{"verseId":"brenton_psalms_71_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":6,"text":"He shall come down as rain upon a fleece; and as drops falling upon the earth.","searchKeywords":["shall","come","down","rain","upon","fleece","and","drops","falling","the","earth"]},{"verseId":"brenton_psalms_71_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":7,"text":"In his days shall righteousness spring up; and abundance of peace till the moon be removed.","searchKeywords":["his","days","shall","righteousness","spring","and","abundance","peace","till","the","moon","removed"]},{"verseId":"brenton_psalms_71_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":8,"text":"And he shall have dominion from sea to sea, and from the river to the ends of the earth.","searchKeywords":["and","shall","have","dominion","from","sea","the","river","ends","earth"]},{"verseId":"brenton_psalms_71_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":9,"text":"The Ethiopians shall fall down before him; and his enemies shall lick the dust.","searchKeywords":["the","ethiopians","shall","fall","down","before","him","and","his","enemies","lick","dust"]},{"verseId":"brenton_psalms_71_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":10,"text":"The kings of Tharsis, and the isles, shall bring presents: the kings of the Arabians and Saba shall offer gifts.","searchKeywords":["the","kings","tharsis","and","isles","shall","bring","presents","arabians","saba","offer","gifts"]},{"verseId":"brenton_psalms_71_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":11,"text":"And all kings shall worship him; all the Gentiles shall serve him.","searchKeywords":["and","all","kings","shall","worship","him","the","gentiles","serve"]},{"verseId":"brenton_psalms_71_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":12,"text":"For he has delivered the poor from the oppressor; and the needy who had no helper.","searchKeywords":["for","has","delivered","the","poor","from","oppressor","and","needy","who","had","helper"]},{"verseId":"brenton_psalms_71_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":13,"text":"He shall spare the poor and needy, and shall deliver the souls of the needy.","searchKeywords":["shall","spare","the","poor","and","needy","deliver","souls"]},{"verseId":"brenton_psalms_71_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":14,"text":"He shall redeem their souls from usury and injustice: and their name precious before him.","searchKeywords":["shall","redeem","their","souls","from","usury","and","injustice","name","precious","before","him"]},{"verseId":"brenton_psalms_71_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":15,"text":"And he shall live, and there shall be given him of the gold of Arabia: and shall pray for him continually; all the day shall they praise him.","searchKeywords":["and","shall","live","there","given","him","the","gold","arabia","pray","for","continually","all","day","they","praise"]},{"verseId":"brenton_psalms_71_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":16,"text":"There shall be an establishment on the earth on the tops of the mountains: the fruit thereof shall be exalted above Libanus, and they of the city shall flourish as grass of the earth.","searchKeywords":["there","shall","establishment","the","earth","tops","mountains","fruit","thereof","exalted","above","libanus","and","they","city","flourish","grass"]},{"verseId":"brenton_psalms_71_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":17,"text":"Let his name be blessed for ever: his name shall endure longer than the sun: and all the tribes of the earth shall be blessed in him: all nations shall call him blessed.","searchKeywords":["let","his","name","blessed","for","ever","shall","endure","longer","than","the","sun","and","all","tribes","earth","him","nations","call"]},{"verseId":"brenton_psalms_71_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":18,"text":"Blessed is the Lord God of Israel, who alone does wonders.","searchKeywords":["blessed","the","lord","god","israel","who","alone","does","wonders"]},{"verseId":"brenton_psalms_71_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":19,"text":"And blessed is his glorious name for ever, even for ever and ever: and all the earth shall be filled with his glory. So be it, so be it.","searchKeywords":["and","blessed","his","glorious","name","for","ever","even","all","the","earth","shall","filled","with","glory"]},{"verseId":"brenton_psalms_71_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":71,"verse":20,"text":"The hymns of David the son of Jessæ are ended.","searchKeywords":["the","hymns","david","son","jess","are","ended"]}]