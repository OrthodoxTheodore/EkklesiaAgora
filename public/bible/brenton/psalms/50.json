[{"verseId":"brenton_psalms_50_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":1,"text":"For the end, a Psalm of David,","searchKeywords":["for","the","end","psalm","david"]},{"verseId":"brenton_psalms_50_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":2,"text":"when Nathan the prophet came to him, when he had gone in to Bersabee.","searchKeywords":["when","nathan","the","prophet","came","him","had","gone","bersabee"]},{"verseId":"brenton_psalms_50_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":3,"text":"Have mercy upon me, O God, according to thy great mercy; and according to the multitude of thy compassions blot out my transgression.","searchKeywords":["have","mercy","upon","god","according","thy","great","and","the","multitude","compassions","blot","out","transgression"]},{"verseId":"brenton_psalms_50_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":4,"text":"Wash me thoroughly from mine iniquity, and cleanse me from my sin.","searchKeywords":["wash","thoroughly","from","mine","iniquity","and","cleanse","sin"]},{"verseId":"brenton_psalms_50_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":5,"text":"For I am conscious of mine iniquity; and my sin is continually before me.","searchKeywords":["for","conscious","mine","iniquity","and","sin","continually","before"]},{"verseId":"brenton_psalms_50_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":6,"text":"Against thee only have I sinned, and done evil before thee: that thou mightest be justified in thy sayings, and mightest overcome when thou art judged.","searchKeywords":["against","thee","only","have","sinned","and","done","evil","before","that","thou","mightest","justified","thy","sayings","overcome","when","art","judged"]},{"verseId":"brenton_psalms_50_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":7,"text":"For, behold, I was conceived in iniquities, and in sins did my mother conceive me.","searchKeywords":["for","behold","was","conceived","iniquities","and","sins","did","mother","conceive"]},{"verseId":"brenton_psalms_50_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":8,"text":"For, behold, thou lovest truth: thou hast manifested to me the secret and hidden things of thy wisdom.","searchKeywords":["for","behold","thou","lovest","truth","hast","manifested","the","secret","and","hidden","things","thy","wisdom"]},{"verseId":"brenton_psalms_50_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":9,"text":"Thou shalt sprinkle me with hyssop, and I shall be purified: thou shalt wash me, and I shall be made whiter than snow.","searchKeywords":["thou","shalt","sprinkle","with","hyssop","and","shall","purified","wash","made","whiter","than","snow"]},{"verseId":"brenton_psalms_50_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":10,"text":"Thou shalt cause me to hear gladness and joy: the afflicted bones shall rejoice.","searchKeywords":["thou","shalt","cause","hear","gladness","and","joy","the","afflicted","bones","shall","rejoice"]},{"verseId":"brenton_psalms_50_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":11,"text":"Turn away thy face from my sins, and blot out all mine iniquities.","searchKeywords":["turn","away","thy","face","from","sins","and","blot","out","all","mine","iniquities"]},{"verseId":"brenton_psalms_50_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":12,"text":"Create in me a clean heart, O God; and renew a right spirit in my inward parts.","searchKeywords":["create","clean","heart","god","and","renew","right","spirit","inward","parts"]},{"verseId":"brenton_psalms_50_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":13,"text":"Cast me not away from thy presence; and remove not thy Holy Spirit from me.","searchKeywords":["cast","not","away","from","thy","presence","and","remove","holy","spirit"]},{"verseId":"brenton_psalms_50_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":14,"text":"Restore to me the joy of thy salvation: establish me with thy directing Spirit.","searchKeywords":["restore","the","joy","thy","salvation","establish","with","directing","spirit"]},{"verseId":"brenton_psalms_50_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":15,"text":"will I teach transgressors thy ways; and ungodly men shall turn to thee.","searchKeywords":["will","teach","transgressors","thy","ways","and","ungodly","men","shall","turn","thee"]},{"verseId":"brenton_psalms_50_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":16,"text":"Deliver me from blood-guiltiness, O God, the God of my salvation: my tongue shall joyfully declare thy righteousness.","searchKeywords":["deliver","from","blood","guiltiness","god","the","salvation","tongue","shall","joyfully","declare","thy","righteousness"]},{"verseId":"brenton_psalms_50_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":17,"text":"O Lord, thou shalt open my lips; and my mouth shall declare thy praise.","searchKeywords":["lord","thou","shalt","open","lips","and","mouth","shall","declare","thy","praise"]},{"verseId":"brenton_psalms_50_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":18,"text":"For if thou desiredst sacrifice, I would have given : thou wilt not take pleasure in whole-burnt-offerings.","searchKeywords":["for","thou","desiredst","sacrifice","would","have","given","wilt","not","take","pleasure","whole","burnt","offerings"]},{"verseId":"brenton_psalms_50_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":19,"text":"Sacrifice to God is a broken spirit: a broken and humbled heart God will not despise.","searchKeywords":["sacrifice","god","broken","spirit","and","humbled","heart","will","not","despise"]},{"verseId":"brenton_psalms_50_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":20,"text":"Do good, O Lord, to Sion in thy good pleasure; and let the walls of Jerusalem be built.","searchKeywords":["good","lord","sion","thy","pleasure","and","let","the","walls","jerusalem","built"]},{"verseId":"brenton_psalms_50_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":50,"verse":21,"text":"Then shalt thou be pleased with a sacrifice of righteousness, offering, and whole-burnt-sacrifices: then shall they offer calves upon thine altar.","searchKeywords":["then","shalt","thou","pleased","with","sacrifice","righteousness","offering","and","whole","burnt","sacrifices","shall","they","offer","calves","upon","thine","altar"]}]