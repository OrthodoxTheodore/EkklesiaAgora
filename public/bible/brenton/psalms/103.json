[{"verseId":"brenton_psalms_103_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":1,"text":"of David.","searchKeywords":["david"]},{"verseId":"brenton_psalms_103_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":2,"text":"who dost robe thyself with light as with a garment; spreading out the heaven as a curtain.","searchKeywords":["who","dost","robe","thyself","with","light","garment","spreading","out","the","heaven","curtain"]},{"verseId":"brenton_psalms_103_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":3,"text":"Who covers his chambers with waters; who makes the clouds his chariot; who walks on the wings of the wind.","searchKeywords":["who","covers","his","chambers","with","waters","makes","the","clouds","chariot","walks","wings","wind"]},{"verseId":"brenton_psalms_103_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":4,"text":"Who makes his angels spirits, and his ministers a flaming fire.","searchKeywords":["who","makes","his","angels","spirits","and","ministers","flaming","fire"]},{"verseId":"brenton_psalms_103_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":5,"text":"Who establishes the earth on her sure foundation: it shall not be moved for ever.","searchKeywords":["who","establishes","the","earth","her","sure","foundation","shall","not","moved","for","ever"]},{"verseId":"brenton_psalms_103_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":6,"text":"The deep, as it were a garment, is his covering: the waters shall stand on the hills.","searchKeywords":["the","deep","were","garment","his","covering","waters","shall","stand","hills"]},{"verseId":"brenton_psalms_103_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":7,"text":"At thy rebuke they shall flee; at the voice of thy thunder they shall be alarmed.","searchKeywords":["thy","rebuke","they","shall","flee","the","voice","thunder","alarmed"]},{"verseId":"brenton_psalms_103_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":8,"text":"They go up to the mountains, and down to the plains, to the place which thou hast founded for them.","searchKeywords":["they","the","mountains","and","down","plains","place","which","thou","hast","founded","for","them"]},{"verseId":"brenton_psalms_103_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":9,"text":"Thou hast set a bound which they shall not pass, neither shall they turn again to cover the earth.","searchKeywords":["thou","hast","set","bound","which","they","shall","not","pass","neither","turn","again","cover","the","earth"]},{"verseId":"brenton_psalms_103_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":10,"text":"He sends forth his fountains among the valleys: the waters shall run between the mountains.","searchKeywords":["sends","forth","his","fountains","among","the","valleys","waters","shall","run","between","mountains"]},{"verseId":"brenton_psalms_103_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":11,"text":"They shall give drink to all the wild beasts of the field: the wild asses shall take to their thirst.","searchKeywords":["they","shall","give","drink","all","the","wild","beasts","field","asses","take","their","thirst"]},{"verseId":"brenton_psalms_103_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":12,"text":"By them shall the birds of the sky lodge: they shall utter a voice out of the midst of the rocks.","searchKeywords":["them","shall","the","birds","sky","lodge","they","utter","voice","out","midst","rocks"]},{"verseId":"brenton_psalms_103_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":13,"text":"He waters the mountains from his chambers: the earth shall be satisfied with the fruit of thy works.","searchKeywords":["waters","the","mountains","from","his","chambers","earth","shall","satisfied","with","fruit","thy","works"]},{"verseId":"brenton_psalms_103_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":14,"text":"He makes grass to grow for the cattle, and green herb for the service of men, to bring bread out of the earth;","searchKeywords":["makes","grass","grow","for","the","cattle","and","green","herb","service","men","bring","bread","out","earth"]},{"verseId":"brenton_psalms_103_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":15,"text":"and wine makes glad the heart of man, to make his face cheerful with oil: and bread strengthens man's heart.","searchKeywords":["and","wine","makes","glad","the","heart","man","make","his","face","cheerful","with","oil","bread","strengthens"]},{"verseId":"brenton_psalms_103_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":16,"text":"The trees of the plain shall be full the cedars of Libanus which he has planted.","searchKeywords":["the","trees","plain","shall","full","cedars","libanus","which","has","planted"]},{"verseId":"brenton_psalms_103_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":17,"text":"There the sparrows will build their nests; and the house of the heron takes the lead among them.","searchKeywords":["there","the","sparrows","will","build","their","nests","and","house","heron","takes","lead","among","them"]},{"verseId":"brenton_psalms_103_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":18,"text":"The high mountains are a refuge for the stags, the rock for the rabbits.","searchKeywords":["the","high","mountains","are","refuge","for","stags","rock","rabbits"]},{"verseId":"brenton_psalms_103_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":19,"text":"He appointed the moon for seasons: the sun knows his going down.","searchKeywords":["appointed","the","moon","for","seasons","sun","knows","his","going","down"]},{"verseId":"brenton_psalms_103_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":20,"text":"Thou didst make darkness, and it was night; in it all the wild beasts of the forest will be abroad:","searchKeywords":["thou","didst","make","darkness","and","was","night","all","the","wild","beasts","forest","will","abroad"]},{"verseId":"brenton_psalms_103_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":21,"text":"young lions roaring for prey, and to seek meat for themselves from God.","searchKeywords":["young","lions","roaring","for","prey","and","seek","meat","themselves","from","god"]},{"verseId":"brenton_psalms_103_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":22,"text":"The sun arises, and they shall be gathered together, and shall lie down in their dens.","searchKeywords":["the","sun","arises","and","they","shall","gathered","together","lie","down","their","dens"]},{"verseId":"brenton_psalms_103_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":23,"text":"Man shall go forth to his work, and to his labour till evening.","searchKeywords":["man","shall","forth","his","work","and","labour","till","evening"]},{"verseId":"brenton_psalms_103_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":24,"text":"How great are thy works, O Lord! in wisdom hast thou wrought them all: the earth is filled with thy creation.","searchKeywords":["how","great","are","thy","works","lord","wisdom","hast","thou","wrought","them","all","the","earth","filled","with","creation"]},{"verseId":"brenton_psalms_103_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":25,"text":"this great and wide sea: there are things creeping innumerable, small animals and great.","searchKeywords":["this","great","and","wide","sea","there","are","things","creeping","innumerable","small","animals"]},{"verseId":"brenton_psalms_103_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":26,"text":"There go the ships; this dragon whom thou hast made to play in it.","searchKeywords":["there","the","ships","this","dragon","whom","thou","hast","made","play"]},{"verseId":"brenton_psalms_103_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":27,"text":"All wait upon thee, to give them food in due season.","searchKeywords":["all","wait","upon","thee","give","them","food","due","season"]},{"verseId":"brenton_psalms_103_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":28,"text":"When thou hast given them, they will gather ; and when thou hast opened thine hand, they shall all be filled with good.","searchKeywords":["when","thou","hast","given","them","they","will","gather","and","opened","thine","hand","shall","all","filled","with","good"]},{"verseId":"brenton_psalms_103_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":29,"text":"But when thou hast turned away thy face, they shall be troubled: thou wilt take away their breath, and they shall fail, and return to their dust.","searchKeywords":["but","when","thou","hast","turned","away","thy","face","they","shall","troubled","wilt","take","their","breath","and","fail","return","dust"]},{"verseId":"brenton_psalms_103_30","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":30,"text":"Thou shalt send forth thy Spirit, and they shall be created; and thou shalt renew the face of the earth.","searchKeywords":["thou","shalt","send","forth","thy","spirit","and","they","shall","created","renew","the","face","earth"]},{"verseId":"brenton_psalms_103_31","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":31,"text":"Let the glory of the Lord be for ever: the Lord shall rejoice in his works;","searchKeywords":["let","the","glory","lord","for","ever","shall","rejoice","his","works"]},{"verseId":"brenton_psalms_103_32","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":32,"text":"who looks upon the earth, and makes it tremble; who touches the mountains, and they smoke.","searchKeywords":["who","looks","upon","the","earth","and","makes","tremble","touches","mountains","they","smoke"]},{"verseId":"brenton_psalms_103_33","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":33,"text":"I will sing to the Lord while I live; I will sing praise to my God while I exist.","searchKeywords":["will","sing","the","lord","while","live","praise","god","exist"]},{"verseId":"brenton_psalms_103_34","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":34,"text":"Let my meditation be sweet to him: and I will rejoice in the Lord.","searchKeywords":["let","meditation","sweet","him","and","will","rejoice","the","lord"]},{"verseId":"brenton_psalms_103_35","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":103,"verse":35,"text":"Let the sinners fail from off the earth, and transgressors, so that they shall be no more. Bless the Lord, O my soul.","searchKeywords":["let","the","sinners","fail","from","off","earth","and","transgressors","that","they","shall","more","bless","lord","soul"]}]