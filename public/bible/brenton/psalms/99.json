[{"verseId":"brenton_psalms_99_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":99,"verse":1,"text":"A Psalm for Thanksgiving.","searchKeywords":["psalm","for","thanksgiving"]},{"verseId":"brenton_psalms_99_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":99,"verse":2,"text":"Serve the Lord with gladness; come before his presence with exultation.","searchKeywords":["serve","the","lord","with","gladness","come","before","his","presence","exultation"]},{"verseId":"brenton_psalms_99_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":99,"verse":3,"text":"Know that the Lord he is God; he made us, and not we ourselves; his people, and the sheep of his pasture.","searchKeywords":["know","that","the","lord","god","made","and","not","ourselves","his","people","sheep","pasture"]},{"verseId":"brenton_psalms_99_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":99,"verse":4,"text":"Enter into his gates with thanksgiving, and his courts with hymns; give thanks to him, praise his name.","searchKeywords":["enter","into","his","gates","with","thanksgiving","and","courts","hymns","give","thanks","him","praise","name"]},{"verseId":"brenton_psalms_99_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":99,"verse":5,"text":"For the Lord is good, his mercy is for ever; and his truth to generation and generation.","searchKeywords":["for","the","lord","good","his","mercy","ever","and","truth","generation"]}]