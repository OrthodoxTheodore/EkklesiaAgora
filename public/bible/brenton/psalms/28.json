[{"verseId":"brenton_psalms_28_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":28,"verse":1,"text":"A Psalm of David of the solemn assembly of the Tabernacle.","searchKeywords":["psalm","david","the","solemn","assembly","tabernacle"]},{"verseId":"brenton_psalms_28_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":28,"verse":2,"text":"Bring to the Lord glory, to his name; worship the Lord in his holy court.","searchKeywords":["bring","the","lord","glory","his","name","worship","holy","court"]},{"verseId":"brenton_psalms_28_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":28,"verse":3,"text":"The voice of the Lord is upon the waters: the God of glory has thundered: the Lord is upon many waters.","searchKeywords":["the","voice","lord","upon","waters","god","glory","has","thundered","many"]},{"verseId":"brenton_psalms_28_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":28,"verse":4,"text":"The voice of the Lord is mighty; the voice of the Lord is full of majesty.","searchKeywords":["the","voice","lord","mighty","full","majesty"]},{"verseId":"brenton_psalms_28_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":28,"verse":5,"text":"the voice of the Lord who breaks the cedars; the Lord will break the cedars of Libanus.","searchKeywords":["the","voice","lord","who","breaks","cedars","will","break","libanus"]},{"verseId":"brenton_psalms_28_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":28,"verse":6,"text":"And he will beat them small, Libanus itself, like a calf; and the beloved one is as a young unicorn.","searchKeywords":["and","will","beat","them","small","libanus","itself","like","calf","the","beloved","one","young","unicorn"]},{"verseId":"brenton_psalms_28_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":28,"verse":7,"text":"a voice of the Lord who divides a flame of fire.","searchKeywords":["voice","the","lord","who","divides","flame","fire"]},{"verseId":"brenton_psalms_28_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":28,"verse":8,"text":"A voice of the Lord who shakes the wilderness; the Lord will shake the wilderness of Cades.","searchKeywords":["voice","the","lord","who","shakes","wilderness","will","shake","cades"]},{"verseId":"brenton_psalms_28_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":28,"verse":9,"text":"The voice of the Lord strengthens the hinds, and will uncover the thickets: and in his temple every one speaks glory.","searchKeywords":["the","voice","lord","strengthens","hinds","and","will","uncover","thickets","his","temple","every","one","speaks","glory"]},{"verseId":"brenton_psalms_28_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":28,"verse":10,"text":"The Lord will dwell on the waterflood: and the Lord will sit a king for ever.","searchKeywords":["the","lord","will","dwell","waterflood","and","sit","king","for","ever"]},{"verseId":"brenton_psalms_28_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":28,"verse":11,"text":"The Lord will give strength to his people; the Lord will bless his people with peace.","searchKeywords":["the","lord","will","give","strength","his","people","bless","with","peace"]}]