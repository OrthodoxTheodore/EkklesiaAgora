[{"verseId":"brenton_psalms_131_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":1,"text":"A Song of Degrees.","searchKeywords":["song","degrees"]},{"verseId":"brenton_psalms_131_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":2,"text":"how he sware to the Lord, vowed to the God of Jacob, ,","searchKeywords":["how","sware","the","lord","vowed","god","jacob"]},{"verseId":"brenton_psalms_131_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":3,"text":"I will not go into the tabernacle of my house; I will not go up to the couch of my bed;","searchKeywords":["will","not","into","the","tabernacle","house","couch","bed"]},{"verseId":"brenton_psalms_131_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":4,"text":"I will not give sleep to mine eyes, nor slumber to mine eyelids, nor rest to my temples,","searchKeywords":["will","not","give","sleep","mine","eyes","nor","slumber","eyelids","rest","temples"]},{"verseId":"brenton_psalms_131_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":5,"text":"until I find a place for the Lord, a tabernacle for the God of Jacob.","searchKeywords":["until","find","place","for","the","lord","tabernacle","god","jacob"]},{"verseId":"brenton_psalms_131_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":6,"text":"Behold, we heard of it in Ephratha; we found it in the fields of the wood.","searchKeywords":["behold","heard","ephratha","found","the","fields","wood"]},{"verseId":"brenton_psalms_131_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":7,"text":"Let us enter into his tabernacles: let us worship at the place where his feet stood.","searchKeywords":["let","enter","into","his","tabernacles","worship","the","place","where","feet","stood"]},{"verseId":"brenton_psalms_131_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":8,"text":"Arise, O Lord, into thy rest; thou, and the ark of thine holiness.","searchKeywords":["arise","lord","into","thy","rest","thou","and","the","ark","thine","holiness"]},{"verseId":"brenton_psalms_131_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":9,"text":"Thy priests shall clothe themselves with righteousness; and thy saints shall exult.","searchKeywords":["thy","priests","shall","clothe","themselves","with","righteousness","and","saints","exult"]},{"verseId":"brenton_psalms_131_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":10,"text":"For the sake of thy servant David turn not away the face of thine anointed.","searchKeywords":["for","the","sake","thy","servant","david","turn","not","away","face","thine","anointed"]},{"verseId":"brenton_psalms_131_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":11,"text":"The Lord sware truth to David, and he will not annul it, , Of the fruit of thy body will I set upon thy throne.","searchKeywords":["the","lord","sware","truth","david","and","will","not","annul","fruit","thy","body","set","upon","throne"]},{"verseId":"brenton_psalms_131_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":12,"text":"If thy children will keep my covenant, and these my testimonies which I shall teach them, their children also shall sit upon thy throne for ever.","searchKeywords":["thy","children","will","keep","covenant","and","these","testimonies","which","shall","teach","them","their","also","sit","upon","throne","for","ever"]},{"verseId":"brenton_psalms_131_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":13,"text":"For the Lord has elected Sion, he has chosen her for a habitation for himself, ,","searchKeywords":["for","the","lord","has","elected","sion","chosen","her","habitation","himself"]},{"verseId":"brenton_psalms_131_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":14,"text":"This is my rest for ever: here will I dwell; for I have chosen it.","searchKeywords":["this","rest","for","ever","here","will","dwell","have","chosen"]},{"verseId":"brenton_psalms_131_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":15,"text":"I will surely bless her provision: I will satisfy her poor with bread.","searchKeywords":["will","surely","bless","her","provision","satisfy","poor","with","bread"]},{"verseId":"brenton_psalms_131_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":16,"text":"I will clothe her priests with salvation; and her saints shall greatly exult.","searchKeywords":["will","clothe","her","priests","with","salvation","and","saints","shall","greatly","exult"]},{"verseId":"brenton_psalms_131_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":17,"text":"There will I cause to spring up a horn to David: I have prepared a lamp for mine anointed.","searchKeywords":["there","will","cause","spring","horn","david","have","prepared","lamp","for","mine","anointed"]},{"verseId":"brenton_psalms_131_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":131,"verse":18,"text":"His enemies will I clothe with shame; but upon himself shall my holiness flourish.","searchKeywords":["his","enemies","will","clothe","with","shame","but","upon","himself","shall","holiness","flourish"]}]