[{"verseId":"brenton_psalms_83_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":83,"verse":1,"text":"For the end, a Psalm for the sons of Core, concerning the wine-presses.","searchKeywords":["for","the","end","psalm","sons","core","concerning","wine","presses"]},{"verseId":"brenton_psalms_83_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":83,"verse":2,"text":"How amiable are thy tabernacles, O Lord of hosts!","searchKeywords":["how","amiable","are","thy","tabernacles","lord","hosts"]},{"verseId":"brenton_psalms_83_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":83,"verse":3,"text":"My soul longs, and faints for the courts of the Lord: my heart and my flesh have exulted in the living God.","searchKeywords":["soul","longs","and","faints","for","the","courts","lord","heart","flesh","have","exulted","living","god"]},{"verseId":"brenton_psalms_83_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":83,"verse":4,"text":"Yea, the sparrow has found himself a home, and the turtle-dove a nest for herself, where she may lay her young, thine altars, O Lord of hosts, my King, and my God.","searchKeywords":["yea","the","sparrow","has","found","himself","home","and","turtle","dove","nest","for","herself","where","she","may","lay","her","young","thine","altars","lord","hosts","king","god"]},{"verseId":"brenton_psalms_83_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":83,"verse":5,"text":"Blessed are they that dwell in thy house: they will praise thee evermore. Pause.","searchKeywords":["blessed","are","they","that","dwell","thy","house","will","praise","thee","evermore","pause"]},{"verseId":"brenton_psalms_83_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":83,"verse":6,"text":"Blessed is the man whose help is of thee, O Lord; in his heart he has purposed to go up","searchKeywords":["blessed","the","man","whose","help","thee","lord","his","heart","has","purposed"]},{"verseId":"brenton_psalms_83_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":83,"verse":7,"text":"the valley of weeping, to the place which he has appointed, for the law-giver will grant blessings.","searchKeywords":["the","valley","weeping","place","which","has","appointed","for","law","giver","will","grant","blessings"]},{"verseId":"brenton_psalms_83_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":83,"verse":8,"text":"They shall go from strength to strength: the God of gods shall be seen in Sion.","searchKeywords":["they","shall","from","strength","the","god","gods","seen","sion"]},{"verseId":"brenton_psalms_83_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":83,"verse":9,"text":"O Lord God of hosts, hear my prayer: hearken, O God of Jacob. Pause.","searchKeywords":["lord","god","hosts","hear","prayer","hearken","jacob","pause"]},{"verseId":"brenton_psalms_83_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":83,"verse":10,"text":"Behold, O God our defender, and look upon the face of thine anointed.","searchKeywords":["behold","god","our","defender","and","look","upon","the","face","thine","anointed"]},{"verseId":"brenton_psalms_83_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":83,"verse":11,"text":"For one day in thy courts is better than thousands. I would rather be an abject in the house of God, than dwell in the tents of sinners.","searchKeywords":["for","one","day","thy","courts","better","than","thousands","would","rather","abject","the","house","god","dwell","tents","sinners"]},{"verseId":"brenton_psalms_83_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":83,"verse":12,"text":"For the Lord loves mercy and truth: God will give grace and glory: the Lord will not withhold good things from them that walk in innocence.","searchKeywords":["for","the","lord","loves","mercy","and","truth","god","will","give","grace","glory","not","withhold","good","things","from","them","that","walk","innocence"]},{"verseId":"brenton_psalms_83_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":83,"verse":13,"text":"O Lord of hosts, blessed is the man that trusts in thee.","searchKeywords":["lord","hosts","blessed","the","man","that","trusts","thee"]}]