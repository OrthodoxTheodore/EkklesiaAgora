[{"verseId":"brenton_psalms_39_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":1,"text":"For the end, a Psalm of David.","searchKeywords":["for","the","end","psalm","david"]},{"verseId":"brenton_psalms_39_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":2,"text":"I waited patiently for the Lord; and he attended to me, and hearkened to my supplication.","searchKeywords":["waited","patiently","for","the","lord","and","attended","hearkened","supplication"]},{"verseId":"brenton_psalms_39_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":3,"text":"And he brought me up out of a pit of misery, and from miry clay: and he set my feet on a rock, and ordered my goings aright.","searchKeywords":["and","brought","out","pit","misery","from","miry","clay","set","feet","rock","ordered","goings","aright"]},{"verseId":"brenton_psalms_39_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":4,"text":"And he put a new song into my mouth, a hymn to our God: many shall see , and fear, and shall hope in the Lord.","searchKeywords":["and","put","new","song","into","mouth","hymn","our","god","many","shall","see","fear","hope","the","lord"]},{"verseId":"brenton_psalms_39_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":5,"text":"Blessed the man whose hope is the name of the Lord, and has not regarded vanities and false frenzies.","searchKeywords":["blessed","the","man","whose","hope","name","lord","and","has","not","regarded","vanities","false","frenzies"]},{"verseId":"brenton_psalms_39_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":6,"text":"O Lord my God, thou hast multiplied thy wonderful works, and in thy thoughts there is none who shall be likened to thee: I declared and spoke : they exceeded number.","searchKeywords":["lord","god","thou","hast","multiplied","thy","wonderful","works","and","thoughts","there","none","who","shall","likened","thee","declared","spoke","they","exceeded","number"]},{"verseId":"brenton_psalms_39_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":7,"text":"Sacrifice and offering thou wouldest not; but a body hast thou prepared me: whole-burnt-offering and for sin thou didst not require.","searchKeywords":["sacrifice","and","offering","thou","wouldest","not","but","body","hast","prepared","whole","burnt","for","sin","didst","require"]},{"verseId":"brenton_psalms_39_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":8,"text":"Then I said, Behold, I come: in the volume of the book it is written concerning me,","searchKeywords":["then","said","behold","come","the","volume","book","written","concerning"]},{"verseId":"brenton_psalms_39_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":9,"text":"I desired to do thy will, O my God, and thy law in the midst of mine heart.","searchKeywords":["desired","thy","will","god","and","law","the","midst","mine","heart"]},{"verseId":"brenton_psalms_39_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":10,"text":"I have preached righteousness in the great congregation; lo! I will not refrain my lips; O Lord, thou knowest my righteousness.","searchKeywords":["have","preached","righteousness","the","great","congregation","will","not","refrain","lips","lord","thou","knowest"]},{"verseId":"brenton_psalms_39_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":11,"text":"I have not hid thy truth within my heart, and I have declared thy salvation; I have not hid thy mercy and thy truth from the great congregation.","searchKeywords":["have","not","hid","thy","truth","within","heart","and","declared","salvation","mercy","from","the","great","congregation"]},{"verseId":"brenton_psalms_39_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":12,"text":"But thou, Lord, remove not thy compassion far from me; thy mercy and thy truth have helped me continually.","searchKeywords":["but","thou","lord","remove","not","thy","compassion","far","from","mercy","and","truth","have","helped","continually"]},{"verseId":"brenton_psalms_39_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":13,"text":"For innumerable evils have encompassed me; my transgressions have taken hold of me, and I could not see; they are multiplied more than the hairs of my head; and my heart has failed me.","searchKeywords":["for","innumerable","evils","have","encompassed","transgressions","taken","hold","and","could","not","see","they","are","multiplied","more","than","the","hairs","head","heart","has","failed"]},{"verseId":"brenton_psalms_39_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":14,"text":"Be pleased, O Lord, to deliver me; O Lord, draw nigh to help me.","searchKeywords":["pleased","lord","deliver","draw","nigh","help"]},{"verseId":"brenton_psalms_39_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":15,"text":"Let those that seek my soul, to destroy it, be ashamed and confounded together; let those that wish me evil be turned backward and put to shame.","searchKeywords":["let","those","that","seek","soul","destroy","ashamed","and","confounded","together","wish","evil","turned","backward","put","shame"]},{"verseId":"brenton_psalms_39_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":16,"text":"Let those that say to me, Aha, aha, quickly receive shame for their reward.","searchKeywords":["let","those","that","say","aha","quickly","receive","shame","for","their","reward"]},{"verseId":"brenton_psalms_39_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":17,"text":"Let all those that seek thee, O Lord, exult and rejoice in thee; and let them that love thy salvation say continually, The Lord be magnified.","searchKeywords":["let","all","those","that","seek","thee","lord","exult","and","rejoice","them","love","thy","salvation","say","continually","the","magnified"]},{"verseId":"brenton_psalms_39_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":39,"verse":18,"text":"But I am poor and needy; the Lord will take care of me; thou art my helper, and my defender, O my God, delay not.","searchKeywords":["but","poor","and","needy","the","lord","will","take","care","thou","art","helper","defender","god","delay","not"]}]