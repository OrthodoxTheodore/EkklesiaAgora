[{"verseId":"brenton_psalms_105_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":1,"text":"Alleluia. for ever.","searchKeywords":["alleluia","for","ever"]},{"verseId":"brenton_psalms_105_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":2,"text":"Who shall tell the mighty acts of the Lord? shall cause all his praises to be heard?","searchKeywords":["who","shall","tell","the","mighty","acts","lord","cause","all","his","praises","heard"]},{"verseId":"brenton_psalms_105_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":3,"text":"Blessed are they that keep judgment, and do righteousness at all times.","searchKeywords":["blessed","are","they","that","keep","judgment","and","righteousness","all","times"]},{"verseId":"brenton_psalms_105_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":4,"text":"Remember us, O Lord, with the favour to thy people: visit us with thy salvation;","searchKeywords":["remember","lord","with","the","favour","thy","people","visit","salvation"]},{"verseId":"brenton_psalms_105_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":5,"text":"that we may behold the good of thine elect, that we may rejoice in the gladness of thy nation, that we may glory with thine inheritance.","searchKeywords":["that","may","behold","the","good","thine","elect","rejoice","gladness","thy","nation","glory","with","inheritance"]},{"verseId":"brenton_psalms_105_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":6,"text":"We have sinned with our fathers, we have transgressed, we have done unrighteously.","searchKeywords":["have","sinned","with","our","fathers","transgressed","done","unrighteously"]},{"verseId":"brenton_psalms_105_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":7,"text":"Our fathers in Egypt understood not thy wonders, and remembered not the multitude of thy mercy; but provoked as they went up by the Red Sea.","searchKeywords":["our","fathers","egypt","understood","not","thy","wonders","and","remembered","the","multitude","mercy","but","provoked","they","went","red","sea"]},{"verseId":"brenton_psalms_105_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":8,"text":"Yet he saved them for his name's sake, that he might cause his mighty power to be known.","searchKeywords":["yet","saved","them","for","his","name","sake","that","might","cause","mighty","power","known"]},{"verseId":"brenton_psalms_105_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":9,"text":"And he rebuked the Red Sea, and it was dried up: so he led them through the deep as through the wilderness.","searchKeywords":["and","rebuked","the","red","sea","was","dried","led","them","through","deep","wilderness"]},{"verseId":"brenton_psalms_105_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":10,"text":"And he saved them out of the hand of them that hated , and redeemed them out of the hand of the enemy.","searchKeywords":["and","saved","them","out","the","hand","that","hated","redeemed","enemy"]},{"verseId":"brenton_psalms_105_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":11,"text":"The water covered those that oppressed them: there was not one of them left.","searchKeywords":["the","water","covered","those","that","oppressed","them","there","was","not","one","left"]},{"verseId":"brenton_psalms_105_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":12,"text":"Then they believed his words, and celebrated his praise.","searchKeywords":["then","they","believed","his","words","and","celebrated","praise"]},{"verseId":"brenton_psalms_105_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":13,"text":"They made haste, they forgot his works; they waited not for his counsel.","searchKeywords":["they","made","haste","forgot","his","works","waited","not","for","counsel"]},{"verseId":"brenton_psalms_105_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":14,"text":"And they lusted exceedingly in the wilderness, and tempted God in the dry .","searchKeywords":["and","they","lusted","exceedingly","the","wilderness","tempted","god","dry"]},{"verseId":"brenton_psalms_105_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":15,"text":"And he gave them their request, and sent fulness into their souls.","searchKeywords":["and","gave","them","their","request","sent","fulness","into","souls"]},{"verseId":"brenton_psalms_105_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":16,"text":"They provoked Moses also in the camp, and Aaron the holy one of the Lord.","searchKeywords":["they","provoked","moses","also","the","camp","and","aaron","holy","one","lord"]},{"verseId":"brenton_psalms_105_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":17,"text":"The earth opened and swallowed up Dathan, and closed upon the congregation of Abiron.","searchKeywords":["the","earth","opened","and","swallowed","dathan","closed","upon","congregation","abiron"]},{"verseId":"brenton_psalms_105_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":18,"text":"And a fire was kindled in their congregation, and a flame burnt up the sinners.","searchKeywords":["and","fire","was","kindled","their","congregation","flame","burnt","the","sinners"]},{"verseId":"brenton_psalms_105_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":19,"text":"And they made a calf in Choreb, and worshipped the graven image,","searchKeywords":["and","they","made","calf","choreb","worshipped","the","graven","image"]},{"verseId":"brenton_psalms_105_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":20,"text":"and they changed their glory into the similitude of a calf that feeds on grass.","searchKeywords":["and","they","changed","their","glory","into","the","similitude","calf","that","feeds","grass"]},{"verseId":"brenton_psalms_105_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":21,"text":"They forgot God that saved them, who had wrought great deeds in Egypt;","searchKeywords":["they","forgot","god","that","saved","them","who","had","wrought","great","deeds","egypt"]},{"verseId":"brenton_psalms_105_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":22,"text":"wondrous in the land of Cham, and terrible things at the Red Sea.","searchKeywords":["wondrous","the","land","cham","and","terrible","things","red","sea"]},{"verseId":"brenton_psalms_105_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":23,"text":"So he said that he would have destroyed them, had not Moses his chosen stood before him in the breach, to turn away from the fierceness of his anger, so that he should not destroy them.","searchKeywords":["said","that","would","have","destroyed","them","had","not","moses","his","chosen","stood","before","him","the","breach","turn","away","from","fierceness","anger","should","destroy"]},{"verseId":"brenton_psalms_105_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":24,"text":"Moreover they set at nought the desirable land, and believed not his word.","searchKeywords":["moreover","they","set","nought","the","desirable","land","and","believed","not","his","word"]},{"verseId":"brenton_psalms_105_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":25,"text":"And they murmured in their tents: they hearkened not to the voice of the Lord.","searchKeywords":["and","they","murmured","their","tents","hearkened","not","the","voice","lord"]},{"verseId":"brenton_psalms_105_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":26,"text":"So he lifted up his hand against them, to cast them down in the wilderness;","searchKeywords":["lifted","his","hand","against","them","cast","down","the","wilderness"]},{"verseId":"brenton_psalms_105_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":27,"text":"and to cast down their seed among the nations, and to scatter them in the countries.","searchKeywords":["and","cast","down","their","seed","among","the","nations","scatter","them","countries"]},{"verseId":"brenton_psalms_105_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":28,"text":"They were joined also to Beelphegor, and ate the sacrifices of the dead. And they provoked him with their devices;","searchKeywords":["they","were","joined","also","beelphegor","and","ate","the","sacrifices","dead","provoked","him","with","their","devices"]},{"verseId":"brenton_psalms_105_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":29,"text":"and destruction was multiplied among them.","searchKeywords":["and","destruction","was","multiplied","among","them"]},{"verseId":"brenton_psalms_105_30","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":30,"text":"Then Phinees stood up, and made atonement: and the plague ceased.","searchKeywords":["then","phinees","stood","and","made","atonement","the","plague","ceased"]},{"verseId":"brenton_psalms_105_31","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":31,"text":"And it was counted to him for righteousness, to all generations for ever.","searchKeywords":["and","was","counted","him","for","righteousness","all","generations","ever"]},{"verseId":"brenton_psalms_105_32","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":32,"text":"They provoked him also at the water of Strife, and Moses was hurt for their sakes;","searchKeywords":["they","provoked","him","also","the","water","strife","and","moses","was","hurt","for","their","sakes"]},{"verseId":"brenton_psalms_105_33","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":33,"text":"for they provoked his spirit, and he spoke with his lips.","searchKeywords":["for","they","provoked","his","spirit","and","spoke","with","lips"]},{"verseId":"brenton_psalms_105_34","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":34,"text":"They destroyed not the nations which the Lord told them ;","searchKeywords":["they","destroyed","not","the","nations","which","lord","told","them"]},{"verseId":"brenton_psalms_105_35","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":35,"text":"but were mingled with the heathen, and learned their works.","searchKeywords":["but","were","mingled","with","the","heathen","and","learned","their","works"]},{"verseId":"brenton_psalms_105_36","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":36,"text":"And they served their graven images; and it became an offence to them.","searchKeywords":["and","they","served","their","graven","images","became","offence","them"]},{"verseId":"brenton_psalms_105_37","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":37,"text":"And they sacrificed their sons and their daughters to devils,","searchKeywords":["and","they","sacrificed","their","sons","daughters","devils"]},{"verseId":"brenton_psalms_105_38","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":38,"text":"and shed innocent blood, the blood of their sons and daughters, whom they sacrificed to the idols of Chanaan; and the land was defiled with blood,","searchKeywords":["and","shed","innocent","blood","the","their","sons","daughters","whom","they","sacrificed","idols","chanaan","land","was","defiled","with"]},{"verseId":"brenton_psalms_105_39","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":39,"text":"and was polluted with their works; and they went a whoring with their own devices.","searchKeywords":["and","was","polluted","with","their","works","they","went","whoring","own","devices"]},{"verseId":"brenton_psalms_105_40","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":40,"text":"So the Lord was very angry with his people, and he abhorred his inheritance.","searchKeywords":["the","lord","was","very","angry","with","his","people","and","abhorred","inheritance"]},{"verseId":"brenton_psalms_105_41","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":41,"text":"And he delivered them into the hands of enemies; and they that hated them ruled over them.","searchKeywords":["and","delivered","them","into","the","hands","enemies","they","that","hated","ruled","over"]},{"verseId":"brenton_psalms_105_42","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":42,"text":"And their enemies oppressed them, and they were brought down under their hands.","searchKeywords":["and","their","enemies","oppressed","them","they","were","brought","down","under","hands"]},{"verseId":"brenton_psalms_105_43","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":43,"text":"Many a time he delivered them; but they provoked him by their counsel, and they were brought low by their iniquities.","searchKeywords":["many","time","delivered","them","but","they","provoked","him","their","counsel","and","were","brought","low","iniquities"]},{"verseId":"brenton_psalms_105_44","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":44,"text":"Yet the Lord looked upon their affliction, when he heard their petition.","searchKeywords":["yet","the","lord","looked","upon","their","affliction","when","heard","petition"]},{"verseId":"brenton_psalms_105_45","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":45,"text":"And he remembered his covenant, and repented according to the multitude of his mercy.","searchKeywords":["and","remembered","his","covenant","repented","according","the","multitude","mercy"]},{"verseId":"brenton_psalms_105_46","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":46,"text":"And he caused them to be pitied in the sight of all who carried them captive.","searchKeywords":["and","caused","them","pitied","the","sight","all","who","carried","captive"]},{"verseId":"brenton_psalms_105_47","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":47,"text":"Save us, O Lord our God, and gather us from among the heathen, that we may give thanks to thy holy name, that we may glory in thy praise.","searchKeywords":["save","lord","our","god","and","gather","from","among","the","heathen","that","may","give","thanks","thy","holy","name","glory","praise"]},{"verseId":"brenton_psalms_105_48","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":105,"verse":48,"text":"Blessed be the Lord God of Israel from everlasting and to everlasting; and all the people shall say, Amen, Amen.","searchKeywords":["blessed","the","lord","god","israel","from","everlasting","and","all","people","shall","say","amen"]}]