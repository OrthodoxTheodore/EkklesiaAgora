[{"verseId":"brenton_psalms_98_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":98,"verse":1,"text":"A Psalm of David. that sits upon the cherubs, let the earth be moved.","searchKeywords":["psalm","david","that","sits","upon","the","cherubs","let","earth","moved"]},{"verseId":"brenton_psalms_98_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":98,"verse":2,"text":"The Lord is great in Sion, and is high over all the people.","searchKeywords":["the","lord","great","sion","and","high","over","all","people"]},{"verseId":"brenton_psalms_98_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":98,"verse":3,"text":"Let them give thanks to thy great name; for it is terrible and holy.","searchKeywords":["let","them","give","thanks","thy","great","name","for","terrible","and","holy"]},{"verseId":"brenton_psalms_98_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":98,"verse":4,"text":"And the king's honour loves judgment; thou hast prepared equity, thou hast wrought judgment and justice in Jacob.","searchKeywords":["and","the","king","honour","loves","judgment","thou","hast","prepared","equity","wrought","justice","jacob"]},{"verseId":"brenton_psalms_98_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":98,"verse":5,"text":"Exalt ye the Lord our God, and worship his footstool; for he is holy.","searchKeywords":["exalt","the","lord","our","god","and","worship","his","footstool","for","holy"]},{"verseId":"brenton_psalms_98_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":98,"verse":6,"text":"Moses and Aaron among his priests, and Samuel among them that call upon his name; they called upon the Lord, and he heard them.","searchKeywords":["moses","and","aaron","among","his","priests","samuel","them","that","call","upon","name","they","called","the","lord","heard"]},{"verseId":"brenton_psalms_98_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":98,"verse":7,"text":"He spoke to them in a pillar of cloud; they kept his testimonies, and the ordinances which he gave them.","searchKeywords":["spoke","them","pillar","cloud","they","kept","his","testimonies","and","the","ordinances","which","gave"]},{"verseId":"brenton_psalms_98_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":98,"verse":8,"text":"O Lord our God, thou heardest them; O God, thou becamest propitious to them, though thou didst take vengeance on all their devices.","searchKeywords":["lord","our","god","thou","heardest","them","becamest","propitious","though","didst","take","vengeance","all","their","devices"]},{"verseId":"brenton_psalms_98_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":98,"verse":9,"text":"Exalt ye the Lord our God, and worship at his holy mountain; for the Lord our God is holy.","searchKeywords":["exalt","the","lord","our","god","and","worship","his","holy","mountain","for"]}]