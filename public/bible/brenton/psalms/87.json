[{"verseId":"brenton_psalms_87_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":1,"text":"A song of a Psalm for the sons of Core for the end, upon Maeleth for responsive , of instruction for Æman the Israelite.","searchKeywords":["song","psalm","for","the","sons","core","end","upon","maeleth","responsive","instruction","man","israelite"]},{"verseId":"brenton_psalms_87_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":2,"text":"O Lord God of my salvation, I have cried by day and in the night before thee.","searchKeywords":["lord","god","salvation","have","cried","day","and","the","night","before","thee"]},{"verseId":"brenton_psalms_87_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":3,"text":"Let my prayer come in before thee; incline thine ear to my supplication, O Lord.","searchKeywords":["let","prayer","come","before","thee","incline","thine","ear","supplication","lord"]},{"verseId":"brenton_psalms_87_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":4,"text":"For my soul is filled with troubles, and my life has drawn nigh to Hades.","searchKeywords":["for","soul","filled","with","troubles","and","life","has","drawn","nigh","hades"]},{"verseId":"brenton_psalms_87_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":5,"text":"I have been reckoned with them that go down to the pit; I became as a man without help;","searchKeywords":["have","been","reckoned","with","them","that","down","the","pit","became","man","without","help"]},{"verseId":"brenton_psalms_87_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":6,"text":"free among the dead, as the slain ones cast out, who sleep in the tomb; whom thou rememberest no more; and they are rejected from thy hand.","searchKeywords":["free","among","the","dead","slain","ones","cast","out","who","sleep","tomb","whom","thou","rememberest","more","and","they","are","rejected","from","thy","hand"]},{"verseId":"brenton_psalms_87_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":7,"text":"They laid me in the lowest pit, in dark , and in the shadow of death.","searchKeywords":["they","laid","the","lowest","pit","dark","and","shadow","death"]},{"verseId":"brenton_psalms_87_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":8,"text":"Thy wrath has pressed heavily upon me, and thou hast brought upon me all thy billows. Pause.","searchKeywords":["thy","wrath","has","pressed","heavily","upon","and","thou","hast","brought","all","billows","pause"]},{"verseId":"brenton_psalms_87_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":9,"text":"Thou hast removed my acquaintance far from me; they have made me an abomination to themselves; I have been delivered up, and have not gone forth.","searchKeywords":["thou","hast","removed","acquaintance","far","from","they","have","made","abomination","themselves","been","delivered","and","not","gone","forth"]},{"verseId":"brenton_psalms_87_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":10,"text":"Mine eyes are dimmed from poverty; but I cried to thee, O Lord, all the day; I spread forth my hands to thee.","searchKeywords":["mine","eyes","are","dimmed","from","poverty","but","cried","thee","lord","all","the","day","spread","forth","hands"]},{"verseId":"brenton_psalms_87_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":11,"text":"Wilt thou work wonders for the dead? or shall physicians raise up, that they shall praise thee?","searchKeywords":["wilt","thou","work","wonders","for","the","dead","shall","physicians","raise","that","they","praise","thee"]},{"verseId":"brenton_psalms_87_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":12,"text":"Shall any one declare thy mercy in the tomb? and thy truth in destruction?","searchKeywords":["shall","any","one","declare","thy","mercy","the","tomb","and","truth","destruction"]},{"verseId":"brenton_psalms_87_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":13,"text":"Shall thy wonders be known in darkness? and thy righteousness in a forgotten land?","searchKeywords":["shall","thy","wonders","known","darkness","and","righteousness","forgotten","land"]},{"verseId":"brenton_psalms_87_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":14,"text":"But I cried to thee, O Lord; and in the morning shall my prayer prevent thee.","searchKeywords":["but","cried","thee","lord","and","the","morning","shall","prayer","prevent"]},{"verseId":"brenton_psalms_87_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":15,"text":"Wherefore, O Lord, dost thou reject my prayer, turn thy face away from me?","searchKeywords":["wherefore","lord","dost","thou","reject","prayer","turn","thy","face","away","from"]},{"verseId":"brenton_psalms_87_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":16,"text":"I am poor and in troubles from my youth; and having been exalted, I was brought low and into despair.","searchKeywords":["poor","and","troubles","from","youth","having","been","exalted","was","brought","low","into","despair"]},{"verseId":"brenton_psalms_87_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":17,"text":"Thy wrath has passed over me; and thy terrors have greatly disquieted me.","searchKeywords":["thy","wrath","has","passed","over","and","terrors","have","greatly","disquieted"]},{"verseId":"brenton_psalms_87_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":18,"text":"They compassed me like water; all the day they beset me together.","searchKeywords":["they","compassed","like","water","all","the","day","beset","together"]},{"verseId":"brenton_psalms_87_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":87,"verse":19,"text":"Thou hast put far from me friend, and mine acquaintances because of wretchedness.","searchKeywords":["thou","hast","put","far","from","friend","and","mine","acquaintances","because","wretchedness"]}]