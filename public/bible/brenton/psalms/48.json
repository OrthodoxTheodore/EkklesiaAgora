[{"verseId":"brenton_psalms_48_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":1,"text":"For the end, a Psalm for the sons of Core.","searchKeywords":["for","the","end","psalm","sons","core"]},{"verseId":"brenton_psalms_48_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":2,"text":"Hear these words, all ye nations, hearken, all ye that dwell upon the earth:","searchKeywords":["hear","these","words","all","nations","hearken","that","dwell","upon","the","earth"]},{"verseId":"brenton_psalms_48_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":3,"text":"both the sons of mean men, and sons of men; the rich and poor together.","searchKeywords":["both","the","sons","mean","men","and","rich","poor","together"]},{"verseId":"brenton_psalms_48_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":4,"text":"My mouth shall speak of wisdom; and the meditation of my heart shall bring understanding.","searchKeywords":["mouth","shall","speak","wisdom","and","the","meditation","heart","bring","understanding"]},{"verseId":"brenton_psalms_48_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":5,"text":"I will incline mine ear to a parable: I will open my riddle on the harp.","searchKeywords":["will","incline","mine","ear","parable","open","riddle","the","harp"]},{"verseId":"brenton_psalms_48_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":6,"text":"Wherefore should I fear in the evil day? the iniquity of my heel shall compass me.","searchKeywords":["wherefore","should","fear","the","evil","day","iniquity","heel","shall","compass"]},{"verseId":"brenton_psalms_48_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":7,"text":"They that trust in their strength, and boast themselves in the multitude of their wealth—","searchKeywords":["they","that","trust","their","strength","and","boast","themselves","the","multitude","wealth"]},{"verseId":"brenton_psalms_48_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":8,"text":"A brother does not redeem, shall a man redeem? he shall not give to God a ransom for himself,","searchKeywords":["brother","does","not","redeem","shall","man","give","god","ransom","for","himself"]},{"verseId":"brenton_psalms_48_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":9,"text":"or the price of the redemption of his soul, though he labour for ever,","searchKeywords":["the","price","redemption","his","soul","though","labour","for","ever"]},{"verseId":"brenton_psalms_48_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":10,"text":"and live to the end, that he should not see corruption.","searchKeywords":["and","live","the","end","that","should","not","see","corruption"]},{"verseId":"brenton_psalms_48_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":11,"text":"When he shall see wise men dying, the fool and the senseless one shall perish together; and they shall leave their wealth to strangers.","searchKeywords":["when","shall","see","wise","men","dying","the","fool","and","senseless","one","perish","together","they","leave","their","wealth","strangers"]},{"verseId":"brenton_psalms_48_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":12,"text":"And their sepulchres are their houses for ever, their tabernacles to all generations: they have called their lands after their own names.","searchKeywords":["and","their","sepulchres","are","houses","for","ever","tabernacles","all","generations","they","have","called","lands","after","own","names"]},{"verseId":"brenton_psalms_48_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":13,"text":"And man being in honour, understands not: he is compared to the senseless cattle, and is like to them.","searchKeywords":["and","man","being","honour","understands","not","compared","the","senseless","cattle","like","them"]},{"verseId":"brenton_psalms_48_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":14,"text":"This their way is an offence to them: yet afterwards men will commend their sayings. Pause.","searchKeywords":["this","their","way","offence","them","yet","afterwards","men","will","commend","sayings","pause"]},{"verseId":"brenton_psalms_48_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":15,"text":"They have laid as sheep in Hades; death shall feed on them; and the upright shall have dominion over them in the morning, and their help shall fail in Hades from their glory.","searchKeywords":["they","have","laid","sheep","hades","death","shall","feed","them","and","the","upright","dominion","over","morning","their","help","fail","from","glory"]},{"verseId":"brenton_psalms_48_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":16,"text":"But God shall deliver my soul from the power of Hades, when he shall receive me. Pause.","searchKeywords":["but","god","shall","deliver","soul","from","the","power","hades","when","receive","pause"]},{"verseId":"brenton_psalms_48_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":17,"text":"Fear not when a man is enriched, and when the glory of his house is increased.","searchKeywords":["fear","not","when","man","enriched","and","the","glory","his","house","increased"]},{"verseId":"brenton_psalms_48_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":18,"text":"For he shall take nothing when he dies; neither shall his glory descend with him.","searchKeywords":["for","shall","take","nothing","when","dies","neither","his","glory","descend","with","him"]},{"verseId":"brenton_psalms_48_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":19,"text":"For his soul shall be blessed in his life: he shall give thanks to thee when thou dost well to him.","searchKeywords":["for","his","soul","shall","blessed","life","give","thanks","thee","when","thou","dost","well","him"]},{"verseId":"brenton_psalms_48_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":20,"text":"he shall go in to the generation of his fathers; he shall never see light.","searchKeywords":["shall","the","generation","his","fathers","never","see","light"]},{"verseId":"brenton_psalms_48_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":48,"verse":21,"text":"Man that is in honour, understands not: he is compared to the senseless cattle, and is like them.","searchKeywords":["man","that","honour","understands","not","compared","the","senseless","cattle","and","like","them"]}]