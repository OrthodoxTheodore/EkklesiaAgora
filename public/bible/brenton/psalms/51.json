[{"verseId":"brenton_psalms_51_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":51,"verse":1,"text":"For the end, of instruction by David,","searchKeywords":["for","the","end","instruction","david"]},{"verseId":"brenton_psalms_51_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":51,"verse":2,"text":"when Doec the Idumean came and told Saul, and said to him, David is gone to the house of Abimelech.","searchKeywords":["when","doec","the","idumean","came","and","told","saul","said","him","david","gone","house","abimelech"]},{"verseId":"brenton_psalms_51_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":51,"verse":3,"text":"Why dost thou, O mighty man, boast of iniquity in mischief? All the day","searchKeywords":["why","dost","thou","mighty","man","boast","iniquity","mischief","all","the","day"]},{"verseId":"brenton_psalms_51_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":51,"verse":4,"text":"thy tongue has devised unrighteousness; like a sharpened razor thou hast wrought deceit.","searchKeywords":["thy","tongue","has","devised","unrighteousness","like","sharpened","razor","thou","hast","wrought","deceit"]},{"verseId":"brenton_psalms_51_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":51,"verse":5,"text":"Thou hast loved wickedness more than goodness; unrighteousness better than to speak righteousness. Pause.","searchKeywords":["thou","hast","loved","wickedness","more","than","goodness","unrighteousness","better","speak","righteousness","pause"]},{"verseId":"brenton_psalms_51_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":51,"verse":6,"text":"Thou hast loved all words of destruction, a deceitful tongue.","searchKeywords":["thou","hast","loved","all","words","destruction","deceitful","tongue"]},{"verseId":"brenton_psalms_51_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":51,"verse":7,"text":"Therefore may God destroy thee for ever, may he pluck thee up and utterly remove thee from dwelling, and thy root from the land of the living. Pause.","searchKeywords":["therefore","may","god","destroy","thee","for","ever","pluck","and","utterly","remove","from","dwelling","thy","root","the","land","living","pause"]},{"verseId":"brenton_psalms_51_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":51,"verse":8,"text":"And the righteous shall see, and fear, and shall laugh at him, and say,","searchKeywords":["and","the","righteous","shall","see","fear","laugh","him","say"]},{"verseId":"brenton_psalms_51_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":51,"verse":9,"text":"Behold the man who made not God his help; but trusted in the abundance of his wealth, and strengthened himself in his vanity.","searchKeywords":["behold","the","man","who","made","not","god","his","help","but","trusted","abundance","wealth","and","strengthened","himself","vanity"]},{"verseId":"brenton_psalms_51_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":51,"verse":10,"text":"But I am as a fruitful olive in the house of God: I have trusted in the mercy of God for ever, even for evermore.","searchKeywords":["but","fruitful","olive","the","house","god","have","trusted","mercy","for","ever","even","evermore"]},{"verseId":"brenton_psalms_51_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":51,"verse":11,"text":"I will give thanks to thee for ever, for thou hast done : and I will wait on thy name; for good before thy saints.","searchKeywords":["will","give","thanks","thee","for","ever","thou","hast","done","and","wait","thy","name","good","before","saints"]}]