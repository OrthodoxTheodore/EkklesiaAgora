[{"verseId":"brenton_psalms_78_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":78,"verse":1,"text":"A Psalm for Asaph.","searchKeywords":["psalm","for","asaph"]},{"verseId":"brenton_psalms_78_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":78,"verse":2,"text":"They have given the dead bodies of thy servants food for the birds of the sky, the flesh of thy holy ones for the wild beasts of the earth.","searchKeywords":["they","have","given","the","dead","bodies","thy","servants","food","for","birds","sky","flesh","holy","ones","wild","beasts","earth"]},{"verseId":"brenton_psalms_78_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":78,"verse":3,"text":"They have shed their blood as water, round about Jerusalem; and there was none to bury .","searchKeywords":["they","have","shed","their","blood","water","round","about","jerusalem","and","there","was","none","bury"]},{"verseId":"brenton_psalms_78_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":78,"verse":4,"text":"We are become a reproach to our neighbours, a scorn and derision to them round about us.","searchKeywords":["are","become","reproach","our","neighbours","scorn","and","derision","them","round","about"]},{"verseId":"brenton_psalms_78_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":78,"verse":5,"text":"How long, O Lord? wilt thou be angry for ever? shall thy jealousy burn like fire?","searchKeywords":["how","long","lord","wilt","thou","angry","for","ever","shall","thy","jealousy","burn","like","fire"]},{"verseId":"brenton_psalms_78_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":78,"verse":6,"text":"Pour out thy wrath upon the heathen that have not known thee, and upon the kingdoms which have not called upon thy name.","searchKeywords":["pour","out","thy","wrath","upon","the","heathen","that","have","not","known","thee","and","kingdoms","which","called","name"]},{"verseId":"brenton_psalms_78_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":78,"verse":7,"text":"For they have devoured Jacob, and laid his place waste.","searchKeywords":["for","they","have","devoured","jacob","and","laid","his","place","waste"]},{"verseId":"brenton_psalms_78_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":78,"verse":8,"text":"Remember not our old transgressions; let thy tender mercies speedily prevent us; for we are greatly impoverished.","searchKeywords":["remember","not","our","old","transgressions","let","thy","tender","mercies","speedily","prevent","for","are","greatly","impoverished"]},{"verseId":"brenton_psalms_78_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":78,"verse":9,"text":"Help us, O God our Saviour; for the glory of thy name, O Lord, deliver us; and be merciful to our sins, for thy name's sake.","searchKeywords":["help","god","our","saviour","for","the","glory","thy","name","lord","deliver","and","merciful","sins","sake"]},{"verseId":"brenton_psalms_78_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":78,"verse":10,"text":"Lest haply they should say among the heathen, Where is their God? and let the avenging of thy servants' blood that has been shed be known among the heathen before our eyes.","searchKeywords":["lest","haply","they","should","say","among","the","heathen","where","their","god","and","let","avenging","thy","servants","blood","that","has","been","shed","known","before","our","eyes"]},{"verseId":"brenton_psalms_78_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":78,"verse":11,"text":"Let the groaning of the prisoners come in before thee; according to the greatness of thine arm preserve the sons of the slain ones.","searchKeywords":["let","the","groaning","prisoners","come","before","thee","according","greatness","thine","arm","preserve","sons","slain","ones"]},{"verseId":"brenton_psalms_78_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":78,"verse":12,"text":"Repay to our neighbours sevenfold into their bosom their reproach, with which they have reproached thee, O Lord.","searchKeywords":["repay","our","neighbours","sevenfold","into","their","bosom","reproach","with","which","they","have","reproached","thee","lord"]},{"verseId":"brenton_psalms_78_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":78,"verse":13,"text":"For we are thy people and the sheep of thy pasture; we will give thee thanks for ever; we will declare thy praise throughout all generations.","searchKeywords":["for","are","thy","people","and","the","sheep","pasture","will","give","thee","thanks","ever","declare","praise","throughout","all","generations"]}]