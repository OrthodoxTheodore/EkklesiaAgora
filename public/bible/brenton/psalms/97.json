[{"verseId":"brenton_psalms_97_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":97,"verse":1,"text":"A Psalm of David.","searchKeywords":["psalm","david"]},{"verseId":"brenton_psalms_97_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":97,"verse":2,"text":"The Lord has made known his salvation, he has revealed his righteousness in the sight of the nations.","searchKeywords":["the","lord","has","made","known","his","salvation","revealed","righteousness","sight","nations"]},{"verseId":"brenton_psalms_97_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":97,"verse":3,"text":"He has remembered his mercy to Jacob, and his truth to the house of Israel; all the ends of the earth have seen the salvation of our God.","searchKeywords":["has","remembered","his","mercy","jacob","and","truth","the","house","israel","all","ends","earth","have","seen","salvation","our","god"]},{"verseId":"brenton_psalms_97_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":97,"verse":4,"text":"Shout to God, all the earth; sing, and exult, and sing psalms.","searchKeywords":["shout","god","all","the","earth","sing","and","exult","psalms"]},{"verseId":"brenton_psalms_97_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":97,"verse":5,"text":"Sing to the Lord with a harp, with a harp, and the voice of a psalm.","searchKeywords":["sing","the","lord","with","harp","and","voice","psalm"]},{"verseId":"brenton_psalms_97_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":97,"verse":6,"text":"With trumpets of metal, and the sound of a trumpet of horn make a joyful noise to the Lord before the king.","searchKeywords":["with","trumpets","metal","and","the","sound","trumpet","horn","make","joyful","noise","lord","before","king"]},{"verseId":"brenton_psalms_97_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":97,"verse":7,"text":"Let the sea be moved, and the fulness of it; the world, and they that dwell in it.","searchKeywords":["let","the","sea","moved","and","fulness","world","they","that","dwell"]},{"verseId":"brenton_psalms_97_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":97,"verse":8,"text":"The rivers shall clap their hands together; the mountains shall exult.","searchKeywords":["the","rivers","shall","clap","their","hands","together","mountains","exult"]},{"verseId":"brenton_psalms_97_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":97,"verse":9,"text":"For he is come to judge the earth; he shall judge the world in righteousness, and the nations in uprightness.","searchKeywords":["for","come","judge","the","earth","shall","world","righteousness","and","nations","uprightness"]}]