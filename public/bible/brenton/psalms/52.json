[{"verseId":"brenton_psalms_52_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":52,"verse":1,"text":"For the end, of David upon Maeleth, of instruction.","searchKeywords":["for","the","end","david","upon","maeleth","instruction"]},{"verseId":"brenton_psalms_52_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":52,"verse":2,"text":"The fool has said in his heart, There is no God. They have corrupted , and become abominable in iniquities: there is none that does good.","searchKeywords":["the","fool","has","said","his","heart","there","god","they","have","corrupted","and","become","abominable","iniquities","none","that","does","good"]},{"verseId":"brenton_psalms_52_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":52,"verse":3,"text":"God looked down from heaven upon the sons of men, to see if there were any that understood, or sought after God.","searchKeywords":["god","looked","down","from","heaven","upon","the","sons","men","see","there","were","any","that","understood","sought","after"]},{"verseId":"brenton_psalms_52_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":52,"verse":4,"text":"They have all gone out of the way, they are together become unprofitable; there is none that does good, there is not even one.","searchKeywords":["they","have","all","gone","out","the","way","are","together","become","unprofitable","there","none","that","does","good","not","even","one"]},{"verseId":"brenton_psalms_52_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":52,"verse":5,"text":"Will none of the workers of iniquity know, who devour my people as they would eat bread? they have not called upon God. There were they greatly afraid, where there was no fear:","searchKeywords":["will","none","the","workers","iniquity","know","who","devour","people","they","would","eat","bread","have","not","called","upon","god","there","were","greatly","afraid","where","was","fear"]},{"verseId":"brenton_psalms_52_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":52,"verse":6,"text":"for God has scattered the bones of the men-pleasers; they were ashamed, for God despised them.","searchKeywords":["for","god","has","scattered","the","bones","men","pleasers","they","were","ashamed","despised","them"]},{"verseId":"brenton_psalms_52_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":52,"verse":7,"text":"Who will bring the salvation of Israel out of Sion? When the Lord turns the captivity of his people, Jacob shall exult, and Israel shall be glad.","searchKeywords":["who","will","bring","the","salvation","israel","out","sion","when","lord","turns","captivity","his","people","jacob","shall","exult","and","glad"]}]