[{"verseId":"brenton_psalms_41_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":41,"verse":1,"text":"For the end, for instruction, for the sons of Core.","searchKeywords":["for","the","end","instruction","sons","core"]},{"verseId":"brenton_psalms_41_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":41,"verse":2,"text":"As the hart earnestly desires the fountains of water, so my soul earnestly longs for thee, O God.","searchKeywords":["the","hart","earnestly","desires","fountains","water","soul","longs","for","thee","god"]},{"verseId":"brenton_psalms_41_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":41,"verse":3,"text":"My soul has thirsted for the living God: when shall I come and appear before God?","searchKeywords":["soul","has","thirsted","for","the","living","god","when","shall","come","and","appear","before"]},{"verseId":"brenton_psalms_41_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":41,"verse":4,"text":"My tears have been bread to me day and night, while they daily said to me, Where is thy God?","searchKeywords":["tears","have","been","bread","day","and","night","while","they","daily","said","where","thy","god"]},{"verseId":"brenton_psalms_41_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":41,"verse":5,"text":"I remembered these things, and poured out my soul in me, for I will go to the place of thy wondrous tabernacle, to the house of God, with a voice of exultation and thanksgiving and of the sound of those who keep festival.","searchKeywords":["remembered","these","things","and","poured","out","soul","for","will","the","place","thy","wondrous","tabernacle","house","god","with","voice","exultation","thanksgiving","sound","those","who","keep","festival"]},{"verseId":"brenton_psalms_41_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":41,"verse":6,"text":"Wherefore art thou very sad, O my soul? and wherefore dost thou trouble me? hope in God; for I will give thanks to him; the salvation of my countenance.","searchKeywords":["wherefore","art","thou","very","sad","soul","and","dost","trouble","hope","god","for","will","give","thanks","him","the","salvation","countenance"]},{"verseId":"brenton_psalms_41_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":41,"verse":7,"text":"O my God, my soul has been troubled within me: therefore will I remember thee from the land of Jordan, and of the Ermonites, from the little hill.","searchKeywords":["god","soul","has","been","troubled","within","therefore","will","remember","thee","from","the","land","jordan","and","ermonites","little","hill"]},{"verseId":"brenton_psalms_41_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":41,"verse":8,"text":"Deep calls to deep at the voice of thy cataracts: all thy billows and thy waves have gone over me.","searchKeywords":["deep","calls","the","voice","thy","cataracts","all","billows","and","waves","have","gone","over"]},{"verseId":"brenton_psalms_41_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":41,"verse":9,"text":"By day the Lord will command his mercy, and manifest by night: with me prayer to the God of my life.","searchKeywords":["day","the","lord","will","command","his","mercy","and","manifest","night","with","prayer","god","life"]},{"verseId":"brenton_psalms_41_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":41,"verse":10,"text":"I will say to God, Thou art my helper; why hast thou forgotten me? wherefore do I go sad of countenance, while the enemy oppresses ?","searchKeywords":["will","say","god","thou","art","helper","why","hast","forgotten","wherefore","sad","countenance","while","the","enemy","oppresses"]},{"verseId":"brenton_psalms_41_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":41,"verse":11,"text":"While my bones were breaking, they that afflicted me reproached me; while they said to me daily, Where is thy God?","searchKeywords":["while","bones","were","breaking","they","that","afflicted","reproached","said","daily","where","thy","god"]},{"verseId":"brenton_psalms_41_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":41,"verse":12,"text":"Wherefore art thou very sad, O my soul? and wherefore dost thou trouble me? hope in God; for I will give thanks to him; the health of my countenance, and my God.","searchKeywords":["wherefore","art","thou","very","sad","soul","and","dost","trouble","hope","god","for","will","give","thanks","him","the","health","countenance"]}]