[{"verseId":"brenton_psalms_113_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":1,"text":"Alleluia.","searchKeywords":["alleluia"]},{"verseId":"brenton_psalms_113_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":2,"text":"Judea became his sanctuary, Israel his dominion.","searchKeywords":["judea","became","his","sanctuary","israel","dominion"]},{"verseId":"brenton_psalms_113_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":3,"text":"The sea saw and fled: Jordan was turned back.","searchKeywords":["the","sea","saw","and","fled","jordan","was","turned","back"]},{"verseId":"brenton_psalms_113_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":4,"text":"The mountains skipped like rams, and the hills like lambs.","searchKeywords":["the","mountains","skipped","like","rams","and","hills","lambs"]},{"verseId":"brenton_psalms_113_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":5,"text":"What thee, O sea, that thou fleddest? and thou Jordan, that thou wast turned back?","searchKeywords":["what","thee","sea","that","thou","fleddest","and","jordan","wast","turned","back"]},{"verseId":"brenton_psalms_113_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":6,"text":"mountains, that ye skipped like rams, and hills, like lambs?","searchKeywords":["mountains","that","skipped","like","rams","and","hills","lambs"]},{"verseId":"brenton_psalms_113_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":7,"text":"The earth trembled at the presence of the Lord, at the presence of the God of Jacob;","searchKeywords":["the","earth","trembled","presence","lord","god","jacob"]},{"verseId":"brenton_psalms_113_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":8,"text":"who turned the rock into pools of water, and the flint into fountains of water.","searchKeywords":["who","turned","the","rock","into","pools","water","and","flint","fountains"]},{"verseId":"brenton_psalms_113_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":9,"text":"Not to us, O Lord, not to us, but to thy name give glory, because of thy mercy and thy truth;","searchKeywords":["not","lord","but","thy","name","give","glory","because","mercy","and","truth"]},{"verseId":"brenton_psalms_113_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":10,"text":"lest at any time the nations should say, Where is their God?","searchKeywords":["lest","any","time","the","nations","should","say","where","their","god"]},{"verseId":"brenton_psalms_113_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":11,"text":"But our God has done in heaven and on earth, whatsoever he has pleased.","searchKeywords":["but","our","god","has","done","heaven","and","earth","whatsoever","pleased"]},{"verseId":"brenton_psalms_113_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":12,"text":"The idols of the nations are silver and gold, the works of men's hands.","searchKeywords":["the","idols","nations","are","silver","and","gold","works","men","hands"]},{"verseId":"brenton_psalms_113_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":13,"text":"They have a mouth, but they cannot speak; they have eyes, but they cannot see:","searchKeywords":["they","have","mouth","but","cannot","speak","eyes","see"]},{"verseId":"brenton_psalms_113_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":14,"text":"they have ears, but they cannot hear; they have noses, but they cannot smell;","searchKeywords":["they","have","ears","but","cannot","hear","noses","smell"]},{"verseId":"brenton_psalms_113_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":15,"text":"they have hands, but they cannot handle; they have feet, but they cannot walk: they cannot speak through their throat.","searchKeywords":["they","have","hands","but","cannot","handle","feet","walk","speak","through","their","throat"]},{"verseId":"brenton_psalms_113_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":16,"text":"Let those that make them become like to them, and all who trust in them.","searchKeywords":["let","those","that","make","them","become","like","and","all","who","trust"]},{"verseId":"brenton_psalms_113_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":17,"text":"The house of Israel trusts in the Lord: he is their helper and defender.","searchKeywords":["the","house","israel","trusts","lord","their","helper","and","defender"]},{"verseId":"brenton_psalms_113_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":18,"text":"The house of Aaron trusts in the Lord: he is their helper and defender.","searchKeywords":["the","house","aaron","trusts","lord","their","helper","and","defender"]},{"verseId":"brenton_psalms_113_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":19,"text":"They that fear the Lord trust in the Lord: he is their helper and defender.","searchKeywords":["they","that","fear","the","lord","trust","their","helper","and","defender"]},{"verseId":"brenton_psalms_113_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":20,"text":"The Lord has remembered us, and blessed us: he has blessed the house of Israel, he has blessed the house of Aaron.","searchKeywords":["the","lord","has","remembered","and","blessed","house","israel","aaron"]},{"verseId":"brenton_psalms_113_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":21,"text":"He has blessed them that fear the Lord, both small and great.","searchKeywords":["has","blessed","them","that","fear","the","lord","both","small","and","great"]},{"verseId":"brenton_psalms_113_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":22,"text":"The Lord add to you and to your children.","searchKeywords":["the","lord","add","you","and","your","children"]},{"verseId":"brenton_psalms_113_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":23,"text":"Blessed are ye of the Lord, who made the heaven and the earth.","searchKeywords":["blessed","are","the","lord","who","made","heaven","and","earth"]},{"verseId":"brenton_psalms_113_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":24,"text":"The heaven of heavens to the Lord: but he has given the earth to the sons of men.","searchKeywords":["the","heaven","heavens","lord","but","has","given","earth","sons","men"]},{"verseId":"brenton_psalms_113_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":25,"text":"The dead shall not praise thee, O Lord, nor any that go down to Hades.","searchKeywords":["the","dead","shall","not","praise","thee","lord","nor","any","that","down","hades"]},{"verseId":"brenton_psalms_113_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":113,"verse":26,"text":"But we, the living, will bless the Lord, from henceforth and for ever.","searchKeywords":["but","the","living","will","bless","lord","from","henceforth","and","for","ever"]}]