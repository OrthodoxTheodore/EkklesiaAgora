[{"verseId":"brenton_psalms_40_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":1,"text":"For the end, a Psalm of David.","searchKeywords":["for","the","end","psalm","david"]},{"verseId":"brenton_psalms_40_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":2,"text":"Blessed who thinks on the poor and needy: the Lord shall deliver him in an evil day.","searchKeywords":["blessed","who","thinks","the","poor","and","needy","lord","shall","deliver","him","evil","day"]},{"verseId":"brenton_psalms_40_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":3,"text":"May the Lord preserve him and keep him alive, and bless him on the earth, and not deliver him into the hands of his enemy.","searchKeywords":["may","the","lord","preserve","him","and","keep","alive","bless","earth","not","deliver","into","hands","his","enemy"]},{"verseId":"brenton_psalms_40_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":4,"text":"May the Lord help him upon the bed of his pain; thou hast made all his bed in his sickness.","searchKeywords":["may","the","lord","help","him","upon","bed","his","pain","thou","hast","made","all","sickness"]},{"verseId":"brenton_psalms_40_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":5,"text":"I said, O Lord, have mercy upon me; heal my soul; for I have sinned against thee.","searchKeywords":["said","lord","have","mercy","upon","heal","soul","for","sinned","against","thee"]},{"verseId":"brenton_psalms_40_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":6,"text":"Mine enemies have spoken evil against me, , When shall he die, and his name perish?","searchKeywords":["mine","enemies","have","spoken","evil","against","when","shall","die","and","his","name","perish"]},{"verseId":"brenton_psalms_40_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":7,"text":"And if he came to see , his heart spoke vainly; he gathered iniquity to himself; he went forth and spoke in like manner.","searchKeywords":["and","came","see","his","heart","spoke","vainly","gathered","iniquity","himself","went","forth","like","manner"]},{"verseId":"brenton_psalms_40_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":8,"text":"All my enemies whispered against me; against me they devised my hurt.","searchKeywords":["all","enemies","whispered","against","they","devised","hurt"]},{"verseId":"brenton_psalms_40_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":9,"text":"They denounced a wicked word against me, , Now that he lies, shall he not rise up again?","searchKeywords":["they","denounced","wicked","word","against","now","that","lies","shall","not","rise","again"]},{"verseId":"brenton_psalms_40_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":10,"text":"For even the man of my peace, in whom I trusted, who ate my bread, lifted up heel against me.","searchKeywords":["for","even","the","man","peace","whom","trusted","who","ate","bread","lifted","heel","against"]},{"verseId":"brenton_psalms_40_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":11,"text":"But thou, O Lord, have compassion upon me, and raise me up, and I shall requite them.","searchKeywords":["but","thou","lord","have","compassion","upon","and","raise","shall","requite","them"]},{"verseId":"brenton_psalms_40_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":12,"text":"By this I know that thou hast delighted in me, because mine enemy shall not rejoice over me.","searchKeywords":["this","know","that","thou","hast","delighted","because","mine","enemy","shall","not","rejoice","over"]},{"verseId":"brenton_psalms_40_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":13,"text":"But thou didst help me because of innocence, and hast established me before thee for ever.","searchKeywords":["but","thou","didst","help","because","innocence","and","hast","established","before","thee","for","ever"]},{"verseId":"brenton_psalms_40_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":40,"verse":14,"text":"Blessed the Lord God of Israel from everlasting, and to everlasting. So be it, so be it.","searchKeywords":["blessed","the","lord","god","israel","from","everlasting","and"]}]