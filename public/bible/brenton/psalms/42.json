[{"verseId":"brenton_psalms_42_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":42,"verse":1,"text":"A Psalm of David.","searchKeywords":["psalm","david"]},{"verseId":"brenton_psalms_42_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":42,"verse":2,"text":"For thou, O God, art my strength: wherefore hast thou cast me off? and why do I go sad of countenance, while the enemy oppresses ?","searchKeywords":["for","thou","god","art","strength","wherefore","hast","cast","off","and","why","sad","countenance","while","the","enemy","oppresses"]},{"verseId":"brenton_psalms_42_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":42,"verse":3,"text":"Send forth thy light and thy truth: they have led me, and brought me to thy holy mountain, and to thy tabernacles.","searchKeywords":["send","forth","thy","light","and","truth","they","have","led","brought","holy","mountain","tabernacles"]},{"verseId":"brenton_psalms_42_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":42,"verse":4,"text":"And I will go in to the altar of God, to God who gladdens my youth: I will give thanks to thee on the harp, O God, my God.","searchKeywords":["and","will","the","altar","god","who","gladdens","youth","give","thanks","thee","harp"]},{"verseId":"brenton_psalms_42_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":42,"verse":5,"text":"Wherefore art thou very sad, O my soul? and wherefore dost thou trouble me? Hope in God; for I will give thanks to him, the health of my countenance, my God.","searchKeywords":["wherefore","art","thou","very","sad","soul","and","dost","trouble","hope","god","for","will","give","thanks","him","the","health","countenance"]}]