[{"verseId":"brenton_psalms_77_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":1,"text":"of instruction for Asaph.","searchKeywords":["instruction","for","asaph"]},{"verseId":"brenton_psalms_77_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":2,"text":"I will open my mouth in parables: I will utter dark sayings from the beginning.","searchKeywords":["will","open","mouth","parables","utter","dark","sayings","from","the","beginning"]},{"verseId":"brenton_psalms_77_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":3,"text":"All which we have heard and known, and our fathers have declared to us.","searchKeywords":["all","which","have","heard","and","known","our","fathers","declared"]},{"verseId":"brenton_psalms_77_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":4,"text":"They were not hid from their children to a second generation; declaring the praises of the Lord, and his mighty acts, and his wonders which he wrought.","searchKeywords":["they","were","not","hid","from","their","children","second","generation","declaring","the","praises","lord","and","his","mighty","acts","wonders","which","wrought"]},{"verseId":"brenton_psalms_77_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":5,"text":"And he raised up a testimony in Jacob, and appointed a law in Israel, which he commanded our fathers, to make it known to their children:","searchKeywords":["and","raised","testimony","jacob","appointed","law","israel","which","commanded","our","fathers","make","known","their","children"]},{"verseId":"brenton_psalms_77_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":6,"text":"that another generation might know, even the sons which should be born; and they should arise and declare them to their children.","searchKeywords":["that","another","generation","might","know","even","the","sons","which","should","born","and","they","arise","declare","them","their","children"]},{"verseId":"brenton_psalms_77_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":7,"text":"That they might set their hope on God, and not forget the works of God, but diligently seek his commandments.","searchKeywords":["that","they","might","set","their","hope","god","and","not","forget","the","works","but","diligently","seek","his","commandments"]},{"verseId":"brenton_psalms_77_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":8,"text":"That they should not be as their fathers, a perverse and provoking generation; a generation which set not its heart aright, and its spirit was not steadfast with God.","searchKeywords":["that","they","should","not","their","fathers","perverse","and","provoking","generation","which","set","its","heart","aright","spirit","was","steadfast","with","god"]},{"verseId":"brenton_psalms_77_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":9,"text":"The children of Ephraim, bending and shooting the bow, turned in the day of battle.","searchKeywords":["the","children","ephraim","bending","and","shooting","bow","turned","day","battle"]},{"verseId":"brenton_psalms_77_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":10,"text":"They kept not the covenant of God, and would not walk in his law.","searchKeywords":["they","kept","not","the","covenant","god","and","would","walk","his","law"]},{"verseId":"brenton_psalms_77_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":11,"text":"And they forgot his benefits, and his miracles which he shewed them;","searchKeywords":["and","they","forgot","his","benefits","miracles","which","shewed","them"]},{"verseId":"brenton_psalms_77_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":12,"text":"the miracles which he wrought before their fathers, in the land of Egypt, in the plain of Tanes.","searchKeywords":["the","miracles","which","wrought","before","their","fathers","land","egypt","plain","tanes"]},{"verseId":"brenton_psalms_77_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":13,"text":"He clave the sea, and led them through: he made the waters to stand as a bottle.","searchKeywords":["clave","the","sea","and","led","them","through","made","waters","stand","bottle"]},{"verseId":"brenton_psalms_77_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":14,"text":"And he guided them with a cloud by day, and all the night with a light of fire.","searchKeywords":["and","guided","them","with","cloud","day","all","the","night","light","fire"]},{"verseId":"brenton_psalms_77_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":15,"text":"He clave a rock in the wilderness, and made them drink as in a great deep.","searchKeywords":["clave","rock","the","wilderness","and","made","them","drink","great","deep"]},{"verseId":"brenton_psalms_77_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":16,"text":"And he brought water out of the rock, and caused waters to flow down as rivers.","searchKeywords":["and","brought","water","out","the","rock","caused","waters","flow","down","rivers"]},{"verseId":"brenton_psalms_77_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":17,"text":"And they sinned yet more against him; they provoked the Most High in the wilderness.","searchKeywords":["and","they","sinned","yet","more","against","him","provoked","the","most","high","wilderness"]},{"verseId":"brenton_psalms_77_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":18,"text":"And they tempted God in their hearts, in asking meat for their souls.","searchKeywords":["and","they","tempted","god","their","hearts","asking","meat","for","souls"]},{"verseId":"brenton_psalms_77_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":19,"text":"They spoke also against God, and said, Will God be able to prepare a table in the wilderness?","searchKeywords":["they","spoke","also","against","god","and","said","will","able","prepare","table","the","wilderness"]},{"verseId":"brenton_psalms_77_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":20,"text":"Forasmuch as he smote the rock, and the waters flowed, and the torrents ran abundantly; will he be able also to give bread, or prepare a table for his people?","searchKeywords":["forasmuch","smote","the","rock","and","waters","flowed","torrents","ran","abundantly","will","able","also","give","bread","prepare","table","for","his","people"]},{"verseId":"brenton_psalms_77_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":21,"text":"Therefore the Lord heard, and was provoked: and fire was kindled in Jacob, and wrath went up against Israel.","searchKeywords":["therefore","the","lord","heard","and","was","provoked","fire","kindled","jacob","wrath","went","against","israel"]},{"verseId":"brenton_psalms_77_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":22,"text":"Because they believed not in God, and trusted not in his salvation.","searchKeywords":["because","they","believed","not","god","and","trusted","his","salvation"]},{"verseId":"brenton_psalms_77_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":23,"text":"Yet he commanded the clouds from above, and opened the doors of heaven,","searchKeywords":["yet","commanded","the","clouds","from","above","and","opened","doors","heaven"]},{"verseId":"brenton_psalms_77_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":24,"text":"and rained upon them manna to eat, and gave them the bread of heaven.","searchKeywords":["and","rained","upon","them","manna","eat","gave","the","bread","heaven"]},{"verseId":"brenton_psalms_77_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":25,"text":"Man ate angels' bread; he sent them provision to the full.","searchKeywords":["man","ate","angels","bread","sent","them","provision","the","full"]},{"verseId":"brenton_psalms_77_26","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":26,"text":"He removed the south wind from heaven; and by his might he brought in the south-west wind.","searchKeywords":["removed","the","south","wind","from","heaven","and","his","might","brought","west"]},{"verseId":"brenton_psalms_77_27","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":27,"text":"And he rained upon them flesh like dust, and feathered birds like the sand of the seas.","searchKeywords":["and","rained","upon","them","flesh","like","dust","feathered","birds","the","sand","seas"]},{"verseId":"brenton_psalms_77_28","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":28,"text":"And they fell into the midst of their camp, round about their tents.","searchKeywords":["and","they","fell","into","the","midst","their","camp","round","about","tents"]},{"verseId":"brenton_psalms_77_29","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":29,"text":"So they ate, and were completely filled; and he gave them their desire.","searchKeywords":["they","ate","and","were","completely","filled","gave","them","their","desire"]},{"verseId":"brenton_psalms_77_30","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":30,"text":"They were not disappointed of their desire: when their food was yet in their mouth,","searchKeywords":["they","were","not","disappointed","their","desire","when","food","was","yet","mouth"]},{"verseId":"brenton_psalms_77_31","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":31,"text":"then the indignation of God rose up against them, and slew the fattest of them, and overthrew the choice men of Israel.","searchKeywords":["then","the","indignation","god","rose","against","them","and","slew","fattest","overthrew","choice","men","israel"]},{"verseId":"brenton_psalms_77_32","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":32,"text":"In the midst of all this they sinned yet more, and believed not his miracles.","searchKeywords":["the","midst","all","this","they","sinned","yet","more","and","believed","not","his","miracles"]},{"verseId":"brenton_psalms_77_33","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":33,"text":"And their days were consumed in vanity, and their years with anxiety.","searchKeywords":["and","their","days","were","consumed","vanity","years","with","anxiety"]},{"verseId":"brenton_psalms_77_34","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":34,"text":"When he slew them, they sought him: and they returned and called betimes upon God.","searchKeywords":["when","slew","them","they","sought","him","and","returned","called","betimes","upon","god"]},{"verseId":"brenton_psalms_77_35","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":35,"text":"And they remembered that God was their helper, and the most high God was their redeemer.","searchKeywords":["and","they","remembered","that","god","was","their","helper","the","most","high","redeemer"]},{"verseId":"brenton_psalms_77_36","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":36,"text":"Yet they loved him with their mouth, and lied to him with their tongue.","searchKeywords":["yet","they","loved","him","with","their","mouth","and","lied","tongue"]},{"verseId":"brenton_psalms_77_37","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":37,"text":"For their heart not right with him, neither were they steadfast in his covenant.","searchKeywords":["for","their","heart","not","right","with","him","neither","were","they","steadfast","his","covenant"]},{"verseId":"brenton_psalms_77_38","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":38,"text":"But he is compassionate, and will forgive their sins, and will not destroy : yea, he will frequently turn away his wrath, and will not kindle all his anger.","searchKeywords":["but","compassionate","and","will","forgive","their","sins","not","destroy","yea","frequently","turn","away","his","wrath","kindle","all","anger"]},{"verseId":"brenton_psalms_77_39","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":39,"text":"And he remembered that they are flesh; a wind that passes away, and returns not.","searchKeywords":["and","remembered","that","they","are","flesh","wind","passes","away","returns","not"]},{"verseId":"brenton_psalms_77_40","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":40,"text":"How often did they provoke him in the wilderness, anger him in a dry land!","searchKeywords":["how","often","did","they","provoke","him","the","wilderness","anger","dry","land"]},{"verseId":"brenton_psalms_77_41","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":41,"text":"Yea, they turned back, and tempted God, and provoked the Holy One of Israel.","searchKeywords":["yea","they","turned","back","and","tempted","god","provoked","the","holy","one","israel"]},{"verseId":"brenton_psalms_77_42","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":42,"text":"They remembered not his hand, the day in which he delivered them from the hand of the oppressor.","searchKeywords":["they","remembered","not","his","hand","the","day","which","delivered","them","from","oppressor"]},{"verseId":"brenton_psalms_77_43","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":43,"text":"How he had wrought his signs in Egypt, and his wonders in the field of Tanes:","searchKeywords":["how","had","wrought","his","signs","egypt","and","wonders","the","field","tanes"]},{"verseId":"brenton_psalms_77_44","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":44,"text":"and had changed their rivers into blood; and their streams, that they should not drink.","searchKeywords":["and","had","changed","their","rivers","into","blood","streams","that","they","should","not","drink"]},{"verseId":"brenton_psalms_77_45","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":45,"text":"He sent against them the dog-fly, and it devoured them; and the frog, and it spoiled them.","searchKeywords":["sent","against","them","the","dog","fly","and","devoured","frog","spoiled"]},{"verseId":"brenton_psalms_77_46","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":46,"text":"And he gave their fruit to the canker worm, and their labours to the locust.","searchKeywords":["and","gave","their","fruit","the","canker","worm","labours","locust"]},{"verseId":"brenton_psalms_77_47","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":47,"text":"He killed their vines with hail, and their sycamores with frost.","searchKeywords":["killed","their","vines","with","hail","and","sycamores","frost"]},{"verseId":"brenton_psalms_77_48","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":48,"text":"And he gave up their cattle to hail, and their substance to the fire.","searchKeywords":["and","gave","their","cattle","hail","substance","the","fire"]},{"verseId":"brenton_psalms_77_49","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":49,"text":"He sent out against them the fury of his anger, wrath, and indignation, and affliction, a message by evil angels.","searchKeywords":["sent","out","against","them","the","fury","his","anger","wrath","and","indignation","affliction","message","evil","angels"]},{"verseId":"brenton_psalms_77_50","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":50,"text":"He made a way for his wrath; he spared not their souls from death, but consigned their cattle to death;","searchKeywords":["made","way","for","his","wrath","spared","not","their","souls","from","death","but","consigned","cattle"]},{"verseId":"brenton_psalms_77_51","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":51,"text":"and smote every first-born in the land of Egypt; the first-fruits of their labours in the tents of Cham.","searchKeywords":["and","smote","every","first","born","the","land","egypt","fruits","their","labours","tents","cham"]},{"verseId":"brenton_psalms_77_52","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":52,"text":"And he removed his people like sheep; he led them as a flock in the wilderness.","searchKeywords":["and","removed","his","people","like","sheep","led","them","flock","the","wilderness"]},{"verseId":"brenton_psalms_77_53","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":53,"text":"And he guided them with hope, and they feared not: but the sea covered their enemies.","searchKeywords":["and","guided","them","with","hope","they","feared","not","but","the","sea","covered","their","enemies"]},{"verseId":"brenton_psalms_77_54","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":54,"text":"And he brought them in to the mountain of his sanctuary, this mountain which his right hand had purchased.","searchKeywords":["and","brought","them","the","mountain","his","sanctuary","this","which","right","hand","had","purchased"]},{"verseId":"brenton_psalms_77_55","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":55,"text":"And he cast out the nations from before them, and made them to inherit by a line of inheritance, and made the tribes of Israel to dwell in their tents.","searchKeywords":["and","cast","out","the","nations","from","before","them","made","inherit","line","inheritance","tribes","israel","dwell","their","tents"]},{"verseId":"brenton_psalms_77_56","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":56,"text":"Yet they tempted and provoked the most high God, and kept not his testimonies.","searchKeywords":["yet","they","tempted","and","provoked","the","most","high","god","kept","not","his","testimonies"]},{"verseId":"brenton_psalms_77_57","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":57,"text":"And they turned back, and broke covenant, even as also their fathers: they became like a crooked bow.","searchKeywords":["and","they","turned","back","broke","covenant","even","also","their","fathers","became","like","crooked","bow"]},{"verseId":"brenton_psalms_77_58","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":58,"text":"And they provoked him with their high places, and moved him to jealousy with their graven images.","searchKeywords":["and","they","provoked","him","with","their","high","places","moved","jealousy","graven","images"]},{"verseId":"brenton_psalms_77_59","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":59,"text":"God heard and lightly regarded , and greatly despised Israel.","searchKeywords":["god","heard","and","lightly","regarded","greatly","despised","israel"]},{"verseId":"brenton_psalms_77_60","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":60,"text":"And he rejected the tabernacle of Selom, his tent where he dwelt among men.","searchKeywords":["and","rejected","the","tabernacle","selom","his","tent","where","dwelt","among","men"]},{"verseId":"brenton_psalms_77_61","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":61,"text":"And he gave their strength into captivity, and their beauty into the enemy's hand.","searchKeywords":["and","gave","their","strength","into","captivity","beauty","the","enemy","hand"]},{"verseId":"brenton_psalms_77_62","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":62,"text":"And he gave his people to the sword; and disdained his inheritance.","searchKeywords":["and","gave","his","people","the","sword","disdained","inheritance"]},{"verseId":"brenton_psalms_77_63","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":63,"text":"Fire devoured their young men; and their virgins mourned not.","searchKeywords":["fire","devoured","their","young","men","and","virgins","mourned","not"]},{"verseId":"brenton_psalms_77_64","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":64,"text":"Their priests fell by the sword; and their widows shall not be wept for.","searchKeywords":["their","priests","fell","the","sword","and","widows","shall","not","wept","for"]},{"verseId":"brenton_psalms_77_65","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":65,"text":"So the Lord awaked as one out of sleep, as a mighty man who has been heated with wine.","searchKeywords":["the","lord","awaked","one","out","sleep","mighty","man","who","has","been","heated","with","wine"]},{"verseId":"brenton_psalms_77_66","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":66,"text":"And he smote his enemies in the hinder parts: he brought on them a perpetual reproach.","searchKeywords":["and","smote","his","enemies","the","hinder","parts","brought","them","perpetual","reproach"]},{"verseId":"brenton_psalms_77_67","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":67,"text":"And he rejected the tabernacle of Joseph, and chose not the tribe of Ephraim;","searchKeywords":["and","rejected","the","tabernacle","joseph","chose","not","tribe","ephraim"]},{"verseId":"brenton_psalms_77_68","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":68,"text":"but chose the tribe of Juda, the mount Sion which he loved.","searchKeywords":["but","chose","the","tribe","juda","mount","sion","which","loved"]},{"verseId":"brenton_psalms_77_69","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":69,"text":"And he built his sanctuary as of unicorns; he founded it for ever on the earth.","searchKeywords":["and","built","his","sanctuary","unicorns","founded","for","ever","the","earth"]},{"verseId":"brenton_psalms_77_70","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":70,"text":"He chose David also his servant, and took him up from the flocks of sheep.","searchKeywords":["chose","david","also","his","servant","and","took","him","from","the","flocks","sheep"]},{"verseId":"brenton_psalms_77_71","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":71,"text":"He took him from following the ewes great with young, to be the shepherd of Jacob his servant, and Israel his inheritance.","searchKeywords":["took","him","from","following","the","ewes","great","with","young","shepherd","jacob","his","servant","and","israel","inheritance"]},{"verseId":"brenton_psalms_77_72","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":77,"verse":72,"text":"So he tended them in the innocency of his heart; and guided them by the skilfulness of his hands.","searchKeywords":["tended","them","the","innocency","his","heart","and","guided","skilfulness","hands"]}]