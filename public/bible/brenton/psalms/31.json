[{"verseId":"brenton_psalms_31_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":31,"verse":1,"text":"of instruction by David. Blessed whose transgressions are forgiven, and whose sins are covered.","searchKeywords":["instruction","david","blessed","whose","transgressions","are","forgiven","and","sins","covered"]},{"verseId":"brenton_psalms_31_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":31,"verse":2,"text":"Blessed is the man to whom the Lord will not impute sin, and in whose mouth there is no guile.","searchKeywords":["blessed","the","man","whom","lord","will","not","impute","sin","and","whose","mouth","there","guile"]},{"verseId":"brenton_psalms_31_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":31,"verse":3,"text":"Because I kept silence, my bones waxed old, from my crying all the day.","searchKeywords":["because","kept","silence","bones","waxed","old","from","crying","all","the","day"]},{"verseId":"brenton_psalms_31_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":31,"verse":4,"text":"For day and night thy hand was heavy upon me: I became thoroughly miserable while a thorn was fastened in . Pause.","searchKeywords":["for","day","and","night","thy","hand","was","heavy","upon","became","thoroughly","miserable","while","thorn","fastened","pause"]},{"verseId":"brenton_psalms_31_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":31,"verse":5,"text":"I acknowledged my sin, and hid not mine iniquity: I said, I will confess mine iniquity to the Lord against myself; and thou forgavest the ungodliness of my heart. Pause.","searchKeywords":["acknowledged","sin","and","hid","not","mine","iniquity","said","will","confess","the","lord","against","myself","thou","forgavest","ungodliness","heart","pause"]},{"verseId":"brenton_psalms_31_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":31,"verse":6,"text":"Therefore shall every holy one pray to thee in a fit time: only in the deluge of many waters they shall not come nigh to him.","searchKeywords":["therefore","shall","every","holy","one","pray","thee","fit","time","only","the","deluge","many","waters","they","not","come","nigh","him"]},{"verseId":"brenton_psalms_31_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":31,"verse":7,"text":"Thou art my refuge from the affliction that encompasses me; my joy, to deliver me from them that have compassed me. Pause.","searchKeywords":["thou","art","refuge","from","the","affliction","that","encompasses","joy","deliver","them","have","compassed","pause"]},{"verseId":"brenton_psalms_31_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":31,"verse":8,"text":"I will instruct thee and guide thee in this way wherein thou shalt go: I will fix mine eyes upon thee.","searchKeywords":["will","instruct","thee","and","guide","this","way","wherein","thou","shalt","fix","mine","eyes","upon"]},{"verseId":"brenton_psalms_31_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":31,"verse":9,"text":"Be ye not as horse and mule, which have no understanding: constrain their jaws with bit and curb, lest they should come nigh to thee.","searchKeywords":["not","horse","and","mule","which","have","understanding","constrain","their","jaws","with","bit","curb","lest","they","should","come","nigh","thee"]},{"verseId":"brenton_psalms_31_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":31,"verse":10,"text":"Many are the scourges of the sinner: but him that hopes in the Lord mercy shall compass about.","searchKeywords":["many","are","the","scourges","sinner","but","him","that","hopes","lord","mercy","shall","compass","about"]},{"verseId":"brenton_psalms_31_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":31,"verse":11,"text":"Be glad in the Lord, and exult, ye righteous: and glory, all ye that are upright in heart.","searchKeywords":["glad","the","lord","and","exult","righteous","glory","all","that","are","upright","heart"]}]