[{"verseId":"brenton_psalms_20_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":1,"text":"For the end, a Psalm of David.","searchKeywords":["for","the","end","psalm","david"]},{"verseId":"brenton_psalms_20_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":2,"text":"O Lord, the king shall rejoice in thy strength; and in thy salvation he shall greatly exult.","searchKeywords":["lord","the","king","shall","rejoice","thy","strength","and","salvation","greatly","exult"]},{"verseId":"brenton_psalms_20_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":3,"text":"Thou hast granted him the desire of his soul, and hast not withheld from him the request of his lips. Pause.","searchKeywords":["thou","hast","granted","him","the","desire","his","soul","and","not","withheld","from","request","lips","pause"]},{"verseId":"brenton_psalms_20_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":4,"text":"For thou hast prevented him with blessings of goodness: thou hast set upon his head a crown of precious stone.","searchKeywords":["for","thou","hast","prevented","him","with","blessings","goodness","set","upon","his","head","crown","precious","stone"]},{"verseId":"brenton_psalms_20_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":5,"text":"He asked life of thee, and thou gavest him length of days for ever and ever.","searchKeywords":["asked","life","thee","and","thou","gavest","him","length","days","for","ever"]},{"verseId":"brenton_psalms_20_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":6,"text":"His glory is great in thy salvation: thou wilt crown him with glory and majesty.","searchKeywords":["his","glory","great","thy","salvation","thou","wilt","crown","him","with","and","majesty"]},{"verseId":"brenton_psalms_20_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":7,"text":"For thou wilt give him a blessing for ever and ever: thou wilt gladden him with joy with thy countenance.","searchKeywords":["for","thou","wilt","give","him","blessing","ever","and","gladden","with","joy","thy","countenance"]},{"verseId":"brenton_psalms_20_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":8,"text":"For the king trusts in the Lord, and through the mercy of the Highest he shall not be moved.","searchKeywords":["for","the","king","trusts","lord","and","through","mercy","highest","shall","not","moved"]},{"verseId":"brenton_psalms_20_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":9,"text":"Let thy hand be found by all thine enemies: let thy right hand find all that hate thee.","searchKeywords":["let","thy","hand","found","all","thine","enemies","right","find","that","hate","thee"]},{"verseId":"brenton_psalms_20_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":10,"text":"Thou shalt make them as a fiery oven at the time of thy presence: the Lord shall trouble them in his anger, and fire shall devour them.","searchKeywords":["thou","shalt","make","them","fiery","oven","the","time","thy","presence","lord","shall","trouble","his","anger","and","fire","devour"]},{"verseId":"brenton_psalms_20_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":11,"text":"Thou shalt destroy their fruit from the earth, and their seed from the sons of men.","searchKeywords":["thou","shalt","destroy","their","fruit","from","the","earth","and","seed","sons","men"]},{"verseId":"brenton_psalms_20_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":12,"text":"For they intended evils against thee; they imagined a device which they shall by no means be able to perform.","searchKeywords":["for","they","intended","evils","against","thee","imagined","device","which","shall","means","able","perform"]},{"verseId":"brenton_psalms_20_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":13,"text":"For thou shalt make them back in thy latter end, thou wilt prepare their face.","searchKeywords":["for","thou","shalt","make","them","back","thy","latter","end","wilt","prepare","their","face"]},{"verseId":"brenton_psalms_20_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":20,"verse":14,"text":"Be thou exalted, O Lord, in thy strength: we will sing and praise thy mighty acts.","searchKeywords":["thou","exalted","lord","thy","strength","will","sing","and","praise","mighty","acts"]}]