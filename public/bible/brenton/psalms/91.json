[{"verseId":"brenton_psalms_91_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":1,"text":"A Psalm of a Song for the Sabbath-day.","searchKeywords":["psalm","song","for","the","sabbath","day"]},{"verseId":"brenton_psalms_91_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":2,"text":"It is a good thing to give thanks to the Lord, and to sing praises to thy name, O thou Most High;","searchKeywords":["good","thing","give","thanks","the","lord","and","sing","praises","thy","name","thou","most","high"]},{"verseId":"brenton_psalms_91_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":3,"text":"to proclaim thy mercy in the morning, and thy truth by night,","searchKeywords":["proclaim","thy","mercy","the","morning","and","truth","night"]},{"verseId":"brenton_psalms_91_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":4,"text":"on a psaltery of ten strings, with a song on the harp.","searchKeywords":["psaltery","ten","strings","with","song","the","harp"]},{"verseId":"brenton_psalms_91_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":5,"text":"For thou, O Lord, hast made me glad with thy work: and in the operations of thy hands will I exult.","searchKeywords":["for","thou","lord","hast","made","glad","with","thy","work","and","the","operations","hands","will","exult"]},{"verseId":"brenton_psalms_91_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":6,"text":"How have thy works been magnified, O Lord! thy thoughts are very deep.","searchKeywords":["how","have","thy","works","been","magnified","lord","thoughts","are","very","deep"]},{"verseId":"brenton_psalms_91_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":7,"text":"A foolish man will not know, and a senseless man will not understand this.","searchKeywords":["foolish","man","will","not","know","and","senseless","understand","this"]},{"verseId":"brenton_psalms_91_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":8,"text":"When the sinners spring up as the grass, and all the workers of iniquity have watched; that they may be utterly destroyed for ever.","searchKeywords":["when","the","sinners","spring","grass","and","all","workers","iniquity","have","watched","that","they","may","utterly","destroyed","for","ever"]},{"verseId":"brenton_psalms_91_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":9,"text":"But thou, O Lord, art most high for ever.","searchKeywords":["but","thou","lord","art","most","high","for","ever"]},{"verseId":"brenton_psalms_91_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":10,"text":"For, behold, thine enemies shall perish; and all the workers of iniquity shall be scattered.","searchKeywords":["for","behold","thine","enemies","shall","perish","and","all","the","workers","iniquity","scattered"]},{"verseId":"brenton_psalms_91_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":11,"text":"But my horn shall be exalted as of a unicorn; and mine old age with rich mercy.","searchKeywords":["but","horn","shall","exalted","unicorn","and","mine","old","age","with","rich","mercy"]},{"verseId":"brenton_psalms_91_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":12,"text":"And mine eye has seen mine enemies, and mine ear shall hear the wicked that rise up against me.","searchKeywords":["and","mine","eye","has","seen","enemies","ear","shall","hear","the","wicked","that","rise","against"]},{"verseId":"brenton_psalms_91_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":13,"text":"The righteous shall flourish as a palm-tree: he shall be increased as the cedar in Libanus.","searchKeywords":["the","righteous","shall","flourish","palm","tree","increased","cedar","libanus"]},{"verseId":"brenton_psalms_91_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":14,"text":"They that are planted in the house of the Lord shall flourish in the courts of our God.","searchKeywords":["they","that","are","planted","the","house","lord","shall","flourish","courts","our","god"]},{"verseId":"brenton_psalms_91_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":15,"text":"Then shall they be increased in a fine old age; and they shall be prosperous; that they may declare","searchKeywords":["then","shall","they","increased","fine","old","age","and","prosperous","that","may","declare"]},{"verseId":"brenton_psalms_91_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":91,"verse":16,"text":"that the Lord my God is righteous, and there is no iniquity in him.","searchKeywords":["that","the","lord","god","righteous","and","there","iniquity","him"]}]