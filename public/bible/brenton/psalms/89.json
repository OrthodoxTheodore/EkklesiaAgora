[{"verseId":"brenton_psalms_89_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":1,"text":"A Prayer of Moses the man of God.","searchKeywords":["prayer","moses","the","man","god"]},{"verseId":"brenton_psalms_89_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":2,"text":"Before the mountains existed, and the earth and the world were formed, even from age to age, Thou art.","searchKeywords":["before","the","mountains","existed","and","earth","world","were","formed","even","from","age","thou","art"]},{"verseId":"brenton_psalms_89_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":3,"text":"Turn not man back to low place, whereas thou saidst, Return, ye sons of men?","searchKeywords":["turn","not","man","back","low","place","whereas","thou","saidst","return","sons","men"]},{"verseId":"brenton_psalms_89_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":4,"text":"For a thousand years in thy sight are as the yesterday which is past, and as a watch in the night.","searchKeywords":["for","thousand","years","thy","sight","are","the","yesterday","which","past","and","watch","night"]},{"verseId":"brenton_psalms_89_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":5,"text":"Years shall be vanity to them: let the morning pass away as grass.","searchKeywords":["years","shall","vanity","them","let","the","morning","pass","away","grass"]},{"verseId":"brenton_psalms_89_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":6,"text":"In the morning let it flower, and pass away: in the evening let it droop, let it be withered and dried up.","searchKeywords":["the","morning","let","flower","and","pass","away","evening","droop","withered","dried"]},{"verseId":"brenton_psalms_89_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":7,"text":"For we have perished in thine anger, and in thy wrath we have been troubled.","searchKeywords":["for","have","perished","thine","anger","and","thy","wrath","been","troubled"]},{"verseId":"brenton_psalms_89_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":8,"text":"Thou hast set our transgressions before thee: our age is in the light of thy countenance.","searchKeywords":["thou","hast","set","our","transgressions","before","thee","age","the","light","thy","countenance"]},{"verseId":"brenton_psalms_89_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":9,"text":"For all our days are gone, and we have passed away in thy wrath: our years have spun out their tale as a spider.","searchKeywords":["for","all","our","days","are","gone","and","have","passed","away","thy","wrath","years","spun","out","their","tale","spider"]},{"verseId":"brenton_psalms_89_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":10,"text":"the days of our years, in them are seventy years; and if in strength, eighty years: and the greater part of them would be labour and trouble; for weakness overtakes us, and we shall be chastened.","searchKeywords":["the","days","our","years","them","are","seventy","and","strength","eighty","greater","part","would","labour","trouble","for","weakness","overtakes","shall","chastened"]},{"verseId":"brenton_psalms_89_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":11,"text":"Who knows the power of thy wrath?","searchKeywords":["who","knows","the","power","thy","wrath"]},{"verseId":"brenton_psalms_89_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":12,"text":"and to number because of the fear of thy wrath? So manifest thy right hand, and those that are instructed in wisdom in the heart.","searchKeywords":["and","number","because","the","fear","thy","wrath","manifest","right","hand","those","that","are","instructed","wisdom","heart"]},{"verseId":"brenton_psalms_89_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":13,"text":"Return, O Lord, how long? and be intreated concerning thy servants.","searchKeywords":["return","lord","how","long","and","intreated","concerning","thy","servants"]},{"verseId":"brenton_psalms_89_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":14,"text":"We have been satisfied in the morning with thy mercy; and we did exult and rejoice:","searchKeywords":["have","been","satisfied","the","morning","with","thy","mercy","and","did","exult","rejoice"]},{"verseId":"brenton_psalms_89_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":15,"text":"let us rejoice in all our days, in return for the days wherein thou didst afflict us, the years wherein we saw evil.","searchKeywords":["let","rejoice","all","our","days","return","for","the","wherein","thou","didst","afflict","years","saw","evil"]},{"verseId":"brenton_psalms_89_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":16,"text":"And look upon thy servants, and upon thy works; and guide their children.","searchKeywords":["and","look","upon","thy","servants","works","guide","their","children"]},{"verseId":"brenton_psalms_89_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":89,"verse":17,"text":"And let the brightness of the Lord our God be upon us: and do thou direct for us the works of our hands.","searchKeywords":["and","let","the","brightness","lord","our","god","upon","thou","direct","for","works","hands"]}]