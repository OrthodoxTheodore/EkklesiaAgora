[{"verseId":"brenton_psalms_27_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":27,"verse":1,"text":"of David.","searchKeywords":["david"]},{"verseId":"brenton_psalms_27_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":27,"verse":2,"text":"Hearken to the voice of my supplication, when I pray to thee, when I lift up my hands toward thy holy temple.","searchKeywords":["hearken","the","voice","supplication","when","pray","thee","lift","hands","toward","thy","holy","temple"]},{"verseId":"brenton_psalms_27_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":27,"verse":3,"text":"Draw not away my soul with sinners, and destroy me not with the workers of iniquity, who speak peace with their neighbours, but evils are in their hearts.","searchKeywords":["draw","not","away","soul","with","sinners","and","destroy","the","workers","iniquity","who","speak","peace","their","neighbours","but","evils","are","hearts"]},{"verseId":"brenton_psalms_27_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":27,"verse":4,"text":"Give them according to their works, and according to the wickedness of their devices: give them according to the works of their hands; render their recompence unto them.","searchKeywords":["give","them","according","their","works","and","the","wickedness","devices","hands","render","recompence","unto"]},{"verseId":"brenton_psalms_27_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":27,"verse":5,"text":"Because they have not attended to the works of the Lord, even to the works of his hands, thou shalt pull them down, and shalt not build them up.","searchKeywords":["because","they","have","not","attended","the","works","lord","even","his","hands","thou","shalt","pull","them","down","and","build"]},{"verseId":"brenton_psalms_27_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":27,"verse":6,"text":"Blessed be the Lord, for he has hearkened to the voice of my petition.","searchKeywords":["blessed","the","lord","for","has","hearkened","voice","petition"]},{"verseId":"brenton_psalms_27_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":27,"verse":7,"text":"The Lord is my helper and my defender; my heart has hoped in him, and I am helped: my flesh has revived, and willingly will I give praise to him.","searchKeywords":["the","lord","helper","and","defender","heart","has","hoped","him","helped","flesh","revived","willingly","will","give","praise"]},{"verseId":"brenton_psalms_27_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":27,"verse":8,"text":"The Lord is the strength of his people, and the saving defender of his anointed.","searchKeywords":["the","lord","strength","his","people","and","saving","defender","anointed"]},{"verseId":"brenton_psalms_27_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":27,"verse":9,"text":"Save thy people, and bless thine inheritance: and take care of them, and lift them up for ever.","searchKeywords":["save","thy","people","and","bless","thine","inheritance","take","care","them","lift","for","ever"]}]