[{"verseId":"brenton_psalms_84_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":1,"text":"For the end, a Psalm for the sons of Core.","searchKeywords":["for","the","end","psalm","sons","core"]},{"verseId":"brenton_psalms_84_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":2,"text":"O Lord, thou hast taken pleasure in thy land: thou hast turned back the captivity of Jacob.","searchKeywords":["lord","thou","hast","taken","pleasure","thy","land","turned","back","the","captivity","jacob"]},{"verseId":"brenton_psalms_84_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":3,"text":"Thou hast forgiven thy people their transgressions; thou hast covered all their sins. Pause.","searchKeywords":["thou","hast","forgiven","thy","people","their","transgressions","covered","all","sins","pause"]},{"verseId":"brenton_psalms_84_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":4,"text":"Thou hast caused all thy wrath to cease: thou hast turned from thy fierce anger.","searchKeywords":["thou","hast","caused","all","thy","wrath","cease","turned","from","fierce","anger"]},{"verseId":"brenton_psalms_84_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":5,"text":"Turn us, O God of our salvation, and turn thine anger away from us.","searchKeywords":["turn","god","our","salvation","and","thine","anger","away","from"]},{"verseId":"brenton_psalms_84_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":6,"text":"Wouldest thou be angry with us for ever? or wilt thou continue thy wrath from generation to generation?","searchKeywords":["wouldest","thou","angry","with","for","ever","wilt","continue","thy","wrath","from","generation"]},{"verseId":"brenton_psalms_84_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":7,"text":"O God, thou wilt turn and quicken us; and thy people shall rejoice in thee.","searchKeywords":["god","thou","wilt","turn","and","quicken","thy","people","shall","rejoice","thee"]},{"verseId":"brenton_psalms_84_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":8,"text":"Shew us thy mercy, O Lord, and grant us thy salvation.","searchKeywords":["shew","thy","mercy","lord","and","grant","salvation"]},{"verseId":"brenton_psalms_84_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":9,"text":"I will hear what the Lord God will say concerning me: for he shall speak peace to his people, and to his saints, and to those that turn their heart toward him.","searchKeywords":["will","hear","what","the","lord","god","say","concerning","for","shall","speak","peace","his","people","and","saints","those","that","turn","their","heart","toward","him"]},{"verseId":"brenton_psalms_84_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":10,"text":"Moreover his salvation is near them that fear him; that glory may dwell in our land.","searchKeywords":["moreover","his","salvation","near","them","that","fear","him","glory","may","dwell","our","land"]},{"verseId":"brenton_psalms_84_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":11,"text":"Mercy and truth are met together: righteousness and peace have kissed .","searchKeywords":["mercy","and","truth","are","met","together","righteousness","peace","have","kissed"]},{"verseId":"brenton_psalms_84_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":12,"text":"Truth has sprung out of the earth; and righteousness has looked down from heaven.","searchKeywords":["truth","has","sprung","out","the","earth","and","righteousness","looked","down","from","heaven"]},{"verseId":"brenton_psalms_84_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":13,"text":"For the Lord will give goodness; and our land shall yield her fruit.","searchKeywords":["for","the","lord","will","give","goodness","and","our","land","shall","yield","her","fruit"]},{"verseId":"brenton_psalms_84_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":84,"verse":14,"text":"Righteousness shall go before him; and shall set his steps in the way.","searchKeywords":["righteousness","shall","before","him","and","set","his","steps","the","way"]}]