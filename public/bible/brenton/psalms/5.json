[{"verseId":"brenton_psalms_5_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":5,"verse":1,"text":"For the end, a Psalm of David, concerning her that inherits.","searchKeywords":["for","the","end","psalm","david","concerning","her","that","inherits"]},{"verseId":"brenton_psalms_5_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":5,"verse":2,"text":"Hearken to my words, O Lord, attend to my cry.","searchKeywords":["hearken","words","lord","attend","cry"]},{"verseId":"brenton_psalms_5_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":5,"verse":3,"text":"Attend to the voice of my supplication, my King, and my God: for to thee, O Lord, will I pray.","searchKeywords":["attend","the","voice","supplication","king","and","god","for","thee","lord","will","pray"]},{"verseId":"brenton_psalms_5_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":5,"verse":4,"text":"In the morning thou shalt hear my voice: in the morning will I wait upon thee, and will look up.","searchKeywords":["the","morning","thou","shalt","hear","voice","will","wait","upon","thee","and","look"]},{"verseId":"brenton_psalms_5_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":5,"verse":5,"text":"For thou art not a God that desires iniquity; neither shall the worker of wickedness dwell with thee.","searchKeywords":["for","thou","art","not","god","that","desires","iniquity","neither","shall","the","worker","wickedness","dwell","with","thee"]},{"verseId":"brenton_psalms_5_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":5,"verse":6,"text":"Neither shall the transgressors continue in thy sight: thou hatest, O Lord, all them that work iniquity.","searchKeywords":["neither","shall","the","transgressors","continue","thy","sight","thou","hatest","lord","all","them","that","work","iniquity"]},{"verseId":"brenton_psalms_5_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":5,"verse":7,"text":"Thou wilt destroy all that speak falsehood: the Lord abhors the bloody and deceitful man.","searchKeywords":["thou","wilt","destroy","all","that","speak","falsehood","the","lord","abhors","bloody","and","deceitful","man"]},{"verseId":"brenton_psalms_5_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":5,"verse":8,"text":"But I will enter into thine house in the multitude of thy mercy: I will worship in thy fear toward thy holy temple.","searchKeywords":["but","will","enter","into","thine","house","the","multitude","thy","mercy","worship","fear","toward","holy","temple"]},{"verseId":"brenton_psalms_5_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":5,"verse":9,"text":"Lead me, O Lord, in thy righteousness because of mine enemies; make my way plain before thy face.","searchKeywords":["lead","lord","thy","righteousness","because","mine","enemies","make","way","plain","before","face"]},{"verseId":"brenton_psalms_5_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":5,"verse":10,"text":"For there is no truth in their mouth; their heart is vain; their throat is an open sepulchre; with their tongues they have used deceit.","searchKeywords":["for","there","truth","their","mouth","heart","vain","throat","open","sepulchre","with","tongues","they","have","used","deceit"]},{"verseId":"brenton_psalms_5_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":5,"verse":11,"text":"Judge them, O God; let them fail of their counsels: cast them out according to the abundance of their ungodliness; for they have provoked thee, O Lord.","searchKeywords":["judge","them","god","let","fail","their","counsels","cast","out","according","the","abundance","ungodliness","for","they","have","provoked","thee","lord"]},{"verseId":"brenton_psalms_5_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":5,"verse":12,"text":"But let all that trust on thee be glad in thee: they shall exult for ever, and thou shalt dwell among them; and all that love thy name shall rejoice in thee.","searchKeywords":["but","let","all","that","trust","thee","glad","they","shall","exult","for","ever","and","thou","shalt","dwell","among","them","love","thy","name","rejoice"]},{"verseId":"brenton_psalms_5_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":5,"verse":13,"text":"For thou, Lord, shalt bless the righteous: thou hast compassed us as with a shield of favour.","searchKeywords":["for","thou","lord","shalt","bless","the","righteous","hast","compassed","with","shield","favour"]}]