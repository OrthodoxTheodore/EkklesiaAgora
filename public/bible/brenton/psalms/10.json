[{"verseId":"brenton_psalms_10_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":10,"verse":1,"text":"For the end, a Psalm of David.","searchKeywords":["for","the","end","psalm","david"]},{"verseId":"brenton_psalms_10_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":10,"verse":2,"text":"For behold the sinners have bent bow, they have prepared their arrows for the quiver, to shoot privily at the upright in heart.","searchKeywords":["for","behold","the","sinners","have","bent","bow","they","prepared","their","arrows","quiver","shoot","privily","upright","heart"]},{"verseId":"brenton_psalms_10_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":10,"verse":3,"text":"For they have pulled down what thou didst frame, but what has the righteous done?","searchKeywords":["for","they","have","pulled","down","what","thou","didst","frame","but","has","the","righteous","done"]},{"verseId":"brenton_psalms_10_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":10,"verse":4,"text":"The Lord is in his holy temple, as for the Lord, his throne is in heaven: his eyes look upon the poor, his eyelids try the sons of men.","searchKeywords":["the","lord","his","holy","temple","for","throne","heaven","eyes","look","upon","poor","eyelids","try","sons","men"]},{"verseId":"brenton_psalms_10_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":10,"verse":5,"text":"The Lord tries the righteous and the ungodly: and he that loves unrighteousness hates his own soul.","searchKeywords":["the","lord","tries","righteous","and","ungodly","that","loves","unrighteousness","hates","his","own","soul"]},{"verseId":"brenton_psalms_10_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":10,"verse":6,"text":"He shall rain upon sinners snares, fire, and brimstone, and a stormy blast the portion of their cup.","searchKeywords":["shall","rain","upon","sinners","snares","fire","and","brimstone","stormy","blast","the","portion","their","cup"]},{"verseId":"brenton_psalms_10_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":10,"verse":7,"text":"For the Lord righteous, and loves righteousness; his face beholds uprightness.","searchKeywords":["for","the","lord","righteous","and","loves","righteousness","his","face","beholds","uprightness"]}]