[{"verseId":"brenton_psalms_30_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":1,"text":"For the end, a Psalm of David, of extreme fear.","searchKeywords":["for","the","end","psalm","david","extreme","fear"]},{"verseId":"brenton_psalms_30_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":2,"text":"O Lord, I have hoped in thee; let me never be ashamed: deliver me in thy righteousness and rescue me.","searchKeywords":["lord","have","hoped","thee","let","never","ashamed","deliver","thy","righteousness","and","rescue"]},{"verseId":"brenton_psalms_30_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":3,"text":"Incline thine ear to me; make haste to rescue me: be thou to me for a protecting God, and for a house of refuge to save me.","searchKeywords":["incline","thine","ear","make","haste","rescue","thou","for","protecting","god","and","house","refuge","save"]},{"verseId":"brenton_psalms_30_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":4,"text":"For thou art my strength and my refuge; and thou shalt guide me for thy name's sake, and maintain me.","searchKeywords":["for","thou","art","strength","and","refuge","shalt","guide","thy","name","sake","maintain"]},{"verseId":"brenton_psalms_30_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":5,"text":"Thou shalt bring me out of the snare which they have hidden for me; for thou, O Lord, art my defender.","searchKeywords":["thou","shalt","bring","out","the","snare","which","they","have","hidden","for","lord","art","defender"]},{"verseId":"brenton_psalms_30_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":6,"text":"Into thine hands I will commit my spirit: thou hast redeemed me, O Lord God of truth.","searchKeywords":["into","thine","hands","will","commit","spirit","thou","hast","redeemed","lord","god","truth"]},{"verseId":"brenton_psalms_30_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":7,"text":"Thou hast hated them that idly persist in vanities: but I have hoped in the Lord.","searchKeywords":["thou","hast","hated","them","that","idly","persist","vanities","but","have","hoped","the","lord"]},{"verseId":"brenton_psalms_30_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":8,"text":"I will exult and be glad in thy mercy: for thou hast looked upon mine affliction; thou hast saved my soul from distresses.","searchKeywords":["will","exult","and","glad","thy","mercy","for","thou","hast","looked","upon","mine","affliction","saved","soul","from","distresses"]},{"verseId":"brenton_psalms_30_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":9,"text":"And thou hast not shut me up into the hands of the enemy: thou hast set my feet in a wide place.","searchKeywords":["and","thou","hast","not","shut","into","the","hands","enemy","set","feet","wide","place"]},{"verseId":"brenton_psalms_30_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":10,"text":"Pity me, O Lord, for I am afflicted: my eye is troubled with indignation, my soul and my belly.","searchKeywords":["pity","lord","for","afflicted","eye","troubled","with","indignation","soul","and","belly"]},{"verseId":"brenton_psalms_30_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":11,"text":"For my life is spent with grief, and my years with groanings: my strength has been weakened through poverty, and my bones are troubled.","searchKeywords":["for","life","spent","with","grief","and","years","groanings","strength","has","been","weakened","through","poverty","bones","are","troubled"]},{"verseId":"brenton_psalms_30_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":12,"text":"I became a reproach among all mine enemies, but exceedingly so to my neighbours, and a fear to mine acquaintance: they that saw me without fled from me.","searchKeywords":["became","reproach","among","all","mine","enemies","but","exceedingly","neighbours","and","fear","acquaintance","they","that","saw","without","fled","from"]},{"verseId":"brenton_psalms_30_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":13,"text":"I have been forgotten as a dead man out of mind: I am become as a broken vessel.","searchKeywords":["have","been","forgotten","dead","man","out","mind","become","broken","vessel"]},{"verseId":"brenton_psalms_30_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":14,"text":"For I heard the slander of many that dwelt round about: when they were gathered together against me, they took counsel to take my life.","searchKeywords":["for","heard","the","slander","many","that","dwelt","round","about","when","they","were","gathered","together","against","took","counsel","take","life"]},{"verseId":"brenton_psalms_30_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":15,"text":"But I hoped in thee, O Lord: I said, Thou art my God.","searchKeywords":["but","hoped","thee","lord","said","thou","art","god"]},{"verseId":"brenton_psalms_30_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":16,"text":"My lots are in thy hands: deliver me from the hand of mine enemies,","searchKeywords":["lots","are","thy","hands","deliver","from","the","hand","mine","enemies"]},{"verseId":"brenton_psalms_30_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":17,"text":"and from them that persecute me. Make thy face to shine upon thy servant: save me in thy mercy.","searchKeywords":["and","from","them","that","persecute","make","thy","face","shine","upon","servant","save","mercy"]},{"verseId":"brenton_psalms_30_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":18,"text":"O Lord, let me not be ashamed, for I have called upon thee: let the ungodly be ashamed, and brought down to Hades.","searchKeywords":["lord","let","not","ashamed","for","have","called","upon","thee","the","ungodly","and","brought","down","hades"]},{"verseId":"brenton_psalms_30_19","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":19,"text":"Let the deceitful lips become dumb, which speak iniquity against the righteous with pride and scorn.","searchKeywords":["let","the","deceitful","lips","become","dumb","which","speak","iniquity","against","righteous","with","pride","and","scorn"]},{"verseId":"brenton_psalms_30_20","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":20,"text":"How abundant is the multitude of thy goodness, O Lord, which thou hast laid up for them that fear thee! thou hast wrought out for them that hope on thee, in the presence of the sons of men.","searchKeywords":["how","abundant","the","multitude","thy","goodness","lord","which","thou","hast","laid","for","them","that","fear","thee","wrought","out","hope","presence","sons","men"]},{"verseId":"brenton_psalms_30_21","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":21,"text":"Thou wilt hide them in the secret of thy presence from the vexation of man: thou wilt screen them in a tabernacle from the contradiction of tongues.","searchKeywords":["thou","wilt","hide","them","the","secret","thy","presence","from","vexation","man","screen","tabernacle","contradiction","tongues"]},{"verseId":"brenton_psalms_30_22","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":22,"text":"Blessed be the Lord: for he has magnified his mercy in a fortified city.","searchKeywords":["blessed","the","lord","for","has","magnified","his","mercy","fortified","city"]},{"verseId":"brenton_psalms_30_23","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":23,"text":"But I said in my extreme fear, I am cast out from the sight of thine eyes: therefore thou didst hearken, O Lord, to the voice of my supplication when I cried to thee.","searchKeywords":["but","said","extreme","fear","cast","out","from","the","sight","thine","eyes","therefore","thou","didst","hearken","lord","voice","supplication","when","cried","thee"]},{"verseId":"brenton_psalms_30_24","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":24,"text":"Love the Lord, all ye his saints: for the Lord seeks for truth, and renders to them that deal very proudly.","searchKeywords":["love","the","lord","all","his","saints","for","seeks","truth","and","renders","them","that","deal","very","proudly"]},{"verseId":"brenton_psalms_30_25","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":30,"verse":25,"text":"Be of good courage, and let your heart be strengthened, all ye that hope in the Lord.","searchKeywords":["good","courage","and","let","your","heart","strengthened","all","that","hope","the","lord"]}]