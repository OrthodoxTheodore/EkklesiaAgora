[{"verseId":"brenton_psalms_144_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":1,"text":"David's praise. for ever and ever.","searchKeywords":["david","praise","for","ever","and"]},{"verseId":"brenton_psalms_144_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":2,"text":"Every day will I bless thee, and I will praise thy name for ever and ever.","searchKeywords":["every","day","will","bless","thee","and","praise","thy","name","for","ever"]},{"verseId":"brenton_psalms_144_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":3,"text":"The Lord is great, and greatly to be praised; and there is no end of his greatness.","searchKeywords":["the","lord","great","and","greatly","praised","there","end","his","greatness"]},{"verseId":"brenton_psalms_144_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":4,"text":"Generation after generation shall praise thy works, and tell of thy power.","searchKeywords":["generation","after","shall","praise","thy","works","and","tell","power"]},{"verseId":"brenton_psalms_144_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":5,"text":"And they shall speak of the glorious majesty of thy holiness, and recount thy wonders.","searchKeywords":["and","they","shall","speak","the","glorious","majesty","thy","holiness","recount","wonders"]},{"verseId":"brenton_psalms_144_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":6,"text":"And they shall speak of the power of thy terrible ; and recount thy greatness.","searchKeywords":["and","they","shall","speak","the","power","thy","terrible","recount","greatness"]},{"verseId":"brenton_psalms_144_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":7,"text":"They shall utter the memory of the abundance of thy goodness, and shall exult in thy righteousness.","searchKeywords":["they","shall","utter","the","memory","abundance","thy","goodness","and","exult","righteousness"]},{"verseId":"brenton_psalms_144_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":8,"text":"The Lord is compassionate, and merciful; long-suffering, and abundant in mercy.","searchKeywords":["the","lord","compassionate","and","merciful","long","suffering","abundant","mercy"]},{"verseId":"brenton_psalms_144_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":9,"text":"The Lord is good to those that wait ; and his compassions are over all his works.","searchKeywords":["the","lord","good","those","that","wait","and","his","compassions","are","over","all","works"]},{"verseId":"brenton_psalms_144_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":10,"text":"Let all thy works, O Lord, give thanks to thee; and let thy saints bless thee.","searchKeywords":["let","all","thy","works","lord","give","thanks","thee","and","saints","bless"]},{"verseId":"brenton_psalms_144_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":11,"text":"They shall speak of the glory of thy kingdom, and talk of thy dominion;","searchKeywords":["they","shall","speak","the","glory","thy","kingdom","and","talk","dominion"]},{"verseId":"brenton_psalms_144_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":12,"text":"to make known to the sons of men thy power, and the glorious majesty of thy kingdom.","searchKeywords":["make","known","the","sons","men","thy","power","and","glorious","majesty","kingdom"]},{"verseId":"brenton_psalms_144_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":13,"text":"Thy kingdom is an everlasting kingdom, and thy dominion through all generations.","searchKeywords":["thy","kingdom","everlasting","and","dominion","through","all","generations"]},{"verseId":"brenton_psalms_144_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":144,"verse":15,"text":"their food in due season.","searchKeywords":["their","food","due","season"]}]