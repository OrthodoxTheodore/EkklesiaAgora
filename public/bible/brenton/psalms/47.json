[{"verseId":"brenton_psalms_47_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":1,"text":"A Psalm of praise for the sons of Core on the second of the week.","searchKeywords":["psalm","praise","for","the","sons","core","second","week"]},{"verseId":"brenton_psalms_47_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":2,"text":"Great is the Lord, and greatly to be praised in the city of our God, in his holy mountain.","searchKeywords":["great","the","lord","and","greatly","praised","city","our","god","his","holy","mountain"]},{"verseId":"brenton_psalms_47_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":3,"text":"The city of the great King is well planted the mountains of Sion, with the joy of the whole earth, the sides of the north.","searchKeywords":["the","city","great","king","well","planted","mountains","sion","with","joy","whole","earth","sides","north"]},{"verseId":"brenton_psalms_47_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":4,"text":"God is known in her palaces, when he undertakes to help her.","searchKeywords":["god","known","her","palaces","when","undertakes","help"]},{"verseId":"brenton_psalms_47_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":5,"text":"For, behold, the kings of the earth were assembled, they came together.","searchKeywords":["for","behold","the","kings","earth","were","assembled","they","came","together"]},{"verseId":"brenton_psalms_47_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":6,"text":"They saw, and so they wondered: they were troubled, they were moved.","searchKeywords":["they","saw","and","wondered","were","troubled","moved"]},{"verseId":"brenton_psalms_47_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":7,"text":"Trembling took hold on them: there were the pangs as of a woman in travail.","searchKeywords":["trembling","took","hold","them","there","were","the","pangs","woman","travail"]},{"verseId":"brenton_psalms_47_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":8,"text":"Thou wilt break the ships of Tharsis with a vehement wind.","searchKeywords":["thou","wilt","break","the","ships","tharsis","with","vehement","wind"]},{"verseId":"brenton_psalms_47_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":9,"text":"As we have heard, so have we also seen, in the city of the Lord of hosts, in the city of our God: God has founded it for ever. Pause.","searchKeywords":["have","heard","also","seen","the","city","lord","hosts","our","god","has","founded","for","ever","pause"]},{"verseId":"brenton_psalms_47_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":10,"text":"We have thought of thy mercy, O God, in the midst of thy people.","searchKeywords":["have","thought","thy","mercy","god","the","midst","people"]},{"verseId":"brenton_psalms_47_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":11,"text":"According to thy name, O God, so is also thy praise to the ends of the earth: thy right hand is full of righteousness.","searchKeywords":["according","thy","name","god","also","praise","the","ends","earth","right","hand","full","righteousness"]},{"verseId":"brenton_psalms_47_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":12,"text":"Let mount Sion rejoice, let the daughters of Judæa exult, because of thy judgments, O Lord.","searchKeywords":["let","mount","sion","rejoice","the","daughters","jud","exult","because","thy","judgments","lord"]},{"verseId":"brenton_psalms_47_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":13,"text":"Go round about Sion, and encompass her: tell ye her towers.","searchKeywords":["round","about","sion","and","encompass","her","tell","towers"]},{"verseId":"brenton_psalms_47_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":14,"text":"Mark ye well her strength, and observe her palaces; that ye may tell the next generation.","searchKeywords":["mark","well","her","strength","and","observe","palaces","that","may","tell","the","next","generation"]},{"verseId":"brenton_psalms_47_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":47,"verse":15,"text":"For this is our God for ever and ever: he will be our guide for evermore.","searchKeywords":["for","this","our","god","ever","and","will","guide","evermore"]}]