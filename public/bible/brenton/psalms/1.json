[{"verseId":"brenton_psalms_1_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":1,"verse":1,"text":"is the man who has not walked in the counsel of the ungodly, and has not stood in the way of sinners, and has not sat in the seat of evil men.","searchKeywords":["the","man","who","has","not","walked","counsel","ungodly","and","stood","way","sinners","sat","seat","evil","men"]},{"verseId":"brenton_psalms_1_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":1,"verse":2,"text":"But his pleasure is in the law of the Lord; and in his law will he meditate day and night.","searchKeywords":["but","his","pleasure","the","law","lord","and","will","meditate","day","night"]},{"verseId":"brenton_psalms_1_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":1,"verse":3,"text":"And he shall be as a tree planted by the brooks of waters, which shall yield its fruit in its season, and its leaf shall not fall off; and whatsoever he shall do shall be prospered.","searchKeywords":["and","shall","tree","planted","the","brooks","waters","which","yield","its","fruit","season","leaf","not","fall","off","whatsoever","prospered"]},{"verseId":"brenton_psalms_1_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":1,"verse":4,"text":"Not so the ungodly;—not so: but rather as the chaff which the wind scatters away from the face of the earth.","searchKeywords":["not","the","ungodly","but","rather","chaff","which","wind","scatters","away","from","face","earth"]},{"verseId":"brenton_psalms_1_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":1,"verse":5,"text":"Therefore the ungodly shall not rise in judgment, nor sinners in the counsel of the just.","searchKeywords":["therefore","the","ungodly","shall","not","rise","judgment","nor","sinners","counsel","just"]},{"verseId":"brenton_psalms_1_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":1,"verse":6,"text":"For the Lord knows the way of the righteous; but the way of the ungodly shall perish.","searchKeywords":["for","the","lord","knows","way","righteous","but","ungodly","shall","perish"]}]