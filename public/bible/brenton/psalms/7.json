[{"verseId":"brenton_psalms_7_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":1,"text":"A Psalm of David, which he sang to the Lord because of the words of Chusi the Benjamite.","searchKeywords":["psalm","david","which","sang","the","lord","because","words","chusi","benjamite"]},{"verseId":"brenton_psalms_7_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":2,"text":"O Lord my God, in thee have I trusted: save me from all them that persecute me, and deliver me.","searchKeywords":["lord","god","thee","have","trusted","save","from","all","them","that","persecute","and","deliver"]},{"verseId":"brenton_psalms_7_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":3,"text":"Lest at any time seize my soul as a lion, while there is none to ransom, nor to save.","searchKeywords":["lest","any","time","seize","soul","lion","while","there","none","ransom","nor","save"]},{"verseId":"brenton_psalms_7_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":4,"text":"O Lord my God, if I have done this; (if there is unrighteousness in my hands;)","searchKeywords":["lord","god","have","done","this","there","unrighteousness","hands"]},{"verseId":"brenton_psalms_7_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":5,"text":"if I have requited with evil those who requited me ; may I then perish empty by means of my enemies.","searchKeywords":["have","requited","with","evil","those","who","may","then","perish","empty","means","enemies"]},{"verseId":"brenton_psalms_7_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":6,"text":"Let the enemy persecute my soul, and take it; and let him trample my life on the ground, and lay my glory in the dust. Pause.","searchKeywords":["let","the","enemy","persecute","soul","and","take","him","trample","life","ground","lay","glory","dust","pause"]},{"verseId":"brenton_psalms_7_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":7,"text":"Arise, O Lord, in thy wrath; be exalted in the utmost boundaries of mine enemies: awake, O Lord my God, according to the decree which thou didst command.","searchKeywords":["arise","lord","thy","wrath","exalted","the","utmost","boundaries","mine","enemies","awake","god","according","decree","which","thou","didst","command"]},{"verseId":"brenton_psalms_7_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":8,"text":"And the congregation of the nations shall compass thee: and for this cause do thou return on high.","searchKeywords":["and","the","congregation","nations","shall","compass","thee","for","this","cause","thou","return","high"]},{"verseId":"brenton_psalms_7_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":9,"text":"The Lord shall judge the nations: judge me, O Lord, according to my righteousness, and according to my innocence that is in me.","searchKeywords":["the","lord","shall","judge","nations","according","righteousness","and","innocence","that"]},{"verseId":"brenton_psalms_7_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":10,"text":"Oh let the wickedness of sinners come to an end; and thou shalt direct the righteous, O God that searchest the hearts and reins.","searchKeywords":["let","the","wickedness","sinners","come","end","and","thou","shalt","direct","righteous","god","that","searchest","hearts","reins"]},{"verseId":"brenton_psalms_7_11","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":11,"text":"My help is righteous, from God who saves the upright in heart.","searchKeywords":["help","righteous","from","god","who","saves","the","upright","heart"]},{"verseId":"brenton_psalms_7_12","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":12,"text":"God is a righteous judge, and strong, and patient, not inflicting vengeance every day.","searchKeywords":["god","righteous","judge","and","strong","patient","not","inflicting","vengeance","every","day"]},{"verseId":"brenton_psalms_7_13","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":13,"text":"If ye will not repent, he will furbish his sword; he has bent his bow, and made it ready.","searchKeywords":["will","not","repent","furbish","his","sword","has","bent","bow","and","made","ready"]},{"verseId":"brenton_psalms_7_14","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":14,"text":"And on it he has fitted the instruments of death; he has completed his arrows for the raging ones.","searchKeywords":["and","has","fitted","the","instruments","death","completed","his","arrows","for","raging","ones"]},{"verseId":"brenton_psalms_7_15","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":15,"text":"Behold, he has travailed with unrighteousness, he has conceived trouble, and brought forth iniquity.","searchKeywords":["behold","has","travailed","with","unrighteousness","conceived","trouble","and","brought","forth","iniquity"]},{"verseId":"brenton_psalms_7_16","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":16,"text":"He has opened a pit, and dug it up, and he shall fall into the ditch which he has made.","searchKeywords":["has","opened","pit","and","dug","shall","fall","into","the","ditch","which","made"]},{"verseId":"brenton_psalms_7_17","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":17,"text":"His trouble shall return on his own head, and his unrighteousness shall come down on his own crown.","searchKeywords":["his","trouble","shall","return","own","head","and","unrighteousness","come","down","crown"]},{"verseId":"brenton_psalms_7_18","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":7,"verse":18,"text":"I will give thanks to the Lord according to his righteousness; I will sing to the name of the Lord most high.","searchKeywords":["will","give","thanks","the","lord","according","his","righteousness","sing","name","most","high"]}]