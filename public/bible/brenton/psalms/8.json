[{"verseId":"brenton_psalms_8_1","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":8,"verse":1,"text":"For the end, concerning the wine-presses, a Psalm of David.","searchKeywords":["for","the","end","concerning","wine","presses","psalm","david"]},{"verseId":"brenton_psalms_8_2","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":8,"verse":2,"text":"O Lord, our Lord, how wonderful is thy name in all the earth! for thy magnificence is exalted above the heavens.","searchKeywords":["lord","our","how","wonderful","thy","name","all","the","earth","for","magnificence","exalted","above","heavens"]},{"verseId":"brenton_psalms_8_3","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":8,"verse":3,"text":"Out of the mouth of babes and sucklings hast thou perfected praise, because of thine enemies; that thou mightest put down the enemy and avenger.","searchKeywords":["out","the","mouth","babes","and","sucklings","hast","thou","perfected","praise","because","thine","enemies","that","mightest","put","down","enemy","avenger"]},{"verseId":"brenton_psalms_8_4","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":8,"verse":4,"text":"For I will regard the heavens, the work of thy fingers; the moon and stars, which thou hast established.","searchKeywords":["for","will","regard","the","heavens","work","thy","fingers","moon","and","stars","which","thou","hast","established"]},{"verseId":"brenton_psalms_8_5","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":8,"verse":5,"text":"What is man, that thou art mindful of him? or the son of man, that thou visitest him?","searchKeywords":["what","man","that","thou","art","mindful","him","the","son","visitest"]},{"verseId":"brenton_psalms_8_6","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":8,"verse":6,"text":"Thou madest him a little less than angels, thou hast crowned him with glory and honour;","searchKeywords":["thou","madest","him","little","less","than","angels","hast","crowned","with","glory","and","honour"]},{"verseId":"brenton_psalms_8_7","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":8,"verse":7,"text":"and thou hast set him over the works of thy hands: thou hast put all things under his feet:","searchKeywords":["and","thou","hast","set","him","over","the","works","thy","hands","put","all","things","under","his","feet"]},{"verseId":"brenton_psalms_8_8","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":8,"verse":8,"text":"sheep and all oxen, yea, and the cattle of the field;","searchKeywords":["sheep","and","all","oxen","yea","the","cattle","field"]},{"verseId":"brenton_psalms_8_9","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":8,"verse":9,"text":"the birds of the sky, and the fish of the sea, the passing through the paths of the sea.","searchKeywords":["the","birds","sky","and","fish","sea","passing","through","paths"]},{"verseId":"brenton_psalms_8_10","translationId":"brenton","testament":"OT","bookIndex":24,"bookName":"Psalms","bookAbbrev":"psalms","chapter":8,"verse":10,"text":"O Lord our Lord, how wonderful is thy name in all the earth!","searchKeywords":["lord","our","how","wonderful","thy","name","all","the","earth"]}]