[{"verseId":"brenton_nahum_1_1","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":1,"text":"burden of Nineve: the book of the vision of Naum the Elkesite.","searchKeywords":["burden","nineve","the","book","vision","naum","elkesite"]},{"verseId":"brenton_nahum_1_2","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":2,"text":"God is jealous, and the Lord avenges; the Lord avenges with wrath; the Lord takes vengeance on his adversaries, and he cuts off his enemies.","searchKeywords":["god","jealous","and","the","lord","avenges","with","wrath","takes","vengeance","his","adversaries","cuts","off","enemies"]},{"verseId":"brenton_nahum_1_3","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":3,"text":"The Lord is long-suffering, and his power is great, and the Lord will not hold any guiltless: his way is in destruction and in the whirlwind, and the clouds are the dust of his feet.","searchKeywords":["the","lord","long","suffering","and","his","power","great","will","not","hold","any","guiltless","way","destruction","whirlwind","clouds","are","dust","feet"]},{"verseId":"brenton_nahum_1_4","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":4,"text":"He threatens the sea, and dries it up, and exhausts all the rivers: the land of Basan, and Carmel are brought low, and the flourishing of Libanus have come to nought.","searchKeywords":["threatens","the","sea","and","dries","exhausts","all","rivers","land","basan","carmel","are","brought","low","flourishing","libanus","have","come","nought"]},{"verseId":"brenton_nahum_1_5","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":5,"text":"The mountains quake at him, and the hills are shaken, and the earth recoils at his presence, the world, and all that dwell in it.","searchKeywords":["the","mountains","quake","him","and","hills","are","shaken","earth","recoils","his","presence","world","all","that","dwell"]},{"verseId":"brenton_nahum_1_6","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":6,"text":"Who shall stand before his anger? and who shall withstand in the anger of his wrath? his wrath brings to nought kingdoms, and the rocks are burst asunder by him.","searchKeywords":["who","shall","stand","before","his","anger","and","withstand","the","wrath","brings","nought","kingdoms","rocks","are","burst","asunder","him"]},{"verseId":"brenton_nahum_1_7","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":7,"text":"The Lord is good to them that wait on him in the day of affliction; and he knows them that reverence him.","searchKeywords":["the","lord","good","them","that","wait","him","day","affliction","and","knows","reverence"]},{"verseId":"brenton_nahum_1_8","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":8,"text":"But with an overrunning flood he will make an utter end: darkness shall pursue those that rise up against and his enemies.","searchKeywords":["but","with","overrunning","flood","will","make","utter","end","darkness","shall","pursue","those","that","rise","against","and","his","enemies"]},{"verseId":"brenton_nahum_1_9","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":9,"text":"What do ye devise against the Lord? he will make a complete end: he will not take vengeance by affliction twice at the same time.","searchKeywords":["what","devise","against","the","lord","will","make","complete","end","not","take","vengeance","affliction","twice","same","time"]},{"verseId":"brenton_nahum_1_10","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":10,"text":"For shall be laid bare even to the foundation, and shall be devoured as twisted yew, and as stubble fully dry.","searchKeywords":["for","shall","laid","bare","even","the","foundation","and","devoured","twisted","yew","stubble","fully","dry"]},{"verseId":"brenton_nahum_1_11","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":11,"text":"Out of thee shall proceed a device against the Lord, counselling evil things hostile .","searchKeywords":["out","thee","shall","proceed","device","against","the","lord","counselling","evil","things","hostile"]},{"verseId":"brenton_nahum_1_12","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":12,"text":"Thus saith the Lord who rules over many waters, Even thus shall they be sent away, and the report of thee shall not be heard any more.","searchKeywords":["thus","saith","the","lord","who","rules","over","many","waters","even","shall","they","sent","away","and","report","thee","not","heard","any","more"]},{"verseId":"brenton_nahum_1_13","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":13,"text":"And now will I break his rod from off thee, and will burst bonds.","searchKeywords":["and","now","will","break","his","rod","from","off","thee","burst","bonds"]},{"verseId":"brenton_nahum_1_14","translationId":"brenton","testament":"OT","bookIndex":39,"bookName":"Nahum","bookAbbrev":"nahum","chapter":1,"verse":14,"text":"And the Lord shall give a command concerning thee; there shall no more of thy name be scattered: I will utterly destroy the graven out of the house of thy god, and the molten : I will make thy grave; for swift.","searchKeywords":["and","the","lord","shall","give","command","concerning","thee","there","more","thy","name","scattered","will","utterly","destroy","graven","out","house","god","molten","make","grave","for","swift"]}]