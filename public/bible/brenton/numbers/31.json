[{"verseId":"brenton_numbers_31_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":1,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_numbers_31_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":2,"text":"Avenge the wrongs of the children of Israel on the Madianites, and afterwards thou shalt be added to thy people.","searchKeywords":["avenge","the","wrongs","children","israel","madianites","and","afterwards","thou","shalt","added","thy","people"]},{"verseId":"brenton_numbers_31_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":3,"text":"And Moses spoke to the people, saying, Arm some of you, and set yourselves in array before the Lord against Madian, to inflict vengeance on Madian from the Lord.","searchKeywords":["and","moses","spoke","the","people","saying","arm","some","you","set","yourselves","array","before","lord","against","madian","inflict","vengeance","from"]},{"verseId":"brenton_numbers_31_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":4,"text":"Send a thousand of each tribe from all the tribes of the children of Israel to set themselves in array.","searchKeywords":["send","thousand","each","tribe","from","all","the","tribes","children","israel","set","themselves","array"]},{"verseId":"brenton_numbers_31_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":5,"text":"And they numbered of the thousands of Israel a thousand of tribe, twelve thousands; armed for war.","searchKeywords":["and","they","numbered","the","thousands","israel","thousand","tribe","twelve","armed","for","war"]},{"verseId":"brenton_numbers_31_6","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":6,"text":"And Moses sent them away a thousand of every tribe with their forces, and Phinees the son of Eleazar the son of Aaron the priest: and the holy instruments, and the signal trumpets in their hands.","searchKeywords":["and","moses","sent","them","away","thousand","every","tribe","with","their","forces","phinees","the","son","eleazar","aaron","priest","holy","instruments","signal","trumpets","hands"]},{"verseId":"brenton_numbers_31_7","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":7,"text":"And they set themselves in array against Madian, as the Lord commanded Moses; and they slew every male.","searchKeywords":["and","they","set","themselves","array","against","madian","the","lord","commanded","moses","slew","every","male"]},{"verseId":"brenton_numbers_31_8","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":8,"text":"And they slew the kings of Madian together with their slain ; even Evi and Rocon, and Sur, and Ur, and Roboc, five kings of Madian; and they slew with the sword Balaam the son of Beor with their slain.","searchKeywords":["and","they","slew","the","kings","madian","together","with","their","slain","even","evi","rocon","sur","roboc","five","sword","balaam","son","beor"]},{"verseId":"brenton_numbers_31_9","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":9,"text":"And they made a prey of the women of Madian, and their store, and their cattle, and all their possessions: and they spoiled their forces.","searchKeywords":["and","they","made","prey","the","women","madian","their","store","cattle","all","possessions","spoiled","forces"]},{"verseId":"brenton_numbers_31_10","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":10,"text":"And they burnt with fire all their cities in the places of their habitation, and they burnt their villages with fire.","searchKeywords":["and","they","burnt","with","fire","all","their","cities","the","places","habitation","villages"]},{"verseId":"brenton_numbers_31_11","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":11,"text":"And they took all their plunder, and all their spoils, both man and beast.","searchKeywords":["and","they","took","all","their","plunder","spoils","both","man","beast"]},{"verseId":"brenton_numbers_31_12","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":12,"text":"And they brought to Moses and to Eleazar the priest, and to all the children of Israel, the captives, and the spoils, and the plunder, to the camp to Araboth Moab, which is at Jordan by Jericho.","searchKeywords":["and","they","brought","moses","eleazar","the","priest","all","children","israel","captives","spoils","plunder","camp","araboth","moab","which","jordan","jericho"]},{"verseId":"brenton_numbers_31_13","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":13,"text":"And Moses and Eleazar the priest and all the rulers of the synagogue went forth out of the camp to meet them.","searchKeywords":["and","moses","eleazar","the","priest","all","rulers","synagogue","went","forth","out","camp","meet","them"]},{"verseId":"brenton_numbers_31_14","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":14,"text":"And Moses was angry with the captains of the host, the heads of thousands and the heads of hundreds who came from the battle-array.","searchKeywords":["and","moses","was","angry","with","the","captains","host","heads","thousands","hundreds","who","came","from","battle","array"]},{"verseId":"brenton_numbers_31_15","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":15,"text":"And Moses said to them, Why have ye saved every female alive?","searchKeywords":["and","moses","said","them","why","have","saved","every","female","alive"]},{"verseId":"brenton_numbers_31_16","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":16,"text":"For they were to the children of Israel by the word of Balaam of their revolting and despising the word of the Lord, because of Phogor; and there was a plague in the congregation of the Lord.","searchKeywords":["for","they","were","the","children","israel","word","balaam","their","revolting","and","despising","lord","because","phogor","there","was","plague","congregation"]},{"verseId":"brenton_numbers_31_17","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":17,"text":"Now then slay every male in all the spoil, slay every woman, who has known the lying with man.","searchKeywords":["now","then","slay","every","male","all","the","spoil","woman","who","has","known","lying","with","man"]},{"verseId":"brenton_numbers_31_18","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":18,"text":"And as for all the captivity of women, who have not known the lying with man, save ye them alive.","searchKeywords":["and","for","all","the","captivity","women","who","have","not","known","lying","with","man","save","them","alive"]},{"verseId":"brenton_numbers_31_19","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":19,"text":"And ye shall encamp outside the camp seven days; every one who has slain and who touches a dead body, shall be purified on the third day, and ye and your captivity on the seventh day.","searchKeywords":["and","shall","encamp","outside","the","camp","seven","days","every","one","who","has","slain","touches","dead","body","purified","third","day","your","captivity","seventh"]},{"verseId":"brenton_numbers_31_20","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":20,"text":"And ye shall purify every garment and every leathern utensil, and all furniture of goat skin, and every wooden vessel.","searchKeywords":["and","shall","purify","every","garment","leathern","utensil","all","furniture","goat","skin","wooden","vessel"]},{"verseId":"brenton_numbers_31_21","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":21,"text":"And Eleazar the priest said to the men of the host that came from the battle-array, This the ordinance of the law which the Lord has commanded Moses.","searchKeywords":["and","eleazar","the","priest","said","men","host","that","came","from","battle","array","this","ordinance","law","which","lord","has","commanded","moses"]},{"verseId":"brenton_numbers_31_22","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":22,"text":"Beside the gold, and the silver, and the brass, and the iron, and lead, and tin,","searchKeywords":["beside","the","gold","and","silver","brass","iron","lead","tin"]},{"verseId":"brenton_numbers_31_23","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":23,"text":"every thing that shall pass through the fire shall so be clean, nevertheless it shall be purified with the water of sanctification; and whatsoever will not pass through the fire shall pass through water.","searchKeywords":["every","thing","that","shall","pass","through","the","fire","clean","nevertheless","purified","with","water","sanctification","and","whatsoever","will","not"]},{"verseId":"brenton_numbers_31_24","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":24,"text":"And on the seventh day ye shall wash your garments, and be clean; and afterwards ye shall come into the camp.","searchKeywords":["and","the","seventh","day","shall","wash","your","garments","clean","afterwards","come","into","camp"]},{"verseId":"brenton_numbers_31_25","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":25,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_numbers_31_26","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":26,"text":"Take the sum of the spoils of the captivity both of man and beast, thou and Eleazar the priest, and the heads of the families of the congregation.","searchKeywords":["take","the","sum","spoils","captivity","both","man","and","beast","thou","eleazar","priest","heads","families","congregation"]},{"verseId":"brenton_numbers_31_27","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":27,"text":"And ye shall divide the spoils between the warriors that went out to battle, and the whole congregation.","searchKeywords":["and","shall","divide","the","spoils","between","warriors","that","went","out","battle","whole","congregation"]},{"verseId":"brenton_numbers_31_28","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":28,"text":"And ye shall take a tribute for the Lord from the warriors that went out to battle; one soul out of five hundred, from the men, and from the cattle, even from the oxen, and from the sheep, and from the asses; and ye shall take from their half.","searchKeywords":["and","shall","take","tribute","for","the","lord","from","warriors","that","went","out","battle","one","soul","five","hundred","men","cattle","even","oxen","sheep","asses","their","half"]},{"verseId":"brenton_numbers_31_29","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":29,"text":"And thou shalt give to Eleazar the priest the first-fruits of the Lord.","searchKeywords":["and","thou","shalt","give","eleazar","the","priest","first","fruits","lord"]},{"verseId":"brenton_numbers_31_30","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":30,"text":"And from the half belonging to the children of Israel thou shalt take one in fifty from the men, and from the oxen, and from the sheep, and from the asses, and from all the cattle; and thou shalt give them to the Levites that keep the charges in the tabernacle of the Lord.","searchKeywords":["and","from","the","half","belonging","children","israel","thou","shalt","take","one","fifty","men","oxen","sheep","asses","all","cattle","give","them","levites","that","keep","charges","tabernacle","lord"]},{"verseId":"brenton_numbers_31_31","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":31,"text":"And Moses and Eleazar the priest did as the Lord commanded Moses.","searchKeywords":["and","moses","eleazar","the","priest","did","lord","commanded"]},{"verseId":"brenton_numbers_31_32","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":32,"text":"And that which remained of the spoil which the warriors took, was—of the sheep, six hundred and seventy-five thousand:","searchKeywords":["and","that","which","remained","the","spoil","warriors","took","was","sheep","six","hundred","seventy","five","thousand"]},{"verseId":"brenton_numbers_31_33","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":33,"text":"and oxen, seventy-two thousand:","searchKeywords":["and","oxen","seventy","two","thousand"]},{"verseId":"brenton_numbers_31_34","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":34,"text":"and asses, sixty-one thousand.","searchKeywords":["and","asses","sixty","one","thousand"]},{"verseId":"brenton_numbers_31_35","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":35,"text":"And persons of women who had not known lying with man, all the souls, thirty-two thousand.","searchKeywords":["and","persons","women","who","had","not","known","lying","with","man","all","the","souls","thirty","two","thousand"]},{"verseId":"brenton_numbers_31_36","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":36,"text":"And the half, the portion of them that went out to war, from the number of the sheep, was three hundred and thirty-seven thousand and five hundred.","searchKeywords":["and","the","half","portion","them","that","went","out","war","from","number","sheep","was","three","hundred","thirty","seven","thousand","five"]},{"verseId":"brenton_numbers_31_37","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":37,"text":"And the tribute to the Lord from the sheep was six hundred and seventy-five.","searchKeywords":["and","the","tribute","lord","from","sheep","was","six","hundred","seventy","five"]},{"verseId":"brenton_numbers_31_38","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":38,"text":"And the oxen, six and thirty thousand, and the tribute to the Lord, seventy-two.","searchKeywords":["and","the","oxen","six","thirty","thousand","tribute","lord","seventy","two"]},{"verseId":"brenton_numbers_31_39","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":39,"text":"And asses, thirty thousand and five hundred, and the tribute to the Lord, sixty-one:","searchKeywords":["and","asses","thirty","thousand","five","hundred","the","tribute","lord","sixty","one"]},{"verseId":"brenton_numbers_31_40","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":40,"text":"and the persons, sixteen thousand, and the tribute of them to the Lord, thirty-two souls.","searchKeywords":["and","the","persons","sixteen","thousand","tribute","them","lord","thirty","two","souls"]},{"verseId":"brenton_numbers_31_41","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":41,"text":"And Moses gave the tribute to the Lord, the heave-offering of God, to Eleazar the priest, as the Lord commanded Moses;","searchKeywords":["and","moses","gave","the","tribute","lord","heave","offering","god","eleazar","priest","commanded"]},{"verseId":"brenton_numbers_31_42","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":42,"text":"from the half belonging to the children of Israel, whom Moses separated from the men of war.","searchKeywords":["from","the","half","belonging","children","israel","whom","moses","separated","men","war"]},{"verseId":"brenton_numbers_31_43","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":43,"text":"And the half from the sheep, belonging to the congregation, was three hundred and thirty-seven thousand and five hundred.","searchKeywords":["and","the","half","from","sheep","belonging","congregation","was","three","hundred","thirty","seven","thousand","five"]},{"verseId":"brenton_numbers_31_44","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":44,"text":"And the oxen, thirty-six thousand;","searchKeywords":["and","the","oxen","thirty","six","thousand"]},{"verseId":"brenton_numbers_31_45","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":45,"text":"asses, thirty thousand and five hundred;","searchKeywords":["asses","thirty","thousand","and","five","hundred"]},{"verseId":"brenton_numbers_31_46","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":46,"text":"and persons, sixteen thousand.","searchKeywords":["and","persons","sixteen","thousand"]},{"verseId":"brenton_numbers_31_47","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":47,"text":"And Moses took of the half belonging to the children of Israel the fiftieth part, of men and of cattle, and he gave them to the Levites who keep the charges of the tabernacle of the Lord, as the Lord commanded Moses.","searchKeywords":["and","moses","took","the","half","belonging","children","israel","fiftieth","part","men","cattle","gave","them","levites","who","keep","charges","tabernacle","lord","commanded"]},{"verseId":"brenton_numbers_31_48","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":48,"text":"And all those who were appointed to be officers of thousands of the host, captains of thousands and captains of hundreds, approached Moses, and said to Moses,","searchKeywords":["and","all","those","who","were","appointed","officers","thousands","the","host","captains","hundreds","approached","moses","said"]},{"verseId":"brenton_numbers_31_49","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":49,"text":"Thy servants have taken the sum of the men of war with us, and not one is missing.","searchKeywords":["thy","servants","have","taken","the","sum","men","war","with","and","not","one","missing"]},{"verseId":"brenton_numbers_31_50","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":50,"text":"And we have brought our gift to the Lord, man who has found an article of gold, whether an armlet, or a chain, or a ring, or a bracelet, or a clasp for hair, to make atonement for us before the Lord.","searchKeywords":["and","have","brought","our","gift","the","lord","man","who","has","found","article","gold","whether","armlet","chain","ring","bracelet","clasp","for","hair","make","atonement","before"]},{"verseId":"brenton_numbers_31_51","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":51,"text":"And Moses and Eleazar the priest took the gold from them, even every wrought article.","searchKeywords":["and","moses","eleazar","the","priest","took","gold","from","them","even","every","wrought","article"]},{"verseId":"brenton_numbers_31_52","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":52,"text":"And all the wrought gold, even the offering that they offered to the Lord, was sixteen thousand and seven hundred and fifty shekels from the captains of thousands and the captains of hundreds.","searchKeywords":["and","all","the","wrought","gold","even","offering","that","they","offered","lord","was","sixteen","thousand","seven","hundred","fifty","shekels","from","captains","thousands","hundreds"]},{"verseId":"brenton_numbers_31_53","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":53,"text":"For the men of war took plunder every one for himself.","searchKeywords":["for","the","men","war","took","plunder","every","one","himself"]},{"verseId":"brenton_numbers_31_54","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":31,"verse":54,"text":"And Moses and Eleazar the priest took the gold from the captains of thousands and captains of hundreds, and brought the vessels into the tabernacle of witness, a memorial of the children of Israel before the Lord.","searchKeywords":["and","moses","eleazar","the","priest","took","gold","from","captains","thousands","hundreds","brought","vessels","into","tabernacle","witness","memorial","children","israel","before","lord"]}]