[{"verseId":"brenton_numbers_33_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":1,"text":"And these are the stages of the children of Israel, as they went out from the land of Egypt with their host by the hand of Moses and Aaron.","searchKeywords":["and","these","are","the","stages","children","israel","they","went","out","from","land","egypt","with","their","host","hand","moses","aaron"]},{"verseId":"brenton_numbers_33_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":2,"text":"And Moses wrote their removals and their stages, by the word of the Lord: and these are the stages of their journeying.","searchKeywords":["and","moses","wrote","their","removals","stages","the","word","lord","these","are","journeying"]},{"verseId":"brenton_numbers_33_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":3,"text":"They departed from Ramesses in the first month, on the fifteenth day of the first month; on the day after the passover the children of Israel went forth with a high hand before all the Egyptians.","searchKeywords":["they","departed","from","ramesses","the","first","month","fifteenth","day","after","passover","children","israel","went","forth","with","high","hand","before","all","egyptians"]},{"verseId":"brenton_numbers_33_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":4,"text":"And the Egyptians buried those that died of them, even all that the Lord smote, every first-born in the land of Egypt; also the Lord executed vengeance on their gods.","searchKeywords":["and","the","egyptians","buried","those","that","died","them","even","all","lord","smote","every","first","born","land","egypt","also","executed","vengeance","their","gods"]},{"verseId":"brenton_numbers_33_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":5,"text":"And the children of Israel departed from Ramesses, and encamped in Socchoth:","searchKeywords":["and","the","children","israel","departed","from","ramesses","encamped","socchoth"]},{"verseId":"brenton_numbers_33_6","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":6,"text":"and they departed from Socchoth and encamped in Buthan, which is a part of the wilderness.","searchKeywords":["and","they","departed","from","socchoth","encamped","buthan","which","part","the","wilderness"]},{"verseId":"brenton_numbers_33_7","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":7,"text":"And they departed from Buthan and encamped at the mouth of Iroth, which is opposite Beel-sepphon, and encamped opposite Magdol.","searchKeywords":["and","they","departed","from","buthan","encamped","the","mouth","iroth","which","opposite","beel","sepphon","magdol"]},{"verseId":"brenton_numbers_33_8","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":8,"text":"And they departed from before Iroth, and crossed the middle of the sea into the wilderness; and they went a journey of three days through the wilderness, and encamped in Picriæ.","searchKeywords":["and","they","departed","from","before","iroth","crossed","the","middle","sea","into","wilderness","went","journey","three","days","through","encamped","picri"]},{"verseId":"brenton_numbers_33_9","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":9,"text":"And they departed from Picriæ, and came to Ælim; and in Ælim twelve fountains of water, and seventy palm-trees, and they encamped there by the water.","searchKeywords":["and","they","departed","from","picri","came","lim","twelve","fountains","water","seventy","palm","trees","encamped","there","the"]},{"verseId":"brenton_numbers_33_10","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":10,"text":"And they departed from Ælim, and encamped by the Red Sea.","searchKeywords":["and","they","departed","from","lim","encamped","the","red","sea"]},{"verseId":"brenton_numbers_33_11","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":11,"text":"And they departed from the Red Sea, and encamped in the wilderness of Sin.","searchKeywords":["and","they","departed","from","the","red","sea","encamped","wilderness","sin"]},{"verseId":"brenton_numbers_33_12","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":12,"text":"And they departed from the wilderness of Sin, and encamped in Raphaca.","searchKeywords":["and","they","departed","from","the","wilderness","sin","encamped","raphaca"]},{"verseId":"brenton_numbers_33_13","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":13,"text":"And they departed from Raphaca, and encamped in Ælus.","searchKeywords":["and","they","departed","from","raphaca","encamped","lus"]},{"verseId":"brenton_numbers_33_14","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":14,"text":"And they departed from Ælus, and encamped in Raphidin; and there was no water there for the people to drink.","searchKeywords":["and","they","departed","from","lus","encamped","raphidin","there","was","water","for","the","people","drink"]},{"verseId":"brenton_numbers_33_15","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":15,"text":"And they departed from Raphidin, and encamped in the wilderness of Sina.","searchKeywords":["and","they","departed","from","raphidin","encamped","the","wilderness","sina"]},{"verseId":"brenton_numbers_33_16","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":16,"text":"And they departed from the wilderness of Sina, and encamped at the Graves of Lust.","searchKeywords":["and","they","departed","from","the","wilderness","sina","encamped","graves","lust"]},{"verseId":"brenton_numbers_33_17","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":17,"text":"And they departed from the Graves of Lust, and encamped in Aseroth.","searchKeywords":["and","they","departed","from","the","graves","lust","encamped","aseroth"]},{"verseId":"brenton_numbers_33_18","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":18,"text":"And they departed from Aseroth, and encamped in Rathama.","searchKeywords":["and","they","departed","from","aseroth","encamped","rathama"]},{"verseId":"brenton_numbers_33_19","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":19,"text":"And they departed from Rathama, and encamped in Remmon Phares.","searchKeywords":["and","they","departed","from","rathama","encamped","remmon","phares"]},{"verseId":"brenton_numbers_33_20","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":20,"text":"And they departed from Remmon Phares, and encamped in Lebona.","searchKeywords":["and","they","departed","from","remmon","phares","encamped","lebona"]},{"verseId":"brenton_numbers_33_21","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":21,"text":"And they departed from Lebona, and encamped in Ressan.","searchKeywords":["and","they","departed","from","lebona","encamped","ressan"]},{"verseId":"brenton_numbers_33_22","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":22,"text":"And they departed from Ressan, and encamped in Makellath.","searchKeywords":["and","they","departed","from","ressan","encamped","makellath"]},{"verseId":"brenton_numbers_33_23","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":23,"text":"And they departed from Makellath, and encamped in Saphar.","searchKeywords":["and","they","departed","from","makellath","encamped","saphar"]},{"verseId":"brenton_numbers_33_24","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":24,"text":"And they departed from Saphar, and encamped in Charadath.","searchKeywords":["and","they","departed","from","saphar","encamped","charadath"]},{"verseId":"brenton_numbers_33_25","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":25,"text":"And they departed from Charadath, and encamped in Makeloth.","searchKeywords":["and","they","departed","from","charadath","encamped","makeloth"]},{"verseId":"brenton_numbers_33_26","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":26,"text":"And they departed from Makeloth, and encamped in Kataath.","searchKeywords":["and","they","departed","from","makeloth","encamped","kataath"]},{"verseId":"brenton_numbers_33_27","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":27,"text":"And they departed from Kataath, and encamped in Tarath.","searchKeywords":["and","they","departed","from","kataath","encamped","tarath"]},{"verseId":"brenton_numbers_33_28","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":28,"text":"And they departed from Tarath, and encamped in Mathecca.","searchKeywords":["and","they","departed","from","tarath","encamped","mathecca"]},{"verseId":"brenton_numbers_33_29","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":29,"text":"And they departed from Mathecca, and encamped in Selmona.","searchKeywords":["and","they","departed","from","mathecca","encamped","selmona"]},{"verseId":"brenton_numbers_33_30","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":30,"text":"And they departed from Selmona, and encamped in Masuruth.","searchKeywords":["and","they","departed","from","selmona","encamped","masuruth"]},{"verseId":"brenton_numbers_33_31","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":31,"text":"And they departed from Masuruth, and encamped in Banæa.","searchKeywords":["and","they","departed","from","masuruth","encamped","ban"]},{"verseId":"brenton_numbers_33_32","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":32,"text":"And they departed from Banæa, and encamped in the mountain Gadgad.","searchKeywords":["and","they","departed","from","ban","encamped","the","mountain","gadgad"]},{"verseId":"brenton_numbers_33_33","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":33,"text":"And they departed from the mountain Gadgad, and encamped in Etebatha.","searchKeywords":["and","they","departed","from","the","mountain","gadgad","encamped","etebatha"]},{"verseId":"brenton_numbers_33_34","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":34,"text":"And they departed from Etebatha, and encamped in Ebrona.","searchKeywords":["and","they","departed","from","etebatha","encamped","ebrona"]},{"verseId":"brenton_numbers_33_35","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":35,"text":"And they departed from Ebrona, and encamped in Gesion Gaber.","searchKeywords":["and","they","departed","from","ebrona","encamped","gesion","gaber"]},{"verseId":"brenton_numbers_33_36","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":36,"text":"And they departed from Gesion Gaber, and encamped in the wilderness of Sin; and they departed from the wilderness of Sin, and encamped in the wilderness of Pharan; this is Cades.","searchKeywords":["and","they","departed","from","gesion","gaber","encamped","the","wilderness","sin","pharan","this","cades"]},{"verseId":"brenton_numbers_33_37","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":37,"text":"And they departed from Cades, and encamped in mount Or near the land of Edom.","searchKeywords":["and","they","departed","from","cades","encamped","mount","near","the","land","edom"]},{"verseId":"brenton_numbers_33_38","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":38,"text":"And Aaron the priest went up by the command of the Lord, and died there in the fortieth year of the departure of the children of Israel from the land of Egypt, in the fifth month, on the first of the month.","searchKeywords":["and","aaron","the","priest","went","command","lord","died","there","fortieth","year","departure","children","israel","from","land","egypt","fifth","month","first"]},{"verseId":"brenton_numbers_33_39","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":39,"text":"And Aaron was a hundred and twenty-three years old, when he died in mount Or.","searchKeywords":["and","aaron","was","hundred","twenty","three","years","old","when","died","mount"]},{"verseId":"brenton_numbers_33_40","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":40,"text":"And Arad the Chananitish king (he too dwelt in the land of Chanaan) having heard when the children of Israel were entering —","searchKeywords":["and","arad","the","chananitish","king","too","dwelt","land","chanaan","having","heard","when","children","israel","were","entering"]},{"verseId":"brenton_numbers_33_41","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":41,"text":"then they departed from mount Or, and encamped in Selmona.","searchKeywords":["then","they","departed","from","mount","and","encamped","selmona"]},{"verseId":"brenton_numbers_33_42","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":42,"text":"And they departed from Selmona, and encamped in Phino.","searchKeywords":["and","they","departed","from","selmona","encamped","phino"]},{"verseId":"brenton_numbers_33_43","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":43,"text":"And they departed from Phino, and encamped in Oboth.","searchKeywords":["and","they","departed","from","phino","encamped","oboth"]},{"verseId":"brenton_numbers_33_44","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":44,"text":"And they departed from Oboth, and encamped in Gai, on the other side on the borders of Moab.","searchKeywords":["and","they","departed","from","oboth","encamped","gai","the","other","side","borders","moab"]},{"verseId":"brenton_numbers_33_45","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":45,"text":"And they departed from Gai, and encamped in Dæbon Gad.","searchKeywords":["and","they","departed","from","gai","encamped","bon","gad"]},{"verseId":"brenton_numbers_33_46","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":46,"text":"And they departed from Dæbon Gad, and encamped in Gelmon Deblathaim.","searchKeywords":["and","they","departed","from","bon","gad","encamped","gelmon","deblathaim"]},{"verseId":"brenton_numbers_33_47","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":47,"text":"And they departed from Gelmon Deblathaim, and encamped on the mountains of Abarim, over against Nabau.","searchKeywords":["and","they","departed","from","gelmon","deblathaim","encamped","the","mountains","abarim","over","against","nabau"]},{"verseId":"brenton_numbers_33_48","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":48,"text":"And they departed from the mountains of Abarim, and encamped on the west of Moab, at Jordan by Jericho.","searchKeywords":["and","they","departed","from","the","mountains","abarim","encamped","west","moab","jordan","jericho"]},{"verseId":"brenton_numbers_33_49","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":49,"text":"And they encamped by Jordan between Æsimoth, as far as Belsa to the west of Moab.","searchKeywords":["and","they","encamped","jordan","between","simoth","far","belsa","the","west","moab"]},{"verseId":"brenton_numbers_33_50","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":50,"text":"And the Lord spoke to Moses at the west of Moab by Jordan at Jericho, saying,","searchKeywords":["and","the","lord","spoke","moses","west","moab","jordan","jericho","saying"]},{"verseId":"brenton_numbers_33_51","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":51,"text":"Speak to the children of Israel, and thou shalt say to them, Ye are to pass over Jordan into the land of Chanaan.","searchKeywords":["speak","the","children","israel","and","thou","shalt","say","them","are","pass","over","jordan","into","land","chanaan"]},{"verseId":"brenton_numbers_33_52","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":52,"text":"And ye shall destroy all that dwell in the land before your face, and ye shall abolish their high places, and all their molten images ye shall destroy, and ye shall demolish all their pillars.","searchKeywords":["and","shall","destroy","all","that","dwell","the","land","before","your","face","abolish","their","high","places","molten","images","demolish","pillars"]},{"verseId":"brenton_numbers_33_53","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":53,"text":"And ye shall destroy all the inhabitants of the land, and ye shall dwell in it, for I have given their land to you for an inheritance.","searchKeywords":["and","shall","destroy","all","the","inhabitants","land","dwell","for","have","given","their","you","inheritance"]},{"verseId":"brenton_numbers_33_54","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":54,"text":"And ye shall inherit their land according to your tribes; to the greater number ye shall give the larger possession, and to the smaller ye shall give the less possession; to whatsoever a man's name shall go forth , there shall be his : ye shall inherit according to the tribes of your families.","searchKeywords":["and","shall","inherit","their","land","according","your","tribes","the","greater","number","give","larger","possession","smaller","less","whatsoever","man","name","forth","there","his","families"]},{"verseId":"brenton_numbers_33_55","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":55,"text":"But if ye will not destroy the dwellers in the land from before you, then it shall come to pass that whomsoever of them ye shall leave shall be thorns in your eyes, and darts in your sides, and they shall be enemies to you on the land on which ye shall dwell;","searchKeywords":["but","will","not","destroy","the","dwellers","land","from","before","you","then","shall","come","pass","that","whomsoever","them","leave","thorns","your","eyes","and","darts","sides","they","enemies","which","dwell"]},{"verseId":"brenton_numbers_33_56","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":33,"verse":56,"text":"and it shall come to pass that as I had determined to do to them, so I will do to you.","searchKeywords":["and","shall","come","pass","that","had","determined","them","will","you"]}]