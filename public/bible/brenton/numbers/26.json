[{"verseId":"brenton_numbers_26_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":26,"verse":1,"text":"And it came to pass after the plague, that the Lord spoke to Moses and Eleazar the priest, saying,","searchKeywords":["and","came","pass","after","the","plague","that","lord","spoke","moses","eleazar","priest","saying"]},{"verseId":"brenton_numbers_26_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":26,"verse":2,"text":"Take the sum of all the congregation of the children of Israel, from twenty years old and upward, according to the houses of their lineage, every one that goes forth to battle in Israel.","searchKeywords":["take","the","sum","all","congregation","children","israel","from","twenty","years","old","and","upward","according","houses","their","lineage","every","one","that","goes","forth","battle"]},{"verseId":"brenton_numbers_26_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":26,"verse":3,"text":"And Moses and Eleazar the priest spoke in Araboth of Moab at the Jordan by Jericho, saying,","searchKeywords":["and","moses","eleazar","the","priest","spoke","araboth","moab","jordan","jericho","saying"]},{"verseId":"brenton_numbers_26_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":26,"verse":4,"text":"from twenty years old and upward as the Lord commanded Moses. And the sons of Israel that came out of Egypt :","searchKeywords":["from","twenty","years","old","and","upward","the","lord","commanded","moses","sons","israel","that","came","out","egypt"]},{"verseId":"brenton_numbers_26_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":26,"verse":5,"text":"Ruben the first-born of Israel: and the sons of Ruben, Enoch, and the family of Enoch; to Pha