[{"verseId":"brenton_numbers_10_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":1,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_numbers_10_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":2,"text":"Make to thyself two silver trumpets: thou shalt make them of beaten work; and they shall be to thee for the purpose of calling the assembly, and of removing the camps.","searchKeywords":["make","thyself","two","silver","trumpets","thou","shalt","them","beaten","work","and","they","shall","thee","for","the","purpose","calling","assembly","removing","camps"]},{"verseId":"brenton_numbers_10_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":3,"text":"And thou shalt sound with them, and all the congregation shall be gathered to the door of the tabernacle of witness.","searchKeywords":["and","thou","shalt","sound","with","them","all","the","congregation","shall","gathered","door","tabernacle","witness"]},{"verseId":"brenton_numbers_10_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":4,"text":"And if they shall sound with one, all the rulers even the princes of Israel shall come to thee.","searchKeywords":["and","they","shall","sound","with","one","all","the","rulers","even","princes","israel","come","thee"]},{"verseId":"brenton_numbers_10_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":5,"text":"And ye shall sound an alarm, and the camps pitched eastward shall begin to move.","searchKeywords":["and","shall","sound","alarm","the","camps","pitched","eastward","begin","move"]},{"verseId":"brenton_numbers_10_6","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":6,"text":"And ye shall sound a second alarm, and the camps pitched southward shall move; and ye shall sound a third alarm, and the camps pitched westward shall move forward; and ye shall sound a fourth alarm, and they that encamp toward the north shall move forward: they shall sound an alarm at their departure.","searchKeywords":["and","shall","sound","second","alarm","the","camps","pitched","southward","move","third","westward","forward","fourth","they","that","encamp","toward","north","their","departure"]},{"verseId":"brenton_numbers_10_7","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":7,"text":"And whenever ye shall gather the assembly, ye shall sound, but not an alarm.","searchKeywords":["and","whenever","shall","gather","the","assembly","sound","but","not","alarm"]},{"verseId":"brenton_numbers_10_8","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":8,"text":"And the priests the sons of Aaron shall sound with the trumpets; and it shall be a perpetual ordinance for you throughout your generations.","searchKeywords":["and","the","priests","sons","aaron","shall","sound","with","trumpets","perpetual","ordinance","for","you","throughout","your","generations"]},{"verseId":"brenton_numbers_10_9","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":9,"text":"And if ye shall go forth to war in your land against your enemies that are opposed to you, then shall ye sound with the trumpets; and ye shall be had in remembrance before the Lord, and ye shall be saved from your enemies.","searchKeywords":["and","shall","forth","war","your","land","against","enemies","that","are","opposed","you","then","sound","with","the","trumpets","had","remembrance","before","lord","saved","from"]},{"verseId":"brenton_numbers_10_10","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":10,"text":"And in the days of your gladness, and in your feasts, and in your new moons, ye shall sound with the trumpets at your whole-burnt-offerings, and at the sacrifices of your peace-offerings; and there shall be a memorial for you before your God: I the Lord your God.","searchKeywords":["and","the","days","your","gladness","feasts","new","moons","shall","sound","with","trumpets","whole","burnt","offerings","sacrifices","peace","there","memorial","for","you","before","god","lord"]},{"verseId":"brenton_numbers_10_11","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":11,"text":"And it came to pass in the second year, in the second month, on the twentieth day of the month, the cloud went up from the tabernacle of witness.","searchKeywords":["and","came","pass","the","second","year","month","twentieth","day","cloud","went","from","tabernacle","witness"]},{"verseId":"brenton_numbers_10_12","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":12,"text":"And the children of Israel set forward with their baggage in the wilderness of Sina; and the cloud rested in the wilderness of Pharan.","searchKeywords":["and","the","children","israel","set","forward","with","their","baggage","wilderness","sina","cloud","rested","pharan"]},{"verseId":"brenton_numbers_10_13","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":13,"text":"And the first rank departed by the word of the Lord by the hand of Moses.","searchKeywords":["and","the","first","rank","departed","word","lord","hand","moses"]},{"verseId":"brenton_numbers_10_14","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":14,"text":"And they first set in motion the order of the camp of the children of Juda with their host; and over their host Naasson, son of Aminadab.","searchKeywords":["and","they","first","set","motion","the","order","camp","children","juda","with","their","host","over","naasson","son","aminadab"]},{"verseId":"brenton_numbers_10_15","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":15,"text":"And over the host of the tribe of the sons of Issachar, Nathanael son of Sogar.","searchKeywords":["and","over","the","host","tribe","sons","issachar","nathanael","son","sogar"]},{"verseId":"brenton_numbers_10_16","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":16,"text":"And over the host of the tribe of the sons of Zabulon, Eliab the son of Chælon.","searchKeywords":["and","over","the","host","tribe","sons","zabulon","eliab","son","lon"]},{"verseId":"brenton_numbers_10_17","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":17,"text":"And they shall take down the tabernacle, and the sons of Gedson shall set forward, and the sons of Merari, who bear the tabernacle.","searchKeywords":["and","they","shall","take","down","the","tabernacle","sons","gedson","set","forward","merari","who","bear"]},{"verseId":"brenton_numbers_10_18","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":18,"text":"And the order of the camp of Ruben set forward with their host; and over their host Elisur the son of Sediur.","searchKeywords":["and","the","order","camp","ruben","set","forward","with","their","host","over","elisur","son","sediur"]},{"verseId":"brenton_numbers_10_19","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":19,"text":"And over the host of the tribe of the sons of Symeon, Salamiel son of Surisadai.","searchKeywords":["and","over","the","host","tribe","sons","symeon","salamiel","son","surisadai"]},{"verseId":"brenton_numbers_10_20","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":20,"text":"And over the host of the tribe of the children of Gad, Elisaph the son of Raguel.","searchKeywords":["and","over","the","host","tribe","children","gad","elisaph","son","raguel"]},{"verseId":"brenton_numbers_10_21","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":21,"text":"And the sons of Caath shall set forward bearing the holy things, and shall set up the tabernacle until they arrive.","searchKeywords":["and","the","sons","caath","shall","set","forward","bearing","holy","things","tabernacle","until","they","arrive"]},{"verseId":"brenton_numbers_10_22","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":22,"text":"And the order of the camp of Ephraim shall set forward with their forces; and over their forces Elisama the son of Semiud.","searchKeywords":["and","the","order","camp","ephraim","shall","set","forward","with","their","forces","over","elisama","son","semiud"]},{"verseId":"brenton_numbers_10_23","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":23,"text":"And over the forces of the tribe of the sons of Manasse, Gamaliel the of Phadassur.","searchKeywords":["and","over","the","forces","tribe","sons","manasse","gamaliel","phadassur"]},{"verseId":"brenton_numbers_10_24","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":24,"text":"And over the forces of the tribe of the children of Benjamin, Abidan the of Gadeoni.","searchKeywords":["and","over","the","forces","tribe","children","benjamin","abidan","gadeoni"]},{"verseId":"brenton_numbers_10_25","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":25,"text":"And the order of the camp of the sons of Dan shall set forward the last of all the camps, with their forces: and over their forces Achiezer the of Amisadai.","searchKeywords":["and","the","order","camp","sons","dan","shall","set","forward","last","all","camps","with","their","forces","over","achiezer","amisadai"]},{"verseId":"brenton_numbers_10_26","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":26,"text":"And over the forces of the tribe of the sons of Aser, Phageel the son of Echran.","searchKeywords":["and","over","the","forces","tribe","sons","aser","phageel","son","echran"]},{"verseId":"brenton_numbers_10_27","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":27,"text":"And over the forces of the tribe of the sons of Nephthali, Achire the son of Ænan.","searchKeywords":["and","over","the","forces","tribe","sons","nephthali","achire","son","nan"]},{"verseId":"brenton_numbers_10_28","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":28,"text":"These the armies of the children of Israel; and they set forward with their forces.","searchKeywords":["these","the","armies","children","israel","and","they","set","forward","with","their","forces"]},{"verseId":"brenton_numbers_10_29","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":29,"text":"And Moses said to Obab the son of Raguel the Madianite, the father-in-law of Moses, We are going forward to the place concerning which the Lord said, This will I give to you: Come with us, and we will do thee good, for the Lord has spoken good concerning Israel.","searchKeywords":["and","moses","said","obab","the","son","raguel","madianite","father","law","are","going","forward","place","concerning","which","lord","this","will","give","you","come","with","thee","good","for","has","spoken","israel"]},{"verseId":"brenton_numbers_10_30","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":30,"text":"And he said to him, I will not go, but to my land and to my kindred.","searchKeywords":["and","said","him","will","not","but","land","kindred"]},{"verseId":"brenton_numbers_10_31","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":31,"text":"And he said, Leave us not, because thou hast been with us in the wilderness, and thou shalt be an elder among us.","searchKeywords":["and","said","leave","not","because","thou","hast","been","with","the","wilderness","shalt","elder","among"]},{"verseId":"brenton_numbers_10_32","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":32,"text":"And it shall come to pass if thou wilt go with us, it shall even come to pass that in whatsoever things the Lord shall do us good, we will also do thee good.","searchKeywords":["and","shall","come","pass","thou","wilt","with","even","that","whatsoever","things","the","lord","good","will","also","thee"]},{"verseId":"brenton_numbers_10_33","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":33,"text":"And they departed from the mount of the Lord a three days' journey; and the ark of the covenant of the Lord went before them a three days' journey to provide rest for them.","searchKeywords":["and","they","departed","from","the","mount","lord","three","days","journey","ark","covenant","went","before","them","provide","rest","for"]},{"verseId":"brenton_numbers_10_34","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":34,"text":"And it came to pass when the ark set forward, that Moses said, Arise, O Lord, and let thine enemies be scattered: let all that hate thee flee.","searchKeywords":["and","came","pass","when","the","ark","set","forward","that","moses","said","arise","lord","let","thine","enemies","scattered","all","hate","thee","flee"]},{"verseId":"brenton_numbers_10_35","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":35,"text":"And in the resting he said, Turn again, O Lord, the thousands tens of thousands in Israel.","searchKeywords":["and","the","resting","said","turn","again","lord","thousands","tens","israel"]},{"verseId":"brenton_numbers_10_36","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":10,"verse":36,"text":"And the cloud overshadowed them by day, when they departed from the camp.","searchKeywords":["and","the","cloud","overshadowed","them","day","when","they","departed","from","camp"]}]