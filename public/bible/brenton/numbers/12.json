[{"verseId":"brenton_numbers_12_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":1,"text":"And Mariam and Aaron spoke against Moses, because of the Ethiopian woman whom Moses took; for he had taken an Ethiopian woman.","searchKeywords":["and","mariam","aaron","spoke","against","moses","because","the","ethiopian","woman","whom","took","for","had","taken"]},{"verseId":"brenton_numbers_12_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":2,"text":"And they said, Has the Lord spoken to Moses only? has he not also spoken to us? and the Lord heard it.","searchKeywords":["and","they","said","has","the","lord","spoken","moses","only","not","also","heard"]},{"verseId":"brenton_numbers_12_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":3,"text":"And the man Moses was very meek beyond all the men that were upon the earth.","searchKeywords":["and","the","man","moses","was","very","meek","beyond","all","men","that","were","upon","earth"]},{"verseId":"brenton_numbers_12_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":4,"text":"And the Lord said immediately to Moses and Aaron and Mariam, Come forth all three of you to the tabernacle of witness.","searchKeywords":["and","the","lord","said","immediately","moses","aaron","mariam","come","forth","all","three","you","tabernacle","witness"]},{"verseId":"brenton_numbers_12_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":5,"text":"And the three came forth to the tabernacle of witness; and the Lord descended in a pillar of a cloud, and stood at the door of the tabernacle of witness; and Aaron and Mariam were called; and both came forth.","searchKeywords":["and","the","three","came","forth","tabernacle","witness","lord","descended","pillar","cloud","stood","door","aaron","mariam","were","called","both"]},{"verseId":"brenton_numbers_12_6","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":6,"text":"And he said to them, Hear my words: If there should be of you a prophet to the Lord, I will be made known to him in a vision, and in sleep will I speak to him.","searchKeywords":["and","said","them","hear","words","there","should","you","prophet","the","lord","will","made","known","him","vision","sleep","speak"]},{"verseId":"brenton_numbers_12_7","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":7,"text":"My servant Moses not so; he is faithful in all my house.","searchKeywords":["servant","moses","not","faithful","all","house"]},{"verseId":"brenton_numbers_12_8","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":8,"text":"I will speak to him mouth to mouth apparently, and not in dark speeches; and he has seen the glory of the Lord; and why were ye not afraid to speak against my servant Moses?","searchKeywords":["will","speak","him","mouth","apparently","and","not","dark","speeches","has","seen","the","glory","lord","why","were","afraid","against","servant","moses"]},{"verseId":"brenton_numbers_12_9","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":9,"text":"And the great anger of the Lord upon them, and he departed.","searchKeywords":["and","the","great","anger","lord","upon","them","departed"]},{"verseId":"brenton_numbers_12_10","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":10,"text":"And the cloud departed from the tabernacle; and, behold, Mariam was leprous, as snow; and Aaron looked upon Mariam, and, behold, she leprous.","searchKeywords":["and","the","cloud","departed","from","tabernacle","behold","mariam","was","leprous","snow","aaron","looked","upon","she"]},{"verseId":"brenton_numbers_12_11","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":11,"text":"And Aaron said to Moses, I beseech thee, my lord, do not lay sin upon us, for we were ignorant wherein we sinned.","searchKeywords":["and","aaron","said","moses","beseech","thee","lord","not","lay","sin","upon","for","were","ignorant","wherein","sinned"]},{"verseId":"brenton_numbers_12_12","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":12,"text":"Let her not be as it were like death, as an abortion coming out of his mother's womb, when devours the half of the flesh.","searchKeywords":["let","her","not","were","like","death","abortion","coming","out","his","mother","womb","when","devours","the","half","flesh"]},{"verseId":"brenton_numbers_12_13","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":13,"text":"And Moses cried to the Lord, saying, O God, I beseech thee, heal her.","searchKeywords":["and","moses","cried","the","lord","saying","god","beseech","thee","heal","her"]},{"verseId":"brenton_numbers_12_14","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":14,"text":"And the Lord said to Moses, If her father had only spit in her face, would she not be ashamed seven days? let her be set apart seven days without the camp, and afterwards she shall come in.","searchKeywords":["and","the","lord","said","moses","her","father","had","only","spit","face","would","she","not","ashamed","seven","days","let","set","apart","without","camp","afterwards","shall","come"]},{"verseId":"brenton_numbers_12_15","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":15,"text":"And Mariam was separated without the camp seven days; and the people moved not forward till Mariam was cleansed.","searchKeywords":["and","mariam","was","separated","without","the","camp","seven","days","people","moved","not","forward","till","cleansed"]},{"verseId":"brenton_numbers_12_16","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":12,"verse":16,"text":"And afterwards the people set forth from Aseroth, and encamped in the wilderness of Pharan.","searchKeywords":["and","afterwards","the","people","set","forth","from","aseroth","encamped","wilderness","pharan"]}]