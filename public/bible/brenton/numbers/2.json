[{"verseId":"brenton_numbers_2_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":1,"text":"And the Lord spoke to Moses and Aaron, saying,","searchKeywords":["and","the","lord","spoke","moses","aaron","saying"]},{"verseId":"brenton_numbers_2_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":2,"text":"Let the children of Israel encamp fronting , every man keeping his own rank, according to standards, according to the houses of their families; the children of Israel shall encamp round about the tabernacle of witness.","searchKeywords":["let","the","children","israel","encamp","fronting","every","man","keeping","his","own","rank","according","standards","houses","their","families","shall","round","about","tabernacle","witness"]},{"verseId":"brenton_numbers_2_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":3,"text":"And they that encamp first toward the east the order of the camp of Juda with their host, and the prince of the sons of Juda, Naasson the son of Aminadab.","searchKeywords":["and","they","that","encamp","first","toward","the","east","order","camp","juda","with","their","host","prince","sons","naasson","son","aminadab"]},{"verseId":"brenton_numbers_2_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":4,"text":"His forces that were numbered, were seventy-four thousand and six hundred.","searchKeywords":["his","forces","that","were","numbered","seventy","four","thousand","and","six","hundred"]},{"verseId":"brenton_numbers_2_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":5,"text":"And they that encamp next of the tribe of Issachar, and the prince of the sons of Issachar Nathanael the son of Sogar.","searchKeywords":["and","they","that","encamp","next","the","tribe","issachar","prince","sons","nathanael","son","sogar"]},{"verseId":"brenton_numbers_2_6","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":6,"text":"His forces that were numbered, were fifty-four thousand and four hundred.","searchKeywords":["his","forces","that","were","numbered","fifty","four","thousand","and","hundred"]},{"verseId":"brenton_numbers_2_7","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":7,"text":"And they that encamp next of the tribe of Zabulon, and the prince of the sons of Zabulon Eliab the son of Chælon.","searchKeywords":["and","they","that","encamp","next","the","tribe","zabulon","prince","sons","eliab","son","lon"]},{"verseId":"brenton_numbers_2_8","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":8,"text":"His forces that were numbered, were fifty-seven thousand and four hundred.","searchKeywords":["his","forces","that","were","numbered","fifty","seven","thousand","and","four","hundred"]},{"verseId":"brenton_numbers_2_9","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":9,"text":"All that were numbered of the camp of Juda were a hundred and eighty thousand and six thousand and four hundred: they shall move first with their forces.","searchKeywords":["all","that","were","numbered","the","camp","juda","hundred","and","eighty","thousand","six","four","they","shall","move","first","with","their","forces"]},{"verseId":"brenton_numbers_2_10","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":10,"text":"the order of the camp of Ruben; their forces toward the south, and the prince of the children of Ruben Elisur the son of Sediur.","searchKeywords":["the","order","camp","ruben","their","forces","toward","south","and","prince","children","elisur","son","sediur"]},{"verseId":"brenton_numbers_2_11","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":11,"text":"His forces that were numbered, were forty-six thousand and five hundred.","searchKeywords":["his","forces","that","were","numbered","forty","six","thousand","and","five","hundred"]},{"verseId":"brenton_numbers_2_12","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":12,"text":"And they that encamp next to him of the tribe of Symeon, and the prince of the sons of Symeon Salamiel the son of Surisadai.","searchKeywords":["and","they","that","encamp","next","him","the","tribe","symeon","prince","sons","salamiel","son","surisadai"]},{"verseId":"brenton_numbers_2_13","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":13,"text":"His forces that were numbered, were fifty-nine thousand and three hundred.","searchKeywords":["his","forces","that","were","numbered","fifty","nine","thousand","and","three","hundred"]},{"verseId":"brenton_numbers_2_14","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":14,"text":"And they that encamp next to them the tribe of Gad; and the prince of the sons of Gad, Elisaph the son of Raguel.","searchKeywords":["and","they","that","encamp","next","them","the","tribe","gad","prince","sons","elisaph","son","raguel"]},{"verseId":"brenton_numbers_2_15","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":15,"text":"His forces that were numbered, were forty-five thousand and six hundred and fifty.","searchKeywords":["his","forces","that","were","numbered","forty","five","thousand","and","six","hundred","fifty"]},{"verseId":"brenton_numbers_2_16","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":16,"text":"All who were numbered of the camp of Ruben, were a hundred and fifty-one thousand and four hundred and fifty: they with their forces shall proceed in the second place.","searchKeywords":["all","who","were","numbered","the","camp","ruben","hundred","and","fifty","one","thousand","four","they","with","their","forces","shall","proceed","second","place"]},{"verseId":"brenton_numbers_2_17","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":17,"text":"And the tabernacle of witness shall be set forward, and the camp of the Levites between the camps; as they shall encamp, so also shall they commence their march, each one next in order to his fellow according to their companies.","searchKeywords":["and","the","tabernacle","witness","shall","set","forward","camp","levites","between","camps","they","encamp","also","commence","their","march","each","one","next","order","his","fellow","according","companies"]},{"verseId":"brenton_numbers_2_18","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":18,"text":"The station of the camp of Ephraim westward with their forces, and the head of the children of Ephraim Elisama the son of Emiud.","searchKeywords":["the","station","camp","ephraim","westward","with","their","forces","and","head","children","elisama","son","emiud"]},{"verseId":"brenton_numbers_2_19","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":19,"text":"His forces that were numbered, are forty thousand and five hundred.","searchKeywords":["his","forces","that","were","numbered","are","forty","thousand","and","five","hundred"]},{"verseId":"brenton_numbers_2_20","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":20,"text":"And they that encamp next of the tribe of Manasse, and the prince of the sons of Manasse, Gamaliel the son of Phadassur.","searchKeywords":["and","they","that","encamp","next","the","tribe","manasse","prince","sons","gamaliel","son","phadassur"]},{"verseId":"brenton_numbers_2_21","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":21,"text":"His forces that were numbered, were thirty-two thousand and two hundred.","searchKeywords":["his","forces","that","were","numbered","thirty","two","thousand","and","hundred"]},{"verseId":"brenton_numbers_2_22","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":22,"text":"And they that encamp next of the tribe of Benjamin, and the prince of the sons of Benjamin, Abidan the son of Gadeoni.","searchKeywords":["and","they","that","encamp","next","the","tribe","benjamin","prince","sons","abidan","son","gadeoni"]},{"verseId":"brenton_numbers_2_23","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":23,"text":"His forces that were numbered, were thirty-five thousand and four hundred.","searchKeywords":["his","forces","that","were","numbered","thirty","five","thousand","and","four","hundred"]},{"verseId":"brenton_numbers_2_24","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":24,"text":"All that were numbered of the camp of Ephraim, were one hundred and eight thousand and one hundred: they with their forces shall set out third.","searchKeywords":["all","that","were","numbered","the","camp","ephraim","one","hundred","and","eight","thousand","they","with","their","forces","shall","set","out","third"]},{"verseId":"brenton_numbers_2_25","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":25,"text":"The order of the camp of Dan northward with their forces; and the prince of the sons of Dan, Achiezer the son of Amisadai.","searchKeywords":["the","order","camp","dan","northward","with","their","forces","and","prince","sons","achiezer","son","amisadai"]},{"verseId":"brenton_numbers_2_26","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":26,"text":"His forces that were numbered, were sixty-two thousand and seven hundred.","searchKeywords":["his","forces","that","were","numbered","sixty","two","thousand","and","seven","hundred"]},{"verseId":"brenton_numbers_2_27","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":27,"text":"And they that encamp next to him the tribe of Aser; and the prince of the sons of Aser, Phagiel the son of Echran.","searchKeywords":["and","they","that","encamp","next","him","the","tribe","aser","prince","sons","phagiel","son","echran"]},{"verseId":"brenton_numbers_2_28","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":28,"text":"His forces that were numbered, were forty-one thousand and five hundred.","searchKeywords":["his","forces","that","were","numbered","forty","one","thousand","and","five","hundred"]},{"verseId":"brenton_numbers_2_29","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":29,"text":"And they that encamp next of the tribe of Nephthali; and the prince of the children of Nephthali, Achire son of Ænan.","searchKeywords":["and","they","that","encamp","next","the","tribe","nephthali","prince","children","achire","son","nan"]},{"verseId":"brenton_numbers_2_30","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":30,"text":"His forces that were numbered were fifty-three thousand and four hundred.","searchKeywords":["his","forces","that","were","numbered","fifty","three","thousand","and","four","hundred"]},{"verseId":"brenton_numbers_2_31","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":31,"text":"All that were numbered of the camp of Dan, a hundred and fifty-seven thousand and six hundred: they shall set out last according to their order.","searchKeywords":["all","that","were","numbered","the","camp","dan","hundred","and","fifty","seven","thousand","six","they","shall","set","out","last","according","their","order"]},{"verseId":"brenton_numbers_2_32","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":32,"text":"This the numbering of the children of Israel according to the houses of their families: all the numbering of the camps with their forces, six hundred and three thousand, five hundred and fifty.","searchKeywords":["this","the","numbering","children","israel","according","houses","their","families","all","camps","with","forces","six","hundred","and","three","thousand","five","fifty"]},{"verseId":"brenton_numbers_2_33","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":33,"text":"But the Levites were not numbered with them, as the Lord commanded Moses.","searchKeywords":["but","the","levites","were","not","numbered","with","them","lord","commanded","moses"]},{"verseId":"brenton_numbers_2_34","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":2,"verse":34,"text":"And the children of Israel did all things that the Lord commanded Moses; thus they encamped in their order, and thus they began their march in succession each according to their divisions, according to the houses of their families.","searchKeywords":["and","the","children","israel","did","all","things","that","lord","commanded","moses","thus","they","encamped","their","order","began","march","succession","each","according","divisions","houses","families"]}]