[{"verseId":"brenton_numbers_24_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":1,"text":"And when Balaam saw that it pleased God to bless Israel, he did not go according to his custom to meet the omens, but turned his face toward the wilderness.","searchKeywords":["and","when","balaam","saw","that","pleased","god","bless","israel","did","not","according","his","custom","meet","the","omens","but","turned","face","toward","wilderness"]},{"verseId":"brenton_numbers_24_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":2,"text":"And Balaam lifted up his eyes, and sees Israel encamped by their tribes; and the Spirit of God came upon him.","searchKeywords":["and","balaam","lifted","his","eyes","sees","israel","encamped","their","tribes","the","spirit","god","came","upon","him"]},{"verseId":"brenton_numbers_24_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":3,"text":"And he took up his parable and said, Balaam son of Beor says, the man who sees truly says,","searchKeywords":["and","took","his","parable","said","balaam","son","beor","says","the","man","who","sees","truly"]},{"verseId":"brenton_numbers_24_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":4,"text":"he says who hears the oracle of the Mighty One, who saw a vision of God in sleep; his eyes were opened:","searchKeywords":["says","who","hears","the","oracle","mighty","one","saw","vision","god","sleep","his","eyes","were","opened"]},{"verseId":"brenton_numbers_24_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":5,"text":"How goodly thy habitations, Jacob, and thy tents, Israel!","searchKeywords":["how","goodly","thy","habitations","jacob","and","tents","israel"]},{"verseId":"brenton_numbers_24_6","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":6,"text":"as shady groves, and as gardens by a river, and as tents which God pitched, and as cedars by the waters.","searchKeywords":["shady","groves","and","gardens","river","tents","which","god","pitched","cedars","the","waters"]},{"verseId":"brenton_numbers_24_7","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":7,"text":"There shall come a man out of his seed, and he shall rule over many nations; and the kingdom of Gog shall be exalted, and his kingdom shall be increased.","searchKeywords":["there","shall","come","man","out","his","seed","and","rule","over","many","nations","the","kingdom","gog","exalted","increased"]},{"verseId":"brenton_numbers_24_8","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":8,"text":"God led him out of Egypt; he has as it were the glory of a unicorn: he shall consume the nations of his enemies, and he shall drain their marrow, and with his darts he shall shoot through the enemy.","searchKeywords":["god","led","him","out","egypt","has","were","the","glory","unicorn","shall","consume","nations","his","enemies","and","drain","their","marrow","with","darts","shoot","through","enemy"]},{"verseId":"brenton_numbers_24_9","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":9,"text":"He lay down, he rested as a lion, and as a young lion; who shall stir him up? they that bless thee are blessed, and they that curse thee are cursed.","searchKeywords":["lay","down","rested","lion","and","young","who","shall","stir","him","they","that","bless","thee","are","blessed","curse","cursed"]},{"verseId":"brenton_numbers_24_10","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":10,"text":"And Balac was angry with Balaam, and clapped his hands together; and Balac said to Balaam, I called thee to curse my enemy, and behold thou hast decidedly blessed this third time.","searchKeywords":["and","balac","was","angry","with","balaam","clapped","his","hands","together","said","called","thee","curse","enemy","behold","thou","hast","decidedly","blessed","this","third","time"]},{"verseId":"brenton_numbers_24_11","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":11,"text":"Now therefore flee to thy place: I said, I will honour thee, but now the Lord has deprived thee of glory.","searchKeywords":["now","therefore","flee","thy","place","said","will","honour","thee","but","the","lord","has","deprived","glory"]},{"verseId":"brenton_numbers_24_12","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":12,"text":"And Balaam said to Balac, Did I not speak to thy messengers also whom thou sentest to me, saying,","searchKeywords":["and","balaam","said","balac","did","not","speak","thy","messengers","also","whom","thou","sentest","saying"]},{"verseId":"brenton_numbers_24_13","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":13,"text":"If Balac should give me his house full of silver and gold, I shall not be able to transgress the word of the Lord to make it good or bad by myself; whatsoever things God shall say, them will I speak.","searchKeywords":["balac","should","give","his","house","full","silver","and","gold","shall","not","able","transgress","the","word","lord","make","good","bad","myself","whatsoever","things","god","say","them","will","speak"]},{"verseId":"brenton_numbers_24_14","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":14,"text":"And now, behold, I return to my place; come, I will advise thee of what this people shall do to thy people in the last days.","searchKeywords":["and","now","behold","return","place","come","will","advise","thee","what","this","people","shall","thy","the","last","days"]},{"verseId":"brenton_numbers_24_15","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":15,"text":"And he took up his parable and said,","searchKeywords":["and","took","his","parable","said"]},{"verseId":"brenton_numbers_24_16","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":16,"text":"hearing the oracles of God, receiving knowledge from the Most High, and having seen a vision of God in sleep; his eyes were opened.","searchKeywords":["hearing","the","oracles","god","receiving","knowledge","from","most","high","and","having","seen","vision","sleep","his","eyes","were","opened"]},{"verseId":"brenton_numbers_24_17","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":17,"text":"I will point to him, but not now; I bless him, but he draws not near: a star shall rise out of Jacob, a man shall spring out of Israel; and shall crush the princes of Moab, and shall spoil all the sons of Seth.","searchKeywords":["will","point","him","but","not","now","bless","draws","near","star","shall","rise","out","jacob","man","spring","israel","and","crush","the","princes","moab","spoil","all","sons","seth"]},{"verseId":"brenton_numbers_24_18","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":18,"text":"And Edom shall be an inheritance, and Esau his enemy shall be an inheritance , and Israel wrought valiantly.","searchKeywords":["and","edom","shall","inheritance","esau","his","enemy","israel","wrought","valiantly"]},{"verseId":"brenton_numbers_24_19","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":19,"text":"And shall arise out of Jacob, and destroy out of the city him that escapes.","searchKeywords":["and","shall","arise","out","jacob","destroy","the","city","him","that","escapes"]},{"verseId":"brenton_numbers_24_20","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":20,"text":"And having seen Amalec, he took up his parable and said, Amalec the first of the nations; yet his seed shall perish.","searchKeywords":["and","having","seen","amalec","took","his","parable","said","the","first","nations","yet","seed","shall","perish"]},{"verseId":"brenton_numbers_24_21","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":21,"text":"And having seen the Kenite, he took up his parable and said, Thy dwelling-place strong; yet though thou shouldest put thy nest in a rock,","searchKeywords":["and","having","seen","the","kenite","took","his","parable","said","thy","dwelling","place","strong","yet","though","thou","shouldest","put","nest","rock"]},{"verseId":"brenton_numbers_24_22","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":22,"text":"and though Beor should have a skilfully contrived hiding-place, the Assyrians shall carry thee away captive.","searchKeywords":["and","though","beor","should","have","skilfully","contrived","hiding","place","the","assyrians","shall","carry","thee","away","captive"]},{"verseId":"brenton_numbers_24_23","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":23,"text":"And he looked upon Og, and took up his parable and said, Oh, oh, who shall live, when God shall do these things?","searchKeywords":["and","looked","upon","took","his","parable","said","who","shall","live","when","god","these","things"]},{"verseId":"brenton_numbers_24_24","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":24,"text":"And one shall come forth from the hands of the Citians, and shall afflict Assur, and shall afflict the Hebrews, and they shall perish together.","searchKeywords":["and","one","shall","come","forth","from","the","hands","citians","afflict","assur","hebrews","they","perish","together"]},{"verseId":"brenton_numbers_24_25","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":24,"verse":25,"text":"And Balaam rose up and departed and returned to his place, and Balac went to his own home.","searchKeywords":["and","balaam","rose","departed","returned","his","place","balac","went","own","home"]}]