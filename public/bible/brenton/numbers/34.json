[{"verseId":"brenton_numbers_34_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":1,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_numbers_34_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":2,"text":"Charge the children of Israel, and thou shalt say to them, Ye are entering into the land of Chanaan: it shall be to you for an inheritance, the land of Chanaan with its boundaries.","searchKeywords":["charge","the","children","israel","and","thou","shalt","say","them","are","entering","into","land","chanaan","shall","you","for","inheritance","with","its","boundaries"]},{"verseId":"brenton_numbers_34_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":3,"text":"And your southern side shall be from the wilderness of Sin to the border of Edom, and your border southward shall extend on the side of the salt sea eastward.","searchKeywords":["and","your","southern","side","shall","from","the","wilderness","sin","border","edom","southward","extend","salt","sea","eastward"]},{"verseId":"brenton_numbers_34_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":4,"text":"And your border shall go round you from the south to the ascent of Acrabin, and shall proceed by Ennac, and the going forth of it shall be southward to Cades Barne, and it shall go forth to the village of Arad, and shall proceed by Asemona.","searchKeywords":["and","your","border","shall","round","you","from","the","south","ascent","acrabin","proceed","ennac","going","forth","southward","cades","barne","village","arad","asemona"]},{"verseId":"brenton_numbers_34_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":5,"text":"And the border shall compass from Asemona to the river of Egypt, and the sea shall be the termination.","searchKeywords":["and","the","border","shall","compass","from","asemona","river","egypt","sea","termination"]},{"verseId":"brenton_numbers_34_6","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":6,"text":"And ye shall have your border on the west, the great sea shall be the boundary: this shall be to you the border on the west.","searchKeywords":["and","shall","have","your","border","the","west","great","sea","boundary","this","you"]},{"verseId":"brenton_numbers_34_7","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":7,"text":"And this shall be your northern border; from the great sea ye shall measure to yourselves, by the side of the mountain.","searchKeywords":["and","this","shall","your","northern","border","from","the","great","sea","measure","yourselves","side","mountain"]},{"verseId":"brenton_numbers_34_8","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":8,"text":"And ye shall measure to yourselves the mountain from mount at the entering in to Emath, and the termination of it shall be the coasts of Saradac.","searchKeywords":["and","shall","measure","yourselves","the","mountain","from","mount","entering","emath","termination","coasts","saradac"]},{"verseId":"brenton_numbers_34_9","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":9,"text":"And the border shall go out to Dephrona, and its termination shall be at Arsenain; this shall be your border from the north.","searchKeywords":["and","the","border","shall","out","dephrona","its","termination","arsenain","this","your","from","north"]},{"verseId":"brenton_numbers_34_10","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":10,"text":"And ye shall measure to yourselves the eastern border from Arsenain to Sepphamar.","searchKeywords":["and","shall","measure","yourselves","the","eastern","border","from","arsenain","sepphamar"]},{"verseId":"brenton_numbers_34_11","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":11,"text":"And the border shall go down from Sepphamar to Bela eastward to the fountains, and the border shall go down from Bela behind the sea Chenereth eastward.","searchKeywords":["and","the","border","shall","down","from","sepphamar","bela","eastward","fountains","behind","sea","chenereth"]},{"verseId":"brenton_numbers_34_12","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":12,"text":"And the border shall go down to Jordan, and the termination shall be the salt sea; this shall be your land and its borders round about.","searchKeywords":["and","the","border","shall","down","jordan","termination","salt","sea","this","your","land","its","borders","round","about"]},{"verseId":"brenton_numbers_34_13","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":13,"text":"And Moses charged the children of Israel, saying, This the land which ye shall inherit by lot, even as the Lord commanded us to give it to the nine tribes and the half-tribe of Manasse.","searchKeywords":["and","moses","charged","the","children","israel","saying","this","land","which","shall","inherit","lot","even","lord","commanded","give","nine","tribes","half","tribe","manasse"]},{"verseId":"brenton_numbers_34_14","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":14,"text":"For the tribe of the children of Ruben, and the tribe of the children of Gad have received according to their families; and the half-tribe of Manasse have received their inheritances.","searchKeywords":["for","the","tribe","children","ruben","and","gad","have","received","according","their","families","half","manasse","inheritances"]},{"verseId":"brenton_numbers_34_15","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":15,"text":"Two tribes and half a tribe have received their inheritance beyond Jordan by Jericho from the south eastwards.","searchKeywords":["two","tribes","and","half","tribe","have","received","their","inheritance","beyond","jordan","jericho","from","the","south","eastwards"]},{"verseId":"brenton_numbers_34_16","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":16,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_numbers_34_17","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":17,"text":"These the names of the men who shall divide the land to you for an inheritance; Eleazar the priest and Joshua the of Naue.","searchKeywords":["these","the","names","men","who","shall","divide","land","you","for","inheritance","eleazar","priest","and","joshua","naue"]},{"verseId":"brenton_numbers_34_18","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":18,"text":"And ye shall take one ruler from tribe to divide the land to you by lot.","searchKeywords":["and","shall","take","one","ruler","from","tribe","divide","the","land","you","lot"]},{"verseId":"brenton_numbers_34_19","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":19,"text":"And these the names of the men; of the tribe of Juda, Chaleb the son of Jephonne.","searchKeywords":["and","these","the","names","men","tribe","juda","chaleb","son","jephonne"]},{"verseId":"brenton_numbers_34_20","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":20,"text":"Of the tribe of Symeon, Salamiel the son of Semiud.","searchKeywords":["the","tribe","symeon","salamiel","son","semiud"]},{"verseId":"brenton_numbers_34_21","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":21,"text":"Of the tribe of Benjamin, Eldad the son of Chaslon.","searchKeywords":["the","tribe","benjamin","eldad","son","chaslon"]},{"verseId":"brenton_numbers_34_22","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":22,"text":"Of the tribe of Dan the prince Bacchir the son of Egli.","searchKeywords":["the","tribe","dan","prince","bacchir","son","egli"]},{"verseId":"brenton_numbers_34_23","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":23,"text":"Of the sons of Joseph of the tribe of the sons of Manasse, the prince was Aniel the son of Suphi.","searchKeywords":["the","sons","joseph","tribe","manasse","prince","was","aniel","son","suphi"]},{"verseId":"brenton_numbers_34_24","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":24,"text":"Of the tribe of the sons of Ephraim, the prince was Camuel the son of Sabathan.","searchKeywords":["the","tribe","sons","ephraim","prince","was","camuel","son","sabathan"]},{"verseId":"brenton_numbers_34_25","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":25,"text":"Of the tribe of Zabulon, the prince was Elisaphan the son of Pharnac.","searchKeywords":["the","tribe","zabulon","prince","was","elisaphan","son","pharnac"]},{"verseId":"brenton_numbers_34_26","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":26,"text":"Of the tribe of the sons of Issachar, the prince was Phaltiel the son of Oza.","searchKeywords":["the","tribe","sons","issachar","prince","was","phaltiel","son","oza"]},{"verseId":"brenton_numbers_34_27","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":27,"text":"Of the tribe of the children of Aser, the prince was Achior the son of Selemi.","searchKeywords":["the","tribe","children","aser","prince","was","achior","son","selemi"]},{"verseId":"brenton_numbers_34_28","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":28,"text":"Of the tribe of Nephthali, the prince was Phadael the son of Jamiud.","searchKeywords":["the","tribe","nephthali","prince","was","phadael","son","jamiud"]},{"verseId":"brenton_numbers_34_29","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":34,"verse":29,"text":"These did the Lord command to distribute to the children of Israel in the land of Chanaan.","searchKeywords":["these","did","the","lord","command","distribute","children","israel","land","chanaan"]}]