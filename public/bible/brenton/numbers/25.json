[{"verseId":"brenton_numbers_25_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":25,"verse":1,"text":"And Israel sojourned in Sattin, and the people profaned itself by going a-whoring after the daughters of Moab.","searchKeywords":["and","israel","sojourned","sattin","the","people","profaned","itself","going","whoring","after","daughters","moab"]},{"verseId":"brenton_numbers_25_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":25,"verse":2,"text":"And they called them to the sacrifices of their idols; and the people ate of their sacrifices, and worshipped their idols.","searchKeywords":["and","they","called","them","the","sacrifices","their","idols","people","ate","worshipped"]},{"verseId":"brenton_numbers_25_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":25,"verse":3,"text":"And Israel consecrated themselves to Beel-phegor; and the Lord was very angry with Israel.","searchKeywords":["and","israel","consecrated","themselves","beel","phegor","the","lord","was","very","angry","with"]},{"verseId":"brenton_numbers_25_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":25,"verse":4,"text":"And the Lord said to Moses, Take all the princes of the people, and make them examples for the Lord in the face of the sun, and the anger of the Lord shall be turned away from Israel.","searchKeywords":["and","the","lord","said","moses","take","all","princes","people","make","them","examples","for","face","sun","anger","shall","turned","away","from","israel"]},{"verseId":"brenton_numbers_25_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":25,"verse":5,"text":"And Moses said to the tribes of Israel, Slay ye every one his friend that is consecrated to Beel-phegor.","sear