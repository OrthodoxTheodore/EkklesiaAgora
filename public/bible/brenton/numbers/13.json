[{"verseId":"brenton_numbers_13_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":1,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_numbers_13_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":2,"text":"Send for thee men, and let them spy the land of the Chananites, which I give to the sons of Israel for a possession; one man for a tribe, thou shalt send them away according to their families, every one of them a prince.","searchKeywords":["send","for","thee","men","and","let","them","spy","the","land","chananites","which","give","sons","israel","possession","one","man","tribe","thou","shalt","away","according","their","families","every","prince"]},{"verseId":"brenton_numbers_13_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":3,"text":"And Moses sent them out of the wilderness of Pharan by the word of the Lord; all these the princes of the sons of Israel.","searchKeywords":["and","moses","sent","them","out","the","wilderness","pharan","word","lord","all","these","princes","sons","israel"]},{"verseId":"brenton_numbers_13_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":4,"text":"And these their names: of the tribe of Ruben, Samuel the son of Zachur.","searchKeywords":["and","these","their","names","the","tribe","ruben","samuel","son","zachur"]},{"verseId":"brenton_numbers_13_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":5,"text":"Of the tribe of Symeon, Saphat the son of Suri.","searchKeywords":["the","tribe","symeon","saphat","son","suri"]},{"verseId":"brenton_numbers_13_6","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":6,"text":"Of the tribe of Judah, Chaleb the son of Jephonne.","searchKeywords":["the","tribe","judah","chaleb","son","jephonne"]},{"verseId":"brenton_numbers_13_7","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":7,"text":"Of the tribe of Issachar, Ilaal the son of Joseph.","searchKeywords":["the","tribe","issachar","ilaal","son","joseph"]},{"verseId":"brenton_numbers_13_8","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":8,"text":"Of the tribe of Ephraim, Ause the son of Naue.","searchKeywords":["the","tribe","ephraim","ause","son","naue"]},{"verseId":"brenton_numbers_13_9","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":9,"text":"Of the tribe of Benjamin, Phalti the son of Raphu.","searchKeywords":["the","tribe","benjamin","phalti","son","raphu"]},{"verseId":"brenton_numbers_13_10","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":10,"text":"Of the tribe of Zabulon, Gudiel the son of Sudi.","searchKeywords":["the","tribe","zabulon","gudiel","son","sudi"]},{"verseId":"brenton_numbers_13_11","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":11,"text":"Of the tribe of Joseph of the sons of Manasse, Gaddi the son of Susi.","searchKeywords":["the","tribe","joseph","sons","manasse","gaddi","son","susi"]},{"verseId":"brenton_numbers_13_12","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":12,"text":"Of the tribe of Dan, Amiel the son of Gamali.","searchKeywords":["the","tribe","dan","amiel","son","gamali"]},{"verseId":"brenton_numbers_13_13","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":13,"text":"Of the tribe of Aser, Sathur the son of Michael.","searchKeywords":["the","tribe","aser","sathur","son","michael"]},{"verseId":"brenton_numbers_13_14","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":14,"text":"Of the tribe of Nephthali, Nabi the son of Sabi.","searchKeywords":["the","tribe","nephthali","nabi","son","sabi"]},{"verseId":"brenton_numbers_13_15","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":15,"text":"Of the tribe of Gad, Gudiel the son of Macchi.","searchKeywords":["the","tribe","gad","gudiel","son","macchi"]},{"verseId":"brenton_numbers_13_16","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":16,"text":"These the names of the men whom Moses sent to spy out the land; and Moses called Ause the son of Naue, Joshua.","searchKeywords":["these","the","names","men","whom","moses","sent","spy","out","land","and","called","ause","son","naue","joshua"]},{"verseId":"brenton_numbers_13_17","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":17,"text":"And Moses sent them to spy out the land of Chanaan, and said to them, Go up by this wilderness; and ye shall go up to the mountain,","searchKeywords":["and","moses","sent","them","spy","out","the","land","chanaan","said","this","wilderness","shall","mountain"]},{"verseId":"brenton_numbers_13_18","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":18,"text":"and ye shall see the land, what it is, and the people that dwells on it, whether it is strong or weak, or they are few or many.","searchKeywords":["and","shall","see","the","land","what","people","that","dwells","whether","strong","weak","they","are","few","many"]},{"verseId":"brenton_numbers_13_19","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":19,"text":"And what the land is on which they dwell, it is good or bad; and what the cities are wherein these dwell, whether they dwell in walled or unwalled.","searchKeywords":["and","what","the","land","which","they","dwell","good","bad","cities","are","wherein","these","whether","walled","unwalled"]},{"verseId":"brenton_numbers_13_20","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":20,"text":"And what the land is, whether rich or poor; whether there are trees in it or no: and ye shall persevere and take of the fruits of the land: and the days the days of spring, the forerunners of the grape.","searchKeywords":["and","what","the","land","whether","rich","poor","there","are","trees","shall","persevere","take","fruits","days","spring","forerunners","grape"]},{"verseId":"brenton_numbers_13_21","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":21,"text":"And they went up and surveyed the land from the wilderness of Sin to Rhoob, as men go in to Æmath.","searchKeywords":["and","they","went","surveyed","the","land","from","wilderness","sin","rhoob","men","math"]},{"verseId":"brenton_numbers_13_22","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":22,"text":"And they went up by the wilderness, and departed as far as Chebron; and there Achiman, and Sessi, and Thelami, the progeny of Enach. Now Chebron was built seven years before Tanin of Egypt.","searchKeywords":["and","they","went","the","wilderness","departed","far","chebron","there","achiman","sessi","thelami","progeny","enach","now","was","built","seven","years","before","tanin","egypt"]},{"verseId":"brenton_numbers_13_23","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":23,"text":"And they came to the valley of the cluster and surveyed it; and they cut down thence a bough and one cluster of grapes upon it, and bore it on staves, and of the pomegranates and the figs.","searchKeywords":["and","they","came","the","valley","cluster","surveyed","cut","down","thence","bough","one","grapes","upon","bore","staves","pomegranates","figs"]},{"verseId":"brenton_numbers_13_24","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":24,"text":"And they called that place, The valley of the cluster, because of the cluster which the children of Israel cut down from thence.","searchKeywords":["and","they","called","that","place","the","valley","cluster","because","which","children","israel","cut","down","from","thence"]},{"verseId":"brenton_numbers_13_25","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":25,"text":"And they returned from thence, having surveyed the land, after forty days.","searchKeywords":["and","they","returned","from","thence","having","surveyed","the","land","after","forty","days"]},{"verseId":"brenton_numbers_13_26","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":26,"text":"And they proceeded and came to Moses and Aaron and all the congregation of the children of Israel, to the wilderness of Pharan Cades; and they brought word to them and to all the congregation, and they shewed the fruit of the land:","searchKeywords":["and","they","proceeded","came","moses","aaron","all","the","congregation","children","israel","wilderness","pharan","cades","brought","word","them","shewed","fruit","land"]},{"verseId":"brenton_numbers_13_27","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":27,"text":"and they reported to him, and said, We came into the land into which thou sentest us, a land flowing with milk and honey; and this is the fruit of it.","searchKeywords":["and","they","reported","him","said","came","into","the","land","which","thou","sentest","flowing","with","milk","honey","this","fruit"]},{"verseId":"brenton_numbers_13_28","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":28,"text":"Only the nation that dwells upon it is bold, and they have very great and strong walled towns, and we saw there the children of Enach.","searchKeywords":["only","the","nation","that","dwells","upon","bold","and","they","have","very","great","strong","walled","towns","saw","there","children","enach"]},{"verseId":"brenton_numbers_13_29","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":29,"text":"And Amalec dwells in the land toward the south: and the Chettite and the Evite, and the Jebusite, and the Amorite dwells in the hill country: and the Chananite dwells by the sea, and by the river Jordan.","searchKeywords":["and","amalec","dwells","the","land","toward","south","chettite","evite","jebusite","amorite","hill","country","chananite","sea","river","jordan"]},{"verseId":"brenton_numbers_13_30","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":30,"text":"And Chaleb stayed the people from speaking before Moses, and said to him, Nay, but we will go up by all means, and will inherit it, for we shall surely prevail against them.","searchKeywords":["and","chaleb","stayed","the","people","from","speaking","before","moses","said","him","nay","but","will","all","means","inherit","for","shall","surely","prevail","against","them"]},{"verseId":"brenton_numbers_13_31","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":31,"text":"But the men that went up together with him said, We will not go up, for we shall not by any means be able to go up against the nation, for it is much stronger than we.","searchKeywords":["but","the","men","that","went","together","with","him","said","will","not","for","shall","any","means","able","against","nation","much","stronger","than"]},{"verseId":"brenton_numbers_13_32","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":32,"text":"And they brought a horror of that land which they surveyed upon the children of Israel, saying, The land which we passed by to survey it, is a land that eats up its inhabitants; and all the people whom we saw in it are men of extraordinary stature.","searchKeywords":["and","they","brought","horror","that","land","which","surveyed","upon","the","children","israel","saying","passed","survey","eats","its","inhabitants","all","people","whom","saw","are","men","extraordinary","stature"]},{"verseId":"brenton_numbers_13_33","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":13,"verse":33,"text":"And there we saw the giants; and we were before them as locusts, yea even so were we before them.","searchKeywords":["and","there","saw","the","giants","were","before","them","locusts","yea","even"]}]