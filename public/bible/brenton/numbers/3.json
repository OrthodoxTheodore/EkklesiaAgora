[{"verseId":"brenton_numbers_3_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":1,"text":"And these the generations of Aaron and Moses, in the day in which the Lord spoke to Moses in mount Sina.","searchKeywords":["and","these","the","generations","aaron","moses","day","which","lord","spoke","mount","sina"]},{"verseId":"brenton_numbers_3_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":2,"text":"And these the names of the sons of Aaron; Nadab the first-born; and Abiud, Eleazar and Ithamar.","searchKeywords":["and","these","the","names","sons","aaron","nadab","first","born","abiud","eleazar","ithamar"]},{"verseId":"brenton_numbers_3_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":3,"text":"These the names of the sons of Aaron, the anointed priests whom they consecrated to the priesthood.","searchKeywords":["these","the","names","sons","aaron","anointed","priests","whom","they","consecrated","priesthood"]},{"verseId":"brenton_numbers_3_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":4,"text":"And Nadab and Abiud died before the Lord, when they offered strange fire before the Lord, in the wilderness of Sina; and they had no children; and Eleazar and Ithamar ministered in the priests' office with Aaron their father.","searchKeywords":["and","nadab","abiud","died","before","the","lord","when","they","offered","strange","fire","wilderness","sina","had","children","eleazar","ithamar","ministered","priests","office","with","aaron","their","father"]},{"verseId":"brenton_numbers_3_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":5,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_numbers_3_6","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":6,"text":"Take the tribe of Levi, and thou shalt set them before Aaron the priest, and they shall minister to him,","searchKeywords":["take","the","tribe","levi","and","thou","shalt","set","them","before","aaron","priest","they","shall","minister","him"]},{"verseId":"brenton_numbers_3_7","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":7,"text":"and shall keep his charges, and the charges of the children of Israel, before the tabernacle of witness, to do the works of the tabernacle.","searchKeywords":["and","shall","keep","his","charges","the","children","israel","before","tabernacle","witness","works"]},{"verseId":"brenton_numbers_3_8","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":8,"text":"And they shall keep all the furniture of the tabernacle of witness, and the charges of the children of Israel as to all the works of the tabernacle.","searchKeywords":["and","they","shall","keep","all","the","furniture","tabernacle","witness","charges","children","israel","works"]},{"verseId":"brenton_numbers_3_9","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":9,"text":"And thou shalt give the Levites to Aaron, and to his sons the priests; they are given for a gift to me of the children of Israel.","searchKeywords":["and","thou","shalt","give","the","levites","aaron","his","sons","priests","they","are","given","for","gift","children","israel"]},{"verseId":"brenton_numbers_3_10","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":10,"text":"And thou shalt appoint Aaron and his sons over the tabernacle of witness; and they shall keep their charge of priesthood, and all things belonging to the altar, and within the veil; and the stranger that touches them shall die.","searchKeywords":["and","thou","shalt","appoint","aaron","his","sons","over","the","tabernacle","witness","they","shall","keep","their","charge","priesthood","all","things","belonging","altar","within","veil","stranger","that","touches","them","die"]},{"verseId":"brenton_numbers_3_11","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":11,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_numbers_3_12","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":12,"text":"Behold, I have taken the Levites from the midst of the children of Israel, instead of every male that opens the womb from among the children of Israel: they shall be their ransom, and the Levites shall be mine.","searchKeywords":["behold","have","taken","the","levites","from","midst","children","israel","instead","every","male","that","opens","womb","among","they","shall","their","ransom","and","mine"]},{"verseId":"brenton_numbers_3_13","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":13,"text":"For every first-born mine; in the day in which I smote every first-born in the land of Egypt, I sanctified to myself every first-born in Israel: both of man and beast, they shall be mine: I the Lord.","searchKeywords":["for","every","first","born","mine","the","day","which","smote","land","egypt","sanctified","myself","israel","both","man","and","beast","they","shall","lord"]},{"verseId":"brenton_numbers_3_14","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":14,"text":"And the Lord spoke to Moses in the wilderness of Sina, saying,","searchKeywords":["and","the","lord","spoke","moses","wilderness","sina","saying"]},{"verseId":"brenton_numbers_3_15","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":15,"text":"Take the number of the sons of Levi, according to the houses of their families, according to their divisions; number ye them every male from a month old and upwards.","searchKeywords":["take","the","number","sons","levi","according","houses","their","families","divisions","them","every","male","from","month","old","and","upwards"]},{"verseId":"brenton_numbers_3_16","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":16,"text":"And Moses and Aaron numbered them by the word of the Lord, as the Lord commanded them.","searchKeywords":["and","moses","aaron","numbered","them","the","word","lord","commanded"]},{"verseId":"brenton_numbers_3_17","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":17,"text":"And these were the sons of Levi by their names; Gedson, Caath, and Merari.","searchKeywords":["and","these","were","the","sons","levi","their","names","gedson","caath","merari"]},{"verseId":"brenton_numbers_3_18","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":18,"text":"And these the names of the sons of Gedson according to their families; Lobeni and Semei:","searchKeywords":["and","these","the","names","sons","gedson","according","their","families","lobeni","semei"]},{"verseId":"brenton_numbers_3_19","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":19,"text":"and the sons of Caath according to their families; Amram and Issaar, Chebron and Oziel:","searchKeywords":["and","the","sons","caath","according","their","families","amram","issaar","chebron","oziel"]},{"verseId":"brenton_numbers_3_20","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":20,"text":"and the sons of Merari according to their families, Mooli and Musi; these are the families of the Levites according to the houses of their families.","searchKeywords":["and","the","sons","merari","according","their","families","mooli","musi","these","are","levites","houses"]},{"verseId":"brenton_numbers_3_21","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":21,"text":"To Gedson belongs the family of Lobeni, and the family of Semei: these are the families of Gedson.","searchKeywords":["gedson","belongs","the","family","lobeni","and","semei","these","are","families"]},{"verseId":"brenton_numbers_3_22","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":22,"text":"The numbering of them according to the number of every male from a month old and upwards, their numbering seven thousand and five hundred.","searchKeywords":["the","numbering","them","according","number","every","male","from","month","old","and","upwards","their","seven","thousand","five","hundred"]},{"verseId":"brenton_numbers_3_23","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":23,"text":"And the sons of Gedson shall encamp westward behind the tabernacle.","searchKeywords":["and","the","sons","gedson","shall","encamp","westward","behind","tabernacle"]},{"verseId":"brenton_numbers_3_24","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":24,"text":"And the ruler of the household of the family of Gedson Elisaph the son of Dael.","searchKeywords":["and","the","ruler","household","family","gedson","elisaph","son","dael"]},{"verseId":"brenton_numbers_3_25","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":25,"text":"And the charge of the sons of Gedson in the tabernacle of witness the tent and the veil, and the covering of the door of the tabernacle of witness,","searchKeywords":["and","the","charge","sons","gedson","tabernacle","witness","tent","veil","covering","door"]},{"verseId":"brenton_numbers_3_26","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":26,"text":"and the curtains of the court, and the veil of the door of the court, which is by the tabernacle, and the remainder of all its works.","searchKeywords":["and","the","curtains","court","veil","door","which","tabernacle","remainder","all","its","works"]},{"verseId":"brenton_numbers_3_27","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":27,"text":"To Caath one division, that of Amram, and another division, that of Issaar, and another division, that of Chebron, and another division, that of Oziel: these are the divisions of Caath, according to number.","searchKeywords":["caath","one","division","that","amram","and","another","issaar","chebron","oziel","these","are","the","divisions","according","number"]},{"verseId":"brenton_numbers_3_28","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":28,"text":"Every male from a month old and upward, eight thousand and six hundred, keeping the charges of the holy things.","searchKeywords":["every","male","from","month","old","and","upward","eight","thousand","six","hundred","keeping","the","charges","holy","things"]},{"verseId":"brenton_numbers_3_29","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":29,"text":"The families of the sons of Caath, shall encamp beside the tabernacle toward the south.","searchKeywords":["the","families","sons","caath","shall","encamp","beside","tabernacle","toward","south"]},{"verseId":"brenton_numbers_3_30","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":30,"text":"And the chief of the house of the families of the divisions of Caath, Elisaphan the son of Oziel.","searchKeywords":["and","the","chief","house","families","divisions","caath","elisaphan","son","oziel"]},{"verseId":"brenton_numbers_3_31","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":31,"text":"And their charge the ark, and the table, and the candlestick, and the altars, and all the vessels of the sanctuary wherewith they do holy service, and the veil, and all their works.","searchKeywords":["and","their","charge","the","ark","table","candlestick","altars","all","vessels","sanctuary","wherewith","they","holy","service","veil","works"]},{"verseId":"brenton_numbers_3_32","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":32,"text":"And the chief over the chief of the Levites, Eleazar the son of Aaron the priest, appointed to keep the charges of the holy things.","searchKeywords":["and","the","chief","over","levites","eleazar","son","aaron","priest","appointed","keep","charges","holy","things"]},{"verseId":"brenton_numbers_3_33","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":33,"text":"To Merari the family of Mooli, and the family of Musi: these are the families of Merari.","searchKeywords":["merari","the","family","mooli","and","musi","these","are","families"]},{"verseId":"brenton_numbers_3_34","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":34,"text":"The mustering of them according to number, every male from a month old and upwards, six thousand and fifty.","searchKeywords":["the","mustering","them","according","number","every","male","from","month","old","and","upwards","six","thousand","fifty"]},{"verseId":"brenton_numbers_3_35","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":35,"text":"And the head of the house of the families of the division of Merari, was Suriel the son of Abichail: they shall encamp by the side of the tabernacle northwards.","searchKeywords":["and","the","head","house","families","division","merari","was","suriel","son","abichail","they","shall","encamp","side","tabernacle","northwards"]},{"verseId":"brenton_numbers_3_36","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":36,"text":"The oversight of the charge of the sons of Merari the chapiters of the tabernacle, and its bars, and its pillars, and its sockets, and all their furniture, and their works,","searchKeywords":["the","oversight","charge","sons","merari","chapiters","tabernacle","and","its","bars","pillars","sockets","all","their","furniture","works"]},{"verseId":"brenton_numbers_3_37","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":37,"text":"and the pillars of the court round about, and their bases, and their pins, and their cords.","searchKeywords":["and","the","pillars","court","round","about","their","bases","pins","cords"]},{"verseId":"brenton_numbers_3_38","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":38,"text":"They that encamp before the tabernacle of witness on the east Moses and Aaron and his sons, keeping the charges of the sanctuary according to the charges of the children of Israel; and the stranger that touches them, shall die.","searchKeywords":["they","that","encamp","before","the","tabernacle","witness","east","moses","and","aaron","his","sons","keeping","charges","sanctuary","according","children","israel","stranger","touches","them","shall","die"]},{"verseId":"brenton_numbers_3_39","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":39,"text":"All the numbering of the Levites, whom Moses and Aaron numbered by the word of the Lord, according to their families, every male from a month old and upwards, two and twenty thousand.","searchKeywords":["all","the","numbering","levites","whom","moses","and","aaron","numbered","word","lord","according","their","families","every","male","from","month","old","upwards","two","twenty","thousand"]},{"verseId":"brenton_numbers_3_40","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":40,"text":"And the Lord spoke to Moses, saying, Count every first-born male of the children of Israel from a month old and upwards, and take the number by name.","searchKeywords":["and","the","lord","spoke","moses","saying","count","every","first","born","male","children","israel","from","month","old","upwards","take","number","name"]},{"verseId":"brenton_numbers_3_41","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":41,"text":"And thou shalt take the Levites for me—I the Lord—instead of all the first-born of the sons of Israel, and the cattle of the Levites instead of all the first-born among the cattle of the children of Israel.","searchKeywords":["and","thou","shalt","take","the","levites","for","lord","instead","all","first","born","sons","israel","cattle","among","children"]},{"verseId":"brenton_numbers_3_42","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":42,"text":"And Moses counted, as the Lord commanded him, every first-born among the children of Israel.","searchKeywords":["and","moses","counted","the","lord","commanded","him","every","first","born","among","children","israel"]},{"verseId":"brenton_numbers_3_43","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":43,"text":"And all the male first-born in number by name, from a month old and upwards, were according to their numbering twenty-two thousand and two hundred and seventy-three.","searchKeywords":["and","all","the","male","first","born","number","name","from","month","old","upwards","were","according","their","numbering","twenty","two","thousand","hundred","seventy","three"]},{"verseId":"brenton_numbers_3_44","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":44,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_numbers_3_45","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":45,"text":"Take the Levites instead of all the first-born of the sons of Israel, and the cattle of the Levites instead of their cattle, and the Levites shall be mine; I the Lord.","searchKeywords":["take","the","levites","instead","all","first","born","sons","israel","and","cattle","their","shall","mine","lord"]},{"verseId":"brenton_numbers_3_46","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":46,"text":"And for the ransoms of the two hundred and seventy-three which exceed the Levites in number of the first-born of the sons of Israel;","searchKeywords":["and","for","the","ransoms","two","hundred","seventy","three","which","exceed","levites","number","first","born","sons","israel"]},{"verseId":"brenton_numbers_3_47","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":47,"text":"thou shalt even take five shekels a head; thou shalt take them according to the holy didrachm, twenty oboli to the shekel.","searchKeywords":["thou","shalt","even","take","five","shekels","head","them","according","the","holy","didrachm","twenty","oboli","shekel"]},{"verseId":"brenton_numbers_3_48","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":48,"text":"And thou shalt give the money to Aaron and to his sons, the ransom of those who exceed in number among them.","searchKeywords":["and","thou","shalt","give","the","money","aaron","his","sons","ransom","those","who","exceed","number","among","them"]},{"verseId":"brenton_numbers_3_49","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":49,"text":"And Moses took the silver, the ransom of those that exceeded in number the redemption of the Levites.","searchKeywords":["and","moses","took","the","silver","ransom","those","that","exceeded","number","redemption","levites"]},{"verseId":"brenton_numbers_3_50","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":50,"text":"He took the silver from the first-born of the sons of Israel, a thousand three hundred and sixty-five shekels, according to the holy shekel.","searchKeywords":["took","the","silver","from","first","born","sons","israel","thousand","three","hundred","and","sixty","five","shekels","according","holy","shekel"]},{"verseId":"brenton_numbers_3_51","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":3,"verse":51,"text":"And Moses gave the ransom of them that were over to Aaron and his sons, by the word of the Lord, as the Lord commanded Moses.","searchKeywords":["and","moses","gave","the","ransom","them","that","were","over","aaron","his","sons","word","lord","commanded"]}]