[{"verseId":"brenton_numbers_23_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":1,"text":"And Balaam said to Balac, Build me here seven altars, and prepare me here seven calves, and seven rams.","searchKeywords":["and","balaam","said","balac","build","here","seven","altars","prepare","calves","rams"]},{"verseId":"brenton_numbers_23_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":2,"text":"And Balac did as Balaam told him; and he offered up a calf and a ram on altar.","searchKeywords":["and","balac","did","balaam","told","him","offered","calf","ram","altar"]},{"verseId":"brenton_numbers_23_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":3,"text":"And Balaam said to Balac, Stand by thy sacrifice, and I will go and see if God will appear to me and meet me, and the word which he shall shew me, I will report to thee. And Balac stood by his sacrifice.","searchKeywords":["and","balaam","said","balac","stand","thy","sacrifice","will","see","god","appear","meet","the","word","which","shall","shew","report","thee","stood","his"]},{"verseId":"brenton_numbers_23_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":4,"text":"And Balaam went to enquire of God; and he went straight forward, and God appeared to Balaam; and Balaam said to him, I have prepared the seven altars, and have offered a calf and a ram on altar.","searchKeywords":["and","balaam","went","enquire","god","straight","forward","appeared","said","him","have","prepared","the","seven","altars","offered","calf","ram","altar"]},{"verseId":"brenton_numbers_23_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":5,"text":"And God put a word into the mouth of Balaam, and said, Thou shalt return to Balac, and thus shalt thou speak.","searchKeywords":["and","god","put","word","into","the","mouth","balaam","said","thou","shalt","return","balac","thus","speak"]},{"verseId":"brenton_numbers_23_6","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":6,"text":"And he returned to him, and moreover he stood over his whole-burnt-offerings, and all the princes of Moab with him; and the Spirit of God came upon him.","searchKeywords":["and","returned","him","moreover","stood","over","his","whole","burnt","offerings","all","the","princes","moab","with","spirit","god","came","upon"]},{"verseId":"brenton_numbers_23_7","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":7,"text":"And he took up his parable, and said, Balac king of Moab sent for me out of Mesopotamia, out of the mountains of the east, saying, Come, curse me Jacob, and Come, call for a curse for me upon Israel.","searchKeywords":["and","took","his","parable","said","balac","king","moab","sent","for","out","mesopotamia","the","mountains","east","saying","come","curse","jacob","call","upon","israel"]},{"verseId":"brenton_numbers_23_8","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":8,"text":"How can I curse whom the Lord curses not? or how can I devote whom God devotes not?","searchKeywords":["how","can","curse","whom","the","lord","curses","not","devote","god","devotes"]},{"verseId":"brenton_numbers_23_9","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":9,"text":"For from the top of the mountains I shall see him, and from the hills I shall observe him: behold, the people shall dwell alone, and shall not be reckoned among the nations.","searchKeywords":["for","from","the","top","mountains","shall","see","him","and","hills","observe","behold","people","dwell","alone","not","reckoned","among","nations"]},{"verseId":"brenton_numbers_23_10","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":10,"text":"Who has exactly calculated the seed of Jacob, and who shall number the families of Israel? let my soul die with the souls of the righteous, and let my seed be as their seed.","searchKeywords":["who","has","exactly","calculated","the","seed","jacob","and","shall","number","families","israel","let","soul","die","with","souls","righteous","their"]},{"verseId":"brenton_numbers_23_11","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":11,"text":"And Balac said to Balaam, What hast thou done to me? I called thee to curse my enemies, and behold thou hast greatly blessed .","searchKeywords":["and","balac","said","balaam","what","hast","thou","done","called","thee","curse","enemies","behold","greatly","blessed"]},{"verseId":"brenton_numbers_23_12","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":12,"text":"And Balaam said to Balac, Whatsoever the Lord shall put into my mouth, shall I not take heed to speak this?","searchKeywords":["and","balaam","said","balac","whatsoever","the","lord","shall","put","into","mouth","not","take","heed","speak","this"]},{"verseId":"brenton_numbers_23_13","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":13,"text":"And Balac said to him, Come yet with me to another place where thou shalt not see the people, but only thou shalt see a part of them, and shalt not see them all; and curse me them from thence.","searchKeywords":["and","balac","said","him","come","yet","with","another","place","where","thou","shalt","not","see","the","people","but","only","part","them","all","curse","from","thence"]},{"verseId":"brenton_numbers_23_14","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":14,"text":"And he took him to a high place of the field to the top of the quarried , and he built there seven altars, and offered a calf and a ram on altar.","searchKeywords":["and","took","him","high","place","the","field","top","quarried","built","there","seven","altars","offered","calf","ram","altar"]},{"verseId":"brenton_numbers_23_15","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":15,"text":"And Balaam said to Balac, Stand by thy sacrifice, and I will go to enquire of God.","searchKeywords":["and","balaam","said","balac","stand","thy","sacrifice","will","enquire","god"]},{"verseId":"brenton_numbers_23_16","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":16,"text":"And God met Balaam, and put a word into his mouth, and said, Return to Balac, and thus shalt thou speak.","searchKeywords":["and","god","met","balaam","put","word","into","his","mouth","said","return","balac","thus","shalt","thou","speak"]},{"verseId":"brenton_numbers_23_17","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":17,"text":"And he returned to him: and he also was standing by his whole-burnt-sacrifice, and all the princes of Moab with him; and Balac said to him, What has the Lord spoken?","searchKeywords":["and","returned","him","also","was","standing","his","whole","burnt","sacrifice","all","the","princes","moab","with","balac","said","what","has","lord","spoken"]},{"verseId":"brenton_numbers_23_18","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":18,"text":"And he took up his parable, and said, Rise up, Balac, and hear; hearken as a witness, thou son of Sepphor.","searchKeywords":["and","took","his","parable","said","rise","balac","hear","hearken","witness","thou","son","sepphor"]},{"verseId":"brenton_numbers_23_19","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":19,"text":"God is not as man to waver, nor as the son of man to be threatened; shall he say and not perform? shall he speak and not keep ?","searchKeywords":["god","not","man","waver","nor","the","son","threatened","shall","say","and","perform","speak","keep"]},{"verseId":"brenton_numbers_23_20","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":20,"text":"Behold, I have received to bless: I will bless, and not turn back.","searchKeywords":["behold","have","received","bless","will","and","not","turn","back"]},{"verseId":"brenton_numbers_23_21","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":21,"text":"There shall not be trouble in Jacob, neither shall sorrow be seen in Israel: the Lord his God with him, the glories of rulers in him.","searchKeywords":["there","shall","not","trouble","jacob","neither","sorrow","seen","israel","the","lord","his","god","with","him","glories","rulers"]},{"verseId":"brenton_numbers_23_22","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":22,"text":"It was God who brought him out of Egypt; he has as it were the glory of a unicorn.","searchKeywords":["was","god","who","brought","him","out","egypt","has","were","the","glory","unicorn"]},{"verseId":"brenton_numbers_23_23","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":23,"text":"For there is no divination in Jacob, nor enchantment in Israel; in season it shall be told to Jacob and Israel what God shall perform.","searchKeywords":["for","there","divination","jacob","nor","enchantment","israel","season","shall","told","and","what","god","perform"]},{"verseId":"brenton_numbers_23_24","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":24,"text":"Behold, the people shall rise up as a lion's whelp, and shall exalt himself as a lion; he shall not lie down till he have eaten the prey, and he shall drink the blood of the slain.","searchKeywords":["behold","the","people","shall","rise","lion","whelp","and","exalt","himself","not","lie","down","till","have","eaten","prey","drink","blood","slain"]},{"verseId":"brenton_numbers_23_25","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":25,"text":"And Balac said to Balaam, Neither curse the people at all for me, nor bless them at all.","searchKeywords":["and","balac","said","balaam","neither","curse","the","people","all","for","nor","bless","them"]},{"verseId":"brenton_numbers_23_26","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":26,"text":"And Balaam answered and said to Balac, Spoke I not to thee, saying, Whatsoever thing God shall speak to me, that will I do?","searchKeywords":["and","balaam","answered","said","balac","spoke","not","thee","saying","whatsoever","thing","god","shall","speak","that","will"]},{"verseId":"brenton_numbers_23_27","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":27,"text":"And Balac said to Balaam, Come I will remove thee to another place, if it shall please God, and curse me them from thence.","searchKeywords":["and","balac","said","balaam","come","will","remove","thee","another","place","shall","please","god","curse","them","from","thence"]},{"verseId":"brenton_numbers_23_28","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":28,"text":"And Balac took Balaam to the top of Phogor, which extends to the wilderness.","searchKeywords":["and","balac","took","balaam","the","top","phogor","which","extends","wilderness"]},{"verseId":"brenton_numbers_23_29","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":29,"text":"And Balaam said to Balac, Build me here seven altars, and prepare me here seven calves, and seven rams.","searchKeywords":["and","balaam","said","balac","build","here","seven","altars","prepare","calves","rams"]},{"verseId":"brenton_numbers_23_30","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":23,"verse":30,"text":"And Balac did as Balaam told him, and offered a calf and a ram on altar.","searchKeywords":["and","balac","did","balaam","told","him","offered","calf","ram","altar"]}]