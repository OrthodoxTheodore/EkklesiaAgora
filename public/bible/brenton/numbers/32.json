[{"verseId":"brenton_numbers_32_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":1,"text":"And the children of Ruben and the children of Gad had a multitude of cattle, very great; and they saw the land of Jazer, and the land of Galaad; and the place was a place for cattle:","searchKeywords":["and","the","children","ruben","gad","had","multitude","cattle","very","great","they","saw","land","jazer","galaad","place","was","for"]},{"verseId":"brenton_numbers_32_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":2,"text":"and the children of Ruben and the children of Gad came, and spoke to Moses, and to Eleazar the priest, and to the princes of the congregation, saying,","searchKeywords":["and","the","children","ruben","gad","came","spoke","moses","eleazar","priest","princes","congregation","saying"]},{"verseId":"brenton_numbers_32_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":3,"text":"Ataroth, and Dæbon, and Jazer, and Namra, and Esebon, and Eleale, and Sebama, and Nabau, and Bæan,","searchKeywords":["ataroth","and","bon","jazer","namra","esebon","eleale","sebama","nabau"]},{"verseId":"brenton_numbers_32_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":4,"text":"the land which the Lord has delivered up before the children of Israel, is pasture land, and thy servants have cattle.","searchKeywords":["the","land","which","lord","has","delivered","before","children","israel","pasture","and","thy","servants","have","cattle"]},{"verseId":"brenton_numbers_32_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":5,"text":"And they said, If we have found grace in thy sight, let this land be given to thy servants for a possession, and do not cause us to pass over Jordan.","searchKeywords":["and","they","said","have","found","grace","thy","sight","let","this","land","given","servants","for","possession","not","cause","pass","over","jordan"]},{"verseId":"brenton_numbers_32_6","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":6,"text":"And Moses said to the sons of Gad and the sons of Ruben, Shall your brethren go to war, and shall ye sit here?","searchKeywords":["and","moses","said","the","sons","gad","ruben","shall","your","brethren","war","sit","here"]},{"verseId":"brenton_numbers_32_7","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":7,"text":"And why do ye pervert the minds of the children of Israel, that they should not cross over into the land, which the Lord gives them?","searchKeywords":["and","why","pervert","the","minds","children","israel","that","they","should","not","cross","over","into","land","which","lord","gives","them"]},{"verseId":"brenton_numbers_32_8","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":8,"text":"Did not your fathers thus, when I sent them from Cades Barne to spy out the land?","searchKeywords":["did","not","your","fathers","thus","when","sent","them","from","cades","barne","spy","out","the","land"]},{"verseId":"brenton_numbers_32_9","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":9,"text":"and they went up to the valley of the cluster, and spied the land, and turned aside the heart of the children of Israel, that they should not go into the land, which the Lord gave them.","searchKeywords":["and","they","went","the","valley","cluster","spied","land","turned","aside","heart","children","israel","that","should","not","into","which","lord","gave","them"]},{"verseId":"brenton_numbers_32_10","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":10,"text":"And the Lord was very angry in that day, and sware, saying,","searchKeywords":["and","the","lord","was","very","angry","that","day","sware","saying"]},{"verseId":"brenton_numbers_32_11","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":11,"text":"Surely these men who came up out of Egypt from twenty years old and upward, who know good and evil, shall not see the land which I sware to Abraam and Isaac and Jacob, for they have not closely followed after me:","searchKeywords":["surely","these","men","who","came","out","egypt","from","twenty","years","old","and","upward","know","good","evil","shall","not","see","the","land","which","sware","abraam","isaac","jacob","for","they","have","closely","followed","after"]},{"verseId":"brenton_numbers_32_12","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":12,"text":"save Caleb the son of Jephonne, who was set apart, and Joshua the son of Naue, for they closely followed after the Lord.","searchKeywords":["save","caleb","the","son","jephonne","who","was","set","apart","and","joshua","naue","for","they","closely","followed","after","lord"]},{"verseId":"brenton_numbers_32_13","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":13,"text":"And the Lord was very angry with Israel; and for forty years he caused them to wander in the wilderness, until all the generation which did evil in the sight of the Lord was extinct.","searchKeywords":["and","the","lord","was","very","angry","with","israel","for","forty","years","caused","them","wander","wilderness","until","all","generation","which","did","evil","sight","extinct"]},{"verseId":"brenton_numbers_32_14","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":14,"text":"Behold, ye are risen up in the room of your fathers, a combination of sinful men, to increase yet farther the fierce wrath of the Lord against Israel.","searchKeywords":["behold","are","risen","the","room","your","fathers","combination","sinful","men","increase","yet","farther","fierce","wrath","lord","against","israel"]},{"verseId":"brenton_numbers_32_15","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":15,"text":"For ye will turn away from him to desert him yet once more in the wilderness, and ye will sin against this whole congregation.","searchKeywords":["for","will","turn","away","from","him","desert","yet","once","more","the","wilderness","and","sin","against","this","whole","congregation"]},{"verseId":"brenton_numbers_32_16","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":16,"text":"And they came to him, and said, We will build here folds for our cattle, and cities for our possessions;","searchKeywords":["and","they","came","him","said","will","build","here","folds","for","our","cattle","cities","possessions"]},{"verseId":"brenton_numbers_32_17","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":17,"text":"and we will arm ourselves and go as an advanced guard before the children of Israel, until we shall have brought them into their place; and our possessions shall remain in walled cities because of the inhabitants of the land.","searchKeywords":["and","will","arm","ourselves","advanced","guard","before","the","children","israel","until","shall","have","brought","them","into","their","place","our","possessions","remain","walled","cities","because","inhabitants","land"]},{"verseId":"brenton_numbers_32_18","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":18,"text":"We will not return to our houses till the children of Israel shall have been distributed, each to his own inheritance.","searchKeywords":["will","not","return","our","houses","till","the","children","israel","shall","have","been","distributed","each","his","own","inheritance"]},{"verseId":"brenton_numbers_32_19","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":19,"text":"And we will not any longer inherit with them from the other side of Jordan and onwards, because we have our full inheritance on the side beyond Jordan eastward.","searchKeywords":["and","will","not","any","longer","inherit","with","them","from","the","other","side","jordan","onwards","because","have","our","full","inheritance","beyond","eastward"]},{"verseId":"brenton_numbers_32_20","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":20,"text":"And Moses said to them, If ye will do according to these words, if ye will arm yourselves before the Lord for battle,","searchKeywords":["and","moses","said","them","will","according","these","words","arm","yourselves","before","the","lord","for","battle"]},{"verseId":"brenton_numbers_32_21","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":21,"text":"and every one of you will pass over Jordan fully armed before the Lord, until his enemy be destroyed from before his face,","searchKeywords":["and","every","one","you","will","pass","over","jordan","fully","armed","before","the","lord","until","his","enemy","destroyed","from","face"]},{"verseId":"brenton_numbers_32_22","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":22,"text":"and the land shall be subdued before the Lord, then afterwards ye shall return, and be guiltless before the Lord, and as regards Israel; and this land shall be to you for a possession before the Lord.","searchKeywords":["and","the","land","shall","subdued","before","lord","then","afterwards","return","guiltless","regards","israel","this","you","for","possession"]},{"verseId":"brenton_numbers_32_23","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":23,"text":"But if ye will not do so, ye will sin against the Lord; and ye shall know your sin, when afflictions shall come upon you.","searchKeywords":["but","will","not","sin","against","the","lord","and","shall","know","your","when","afflictions","come","upon","you"]},{"verseId":"brenton_numbers_32_24","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":24,"text":"And ye shall build for yourselves cities for your store, and folds for your cattle; and ye shall do that which proceeds out of your mouth.","searchKeywords":["and","shall","build","for","yourselves","cities","your","store","folds","cattle","that","which","proceeds","out","mouth"]},{"verseId":"brenton_numbers_32_25","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":25,"text":"And the sons of Ruben and the sons of Gad spoke to Moses, saying, Thy servants will do as our lord commands.","searchKeywords":["and","the","sons","ruben","gad","spoke","moses","saying","thy","servants","will","our","lord","commands"]},{"verseId":"brenton_numbers_32_26","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":26,"text":"Our store, and our wives, and all our cattle shall be in the cities of Galaad.","searchKeywords":["our","store","and","wives","all","cattle","shall","the","cities","galaad"]},{"verseId":"brenton_numbers_32_27","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":27,"text":"But thy servants will go over all armed and set in order before the Lord to battle, as lord says.","searchKeywords":["but","thy","servants","will","over","all","armed","and","set","order","before","the","lord","battle","says"]},{"verseId":"brenton_numbers_32_28","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":28,"text":"And Moses appointed to them Eleazar the priest, and Joshua the son of Naue, and the chiefs of the families of the tribes of Israel.","searchKeywords":["and","moses","appointed","them","eleazar","the","priest","joshua","son","naue","chiefs","families","tribes","israel"]},{"verseId":"brenton_numbers_32_29","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":29,"text":"And Moses said to them, If the sons of Ruben and the sons of Gad will pass over Jordan with you, every one armed for war before the Lord, and ye shall subdue the land before you, then ye shall give to them the land of Galaad for a possession.","searchKeywords":["and","moses","said","them","the","sons","ruben","gad","will","pass","over","jordan","with","you","every","one","armed","for","war","before","lord","shall","subdue","land","then","give","galaad","possession"]},{"verseId":"brenton_numbers_32_30","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":30,"text":"But if they will not pass over armed with you to war before the Lord, then shall ye cause to pass over their possessions and their wives and their cattle before you into the land of Chanaan, and they shall inherit with you in the land of Chanaan.","searchKeywords":["but","they","will","not","pass","over","armed","with","you","war","before","the","lord","then","shall","cause","their","possessions","and","wives","cattle","into","land","chanaan","inherit"]},{"verseId":"brenton_numbers_32_31","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":31,"text":"And the sons of Ruben and the sons of Gad answered, saying, Whatsoever the Lord says to his servants, that will we do.","searchKeywords":["and","the","sons","ruben","gad","answered","saying","whatsoever","lord","says","his","servants","that","will"]},{"verseId":"brenton_numbers_32_32","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":32,"text":"We will go over armed before the Lord into the land of Chanaan, and ye shall give us our inheritance beyond Jordan.","searchKeywords":["will","over","armed","before","the","lord","into","land","chanaan","and","shall","give","our","inheritance","beyond","jordan"]},{"verseId":"brenton_numbers_32_33","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":33,"text":"And Moses gave to them, even to the sons of Gad and the sons of Ruben, and to the half tribe of Manasse of the sons of Joseph, the kingdom of Seon king of the Amorites, and the kingdom of Og king of Basan, the land and its cities with its coasts, the cities of the land round about.","searchKeywords":["and","moses","gave","them","even","the","sons","gad","ruben","half","tribe","manasse","joseph","kingdom","seon","king","amorites","basan","land","its","cities","with","coasts","round","about"]},{"verseId":"brenton_numbers_32_34","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":34,"text":"And the sons of Gad built Dæbon, and Ataroth, and Aroer,","searchKeywords":["and","the","sons","gad","built","bon","ataroth","aroer"]},{"verseId":"brenton_numbers_32_35","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":35,"text":"and Sophar, and Jazer, and they set them up,","searchKeywords":["and","sophar","jazer","they","set","them"]},{"verseId":"brenton_numbers_32_36","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":36,"text":"and Namram, and Bætharan, strong cities, and folds for sheep.","searchKeywords":["and","namram","tharan","strong","cities","folds","for","sheep"]},{"verseId":"brenton_numbers_32_37","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":37,"text":"And the sons of Ruben built Esebon, and Eleale, and Kariatham,","searchKeywords":["and","the","sons","ruben","built","esebon","eleale","kariatham"]},{"verseId":"brenton_numbers_32_38","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":38,"text":"and Beelmeon, surrounded , and Sebama; and they called the names of the cities which they built, after their own names.","searchKeywords":["and","beelmeon","surrounded","sebama","they","called","the","names","cities","which","built","after","their","own"]},{"verseId":"brenton_numbers_32_39","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":39,"text":"And a son of Machir the son of Manasse went to Galaad, and took it, and destroyed the Amorite who dwelt in it.","searchKeywords":["and","son","machir","the","manasse","went","galaad","took","destroyed","amorite","who","dwelt"]},{"verseId":"brenton_numbers_32_40","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":40,"text":"And Moses gave Galaad to Machir the son of Manasse, and he dwelt there.","searchKeywords":["and","moses","gave","galaad","machir","the","son","manasse","dwelt","there"]},{"verseId":"brenton_numbers_32_41","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":41,"text":"And Jair the of Manasse went and took their villages, and called them the villages of Jair.","searchKeywords":["and","jair","the","manasse","went","took","their","villages","called","them"]},{"verseId":"brenton_numbers_32_42","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":32,"verse":42,"text":"And Nabau went and took Caath and her villages, and called them Naboth after his name.","searchKeywords":["and","nabau","went","took","caath","her","villages","called","them","naboth","after","his","name"]}]