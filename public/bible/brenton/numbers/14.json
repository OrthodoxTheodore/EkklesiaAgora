[{"verseId":"brenton_numbers_14_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":1,"text":"And all the congregation lifted up their voice and cried; and the people wept all that night.","searchKeywords":["and","all","the","congregation","lifted","their","voice","cried","people","wept","that","night"]},{"verseId":"brenton_numbers_14_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":2,"text":"And all the children of Israel murmured against Moses and Aaron; and all the congregation said to them,","searchKeywords":["and","all","the","children","israel","murmured","against","moses","aaron","congregation","said","them"]},{"verseId":"brenton_numbers_14_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":3,"text":"Would we had died in the land of Egypt! or in this wilderness, would we had died! and why does the Lord bring us into this land to fall in war? our wives and our children shall be for a prey: now then it is better to return into Egypt.","searchKeywords":["would","had","died","the","land","egypt","this","wilderness","and","why","does","lord","bring","into","fall","war","our","wives","children","shall","for","prey","now","then","better","return"]},{"verseId":"brenton_numbers_14_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":4,"text":"And they said one to another, Let us make a ruler, and return into Egypt.","searchKeywords":["and","they","said","one","another","let","make","ruler","return","into","egypt"]},{"verseId":"brenton_numbers_14_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":5,"text":"And Moses and Aaron fell upon their face before all the congregation of the children of Israel.","searchKeywords":["and","moses","aaron","fell","upon","their","face","before","all","the","congregation","children","israel"]},{"verseId":"brenton_numbers_14_6","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":6,"text":"But Joshua the of Naue, and Chaleb the of Jephonne, of them that spied out the land, rent their garments,","searchKeywords":["but","joshua","the","naue","and","chaleb","jephonne","them","that","spied","out","land","rent","their","garments"]},{"verseId":"brenton_numbers_14_7","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":7,"text":"and spoke to all the congregation of the children of Israel, saying, The land which we surveyed is indeed extremely good.","searchKeywords":["and","spoke","all","the","congregation","children","israel","saying","land","which","surveyed","indeed","extremely","good"]},{"verseId":"brenton_numbers_14_8","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":8,"text":"If the Lord choose us, he will bring us into this land, and give it us; a land which flows with milk and honey.","searchKeywords":["the","lord","choose","will","bring","into","this","land","and","give","which","flows","with","milk","honey"]},{"verseId":"brenton_numbers_14_9","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":9,"text":"Only depart not from the Lord; and fear ye not the people of the land, for they are meat for us; for the season is departed from them, but the Lord among us: fear them not.","searchKeywords":["only","depart","not","from","the","lord","and","fear","people","land","for","they","are","meat","season","departed","them","but","among"]},{"verseId":"brenton_numbers_14_10","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":10,"text":"And all the congregation bade stone them with stones; and the glory of the Lord appeared in the cloud on the tabernacle of witness to all the children of Israel.","searchKeywords":["and","all","the","congregation","bade","stone","them","with","stones","glory","lord","appeared","cloud","tabernacle","witness","children","israel"]},{"verseId":"brenton_numbers_14_11","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":11,"text":"And the Lord said to Moses, How long does this people provoke me? and how long do they refuse to believe me for all the signs which I have wrought among them?","searchKeywords":["and","the","lord","said","moses","how","long","does","this","people","provoke","they","refuse","believe","for","all","signs","which","have","wrought","among","them"]},{"verseId":"brenton_numbers_14_12","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":12,"text":"I will smite them with death, and destroy them; and I will make of thee and of thy father's house a great nation, and much greater than this.","searchKeywords":["will","smite","them","with","death","and","destroy","make","thee","thy","father","house","great","nation","much","greater","than","this"]},{"verseId":"brenton_numbers_14_13","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":13,"text":"And Moses said to the Lord, So Egypt shall hear, for thou hast brought up this people from them by thy might.","searchKeywords":["and","moses","said","the","lord","egypt","shall","hear","for","thou","hast","brought","this","people","from","them","thy","might"]},{"verseId":"brenton_numbers_14_14","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":14,"text":"Moreover all the dwellers upon this land have heard that thou art Lord in the midst of this people, who, O Lord, art seen face to face, and thy cloud rests upon them, and thou goest before them by day in a pillar of a cloud, and by night in a pillar of fire.","searchKeywords":["moreover","all","the","dwellers","upon","this","land","have","heard","that","thou","art","lord","midst","people","who","seen","face","and","thy","cloud","rests","them","goest","before","day","pillar","night","fire"]},{"verseId":"brenton_numbers_14_15","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":15,"text":"And thou shalt destroy this nation as one man; then all the nations that have heard thy name shall speak, saying,","searchKeywords":["and","thou","shalt","destroy","this","nation","one","man","then","all","the","nations","that","have","heard","thy","name","shall","speak","saying"]},{"verseId":"brenton_numbers_14_16","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":16,"text":"Because the Lord could not bring this people into the land which he sware to them, he has overthrown them in the wilderness.","searchKeywords":["because","the","lord","could","not","bring","this","people","into","land","which","sware","them","has","overthrown","wilderness"]},{"verseId":"brenton_numbers_14_17","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":17,"text":"And now, O Lord, let thy strength be exalted, as thou spakest, saying,","searchKeywords":["and","now","lord","let","thy","strength","exalted","thou","spakest","saying"]},{"verseId":"brenton_numbers_14_18","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":18,"text":"The Lord long-suffering and merciful, and true, removing transgressions and iniquities and sins, and he will by no means clear the guilty, visiting the sins of the fathers upon the children to the third and fourth generation.","searchKeywords":["the","lord","long","suffering","and","merciful","true","removing","transgressions","iniquities","sins","will","means","clear","guilty","visiting","fathers","upon","children","third","fourth","generation"]},{"verseId":"brenton_numbers_14_19","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":19,"text":"Forgive this people their sin according to thy great mercy, as thou wast favourable to them from Egypt until now.","searchKeywords":["forgive","this","people","their","sin","according","thy","great","mercy","thou","wast","favourable","them","from","egypt","until","now"]},{"verseId":"brenton_numbers_14_20","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":20,"text":"And the Lord said to Moses, I am gracious to them according to thy word.","searchKeywords":["and","the","lord","said","moses","gracious","them","according","thy","word"]},{"verseId":"brenton_numbers_14_21","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":21,"text":"But I live and my name is living, so the glory of the Lord shall fill all the earth.","searchKeywords":["but","live","and","name","living","the","glory","lord","shall","fill","all","earth"]},{"verseId":"brenton_numbers_14_22","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":22,"text":"For all the men who see my glory, and the signs which I wrought in Egypt, and in the wilderness, and have tempted me this tenth time, and have not hearkened to my voice,","searchKeywords":["for","all","the","men","who","see","glory","and","signs","which","wrought","egypt","wilderness","have","tempted","this","tenth","time","not","hearkened","voice"]},{"verseId":"brenton_numbers_14_23","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":23,"text":"surely they shall not see the land, which I sware to their fathers; but their children which are with me here, as many as know not good or evil, every inexperienced youth, to them will I give the land; but none who have provoked me shall see it.","searchKeywords":["surely","they","shall","not","see","the","land","which","sware","their","fathers","but","children","are","with","here","many","know","good","evil","every","inexperienced","youth","them","will","give","none","who","have","provoked"]},{"verseId":"brenton_numbers_14_24","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":24,"text":"But my servant Chaleb, because there was another spirit in him, and he followed me, I will bring him into the land into which he entered, and his seed shall inherit it.","searchKeywords":["but","servant","chaleb","because","there","was","another","spirit","him","and","followed","will","bring","into","the","land","which","entered","his","seed","shall","inherit"]},{"verseId":"brenton_numbers_14_25","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":25,"text":"But Amalec and the Chananite dwell in the valley: to-morrow turn and depart for the wilderness by the way of the Red Sea.","searchKeywords":["but","amalec","and","the","chananite","dwell","valley","morrow","turn","depart","for","wilderness","way","red","sea"]},{"verseId":"brenton_numbers_14_26","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":26,"text":"And the Lord spoke to Moses and Aaron, saying,","searchKeywords":["and","the","lord","spoke","moses","aaron","saying"]},{"verseId":"brenton_numbers_14_27","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":27,"text":"How long this wicked congregation? I have heard their murmurings against me, the murmuring of the children of Israel, which they have murmured concerning you.","searchKeywords":["how","long","this","wicked","congregation","have","heard","their","murmurings","against","the","murmuring","children","israel","which","they","murmured","concerning","you"]},{"verseId":"brenton_numbers_14_28","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":28,"text":"Say to them, I live, saith the Lord: surely as ye spoke into my ears, so will I do to you.","searchKeywords":["say","them","live","saith","the","lord","surely","spoke","into","ears","will","you"]},{"verseId":"brenton_numbers_14_29","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":29,"text":"Your carcases shall fall in this wilderness; and all those of you that were reviewed, and those of you that were numbered from twenty years old and upward, all that murmured against me,","searchKeywords":["your","carcases","shall","fall","this","wilderness","and","all","those","you","that","were","reviewed","numbered","from","twenty","years","old","upward","murmured","against"]},{"verseId":"brenton_numbers_14_30","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":30,"text":"ye shall not enter into the land for which I stretched out my hand to establish you upon it; except only Chaleb the son of Jephonne, and Joshua the of Naue.","searchKeywords":["shall","not","enter","into","the","land","for","which","stretched","out","hand","establish","you","upon","except","only","chaleb","son","jephonne","and","joshua","naue"]},{"verseId":"brenton_numbers_14_31","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":31,"text":"And your little ones, who ye said should be a prey, them will I bring into the land; and they shall inherit the land, which ye rejected.","searchKeywords":["and","your","little","ones","who","said","should","prey","them","will","bring","into","the","land","they","shall","inherit","which","rejected"]},{"verseId":"brenton_numbers_14_32","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":32,"text":"And your carcases shall fall in this wilderness.","searchKeywords":["and","your","carcases","shall","fall","this","wilderness"]},{"verseId":"brenton_numbers_14_33","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":33,"text":"And your sons shall be fed in the wilderness forty years, and they shall bear your fornication, until your carcases be consumed in the wilderness.","searchKeywords":["and","your","sons","shall","fed","the","wilderness","forty","years","they","bear","fornication","until","carcases","consumed"]},{"verseId":"brenton_numbers_14_34","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":34,"text":"According to the number of the days during which ye spied the land, forty days, a day for a year, ye shall bear your sins forty years, and ye shall know my fierce anger.","searchKeywords":["according","the","number","days","during","which","spied","land","forty","day","for","year","shall","bear","your","sins","years","and","know","fierce","anger"]},{"verseId":"brenton_numbers_14_35","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":35,"text":"I the Lord have spoken, Surely will I do thus to this evil congregation that has risen up together against me: in this wilderness they shall be utterly consumed, and there they shall die.","searchKeywords":["the","lord","have","spoken","surely","will","thus","this","evil","congregation","that","has","risen","together","against","wilderness","they","shall","utterly","consumed","and","there","die"]},{"verseId":"brenton_numbers_14_36","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":36,"text":"And the men whom Moses sent to spy out the land, and who came and murmured against it to the assembly so as to bring out evil words concerning the land,—","searchKeywords":["and","the","men","whom","moses","sent","spy","out","land","who","came","murmured","against","assembly","bring","evil","words","concerning"]},{"verseId":"brenton_numbers_14_37","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":37,"text":"the men that spoke evil reports against the land, even died of the plague before the Lord.","searchKeywords":["the","men","that","spoke","evil","reports","against","land","even","died","plague","before","lord"]},{"verseId":"brenton_numbers_14_38","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":38,"text":"And Joshua the son of Naue and Chaleb the son of Jephonne lived of those men that went to spy out the land.","searchKeywords":["and","joshua","the","son","naue","chaleb","jephonne","lived","those","men","that","went","spy","out","land"]},{"verseId":"brenton_numbers_14_39","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":39,"text":"And Moses spoke these words to all the children of Israel; and the people mourned exceedingly.","searchKeywords":["and","moses","spoke","these","words","all","the","children","israel","people","mourned","exceedingly"]},{"verseId":"brenton_numbers_14_40","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":40,"text":"And they rose early in the morning and went up to the top of the mountain, saying, Behold, we that are here will go up to the place of which the Lord has spoken, because we have sinned.","searchKeywords":["and","they","rose","early","the","morning","went","top","mountain","saying","behold","that","are","here","will","place","which","lord","has","spoken","because","have","sinned"]},{"verseId":"brenton_numbers_14_41","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":41,"text":"And Moses said, Why do ye transgress the word of the Lord? ye shall not prosper.","searchKeywords":["and","moses","said","why","transgress","the","word","lord","shall","not","prosper"]},{"verseId":"brenton_numbers_14_42","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":42,"text":"Go not up, for the Lord is not with you; so shall ye fall before the face of your enemies.","searchKeywords":["not","for","the","lord","with","you","shall","fall","before","face","your","enemies"]},{"verseId":"brenton_numbers_14_43","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":43,"text":"For Amalec and the Chananite there before you, and ye shall fall by the sword; because ye have disobeyed the Lord and turned aside, and the Lord will not be among you.","searchKeywords":["for","amalec","and","the","chananite","there","before","you","shall","fall","sword","because","have","disobeyed","lord","turned","aside","will","not","among"]},{"verseId":"brenton_numbers_14_44","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":44,"text":"And having forced their passage, they went up to the top of the mountain; but the ark of the covenant of the Lord and Moses stirred not out of the camp.","searchKeywords":["and","having","forced","their","passage","they","went","the","top","mountain","but","ark","covenant","lord","moses","stirred","not","out","camp"]},{"verseId":"brenton_numbers_14_45","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":14,"verse":45,"text":"And Amalec and the Chananite that dwelt in that mountain came down, and routed them, and destroyed them unto Herman; and they returned to the camp.","searchKeywords":["and","amalec","the","chananite","that","dwelt","mountain","came","down","routed","them","destroyed","unto","herman","they","returned","camp"]}]