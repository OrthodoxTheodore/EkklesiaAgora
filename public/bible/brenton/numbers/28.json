[{"verseId":"brenton_numbers_28_1","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":1,"text":"And the Lord spoke to Moses, saying,","searchKeywords":["and","the","lord","spoke","moses","saying"]},{"verseId":"brenton_numbers_28_2","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":2,"text":"Charge the children of Israel, and thou shalt speak to them, saying, Ye shall observe to offer to me in my feasts my gifts, my presents, my burnt-offerings for a sweet-smelling savour.","searchKeywords":["charge","the","children","israel","and","thou","shalt","speak","them","saying","shall","observe","offer","feasts","gifts","presents","burnt","offerings","for","sweet","smelling","savour"]},{"verseId":"brenton_numbers_28_3","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":3,"text":"And thou shalt say to them, These are the burnt-offerings, all that ye shall bring to the Lord; two lambs of a year old without blemish daily, for a whole-burnt offering perpetually.","searchKeywords":["and","thou","shalt","say","them","these","are","the","burnt","offerings","all","that","shall","bring","lord","two","lambs","year","old","without","blemish","daily","for","whole","offering","perpetually"]},{"verseId":"brenton_numbers_28_4","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":4,"text":"Thou shalt offer one lamb in the morning, and thou shalt offer the second lamb towards evening.","searchKeywords":["thou","shalt","offer","one","lamb","the","morning","and","second","towards","evening"]},{"verseId":"brenton_numbers_28_5","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":5,"text":"And thou shalt offer the tenth part of an ephah of fine flour for a meat-offering, mingled with oil, with the fourth part of a hin.","searchKeywords":["and","thou","shalt","offer","the","tenth","part","ephah","fine","flour","for","meat","offering","mingled","with","oil","fourth","hin"]},{"verseId":"brenton_numbers_28_6","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":6,"text":"a perpetual whole-burnt-offering, a sacrifice offered in the mount of Sina for a sweet-smelling savour to the Lord.","searchKeywords":["perpetual","whole","burnt","offering","sacrifice","offered","the","mount","sina","for","sweet","smelling","savour","lord"]},{"verseId":"brenton_numbers_28_7","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":7,"text":"And its drink-offering, the fourth part of a hin to each lamb; in the holy place shalt thou pour strong drink as a drink-offering to the Lord.","searchKeywords":["and","its","drink","offering","the","fourth","part","hin","each","lamb","holy","place","shalt","thou","pour","strong","lord"]},{"verseId":"brenton_numbers_28_8","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":8,"text":"And the second lamb thou shalt offer toward evening; thou shalt offer it according to its meat-offering and according to its drink-offering for a smell of sweet savour to the Lord.","searchKeywords":["and","the","second","lamb","thou","shalt","offer","toward","evening","according","its","meat","offering","drink","for","smell","sweet","savour","lord"]},{"verseId":"brenton_numbers_28_9","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":9,"text":"And on the sabbath-day ye shall offer two lambs of a year old without blemish, and two tenth deals of fine flour mingled with oil for a meat-offering, and a drink-offering.","searchKeywords":["and","the","sabbath","day","shall","offer","two","lambs","year","old","without","blemish","tenth","deals","fine","flour","mingled","with","oil","for","meat","offering","drink"]},{"verseId":"brenton_numbers_28_10","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":10,"text":"a whole-burnt-offering of the sabbaths on the sabbath days, besides the continued whole-burnt-offering, and its drink offering.","searchKeywords":["whole","burnt","offering","the","sabbaths","sabbath","days","besides","continued","and","its","drink"]},{"verseId":"brenton_numbers_28_11","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":11,"text":"And at the new moons ye shall bring a whole-burnt-offering to the Lord, two calves of the herd, and one ram, seven lambs of a year old without blemish.","searchKeywords":["and","the","new","moons","shall","bring","whole","burnt","offering","lord","two","calves","herd","one","ram","seven","lambs","year","old","without","blemish"]},{"verseId":"brenton_numbers_28_12","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":12,"text":"Three tenth deals of fine flour mingled with oil for one calf, and two tenth deals of fine flour mingled with oil for one ram.","searchKeywords":["three","tenth","deals","fine","flour","mingled","with","oil","for","one","calf","and","two","ram"]},{"verseId":"brenton_numbers_28_13","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":13,"text":"A tenth deal of fine flour mingled with oil for each lamb, as a meat-offering, a sweet-smelling savour, a burnt-offering to the Lord.","searchKeywords":["tenth","deal","fine","flour","mingled","with","oil","for","each","lamb","meat","offering","sweet","smelling","savour","burnt","the","lord"]},{"verseId":"brenton_numbers_28_14","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":14,"text":"Their drink-offering shall be the half of a hin for one calf; and the third of a hin for one ram; and the fourth part of a hin of wine for one lamb: this the whole-burnt-offering monthly throughout the months of the year.","searchKeywords":["their","drink","offering","shall","the","half","hin","for","one","calf","and","third","ram","fourth","part","wine","lamb","this","whole","burnt","monthly","throughout","months","year"]},{"verseId":"brenton_numbers_28_15","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":15,"text":"And one kid of the goats for a sin-offering to the Lord; it shall be offered beside the continual whole-burnt-offering and its drink-offering.","searchKeywords":["and","one","kid","the","goats","for","sin","offering","lord","shall","offered","beside","continual","whole","burnt","its","drink"]},{"verseId":"brenton_numbers_28_16","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":16,"text":"And in the first month, on the fourteenth day of the month, the passover to the Lord.","searchKeywords":["and","the","first","month","fourteenth","day","passover","lord"]},{"verseId":"brenton_numbers_28_17","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":17,"text":"And on the fifteenth day of this month a feast; seven days ye shall eat unleavened bread.","searchKeywords":["and","the","fifteenth","day","this","month","feast","seven","days","shall","eat","unleavened","bread"]},{"verseId":"brenton_numbers_28_18","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":18,"text":"And the first day shall be to you a holy convocation; ye shall do no servile work.","searchKeywords":["and","the","first","day","shall","you","holy","convocation","servile","work"]},{"verseId":"brenton_numbers_28_19","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":19,"text":"And ye shall bring whole-burnt-offerings, a sacrifice to the Lord, two calves of the herd, one ram, seven lambs of a year old; they shall be to you without blemish.","searchKeywords":["and","shall","bring","whole","burnt","offerings","sacrifice","the","lord","two","calves","herd","one","ram","seven","lambs","year","old","they","you","without","blemish"]},{"verseId":"brenton_numbers_28_20","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":20,"text":"And their meat-offering shall be fine flour mingled with oil; three tenth deals for one calf, and two tenth deals for one ram.","searchKeywords":["and","their","meat","offering","shall","fine","flour","mingled","with","oil","three","tenth","deals","for","one","calf","two","ram"]},{"verseId":"brenton_numbers_28_21","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":21,"text":"Thou shalt offer a tenth for each lamb, for the seven lambs.","searchKeywords":["thou","shalt","offer","tenth","for","each","lamb","the","seven","lambs"]},{"verseId":"brenton_numbers_28_22","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":22,"text":"And one kid of the goats for a sin-offering, to make atonement for you.","searchKeywords":["and","one","kid","the","goats","for","sin","offering","make","atonement","you"]},{"verseId":"brenton_numbers_28_23","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":23,"text":"Beside the perpetual whole-burnt-offering in the morning, which is a whole-burnt-sacrifice for a continuance,","searchKeywords":["beside","the","perpetual","whole","burnt","offering","morning","which","sacrifice","for","continuance"]},{"verseId":"brenton_numbers_28_24","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":24,"text":"these shall ye thus offer daily for seven days, a gift, a sacrifice for a sweet-smelling savour to the Lord; beside the continual whole-burnt-offering, thou shalt offer its drink-offering.","searchKeywords":["these","shall","thus","offer","daily","for","seven","days","gift","sacrifice","sweet","smelling","savour","the","lord","beside","continual","whole","burnt","offering","thou","shalt","its","drink"]},{"verseId":"brenton_numbers_28_25","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":25,"text":"And the seventh day shall be to you a holy convocation; ye shall do no servile work in it.","searchKeywords":["and","the","seventh","day","shall","you","holy","convocation","servile","work"]},{"verseId":"brenton_numbers_28_26","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":26,"text":"And on the day of the new corn, when ye shall offer a new sacrifice of weeks to the Lord, there shall be to you a holy convocation; ye shall do no servile work,","searchKeywords":["and","the","day","new","corn","when","shall","offer","sacrifice","weeks","lord","there","you","holy","convocation","servile","work"]},{"verseId":"brenton_numbers_28_27","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":27,"text":"and ye shall bring whole-burnt-offerings for a sweet-smelling savour to the Lord, two calves of the herd, one ram, seven lambs without blemish.","searchKeywords":["and","shall","bring","whole","burnt","offerings","for","sweet","smelling","savour","the","lord","two","calves","herd","one","ram","seven","lambs","without","blemish"]},{"verseId":"brenton_numbers_28_28","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":28,"text":"Their meat-offering fine flour mingled with oil; there shall be three tenth deals for one calf, and two tenth deals for one ram.","searchKeywords":["their","meat","offering","fine","flour","mingled","with","oil","there","shall","three","tenth","deals","for","one","calf","and","two","ram"]},{"verseId":"brenton_numbers_28_29","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":29,"text":"A tenth for each lamb separately, for the seven lambs; and a kid of the goats,","searchKeywords":["tenth","for","each","lamb","separately","the","seven","lambs","and","kid","goats"]},{"verseId":"brenton_numbers_28_30","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":30,"text":"for a sin-offering, to make atonement for you; beside the perpetual whole-burnt-offering: and","searchKeywords":["for","sin","offering","make","atonement","you","beside","the","perpetual","whole","burnt","and"]},{"verseId":"brenton_numbers_28_31","translationId":"brenton","testament":"OT","bookIndex":4,"bookName":"Numbers","bookAbbrev":"numbers","chapter":28,"verse":31,"text":"ye shall offer to me their meat-offering. They shall be to you unblemished, and ye shall offer their drink-offerings.","searchKeywords":["shall","offer","their","meat","offering","they","you","unblemished","and","drink","offerings"]}]