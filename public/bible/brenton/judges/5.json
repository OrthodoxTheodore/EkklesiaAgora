[{"verseId":"brenton_judges_5_1","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":1,"text":"And Debbora and Barac son of Abineem sang in that day, saying,","searchKeywords":["and","debbora","barac","son","abineem","sang","that","day","saying"]},{"verseId":"brenton_judges_5_2","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":2,"text":"A revelation was made in Israel when the people were made willing: Praise ye the Lord.","searchKeywords":["revelation","was","made","israel","when","the","people","were","willing","praise","lord"]},{"verseId":"brenton_judges_5_3","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":3,"text":"Hear, ye kings, and hearken, rulers: I will sing, it is I to the Lord, it is I, I will sing a psalm to the Lord the God of Israel.","searchKeywords":["hear","kings","and","hearken","rulers","will","sing","the","lord","psalm","god","israel"]},{"verseId":"brenton_judges_5_4","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":4,"text":"O Lord, in thy going forth on Seir, when thou wentest forth out of the land of Edom, the earth quaked and the heaven dropped dews, and the clouds dropped water.","searchKeywords":["lord","thy","going","forth","seir","when","thou","wentest","out","the","land","edom","earth","quaked","and","heaven","dropped","dews","clouds","water"]},{"verseId":"brenton_judges_5_5","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":5,"text":"The mountains were shaken before the face of the Lord Eloi, this Sina before the face of the Lord God of Israel.","searchKeywords":["the","mountains","were","shaken","before","face","lord","eloi","this","sina","god","israel"]},{"verseId":"brenton_judges_5_6","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":6,"text":"In the days of Samegar son of Anath, in the days of Jael, they deserted the ways, and went in by-ways; they went in crooked paths.","searchKeywords":["the","days","samegar","son","anath","jael","they","deserted","ways","and","went","crooked","paths"]},{"verseId":"brenton_judges_5_7","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":7,"text":"The mighty men in Israel failed, they failed until Debbora arose, until she arose a mother in Israel.","searchKeywords":["the","mighty","men","israel","failed","they","until","debbora","arose","she","mother"]},{"verseId":"brenton_judges_5_8","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":8,"text":"They chose new gods; then the cities of rulers fought; there was not a shield or spear seen among forty thousand in Israel.","searchKeywords":["they","chose","new","gods","then","the","cities","rulers","fought","there","was","not","shield","spear","seen","among","forty","thousand","israel"]},{"verseId":"brenton_judges_5_9","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":9,"text":"My heart to the orders given in Israel; ye that are willing among the people, bless the Lord.","searchKeywords":["heart","the","orders","given","israel","that","are","willing","among","people","bless","lord"]},{"verseId":"brenton_judges_5_10","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":10,"text":"Ye that mount a she-ass at noon-day, ye that sit on the judgment-seat, and walk by the roads of them that sit in judgment by the way; declare","searchKeywords":["that","mount","she","ass","noon","day","sit","the","judgment","seat","and","walk","roads","them","way","declare"]},{"verseId":"brenton_judges_5_11","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":11,"text":"from the noise of disturbers among the drawers of water; there shall they relate righteous acts: O Lord, increase righteous acts in Israel: then the people of the Lord went down to the cities.","searchKeywords":["from","the","noise","disturbers","among","drawers","water","there","shall","they","relate","righteous","acts","lord","increase","israel","then","people","went","down","cities"]},{"verseId":"brenton_judges_5_12","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":12,"text":"Awake, awake, Debbora; awake, awake, utter a song: arise, Barac, and lead thy captivity captive, son of Abineem.","searchKeywords":["awake","debbora","utter","song","arise","barac","and","lead","thy","captivity","captive","son","abineem"]},{"verseId":"brenton_judges_5_13","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":13,"text":"Then went down the remnant to the strong, the people of the Lord went down for him among the mighty ones from me.","searchKeywords":["then","went","down","the","remnant","strong","people","lord","for","him","among","mighty","ones","from"]},{"verseId":"brenton_judges_5_14","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":14,"text":"Ephraim rooted them out in Amalec, behind thee was Benjamin among thy people: the inhabitants of Machir came down with me searching out the enemy, and from Zabulon came they that draw with the scribe's pen of record.","searchKeywords":["ephraim","rooted","them","out","amalec","behind","thee","was","benjamin","among","thy","people","the","inhabitants","machir","came","down","with","searching","enemy","and","from","zabulon","they","that","draw","scribe","pen","record"]},{"verseId":"brenton_judges_5_15","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":15,"text":"And princes in Issachar were with Debbora and Barac, thus she sent Barac on his feet in the valleys into the portions of Ruben; great reached to the heart.","searchKeywords":["and","princes","issachar","were","with","debbora","barac","thus","she","sent","his","feet","the","valleys","into","portions","ruben","great","reached","heart"]},{"verseId":"brenton_judges_5_16","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":16,"text":"Why did they sit between the sheep-folds to hear the bleating of flocks for the divisions of Ruben? great searchings of heart.","searchKeywords":["why","did","they","sit","between","the","sheep","folds","hear","bleating","flocks","for","divisions","ruben","great","searchings","heart"]},{"verseId":"brenton_judges_5_17","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":17,"text":"Galaad on the other side of Jordan where he pitched his tents; and why does Dan remain in ships? Aser sat down on the sea-coasts, and he will tabernacle at his ports.","searchKeywords":["galaad","the","other","side","jordan","where","pitched","his","tents","and","why","does","dan","remain","ships","aser","sat","down","sea","coasts","will","tabernacle","ports"]},{"verseId":"brenton_judges_5_18","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":18,"text":"The people Zabulon exposed their soul to death, and Nephthali came to the high places of their land.","searchKeywords":["the","people","zabulon","exposed","their","soul","death","and","nephthali","came","high","places","land"]},{"verseId":"brenton_judges_5_19","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":19,"text":"Kings set themselves in array, then the kings of Chanaan fought in Thanaach at the water of Mageddo; they took no gift of money.","searchKeywords":["kings","set","themselves","array","then","the","chanaan","fought","thanaach","water","mageddo","they","took","gift","money"]},{"verseId":"brenton_judges_5_20","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":20,"text":"The stars from heaven set themselves in array, they set themselves with Sisara out of their paths.","searchKeywords":["the","stars","from","heaven","set","themselves","array","they","with","sisara","out","their","paths"]},{"verseId":"brenton_judges_5_21","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":21,"text":"The brook of Kison swept them away, the ancient brook, the brook Kison: my mighty soul will trample him down.","searchKeywords":["the","brook","kison","swept","them","away","ancient","mighty","soul","will","trample","him","down"]},{"verseId":"brenton_judges_5_22","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":22,"text":"When the hoofs of the horse were entangled, his mighty ones earnestly hasted","searchKeywords":["when","the","hoofs","horse","were","entangled","his","mighty","ones","earnestly","hasted"]},{"verseId":"brenton_judges_5_23","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":23,"text":"to curse Meroz: Curse ye , said the angel of the Lord; cursed every one that dwells in it, because they came not to the help of the Lord, to his help among the mighty.","searchKeywords":["curse","meroz","said","the","angel","lord","cursed","every","one","that","dwells","because","they","came","not","help","his","among","mighty"]},{"verseId":"brenton_judges_5_24","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":24,"text":"Blessed among women be Jael wife of Chaber the Kenite; let her be blessed above women in tents.","searchKeywords":["blessed","among","women","jael","wife","chaber","the","kenite","let","her","above","tents"]},{"verseId":"brenton_judges_5_25","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":25,"text":"He asked for water, she gave him milk in a dish; she brought butter of princes.","searchKeywords":["asked","for","water","she","gave","him","milk","dish","brought","butter","princes"]},{"verseId":"brenton_judges_5_26","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":26,"text":"She stretched forth her left hand to the nail, and her right hand to the workman's hammer, and she smote Sisara with it, she nailed through his head and smote him; she nailed through his temples.","searchKeywords":["she","stretched","forth","her","left","hand","the","nail","and","right","workman","hammer","smote","sisara","with","nailed","through","his","head","him","temples"]},{"verseId":"brenton_judges_5_27","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":27,"text":"He rolled down between her feet; he fell and lay between her feet; he bowed and fell: where he bowed, there he fell dead.","searchKeywords":["rolled","down","between","her","feet","fell","and","lay","bowed","where","there","dead"]},{"verseId":"brenton_judges_5_28","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":28,"text":"The mother of Sisara looked down through the window out of the loophole, , Why was his chariot ashamed? why did the wheels of his chariots tarry?","searchKeywords":["the","mother","sisara","looked","down","through","window","out","loophole","why","was","his","chariot","ashamed","did","wheels","chariots","tarry"]},{"verseId":"brenton_judges_5_29","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":29,"text":"Her wise ladies answered her, and she returned answers to herself, ,","searchKeywords":["her","wise","ladies","answered","and","she","returned","answers","herself"]},{"verseId":"brenton_judges_5_30","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":30,"text":"Will they not find him dividing the spoil? he will surely be gracious to every man: spoils of dyed garments for Sisara, spoils of various dyed garments, dyed embroidered garments, they the spoils for his neck.","searchKeywords":["will","they","not","find","him","dividing","the","spoil","surely","gracious","every","man","spoils","dyed","garments","for","sisara","various","embroidered","his","neck"]},{"verseId":"brenton_judges_5_31","translationId":"brenton","testament":"OT","bookIndex":7,"bookName":"Judges","bookAbbrev":"judges","chapter":5,"verse":31,"text":"Thus let all thine enemies perish, O Lord: and they that love him shall be as the going forth of the sun in his strength.","searchKeywords":["thus","let","all","thine","enemies","perish","lord","and","they","that","love","him","shall","the","going","forth","sun","his","strength"]}]