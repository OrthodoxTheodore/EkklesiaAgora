[{"verseId":"brenton_prayer-of-manasseh_1_1","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":1,"text":"Almighty, the God of our fathers Abraham and Isaac and Jacob and of their righteous seed;","searchKeywords":["almighty","the","god","our","fathers","abraham","and","isaac","jacob","their","righteous","seed"]},{"verseId":"brenton_prayer-of-manasseh_1_2","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":2,"text":"that hast made the heaven and the earth with all their adornment;","searchKeywords":["that","hast","made","the","heaven","and","earth","with","all","their","adornment"]},{"verseId":"brenton_prayer-of-manasseh_1_3","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":3,"text":"that hast bound the sea with the word of thy commandment; that hast closed the abyss and sealed it with thy fearful and glorious name;","searchKeywords":["that","hast","bound","the","sea","with","word","thy","commandment","closed","abyss","and","sealed","fearful","glorious","name"]},{"verseId":"brenton_prayer-of-manasseh_1_4","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":4,"text":"whom all things revere and tremble before the face of thy power,","searchKeywords":["whom","all","things","revere","and","tremble","before","the","face","thy","power"]},{"verseId":"brenton_prayer-of-manasseh_1_5","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":5,"text":"because the magnificence of thy glory is unendurable and irresistible the wrath of thy threatening against sinners:","searchKeywords":["because","the","magnificence","thy","glory","unendurable","and","irresistible","wrath","threatening","against","sinners"]},{"verseId":"brenton_prayer-of-manasseh_1_6","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":6,"text":"the mercy of thy promise is both immeasurable and inscrutable;","searchKeywords":["the","mercy","thy","promise","both","immeasurable","and","inscrutable"]},{"verseId":"brenton_prayer-of-manasseh_1_7","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":7,"text":"for thou art the Lord most high, compassionate, longsuffering, and most merciful, repenting of the evils of men. Thou, Lord, according to the abundance of thy goodness, hast proclaimed repentance and forgiveness to those that have sinned against thee, and in the multitude of thy kindnesses thou hast decreed for sinners repentance unto salvation.","searchKeywords":["for","thou","art","the","lord","most","high","compassionate","longsuffering","and","merciful","repenting","evils","men","according","abundance","thy","goodness","hast","proclaimed","repentance","forgiveness","those","that","have","sinned","against","thee","multitude","kindnesses","decreed","sinners","unto","salvation"]},{"verseId":"brenton_prayer-of-manasseh_1_8","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":8,"text":"Surely thou, O Lord, the God of the just, hast not appointed repentance for the just, for Abraham and Isaac and Jacob who have not sinned against thee; but thou hast appointed repentance for me a sinner:","searchKeywords":["surely","thou","lord","the","god","just","hast","not","appointed","repentance","for","abraham","and","isaac","jacob","who","have","sinned","against","thee","but","sinner"]},{"verseId":"brenton_prayer-of-manasseh_1_9","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":9,"text":"for I have sinned above the number of the sand of the sea. My transgressions are multiplied, O Lord, they are multiplied, and I am not worthy to look at or see the height of heaven, for the multitude of my iniquities,","searchKeywords":["for","have","sinned","above","the","number","sand","sea","transgressions","are","multiplied","lord","they","and","not","worthy","look","see","height","heaven","multitude","iniquities"]},{"verseId":"brenton_prayer-of-manasseh_1_10","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":10,"text":"being bowed down by many iron bonds, so that I cannot uplift my head, and there is no release for me, because I have provoked thy anger, and have done evil before thee, not doing thy will, nor keeping thy commandments, but setting up abominations and multiplying offences.","searchKeywords":["being","bowed","down","many","iron","bonds","that","cannot","uplift","head","and","there","release","for","because","have","provoked","thy","anger","done","evil","before","thee","not","doing","will","nor","keeping","commandments","but","setting","abominations","multiplying","offences"]},{"verseId":"brenton_prayer-of-manasseh_1_11","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":11,"text":"And now I bend the knee of my heart, beseeching thy goodness:","searchKeywords":["and","now","bend","the","knee","heart","beseeching","thy","goodness"]},{"verseId":"brenton_prayer-of-manasseh_1_12","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":12,"text":"I have sinned, Lord, I have sinned, and I acknowledge my transgressions:","searchKeywords":["have","sinned","lord","and","acknowledge","transgressions"]},{"verseId":"brenton_prayer-of-manasseh_1_13","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":13,"text":"but I pray and beseech thee, release me, Lord, release me, and destroy me not with my transgressions; keep not evils for me in anger for ever, nor condemn me to the lowest parts of the earth: because thou art God, the God of the repenting;","searchKeywords":["but","pray","and","beseech","thee","release","lord","destroy","not","with","transgressions","keep","evils","for","anger","ever","nor","condemn","the","lowest","parts","earth","because","thou","art","god","repenting"]},{"verseId":"brenton_prayer-of-manasseh_1_14","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":14,"text":"and in me thou wilt shew all thy benevolence, for that me unworthy thou wilt save, according to thy great mercy:","searchKeywords":["and","thou","wilt","shew","all","thy","benevolence","for","that","unworthy","save","according","great","mercy"]},{"verseId":"brenton_prayer-of-manasseh_1_15","translationId":"brenton","testament":"OT","bookIndex":25,"bookName":"Prayer of Manasseh","bookAbbrev":"prayer-of-manasseh","chapter":1,"verse":15,"text":"and I will praise thee continually all the days of my life: for all the host of the heavens sings to thee, and thine is the glory for ever and ever. Amen.","searchKeywords":["and","will","praise","thee","continually","all","the","days","life","for","host","heavens","sings","thine","glory","ever","amen"]}]