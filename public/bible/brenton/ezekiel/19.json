[{"verseId":"brenton_ezekiel_19_1","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":1,"text":"Moreover do thou take up a lamentation for the prince of Israel,","searchKeywords":["moreover","thou","take","lamentation","for","the","prince","israel"]},{"verseId":"brenton_ezekiel_19_2","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":2,"text":"and say, Why is thy mother become a whelp in the midst of lions? in the midst of lions she has multiplied her whelps.","searchKeywords":["and","say","why","thy","mother","become","whelp","the","midst","lions","she","has","multiplied","her","whelps"]},{"verseId":"brenton_ezekiel_19_3","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":3,"text":"And one of her whelps sprang forth; he became a lion, and learned to take prey, he devoured men.","searchKeywords":["and","one","her","whelps","sprang","forth","became","lion","learned","take","prey","devoured","men"]},{"verseId":"brenton_ezekiel_19_4","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":4,"text":"And the nations heard a report of him; he was caught in their pit, and they brought him into the land of Egypt in chains.","searchKeywords":["and","the","nations","heard","report","him","was","caught","their","pit","they","brought","into","land","egypt","chains"]},{"verseId":"brenton_ezekiel_19_5","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":5,"text":"And she saw that he was driven away from her, her hope perished, and she took another of her whelps; she made him a lion.","searchKeywords":["and","she","saw","that","was","driven","away","from","her","hope","perished","took","another","whelps","made","him","lion"]},{"verseId":"brenton_ezekiel_19_6","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":6,"text":"And he went up and down in the midst of lions, he became a lion, and learned to take prey, he devoured men.","searchKeywords":["and","went","down","the","midst","lions","became","lion","learned","take","prey","devoured","men"]},{"verseId":"brenton_ezekiel_19_7","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":7,"text":"And he prowled in his boldness and laid waste their cities, and made the land desolate, and the fulness of it, by the voice of his roaring.","searchKeywords":["and","prowled","his","boldness","laid","waste","their","cities","made","the","land","desolate","fulness","voice","roaring"]},{"verseId":"brenton_ezekiel_19_8","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":8,"text":"Then the nations set upon him from the countries round about, and they spread their nets upon him: he was taken in their pit.","searchKeywords":["then","the","nations","set","upon","him","from","countries","round","about","and","they","spread","their","nets","was","taken","pit"]},{"verseId":"brenton_ezekiel_19_9","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":9,"text":"And they put him in chains and in a cage, he came to the king of Babylon; and he cast him into prison, that his voice should not be heard on the mountains of Israel.","searchKeywords":["and","they","put","him","chains","cage","came","the","king","babylon","cast","into","prison","that","his","voice","should","not","heard","mountains","israel"]},{"verseId":"brenton_ezekiel_19_10","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":10,"text":"Thy mother was as a vine and as a blossom on a pomegranate tree, planted by water: her fruit and her shoots abounded by reason of much water.","searchKeywords":["thy","mother","was","vine","and","blossom","pomegranate","tree","planted","water","her","fruit","shoots","abounded","reason","much"]},{"verseId":"brenton_ezekiel_19_11","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":11,"text":"And she became a rod for a tribe of princes, and was elevated in her bulk in the midst of trees, and she saw her bulk in the multitude of her branches.","searchKeywords":["and","she","became","rod","for","tribe","princes","was","elevated","her","bulk","the","midst","trees","saw","multitude","branches"]},{"verseId":"brenton_ezekiel_19_12","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":12,"text":"But she was broken down in wrath, she was cast upon the ground, and the east wind dried up her choice : vengeance came upon them, and the rod of her strength was withered; fire consumed it.","searchKeywords":["but","she","was","broken","down","wrath","cast","upon","the","ground","and","east","wind","dried","her","choice","vengeance","came","them","rod","strength","withered","fire","consumed"]},{"verseId":"brenton_ezekiel_19_13","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":13,"text":"And now they have planted her in the wilderness, in a dry land.","searchKeywords":["and","now","they","have","planted","her","the","wilderness","dry","land"]},{"verseId":"brenton_ezekiel_19_14","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":19,"verse":14,"text":"And fire is gone out of a rod of her choice , and has devoured her; and there was no rod of strength in her. Her race is become a parable of lamentation, and it shall be for a lamentation.","searchKeywords":["and","fire","gone","out","rod","her","choice","has","devoured","there","was","strength","race","become","parable","lamentation","shall","for"]}]