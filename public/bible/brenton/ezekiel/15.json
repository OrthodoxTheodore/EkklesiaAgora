[{"verseId":"brenton_ezekiel_15_1","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":15,"verse":1,"text":"And the word of the Lord came to me, saying,","searchKeywords":["and","the","word","lord","came","saying"]},{"verseId":"brenton_ezekiel_15_2","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":15,"verse":2,"text":"And thou, son of man—of all the wood of the branches that are among the trees of the forest, what shall be made of the wood of the vine?","searchKeywords":["and","thou","son","man","all","the","wood","branches","that","are","among","trees","forest","what","shall","made","vine"]},{"verseId":"brenton_ezekiel_15_3","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":15,"verse":3,"text":"Will they take wood of it to make for work? will they take of it a peg to hang any vessel upon it?","searchKeywords":["will","they","take","wood","make","for","work","peg","hang","any","vessel","upon"]},{"verseId":"brenton_ezekiel_15_4","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":15,"verse":4,"text":"It is only given to the fire to be consumed; the fire consumes that which is yearly pruned of it, and it is utterly gone. Will it be useful for work?","searchKeywords":["only","given","the","fire","consumed","consumes","that","which","yearly","pruned","and","utterly","gone","will","useful","for","work"]},{"verseId":"brenton_ezekiel_15_5","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":15,"verse":5,"text":"Not even while it is yet whole will it be for work: if the fire shall have utterly consumed it, will it still be for work?","searchKeywords":["not","even","while","yet","whole","will","for","work","the","fire","shall","have","utterly","consumed","still"]},{"verseId":"brenton_ezekiel_15_6","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":15,"verse":6,"text":"Therefore say,","searchKeywords":["therefore","say"]},{"verseId":"brenton_ezekiel_15_7","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":15,"verse":7,"text":"And I will set my face against them; they shall go forth of the fire, and fire shall devour them; and they shall know that I am the Lord, when I have set my face against them.","searchKeywords":["and","will","set","face","against","them","they","shall","forth","the","fire","devour","know","that","lord","when","have"]},{"verseId":"brenton_ezekiel_15_8","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":15,"verse":8,"text":"And I will give up the land to ruin, because they have utterly transgressed, saith the Lord.","searchKeywords":["and","will","give","the","land","ruin","because","they","have","utterly","transgressed","saith","lord"]}]