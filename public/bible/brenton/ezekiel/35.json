[{"verseId":"brenton_ezekiel_35_1","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":1,"text":"And the word of the Lord came to me, saying,","searchKeywords":["and","the","word","lord","came","saying"]},{"verseId":"brenton_ezekiel_35_2","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":2,"text":"Son of man, set thy face against mount Seir, and prophesy against it,","searchKeywords":["son","man","set","thy","face","against","mount","seir","and","prophesy"]},{"verseId":"brenton_ezekiel_35_3","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":3,"text":"and say to it,","searchKeywords":["and","say"]},{"verseId":"brenton_ezekiel_35_4","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":4,"text":"And I will cause desolation in thy cities, and thou shalt be desolate, and thou shalt know that I am the Lord.","searchKeywords":["and","will","cause","desolation","thy","cities","thou","shalt","desolate","know","that","the","lord"]},{"verseId":"brenton_ezekiel_35_5","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":5,"text":"Because thou hast been a perpetual enemy, and hast laid wait craftily for the house of Israel, with the hand of enemies with a sword, in the time of injustice, at the last:","searchKeywords":["because","thou","hast","been","perpetual","enemy","and","laid","wait","craftily","for","the","house","israel","with","hand","enemies","sword","time","injustice","last"]},{"verseId":"brenton_ezekiel_35_6","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":6,"text":"Therefore, as I live, saith the Lord God, verily thou hast sinned even to blood, therefore blood shall pursue thee.","searchKeywords":["therefore","live","saith","the","lord","god","verily","thou","hast","sinned","even","blood","shall","pursue","thee"]},{"verseId":"brenton_ezekiel_35_7","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":7,"text":"And I will make mount Seir a waste, and desolate, and I will destroy from off it men and cattle:","searchKeywords":["and","will","make","mount","seir","waste","desolate","destroy","from","off","men","cattle"]},{"verseId":"brenton_ezekiel_35_8","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":8,"text":"and I will fill thy hills and thy valleys with slain men, and in all thy plains there shall fall in thee men slain with the sword.","searchKeywords":["and","will","fill","thy","hills","valleys","with","slain","men","all","plains","there","shall","fall","thee","the","sword"]},{"verseId":"brenton_ezekiel_35_9","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":9,"text":"I will make thee a perpetual desolation, and thy cities shall not be inhabited any more: and thou shalt know that I am the Lord.","searchKeywords":["will","make","thee","perpetual","desolation","and","thy","cities","shall","not","inhabited","any","more","thou","shalt","know","that","the","lord"]},{"verseId":"brenton_ezekiel_35_10","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":10,"text":"Because thou saidst, The two nations and the two countries shall be mine, and I shall inherit them; whereas the Lord is there:","searchKeywords":["because","thou","saidst","the","two","nations","and","countries","shall","mine","inherit","them","whereas","lord","there"]},{"verseId":"brenton_ezekiel_35_11","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":11,"text":"therefore, I live, saith the Lord, I will even deal with thee according to thine enmity, and I will be made known to thee when I shall judge thee:","searchKeywords":["therefore","live","saith","the","lord","will","even","deal","with","thee","according","thine","enmity","and","made","known","when","shall","judge"]},{"verseId":"brenton_ezekiel_35_12","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":12,"text":"and thou shalt know that I am the Lord. I have heard the voice of thy blasphemies, whereas thou hast said, The desert mountains of Israel are given to us for food;","searchKeywords":["and","thou","shalt","know","that","the","lord","have","heard","voice","thy","blasphemies","whereas","hast","said","desert","mountains","israel","are","given","for","food"]},{"verseId":"brenton_ezekiel_35_13","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":13,"text":"and thou hast spoken swelling words against me with thy mouth: I have heard .","searchKeywords":["and","thou","hast","spoken","swelling","words","against","with","thy","mouth","have","heard"]},{"verseId":"brenton_ezekiel_35_14","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":14,"text":"Thus saith the Lord; When all the earth is rejoicing, I will make thee desert.","searchKeywords":["thus","saith","the","lord","when","all","earth","rejoicing","will","make","thee","desert"]},{"verseId":"brenton_ezekiel_35_15","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":35,"verse":15,"text":"Thou shalt be desert, O mount Seir, and all Idumea; and it shall be utterly consumed: and thou shalt know that I am the Lord their God.","searchKeywords":["thou","shalt","desert","mount","seir","and","all","idumea","shall","utterly","consumed","know","that","the","lord","their","god"]}]