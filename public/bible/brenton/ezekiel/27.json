[{"verseId":"brenton_ezekiel_27_1","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":1,"text":"And the word of the Lord came to me, saying,","searchKeywords":["and","the","word","lord","came","saying"]},{"verseId":"brenton_ezekiel_27_2","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":2,"text":"And thou, son of man, take up a lamentation against Sor;","searchKeywords":["and","thou","son","man","take","lamentation","against","sor"]},{"verseId":"brenton_ezekiel_27_3","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":3,"text":"and thou shalt say to Sor that dwells at the entrance of the sea, to the mart of the nations coming from many islands, Thus saith the Lord to Sor;","searchKeywords":["and","thou","shalt","say","sor","that","dwells","the","entrance","sea","mart","nations","coming","from","many","islands","thus","saith","lord"]},{"verseId":"brenton_ezekiel_27_4","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":4,"text":"In the heart of the sea thy sons have put beauty upon thee for Beelim.","searchKeywords":["the","heart","sea","thy","sons","have","put","beauty","upon","thee","for","beelim"]},{"verseId":"brenton_ezekiel_27_5","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":5,"text":"Cedar in Senir was employed for thee in building: boards of cypress timber were taken out of Libanus, and wood to make thee masts of fir.","searchKeywords":["cedar","senir","was","employed","for","thee","building","boards","cypress","timber","were","taken","out","libanus","and","wood","make","masts","fir"]},{"verseId":"brenton_ezekiel_27_6","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":6,"text":"They made thine oars out of the land of Basan; thy sacred utensils they made of ivory, thy shady houses of wood from the isles of Chetiim.","searchKeywords":["they","made","thine","oars","out","the","land","basan","thy","sacred","utensils","ivory","shady","houses","wood","from","isles","chetiim"]},{"verseId":"brenton_ezekiel_27_7","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":7,"text":"Fine linen with embroidery from Egypt supplied thy couch, to put honour upon thee, and to clothe thee with blue and purple from the isles of Elisai; and they became thy coverings.","searchKeywords":["fine","linen","with","embroidery","from","egypt","supplied","thy","couch","put","honour","upon","thee","and","clothe","blue","purple","the","isles","elisai","they","became","coverings"]},{"verseId":"brenton_ezekiel_27_8","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":8,"text":"And thy princes were the dwellers in Sidon, and the Aradians were thy rowers: thy wise men, O Sor, who were in thee, these were thy pilots.","searchKeywords":["and","thy","princes","were","the","dwellers","sidon","aradians","rowers","wise","men","sor","who","thee","these","pilots"]},{"verseId":"brenton_ezekiel_27_9","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":9,"text":"The elders of the Biblians, and their wise men, who were in thee, these helped thy counsel: and all the ships of the sea and their rowers traded for thee to the utmost west.","searchKeywords":["the","elders","biblians","and","their","wise","men","who","were","thee","these","helped","thy","counsel","all","ships","sea","rowers","traded","for","utmost","west"]},{"verseId":"brenton_ezekiel_27_10","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":10,"text":"Persians and Lydians and Libyans were in thine army: thy warriors hung in thee shields and helmets; these gave thy glory.","searchKeywords":["persians","and","lydians","libyans","were","thine","army","thy","warriors","hung","thee","shields","helmets","these","gave","glory"]},{"verseId":"brenton_ezekiel_27_11","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":11,"text":"The sons of the Aradians and thine army were upon thy walls; there were guards in thy towers: they hung their quivers on thy battlements round about; these completed thy beauty.","searchKeywords":["the","sons","aradians","and","thine","army","were","upon","thy","walls","there","guards","towers","they","hung","their","quivers","battlements","round","about","these","completed","beauty"]},{"verseId":"brenton_ezekiel_27_12","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":12,"text":"The Carthaginians were thy merchants because of the abundance of all thy strength; they furnished thy market with silver, and gold, and iron, and tin, and lead.","searchKeywords":["the","carthaginians","were","thy","merchants","because","abundance","all","strength","they","furnished","market","with","silver","and","gold","iron","tin","lead"]},{"verseId":"brenton_ezekiel_27_13","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":13,"text":"Greece, both the whole , and the adjacent coasts, these traded with thee in the persons of men, and they gave thy merchandise vessels of brass.","searchKeywords":["greece","both","the","whole","and","adjacent","coasts","these","traded","with","thee","persons","men","they","gave","thy","merchandise","vessels","brass"]},{"verseId":"brenton_ezekiel_27_14","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":14,"text":"Out of the house of Thogarma horses and horsemen furnished thy market.","searchKeywords":["out","the","house","thogarma","horses","and","horsemen","furnished","thy","market"]},{"verseId":"brenton_ezekiel_27_15","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":15,"text":"The sons of the Rhodians were thy merchants; from the islands they multiplied thy merchandise, elephants' teeth: and to them that came in thou didst return thy prices,","searchKeywords":["the","sons","rhodians","were","thy","merchants","from","islands","they","multiplied","merchandise","elephants","teeth","and","them","that","came","thou","didst","return","prices"]},{"verseId":"brenton_ezekiel_27_16","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":16,"text":"men thy merchandise, from the multitude of thy trading , myrrh and embroidered works from Tharsis: Ramoth also and Chorchor furnished thy market.","searchKeywords":["men","thy","merchandise","from","the","multitude","trading","myrrh","and","embroidered","works","tharsis","ramoth","also","chorchor","furnished","market"]},{"verseId":"brenton_ezekiel_27_17","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":17,"text":"Juda and the children of Israel, these were thy merchants; in the sale of corn and ointments and cassia: and they gave the best honey, and oil, and resin, to thy trading .","searchKeywords":["juda","and","the","children","israel","these","were","thy","merchants","sale","corn","ointments","cassia","they","gave","best","honey","oil","resin","trading"]},{"verseId":"brenton_ezekiel_27_18","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":18,"text":"Damascus were thy merchants by reason of the abundance of all thy power; wine out of Chelbon, and wool from Miletus; and they brought wine into thy market.","searchKeywords":["damascus","were","thy","merchants","reason","the","abundance","all","power","wine","out","chelbon","and","wool","from","miletus","they","brought","into","market"]},{"verseId":"brenton_ezekiel_27_19","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":19,"text":"Out of Asel wrought iron, and there is the sound of wheels among thy trading .","searchKeywords":["out","asel","wrought","iron","and","there","the","sound","wheels","among","thy","trading"]},{"verseId":"brenton_ezekiel_27_20","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":20,"text":"Dædan were thy merchants, with choice cattle for chariots.","searchKeywords":["dan","were","thy","merchants","with","choice","cattle","for","chariots"]},{"verseId":"brenton_ezekiel_27_21","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":21,"text":"Arabia and all the princes of Kedar, these were thy traders with thee, camels, and lambs, and rams, in which they trade with thee.","searchKeywords":["arabia","and","all","the","princes","kedar","these","were","thy","traders","with","thee","camels","lambs","rams","which","they","trade"]},{"verseId":"brenton_ezekiel_27_22","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":22,"text":"The merchants of Sabba and Ramma, these were thy merchants, with choice spices, and precious stones: and they brought gold to thy market.","searchKeywords":["the","merchants","sabba","and","ramma","these","were","thy","with","choice","spices","precious","stones","they","brought","gold","market"]},{"verseId":"brenton_ezekiel_27_23","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":23,"text":"Charra, and Chanaa, these were thy merchants: Assur, and Charman, were thy merchants:","searchKeywords":["charra","and","chanaa","these","were","thy","merchants","assur","charman"]},{"verseId":"brenton_ezekiel_27_24","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":24,"text":"bringing merchandise blue, and choice stores bound with cords, and cypress wood.","searchKeywords":["bringing","merchandise","blue","and","choice","stores","bound","with","cords","cypress","wood"]},{"verseId":"brenton_ezekiel_27_25","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":25,"text":"Ships were thy merchants, in abundance, with thy trading : and thou wast filled and very heavily loaded in the heart of the sea.","searchKeywords":["ships","were","thy","merchants","abundance","with","trading","and","thou","wast","filled","very","heavily","loaded","the","heart","sea"]},{"verseId":"brenton_ezekiel_27_26","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":26,"text":"Thy rowers have brought thee into great waters: the south wind has broken thee in the heart of the sea.","searchKeywords":["thy","rowers","have","brought","thee","into","great","waters","the","south","wind","has","broken","heart","sea"]},{"verseId":"brenton_ezekiel_27_27","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":27,"text":"Thy forces, and thy gain, and that of thy traders, and thy rowers, and thy pilots, and thy counsellors, and they that traffic with thee, and all thy warriors that are in thee: and all thy company in the midst of thee shall perish in the heart of the sea, in the day of thy fall.","searchKeywords":["thy","forces","and","gain","that","traders","rowers","pilots","counsellors","they","traffic","with","thee","all","warriors","are","company","the","midst","shall","perish","heart","sea","day","fall"]},{"verseId":"brenton_ezekiel_27_28","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":28,"text":"At the cry of thy voice thy pilots shall be greatly terrified.","searchKeywords":["the","cry","thy","voice","pilots","shall","greatly","terrified"]},{"verseId":"brenton_ezekiel_27_29","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":29,"text":"And all the rowers and the mariners shall come down from the ships, and the pilots of the sea shall stand on the land.","searchKeywords":["and","all","the","rowers","mariners","shall","come","down","from","ships","pilots","sea","stand","land"]},{"verseId":"brenton_ezekiel_27_30","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":30,"text":"And they shall wail over thee with their voice, and cry bitterly, and put earth on their heads, and spread ashes under them.","searchKeywords":["and","they","shall","wail","over","thee","with","their","voice","cry","bitterly","put","earth","heads","spread","ashes","under","them"]},{"verseId":"brenton_ezekiel_27_32","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":32,"text":"And their sons shall take up a for thee, even a lamentation for Sor, ,","searchKeywords":["and","their","sons","shall","take","for","thee","even","lamentation","sor"]},{"verseId":"brenton_ezekiel_27_33","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":33,"text":"How large a reward hast thou gained from the sea? thou hast filled nations out of thine abundance; and out of thy mixed merchandise thou hast enriched all the kings of the earth.","searchKeywords":["how","large","reward","hast","thou","gained","from","the","sea","filled","nations","out","thine","abundance","and","thy","mixed","merchandise","enriched","all","kings","earth"]},{"verseId":"brenton_ezekiel_27_34","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":34,"text":"Now art thou broken in the sea, thy traders are in the deep water, and all thy company in the midst of thee: all thy rowers have fallen.","searchKeywords":["now","art","thou","broken","the","sea","thy","traders","are","deep","water","and","all","company","midst","thee","rowers","have","fallen"]},{"verseId":"brenton_ezekiel_27_35","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":35,"text":"All the dwellers in the islands have mourned over thee, and their kings have been utterly amazed, and their countenance has wept.","searchKeywords":["all","the","dwellers","islands","have","mourned","over","thee","and","their","kings","been","utterly","amazed","countenance","has","wept"]},{"verseId":"brenton_ezekiel_27_36","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":27,"verse":36,"text":"Merchants from the nations have hissed at thee; thou art utterly destroyed, and shalt not be any more for ever.","searchKeywords":["merchants","from","the","nations","have","hissed","thee","thou","art","utterly","destroyed","and","shalt","not","any","more","for","ever"]}]