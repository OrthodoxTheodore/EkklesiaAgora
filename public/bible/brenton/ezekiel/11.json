[{"verseId":"brenton_ezekiel_11_1","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":1,"text":"Moreover the Spirit took me up, and brought me to the front gate of the house of the Lord, that looks eastward: and behold at the entrance of the gate were about five and twenty men; and I saw in the midst of them Jechonias the son of Ezer, and Phaltias the son of Banæas, the leaders of the people.","searchKeywords":["moreover","the","spirit","took","and","brought","front","gate","house","lord","that","looks","eastward","behold","entrance","were","about","five","twenty","men","saw","midst","them","jechonias","son","ezer","phaltias","ban","leaders","people"]},{"verseId":"brenton_ezekiel_11_2","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":2,"text":"And the Lord said to me, Son of man, these are the men that devise vanities, and take evil counsel in this city:","searchKeywords":["and","the","lord","said","son","man","these","are","men","that","devise","vanities","take","evil","counsel","this","city"]},{"verseId":"brenton_ezekiel_11_3","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":3,"text":"who say, Have not the houses been newly built? This is the caldron, and we are the flesh.","searchKeywords":["who","say","have","not","the","houses","been","newly","built","this","caldron","and","are","flesh"]},{"verseId":"brenton_ezekiel_11_4","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":4,"text":"Therefore prophesy against them, prophesy, son of man.","searchKeywords":["therefore","prophesy","against","them","son","man"]},{"verseId":"brenton_ezekiel_11_5","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":5,"text":"And the Spirit of the Lord fell upon me, and said to me, say;","searchKeywords":["and","the","spirit","lord","fell","upon","said","say"]},{"verseId":"brenton_ezekiel_11_6","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":6,"text":"Ye have multiplied your dead in this city, and ye have filled your ways with slain men.","searchKeywords":["have","multiplied","your","dead","this","city","and","filled","ways","with","slain","men"]},{"verseId":"brenton_ezekiel_11_7","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":7,"text":"Therefore thus saith the Lord; Your dead whom ye have smitten in the midst of it, these are the flesh, and this is the caldron: but I will bring you forth out of the midst of it.","searchKeywords":["therefore","thus","saith","the","lord","your","dead","whom","have","smitten","midst","these","are","flesh","and","this","caldron","but","will","bring","you","forth","out"]},{"verseId":"brenton_ezekiel_11_8","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":8,"text":"Ye fear the sword; and I will bring a sword upon you, saith the Lord.","searchKeywords":["fear","the","sword","and","will","bring","upon","you","saith","lord"]},{"verseId":"brenton_ezekiel_11_9","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":9,"text":"And I will bring you forth out of the midst of it, and will deliver you into the hands of strangers, and will execute judgments among you.","searchKeywords":["and","will","bring","you","forth","out","the","midst","deliver","into","hands","strangers","execute","judgments","among"]},{"verseId":"brenton_ezekiel_11_10","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":10,"text":"Ye shall fall by the sword; I will judge you on the mountains of Israel; and ye shall know that I am the Lord.","searchKeywords":["shall","fall","the","sword","will","judge","you","mountains","israel","and","know","that","lord"]},{"verseId":"brenton_ezekiel_11_13","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":13,"text":"And it came to pass, while I was prophesying, that Phaltias the son of Banæas died. And I fell upon my face, and cried with a loud voice, and said, Alas, alas, O Lord! wilt thou utterly destroy the remnant of Israel?","searchKeywords":["and","came","pass","while","was","prophesying","that","phaltias","the","son","ban","died","fell","upon","face","cried","with","loud","voice","said","alas","lord","wilt","thou","utterly","destroy","remnant","israel"]},{"verseId":"brenton_ezekiel_11_14","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":14,"text":"And the word of the Lord came to me, saying,","searchKeywords":["and","the","word","lord","came","saying"]},{"verseId":"brenton_ezekiel_11_15","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":15,"text":"Son of man, thy brethren, and the men of thy captivity, and all the house of Israel are come to the full, to whom the inhabitants of Jerusalem said, Keep ye far away from the Lord: the land is given to us for an inheritance.","searchKeywords":["son","man","thy","brethren","and","the","men","captivity","all","house","israel","are","come","full","whom","inhabitants","jerusalem","said","keep","far","away","from","lord","land","given","for","inheritance"]},{"verseId":"brenton_ezekiel_11_16","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":16,"text":"Therefore say thou,","searchKeywords":["therefore","say","thou"]},{"verseId":"brenton_ezekiel_11_17","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":17,"text":"Therefore say thou, Thus saith the Lord; I will also take them from the heathen, and gather them out of the lands wherein I have scattered them, and will give them the land of Israel.","searchKeywords":["therefore","say","thou","thus","saith","the","lord","will","also","take","them","from","heathen","and","gather","out","lands","wherein","have","scattered","give","land","israel"]},{"verseId":"brenton_ezekiel_11_18","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":18,"text":"And they shall enter in there, and shall remove all the abominations of it, and all its iniquities from it.","searchKeywords":["and","they","shall","enter","there","remove","all","the","abominations","its","iniquities","from"]},{"verseId":"brenton_ezekiel_11_19","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":19,"text":"And I will give them another heart, and will put a new spirit within them; and will extract the heart of stone from their flesh, and give them a heart of flesh:","searchKeywords":["and","will","give","them","another","heart","put","new","spirit","within","extract","the","stone","from","their","flesh"]},{"verseId":"brenton_ezekiel_11_20","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":20,"text":"that they may walk in my commandments, and keep mine ordinances, and do them: and they shall be to me a people, and I will be to them a God.","searchKeywords":["that","they","may","walk","commandments","and","keep","mine","ordinances","them","shall","people","will","god"]},{"verseId":"brenton_ezekiel_11_21","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":21,"text":"And as for the heart their abominations and their iniquities, as their heart went , I have recompensed their ways on their heads, saith the Lord.","searchKeywords":["and","for","the","heart","their","abominations","iniquities","went","have","recompensed","ways","heads","saith","lord"]},{"verseId":"brenton_ezekiel_11_22","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":22,"text":"Then the cherubs lifted up their wings, and the wheels beside them; and the glory of the God of Israel was over them above.","searchKeywords":["then","the","cherubs","lifted","their","wings","and","wheels","beside","them","glory","god","israel","was","over","above"]},{"verseId":"brenton_ezekiel_11_23","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":23,"text":"And the glory of the Lord went up from the midst of the city, and stood on the mountain which was in front of the city.","searchKeywords":["and","the","glory","lord","went","from","midst","city","stood","mountain","which","was","front"]},{"verseId":"brenton_ezekiel_11_24","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":24,"text":"And the Spirit took me up, and brought me to the land of the Chaldeans, to the captivity, in a vision by the Spirit of God: and I went up after the vision which I saw.","searchKeywords":["and","the","spirit","took","brought","land","chaldeans","captivity","vision","god","went","after","which","saw"]},{"verseId":"brenton_ezekiel_11_25","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":11,"verse":25,"text":"And I spoke to the captivity all the words of the Lord which he had shewed me.","searchKeywords":["and","spoke","the","captivity","all","words","lord","which","had","shewed"]}]