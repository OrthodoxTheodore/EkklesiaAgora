[{"verseId":"brenton_ezekiel_12_1","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":1,"text":"And the word of the Lord came to me, saying,","searchKeywords":["and","the","word","lord","came","saying"]},{"verseId":"brenton_ezekiel_12_2","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":2,"text":"Son of man, thou dwellest in the midst of the iniquities of those, who have eyes to see, and see not; and have ears to hear, and hear not: because it is a provoking house.","searchKeywords":["son","man","thou","dwellest","the","midst","iniquities","those","who","have","eyes","see","and","not","ears","hear","because","provoking","house"]},{"verseId":"brenton_ezekiel_12_3","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":3,"text":"Thou therefore, son of man, prepare thyself baggage for going into captivity by day in their sight; and thou shalt be led into captivity from thy place into another place in their sight; that they may see that it is a provoking house.","searchKeywords":["thou","therefore","son","man","prepare","thyself","baggage","for","going","into","captivity","day","their","sight","and","shalt","led","from","thy","place","another","that","they","may","see","provoking","house"]},{"verseId":"brenton_ezekiel_12_4","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":4,"text":"And thou shalt carry forth thy baggage, baggage for captivity, by day before their eyes: and thou shalt go forth at even, as a captive goes forth, in their sight.","searchKeywords":["and","thou","shalt","carry","forth","thy","baggage","for","captivity","day","before","their","eyes","even","captive","goes","sight"]},{"verseId":"brenton_ezekiel_12_5","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":5,"text":"Dig for thyself into the wall , and thou shalt pass through it in their sight:","searchKeywords":["dig","for","thyself","into","the","wall","and","thou","shalt","pass","through","their","sight"]},{"verseId":"brenton_ezekiel_12_6","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":6,"text":"thou shalt be lifted up on shoulders, and shalt go forth in secret: thou shalt cover thy face, and shalt not see the ground: because I have made thee a sign to the house of Israel.","searchKeywords":["thou","shalt","lifted","shoulders","and","forth","secret","cover","thy","face","not","see","the","ground","because","have","made","thee","sign","house","israel"]},{"verseId":"brenton_ezekiel_12_7","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":7,"text":"And I did thus according to all that he commanded me; and I carried forth my baggage for captivity by day, and in the evening I dug through the wall for myself, and went out secretly; I was taken up on shoulders before them.","searchKeywords":["and","did","thus","according","all","that","commanded","carried","forth","baggage","for","captivity","day","the","evening","dug","through","wall","myself","went","out","secretly","was","taken","shoulders","before","them"]},{"verseId":"brenton_ezekiel_12_8","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":8,"text":"And the word of the Lord came to me in the morning, saying,","searchKeywords":["and","the","word","lord","came","morning","saying"]},{"verseId":"brenton_ezekiel_12_9","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":9,"text":"Son of man, have not the house of Israel, the provoking house, said to thee, What doest thou?","searchKeywords":["son","man","have","not","the","house","israel","provoking","said","thee","what","doest","thou"]},{"verseId":"brenton_ezekiel_12_10","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":10,"text":"Say to them,","searchKeywords":["say","them"]},{"verseId":"brenton_ezekiel_12_11","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":11,"text":"say, I am performing signs: as I have done, so shall it be to him: they shall go into banishment and captivity.","searchKeywords":["say","performing","signs","have","done","shall","him","they","into","banishment","and","captivity"]},{"verseId":"brenton_ezekiel_12_12","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":12,"text":"And the prince in the midst of them shall be borne upon shoulders, and shall go forth in secret through the wall, and shall dig so that he may go forth thereby: he shall cover his face, that he may not be seen by eye, and he himself shall not see the ground.","searchKeywords":["and","the","prince","midst","them","shall","borne","upon","shoulders","forth","secret","through","wall","dig","that","may","thereby","cover","his","face","not","seen","eye","himself","see","ground"]},{"verseId":"brenton_ezekiel_12_13","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":13,"text":"And I will spread out my net upon him, and he shall be caught in my toils: and I will bring him to Babylon to the land of the Chaldeans; but he shall not see it, though he shall die there.","searchKeywords":["and","will","spread","out","net","upon","him","shall","caught","toils","bring","babylon","the","land","chaldeans","but","not","see","though","die","there"]},{"verseId":"brenton_ezekiel_12_14","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":14,"text":"And I will scatter to every wind all his assistants round about him, and all that help him; and I will draw out a sword after them.","searchKeywords":["and","will","scatter","every","wind","all","his","assistants","round","about","him","that","help","draw","out","sword","after","them"]},{"verseId":"brenton_ezekiel_12_15","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":15,"text":"And they shall know that I am the Lord, when I have scattered them among the nations; and I will disperse them in the countries.","searchKeywords":["and","they","shall","know","that","the","lord","when","have","scattered","them","among","nations","will","disperse","countries"]},{"verseId":"brenton_ezekiel_12_16","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":16,"text":"And I will leave of them men in number from the sword, and from famine, and from pestilence; that they may declare all their iniquities among the nations whither they have gone; and they shall know that I am the Lord.","searchKeywords":["and","will","leave","them","men","number","from","the","sword","famine","pestilence","that","they","may","declare","all","their","iniquities","among","nations","whither","have","gone","shall","know","lord"]},{"verseId":"brenton_ezekiel_12_17","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":17,"text":"And the word of the Lord came to me, saying,","searchKeywords":["and","the","word","lord","came","saying"]},{"verseId":"brenton_ezekiel_12_18","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":18,"text":"Son of man, eat thy bread with sorrow, and drink water with torment and affliction.","searchKeywords":["son","man","eat","thy","bread","with","sorrow","and","drink","water","torment","affliction"]},{"verseId":"brenton_ezekiel_12_19","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":19,"text":"And thou shalt say to the people of the land, Thus saith the Lord to the inhabitants of Jerusalem on the land of Israel; They shall eat their bread in scarcity, and shall drink their water in desolation, that the land may be desolate with all that it contains: for all that dwell in it are ungodly.","searchKeywords":["and","thou","shalt","say","the","people","land","thus","saith","lord","inhabitants","jerusalem","israel","they","shall","eat","their","bread","scarcity","drink","water","desolation","that","may","desolate","with","all","contains","for","dwell","are","ungodly"]},{"verseId":"brenton_ezekiel_12_20","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":20,"text":"And their inhabited cities shall be laid utterly waste, and the land shall be desolate; and ye shall know that I am the Lord.","searchKeywords":["and","their","inhabited","cities","shall","laid","utterly","waste","the","land","desolate","know","that","lord"]},{"verseId":"brenton_ezekiel_12_21","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":21,"text":"And the word of the Lord came to me, saying,","searchKeywords":["and","the","word","lord","came","saying"]},{"verseId":"brenton_ezekiel_12_22","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":22,"text":"Son of man, what is your parable on the land of Israel, that ye say, The days are long, the vision has perished?","searchKeywords":["son","man","what","your","parable","the","land","israel","that","say","days","are","long","vision","has","perished"]},{"verseId":"brenton_ezekiel_12_23","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":23,"text":"Therefore say to them,","searchKeywords":["therefore","say","them"]},{"verseId":"brenton_ezekiel_12_24","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":24,"text":"For there shall no more be any false vision, nor any one prophesying flatteries in the midst of the children of Israel.","searchKeywords":["for","there","shall","more","any","false","vision","nor","one","prophesying","flatteries","the","midst","children","israel"]},{"verseId":"brenton_ezekiel_12_25","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":25,"text":"For I the Lord will speak my words; I will speak and perform , and will no more delay, for in your days, O provoking house, I will speak the word, and will perform , saith the Lord.","searchKeywords":["for","the","lord","will","speak","words","and","perform","more","delay","your","days","provoking","house","word","saith"]},{"verseId":"brenton_ezekiel_12_26","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":26,"text":"Moreover the word of the Lord came to me, saying,","searchKeywords":["moreover","the","word","lord","came","saying"]},{"verseId":"brenton_ezekiel_12_27","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":27,"text":"Son of man, behold, the provoking house of Israel boldly say, The vision which this man sees is for many days, and he prophesies for times afar off.","searchKeywords":["son","man","behold","the","provoking","house","israel","boldly","say","vision","which","this","sees","for","many","days","and","prophesies","times","afar","off"]},{"verseId":"brenton_ezekiel_12_28","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":12,"verse":28,"text":"Therefore say to them,","searchKeywords":["therefore","say","them"]}]