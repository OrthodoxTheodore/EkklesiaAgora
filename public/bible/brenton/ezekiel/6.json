[{"verseId":"brenton_ezekiel_6_1","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":1,"text":"And the word of the Lord came to me, saying,","searchKeywords":["and","the","word","lord","came","saying"]},{"verseId":"brenton_ezekiel_6_2","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":2,"text":"Son of man, set thy face against the mountains of Israel, and prophesy against them;","searchKeywords":["son","man","set","thy","face","against","the","mountains","israel","and","prophesy","them"]},{"verseId":"brenton_ezekiel_6_3","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":3,"text":"and thou shalt say,","searchKeywords":["and","thou","shalt","say"]},{"verseId":"brenton_ezekiel_6_4","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":4,"text":"And your altars shall be broken to pieces, and your consecrated plats; and I will cast down your slain before your idols.","searchKeywords":["and","your","altars","shall","broken","pieces","consecrated","plats","will","cast","down","slain","before","idols"]},{"verseId":"brenton_ezekiel_6_5","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":5,"text":"And I will scatter your bones round about your altars,","searchKeywords":["and","will","scatter","your","bones","round","about","altars"]},{"verseId":"brenton_ezekiel_6_6","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":6,"text":"and in all your habitations: the cities shall be made desolate, and the high places utterly laid waste; that your altars may be destroyed, and your idols be broken to pieces, and your consecrated plats be abolished.","searchKeywords":["and","all","your","habitations","the","cities","shall","made","desolate","high","places","utterly","laid","waste","that","altars","may","destroyed","idols","broken","pieces","consecrated","plats","abolished"]},{"verseId":"brenton_ezekiel_6_7","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":7,"text":"And slain shall fall in the midst of you, and ye shall know that I am the Lord.","searchKeywords":["and","slain","shall","fall","the","midst","you","know","that","lord"]},{"verseId":"brenton_ezekiel_6_8","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":8,"text":"When there are of you escaping from the sword among the Gentiles, and when ye are scattered in the countries;","searchKeywords":["when","there","are","you","escaping","from","the","sword","among","gentiles","and","scattered","countries"]},{"verseId":"brenton_ezekiel_6_9","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":9,"text":"then they of you that escape among the nations whither they were carried captive shall remember me; (I have sworn against their heart that goes a-whoring from me, and their eyes that go a-whoring after their practices;) and they shall mourn over themselves for all their abominations.","searchKeywords":["then","they","you","that","escape","among","the","nations","whither","were","carried","captive","shall","remember","have","sworn","against","their","heart","goes","whoring","from","and","eyes","after","practices","mourn","over","themselves","for","all","abominations"]},{"verseId":"brenton_ezekiel_6_10","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":10,"text":"And they shall know that I the Lord have spoken.","searchKeywords":["and","they","shall","know","that","the","lord","have","spoken"]},{"verseId":"brenton_ezekiel_6_11","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":11,"text":"Thus saith the Lord; Clap with hand, and stamp with foot and say, Aha, aha! for all the abominations of the house of Israel: they shall fall by the sword, and by pestilence, and by famine.","searchKeywords":["thus","saith","the","lord","clap","with","hand","and","stamp","foot","say","aha","for","all","abominations","house","israel","they","shall","fall","sword","pestilence","famine"]},{"verseId":"brenton_ezekiel_6_12","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":12,"text":"He that is near shall fall by the sword; and he that is far off shall die by the pestilence; and he that is in the siege shall be consumed with famine: and I will accomplish mine anger upon them.","searchKeywords":["that","near","shall","fall","the","sword","and","far","off","die","pestilence","siege","consumed","with","famine","will","accomplish","mine","anger","upon","them"]},{"verseId":"brenton_ezekiel_6_13","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":13,"text":"Then ye shall know that I am the Lord, when your slain are in the midst of your idols round about your altars, on every high hill, and under shady tree, where they offered a sweet savour to all their idols.","searchKeywords":["then","shall","know","that","the","lord","when","your","slain","are","midst","idols","round","about","altars","every","high","hill","and","under","shady","tree","where","they","offered","sweet","savour","all","their"]},{"verseId":"brenton_ezekiel_6_14","translationId":"brenton","testament":"OT","bookIndex":49,"bookName":"Ezekiel","bookAbbrev":"ezekiel","chapter":6,"verse":14,"text":"And I will stretch out my hand against them, and I will make the land desolate and ruined from the wilderness of Deblatha, in all their habitations: ye shall know that I am the Lord.","searchKeywords":["and","will","stretch","out","hand","against","them","make","the","land","desolate","ruined","from","wilderness","deblatha","all","their","habitations","shall","know","that","lord"]}]