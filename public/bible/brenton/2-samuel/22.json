[{"verseId":"brenton_2-samuel_22_1","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":1,"text":"And David spoke to the Lord the words of this song, in the day in which the Lord rescued him out of the hand of all his enemies, and out of the hand of Saul.","searchKeywords":["and","david","spoke","the","lord","words","this","song","day","which","rescued","him","out","hand","all","his","enemies","saul"]},{"verseId":"brenton_2-samuel_22_2","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":2,"text":"And the song was thus:","searchKeywords":["and","the","song","was","thus"]},{"verseId":"brenton_2-samuel_22_3","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":3,"text":"my God; he shall be to me my guard, I will trust in him: my protector, and the horn of my salvation, my helper, and my sure refuge; thou shalt save me from the unjust man.","searchKeywords":["god","shall","guard","will","trust","him","protector","and","the","horn","salvation","helper","sure","refuge","thou","shalt","save","from","unjust","man"]},{"verseId":"brenton_2-samuel_22_4","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":4,"text":"I will call upon the Lord who is worthy to be praised, and I shall be saved from my enemies.","searchKeywords":["will","call","upon","the","lord","who","worthy","praised","and","shall","saved","from","enemies"]},{"verseId":"brenton_2-samuel_22_5","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":5,"text":"For the troubles of death compassed me, the floods of iniquity amazed me:","searchKeywords":["for","the","troubles","death","compassed","floods","iniquity","amazed"]},{"verseId":"brenton_2-samuel_22_6","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":6,"text":"the pangs of death surrounded me, the agonies of death prevented me.","searchKeywords":["the","pangs","death","surrounded","agonies","prevented"]},{"verseId":"brenton_2-samuel_22_7","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":7,"text":"When I am afflicted I will call upon the Lord, and will cry to my God, and he shall hear my voice out of his temple, and my cry shall come into his ears.","searchKeywords":["when","afflicted","will","call","upon","the","lord","and","cry","god","shall","hear","voice","out","his","temple","come","into","ears"]},{"verseId":"brenton_2-samuel_22_8","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":8,"text":"And the earth was troubled and quaked, and the foundations of heaven were confounded and torn asunder, because the Lord was wroth with them.","searchKeywords":["and","the","earth","was","troubled","quaked","foundations","heaven","were","confounded","torn","asunder","because","lord","wroth","with","them"]},{"verseId":"brenton_2-samuel_22_9","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":9,"text":"There went up a smoke in his wrath, and fire out of his mouth devours: coals were kindled at it.","searchKeywords":["there","went","smoke","his","wrath","and","fire","out","mouth","devours","coals","were","kindled"]},{"verseId":"brenton_2-samuel_22_10","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":10,"text":"And he bowed the heavens, and came down, and darkness under his feet.","searchKeywords":["and","bowed","the","heavens","came","down","darkness","under","his","feet"]},{"verseId":"brenton_2-samuel_22_11","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":11,"text":"And he rode upon the cherubs and did fly, and was seen upon the wings of the wind.","searchKeywords":["and","rode","upon","the","cherubs","did","fly","was","seen","wings","wind"]},{"verseId":"brenton_2-samuel_22_12","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":12,"text":"And he made darkness his hiding-place; his tabernacle round about him was the darkness of waters, he condensed it with the clouds of the air.","searchKeywords":["and","made","darkness","his","hiding","place","tabernacle","round","about","him","was","the","waters","condensed","with","clouds","air"]},{"verseId":"brenton_2-samuel_22_13","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":13,"text":"At the brightness before him coals of fire were kindled.","searchKeywords":["the","brightness","before","him","coals","fire","were","kindled"]},{"verseId":"brenton_2-samuel_22_14","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":14,"text":"The Lord thundered out of heaven, and the Most High uttered his voice.","searchKeywords":["the","lord","thundered","out","heaven","and","most","high","uttered","his","voice"]},{"verseId":"brenton_2-samuel_22_15","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":15,"text":"And he sent forth arrows, and scattered them, and he flashed lightning, and dismayed them.","searchKeywords":["and","sent","forth","arrows","scattered","them","flashed","lightning","dismayed"]},{"verseId":"brenton_2-samuel_22_16","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":16,"text":"And the channels of the sea were seen, and the foundations of the world were discovered, at the rebuke of the Lord, at the blast of the breath of his anger.","searchKeywords":["and","the","channels","sea","were","seen","foundations","world","discovered","rebuke","lord","blast","breath","his","anger"]},{"verseId":"brenton_2-samuel_22_17","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":17,"text":"He sent from above and took me; he drew me out of many waters.","searchKeywords":["sent","from","above","and","took","drew","out","many","waters"]},{"verseId":"brenton_2-samuel_22_18","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":18,"text":"He delivered me from my strong enemies, from them that hated me, for they were stronger than I.","searchKeywords":["delivered","from","strong","enemies","them","that","hated","for","they","were","stronger","than"]},{"verseId":"brenton_2-samuel_22_19","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":19,"text":"The days of my affliction prevented me; but the Lord was my stay.","searchKeywords":["the","days","affliction","prevented","but","lord","was","stay"]},{"verseId":"brenton_2-samuel_22_20","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":20,"text":"And he brought me into a wide place, and rescued me, because he delighted in me.","searchKeywords":["and","brought","into","wide","place","rescued","because","delighted"]},{"verseId":"brenton_2-samuel_22_21","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":21,"text":"And the Lord recompensed me according to my righteousness; even according to the purity of my hands did he recompense me.","searchKeywords":["and","the","lord","recompensed","according","righteousness","even","purity","hands","did","recompense"]},{"verseId":"brenton_2-samuel_22_22","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":22,"text":"Because I kept the ways of the Lord, and did not wickedly depart from my God.","searchKeywords":["because","kept","the","ways","lord","and","did","not","wickedly","depart","from","god"]},{"verseId":"brenton_2-samuel_22_23","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":23,"text":"For all his judgments and his ordinances before me: I departed not from them.","searchKeywords":["for","all","his","judgments","and","ordinances","before","departed","not","from","them"]},{"verseId":"brenton_2-samuel_22_24","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":24,"text":"And I shall be blameless before him, and will keep myself from my iniquity.","searchKeywords":["and","shall","blameless","before","him","will","keep","myself","from","iniquity"]},{"verseId":"brenton_2-samuel_22_25","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":25,"text":"And the Lord will recompense me according to my righteousness, and according to the purity of my hands in his eye-sight.","searchKeywords":["and","the","lord","will","recompense","according","righteousness","purity","hands","his","eye","sight"]},{"verseId":"brenton_2-samuel_22_26","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":26,"text":"With the holy thou wilt be holy, and with the perfect man thou wilt be perfect,","searchKeywords":["with","the","holy","thou","wilt","and","perfect","man"]},{"verseId":"brenton_2-samuel_22_27","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":27,"text":"and with the excellent thou wilt be excellent, and with the froward thou wilt be froward.","searchKeywords":["and","with","the","excellent","thou","wilt","froward"]},{"verseId":"brenton_2-samuel_22_28","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":28,"text":"And thou wilt save the poor people, and wilt bring down the eyes of the haughty.","searchKeywords":["and","thou","wilt","save","the","poor","people","bring","down","eyes","haughty"]},{"verseId":"brenton_2-samuel_22_29","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":29,"text":"For thou, Lord, my lamp, and the Lord shall shine forth to me in my darkness.","searchKeywords":["for","thou","lord","lamp","and","the","shall","shine","forth","darkness"]},{"verseId":"brenton_2-samuel_22_30","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":30,"text":"For by thee shall I run a girded man, and by my God shall I leap over a wall.","searchKeywords":["for","thee","shall","run","girded","man","and","god","leap","over","wall"]},{"verseId":"brenton_2-samuel_22_31","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":31,"text":"As for the Mighty One, his way blameless: the word of the Lord strong tried in the fire: he is a protector to all that put their trust in him.","searchKeywords":["for","the","mighty","one","his","way","blameless","word","lord","strong","tried","fire","protector","all","that","put","their","trust","him"]},{"verseId":"brenton_2-samuel_22_32","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":32,"text":"Who strong, but the Lord? and who will be a Creator except our God?","searchKeywords":["who","strong","but","the","lord","and","will","creator","except","our","god"]},{"verseId":"brenton_2-samuel_22_33","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":33,"text":"the Mighty One who strengthens me with might, and has prepared my way without fault.","searchKeywords":["the","mighty","one","who","strengthens","with","might","and","has","prepared","way","without","fault"]},{"verseId":"brenton_2-samuel_22_34","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":34,"text":"He makes my feet like harts' feet, and sets me upon the high places.","searchKeywords":["makes","feet","like","harts","and","sets","upon","the","high","places"]},{"verseId":"brenton_2-samuel_22_35","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":35,"text":"He teaches my hands to war, and has broken a brazen bow by my arm.","searchKeywords":["teaches","hands","war","and","has","broken","brazen","bow","arm"]},{"verseId":"brenton_2-samuel_22_36","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":36,"text":"And thou hast given me the shield of my salvation, and thy propitious dealing has increased me,","searchKeywords":["and","thou","hast","given","the","shield","salvation","thy","propitious","dealing","has","increased"]},{"verseId":"brenton_2-samuel_22_37","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":37,"text":"so as to make room under me for my going, and my legs did not totter.","searchKeywords":["make","room","under","for","going","and","legs","did","not","totter"]},{"verseId":"brenton_2-samuel_22_38","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":38,"text":"I will pursue my enemies, and will utterly destroy them; and I will not turn again till I have consumed them.","searchKeywords":["will","pursue","enemies","and","utterly","destroy","them","not","turn","again","till","have","consumed"]},{"verseId":"brenton_2-samuel_22_39","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":39,"text":"And I will crush them, and they shall not rise; and they shall fall under my feet.","searchKeywords":["and","will","crush","them","they","shall","not","rise","fall","under","feet"]},{"verseId":"brenton_2-samuel_22_40","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":40,"text":"And thou shalt strengthen me with power for the war; thou shalt cause them that rise up against me to bow down under me.","searchKeywords":["and","thou","shalt","strengthen","with","power","for","the","war","cause","them","that","rise","against","bow","down","under"]},{"verseId":"brenton_2-samuel_22_41","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":41,"text":"And thou hast caused mine enemies to flee before me, even them that hated me, and thou hast slain them.","searchKeywords":["and","thou","hast","caused","mine","enemies","flee","before","even","them","that","hated","slain"]},{"verseId":"brenton_2-samuel_22_42","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":42,"text":"They shall cry, and there shall be no helper; to the Lord, but he hearkens not to them.","searchKeywords":["they","shall","cry","and","there","helper","the","lord","but","hearkens","not","them"]},{"verseId":"brenton_2-samuel_22_43","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":43,"text":"And I ground them as the dust of the earth, I beat them small as the mire of the streets.","searchKeywords":["and","ground","them","the","dust","earth","beat","small","mire","streets"]},{"verseId":"brenton_2-samuel_22_44","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":44,"text":"And thou shalt deliver me from the striving of the peoples, thou shalt keep me the head of the Gentiles: a people which I knew not served me.","searchKeywords":["and","thou","shalt","deliver","from","the","striving","peoples","keep","head","gentiles","people","which","knew","not","served"]},{"verseId":"brenton_2-samuel_22_45","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":45,"text":"The strange children feigned to me; they hearkened to me as soon as they heard.","searchKeywords":["the","strange","children","feigned","they","hearkened","soon","heard"]},{"verseId":"brenton_2-samuel_22_46","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":46,"text":"The strange children shall be cast away, and shall be overthrown out of their hiding-places.","searchKeywords":["the","strange","children","shall","cast","away","and","overthrown","out","their","hiding","places"]},{"verseId":"brenton_2-samuel_22_47","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":47,"text":"The Lord lives, and blessed my guardian, and my God, my strong keeper, shall be exalted.","searchKeywords":["the","lord","lives","and","blessed","guardian","god","strong","keeper","shall","exalted"]},{"verseId":"brenton_2-samuel_22_48","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":48,"text":"The Lord who avenges me strong, chastening the nations under me,","searchKeywords":["the","lord","who","avenges","strong","chastening","nations","under"]},{"verseId":"brenton_2-samuel_22_49","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":49,"text":"and bringing me out from my enemies: and thou shalt set me on high from among those that rise up against me: thou shalt deliver me from the violent man.","searchKeywords":["and","bringing","out","from","enemies","thou","shalt","set","high","among","those","that","rise","against","deliver","the","violent","man"]},{"verseId":"brenton_2-samuel_22_50","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":50,"text":"Therefore will I confess to thee, O Lord, among the Gentiles, and sing to thy name.","searchKeywords":["therefore","will","confess","thee","lord","among","the","gentiles","and","sing","thy","name"]},{"verseId":"brenton_2-samuel_22_51","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":22,"verse":51,"text":"He magnifies the salvation of his king, and works mercy for his anointed, even for David and for his seed for ever.","searchKeywords":["magnifies","the","salvation","his","king","and","works","mercy","for","anointed","even","david","seed","ever"]}]