[{"verseId":"brenton_2-samuel_23_1","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":1,"text":"And these the last words of David. David the son of Jessæ, and faithful the man whom the Lord raised up to be the anointed of the God of Jacob, and beautiful the psalms of Israel.","searchKeywords":["and","these","the","last","words","david","son","jess","faithful","man","whom","lord","raised","anointed","god","jacob","beautiful","psalms","israel"]},{"verseId":"brenton_2-samuel_23_2","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":2,"text":"The Spirit of the Lord spoke by me, and his word upon my tongue.","searchKeywords":["the","spirit","lord","spoke","and","his","word","upon","tongue"]},{"verseId":"brenton_2-samuel_23_3","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":3,"text":"The God of Israel says, A watchman out of Israel spoke to me a parable: I said among men, How will ye strengthen the fear of the anointed?","searchKeywords":["the","god","israel","says","watchman","out","spoke","parable","said","among","men","how","will","strengthen","fear","anointed"]},{"verseId":"brenton_2-samuel_23_4","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":4,"text":"And in the morning light of God, let the sun arise in the morning, from the light of which the Lord passed on, and as it were from the rain of the tender grass upon the earth.","searchKeywords":["and","the","morning","light","god","let","sun","arise","from","which","lord","passed","were","rain","tender","grass","upon","earth"]},{"verseId":"brenton_2-samuel_23_5","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":5,"text":"For my house not so with the Mighty One: for he has made an everlasting covenant with me, ready, guarded at every time; for all my salvation and all my desire , that the wicked should not flourish.","searchKeywords":["for","house","not","with","the","mighty","one","has","made","everlasting","covenant","ready","guarded","every","time","all","salvation","and","desire","that","wicked","should","flourish"]},{"verseId":"brenton_2-samuel_23_6","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":6,"text":"All these as a thorn thrust forth, for they shall not be taken with the hand,","searchKeywords":["all","these","thorn","thrust","forth","for","they","shall","not","taken","with","the","hand"]},{"verseId":"brenton_2-samuel_23_7","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":7,"text":"and a man shall not labour among them; and that which is fully armed with iron, and the staff of a spear, and he shall burn them with fire, and they shall be burnt in their shame.","searchKeywords":["and","man","shall","not","labour","among","them","that","which","fully","armed","with","iron","the","staff","spear","burn","fire","they","burnt","their","shame"]},{"verseId":"brenton_2-samuel_23_8","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":8,"text":"These the names of the mighty men of David: Jebosthe the Chananite is a captain of the third : Adinon the Asonite, he drew his sword against eight hundred soldiers at once.","searchKeywords":["these","the","names","mighty","men","david","jebosthe","chananite","captain","third","adinon","asonite","drew","his","sword","against","eight","hundred","soldiers","once"]},{"verseId":"brenton_2-samuel_23_9","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":9,"text":"And after him Eleanan the son of his uncle, son of Dudi who was among the three mighty men with David; and when he defied the Philistines they were gathered there to war, and the men of Israel went up.","searchKeywords":["and","after","him","eleanan","the","son","his","uncle","dudi","who","was","among","three","mighty","men","with","david","when","defied","philistines","they","were","gathered","there","war","israel","went"]},{"verseId":"brenton_2-samuel_23_10","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":10,"text":"He arose and smote the Philistines, until his hand was weary, and his hand clave to the sword: and the Lord wrought a great salvation in that day, and the people rested behind him only to strip .","searchKeywords":["arose","and","smote","the","philistines","until","his","hand","was","weary","clave","sword","lord","wrought","great","salvation","that","day","people","rested","behind","him","only","strip"]},{"verseId":"brenton_2-samuel_23_11","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":11,"text":"And after him Samaia the son of Asa the Arachite: and the Philistines were gathered to Theria; and there was there a portion of ground full of lentiles; and the people fled before the Philistines.","searchKeywords":["and","after","him","samaia","the","son","asa","arachite","philistines","were","gathered","theria","there","was","portion","ground","full","lentiles","people","fled","before"]},{"verseId":"brenton_2-samuel_23_12","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":12,"text":"And he stood firm in the midst of the portion, and rescued it, and smote the Philistines; and the Lord wrought a great deliverance.","searchKeywords":["and","stood","firm","the","midst","portion","rescued","smote","philistines","lord","wrought","great","deliverance"]},{"verseId":"brenton_2-samuel_23_13","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":13,"text":"And three out of the thirty went down, and came to Cason to David, to the cave of Odollam; and an army of the Philistines, and they encamped in the valley of Raphain.","searchKeywords":["and","three","out","the","thirty","went","down","came","cason","david","cave","odollam","army","philistines","they","encamped","valley","raphain"]},{"verseId":"brenton_2-samuel_23_14","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":14,"text":"And David then in the strong hold, and the garrison of the Philistines then in Bethleem.","searchKeywords":["and","david","then","the","strong","hold","garrison","philistines","bethleem"]},{"verseId":"brenton_2-samuel_23_15","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":15,"text":"And David longed, and said, Who will give me water to drink out of the well that is in Bethleem by the gate? now the band of the Philistines then in Bethleem.","searchKeywords":["and","david","longed","said","who","will","give","water","drink","out","the","well","that","bethleem","gate","now","band","philistines","then"]},{"verseId":"brenton_2-samuel_23_16","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":16,"text":"And the three mighty men broke through the host of the Philistines, and drew water out of the well that was in Bethleem in the gate: and they took it, and brought it to David, and he would not drink it, but poured it out before the Lord.","searchKeywords":["and","the","three","mighty","men","broke","through","host","philistines","drew","water","out","well","that","was","bethleem","gate","they","took","brought","david","would","not","drink","but","poured","before","lord"]},{"verseId":"brenton_2-samuel_23_17","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":17,"text":"And he said, O Lord, forbid that I should do this, that I should drink the blood of the men who went at their lives: and he would not drink it. These things did these three mighty men.","searchKeywords":["and","said","lord","forbid","that","should","this","drink","the","blood","men","who","went","their","lives","would","not","these","things","did","three","mighty"]},{"verseId":"brenton_2-samuel_23_18","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":18,"text":"And Abessa the brother of Joab the son of Saruia, he chief among the three, and he lifted up his spear against three hundred whom he slew; and he had a name among three.","searchKeywords":["and","abessa","the","brother","joab","son","saruia","chief","among","three","lifted","his","spear","against","hundred","whom","slew","had","name"]},{"verseId":"brenton_2-samuel_23_19","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":19,"text":"Of those three most honourable, and he became a chief over them, but he reached not to the three.","searchKeywords":["those","three","most","honourable","and","became","chief","over","them","but","reached","not","the"]},{"verseId":"brenton_2-samuel_23_20","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":20,"text":"And Banæas the son of Jodae, he was abundant in deeds, from Cabeseel, and he smote the two sons of Ariel of Moab: and he went down and smote a lion in the midst of a pit on a snowy day.","searchKeywords":["and","ban","the","son","jodae","was","abundant","deeds","from","cabeseel","smote","two","sons","ariel","moab","went","down","lion","midst","pit","snowy","day"]},{"verseId":"brenton_2-samuel_23_21","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":21,"text":"He smote an Egyptian, a wonderful man, and in the hand of the Egyptian a spear as the side of a ladder; and he went down to him with a staff, and snatched the spear from the Egyptian's hand, and slew him with his own spear.","searchKeywords":["smote","egyptian","wonderful","man","and","the","hand","spear","side","ladder","went","down","him","with","staff","snatched","from","slew","his","own"]},{"verseId":"brenton_2-samuel_23_22","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":22,"text":"These things did Banæas the son of Jodae, and he had a name among the three mighty men.","searchKeywords":["these","things","did","ban","the","son","jodae","and","had","name","among","three","mighty","men"]},{"verseId":"brenton_2-samuel_23_23","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":23,"text":"He was honourable among the three, but he reached not to the three: and David made him his reporter. the names of king David's mighty men.","searchKeywords":["was","honourable","among","the","three","but","reached","not","and","david","made","him","his","reporter","names","king","mighty","men"]},{"verseId":"brenton_2-samuel_23_24","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":24,"text":"Asael Joab's brother; he among the thirty. Eleanan son of Dudi his uncle in Bethleem.","searchKeywords":["asael","joab","brother","among","the","thirty","eleanan","son","dudi","his","uncle","bethleem"]},{"verseId":"brenton_2-samuel_23_25","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":25,"text":"Sæma the Rudæan.","searchKeywords":["the","rud"]},{"verseId":"brenton_2-samuel_23_26","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":26,"text":"Selles the Kelothite: Iras the son of Isca the Thecoite.","searchKeywords":["selles","the","kelothite","iras","son","isca","thecoite"]},{"verseId":"brenton_2-samuel_23_27","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":27,"text":"Abiezer the Anothite, of the sons of the Anothite.","searchKeywords":["abiezer","the","anothite","sons"]},{"verseId":"brenton_2-samuel_23_28","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":28,"text":"Ellon the Aoite; Noëre the Netophatite.","searchKeywords":["ellon","the","aoite","netophatite"]},{"verseId":"brenton_2-samuel_23_29","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":29,"text":"Esthai the son of Riba of Gabaeth, son of Benjamin the Ephrathite; Asmoth the Bardiamite; Emasu the Salabonite:","searchKeywords":["esthai","the","son","riba","gabaeth","benjamin","ephrathite","asmoth","bardiamite","emasu","salabonite"]},{"verseId":"brenton_2-samuel_23_32","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":32,"text":"the sons of Asan, Jonathan;","searchKeywords":["the","sons","asan","jonathan"]},{"verseId":"brenton_2-samuel_23_33","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":33,"text":"Samnan the Arodite; Amnan the son of Arai the Saraurite.","searchKeywords":["samnan","the","arodite","amnan","son","arai","saraurite"]},{"verseId":"brenton_2-samuel_23_34","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":34,"text":"Aliphaleth the son of Asbites, the son of the Machachachite; Eliab the son of Achitophel the Gelonite.","searchKeywords":["aliphaleth","the","son","asbites","machachachite","eliab","achitophel","gelonite"]},{"verseId":"brenton_2-samuel_23_35","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":35,"text":"Asarai the Carmelite the son of Uræoerchi.","searchKeywords":["asarai","the","carmelite","son","oerchi"]},{"verseId":"brenton_2-samuel_23_36","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":36,"text":"Gaal the son of Nathana. The son of much valour, of Galaaddi.","searchKeywords":["gaal","the","son","nathana","much","valour","galaaddi"]},{"verseId":"brenton_2-samuel_23_37","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":23,"verse":37,"text":"Elie the Ammanite.","searchKeywords":["elie","the","ammanite"]}]