[{"verseId":"brenton_2-samuel_1_1","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":1,"text":"it came to pass after Saul was dead, that David returned from smiting Amalec, and David abode two days in Sekelac.","searchKeywords":["came","pass","after","saul","was","dead","that","david","returned","from","smiting","amalec","and","abode","two","days","sekelac"]},{"verseId":"brenton_2-samuel_1_2","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":2,"text":"And it came to pass on the third day, that, behold, a man came from the camp, from the people of Saul, and his garments were rent, and earth upon his head: and it came to pass when he went in to David, that he fell upon the earth, and did obeisance to him.","searchKeywords":["and","came","pass","the","third","day","that","behold","man","from","camp","people","saul","his","garments","were","rent","earth","upon","head","when","went","david","fell","did","obeisance","him"]},{"verseId":"brenton_2-samuel_1_3","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":3,"text":"And David said to him, Whence comest thou? and he said to him, I have escaped out of the camp of Israel.","searchKeywords":["and","david","said","him","whence","comest","thou","have","escaped","out","the","camp","israel"]},{"verseId":"brenton_2-samuel_1_4","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":4,"text":"And David said to him, What the matter? tell me. And he said, The people fled out of the battle, and many of the people have fallen and are dead, and Saul and Jonathan his son are dead.","searchKeywords":["and","david","said","him","what","the","matter","tell","people","fled","out","battle","many","have","fallen","are","dead","saul","jonathan","his","son"]},{"verseId":"brenton_2-samuel_1_5","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":5,"text":"And David said to the young man who brought him the tidings, How knowest thou that Saul and Jonathan his son are dead?","searchKeywords":["and","david","said","the","young","man","who","brought","him","tidings","how","knowest","thou","that","saul","jonathan","his","son","are","dead"]},{"verseId":"brenton_2-samuel_1_6","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":6,"text":"And the young man that brought the tidings, said to him, I happened accidentally to be upon mount Gelbue; and, behold, Saul was leaning upon his spear, and, behold, the chariots and captains of horse pressed hard upon him.","searchKeywords":["and","the","young","man","that","brought","tidings","said","him","happened","accidentally","upon","mount","gelbue","behold","saul","was","leaning","his","spear","chariots","captains","horse","pressed","hard"]},{"verseId":"brenton_2-samuel_1_7","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":7,"text":"And he looked behind him, and saw me, and called me; and I said, Behold, I.","searchKeywords":["and","looked","behind","him","saw","called","said","behold"]},{"verseId":"brenton_2-samuel_1_8","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":8,"text":"And he said to me, Who art thou? and I said, I am an Amalekite.","searchKeywords":["and","said","who","art","thou","amalekite"]},{"verseId":"brenton_2-samuel_1_9","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":9,"text":"And he said to me, Stand, I pray thee, over me, and slay me, for a dreadful darkness has come upon me, for all my life in me.","searchKeywords":["and","said","stand","pray","thee","over","slay","for","dreadful","darkness","has","come","upon","all","life"]},{"verseId":"brenton_2-samuel_1_10","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":10,"text":"So I stood over him and slew him, because I knew he would not live after he was fallen; and I took the crown that was upon his head, and the bracelet that was upon his arm, and I have brought them hither to my lord.","searchKeywords":["stood","over","him","and","slew","because","knew","would","not","live","after","was","fallen","took","the","crown","that","upon","his","head","bracelet","arm","have","brought","them","hither","lord"]},{"verseId":"brenton_2-samuel_1_11","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":11,"text":"And David laid hold of his garments, and rent them; and all the men who were with him rent their garments.","searchKeywords":["and","david","laid","hold","his","garments","rent","them","all","the","men","who","were","with","him","their"]},{"verseId":"brenton_2-samuel_1_12","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":12,"text":"And they lamented, and wept, and fasted till evening, for Saul and for Jonathan his son, and for the people of Juda, and for the house of Israel, because they were smitten with the sword.","searchKeywords":["and","they","lamented","wept","fasted","till","evening","for","saul","jonathan","his","son","the","people","juda","house","israel","because","were","smitten","with","sword"]},{"verseId":"brenton_2-samuel_1_13","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":13,"text":"And David said to the young man who brought the tidings to him, Whence art thou? and he said, I am the son of an Amalekite sojourner.","searchKeywords":["and","david","said","the","young","man","who","brought","tidings","him","whence","art","thou","son","amalekite","sojourner"]},{"verseId":"brenton_2-samuel_1_14","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":14,"text":"And David said to him, How was it thou wast not afraid to lift thy hand to destroy the anointed of the Lord?","searchKeywords":["and","david","said","him","how","was","thou","wast","not","afraid","lift","thy","hand","destroy","the","anointed","lord"]},{"verseId":"brenton_2-samuel_1_15","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":15,"text":"And David called one of his young men, and said, Go and fall upon him: and he smote him, and he died.","searchKeywords":["and","david","called","one","his","young","men","said","fall","upon","him","smote","died"]},{"verseId":"brenton_2-samuel_1_16","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":16,"text":"And David said to him, Thy blood upon thine own head; for thy mouth has testified against thee, saying, I have slain the anointed of the Lord.","searchKeywords":["and","david","said","him","thy","blood","upon","thine","own","head","for","mouth","has","testified","against","thee","saying","have","slain","the","anointed","lord"]},{"verseId":"brenton_2-samuel_1_17","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":17,"text":"And David lamented with this lamentation over Saul and over Jonathan his son.","searchKeywords":["and","david","lamented","with","this","lamentation","over","saul","jonathan","his","son"]},{"verseId":"brenton_2-samuel_1_18","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":18,"text":"And he gave orders to teach it the sons of Juda: behold, it is written in the book of Right.","searchKeywords":["and","gave","orders","teach","the","sons","juda","behold","written","book","right"]},{"verseId":"brenton_2-samuel_1_19","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":19,"text":"Set up a pillar, O Israel, for the slain that died upon thy high places: how are the mighty fallen!","searchKeywords":["set","pillar","israel","for","the","slain","that","died","upon","thy","high","places","how","are","mighty","fallen"]},{"verseId":"brenton_2-samuel_1_20","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":20,"text":"Tell it not in Geth, and tell it not as glad tidings in the streets of Ascalon, lest the daughters of the Philistines rejoice, lest the daughters of the uncircumcised triumph.","searchKeywords":["tell","not","geth","and","glad","tidings","the","streets","ascalon","lest","daughters","philistines","rejoice","uncircumcised","triumph"]},{"verseId":"brenton_2-samuel_1_21","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":21,"text":"Ye mountains of Gelbue, let not dew nor rain descend upon you, nor fields of first-fruits , for there the shield of the mighty ones has been grievously assailed; the shield of Saul was not anointed with oil.","searchKeywords":["mountains","gelbue","let","not","dew","nor","rain","descend","upon","you","fields","first","fruits","for","there","the","shield","mighty","ones","has","been","grievously","assailed","saul","was","anointed","with","oil"]},{"verseId":"brenton_2-samuel_1_22","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":22,"text":"From the blood of the slain, and from the fat of the mighty, the bow of Jonathan returned not empty; and the sword of Saul turned not back empty.","searchKeywords":["from","the","blood","slain","and","fat","mighty","bow","jonathan","returned","not","empty","sword","saul","turned","back"]},{"verseId":"brenton_2-samuel_1_23","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":23,"text":"Saul and Jonathan, the beloved and the beautiful, were not divided: comely in their life, and in their death they were not divided: swifter than eagles, and they were stronger than lions.","searchKeywords":["saul","and","jonathan","the","beloved","beautiful","were","not","divided","comely","their","life","death","they","swifter","than","eagles","stronger","lions"]},{"verseId":"brenton_2-samuel_1_24","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":24,"text":"Daughters of Israel, weep for Saul, who clothed you with scarlet together with your adorning, who added golden ornaments to your apparel.","searchKeywords":["daughters","israel","weep","for","saul","who","clothed","you","with","scarlet","together","your","adorning","added","golden","ornaments","apparel"]},{"verseId":"brenton_2-samuel_1_25","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":25,"text":"How are the mighty fallen in the midst of the battle! O Jonathan, even the slain ones upon thy high places!","searchKeywords":["how","are","the","mighty","fallen","midst","battle","jonathan","even","slain","ones","upon","thy","high","places"]},{"verseId":"brenton_2-samuel_1_26","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":26,"text":"I am grieved for thee, my brother Jonathan; thou wast very lovely to me; thy love to me was wonderful beyond the love of women.","searchKeywords":["grieved","for","thee","brother","jonathan","thou","wast","very","lovely","thy","love","was","wonderful","beyond","the","women"]},{"verseId":"brenton_2-samuel_1_27","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":1,"verse":27,"text":"How are the mighty fallen, and the weapons of war perished!","searchKeywords":["how","are","the","mighty","fallen","and","weapons","war","perished"]}]