[{"verseId":"brenton_2-samuel_5_1","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":1,"text":"And all the tribes of Israel come to David to Chebron, and they said to him, Behold, we thy bone and thy flesh.","searchKeywords":["and","all","the","tribes","israel","come","david","chebron","they","said","him","behold","thy","bone","flesh"]},{"verseId":"brenton_2-samuel_5_2","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":2,"text":"And heretofore Saul being king over us, thou wast he that didst lead out and bring in Israel: and the Lord said to thee, Thou shalt feed my people Israel, and thou shalt be for a leader to my people Israel.","searchKeywords":["and","heretofore","saul","being","king","over","thou","wast","that","didst","lead","out","bring","israel","the","lord","said","thee","shalt","feed","people","for","leader"]},{"verseId":"brenton_2-samuel_5_3","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":3,"text":"And all the elders of Israel come to the king to Chebron; and king David made a covenant with them in Chebron before the Lord; and they anoint David king over all Israel.","searchKeywords":["and","all","the","elders","israel","come","king","chebron","david","made","covenant","with","them","before","lord","they","anoint","over"]},{"verseId":"brenton_2-samuel_5_4","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":4,"text":"David thirty years old when he began to reign, and he reigned forty years.","searchKeywords":["david","thirty","years","old","when","began","reign","and","reigned","forty"]},{"verseId":"brenton_2-samuel_5_5","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":5,"text":"Seven years and six months he reigned in Chebron over Juda, and thirty-three years he reigned over all Israel and Juda in Jerusalem.","searchKeywords":["seven","years","and","six","months","reigned","chebron","over","juda","thirty","three","all","israel","jerusalem"]},{"verseId":"brenton_2-samuel_5_6","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":6,"text":"And David and his men departed to Jerusalem, to the Jebusite that inhabited the land: and it was said to David, Thou shalt not come in hither: for the blind and the lame withstood him, saying, David shall not come in hither.","searchKeywords":["and","david","his","men","departed","jerusalem","the","jebusite","that","inhabited","land","was","said","thou","shalt","not","come","hither","for","blind","lame","withstood","him","saying","shall"]},{"verseId":"brenton_2-samuel_5_7","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":7,"text":"And David took first the hold of Sion: this the city of David.","searchKeywords":["and","david","took","first","the","hold","sion","this","city"]},{"verseId":"brenton_2-samuel_5_8","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":8,"text":"And David said on that day, Every one that smites the Jebusite, let him attack with the dagger both the lame and the blind, and those that hate the soul of David. Therefore they say, The lame and the blind shall not enter into the house of the Lord.","searchKeywords":["and","david","said","that","day","every","one","smites","the","jebusite","let","him","attack","with","dagger","both","lame","blind","those","hate","soul","therefore","they","say","shall","not","enter","into","house","lord"]},{"verseId":"brenton_2-samuel_5_9","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":9,"text":"And David dwelt in the hold, and it was called the city of David, and he built the city itself round about from the citadel, and his own house.","searchKeywords":["and","david","dwelt","the","hold","was","called","city","built","itself","round","about","from","citadel","his","own","house"]},{"verseId":"brenton_2-samuel_5_10","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":10,"text":"And David advanced and became great, and the Lord Almighty with him.","searchKeywords":["and","david","advanced","became","great","the","lord","almighty","with","him"]},{"verseId":"brenton_2-samuel_5_11","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":11,"text":"And Chiram king of Tyre sent messengers to David, and cedar wood, and carpenters, and stone-masons: and they built a house for David.","searchKeywords":["and","chiram","king","tyre","sent","messengers","david","cedar","wood","carpenters","stone","masons","they","built","house","for"]},{"verseId":"brenton_2-samuel_5_12","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":12,"text":"And David knew that the Lord had prepared him to be king over Israel, and that his kingdom was exalted for the sake of his people Israel.","searchKeywords":["and","david","knew","that","the","lord","had","prepared","him","king","over","israel","his","kingdom","was","exalted","for","sake","people"]},{"verseId":"brenton_2-samuel_5_13","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":13,"text":"And David took again wives and concubines out of Jerusalem, after he came from Chebron: and David had still more sons and daughters born to him.","searchKeywords":["and","david","took","again","wives","concubines","out","jerusalem","after","came","from","chebron","had","still","more","sons","daughters","born","him"]},{"verseId":"brenton_2-samuel_5_14","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":14,"text":"And these the names of those that were born to him in Jerusalem; Sammus, and Sobab, and Nathan, and Solomon.","searchKeywords":["and","these","the","names","those","that","were","born","him","jerusalem","sammus","sobab","nathan","solomon"]},{"verseId":"brenton_2-samuel_5_15","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":15,"text":"And Ebear, and Elisue, and Naphec, and Jephies.","searchKeywords":["and","ebear","elisue","naphec","jephies"]},{"verseId":"brenton_2-samuel_5_16","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":16,"text":"And Elisama, and Elidae, and Eliphalath, Samae, Jessibath, Nathan, Galamaan, Jebaar, Theësus, Eliphalat, Naged, Naphec, Janathan, Leasamys, Baalimath, Eliphaath.","searchKeywords":["and","elisama","elidae","eliphalath","samae","jessibath","nathan","galamaan","jebaar","the","sus","eliphalat","naged","naphec","janathan","leasamys","baalimath","eliphaath"]},{"verseId":"brenton_2-samuel_5_18","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":18,"text":"giants.","searchKeywords":["giants"]},{"verseId":"brenton_2-samuel_5_20","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":20,"text":"Upper Breaches, and smote the Philistines there: and David said, The Lord has destroyed the hostile Philistines before me, as water is dispersed; therefore the name of that place was called Over Breaches.","searchKeywords":["upper","breaches","and","smote","the","philistines","there","david","said","lord","has","destroyed","hostile","before","water","dispersed","therefore","name","that","place","was","called","over"]},{"verseId":"brenton_2-samuel_5_23","translationId":"brenton","testament":"OT","bookIndex":10,"bookName":"2 Samuel","bookAbbrev":"2-samuel","chapter":5,"verse":23,"text":"weeping.","searchKeywords":["weeping"]}]