[{"verseId":"brenton_judith_3_1","translationId":"brenton","testament":"OT","bookIndex":19,"bookName":"Judith","bookAbbrev":"judith","chapter":3,"verse":1,"text":"So they sent ambassadors unto him to treat of peace, saying,","searchKeywords":["they","sent","ambassadors","unto","him","treat","peace","saying"]},{"verseId":"brenton_judith_3_2","translationId":"brenton","testament":"OT","bookIndex":19,"bookName":"Judith","bookAbbrev":"judith","chapter":3,"verse":2,"text":"Behold, we the servants of Nabuchodonosor the great king lie before thee; use us as shall be good in thy sight.","searchKeywords":["behold","the","servants","nabuchodonosor","great","king","lie","before","thee","use","shall","good","thy","sight"]},{"verseId":"brenton_judith_3_3","translationId":"brenton","testament":"OT","bookIndex":19,"bookName":"Judith","bookAbbrev":"judith","chapter":3,"verse":3,"text":"Behold, our houses, and all our places, and all our fields of wheat, and flocks, and herds, and all the lodges of our tents, lie before thy face; use them as it pleaseth thee.","searchKeywords":["behold","our","houses","and","all","places","fields","wheat","flocks","herds","the","lodges","tents","lie","before","thy","face","use","them","pleaseth","thee"]},{"verseId":"brenton_judith_3_4","translationId":"brenton","testament":"OT","bookIndex":19,"bookName":"Judith","bookAbbrev":"judith","chapter":3,"verse":4,"text":"Behold, even our cities and the inhabitants thereof are thy servants; come and deal with them as seemeth good unto thee.","searchKeywords":["behold","even","our","cities","and","the","inhabitants","thereof","are","thy","servants","come","deal","with","them","seemeth","good","unto","thee"]},{"verseId":"brenton_judith_3_5","translationId":"brenton","testament":"OT","bookIndex":19,"bookName":"Judith","bookAbbrev":"judith","chapter":3,"verse":5,"text":"So the men came to Holofernes, and declared unto him after this manner.","searchKeywords":["the","men","came","holofernes","and","declared","unto","him","after","this","manner"]},{"verseId":"brenton_judith_3_6","translationId":"brenton","testament":"OT","bookIndex":19,"bookName":"Judith","bookAbbrev":"judith","chapter":3,"verse":6,"text":"Then came he down toward the sea coast, both he and his army, and set garrisons in the high cities, and took out of them chosen men for aid.","searchKeywords":["then","came","down","toward","the","sea","coast","both","and","his","army","set","garrisons","high","cities","took","out","them","chosen","men","for","aid"]},{"verseId":"brenton_judith_3_7","translationId":"brenton","testament":"OT","bookIndex":19,"bookName":"Judith","bookAbbrev":"judith","chapter":3,"verse":7,"text":"So they and all the country round about received him with garlands, with dances, and with timbrels.","searchKeywords":["they","and","all","the","country","round","about","received","him","with","garlands","dances","timbrels"]},{"verseId":"brenton_judith_3_8","translationId":"brenton","testament":"OT","bookIndex":19,"bookName":"Judith","bookAbbrev":"judith","chapter":3,"verse":8,"text":"Yet he did cast down their frontiers, and cut down their groves: for he had decreed to destroy all the gods of the land, that all nations should worship Nabuchodonosor only, and that all tongues and tribes should call upon him as a god.","searchKeywords":["yet","did","cast","down","their","frontiers","and","cut","groves","for","had","decreed","destroy","all","the","gods","land","that","nations","should","worship","nabuchodonosor","only","tongues","tribes","call","upon","him","god"]},{"verseId":"brenton_judith_3_9","translationId":"brenton","testament":"OT","bookIndex":19,"bookName":"Judith","bookAbbrev":"judith","chapter":3,"verse":9,"text":"Also he came over against Esdraelon near unto Judea, over against the great strait of Judea.","searchKeywords":["also","came","over","against","esdraelon","near","unto","judea","the","great","strait"]},{"verseId":"brenton_judith_3_10","translationId":"brenton","testament":"OT","bookIndex":19,"bookName":"Judith","bookAbbrev":"judith","chapter":3,"verse":10,"text":"And he pitched between Geba and Scythopolis, and there he tarried a whole month, that he might gather together all the carriages of his army.","searchKeywords":["and","pitched","between","geba","scythopolis","there","tarried","whole","month","that","might","gather","together","all","the","carriages","his","army"]}]