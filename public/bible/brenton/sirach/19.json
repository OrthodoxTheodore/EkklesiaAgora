[{"verseId":"brenton_sirach_19_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":1,"text":"A labouring man that is given to drunkenness shall not be rich: and he that contemneth small things shall fall by little and little.","searchKeywords":["labouring","man","that","given","drunkenness","shall","not","rich","and","contemneth","small","things","fall","little"]},{"verseId":"brenton_sirach_19_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":2,"text":"Wine and women will make men of understanding to fall away: and he that cleaveth to harlots will become impudent.","searchKeywords":["wine","and","women","will","make","men","understanding","fall","away","that","cleaveth","harlots","become","impudent"]},{"verseId":"brenton_sirach_19_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":3,"text":"Moths and worms shall have him to heritage, and a bold man shall be taken away.","searchKeywords":["moths","and","worms","shall","have","him","heritage","bold","man","taken","away"]},{"verseId":"brenton_sirach_19_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":4,"text":"He that is hasty to give credit is light-minded; and he that sinneth shall offend against his own soul.","searchKeywords":["that","hasty","give","credit","light","minded","and","sinneth","shall","offend","against","his","own","soul"]},{"verseId":"brenton_sirach_19_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":5,"text":"Whoso taketh pleasure in wickedness shall be condemned:","searchKeywords":["whoso","taketh","pleasure","wickedness","shall","condemned"]},{"verseId":"brenton_sirach_19_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":6,"text":"but he that hateth babbling hath less of evil.","searchKeywords":["but","that","hateth","babbling","hath","less","evil"]},{"verseId":"brenton_sirach_19_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":7,"text":"Rehearse not unto another that which is told unto thee, and thou shalt fare never the worse.","searchKeywords":["rehearse","not","unto","another","that","which","told","thee","and","thou","shalt","fare","never","the","worse"]},{"verseId":"brenton_sirach_19_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":8,"text":"Whether it be to friend or foe, talk not of other men's lives; and if thou canst not without offence, reveal them not.","searchKeywords":["whether","friend","foe","talk","not","other","men","lives","and","thou","canst","without","offence","reveal","them"]},{"verseId":"brenton_sirach_19_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":9,"text":"For he heard and observed thee, and when time cometh he will hate thee.","searchKeywords":["for","heard","and","observed","thee","when","time","cometh","will","hate"]},{"verseId":"brenton_sirach_19_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":10,"text":"If thou hast heard a word, let it die with thee; and be bold, it will not burst thee.","searchKeywords":["thou","hast","heard","word","let","die","with","thee","and","bold","will","not","burst"]},{"verseId":"brenton_sirach_19_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":11,"text":"A fool travaileth with a word, as a woman in labour of a child.","searchKeywords":["fool","travaileth","with","word","woman","labour","child"]},{"verseId":"brenton_sirach_19_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":12,"text":"As an arrow that sticketh in a man's thigh, so is a word within a fool's belly.","searchKeywords":["arrow","that","sticketh","man","thigh","word","within","fool","belly"]},{"verseId":"brenton_sirach_19_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":13,"text":"Admonish a friend, it may be he hath not done it: and if he have done it, that he do it no more.","searchKeywords":["admonish","friend","may","hath","not","done","and","have","that","more"]},{"verseId":"brenton_sirach_19_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":14,"text":"Admonish thy friend, it may be he hath not said it: and if he have, that he speak it not again.","searchKeywords":["admonish","thy","friend","may","hath","not","said","and","have","that","speak","again"]},{"verseId":"brenton_sirach_19_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":15,"text":"Admonish a friend: for many times it is a slander, and believe not every tale.","searchKeywords":["admonish","friend","for","many","times","slander","and","believe","not","every","tale"]},{"verseId":"brenton_sirach_19_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":16,"text":"There is one that slippeth in his speech, but not from his heart; and who is he that hath not offended with his tongue?","searchKeywords":["there","one","that","slippeth","his","speech","but","not","from","heart","and","who","hath","offended","with","tongue"]},{"verseId":"brenton_sirach_19_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":17,"text":"Admonish thy neighbour before thou threaten him; and give place to the law of the most High.","searchKeywords":["admonish","thy","neighbour","before","thou","threaten","him","and","give","place","the","law","most","high"]},{"verseId":"brenton_sirach_19_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":20,"text":"The fear of the Lord is all wisdom; and in all wisdom is the performance of the law.","searchKeywords":["the","fear","lord","all","wisdom","and","performance","law"]},{"verseId":"brenton_sirach_19_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":22,"text":"The knowledge of wickedness is not wisdom, neither at any time the counsel of sinners prudence.","searchKeywords":["the","knowledge","wickedness","not","wisdom","neither","any","time","counsel","sinners","prudence"]},{"verseId":"brenton_sirach_19_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":23,"text":"There is a wickedness, and the same an abomination; and there is a fool wanting in wisdom.","searchKeywords":["there","wickedness","and","the","same","abomination","fool","wanting","wisdom"]},{"verseId":"brenton_sirach_19_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":24,"text":"He that hath small understanding, and feareth God, is better than one that hath much wisdom, and transgresseth the law of the most High.","searchKeywords":["that","hath","small","understanding","and","feareth","god","better","than","one","much","wisdom","transgresseth","the","law","most","high"]},{"verseId":"brenton_sirach_19_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":25,"text":"There is an exquisite subtilty, and the same is unjust; and there is one that turneth aside to make judgment appear.","searchKeywords":["there","exquisite","subtilty","and","the","same","unjust","one","that","turneth","aside","make","judgment","appear"]},{"verseId":"brenton_sirach_19_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":26,"text":"There is a wicked man that hangeth down his head sadly; but inwardly he is full of deceit,","searchKeywords":["there","wicked","man","that","hangeth","down","his","head","sadly","but","inwardly","full","deceit"]},{"verseId":"brenton_sirach_19_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":27,"text":"casting down his countenance, and making as if he heard not: where he is not known, he will do thee a mischief before thou be aware.","searchKeywords":["casting","down","his","countenance","and","making","heard","not","where","known","will","thee","mischief","before","thou","aware"]},{"verseId":"brenton_sirach_19_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":28,"text":"And if for want of power he be hindered from sinning, yet when he findeth opportunity he will do evil.","searchKeywords":["and","for","want","power","hindered","from","sinning","yet","when","findeth","opportunity","will","evil"]},{"verseId":"brenton_sirach_19_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":29,"text":"A man may be known by his look, and one that hath understanding by his countenance, when thou meetest him.","searchKeywords":["man","may","known","his","look","and","one","that","hath","understanding","countenance","when","thou","meetest","him"]},{"verseId":"brenton_sirach_19_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":19,"verse":30,"text":"A man's attire, and excessive laughter, and gait, shew what he is.","searchKeywords":["man","attire","and","excessive","laughter","gait","shew","what"]}]