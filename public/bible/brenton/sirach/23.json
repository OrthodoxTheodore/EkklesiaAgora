[{"verseId":"brenton_sirach_23_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":1,"text":"O Lord, Father and Governor of my life, leave me not to their counsels, and let me not fall by them.","searchKeywords":["lord","father","and","governor","life","leave","not","their","counsels","let","fall","them"]},{"verseId":"brenton_sirach_23_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":2,"text":"Who will set scourges over my thoughts, and the discipline of wisdom over mine heart? that they spare me not for mine ignorances, and it pass not by my sins:","searchKeywords":["who","will","set","scourges","over","thoughts","and","the","discipline","wisdom","mine","heart","that","they","spare","not","for","ignorances","pass","sins"]},{"verseId":"brenton_sirach_23_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":3,"text":"lest mine ignorances increase, and my sins abound to my destruction, and I fall before mine adversaries, and mine enemy rejoice over me, whose hope is far from thy mercy.","searchKeywords":["lest","mine","ignorances","increase","and","sins","abound","destruction","fall","before","adversaries","enemy","rejoice","over","whose","hope","far","from","thy","mercy"]},{"verseId":"brenton_sirach_23_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":4,"text":"O Lord, Father and God of my life, give me not a proud look.","searchKeywords":["lord","father","and","god","life","give","not","proud","look"]},{"verseId":"brenton_sirach_23_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":5,"text":"Turn away concupiscence from me.","searchKeywords":["turn","away","concupiscence","from"]},{"verseId":"brenton_sirach_23_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":6,"text":"Let not the greediness of the belly nor lust of the flesh take hold of me; and give me not over into an impudent mind.","searchKeywords":["let","not","the","greediness","belly","nor","lust","flesh","take","hold","and","give","over","into","impudent","mind"]},{"verseId":"brenton_sirach_23_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":7,"text":"Hear, O ye children, the discipline of the mouth: he that keepeth it shall never be taken in his lips.","searchKeywords":["hear","children","the","discipline","mouth","that","keepeth","shall","never","taken","his","lips"]},{"verseId":"brenton_sirach_23_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":8,"text":"The sinner shall be left in his foolishness: both the evil speaker and the proud shall fall thereby.","searchKeywords":["the","sinner","shall","left","his","foolishness","both","evil","speaker","and","proud","fall","thereby"]},{"verseId":"brenton_sirach_23_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":9,"text":"Accustom not thy mouth to swearing; neither use thyself to the naming of the Holy One.","searchKeywords":["accustom","not","thy","mouth","swearing","neither","use","thyself","the","naming","holy","one"]},{"verseId":"brenton_sirach_23_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":10,"text":"For as a servant that is continually beaten shall not be without a blue mark: so he that sweareth and nameth God continually shall not be faultless.","searchKeywords":["for","servant","that","continually","beaten","shall","not","without","blue","mark","sweareth","and","nameth","god","faultless"]},{"verseId":"brenton_sirach_23_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":11,"text":"A man that useth much swearing shall be filled with iniquity, and the plague shall never depart from his house: if he shall offend, his sin shall be upon him: and if he acknowledge not his sin, he maketh a double offence: and if he swear in vain, he shall not be innocent, but his house shall be full of calamities.","searchKeywords":["man","that","useth","much","swearing","shall","filled","with","iniquity","and","the","plague","never","depart","from","his","house","offend","sin","upon","him","acknowledge","not","maketh","double","offence","swear","vain","innocent","but","full","calamities"]},{"verseId":"brenton_sirach_23_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":12,"text":"There is a word that is clothed about with death: God grant that it be not found in the heritage of Jacob; for all such things shall be far from the godly, and they shall not wallow in their sins.","searchKeywords":["there","word","that","clothed","about","with","death","god","grant","not","found","the","heritage","jacob","for","all","such","things","shall","far","from","godly","and","they","wallow","their","sins"]},{"verseId":"brenton_sirach_23_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":13,"text":"Use not thy mouth to intemperate swearing, for therein is the word of sin.","searchKeywords":["use","not","thy","mouth","intemperate","swearing","for","therein","the","word","sin"]},{"verseId":"brenton_sirach_23_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":14,"text":"Remember thy father and thy mother, when thou sittest among great men. Be not forgetful before them, and so thou by thy custom become a fool, and wish that thou hadst not been born, and curse the day of thy nativity.","searchKeywords":["remember","thy","father","and","mother","when","thou","sittest","among","great","men","not","forgetful","before","them","custom","become","fool","wish","that","hadst","been","born","curse","the","day","nativity"]},{"verseId":"brenton_sirach_23_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":15,"text":"The man that is accustomed to opprobrious words will never be reformed all the days of his life.","searchKeywords":["the","man","that","accustomed","opprobrious","words","will","never","reformed","all","days","his","life"]},{"verseId":"brenton_sirach_23_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":16,"text":"Two sorts of men multiply sin, and the third will bring wrath: a hot mind is as a burning fire, it will never be quenched till it be consumed: a fornicator in the body of his flesh will never cease till he hath kindled a fire.","searchKeywords":["two","sorts","men","multiply","sin","and","the","third","will","bring","wrath","hot","mind","burning","fire","never","quenched","till","consumed","fornicator","body","his","flesh","cease","hath","kindled"]},{"verseId":"brenton_sirach_23_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":17,"text":"All bread is sweet to a whoremonger, he will not leave off till he die.","searchKeywords":["all","bread","sweet","whoremonger","will","not","leave","off","till","die"]},{"verseId":"brenton_sirach_23_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":18,"text":"A man that breaketh wedlock, saying thus in his heart, Who seeth me? I am compassed about with darkness, the walls cover me, and no body seeth me; what need I to fear? the most High will not remember my sins:","searchKeywords":["man","that","breaketh","wedlock","saying","thus","his","heart","who","seeth","compassed","about","with","darkness","the","walls","cover","and","body","what","need","fear","most","high","will","not","remember","sins"]},{"verseId":"brenton_sirach_23_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":19,"text":"such a man only feareth the eyes of men, and knoweth not that the eyes of the Lord are ten thousand times brighter than the sun, beholding all the ways of men, and considering the most secret parts.","searchKeywords":["such","man","only","feareth","the","eyes","men","and","knoweth","not","that","lord","are","ten","thousand","times","brighter","than","sun","beholding","all","ways","considering","most","secret","parts"]},{"verseId":"brenton_sirach_23_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":20,"text":"He knew all things ere ever they were created; so also after they were perfected he looked upon them all.","searchKeywords":["knew","all","things","ere","ever","they","were","created","also","after","perfected","looked","upon","them"]},{"verseId":"brenton_sirach_23_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":21,"text":"This man shall be punished in the streets of the city, and where he suspecteth not he shall be taken.","searchKeywords":["this","man","shall","punished","the","streets","city","and","where","suspecteth","not","taken"]},{"verseId":"brenton_sirach_23_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":22,"text":"Thus shall it go also with the wife that leaveth her husband, and bringeth in an heir by another.","searchKeywords":["thus","shall","also","with","the","wife","that","leaveth","her","husband","and","bringeth","heir","another"]},{"verseId":"brenton_sirach_23_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":23,"text":"For first, she hath disobeyed the law of the most High; and secondly, she hath trespassed against her own husband; and thirdly, she hath played the whore in adultery, and brought children by another man.","searchKeywords":["for","first","she","hath","disobeyed","the","law","most","high","and","secondly","trespassed","against","her","own","husband","thirdly","played","whore","adultery","brought","children","another","man"]},{"verseId":"brenton_sirach_23_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":24,"text":"She shall be brought out into the congregation, and inquisition shall be made of her children.","searchKeywords":["she","shall","brought","out","into","the","congregation","and","inquisition","made","her","children"]},{"verseId":"brenton_sirach_23_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":25,"text":"Her children shall not take root, and her branches shall bring forth no fruit.","searchKeywords":["her","children","shall","not","take","root","and","branches","bring","forth","fruit"]},{"verseId":"brenton_sirach_23_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":26,"text":"She shall leave her memory to be cursed, and her reproach shall not be blotted out.","searchKeywords":["she","shall","leave","her","memory","cursed","and","reproach","not","blotted","out"]},{"verseId":"brenton_sirach_23_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":23,"verse":27,"text":"And they that remain shall know that there is nothing better than the fear of the Lord, and that there is nothing sweeter than to take heed unto the commandments of the Lord.","searchKeywords":["and","they","that","remain","shall","know","there","nothing","better","than","the","fear","lord","sweeter","take","heed","unto","commandments"]}]