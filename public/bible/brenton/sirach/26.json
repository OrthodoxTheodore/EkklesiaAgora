[{"verseId":"brenton_sirach_26_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":1,"text":"Blessed is the man that hath a virtuous wife, for the number of his days shall be double.","searchKeywords":["blessed","the","man","that","hath","virtuous","wife","for","number","his","days","shall","double"]},{"verseId":"brenton_sirach_26_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":2,"text":"A virtuous woman rejoiceth her husband, and he shall fulfil the years of his life in peace.","searchKeywords":["virtuous","woman","rejoiceth","her","husband","and","shall","fulfil","the","years","his","life","peace"]},{"verseId":"brenton_sirach_26_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":3,"text":"A good wife is a good portion, which shall be given in the portion of them that fear the Lord.","searchKeywords":["good","wife","portion","which","shall","given","the","them","that","fear","lord"]},{"verseId":"brenton_sirach_26_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":4,"text":"Whether a man be rich or poor, if he have a good heart toward the Lord, he shall at all times rejoice with a cheerful countenance.","searchKeywords":["whether","man","rich","poor","have","good","heart","toward","the","lord","shall","all","times","rejoice","with","cheerful","countenance"]},{"verseId":"brenton_sirach_26_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":5,"text":"There be three things that mine heart feareth; and for the fourth I was sore afraid: the slander of a city, the gathering together of an unruly multitude, and a false accusation: all these are worse than death.","searchKeywords":["there","three","things","that","mine","heart","feareth","and","for","the","fourth","was","sore","afraid","slander","city","gathering","together","unruly","multitude","false","accusation","all","these","are","worse","than","death"]},{"verseId":"brenton_sirach_26_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":6,"text":"But a grief of heart and sorrow is a woman that is jealous over another woman, and a scourge of the tongue which communicateth with all.","searchKeywords":["but","grief","heart","and","sorrow","woman","that","jealous","over","another","scourge","the","tongue","which","communicateth","with","all"]},{"verseId":"brenton_sirach_26_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":7,"text":"An evil wife is a yoke shaken to and fro: he that hath hold of her is as though he held a scorpion.","searchKeywords":["evil","wife","yoke","shaken","and","fro","that","hath","hold","her","though","held","scorpion"]},{"verseId":"brenton_sirach_26_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":8,"text":"A drunken woman and a gadder abroad causeth great anger, and she will not cover her own shame.","searchKeywords":["drunken","woman","and","gadder","abroad","causeth","great","anger","she","will","not","cover","her","own","shame"]},{"verseId":"brenton_sirach_26_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":9,"text":"The whoredom of a woman may be known in her haughty looks and eyelids.","searchKeywords":["the","whoredom","woman","may","known","her","haughty","looks","and","eyelids"]},{"verseId":"brenton_sirach_26_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":10,"text":"If thy daughter be shameless, keep her in straitly, lest she abuse herself through overmuch liberty.","searchKeywords":["thy","daughter","shameless","keep","her","straitly","lest","she","abuse","herself","through","overmuch","liberty"]},{"verseId":"brenton_sirach_26_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":11,"text":"Watch over an impudent eye: and marvel not if she trespass against thee.","searchKeywords":["watch","over","impudent","eye","and","marvel","not","she","trespass","against","thee"]},{"verseId":"brenton_sirach_26_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":12,"text":"She will open her mouth, as a thirsty traveller when he hath found a fountain, and drink of every water near her: by every hedge will she sit down, and open her quiver against every arrow.","searchKeywords":["she","will","open","her","mouth","thirsty","traveller","when","hath","found","fountain","and","drink","every","water","near","hedge","sit","down","quiver","against","arrow"]},{"verseId":"brenton_sirach_26_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":13,"text":"The grace of a wife delighteth her husband, and her discretion will fatten his bones.","searchKeywords":["the","grace","wife","delighteth","her","husband","and","discretion","will","fatten","his","bones"]},{"verseId":"brenton_sirach_26_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":14,"text":"A silent and loving woman is a gift of the Lord; and there is nothing so much worth as a mind well instructed.","searchKeywords":["silent","and","loving","woman","gift","the","lord","there","nothing","much","worth","mind","well","instructed"]},{"verseId":"brenton_sirach_26_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":15,"text":"A shamefaced and faithful woman is a double grace, and her continent mind cannot be valued.","searchKeywords":["shamefaced","and","faithful","woman","double","grace","her","continent","mind","cannot","valued"]},{"verseId":"brenton_sirach_26_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":16,"text":"As the sun when it ariseth in the high heaven; so is the beauty of a good wife in the ordering of her house.","searchKeywords":["the","sun","when","ariseth","high","heaven","beauty","good","wife","ordering","her","house"]},{"verseId":"brenton_sirach_26_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":17,"text":"As the clear light is upon the holy candlestick: so is the beauty of the face in ripe age.","searchKeywords":["the","clear","light","upon","holy","candlestick","beauty","face","ripe","age"]},{"verseId":"brenton_sirach_26_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":18,"text":"As the golden pillars are upon the sockets of silver; so are the fair feet with a constant heart.","searchKeywords":["the","golden","pillars","are","upon","sockets","silver","fair","feet","with","constant","heart"]},{"verseId":"brenton_sirach_26_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":28,"text":"There be two things that grieve my heart; and the third maketh me angry: a man of war that suffereth poverty; and men of understanding that are not set by: and one that returneth from righteousness to sin; the Lord prepareth such an one for the sword.","searchKeywords":["there","two","things","that","grieve","heart","and","the","third","maketh","angry","man","war","suffereth","poverty","men","understanding","are","not","set","one","returneth","from","righteousness","sin","lord","prepareth","such","for","sword"]},{"verseId":"brenton_sirach_26_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":26,"verse":29,"text":"A merchant shall hardly keep himself from doing wrong; and an huckster shall not be freed from sin.","searchKeywords":["merchant","shall","hardly","keep","himself","from","doing","wrong","and","huckster","not","freed","sin"]}]