[{"verseId":"brenton_sirach_16_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":1,"text":"Desire not a multitude of unprofitable children, neither delight in ungodly sons.","searchKeywords":["desire","not","multitude","unprofitable","children","neither","delight","ungodly","sons"]},{"verseId":"brenton_sirach_16_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":2,"text":"Though they multiply, rejoice not in them, except the fear of the Lord be with them.","searchKeywords":["though","they","multiply","rejoice","not","them","except","the","fear","lord","with"]},{"verseId":"brenton_sirach_16_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":3,"text":"Trust not thou in their life, neither respect their multitude: for one that is just is better than a thousand; and better it is to die without children, than to have them that are ungodly.","searchKeywords":["trust","not","thou","their","life","neither","respect","multitude","for","one","that","just","better","than","thousand","and","die","without","children","have","them","are","ungodly"]},{"verseId":"brenton_sirach_16_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":4,"text":"For by one that hath understanding shall the city be replenished: but the kindred of the wicked shall speedily become desolate.","searchKeywords":["for","one","that","hath","understanding","shall","the","city","replenished","but","kindred","wicked","speedily","become","desolate"]},{"verseId":"brenton_sirach_16_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":5,"text":"Many such things have I seen with mine eyes, and mine ear hath heard greater things than these.","searchKeywords":["many","such","things","have","seen","with","mine","eyes","and","ear","hath","heard","greater","than","these"]},{"verseId":"brenton_sirach_16_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":6,"text":"In the congregation of the ungodly shall a fire be kindled; and in a rebellious nation wrath is set on fire.","searchKeywords":["the","congregation","ungodly","shall","fire","kindled","and","rebellious","nation","wrath","set"]},{"verseId":"brenton_sirach_16_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":7,"text":"He was not pacified toward the old giants, who fell away in the strength of their foolishness.","searchKeywords":["was","not","pacified","toward","the","old","giants","who","fell","away","strength","their","foolishness"]},{"verseId":"brenton_sirach_16_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":8,"text":"Neither spared he the place where Lot sojourned, but abhorred them for their pride.","searchKeywords":["neither","spared","the","place","where","lot","sojourned","but","abhorred","them","for","their","pride"]},{"verseId":"brenton_sirach_16_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":9,"text":"He pitied not the people of perdition, who were taken away in their sins:","searchKeywords":["pitied","not","the","people","perdition","who","were","taken","away","their","sins"]},{"verseId":"brenton_sirach_16_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":10,"text":"nor the six hundred thousand footmen, who were gathered together in the hardness of their hearts.","searchKeywords":["nor","the","six","hundred","thousand","footmen","who","were","gathered","together","hardness","their","hearts"]},{"verseId":"brenton_sirach_16_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":11,"text":"And if there be one stiffnecked among the people, it is marvel if he escape unpunished: for mercy and wrath are with him; he is mighty to forgive and to pour out displeasure.","searchKeywords":["and","there","one","stiffnecked","among","the","people","marvel","escape","unpunished","for","mercy","wrath","are","with","him","mighty","forgive","pour","out","displeasure"]},{"verseId":"brenton_sirach_16_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":12,"text":"As his mercy is great, so is his correction also: he judgeth a man according to his works.","searchKeywords":["his","mercy","great","correction","also","judgeth","man","according","works"]},{"verseId":"brenton_sirach_16_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":13,"text":"The sinner shall not escape with his spoils: and the patience of the godly shall not be frustrate.","searchKeywords":["the","sinner","shall","not","escape","with","his","spoils","and","patience","godly","frustrate"]},{"verseId":"brenton_sirach_16_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":14,"text":"Make way for every work of mercy: for every man shall find according to his works.","searchKeywords":["make","way","for","every","work","mercy","man","shall","find","according","his","works"]},{"verseId":"brenton_sirach_16_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":17,"text":"Say not thou, I will hide myself from the Lord: shall any remember me from above? I shall not be remembered among so many people: for what is my soul among such an infinite number of creatures?","searchKeywords":["say","not","thou","will","hide","myself","from","the","lord","shall","any","remember","above","remembered","among","many","people","for","what","soul","such","infinite","number","creatures"]},{"verseId":"brenton_sirach_16_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":18,"text":"Behold, the heaven, and the heaven of heavens, the deep, and the earth, and all that therein is, shall be moved when he shall visit.","searchKeywords":["behold","the","heaven","and","heavens","deep","earth","all","that","therein","shall","moved","when","visit"]},{"verseId":"brenton_sirach_16_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":19,"text":"The mountains also and foundations of the earth shall be shaken with trembling, when he looketh upon them.","searchKeywords":["the","mountains","also","and","foundations","earth","shall","shaken","with","trembling","when","looketh","upon","them"]},{"verseId":"brenton_sirach_16_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":20,"text":"No heart can think upon these things worthily: and who is able to conceive his ways?","searchKeywords":["heart","can","think","upon","these","things","worthily","and","who","able","conceive","his","ways"]},{"verseId":"brenton_sirach_16_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":21,"text":"It is a tempest which no man can see: for the most part of his works are hid.","searchKeywords":["tempest","which","man","can","see","for","the","most","part","his","works","are","hid"]},{"verseId":"brenton_sirach_16_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":22,"text":"Who can declare the works of his justice? or who can endure them? for his covenant is afar off.","searchKeywords":["who","can","declare","the","works","his","justice","endure","them","for","covenant","afar","off"]},{"verseId":"brenton_sirach_16_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":23,"text":"He that wanteth understanding will think upon vain things: and a foolish man erring imagineth follies.","searchKeywords":["that","wanteth","understanding","will","think","upon","vain","things","and","foolish","man","erring","imagineth","follies"]},{"verseId":"brenton_sirach_16_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":24,"text":"My son, hearken unto me, and learn knowledge, and mark my words with thy heart.","searchKeywords":["son","hearken","unto","and","learn","knowledge","mark","words","with","thy","heart"]},{"verseId":"brenton_sirach_16_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":25,"text":"I will shew forth doctrine in weight, and declare his knowledge exactly.","searchKeywords":["will","shew","forth","doctrine","weight","and","declare","his","knowledge","exactly"]},{"verseId":"brenton_sirach_16_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":26,"text":"The works of the Lord are done in judgment from the beginning: and from the time he made them he disposed the parts thereof.","searchKeywords":["the","works","lord","are","done","judgment","from","beginning","and","time","made","them","disposed","parts","thereof"]},{"verseId":"brenton_sirach_16_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":27,"text":"He garnished his works for ever, and the chief of them unto all generations: they neither labour, nor are weary, nor cease from their works.","searchKeywords":["garnished","his","works","for","ever","and","the","chief","them","unto","all","generations","they","neither","labour","nor","are","weary","cease","from","their"]},{"verseId":"brenton_sirach_16_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":28,"text":"None of them hindereth another, and they shall never disobey his word.","searchKeywords":["none","them","hindereth","another","and","they","shall","never","disobey","his","word"]},{"verseId":"brenton_sirach_16_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":29,"text":"After this the Lord looked upon the earth, and filled it with his blessings.","searchKeywords":["after","this","the","lord","looked","upon","earth","and","filled","with","his","blessings"]},{"verseId":"brenton_sirach_16_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":16,"verse":30,"text":"With all manner of living things hath he covered the face thereof; and they shall return into it again.","searchKeywords":["with","all","manner","living","things","hath","covered","the","face","thereof","and","they","shall","return","into","again"]}]