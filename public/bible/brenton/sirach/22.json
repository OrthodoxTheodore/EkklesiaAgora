[{"verseId":"brenton_sirach_22_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":1,"text":"A slothful man is compared to a filthy stone, and every one will hiss him out to his disgrace.","searchKeywords":["slothful","man","compared","filthy","stone","and","every","one","will","hiss","him","out","his","disgrace"]},{"verseId":"brenton_sirach_22_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":2,"text":"A slothful man is compared to the filth of a dunghill: every man that takes it up will shake his hand.","searchKeywords":["slothful","man","compared","the","filth","dunghill","every","that","takes","will","shake","his","hand"]},{"verseId":"brenton_sirach_22_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":3,"text":"An evil-nurtured son is the dishonour of his father that begat him: and a [foolish] daughter is born to his loss.","searchKeywords":["evil","nurtured","son","the","dishonour","his","father","that","begat","him","and","foolish","daughter","born","loss"]},{"verseId":"brenton_sirach_22_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":4,"text":"A wise daughter shall bring an inheritance to her husband: but she that liveth dishonestly is her father's heaviness.","searchKeywords":["wise","daughter","shall","bring","inheritance","her","husband","but","she","that","liveth","dishonestly","father","heaviness"]},{"verseId":"brenton_sirach_22_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":5,"text":"She that is bold dishonoureth both her father and her husband, and they both shall despise her.","searchKeywords":["she","that","bold","dishonoureth","both","her","father","and","husband","they","shall","despise"]},{"verseId":"brenton_sirach_22_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":6,"text":"A tale out of season [is as] music in mourning: but stripes and correction of wisdom are never out of time.","searchKeywords":["tale","out","season","music","mourning","but","stripes","and","correction","wisdom","are","never","time"]},{"verseId":"brenton_sirach_22_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":9,"text":"Whoso teacheth a fool is as one that glueth a potsherd together, and as he that waketh one from a sound sleep.","searchKeywords":["whoso","teacheth","fool","one","that","glueth","potsherd","together","and","waketh","from","sound","sleep"]},{"verseId":"brenton_sirach_22_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":10,"text":"He that telleth a tale to a fool speaketh to one in a slumber: when he hath told his tale, he will say, What is the matter?","searchKeywords":["that","telleth","tale","fool","speaketh","one","slumber","when","hath","told","his","will","say","what","the","matter"]},{"verseId":"brenton_sirach_22_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":11,"text":"Weep for the dead, for he hath lost the light: and weep for the fool, for he wanteth understanding: make little weeping for the dead, for he is at rest: but the life of the fool is worse than death.","searchKeywords":["weep","for","the","dead","hath","lost","light","and","fool","wanteth","understanding","make","little","weeping","rest","but","life","worse","than","death"]},{"verseId":"brenton_sirach_22_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":12,"text":"Seven days do men mourn for him that is dead; but for a fool and an ungodly man all the days of his life.","searchKeywords":["seven","days","men","mourn","for","him","that","dead","but","fool","and","ungodly","man","all","the","his","life"]},{"verseId":"brenton_sirach_22_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":13,"text":"Talk not much with a fool, and go not to him that hath no understanding: beware of him, lest thou have trouble, and thou shalt never be defiled with his fooleries: depart from him, and thou shalt find rest, and never be disquieted with madness.","searchKeywords":["talk","not","much","with","fool","and","him","that","hath","understanding","beware","lest","thou","have","trouble","shalt","never","defiled","his","fooleries","depart","from","find","rest","disquieted","madness"]},{"verseId":"brenton_sirach_22_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":14,"text":"What is heavier than lead? and what is the name thereof, but a fool?","searchKeywords":["what","heavier","than","lead","and","the","name","thereof","but","fool"]},{"verseId":"brenton_sirach_22_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":15,"text":"Sand, and salt, and a mass of iron, are easier to bear, than a man without understanding.","searchKeywords":["sand","and","salt","mass","iron","are","easier","bear","than","man","without","understanding"]},{"verseId":"brenton_sirach_22_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":16,"text":"As timber girt and bound together in a building cannot be loosed with shaking: so the heart that is stablished by advised counsel shall fear at no time.","searchKeywords":["timber","girt","and","bound","together","building","cannot","loosed","with","shaking","the","heart","that","stablished","advised","counsel","shall","fear","time"]},{"verseId":"brenton_sirach_22_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":17,"text":"A heart settled upon a thought of understanding is as a fair plaistering on the wall of a gallery.","searchKeywords":["heart","settled","upon","thought","understanding","fair","plaistering","the","wall","gallery"]},{"verseId":"brenton_sirach_22_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":18,"text":"Pales set on an high place will never stand against the wind: so a fearful heart in the imagination of a fool cannot stand against any fear.","searchKeywords":["pales","set","high","place","will","never","stand","against","the","wind","fearful","heart","imagination","fool","cannot","any","fear"]},{"verseId":"brenton_sirach_22_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":19,"text":"He that pricketh the eye will make tears to fall: and he that pricketh the heart maketh it to shew her knowledge.","searchKeywords":["that","pricketh","the","eye","will","make","tears","fall","and","heart","maketh","shew","her","knowledge"]},{"verseId":"brenton_sirach_22_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":20,"text":"Whoso casteth a stone at the birds frayeth them away: and he that upbraideth his friend breaketh friendship.","searchKeywords":["whoso","casteth","stone","the","birds","frayeth","them","away","and","that","upbraideth","his","friend","breaketh","friendship"]},{"verseId":"brenton_sirach_22_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":21,"text":"Though thou drewest a sword at thy friend, yet despair not: for there may be a returning [to favour].","searchKeywords":["though","thou","drewest","sword","thy","friend","yet","despair","not","for","there","may","returning","favour"]},{"verseId":"brenton_sirach_22_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":22,"text":"If thou hast opened thy mouth against thy friend, fear not; for there may be a reconciliation: except for upbraiding, or pride, or disclosing of secrets, or a treacherous wound: for for these things every friend will depart.","searchKeywords":["thou","hast","opened","thy","mouth","against","friend","fear","not","for","there","may","reconciliation","except","upbraiding","pride","disclosing","secrets","treacherous","wound","these","things","every","will","depart"]},{"verseId":"brenton_sirach_22_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":23,"text":"Be faithful to thy neighbour in his poverty, that thou mayest rejoice in his prosperity: abide steadfast unto him in the time of his trouble, that thou mayest be heir with him in his heritage.","searchKeywords":["faithful","thy","neighbour","his","poverty","that","thou","mayest","rejoice","prosperity","abide","steadfast","unto","him","the","time","trouble","heir","with","heritage"]},{"verseId":"brenton_sirach_22_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":24,"text":"As the vapour and smoke of a furnace goeth before the fire; so reviling before blood.","searchKeywords":["the","vapour","and","smoke","furnace","goeth","before","fire","reviling","blood"]},{"verseId":"brenton_sirach_22_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":25,"text":"I will not be ashamed to defend a friend; neither will I hide myself from him;","searchKeywords":["will","not","ashamed","defend","friend","neither","hide","myself","from","him"]},{"verseId":"brenton_sirach_22_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":26,"text":"and if any evil happen unto me by him, every one that heareth it will beware of him.","searchKeywords":["and","any","evil","happen","unto","him","every","one","that","heareth","will","beware"]},{"verseId":"brenton_sirach_22_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":22,"verse":27,"text":"Who shall set a watch before my mouth, and a seal of wisdom upon my lips, that I fall not suddenly by them, and that my tongue destroy me not?","searchKeywords":["who","shall","set","watch","before","mouth","and","seal","wisdom","upon","lips","that","fall","not","suddenly","them","tongue","destroy"]}]