[{"verseId":"brenton_sirach_21_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":1,"text":"My son, hast thou sinned? do so no more, but ask pardon for thy former sins.","searchKeywords":["son","hast","thou","sinned","more","but","ask","pardon","for","thy","former","sins"]},{"verseId":"brenton_sirach_21_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":2,"text":"Flee from sin as from the face of a serpent: for if thou comest too near it, it will bite thee: the teeth thereof are as the teeth of a lion, slaying the souls of men.","searchKeywords":["flee","from","sin","the","face","serpent","for","thou","comest","too","near","will","bite","thee","teeth","thereof","are","lion","slaying","souls","men"]},{"verseId":"brenton_sirach_21_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":3,"text":"All iniquity is as a two edged sword, the wounds whereof cannot be healed.","searchKeywords":["all","iniquity","two","edged","sword","the","wounds","whereof","cannot","healed"]},{"verseId":"brenton_sirach_21_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":4,"text":"To terrify and do wrong will waste riches: thus the house of proud men shall be made desolate.","searchKeywords":["terrify","and","wrong","will","waste","riches","thus","the","house","proud","men","shall","made","desolate"]},{"verseId":"brenton_sirach_21_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":5,"text":"A prayer out of a poor man's mouth reacheth to the ears of God, and his judgment cometh speedily.","searchKeywords":["prayer","out","poor","man","mouth","reacheth","the","ears","god","and","his","judgment","cometh","speedily"]},{"verseId":"brenton_sirach_21_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":6,"text":"He that hateth reproof is in the way of sinners: but he that feareth the Lord will repent from his heart.","searchKeywords":["that","hateth","reproof","the","way","sinners","but","feareth","lord","will","repent","from","his","heart"]},{"verseId":"brenton_sirach_21_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":7,"text":"An eloquent man is known far ; but a man of understanding knoweth when he slippeth.","searchKeywords":["eloquent","man","known","far","but","understanding","knoweth","when","slippeth"]},{"verseId":"brenton_sirach_21_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":8,"text":"He that buildeth his house with other men's money is like one that gathereth himself stones for the tomb of his burial.","searchKeywords":["that","buildeth","his","house","with","other","men","money","like","one","gathereth","himself","stones","for","the","tomb","burial"]},{"verseId":"brenton_sirach_21_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":9,"text":"The congregation of the wicked is like tow wrapped together: and the end of them is a flame of fire to destroy them.","searchKeywords":["the","congregation","wicked","like","tow","wrapped","together","and","end","them","flame","fire","destroy"]},{"verseId":"brenton_sirach_21_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":10,"text":"The way of sinners is made plain with stones, but at the end thereof is the pit of hell.","searchKeywords":["the","way","sinners","made","plain","with","stones","but","end","thereof","pit","hell"]},{"verseId":"brenton_sirach_21_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":11,"text":"He that keepeth the law of the Lord getteth the understanding thereof: and the perfection of the fear of the Lord is wisdom.","searchKeywords":["that","keepeth","the","law","lord","getteth","understanding","thereof","and","perfection","fear","wisdom"]},{"verseId":"brenton_sirach_21_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":12,"text":"He that is not wise will not be taught: but there is a wisdom which multiplieth bitterness.","searchKeywords":["that","not","wise","will","taught","but","there","wisdom","which","multiplieth","bitterness"]},{"verseId":"brenton_sirach_21_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":13,"text":"The knowledge of a wise man shall abound like a flood: and his counsel is like a pure fountain of life.","searchKeywords":["the","knowledge","wise","man","shall","abound","like","flood","and","his","counsel","pure","fountain","life"]},{"verseId":"brenton_sirach_21_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":14,"text":"The inner parts of a fool are like a broken vessel, and he will hold no knowledge as long as he liveth.","searchKeywords":["the","inner","parts","fool","are","like","broken","vessel","and","will","hold","knowledge","long","liveth"]},{"verseId":"brenton_sirach_21_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":15,"text":"If a skilful man hear a wise word, he will commend it, and add unto it: but when one of no understanding heareth it, it displeaseth him, and he casteth it behind his back.","searchKeywords":["skilful","man","hear","wise","word","will","commend","and","add","unto","but","when","one","understanding","heareth","displeaseth","him","casteth","behind","his","back"]},{"verseId":"brenton_sirach_21_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":16,"text":"The talking of a fool is like a burden in the way: but grace shall be found in the lips of the wise.","searchKeywords":["the","talking","fool","like","burden","way","but","grace","shall","found","lips","wise"]},{"verseId":"brenton_sirach_21_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":17,"text":"They enquire at the mouth of the wise man in the congregation, and they shall ponder his words in their heart.","searchKeywords":["they","enquire","the","mouth","wise","man","congregation","and","shall","ponder","his","words","their","heart"]},{"verseId":"brenton_sirach_21_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":18,"text":"As a house that is destroyed, so is wisdom to a fool: and the knowledge of the unwise is as talk without sense.","searchKeywords":["house","that","destroyed","wisdom","fool","and","the","knowledge","unwise","talk","without","sense"]},{"verseId":"brenton_sirach_21_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":19,"text":"Doctrine unto fools is as fetters on the feet, and like manacles on the right hand.","searchKeywords":["doctrine","unto","fools","fetters","the","feet","and","like","manacles","right","hand"]},{"verseId":"brenton_sirach_21_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":20,"text":"A fool lifteth up his voice with laughter; but a wise man doth scarce smile a little.","searchKeywords":["fool","lifteth","his","voice","with","laughter","but","wise","man","doth","scarce","smile","little"]},{"verseId":"brenton_sirach_21_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":21,"text":"Learning is unto a wise man as an ornament of gold, and like a bracelet upon his right arm.","searchKeywords":["learning","unto","wise","man","ornament","gold","and","like","bracelet","upon","his","right","arm"]},{"verseId":"brenton_sirach_21_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":22,"text":"A foolish man's foot is soon in [his neighbour's] house: but a man of experience is ashamed of him.","searchKeywords":["foolish","man","foot","soon","his","neighbour","house","but","experience","ashamed","him"]},{"verseId":"brenton_sirach_21_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":23,"text":"A fool will peep in at the door into the house: but he that is well nurtured will stand without.","searchKeywords":["fool","will","peep","the","door","into","house","but","that","well","nurtured","stand","without"]},{"verseId":"brenton_sirach_21_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":24,"text":"It is the rudeness of a man to hearken at the door: but a wise man will be grieved with the disgrace.","searchKeywords":["the","rudeness","man","hearken","door","but","wise","will","grieved","with","disgrace"]},{"verseId":"brenton_sirach_21_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":25,"text":"The lips of talkers will be telling such things as pertain not unto them: but the words of such as have understanding are weighed in the balance.","searchKeywords":["the","lips","talkers","will","telling","such","things","pertain","not","unto","them","but","words","have","understanding","are","weighed","balance"]},{"verseId":"brenton_sirach_21_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":26,"text":"The heart of fools is in their mouth: but the mouth of the wise is in their heart.","searchKeywords":["the","heart","fools","their","mouth","but","wise"]},{"verseId":"brenton_sirach_21_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":27,"text":"When the ungodly curseth Satan, he curseth his own soul.","searchKeywords":["when","the","ungodly","curseth","satan","his","own","soul"]},{"verseId":"brenton_sirach_21_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":21,"verse":28,"text":"A whisperer defileth his own soul, and is hated wheresoever he dwelleth.","searchKeywords":["whisperer","defileth","his","own","soul","and","hated","wheresoever","dwelleth"]}]