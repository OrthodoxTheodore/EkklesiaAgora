[{"verseId":"brenton_sirach_13_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":1,"text":"He that toucheth pitch shall be defiled therewith; and he that hath fellowship with a proud man shall be like unto him.","searchKeywords":["that","toucheth","pitch","shall","defiled","therewith","and","hath","fellowship","with","proud","man","like","unto","him"]},{"verseId":"brenton_sirach_13_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":2,"text":"Burden not thyself above thy power while thou livest; and have no fellowship with one that is mightier and richer than thyself: for how agree the kettle and the earthen pot together? for if the one be smitten against the other, it shall be broken.","searchKeywords":["burden","not","thyself","above","thy","power","while","thou","livest","and","have","fellowship","with","one","that","mightier","richer","than","for","how","agree","the","kettle","earthen","pot","together","smitten","against","other","shall","broken"]},{"verseId":"brenton_sirach_13_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":3,"text":"The rich man hath done wrong, and yet he threateneth withal: the poor is wronged, and he must intreat also.","searchKeywords":["the","rich","man","hath","done","wrong","and","yet","threateneth","withal","poor","wronged","must","intreat","also"]},{"verseId":"brenton_sirach_13_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":4,"text":"If thou be for his profit, he will use thee; but if thou have nothing, he will forsake thee.","searchKeywords":["thou","for","his","profit","will","use","thee","but","have","nothing","forsake"]},{"verseId":"brenton_sirach_13_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":5,"text":"If thou have any thing, he will live with thee: yea, he will make thee bare, and will not be sorry for it.","searchKeywords":["thou","have","any","thing","will","live","with","thee","yea","make","bare","and","not","sorry","for"]},{"verseId":"brenton_sirach_13_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":6,"text":"If he have need of thee, he will deceive thee, and smile upon thee, and put thee in hope; he will speak thee fair, and say, What wantest thou?","searchKeywords":["have","need","thee","will","deceive","and","smile","upon","put","hope","speak","fair","say","what","wantest","thou"]},{"verseId":"brenton_sirach_13_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":7,"text":"And he will shame thee by his meats, until he have drawn thee dry twice or thrice, and at the last he will laugh thee to scorn: afterward, when he seeth thee, he will forsake thee, and shake his head at thee.","searchKeywords":["and","will","shame","thee","his","meats","until","have","drawn","dry","twice","thrice","the","last","laugh","scorn","afterward","when","seeth","forsake","shake","head"]},{"verseId":"brenton_sirach_13_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":8,"text":"Beware that thou be not deceived, and brought down in thy jollity.","searchKeywords":["beware","that","thou","not","deceived","and","brought","down","thy","jollity"]},{"verseId":"brenton_sirach_13_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":9,"text":"If thou be invited of a mighty man, withdraw thyself, and so much the more will he invite thee.","searchKeywords":["thou","invited","mighty","man","withdraw","thyself","and","much","the","more","will","invite","thee"]},{"verseId":"brenton_sirach_13_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":10,"text":"Press thou not upon him, lest thou be put back; stand not far off, lest thou be forgotten.","searchKeywords":["press","thou","not","upon","him","lest","put","back","stand","far","off","forgotten"]},{"verseId":"brenton_sirach_13_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":11,"text":"Affect not to be made equal unto him in talk, and believe not his many words: for with much communication will he tempt thee, and smiling upon thee will get out thy secrets:","searchKeywords":["affect","not","made","equal","unto","him","talk","and","believe","his","many","words","for","with","much","communication","will","tempt","thee","smiling","upon","get","out","thy","secrets"]},{"verseId":"brenton_sirach_13_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":12,"text":"but cruelly he will lay up thy words, and will not spare to do thee hurt, and to put thee in prison.","searchKeywords":["but","cruelly","will","lay","thy","words","and","not","spare","thee","hurt","put","prison"]},{"verseId":"brenton_sirach_13_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":13,"text":"Observe, and take good heed, for thou walkest in peril of thy overthrowing: when thou hearest these things, awake in thy sleep.","searchKeywords":["observe","and","take","good","heed","for","thou","walkest","peril","thy","overthrowing","when","hearest","these","things","awake","sleep"]},{"verseId":"brenton_sirach_13_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":15,"text":"Every beast loveth his like, and every man loveth his neighbour.","searchKeywords":["every","beast","loveth","his","like","and","man","neighbour"]},{"verseId":"brenton_sirach_13_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":16,"text":"All flesh consorteth according to kind, and a man will cleave to his like.","searchKeywords":["all","flesh","consorteth","according","kind","and","man","will","cleave","his","like"]},{"verseId":"brenton_sirach_13_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":17,"text":"What fellowship hath the wolf with the lamb? so the sinner with the godly.","searchKeywords":["what","fellowship","hath","the","wolf","with","lamb","sinner","godly"]},{"verseId":"brenton_sirach_13_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":18,"text":"What agreement is there between the hyena and a dog? and what peace between the rich and the poor?","searchKeywords":["what","agreement","there","between","the","hyena","and","dog","peace","rich","poor"]},{"verseId":"brenton_sirach_13_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":19,"text":"As the wild ass is the lion's prey in the wilderness: so the rich eat up the poor.","searchKeywords":["the","wild","ass","lion","prey","wilderness","rich","eat","poor"]},{"verseId":"brenton_sirach_13_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":20,"text":"As the proud hate humility: so doth the rich abhor the poor.","searchKeywords":["the","proud","hate","humility","doth","rich","abhor","poor"]},{"verseId":"brenton_sirach_13_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":21,"text":"A rich man beginning to fall is held up of his friends: but a poor man being down is thrust also away by his friends.","searchKeywords":["rich","man","beginning","fall","held","his","friends","but","poor","being","down","thrust","also","away"]},{"verseId":"brenton_sirach_13_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":22,"text":"When a rich man is fallen, he hath many helpers: he speaketh things not to be spoken, and yet men justify him: the poor man slipped, and yet they rebuked him too; he spake wisely, and could have no place.","searchKeywords":["when","rich","man","fallen","hath","many","helpers","speaketh","things","not","spoken","and","yet","men","justify","him","the","poor","slipped","they","rebuked","too","spake","wisely","could","have","place"]},{"verseId":"brenton_sirach_13_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":23,"text":"When a rich man speaketh, every man holdeth his tongue, and, look, what he saith, they extol it to the clouds: but if the poor man speak, they say, What fellow is this? and if he stumble, they will help to overthrow him.","searchKeywords":["when","rich","man","speaketh","every","holdeth","his","tongue","and","look","what","saith","they","extol","the","clouds","but","poor","speak","say","fellow","this","stumble","will","help","overthrow","him"]},{"verseId":"brenton_sirach_13_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":24,"text":"Riches are good unto him that hath no sin, and poverty is evil in the mouth of the ungodly.","searchKeywords":["riches","are","good","unto","him","that","hath","sin","and","poverty","evil","the","mouth","ungodly"]},{"verseId":"brenton_sirach_13_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":25,"text":"The heart of a man changeth his countenance, whether it be for good or evil.","searchKeywords":["the","heart","man","changeth","his","countenance","whether","for","good","evil"]},{"verseId":"brenton_sirach_13_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":13,"verse":26,"text":"A cheerful countenance is a token of a heart that is in prosperity; and the finding out of parables is a wearisome labour of the mind.","searchKeywords":["cheerful","countenance","token","heart","that","prosperity","and","the","finding","out","parables","wearisome","labour","mind"]}]