[{"verseId":"brenton_sirach_42_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":1,"text":"Of these things be not thou ashamed, and accept no person to sin thereby:","searchKeywords":["these","things","not","thou","ashamed","and","accept","person","sin","thereby"]},{"verseId":"brenton_sirach_42_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":2,"text":"of the law of the most High, and his covenant; and of judgment to justify the ungodly;","searchKeywords":["the","law","most","high","and","his","covenant","judgment","justify","ungodly"]},{"verseId":"brenton_sirach_42_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":3,"text":"of reckoning with thy partners and travellers; or of the gift of the heritage of friends;","searchKeywords":["reckoning","with","thy","partners","and","travellers","the","gift","heritage","friends"]},{"verseId":"brenton_sirach_42_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":4,"text":"of exactness of balance and weights; or of getting much or little;","searchKeywords":["exactness","balance","and","weights","getting","much","little"]},{"verseId":"brenton_sirach_42_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":5,"text":"and of merchants' indifferent selling; of much correction of children; and to make the side of an evil servant to bleed.","searchKeywords":["and","merchants","indifferent","selling","much","correction","children","make","the","side","evil","servant","bleed"]},{"verseId":"brenton_sirach_42_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":6,"text":"Sure keeping is good, where an evil wife is; and locked up, where many hands are.","searchKeywords":["sure","keeping","good","where","evil","wife","and","locked","many","hands","are"]},{"verseId":"brenton_sirach_42_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":7,"text":"Deliver all things in number and weight; and put all in writing that thou givest out, or receivest in.","searchKeywords":["deliver","all","things","number","and","weight","put","writing","that","thou","givest","out","receivest"]},{"verseId":"brenton_sirach_42_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":8,"text":"Be not ashamed to inform the unwise and foolish, and the extreme aged that contendeth with those that are young: thus shalt thou be truly learned, and approved of all men living.","searchKeywords":["not","ashamed","inform","the","unwise","and","foolish","extreme","aged","that","contendeth","with","those","are","young","thus","shalt","thou","truly","learned","approved","all","men","living"]},{"verseId":"brenton_sirach_42_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":9,"text":"A daughter is a wakeful care to a father; and the care for her taketh away sleep: when she is young, lest she pass away the flower of her age; and being married, lest she should be hated:","searchKeywords":["daughter","wakeful","care","father","and","the","for","her","taketh","away","sleep","when","she","young","lest","pass","flower","age","being","married","should","hated"]},{"verseId":"brenton_sirach_42_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":10,"text":"in her virginity, lest she should be defiled and gotten with child in her father's house; and having an husband, lest she should misbehave herself; and when she is married, lest she should be barren.","searchKeywords":["her","virginity","lest","she","should","defiled","and","gotten","with","child","father","house","having","husband","misbehave","herself","when","married","barren"]},{"verseId":"brenton_sirach_42_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":11,"text":"Keep a sure watch over a shameless daughter, lest she make thee a laughingstock to thine enemies, and a byword in the city, and a reproach among the people, and make thee ashamed before the multitude.","searchKeywords":["keep","sure","watch","over","shameless","daughter","lest","she","make","thee","laughingstock","thine","enemies","and","byword","the","city","reproach","among","people","ashamed","before","multitude"]},{"verseId":"brenton_sirach_42_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":12,"text":"Behold not everybody's beauty, and sit not in the midst of women.","searchKeywords":["behold","not","everybody","beauty","and","sit","the","midst","women"]},{"verseId":"brenton_sirach_42_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":13,"text":"For from garments cometh a moth, and from women wickedness.","searchKeywords":["for","from","garments","cometh","moth","and","women","wickedness"]},{"verseId":"brenton_sirach_42_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":14,"text":"Better is the churlishness of a man than a courteous woman, a woman, , which bringeth shame and reproach.","searchKeywords":["better","the","churlishness","man","than","courteous","woman","which","bringeth","shame","and","reproach"]},{"verseId":"brenton_sirach_42_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":15,"text":"I will now remember the works of the Lord, and declare the things that I have seen: In the words of the Lord are his works.","searchKeywords":["will","now","remember","the","works","lord","and","declare","things","that","have","seen","words","are","his"]},{"verseId":"brenton_sirach_42_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":16,"text":"The sun that giveth light looketh upon all things, and the work thereof full of the glory of the Lord.","searchKeywords":["the","sun","that","giveth","light","looketh","upon","all","things","and","work","thereof","full","glory","lord"]},{"verseId":"brenton_sirach_42_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":17,"text":"The Lord hath not given power to the saints to declare all his marvellous works, which the Almighty Lord firmly settled, that whatsoever is might be established for his glory.","searchKeywords":["the","lord","hath","not","given","power","saints","declare","all","his","marvellous","works","which","almighty","firmly","settled","that","whatsoever","might","established","for","glory"]},{"verseId":"brenton_sirach_42_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":18,"text":"He seeketh out the deep, and the heart, and considereth their crafty devices: for the Lord knoweth all that can be known, and he beholdeth the signs of the world,","searchKeywords":["seeketh","out","the","deep","and","heart","considereth","their","crafty","devices","for","lord","knoweth","all","that","can","known","beholdeth","signs","world"]},{"verseId":"brenton_sirach_42_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":19,"text":"declaring the things that are past, and for to come, and revealing the steps of hidden things.","searchKeywords":["declaring","the","things","that","are","past","and","for","come","revealing","steps","hidden"]},{"verseId":"brenton_sirach_42_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":20,"text":"No thought escapeth him, neither any word is hidden from him.","searchKeywords":["thought","escapeth","him","neither","any","word","hidden","from"]},{"verseId":"brenton_sirach_42_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":21,"text":"He hath garnished the excellent works of his wisdom, and he is from everlasting to everlasting: unto him may nothing be added, neither can he be diminished, and he hath no need of any counsellor.","searchKeywords":["hath","garnished","the","excellent","works","his","wisdom","and","from","everlasting","unto","him","may","nothing","added","neither","can","diminished","need","any","counsellor"]},{"verseId":"brenton_sirach_42_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":22,"text":"Oh how desirable are all his works! and that a man may see even to a spark.","searchKeywords":["how","desirable","are","all","his","works","and","that","man","may","see","even","spark"]},{"verseId":"brenton_sirach_42_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":23,"text":"All these things live and remain for ever for all uses, and they are all obedient.","searchKeywords":["all","these","things","live","and","remain","for","ever","uses","they","are","obedient"]},{"verseId":"brenton_sirach_42_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":24,"text":"All things are double one against another: and he hath made nothing imperfect.","searchKeywords":["all","things","are","double","one","against","another","and","hath","made","nothing","imperfect"]},{"verseId":"brenton_sirach_42_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":42,"verse":25,"text":"One thing establisheth the good of another: and who shall be filled with beholding his glory?","searchKeywords":["one","thing","establisheth","the","good","another","and","who","shall","filled","with","beholding","his","glory"]}]