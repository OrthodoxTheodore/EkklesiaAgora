[{"verseId":"brenton_sirach_14_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":1,"text":"Blessed is the man that hath not slipped with his mouth, and is not pricked with the multitude of sins.","searchKeywords":["blessed","the","man","that","hath","not","slipped","with","his","mouth","and","pricked","multitude","sins"]},{"verseId":"brenton_sirach_14_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":2,"text":"Blessed is he whose conscience hath not condemned him, and who is not fallen from his hope .","searchKeywords":["blessed","whose","conscience","hath","not","condemned","him","and","who","fallen","from","his","hope"]},{"verseId":"brenton_sirach_14_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":3,"text":"Riches are not comely for a niggard: and what should an envious man do with money?","searchKeywords":["riches","are","not","comely","for","niggard","and","what","should","envious","man","with","money"]},{"verseId":"brenton_sirach_14_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":4,"text":"He that gathereth by defrauding his own soul gathereth for others that shall spend his goods riotously.","searchKeywords":["that","gathereth","defrauding","his","own","soul","for","others","shall","spend","goods","riotously"]},{"verseId":"brenton_sirach_14_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":5,"text":"He that is evil to himself, to whom will he be good? he shall not take pleasure in his goods.","searchKeywords":["that","evil","himself","whom","will","good","shall","not","take","pleasure","his","goods"]},{"verseId":"brenton_sirach_14_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":6,"text":"There is none worse than he that envieth himself; and this is a recompence of his wickedness.","searchKeywords":["there","none","worse","than","that","envieth","himself","and","this","recompence","his","wickedness"]},{"verseId":"brenton_sirach_14_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":7,"text":"And if he doeth good, he doeth it unwillingly; and at the last he will declare his wickedness.","searchKeywords":["and","doeth","good","unwillingly","the","last","will","declare","his","wickedness"]},{"verseId":"brenton_sirach_14_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":8,"text":"The envious man hath a wicked eye; he turneth away his face, and despiseth men.","searchKeywords":["the","envious","man","hath","wicked","eye","turneth","away","his","face","and","despiseth","men"]},{"verseId":"brenton_sirach_14_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":9,"text":"A covetous man's eye is not satisfied with his portion; and the iniquity of the wicked drieth up his soul.","searchKeywords":["covetous","man","eye","not","satisfied","with","his","portion","and","the","iniquity","wicked","drieth","soul"]},{"verseId":"brenton_sirach_14_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":10,"text":"A wicked eye envieth [his] bread, and he is a niggard at his table.","searchKeywords":["wicked","eye","envieth","his","bread","and","niggard","table"]},{"verseId":"brenton_sirach_14_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":11,"text":"My son, according to thy ability do good to thyself, and give the Lord his due offering.","searchKeywords":["son","according","thy","ability","good","thyself","and","give","the","lord","his","due","offering"]},{"verseId":"brenton_sirach_14_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":12,"text":"Remember that death will not be long in coming, and that the covenant of the grave is not shewed unto thee.","searchKeywords":["remember","that","death","will","not","long","coming","and","the","covenant","grave","shewed","unto","thee"]},{"verseId":"brenton_sirach_14_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":13,"text":"Do good unto thy friend before thou die, and according to thy ability stretch out thy hand and give to him.","searchKeywords":["good","unto","thy","friend","before","thou","die","and","according","ability","stretch","out","hand","give","him"]},{"verseId":"brenton_sirach_14_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":14,"text":"Defraud not thyself of the good day, and let not the part of a good desire overpass thee.","searchKeywords":["defraud","not","thyself","the","good","day","and","let","part","desire","overpass","thee"]},{"verseId":"brenton_sirach_14_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":15,"text":"Shalt thou not leave thy travails unto another? and thy labours to be divided by lot?","searchKeywords":["shalt","thou","not","leave","thy","travails","unto","another","and","labours","divided","lot"]},{"verseId":"brenton_sirach_14_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":16,"text":"Give, and take, and sanctify thy soul; for there is no seeking of dainties in the grave.","searchKeywords":["give","and","take","sanctify","thy","soul","for","there","seeking","dainties","the","grave"]},{"verseId":"brenton_sirach_14_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":17,"text":"All flesh waxeth old as a garment: for the covenant from the beginning is, Thou shalt die the death.","searchKeywords":["all","flesh","waxeth","old","garment","for","the","covenant","from","beginning","thou","shalt","die","death"]},{"verseId":"brenton_sirach_14_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":18,"text":"As of the green leaves on a thick tree, some fall, and some grow: so is the generation of flesh and blood, one cometh to an end, and another is born.","searchKeywords":["the","green","leaves","thick","tree","some","fall","and","grow","generation","flesh","blood","one","cometh","end","another","born"]},{"verseId":"brenton_sirach_14_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":19,"text":"Every work rotteth and consumeth away, and the worker thereof shall go withal.","searchKeywords":["every","work","rotteth","and","consumeth","away","the","worker","thereof","shall","withal"]},{"verseId":"brenton_sirach_14_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":20,"text":"Blessed is the man that doth meditate good things in wisdom, and that reasoneth of holy things by his understanding.","searchKeywords":["blessed","the","man","that","doth","meditate","good","things","wisdom","and","reasoneth","holy","his","understanding"]},{"verseId":"brenton_sirach_14_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":21,"text":"He that considereth her ways in his heart shall also have understanding in her secrets.","searchKeywords":["that","considereth","her","ways","his","heart","shall","also","have","understanding","secrets"]},{"verseId":"brenton_sirach_14_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":22,"text":"Go after her as one that traceth, and lie in wait in her ways.","searchKeywords":["after","her","one","that","traceth","and","lie","wait","ways"]},{"verseId":"brenton_sirach_14_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":23,"text":"He that prieth in at her windows shall also hearken at her doors.","searchKeywords":["that","prieth","her","windows","shall","also","hearken","doors"]},{"verseId":"brenton_sirach_14_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":24,"text":"He that doth lodge near her house shall also fasten a pin in her walls.","searchKeywords":["that","doth","lodge","near","her","house","shall","also","fasten","pin","walls"]},{"verseId":"brenton_sirach_14_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":25,"text":"He shall pitch his tent nigh unto her, and shall lodge in a lodging where good things are.","searchKeywords":["shall","pitch","his","tent","nigh","unto","her","and","lodge","lodging","where","good","things","are"]},{"verseId":"brenton_sirach_14_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":26,"text":"He shall set his children under her shelter, and shall lodge under her branches.","searchKeywords":["shall","set","his","children","under","her","shelter","and","lodge","branches"]},{"verseId":"brenton_sirach_14_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":14,"verse":27,"text":"By her he shall be covered from heat, and in her glory shall he dwell.","searchKeywords":["her","shall","covered","from","heat","and","glory","dwell"]}]