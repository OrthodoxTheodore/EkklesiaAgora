[{"verseId":"brenton_sirach_3_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":1,"text":"Hear me your father, O children, and do thereafter, that ye may be safe.","searchKeywords":["hear","your","father","children","and","thereafter","that","may","safe"]},{"verseId":"brenton_sirach_3_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":2,"text":"For the Lord hath given the father honour over the children, and hath confirmed the authority of the mother over the sons.","searchKeywords":["for","the","lord","hath","given","father","honour","over","children","and","confirmed","authority","mother","sons"]},{"verseId":"brenton_sirach_3_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":3,"text":"Whoso honoureth his father maketh an atonement for his sins:","searchKeywords":["whoso","honoureth","his","father","maketh","atonement","for","sins"]},{"verseId":"brenton_sirach_3_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":4,"text":"and he that honoureth his mother is as one that layeth up treasure.","searchKeywords":["and","that","honoureth","his","mother","one","layeth","treasure"]},{"verseId":"brenton_sirach_3_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":5,"text":"Whoso honoureth his father shall have joy of children; and when he maketh his prayer, he shall be heard.","searchKeywords":["whoso","honoureth","his","father","shall","have","joy","children","and","when","maketh","prayer","heard"]},{"verseId":"brenton_sirach_3_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":6,"text":"He that honoureth his father shall have a long life; and he that is obedient unto the Lord shall be a comfort to his mother,","searchKeywords":["that","honoureth","his","father","shall","have","long","life","and","obedient","unto","the","lord","comfort","mother"]},{"verseId":"brenton_sirach_3_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":7,"text":"and will do service unto his parents, as to his masters.","searchKeywords":["and","will","service","unto","his","parents","masters"]},{"verseId":"brenton_sirach_3_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":8,"text":"Honour thy father and mother both in word and deed, that a blessing may come upon thee from them.","searchKeywords":["honour","thy","father","and","mother","both","word","deed","that","blessing","may","come","upon","thee","from","them"]},{"verseId":"brenton_sirach_3_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":9,"text":"For the blessing of the father establisheth the houses of children; but the curse of the mother rooteth out foundations.","searchKeywords":["for","the","blessing","father","establisheth","houses","children","but","curse","mother","rooteth","out","foundations"]},{"verseId":"brenton_sirach_3_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":10,"text":"Glory not in the dishonour of thy father; for thy father's dishonour is no glory unto thee.","searchKeywords":["glory","not","the","dishonour","thy","father","for","unto","thee"]},{"verseId":"brenton_sirach_3_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":11,"text":"For the glory of a man is from the honour of his father; and a mother in dishonour is a reproach to the children.","searchKeywords":["for","the","glory","man","from","honour","his","father","and","mother","dishonour","reproach","children"]},{"verseId":"brenton_sirach_3_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":12,"text":"My son, help thy father in his age, and grieve him not as long as he liveth.","searchKeywords":["son","help","thy","father","his","age","and","grieve","him","not","long","liveth"]},{"verseId":"brenton_sirach_3_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":13,"text":"And if his understanding fail, have patience with him; and despise him not when thou art in thy full strength.","searchKeywords":["and","his","understanding","fail","have","patience","with","him","despise","not","when","thou","art","thy","full","strength"]},{"verseId":"brenton_sirach_3_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":14,"text":"For the relieving of thy father shall not be forgotten: and instead of sins it shall be added to build thee up.","searchKeywords":["for","the","relieving","thy","father","shall","not","forgotten","and","instead","sins","added","build","thee"]},{"verseId":"brenton_sirach_3_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":15,"text":"In the day of thine affliction it shall be remembered; thy sins also shall melt away, as the ice in the fair warm weather.","searchKeywords":["the","day","thine","affliction","shall","remembered","thy","sins","also","melt","away","ice","fair","warm","weather"]},{"verseId":"brenton_sirach_3_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":16,"text":"He that forsaketh his father is as a blasphemer; and he that angereth his mother is cursed of God.","searchKeywords":["that","forsaketh","his","father","blasphemer","and","angereth","mother","cursed","god"]},{"verseId":"brenton_sirach_3_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":17,"text":"My son, go on with thy business in meekness; so shalt thou be beloved of him that is approved.","searchKeywords":["son","with","thy","business","meekness","shalt","thou","beloved","him","that","approved"]},{"verseId":"brenton_sirach_3_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":18,"text":"The greater thou art, the more humble thyself, and thou shalt find favour before the Lord.","searchKeywords":["the","greater","thou","art","more","humble","thyself","and","shalt","find","favour","before","lord"]},{"verseId":"brenton_sirach_3_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":20,"text":"For the power of the Lord is great, and he is honoured of the lowly.","searchKeywords":["for","the","power","lord","great","and","honoured","lowly"]},{"verseId":"brenton_sirach_3_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":21,"text":"Seek not out the things that are too hard for thee, neither search the things that are above thy strength.","searchKeywords":["seek","not","out","the","things","that","are","too","hard","for","thee","neither","search","above","thy","strength"]},{"verseId":"brenton_sirach_3_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":22,"text":"But what is commanded thee, think thereupon ; for it is not needful for thee the things that are in secret.","searchKeywords":["but","what","commanded","thee","think","thereupon","for","not","needful","the","things","that","are","secret"]},{"verseId":"brenton_sirach_3_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":23,"text":"Be not curious in unnecessary matters; for more things are shewed unto thee than men understand.","searchKeywords":["not","curious","unnecessary","matters","for","more","things","are","shewed","unto","thee","than","men","understand"]},{"verseId":"brenton_sirach_3_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":24,"text":"For many are deceived by their own vain opinion; and an evil suspicion hath overthrown their judgment.","searchKeywords":["for","many","are","deceived","their","own","vain","opinion","and","evil","suspicion","hath","overthrown","judgment"]},{"verseId":"brenton_sirach_3_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":26,"text":"A stubborn heart shall fare evil at the last; and he that loveth danger shall perish therein.","searchKeywords":["stubborn","heart","shall","fare","evil","the","last","and","that","loveth","danger","perish","therein"]},{"verseId":"brenton_sirach_3_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":27,"text":"An obstinate heart shall be laden with sorrows; and the wicked man shall heap sin upon sin.","searchKeywords":["obstinate","heart","shall","laden","with","sorrows","and","the","wicked","man","heap","sin","upon"]},{"verseId":"brenton_sirach_3_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":28,"text":"In the punishment of the proud there is no remedy; for the plant of wickedness hath taken root in him.","searchKeywords":["the","punishment","proud","there","remedy","for","plant","wickedness","hath","taken","root","him"]},{"verseId":"brenton_sirach_3_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":29,"text":"The heart of the prudent will understand a parable; and an attentive ear is the desire of a wise man.","searchKeywords":["the","heart","prudent","will","understand","parable","and","attentive","ear","desire","wise","man"]},{"verseId":"brenton_sirach_3_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":30,"text":"Water will quench a flaming fire; and alms maketh an atonement for sins.","searchKeywords":["water","will","quench","flaming","fire","and","alms","maketh","atonement","for","sins"]},{"verseId":"brenton_sirach_3_31","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":3,"verse":31,"text":"And he that requiteth good turns is mindful of that which may come hereafter; and when he falleth, he shall find a stay.","searchKeywords":["and","that","requiteth","good","turns","mindful","which","may","come","hereafter","when","falleth","shall","find","stay"]}]