[{"verseId":"brenton_sirach_11_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":1,"text":"Wisdom lifteth up the head of him that is of low degree, and maketh him to sit among great men.","searchKeywords":["wisdom","lifteth","the","head","him","that","low","degree","and","maketh","sit","among","great","men"]},{"verseId":"brenton_sirach_11_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":2,"text":"Commend not a man for his beauty; neither abhor a man for his outward appearance.","searchKeywords":["commend","not","man","for","his","beauty","neither","abhor","outward","appearance"]},{"verseId":"brenton_sirach_11_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":3,"text":"The bee is little among such as fly; but her fruit is the chief of sweet things.","searchKeywords":["the","bee","little","among","such","fly","but","her","fruit","chief","sweet","things"]},{"verseId":"brenton_sirach_11_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":4,"text":"Boast not of thy clothing and raiment, and exalt not thyself in the day of honour: for the works of the Lord are wonderful, and his works among men are hidden.","searchKeywords":["boast","not","thy","clothing","and","raiment","exalt","thyself","the","day","honour","for","works","lord","are","wonderful","his","among","men","hidden"]},{"verseId":"brenton_sirach_11_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":5,"text":"Many kings have sat down upon the ground; and one that was never thought of hath worn the crown.","searchKeywords":["many","kings","have","sat","down","upon","the","ground","and","one","that","was","never","thought","hath","worn","crown"]},{"verseId":"brenton_sirach_11_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":6,"text":"Many mighty men have been greatly disgraced; and the honourable delivered into other men's hands.","searchKeywords":["many","mighty","men","have","been","greatly","disgraced","and","the","honourable","delivered","into","other","hands"]},{"verseId":"brenton_sirach_11_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":7,"text":"Blame not before thou hast examined the truth: understand first, and then rebuke.","searchKeywords":["blame","not","before","thou","hast","examined","the","truth","understand","first","and","then","rebuke"]},{"verseId":"brenton_sirach_11_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":8,"text":"Answer not before thou hast heard the cause: neither interrupt men in the midst of their talk.","searchKeywords":["answer","not","before","thou","hast","heard","the","cause","neither","interrupt","men","midst","their","talk"]},{"verseId":"brenton_sirach_11_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":9,"text":"Strive not in a matter that concerneth thee not; and sit not in judgment with sinners.","searchKeywords":["strive","not","matter","that","concerneth","thee","and","sit","judgment","with","sinners"]},{"verseId":"brenton_sirach_11_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":10,"text":"My son, meddle not with many matters: for if thou meddle much, thou shalt not be innocent; and if thou follow after, thou shalt not obtain, neither shalt thou escape by fleeing.","searchKeywords":["son","meddle","not","with","many","matters","for","thou","much","shalt","innocent","and","follow","after","obtain","neither","escape","fleeing"]},{"verseId":"brenton_sirach_11_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":11,"text":"There is one that laboureth, and taketh pains, and maketh haste, and is so much the more behind.","searchKeywords":["there","one","that","laboureth","and","taketh","pains","maketh","haste","much","the","more","behind"]},{"verseId":"brenton_sirach_11_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":12,"text":"Again, there is another that is slow, and hath need of help, wanting ability, and full of poverty; yet the eye of the Lord looked upon him for good, and set him up from his low estate,","searchKeywords":["again","there","another","that","slow","and","hath","need","help","wanting","ability","full","poverty","yet","the","eye","lord","looked","upon","him","for","good","set","from","his","low","estate"]},{"verseId":"brenton_sirach_11_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":13,"text":"and lifted up his head from misery; so that many that saw it marvelled at him.","searchKeywords":["and","lifted","his","head","from","misery","that","many","saw","marvelled","him"]},{"verseId":"brenton_sirach_11_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":14,"text":"Prosperity and adversity, life and death, poverty and riches, come of the Lord.","searchKeywords":["prosperity","and","adversity","life","death","poverty","riches","come","the","lord"]},{"verseId":"brenton_sirach_11_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":17,"text":"The gift of the Lord remaineth with the godly, and his favour bringeth prosperity for ever.","searchKeywords":["the","gift","lord","remaineth","with","godly","and","his","favour","bringeth","prosperity","for","ever"]},{"verseId":"brenton_sirach_11_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":18,"text":"There is that waxeth rich by his wariness and pinching, and this is the portion of his reward:","searchKeywords":["there","that","waxeth","rich","his","wariness","and","pinching","this","the","portion","reward"]},{"verseId":"brenton_sirach_11_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":19,"text":"whereas he saith, I have found rest, and now will eat continually of my goods; and he knoweth not what time shall come upon him, and that he must leave those things to others, and die.","searchKeywords":["whereas","saith","have","found","rest","and","now","will","eat","continually","goods","knoweth","not","what","time","shall","come","upon","him","that","must","leave","those","things","others","die"]},{"verseId":"brenton_sirach_11_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":20,"text":"Be stedfast in thy covenant, and be conversant therein, and wax old in thy work.","searchKeywords":["stedfast","thy","covenant","and","conversant","therein","wax","old","work"]},{"verseId":"brenton_sirach_11_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":21,"text":"Marvel not at the works of sinners; but trust in the Lord, and abide in thy labour: for it is an easy thing in the sight of the Lord on the sudden to make a poor man rich.","searchKeywords":["marvel","not","the","works","sinners","but","trust","lord","and","abide","thy","labour","for","easy","thing","sight","sudden","make","poor","man","rich"]},{"verseId":"brenton_sirach_11_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":22,"text":"The blessing of the Lord is in the reward of the godly, and suddenly he maketh his blessing to flourish.","searchKeywords":["the","blessing","lord","reward","godly","and","suddenly","maketh","his","flourish"]},{"verseId":"brenton_sirach_11_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":23,"text":"Say not, What profit is there of my service? and what good things shall I have hereafter?","searchKeywords":["say","not","what","profit","there","service","and","good","things","shall","have","hereafter"]},{"verseId":"brenton_sirach_11_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":24,"text":"Again, say not, I have enough, and possess many things, and what evil can come to me hereafter?","searchKeywords":["again","say","not","have","enough","and","possess","many","things","what","evil","can","come","hereafter"]},{"verseId":"brenton_sirach_11_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":25,"text":"In the day of prosperity there is a forgetfulness of affliction: and in the day of affliction there is no more remembrance of prosperity.","searchKeywords":["the","day","prosperity","there","forgetfulness","affliction","and","more","remembrance"]},{"verseId":"brenton_sirach_11_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":26,"text":"For it is an easy thing unto the Lord in the day of death to reward a man according to his ways.","searchKeywords":["for","easy","thing","unto","the","lord","day","death","reward","man","according","his","ways"]},{"verseId":"brenton_sirach_11_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":27,"text":"The affliction of an hour maketh a man forget pleasure: and in his end his deeds shall be discovered.","searchKeywords":["the","affliction","hour","maketh","man","forget","pleasure","and","his","end","deeds","shall","discovered"]},{"verseId":"brenton_sirach_11_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":28,"text":"Judge none blessed before his death: for a man shall be known in his children.","searchKeywords":["judge","none","blessed","before","his","death","for","man","shall","known","children"]},{"verseId":"brenton_sirach_11_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":29,"text":"Bring not every man into thine house: for the deceitful man hath many trains.","searchKeywords":["bring","not","every","man","into","thine","house","for","the","deceitful","hath","many","trains"]},{"verseId":"brenton_sirach_11_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":30,"text":"Like as a partridge taken [and kept] in a cage, so is the heart of the proud: and like as a spy, watcheth he for thy fall:","searchKeywords":["like","partridge","taken","and","kept","cage","the","heart","proud","spy","watcheth","for","thy","fall"]},{"verseId":"brenton_sirach_11_31","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":31,"text":"for he lieth in wait, and turneth good into evil, and in things worthy praise will lay blame upon thee.","searchKeywords":["for","lieth","wait","and","turneth","good","into","evil","things","worthy","praise","will","lay","blame","upon","thee"]},{"verseId":"brenton_sirach_11_32","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":32,"text":"Of a spark of fire a heap of coals is kindled: and a sinful man layeth wait for blood.","searchKeywords":["spark","fire","heap","coals","kindled","and","sinful","man","layeth","wait","for","blood"]},{"verseId":"brenton_sirach_11_33","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":33,"text":"Take heed of a mischievous man, for he worketh wickedness: lest he bring upon thee a perpetual blot.","searchKeywords":["take","heed","mischievous","man","for","worketh","wickedness","lest","bring","upon","thee","perpetual","blot"]},{"verseId":"brenton_sirach_11_34","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":11,"verse":34,"text":"Receive a stranger into thine house, and he will disturb thee, and turn thee out of thine own.","searchKeywords":["receive","stranger","into","thine","house","and","will","disturb","thee","turn","out","own"]}]