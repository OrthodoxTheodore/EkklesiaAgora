[{"verseId":"brenton_sirach_28_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":1,"text":"He that revengeth shall find vengeance from the Lord, and he will surely keep his sins [in remembrance].","searchKeywords":["that","revengeth","shall","find","vengeance","from","the","lord","and","will","surely","keep","his","sins","remembrance"]},{"verseId":"brenton_sirach_28_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":2,"text":"Forgive thy neighbour the hurt that he hath done unto thee, so shall thy sins also be forgiven when thou prayest.","searchKeywords":["forgive","thy","neighbour","the","hurt","that","hath","done","unto","thee","shall","sins","also","forgiven","when","thou","prayest"]},{"verseId":"brenton_sirach_28_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":3,"text":"One man beareth hatred against another, and doth he seek pardon from the Lord?","searchKeywords":["one","man","beareth","hatred","against","another","and","doth","seek","pardon","from","the","lord"]},{"verseId":"brenton_sirach_28_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":4,"text":"He sheweth no mercy to a man, which is like himself: and doth he ask forgiveness of his own sins?","searchKeywords":["sheweth","mercy","man","which","like","himself","and","doth","ask","forgiveness","his","own","sins"]},{"verseId":"brenton_sirach_28_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":5,"text":"If he that is but flesh nourish hatred, who will intreat for pardon of his sins?","searchKeywords":["that","but","flesh","nourish","hatred","who","will","intreat","for","pardon","his","sins"]},{"verseId":"brenton_sirach_28_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":6,"text":"Remember thy end, and let thy enmity cease; [remember] corruption and death, and abide in the commandments.","searchKeywords":["remember","thy","end","and","let","enmity","cease","corruption","death","abide","the","commandments"]},{"verseId":"brenton_sirach_28_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":7,"text":"Remember the commandments, and bear no malice to thy neighbour: [remember] the covenant of the Highest, and wink at ignorance.","searchKeywords":["remember","the","commandments","and","bear","malice","thy","neighbour","covenant","highest","wink","ignorance"]},{"verseId":"brenton_sirach_28_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":8,"text":"Abstain from strife, and thou shalt diminish thy sins: for a furious man will kindle strife.","searchKeywords":["abstain","from","strife","and","thou","shalt","diminish","thy","sins","for","furious","man","will","kindle"]},{"verseId":"brenton_sirach_28_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":9,"text":"A sinful man disquieteth friends, and maketh debate among them that be at peace.","searchKeywords":["sinful","man","disquieteth","friends","and","maketh","debate","among","them","that","peace"]},{"verseId":"brenton_sirach_28_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":10,"text":"As the matter of the fire is, so it burneth: and as a man's strength is, so is his wrath; and according to his riches his anger riseth; and the stronger they are which contend, the more they will be inflamed.","searchKeywords":["the","matter","fire","burneth","and","man","strength","his","wrath","according","riches","anger","riseth","stronger","they","are","which","contend","more","will","inflamed"]},{"verseId":"brenton_sirach_28_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":11,"text":"An hasty contention kindleth a fire: and an hasty fighting sheddeth blood.","searchKeywords":["hasty","contention","kindleth","fire","and","fighting","sheddeth","blood"]},{"verseId":"brenton_sirach_28_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":12,"text":"If thou blow the spark, it shall burn: if thou spit upon it, it shall be quenched: and both these come out of thy mouth.","searchKeywords":["thou","blow","the","spark","shall","burn","spit","upon","quenched","and","both","these","come","out","thy","mouth"]},{"verseId":"brenton_sirach_28_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":13,"text":"Curse the whisperer and double-tongued: for such have destroyed many that were at peace.","searchKeywords":["curse","the","whisperer","and","double","tongued","for","such","have","destroyed","many","that","were","peace"]},{"verseId":"brenton_sirach_28_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":14,"text":"A backbiting tongue hath disquieted many, and driven them from nation to nation: strong cities hath it pulled down, and overthrown the houses of great men.","searchKeywords":["backbiting","tongue","hath","disquieted","many","and","driven","them","from","nation","strong","cities","pulled","down","overthrown","the","houses","great","men"]},{"verseId":"brenton_sirach_28_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":15,"text":"A backbiting tongue hath cast out virtuous women, and deprived them of their labours.","searchKeywords":["backbiting","tongue","hath","cast","out","virtuous","women","and","deprived","them","their","labours"]},{"verseId":"brenton_sirach_28_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":16,"text":"Whoso hearkeneth unto it shall never find rest, and never dwell quietly.","searchKeywords":["whoso","hearkeneth","unto","shall","never","find","rest","and","dwell","quietly"]},{"verseId":"brenton_sirach_28_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":17,"text":"The stroke of the whip maketh marks in the flesh: but the stroke of the tongue breaketh the bones.","searchKeywords":["the","stroke","whip","maketh","marks","flesh","but","tongue","breaketh","bones"]},{"verseId":"brenton_sirach_28_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":18,"text":"Many have fallen by the edge of the sword: but not so many as have fallen by the tongue.","searchKeywords":["many","have","fallen","the","edge","sword","but","not","tongue"]},{"verseId":"brenton_sirach_28_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":19,"text":"Well is he that is defended from it, and hath not passed through the venom thereof, who hath not drawn the yoke thereof, nor hath been bound in her bands.","searchKeywords":["well","that","defended","from","and","hath","not","passed","through","the","venom","thereof","who","drawn","yoke","nor","been","bound","her","bands"]},{"verseId":"brenton_sirach_28_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":20,"text":"For the yoke thereof is a yoke of iron, and the bands thereof are bands of brass.","searchKeywords":["for","the","yoke","thereof","iron","and","bands","are","brass"]},{"verseId":"brenton_sirach_28_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":21,"text":"The death thereof is an evil death, the grave were better than it.","searchKeywords":["the","death","thereof","evil","grave","were","better","than"]},{"verseId":"brenton_sirach_28_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":22,"text":"It shall not have rule over them that fear God, neither shall they be burned with the flame thereof.","searchKeywords":["shall","not","have","rule","over","them","that","fear","god","neither","they","burned","with","the","flame","thereof"]},{"verseId":"brenton_sirach_28_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":23,"text":"Such as forsake the Lord shall fall into it; and it shall burn in them, and not be quenched; it shall be sent upon them as a lion, and devour them as a leopard.","searchKeywords":["such","forsake","the","lord","shall","fall","into","and","burn","them","not","quenched","sent","upon","lion","devour","leopard"]},{"verseId":"brenton_sirach_28_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":24,"text":"Look that thou hedge thy possession about with thorns, and bind up thy silver and gold,","searchKeywords":["look","that","thou","hedge","thy","possession","about","with","thorns","and","bind","silver","gold"]},{"verseId":"brenton_sirach_28_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":25,"text":"and weigh thy words in a balance, and make a door and bar for thy mouth.","searchKeywords":["and","weigh","thy","words","balance","make","door","bar","for","mouth"]},{"verseId":"brenton_sirach_28_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":28,"verse":26,"text":"Beware thou slide not by it, lest thou fall before him that lieth in wait.","searchKeywords":["beware","thou","slide","not","lest","fall","before","him","that","lieth","wait"]}]