[{"verseId":"brenton_sirach_44_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":1,"text":"Let us now praise famous men, and our fathers that begat us.","searchKeywords":["let","now","praise","famous","men","and","our","fathers","that","begat"]},{"verseId":"brenton_sirach_44_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":2,"text":"The Lord hath wrought great glory by them through his great power from the beginning.","searchKeywords":["the","lord","hath","wrought","great","glory","them","through","his","power","from","beginning"]},{"verseId":"brenton_sirach_44_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":3,"text":"Such as did bear rule in their kingdoms, men renowned for their power, giving counsel by their understanding, and declaring prophecies:","searchKeywords":["such","did","bear","rule","their","kingdoms","men","renowned","for","power","giving","counsel","understanding","and","declaring","prophecies"]},{"verseId":"brenton_sirach_44_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":4,"text":"leaders of the people by their counsels, and by their knowledge of learning meet for the people, wise and eloquent in their instruction:","searchKeywords":["leaders","the","people","their","counsels","and","knowledge","learning","meet","for","wise","eloquent","instruction"]},{"verseId":"brenton_sirach_44_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":5,"text":"such as found out musical tunes, and recited verses in writing:","searchKeywords":["such","found","out","musical","tunes","and","recited","verses","writing"]},{"verseId":"brenton_sirach_44_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":6,"text":"rich men furnished with ability, living peaceably in their habitations:","searchKeywords":["rich","men","furnished","with","ability","living","peaceably","their","habitations"]},{"verseId":"brenton_sirach_44_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":7,"text":"all these were honoured in their generations, and were the glory of their times.","searchKeywords":["all","these","were","honoured","their","generations","and","the","glory","times"]},{"verseId":"brenton_sirach_44_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":8,"text":"There be of them that have left a name behind them, that their praises might be reported.","searchKeywords":["there","them","that","have","left","name","behind","their","praises","might","reported"]},{"verseId":"brenton_sirach_44_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":9,"text":"And some there be, which have no memorial; who are perished, as though they had never been; and are become as though they had never been born; and their children after them.","searchKeywords":["and","some","there","which","have","memorial","who","are","perished","though","they","had","never","been","become","born","their","children","after","them"]},{"verseId":"brenton_sirach_44_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":10,"text":"But these were merciful men, whose righteousness hath not been forgotten.","searchKeywords":["but","these","were","merciful","men","whose","righteousness","hath","not","been","forgotten"]},{"verseId":"brenton_sirach_44_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":11,"text":"With their seed shall continually remain a good inheritance, and their children are within the covenant.","searchKeywords":["with","their","seed","shall","continually","remain","good","inheritance","and","children","are","within","the","covenant"]},{"verseId":"brenton_sirach_44_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":12,"text":"Their seed standeth fast, and their children for their sakes.","searchKeywords":["their","seed","standeth","fast","and","children","for","sakes"]},{"verseId":"brenton_sirach_44_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":13,"text":"Their seed shall remain for ever, and their glory shall not be blotted out.","searchKeywords":["their","seed","shall","remain","for","ever","and","glory","not","blotted","out"]},{"verseId":"brenton_sirach_44_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":14,"text":"Their bodies are buried in peace; but their name liveth for evermore.","searchKeywords":["their","bodies","are","buried","peace","but","name","liveth","for","evermore"]},{"verseId":"brenton_sirach_44_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":15,"text":"The people will tell of their wisdom, and the congregation will shew forth their praise.","searchKeywords":["the","people","will","tell","their","wisdom","and","congregation","shew","forth","praise"]},{"verseId":"brenton_sirach_44_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":16,"text":"Enoch pleased the Lord, and was translated, being an example of repentance to all generations.","searchKeywords":["enoch","pleased","the","lord","and","was","translated","being","example","repentance","all","generations"]},{"verseId":"brenton_sirach_44_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":17,"text":"Noah was found perfect and righteous; in the time of wrath he was taken in exchange [for the world;] therefore was he left as a remnant unto the earth, when the flood came.","searchKeywords":["noah","was","found","perfect","and","righteous","the","time","wrath","taken","exchange","for","world","therefore","left","remnant","unto","earth","when","flood","came"]},{"verseId":"brenton_sirach_44_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":18,"text":"An everlasting covenant was made with him, that all flesh shall perish no more by the flood.","searchKeywords":["everlasting","covenant","was","made","with","him","that","all","flesh","shall","perish","more","the","flood"]},{"verseId":"brenton_sirach_44_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":19,"text":"Abraham was a great father of many people: in glory was there none like unto him;","searchKeywords":["abraham","was","great","father","many","people","glory","there","none","like","unto","him"]},{"verseId":"brenton_sirach_44_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":20,"text":"who kept the law of the most High, and was in covenant with him: he established the covenant in his flesh; and when he was proved, he was found faithful.","searchKeywords":["who","kept","the","law","most","high","and","was","covenant","with","him","established","his","flesh","when","proved","found","faithful"]},{"verseId":"brenton_sirach_44_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":21,"text":"Therefore he assured him by an oath, that he would bless the nations in his seed, and that he would multiply him as the dust of the earth, and exalt his seed as the stars, and cause them to inherit from sea to sea, and from the river unto the utmost part of the land.","searchKeywords":["therefore","assured","him","oath","that","would","bless","the","nations","his","seed","and","multiply","dust","earth","exalt","stars","cause","them","inherit","from","sea","river","unto","utmost","part","land"]},{"verseId":"brenton_sirach_44_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":22,"text":"With Isaac did he establish likewise, for Abraham his father's sake, the blessing of all men, and the covenant,","searchKeywords":["with","isaac","did","establish","likewise","for","abraham","his","father","sake","the","blessing","all","men","and","covenant"]},{"verseId":"brenton_sirach_44_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":44,"verse":23,"text":"and made it rest upon the head of Jacob. He acknowledged him in his blessing, and gave him an heritage, and divided his portions; among the twelve tribes did he part them.","searchKeywords":["and","made","rest","upon","the","head","jacob","acknowledged","him","his","blessing","gave","heritage","divided","portions","among","twelve","tribes","did","part","them"]}]