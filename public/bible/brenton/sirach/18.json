[{"verseId":"brenton_sirach_18_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":1,"text":"He that liveth for ever created all things in general.","searchKeywords":["that","liveth","for","ever","created","all","things","general"]},{"verseId":"brenton_sirach_18_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":2,"text":"The Lord only is righteous.","searchKeywords":["the","lord","only","righteous"]},{"verseId":"brenton_sirach_18_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":4,"text":"To none hath he given power to declare his works; and who shall find out his noble acts?","searchKeywords":["none","hath","given","power","declare","his","works","and","who","shall","find","out","noble","acts"]},{"verseId":"brenton_sirach_18_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":5,"text":"Who shall number the strength of his majesty? and who shall also tell out his mercies?","searchKeywords":["who","shall","number","the","strength","his","majesty","and","also","tell","out","mercies"]},{"verseId":"brenton_sirach_18_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":6,"text":"As for the wondrous works of the Lord, there may nothing be taken from them, neither may any thing be put unto them, neither can the ground of them be found out.","searchKeywords":["for","the","wondrous","works","lord","there","may","nothing","taken","from","them","neither","any","thing","put","unto","can","ground","found","out"]},{"verseId":"brenton_sirach_18_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":7,"text":"When a man hath done, then he beginneth; and when he leaveth off, then he shall be doubtful.","searchKeywords":["when","man","hath","done","then","beginneth","and","leaveth","off","shall","doubtful"]},{"verseId":"brenton_sirach_18_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":8,"text":"What is man, and whereto serveth he; what is his good, and what is his evil?","searchKeywords":["what","man","and","whereto","serveth","his","good","evil"]},{"verseId":"brenton_sirach_18_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":9,"text":"The number of a man's days at the most is an hundred years.","searchKeywords":["the","number","man","days","most","hundred","years"]},{"verseId":"brenton_sirach_18_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":10,"text":"As a drop of water unto the sea, and a gravel-stone in comparison of the sand; so are a thousand years to the days of eternity.","searchKeywords":["drop","water","unto","the","sea","and","gravel","stone","comparison","sand","are","thousand","years","days","eternity"]},{"verseId":"brenton_sirach_18_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":11,"text":"Therefore is God patient with them, and poureth forth his mercy upon them.","searchKeywords":["therefore","god","patient","with","them","and","poureth","forth","his","mercy","upon"]},{"verseId":"brenton_sirach_18_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":12,"text":"He saw and perceived their end to be evil; therefore he multiplied his compassion.","searchKeywords":["saw","and","perceived","their","end","evil","therefore","multiplied","his","compassion"]},{"verseId":"brenton_sirach_18_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":13,"text":"The mercy of man is toward his neighbour; but the mercy of the Lord is upon all flesh: he reproveth, and nurtureth, and teacheth, and bringeth again, as a shepherd his flock.","searchKeywords":["the","mercy","man","toward","his","neighbour","but","lord","upon","all","flesh","reproveth","and","nurtureth","teacheth","bringeth","again","shepherd","flock"]},{"verseId":"brenton_sirach_18_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":14,"text":"He hath mercy on them that receive discipline, and that diligently seek after his judgments.","searchKeywords":["hath","mercy","them","that","receive","discipline","and","diligently","seek","after","his","judgments"]},{"verseId":"brenton_sirach_18_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":15,"text":"My son, blemish not thy good deeds, neither use uncomfortable words when thou givest any thing.","searchKeywords":["son","blemish","not","thy","good","deeds","neither","use","uncomfortable","words","when","thou","givest","any","thing"]},{"verseId":"brenton_sirach_18_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":16,"text":"Shall not the dew assuage the heat? so is a word better than a gift.","searchKeywords":["shall","not","the","dew","assuage","heat","word","better","than","gift"]},{"verseId":"brenton_sirach_18_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":17,"text":"Lo, is not a word better than a gift? but both are with a gracious man.","searchKeywords":["not","word","better","than","gift","but","both","are","with","gracious","man"]},{"verseId":"brenton_sirach_18_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":18,"text":"A fool will upbraid churlishly, and a gift of the envious consumeth the eyes.","searchKeywords":["fool","will","upbraid","churlishly","and","gift","the","envious","consumeth","eyes"]},{"verseId":"brenton_sirach_18_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":19,"text":"Learn before thou speak, and use physic or ever thou be sick.","searchKeywords":["learn","before","thou","speak","and","use","physic","ever","sick"]},{"verseId":"brenton_sirach_18_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":20,"text":"Before judgment examine thyself, and in the day of visitation thou shalt find mercy.","searchKeywords":["before","judgment","examine","thyself","and","the","day","visitation","thou","shalt","find","mercy"]},{"verseId":"brenton_sirach_18_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":21,"text":"Humble thyself before thou be sick, and in the time of sins shew repentance.","searchKeywords":["humble","thyself","before","thou","sick","and","the","time","sins","shew","repentance"]},{"verseId":"brenton_sirach_18_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":22,"text":"Let nothing hinder thee to pay thy vow in due time, and defer not until death to be justified.","searchKeywords":["let","nothing","hinder","thee","pay","thy","vow","due","time","and","defer","not","until","death","justified"]},{"verseId":"brenton_sirach_18_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":23,"text":"Before thou prayest, prepare thyself; and be not as one that tempteth the Lord.","searchKeywords":["before","thou","prayest","prepare","thyself","and","not","one","that","tempteth","the","lord"]},{"verseId":"brenton_sirach_18_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":24,"text":"Think upon the wrath that shall be at the end, and the time of vengeance, when he shall turn away his face.","searchKeywords":["think","upon","the","wrath","that","shall","end","and","time","vengeance","when","turn","away","his","face"]},{"verseId":"brenton_sirach_18_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":25,"text":"When thou hast enough, remember the time of hunger: and when thou art rich, think upon poverty and need.","searchKeywords":["when","thou","hast","enough","remember","the","time","hunger","and","art","rich","think","upon","poverty","need"]},{"verseId":"brenton_sirach_18_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":26,"text":"From the morning until the evening the time is changed, and all things are soon done before the Lord.","searchKeywords":["from","the","morning","until","evening","time","changed","and","all","things","are","soon","done","before","lord"]},{"verseId":"brenton_sirach_18_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":27,"text":"A wise man will fear in every thing, and in the day of sinning he will beware of offence: but a fool will not observe time.","searchKeywords":["wise","man","will","fear","every","thing","and","the","day","sinning","beware","offence","but","fool","not","observe","time"]},{"verseId":"brenton_sirach_18_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":28,"text":"Every man of understanding knoweth wisdom, and will give praise unto him that found her.","searchKeywords":["every","man","understanding","knoweth","wisdom","and","will","give","praise","unto","him","that","found","her"]},{"verseId":"brenton_sirach_18_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":29,"text":"They that had understanding in sayings became also wise themselves, and poured forth exquisite parables.","searchKeywords":["they","that","had","understanding","sayings","became","also","wise","themselves","and","poured","forth","exquisite","parables"]},{"verseId":"brenton_sirach_18_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":30,"text":"Go not after thy lusts, but refrain thyself from thine appetites.","searchKeywords":["not","after","thy","lusts","but","refrain","thyself","from","thine","appetites"]},{"verseId":"brenton_sirach_18_31","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":31,"text":"If thou givest thy soul the desires that please her, she will make thee a laughingstock to thine enemies that malign thee.","searchKeywords":["thou","givest","thy","soul","the","desires","that","please","her","she","will","make","thee","laughingstock","thine","enemies","malign"]},{"verseId":"brenton_sirach_18_32","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":32,"text":"Take not pleasure in much good cheer, neither be tied to the expence thereof.","searchKeywords":["take","not","pleasure","much","good","cheer","neither","tied","the","expence","thereof"]},{"verseId":"brenton_sirach_18_33","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":18,"verse":33,"text":"Be not made a beggar by banqueting upon borrowing, when thou hast nothing in thy purse.","searchKeywords":["not","made","beggar","banqueting","upon","borrowing","when","thou","hast","nothing","thy","purse"]}]