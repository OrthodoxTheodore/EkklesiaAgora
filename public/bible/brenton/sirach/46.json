[{"verseId":"brenton_sirach_46_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":1,"text":"Jesus the son of Nave was valiant in the wars, and was the successor of Moses in prophecies, who according to his name was made great for the saving of the elect of God, and taking vengeance of the enemies that rose up against them, that he might set Israel in their inheritance.","searchKeywords":["jesus","the","son","nave","was","valiant","wars","and","successor","moses","prophecies","who","according","his","name","made","great","for","saving","elect","god","taking","vengeance","enemies","that","rose","against","them","might","set","israel","their","inheritance"]},{"verseId":"brenton_sirach_46_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":2,"text":"How great glory gat he, when he did lift up his hands, and stretched out his sword against the cities!","searchKeywords":["how","great","glory","gat","when","did","lift","his","hands","and","stretched","out","sword","against","the","cities"]},{"verseId":"brenton_sirach_46_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":3,"text":"Who before him has so stood? for the Lord himself brought his enemies over to him.","searchKeywords":["who","before","him","has","stood","for","the","lord","himself","brought","his","enemies","over"]},{"verseId":"brenton_sirach_46_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":4,"text":"Did not the sun go back by his means? and was not one day as long as two?","searchKeywords":["did","not","the","sun","back","his","means","and","was","one","day","long","two"]},{"verseId":"brenton_sirach_46_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":5,"text":"He called upon the most high Lord, when the enemies pressed upon him on every side; and the great Lord heard him.","searchKeywords":["called","upon","the","most","high","lord","when","enemies","pressed","him","every","side","and","great","heard"]},{"verseId":"brenton_sirach_46_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":6,"text":"And with hailstones of mighty power he made the battle to fall violently upon the nations, and by their falling he destroyed them that resisted, that the nations might know all their strength, because he fought in the sight of the Lord, and he followed the Mighty One.","searchKeywords":["and","with","hailstones","mighty","power","made","the","battle","fall","violently","upon","nations","their","falling","destroyed","them","that","resisted","might","know","all","strength","because","fought","sight","lord","followed","one"]},{"verseId":"brenton_sirach_46_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":7,"text":"In the time of Moses also he did a work of mercy, he and Caleb the son of Jephunne, in that they withstood the enemy, and withheld the people from sin, and appeased the wicked murmuring.","searchKeywords":["the","time","moses","also","did","work","mercy","and","caleb","son","jephunne","that","they","withstood","enemy","withheld","people","from","sin","appeased","wicked","murmuring"]},{"verseId":"brenton_sirach_46_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":8,"text":"And of six hundred thousand people on foot, they two alone were preserved to bring them into the heritage, even unto the land that floweth with milk and honey.","searchKeywords":["and","six","hundred","thousand","people","foot","they","two","alone","were","preserved","bring","them","into","the","heritage","even","unto","land","that","floweth","with","milk","honey"]},{"verseId":"brenton_sirach_46_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":9,"text":"The Lord gave strength also unto Caleb, which remained with him unto his old age: so that he entered upon the high places of the land, and his seed obtained it for an heritage:","searchKeywords":["the","lord","gave","strength","also","unto","caleb","which","remained","with","him","his","old","age","that","entered","upon","high","places","land","and","seed","obtained","for","heritage"]},{"verseId":"brenton_sirach_46_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":10,"text":"that all the children of Israel might see that it is good to follow the Lord.","searchKeywords":["that","all","the","children","israel","might","see","good","follow","lord"]},{"verseId":"brenton_sirach_46_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":11,"text":"And concerning the judges, every one by name, whose heart went not a whoring, nor departed from the Lord, let their memory be blessed.","searchKeywords":["and","concerning","the","judges","every","one","name","whose","heart","went","not","whoring","nor","departed","from","lord","let","their","memory","blessed"]},{"verseId":"brenton_sirach_46_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":12,"text":"Let their bones flourish out of their place, and let the name of them that were honoured be continued upon their children.","searchKeywords":["let","their","bones","flourish","out","place","and","the","name","them","that","were","honoured","continued","upon","children"]},{"verseId":"brenton_sirach_46_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":13,"text":"Samuel, the prophet of the Lord, beloved of his Lord, established a kingdom, and anointed princes over his people.","searchKeywords":["samuel","the","prophet","lord","beloved","his","established","kingdom","and","anointed","princes","over","people"]},{"verseId":"brenton_sirach_46_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":14,"text":"By the law of the Lord he judged the congregation, and the Lord had respect unto Jacob.","searchKeywords":["the","law","lord","judged","congregation","and","had","respect","unto","jacob"]},{"verseId":"brenton_sirach_46_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":15,"text":"By his faithfulness he was found a true prophet, and by his word he was known to be faithful in vision.","searchKeywords":["his","faithfulness","was","found","true","prophet","and","word","known","faithful","vision"]},{"verseId":"brenton_sirach_46_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":16,"text":"He called upon the mighty Lord, when his enemies pressed upon him on every side, when he offered the sucking lamb.","searchKeywords":["called","upon","the","mighty","lord","when","his","enemies","pressed","him","every","side","offered","sucking","lamb"]},{"verseId":"brenton_sirach_46_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":17,"text":"And the Lord thundered from heaven, and with a great noise made his voice to be heard.","searchKeywords":["and","the","lord","thundered","from","heaven","with","great","noise","made","his","voice","heard"]},{"verseId":"brenton_sirach_46_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":18,"text":"And he destroyed the rulers of the Tyrians, and all the princes of the Philistines.","searchKeywords":["and","destroyed","the","rulers","tyrians","all","princes","philistines"]},{"verseId":"brenton_sirach_46_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":19,"text":"And before his long sleep he made protestation in the sight of the Lord and his anointed, I have not taken any man's goods, so much as a shoe: and no man did accuse him.","searchKeywords":["and","before","his","long","sleep","made","protestation","the","sight","lord","anointed","have","not","taken","any","man","goods","much","shoe","did","accuse","him"]},{"verseId":"brenton_sirach_46_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":46,"verse":20,"text":"And after his death he prophesied, and shewed the king his end, and lifted up his voice from the earth in prophecy, to blot out the wickedness of the people.","searchKeywords":["and","after","his","death","prophesied","shewed","the","king","end","lifted","voice","from","earth","prophecy","blot","out","wickedness","people"]}]