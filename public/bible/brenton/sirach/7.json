[{"verseId":"brenton_sirach_7_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":1,"text":"Do no evil, so shall no harm come unto thee.","searchKeywords":["evil","shall","harm","come","unto","thee"]},{"verseId":"brenton_sirach_7_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":2,"text":"Depart from the unjust, and iniquity shall turn away from thee.","searchKeywords":["depart","from","the","unjust","and","iniquity","shall","turn","away","thee"]},{"verseId":"brenton_sirach_7_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":3,"text":"My son, sow not upon the furrows of unrighteousness, and thou shalt not reap them sevenfold.","searchKeywords":["son","sow","not","upon","the","furrows","unrighteousness","and","thou","shalt","reap","them","sevenfold"]},{"verseId":"brenton_sirach_7_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":4,"text":"Seek not of the Lord preeminence, neither of the king the seat of honour.","searchKeywords":["seek","not","the","lord","preeminence","neither","king","seat","honour"]},{"verseId":"brenton_sirach_7_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":5,"text":"Justify not thyself before the Lord; and boast not of thy wisdom before the king.","searchKeywords":["justify","not","thyself","before","the","lord","and","boast","thy","wisdom","king"]},{"verseId":"brenton_sirach_7_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":6,"text":"Seek not to be judge, being not able to take away iniquity; lest at any time thou fear the person of the mighty, and lay a stumblingblock in the way of thy uprightness.","searchKeywords":["seek","not","judge","being","able","take","away","iniquity","lest","any","time","thou","fear","the","person","mighty","and","lay","stumblingblock","way","thy","uprightness"]},{"verseId":"brenton_sirach_7_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":7,"text":"Offend not against the multitude of a city, and then thou shalt not cast thyself down among the people.","searchKeywords":["offend","not","against","the","multitude","city","and","then","thou","shalt","cast","thyself","down","among","people"]},{"verseId":"brenton_sirach_7_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":8,"text":"Bind not one sin upon another; for in one thou shalt not be unpunished.","searchKeywords":["bind","not","one","sin","upon","another","for","thou","shalt","unpunished"]},{"verseId":"brenton_sirach_7_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":9,"text":"Say not, God will look upon the multitude of my oblations, and when I offer to the most high God, he will accept it.","searchKeywords":["say","not","god","will","look","upon","the","multitude","oblations","and","when","offer","most","high","accept"]},{"verseId":"brenton_sirach_7_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":10,"text":"Be not fainthearted when thou makest thy prayer, and neglect not to give alms.","searchKeywords":["not","fainthearted","when","thou","makest","thy","prayer","and","neglect","give","alms"]},{"verseId":"brenton_sirach_7_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":11,"text":"Laugh no man to scorn in the bitterness of his soul: for there is one which humbleth and exalteth.","searchKeywords":["laugh","man","scorn","the","bitterness","his","soul","for","there","one","which","humbleth","and","exalteth"]},{"verseId":"brenton_sirach_7_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":12,"text":"Devise not a lie against thy brother; neither do the like to thy friend.","searchKeywords":["devise","not","lie","against","thy","brother","neither","the","like","friend"]},{"verseId":"brenton_sirach_7_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":13,"text":"Use not to make any manner of lie: for the custom thereof is not good.","searchKeywords":["use","not","make","any","manner","lie","for","the","custom","thereof","good"]},{"verseId":"brenton_sirach_7_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":14,"text":"Use not many words in a multitude of elders, and make not much babbling when thou prayest.","searchKeywords":["use","not","many","words","multitude","elders","and","make","much","babbling","when","thou","prayest"]},{"verseId":"brenton_sirach_7_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":15,"text":"Hate not laborious work, neither husbandry, which the most High hath ordained.","searchKeywords":["hate","not","laborious","work","neither","husbandry","which","the","most","high","hath","ordained"]},{"verseId":"brenton_sirach_7_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":16,"text":"Number not thyself among the multitude of sinners, but remember that wrath will not tarry long.","searchKeywords":["number","not","thyself","among","the","multitude","sinners","but","remember","that","wrath","will","tarry","long"]},{"verseId":"brenton_sirach_7_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":17,"text":"Humble thy soul greatly: for the vengeance of the ungodly is fire and worms.","searchKeywords":["humble","thy","soul","greatly","for","the","vengeance","ungodly","fire","and","worms"]},{"verseId":"brenton_sirach_7_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":18,"text":"Change not a friend for any good by no means; neither a faithful brother for the gold of Suphir.","searchKeywords":["change","not","friend","for","any","good","means","neither","faithful","brother","the","gold","suphir"]},{"verseId":"brenton_sirach_7_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":19,"text":"Forego not a wise and good woman: for her grace is above gold.","searchKeywords":["forego","not","wise","and","good","woman","for","her","grace","above","gold"]},{"verseId":"brenton_sirach_7_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":20,"text":"Whereas thy servant worketh truly, entreat him not evil, nor the hireling that bestoweth himself wholly for thee.","searchKeywords":["whereas","thy","servant","worketh","truly","entreat","him","not","evil","nor","the","hireling","that","bestoweth","himself","wholly","for","thee"]},{"verseId":"brenton_sirach_7_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":21,"text":"Let thy soul love a good servant, and defraud him not of liberty.","searchKeywords":["let","thy","soul","love","good","servant","and","defraud","him","not","liberty"]},{"verseId":"brenton_sirach_7_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":22,"text":"Hast thou cattle? have an eye to them: and if they be for thy profit, keep them with thee.","searchKeywords":["hast","thou","cattle","have","eye","them","and","they","for","thy","profit","keep","with","thee"]},{"verseId":"brenton_sirach_7_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":23,"text":"Hast thou children? instruct them, and bow down their neck from their youth.","searchKeywords":["hast","thou","children","instruct","them","and","bow","down","their","neck","from","youth"]},{"verseId":"brenton_sirach_7_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":24,"text":"Hast thou daughters? have a care of their body, and shew not thyself cheerful toward them.","searchKeywords":["hast","thou","daughters","have","care","their","body","and","shew","not","thyself","cheerful","toward","them"]},{"verseId":"brenton_sirach_7_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":25,"text":"Marry thy daughter, and so shalt thou have performed a weighty matter: but give her to a man of understanding.","searchKeywords":["marry","thy","daughter","and","shalt","thou","have","performed","weighty","matter","but","give","her","man","understanding"]},{"verseId":"brenton_sirach_7_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":26,"text":"Hast thou a wife after thy mind? forsake her not.","searchKeywords":["hast","thou","wife","after","thy","mind","forsake","her","not"]},{"verseId":"brenton_sirach_7_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":27,"text":"Honour thy father with thy whole heart, and forget not the sorrows of thy mother.","searchKeywords":["honour","thy","father","with","whole","heart","and","forget","not","the","sorrows","mother"]},{"verseId":"brenton_sirach_7_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":28,"text":"Remember that thou wast begotten of them; and how canst thou recompense them the things that they have done for thee?","searchKeywords":["remember","that","thou","wast","begotten","them","and","how","canst","recompense","the","things","they","have","done","for","thee"]},{"verseId":"brenton_sirach_7_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":29,"text":"Fear the Lord with all thy soul, and reverence his priests.","searchKeywords":["fear","the","lord","with","all","thy","soul","and","reverence","his","priests"]},{"verseId":"brenton_sirach_7_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":30,"text":"Love him that made thee with all thy strength, and forsake not his ministers.","searchKeywords":["love","him","that","made","thee","with","all","thy","strength","and","forsake","not","his","ministers"]},{"verseId":"brenton_sirach_7_31","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":31,"text":"Fear the Lord, and honour the priest: and give him his portion, as it is commanded thee: the firstfruits, and the trespass offering, and the gift of the shoulders, and the sacrifice of sanctification, and the firstfruits of the holy things.","searchKeywords":["fear","the","lord","and","honour","priest","give","him","his","portion","commanded","thee","firstfruits","trespass","offering","gift","shoulders","sacrifice","sanctification","holy","things"]},{"verseId":"brenton_sirach_7_32","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":32,"text":"And stretch thine hand unto the poor, that thy blessing may be perfected.","searchKeywords":["and","stretch","thine","hand","unto","the","poor","that","thy","blessing","may","perfected"]},{"verseId":"brenton_sirach_7_33","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":33,"text":"A gift hath grace in the sight of every man living; and for the dead detain it not.","searchKeywords":["gift","hath","grace","the","sight","every","man","living","and","for","dead","detain","not"]},{"verseId":"brenton_sirach_7_34","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":34,"text":"Fail not to be with them that weep, and mourn with them that mourn.","searchKeywords":["fail","not","with","them","that","weep","and","mourn"]},{"verseId":"brenton_sirach_7_35","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":35,"text":"Be not slow to visit the sick: for that shall make thee to be beloved.","searchKeywords":["not","slow","visit","the","sick","for","that","shall","make","thee","beloved"]},{"verseId":"brenton_sirach_7_36","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":7,"verse":36,"text":"Whatsoever thou takest in hand, remember the end, and thou shalt never do amiss.","searchKeywords":["whatsoever","thou","takest","hand","remember","the","end","and","shalt","never","amiss"]}]