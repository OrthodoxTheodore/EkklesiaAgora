[{"verseId":"brenton_sirach_39_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":1,"text":"will seek out the wisdom of all the ancients, and be occupied in prophecies.","searchKeywords":["will","seek","out","the","wisdom","all","ancients","and","occupied","prophecies"]},{"verseId":"brenton_sirach_39_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":2,"text":"He will keep the sayings of the renowned men: and where subtil parables are, he will be there also.","searchKeywords":["will","keep","the","sayings","renowned","men","and","where","subtil","parables","are","there","also"]},{"verseId":"brenton_sirach_39_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":3,"text":"He will seek out the secrets of grave sentences, and be conversant in dark parables.","searchKeywords":["will","seek","out","the","secrets","grave","sentences","and","conversant","dark","parables"]},{"verseId":"brenton_sirach_39_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":4,"text":"He shall serve among great men, and appear before princes: he will travel through strange countries; for he hath tried the good and the evil among men.","searchKeywords":["shall","serve","among","great","men","and","appear","before","princes","will","travel","through","strange","countries","for","hath","tried","the","good","evil"]},{"verseId":"brenton_sirach_39_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":5,"text":"He will give his heart to resort early to the Lord that made him, and will pray before the most High, and will open his mouth in prayer, and make supplication for his sins.","searchKeywords":["will","give","his","heart","resort","early","the","lord","that","made","him","and","pray","before","most","high","open","mouth","prayer","make","supplication","for","sins"]},{"verseId":"brenton_sirach_39_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":6,"text":"When the great Lord will, he shall be filled with the spirit of understanding: he shall pour out wise sentences, and give thanks unto the Lord in his prayer.","searchKeywords":["when","the","great","lord","will","shall","filled","with","spirit","understanding","pour","out","wise","sentences","and","give","thanks","unto","his","prayer"]},{"verseId":"brenton_sirach_39_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":7,"text":"He shall direct his counsel and knowledge, and on his secrets shall he meditate.","searchKeywords":["shall","direct","his","counsel","and","knowledge","secrets","meditate"]},{"verseId":"brenton_sirach_39_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":8,"text":"He shall shew forth that which he hath learned, and shall glory in the law of the covenant of the Lord.","searchKeywords":["shall","shew","forth","that","which","hath","learned","and","glory","the","law","covenant","lord"]},{"verseId":"brenton_sirach_39_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":9,"text":"Many shall commend his understanding; and so long as the world endureth, it shall not be blotted out; his memorial shall not depart away, and his name shall live from generation to generation.","searchKeywords":["many","shall","commend","his","understanding","and","long","the","world","endureth","not","blotted","out","memorial","depart","away","name","live","from","generation"]},{"verseId":"brenton_sirach_39_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":10,"text":"Nations shall shew forth his wisdom, and the congregation shall declare his praise.","searchKeywords":["nations","shall","shew","forth","his","wisdom","and","the","congregation","declare","praise"]},{"verseId":"brenton_sirach_39_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":11,"text":"If he die, he shall leave a greater name than a thousand: and if he live, he shall increase it.","searchKeywords":["die","shall","leave","greater","name","than","thousand","and","live","increase"]},{"verseId":"brenton_sirach_39_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":12,"text":"Yet have I more to say, which I have thought upon; for I am filled as the moon at the full.","searchKeywords":["yet","have","more","say","which","thought","upon","for","filled","the","moon","full"]},{"verseId":"brenton_sirach_39_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":13,"text":"Hearken unto me, ye holy children, and bud forth as a rose growing by the brook of the field:","searchKeywords":["hearken","unto","holy","children","and","bud","forth","rose","growing","the","brook","field"]},{"verseId":"brenton_sirach_39_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":14,"text":"and give ye a sweet savour as frankincense, and flourish as a lily, send forth a smell, and sing a song of praise, bless the Lord in all his works.","searchKeywords":["and","give","sweet","savour","frankincense","flourish","lily","send","forth","smell","sing","song","praise","bless","the","lord","all","his","works"]},{"verseId":"brenton_sirach_39_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":15,"text":"Magnify his name, and shew forth his praise with the songs of your lips, and with harps, and in praising him ye shall say after this manner:","searchKeywords":["magnify","his","name","and","shew","forth","praise","with","the","songs","your","lips","harps","praising","him","shall","say","after","this","manner"]},{"verseId":"brenton_sirach_39_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":16,"text":"All the works of the Lord are exceeding good, and whatsoever he commandeth shall be in due season.","searchKeywords":["all","the","works","lord","are","exceeding","good","and","whatsoever","commandeth","shall","due","season"]},{"verseId":"brenton_sirach_39_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":17,"text":"For at time convenient they shall all be sought out: at his commandment the waters stood as an heap, and at the words of his mouth, the receptacles of waters.","searchKeywords":["for","time","convenient","they","shall","all","sought","out","his","commandment","the","waters","stood","heap","and","words","mouth","receptacles"]},{"verseId":"brenton_sirach_39_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":18,"text":"At his commandment is done whatsoever pleaseth him; and none can hinder, when he will save.","searchKeywords":["his","commandment","done","whatsoever","pleaseth","him","and","none","can","hinder","when","will","save"]},{"verseId":"brenton_sirach_39_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":19,"text":"The works of all flesh are before him, and nothing can be hid from his eyes.","searchKeywords":["the","works","all","flesh","are","before","him","and","nothing","can","hid","from","his","eyes"]},{"verseId":"brenton_sirach_39_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":20,"text":"He seeth from everlasting to everlasting; and there is nothing wonderful before him.","searchKeywords":["seeth","from","everlasting","and","there","nothing","wonderful","before","him"]},{"verseId":"brenton_sirach_39_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":21,"text":"A man need not to say, What is this? wherefore is that? for he hath made all things for their uses.","searchKeywords":["man","need","not","say","what","this","wherefore","that","for","hath","made","all","things","their","uses"]},{"verseId":"brenton_sirach_39_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":22,"text":"His blessing covered the dry land as a river, and watered it as a flood.","searchKeywords":["his","blessing","covered","the","dry","land","river","and","watered","flood"]},{"verseId":"brenton_sirach_39_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":23,"text":"As he hath turned the waters into saltness: so shall the heathen inherit his wrath.","searchKeywords":["hath","turned","the","waters","into","saltness","shall","heathen","inherit","his","wrath"]},{"verseId":"brenton_sirach_39_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":24,"text":"As his ways are plain unto the holy; so are they stumbling-blocks unto the wicked.","searchKeywords":["his","ways","are","plain","unto","the","holy","they","stumbling","blocks","wicked"]},{"verseId":"brenton_sirach_39_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":25,"text":"For the good are good things created from the beginning: so evil things for sinners.","searchKeywords":["for","the","good","are","things","created","from","beginning","evil","sinners"]},{"verseId":"brenton_sirach_39_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":26,"text":"The principal things for the whole use of man's life are water, fire, iron, and salt, flour of wheat, honey, milk, and the blood of the grape, and oil, and clothing.","searchKeywords":["the","principal","things","for","whole","use","man","life","are","water","fire","iron","and","salt","flour","wheat","honey","milk","blood","grape","oil","clothing"]},{"verseId":"brenton_sirach_39_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":27,"text":"All these things are for good to the godly: so to the sinners they are turned into evil.","searchKeywords":["all","these","things","are","for","good","the","godly","sinners","they","turned","into","evil"]},{"verseId":"brenton_sirach_39_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":28,"text":"There be spirits that are created for vengeance, which in their fury lay on sore strokes; in the time of destruction they pour out their force, and appease the wrath of him that made them.","searchKeywords":["there","spirits","that","are","created","for","vengeance","which","their","fury","lay","sore","strokes","the","time","destruction","they","pour","out","force","and","appease","wrath","him","made","them"]},{"verseId":"brenton_sirach_39_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":29,"text":"Fire, and hail, and famine, and death, all these were created for vengeance;","searchKeywords":["fire","and","hail","famine","death","all","these","were","created","for","vengeance"]},{"verseId":"brenton_sirach_39_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":30,"text":"teeth of wild beasts, and scorpions, serpents, and the sword, punishing the wicked to destruction,","searchKeywords":["teeth","wild","beasts","and","scorpions","serpents","the","sword","punishing","wicked","destruction"]},{"verseId":"brenton_sirach_39_31","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":31,"text":"shall rejoice in his commandment, and they shall be ready upon earth, when need is; and when their time is come, they shall not go beyond his word.","searchKeywords":["shall","rejoice","his","commandment","and","they","ready","upon","earth","when","need","their","time","come","not","beyond","word"]},{"verseId":"brenton_sirach_39_32","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":32,"text":"Therefore from the beginning I was resolved, and thought upon these things, and have left them in writing.","searchKeywords":["therefore","from","the","beginning","was","resolved","and","thought","upon","these","things","have","left","them","writing"]},{"verseId":"brenton_sirach_39_33","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":33,"text":"All the works of the Lord are good: and he will give every needful thing in due season.","searchKeywords":["all","the","works","lord","are","good","and","will","give","every","needful","thing","due","season"]},{"verseId":"brenton_sirach_39_34","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":34,"text":"So that a man cannot say, This is worse than that: for in time they shall all be well approved.","searchKeywords":["that","man","cannot","say","this","worse","than","for","time","they","shall","all","well","approved"]},{"verseId":"brenton_sirach_39_35","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":39,"verse":35,"text":"And therefore praise ye the Lord with the whole heart and mouth, and bless the name of the Lord.","searchKeywords":["and","therefore","praise","the","lord","with","whole","heart","mouth","bless","name"]}]