[{"verseId":"brenton_sirach_41_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":1,"text":"O death, how bitter is the remembrance of thee to a man that liveth at rest in his possessions, unto the man that hath nothing to vex him, and that hath prosperity in all things: yea, unto him that is yet able to receive meat!","searchKeywords":["death","how","bitter","the","remembrance","thee","man","that","liveth","rest","his","possessions","unto","hath","nothing","vex","him","and","prosperity","all","things","yea","yet","able","receive","meat"]},{"verseId":"brenton_sirach_41_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":2,"text":"O death, acceptable is thy sentence unto the needy, and unto him whose strength faileth, that is now in the last age, and is vexed with all things, and to him that despaireth, and hath lost patience!","searchKeywords":["death","acceptable","thy","sentence","unto","the","needy","and","him","whose","strength","faileth","that","now","last","age","vexed","with","all","things","despaireth","hath","lost","patience"]},{"verseId":"brenton_sirach_41_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":3,"text":"Fear not the sentence of death, remember them that have been before thee, and that come after; for this is the sentence of the Lord over all flesh.","searchKeywords":["fear","not","the","sentence","death","remember","them","that","have","been","before","thee","and","come","after","for","this","lord","over","all","flesh"]},{"verseId":"brenton_sirach_41_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":4,"text":"And why art thou against the pleasure of the most High? there is no inquisition in the grave, whether thou have lived ten, or an hundred, or a thousand years.","searchKeywords":["and","why","art","thou","against","the","pleasure","most","high","there","inquisition","grave","whether","have","lived","ten","hundred","thousand","years"]},{"verseId":"brenton_sirach_41_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":5,"text":"The children of sinners are abominable children, and they that are conversant in the dwelling of the ungodly.","searchKeywords":["the","children","sinners","are","abominable","and","they","that","conversant","dwelling","ungodly"]},{"verseId":"brenton_sirach_41_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":6,"text":"The inheritance of sinners' children shall perish, and from their posterity shall be a perpetual reproach.","searchKeywords":["the","inheritance","sinners","children","shall","perish","and","from","their","posterity","perpetual","reproach"]},{"verseId":"brenton_sirach_41_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":7,"text":"The children will complain of an ungodly father, because they will be reproached for his sake.","searchKeywords":["the","children","will","complain","ungodly","father","because","they","reproached","for","his","sake"]},{"verseId":"brenton_sirach_41_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":8,"text":"Who be unto you, ungodly men, which have forsaken the law of the most high God! for if ye increase, it shall be to your destruction:","searchKeywords":["who","unto","you","ungodly","men","which","have","forsaken","the","law","most","high","god","for","increase","shall","your","destruction"]},{"verseId":"brenton_sirach_41_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":9,"text":"and if ye be born, ye shall be born to a curse: and if ye die, a curse shall be your portion.","searchKeywords":["and","born","shall","curse","die","your","portion"]},{"verseId":"brenton_sirach_41_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":10,"text":"All that are of the earth shall turn to earth again: so the ungodly shall go from a curse to destruction.","searchKeywords":["all","that","are","the","earth","shall","turn","again","ungodly","from","curse","destruction"]},{"verseId":"brenton_sirach_41_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":11,"text":"The mourning of men is about their bodies: but an ill name of sinners shall be blotted out.","searchKeywords":["the","mourning","men","about","their","bodies","but","ill","name","sinners","shall","blotted","out"]},{"verseId":"brenton_sirach_41_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":12,"text":"Have regard to thy name; for that shall continue with thee above a thousand great treasures of gold.","searchKeywords":["have","regard","thy","name","for","that","shall","continue","with","thee","above","thousand","great","treasures","gold"]},{"verseId":"brenton_sirach_41_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":13,"text":"A good life hath but few days: but a good name endureth for ever.","searchKeywords":["good","life","hath","but","few","days","name","endureth","for","ever"]},{"verseId":"brenton_sirach_41_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":14,"text":"My children, keep discipline in peace: for wisdom that is hid, and a treasure that is not seen, what profit is in them both?","searchKeywords":["children","keep","discipline","peace","for","wisdom","that","hid","and","treasure","not","seen","what","profit","them","both"]},{"verseId":"brenton_sirach_41_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":15,"text":"A man that hideth his foolishness is better than a man that hideth his wisdom.","searchKeywords":["man","that","hideth","his","foolishness","better","than","wisdom"]},{"verseId":"brenton_sirach_41_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":16,"text":"Therefore be shamefaced according to my word: for it is not good to retain all shamefacedness; neither is it altogether approved in every thing.","searchKeywords":["therefore","shamefaced","according","word","for","not","good","retain","all","shamefacedness","neither","altogether","approved","every","thing"]},{"verseId":"brenton_sirach_41_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":17,"text":"Be ashamed of whoredom before father and mother: and of a lie before a prince and a mighty man;","searchKeywords":["ashamed","whoredom","before","father","and","mother","lie","prince","mighty","man"]},{"verseId":"brenton_sirach_41_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":18,"text":"of an offence before a judge and ruler; of iniquity before a congregation and people; of unjust dealing before thy partner and friend;","searchKeywords":["offence","before","judge","and","ruler","iniquity","congregation","people","unjust","dealing","thy","partner","friend"]},{"verseId":"brenton_sirach_41_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":19,"text":"and of theft in regard of the place where thou sojournest, and in regard of the truth of God and his covenant; and to lean with thine elbow upon the meat; and of scorning to give and take;","searchKeywords":["and","theft","regard","the","place","where","thou","sojournest","truth","god","his","covenant","lean","with","thine","elbow","upon","meat","scorning","give","take"]},{"verseId":"brenton_sirach_41_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":20,"text":"and of silence before them that salute thee; and to look upon an harlot;","searchKeywords":["and","silence","before","them","that","salute","thee","look","upon","harlot"]},{"verseId":"brenton_sirach_41_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":21,"text":"and to turn away thy face from thy kinsman; or to take away a portion or a gift; or to gaze upon another man's wife;","searchKeywords":["and","turn","away","thy","face","from","kinsman","take","portion","gift","gaze","upon","another","man","wife"]},{"verseId":"brenton_sirach_41_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":22,"text":"or to be overbusy with his maid, and come not near her bed; or of upbraiding speeches before friends; and after thou hast given, upbraid not;","searchKeywords":["overbusy","with","his","maid","and","come","not","near","her","bed","upbraiding","speeches","before","friends","after","thou","hast","given","upbraid"]},{"verseId":"brenton_sirach_41_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":23,"text":"Or of iterating and speaking again that which thou hast heard; and of revealing of secrets;","searchKeywords":["iterating","and","speaking","again","that","which","thou","hast","heard","revealing","secrets"]},{"verseId":"brenton_sirach_41_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":41,"verse":24,"text":"so shalt thou be truly shamefaced, and find favour before all men.","searchKeywords":["shalt","thou","truly","shamefaced","and","find","favour","before","all","men"]}]