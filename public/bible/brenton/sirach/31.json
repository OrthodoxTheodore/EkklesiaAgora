[{"verseId":"brenton_sirach_31_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":1,"text":"The hopes of a man void of understanding are vain and false: and dreams lift up fools.","searchKeywords":["the","hopes","man","void","understanding","are","vain","and","false","dreams","lift","fools"]},{"verseId":"brenton_sirach_31_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":2,"text":"Whoso regardeth dreams is like him that catcheth at a shadow, and followeth after the wind.","searchKeywords":["whoso","regardeth","dreams","like","him","that","catcheth","shadow","and","followeth","after","the","wind"]},{"verseId":"brenton_sirach_31_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":3,"text":"The vision of dreams is the resemblance of one thing to another, even as the likeness of a face to a face.","searchKeywords":["the","vision","dreams","resemblance","one","thing","another","even","likeness","face"]},{"verseId":"brenton_sirach_31_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":4,"text":"Of an unclean thing what can be cleansed? and from that thing which is false what truth can come?","searchKeywords":["unclean","thing","what","can","cleansed","and","from","that","which","false","truth","come"]},{"verseId":"brenton_sirach_31_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":5,"text":"Divinations, and soothsayings, and dreams, are vain: and the heart fancieth, as a woman's heart in travail.","searchKeywords":["divinations","and","soothsayings","dreams","are","vain","the","heart","fancieth","woman","travail"]},{"verseId":"brenton_sirach_31_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":6,"text":"If they be not sent from the most High in thy visitation, set not thy heart upon them.","searchKeywords":["they","not","sent","from","the","most","high","thy","visitation","set","heart","upon","them"]},{"verseId":"brenton_sirach_31_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":7,"text":"For dreams have deceived many, and they have failed that put their trust in them.","searchKeywords":["for","dreams","have","deceived","many","and","they","failed","that","put","their","trust","them"]},{"verseId":"brenton_sirach_31_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":8,"text":"The law shall be found perfect without lies: and wisdom is perfection to a faithful mouth.","searchKeywords":["the","law","shall","found","perfect","without","lies","and","wisdom","perfection","faithful","mouth"]},{"verseId":"brenton_sirach_31_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":9,"text":"A man that hath travelled knoweth many things: and he that hath much experience will declare wisdom.","searchKeywords":["man","that","hath","travelled","knoweth","many","things","and","much","experience","will","declare","wisdom"]},{"verseId":"brenton_sirach_31_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":10,"text":"He that hath no experience knoweth little: but he that hath travelled is full of prudence.","searchKeywords":["that","hath","experience","knoweth","little","but","travelled","full","prudence"]},{"verseId":"brenton_sirach_31_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":11,"text":"When I travelled, I saw many things; and I understand more than I can express.","searchKeywords":["when","travelled","saw","many","things","and","understand","more","than","can","express"]},{"verseId":"brenton_sirach_31_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":12,"text":"I was oft-times in danger of death: yet I was delivered because of these things.","searchKeywords":["was","oft","times","danger","death","yet","delivered","because","these","things"]},{"verseId":"brenton_sirach_31_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":13,"text":"The spirit of those that fear the Lord shall live; for their hope is in him that saveth them.","searchKeywords":["the","spirit","those","that","fear","lord","shall","live","for","their","hope","him","saveth","them"]},{"verseId":"brenton_sirach_31_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":14,"text":"Whoso feareth the Lord shall not fear nor be afraid; for he is his hope.","searchKeywords":["whoso","feareth","the","lord","shall","not","fear","nor","afraid","for","his","hope"]},{"verseId":"brenton_sirach_31_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":15,"text":"Blessed is the soul of him that feareth the Lord: to whom doth he look? and who is his strength?","searchKeywords":["blessed","the","soul","him","that","feareth","lord","whom","doth","look","and","who","his","strength"]},{"verseId":"brenton_sirach_31_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":16,"text":"For the eyes of the Lord are upon them that love him, he is their mighty protection and strong stay, a defence from heat, and a cover from the sun at noon, a preservation from stumbling, and an help from falling;","searchKeywords":["for","the","eyes","lord","are","upon","them","that","love","him","their","mighty","protection","and","strong","stay","defence","from","heat","cover","sun","noon","preservation","stumbling","help","falling"]},{"verseId":"brenton_sirach_31_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":17,"text":"he raiseth up the soul, and lighteneth the eyes: he giveth health, life, and blessing.","searchKeywords":["raiseth","the","soul","and","lighteneth","eyes","giveth","health","life","blessing"]},{"verseId":"brenton_sirach_31_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":18,"text":"He that sacrificeth of a thing wrongfully gotten, his offering is ridiculous; and the gifts of unjust men are not accepted.","searchKeywords":["that","sacrificeth","thing","wrongfully","gotten","his","offering","ridiculous","and","the","gifts","unjust","men","are","not","accepted"]},{"verseId":"brenton_sirach_31_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":19,"text":"The most High is not pleased with the offerings of the wicked; neither is he pacified for sin by the multitude of sacrifices.","searchKeywords":["the","most","high","not","pleased","with","offerings","wicked","neither","pacified","for","sin","multitude","sacrifices"]},{"verseId":"brenton_sirach_31_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":20,"text":"Whoso bringeth an offering of the goods of the poor doeth as one that killeth the son before his father's eyes.","searchKeywords":["whoso","bringeth","offering","the","goods","poor","doeth","one","that","killeth","son","before","his","father","eyes"]},{"verseId":"brenton_sirach_31_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":21,"text":"The bread of the needy is their life: he that defraudeth him thereof is a man of blood.","searchKeywords":["the","bread","needy","their","life","that","defraudeth","him","thereof","man","blood"]},{"verseId":"brenton_sirach_31_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":22,"text":"He that taketh away his neighbour's living slayeth him; and he that defraudeth the labourer his hire is a bloodshedder.","searchKeywords":["that","taketh","away","his","neighbour","living","slayeth","him","and","defraudeth","the","labourer","hire","bloodshedder"]},{"verseId":"brenton_sirach_31_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":23,"text":"When one buildeth, and another pulleth down, what profit have they then but labour?","searchKeywords":["when","one","buildeth","and","another","pulleth","down","what","profit","have","they","then","but","labour"]},{"verseId":"brenton_sirach_31_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":24,"text":"When one prayeth, and another curseth, whose voice will the Lord hear?","searchKeywords":["when","one","prayeth","and","another","curseth","whose","voice","will","the","lord","hear"]},{"verseId":"brenton_sirach_31_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":25,"text":"He that washeth himself after the touching of a dead body, if he touch it again, what availeth his washing?","searchKeywords":["that","washeth","himself","after","the","touching","dead","body","touch","again","what","availeth","his","washing"]},{"verseId":"brenton_sirach_31_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":31,"verse":26,"text":"So is it with a man that fasteth for his sins, and goeth again, and doeth the same: who will hear his prayer? or what doth his humbling profit him?","searchKeywords":["with","man","that","fasteth","for","his","sins","and","goeth","again","doeth","the","same","who","will","hear","prayer","what","doth","humbling","profit","him"]}]