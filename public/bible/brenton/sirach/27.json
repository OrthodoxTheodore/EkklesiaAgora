[{"verseId":"brenton_sirach_27_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":1,"text":"Many have sinned for a small matter; and he that seeketh for abundance will turn his eyes away.","searchKeywords":["many","have","sinned","for","small","matter","and","that","seeketh","abundance","will","turn","his","eyes","away"]},{"verseId":"brenton_sirach_27_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":2,"text":"As a nail sticketh fast between the joinings of the stones; so doth sin stick close between buying and selling.","searchKeywords":["nail","sticketh","fast","between","the","joinings","stones","doth","sin","stick","close","buying","and","selling"]},{"verseId":"brenton_sirach_27_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":3,"text":"Unless a man hold himself diligently in the fear of the Lord, his house shall soon be overthrown.","searchKeywords":["unless","man","hold","himself","diligently","the","fear","lord","his","house","shall","soon","overthrown"]},{"verseId":"brenton_sirach_27_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":4,"text":"As when one sifteth with a sieve, the refuse remaineth; so the filth of man in his talk.","searchKeywords":["when","one","sifteth","with","sieve","the","refuse","remaineth","filth","man","his","talk"]},{"verseId":"brenton_sirach_27_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":5,"text":"The furnace proveth the potter's vessels; so the trial of man is in his reasoning.","searchKeywords":["the","furnace","proveth","potter","vessels","trial","man","his","reasoning"]},{"verseId":"brenton_sirach_27_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":6,"text":"The fruit declareth if the tree have been dressed; so is the utterance of a conceit in the heart of man.","searchKeywords":["the","fruit","declareth","tree","have","been","dressed","utterance","conceit","heart","man"]},{"verseId":"brenton_sirach_27_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":7,"text":"Praise no man before thou hearest him speak; for this is the trial of men.","searchKeywords":["praise","man","before","thou","hearest","him","speak","for","this","the","trial","men"]},{"verseId":"brenton_sirach_27_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":8,"text":"If thou followest righteousness, thou shalt obtain her, and put her on, as a glorious long robe.","searchKeywords":["thou","followest","righteousness","shalt","obtain","her","and","put","glorious","long","robe"]},{"verseId":"brenton_sirach_27_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":9,"text":"The birds will resort unto their like; so will truth return unto them that practise in her.","searchKeywords":["the","birds","will","resort","unto","their","like","truth","return","them","that","practise","her"]},{"verseId":"brenton_sirach_27_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":10,"text":"As the lion lieth in wait for the prey; so sin for them that work iniquity.","searchKeywords":["the","lion","lieth","wait","for","prey","sin","them","that","work","iniquity"]},{"verseId":"brenton_sirach_27_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":11,"text":"The discourse of a godly man is always with wisdom; but a fool changeth as the moon.","searchKeywords":["the","discourse","godly","man","always","with","wisdom","but","fool","changeth","moon"]},{"verseId":"brenton_sirach_27_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":12,"text":"If thou be among the indiscreet, observe the time; but be continually among men of understanding.","searchKeywords":["thou","among","the","indiscreet","observe","time","but","continually","men","understanding"]},{"verseId":"brenton_sirach_27_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":13,"text":"The discourse of fools is irksome, and their sport is the wantonness of sin.","searchKeywords":["the","discourse","fools","irksome","and","their","sport","wantonness","sin"]},{"verseId":"brenton_sirach_27_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":14,"text":"The talk of him that sweareth much maketh the hair stand upright; and their brawls make one stop his ears.","searchKeywords":["the","talk","him","that","sweareth","much","maketh","hair","stand","upright","and","their","brawls","make","one","stop","his","ears"]},{"verseId":"brenton_sirach_27_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":15,"text":"The strife of the proud is bloodshedding, and their revilings are grievous to the ear.","searchKeywords":["the","strife","proud","bloodshedding","and","their","revilings","are","grievous","ear"]},{"verseId":"brenton_sirach_27_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":16,"text":"Whoso discovereth secrets loseth his credit; and shall never find friend to his mind.","searchKeywords":["whoso","discovereth","secrets","loseth","his","credit","and","shall","never","find","friend","mind"]},{"verseId":"brenton_sirach_27_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":17,"text":"Love thy friend, and be faithful unto him: but if thou betrayest his secrets, follow no more after him.","searchKeywords":["love","thy","friend","and","faithful","unto","him","but","thou","betrayest","his","secrets","follow","more","after"]},{"verseId":"brenton_sirach_27_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":18,"text":"For as a man hath destroyed his enemy; so hast thou lost the love of thy neighbour.","searchKeywords":["for","man","hath","destroyed","his","enemy","hast","thou","lost","the","love","thy","neighbour"]},{"verseId":"brenton_sirach_27_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":19,"text":"As one that letteth a bird go out of his hand, so hast thou let thy neighbour go, and shalt not get him again.","searchKeywords":["one","that","letteth","bird","out","his","hand","hast","thou","let","thy","neighbour","and","shalt","not","get","him","again"]},{"verseId":"brenton_sirach_27_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":20,"text":"Follow after him no more, for he is too far off; he is as a roe escaped out of the snare.","searchKeywords":["follow","after","him","more","for","too","far","off","roe","escaped","out","the","snare"]},{"verseId":"brenton_sirach_27_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":21,"text":"As for a wound, it may be bound up; and after reviling there may be reconcilement: but he that betrayeth secrets is without hope.","searchKeywords":["for","wound","may","bound","and","after","reviling","there","reconcilement","but","that","betrayeth","secrets","without","hope"]},{"verseId":"brenton_sirach_27_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":22,"text":"He that winketh with the eyes worketh evil: and he that knoweth him will depart from him.","searchKeywords":["that","winketh","with","the","eyes","worketh","evil","and","knoweth","him","will","depart","from"]},{"verseId":"brenton_sirach_27_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":23,"text":"When thou art present, he will speak sweetly, and will admire thy words: but at the last he will writhe his mouth, and slander thy sayings.","searchKeywords":["when","thou","art","present","will","speak","sweetly","and","admire","thy","words","but","the","last","writhe","his","mouth","slander","sayings"]},{"verseId":"brenton_sirach_27_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":24,"text":"I have hated many things, but nothing like him; for the Lord will hate him.","searchKeywords":["have","hated","many","things","but","nothing","like","him","for","the","lord","will","hate"]},{"verseId":"brenton_sirach_27_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":25,"text":"Whoso casteth a stone on high casteth it on his own head; and a deceitful stroke shall make wounds.","searchKeywords":["whoso","casteth","stone","high","his","own","head","and","deceitful","stroke","shall","make","wounds"]},{"verseId":"brenton_sirach_27_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":26,"text":"Whoso diggeth a pit shall fall therein: and he that setteth a trap shall be taken therein.","searchKeywords":["whoso","diggeth","pit","shall","fall","therein","and","that","setteth","trap","taken"]},{"verseId":"brenton_sirach_27_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":27,"text":"He that worketh mischief, it shall fall upon him, and he shall not know whence it cometh.","searchKeywords":["that","worketh","mischief","shall","fall","upon","him","and","not","know","whence","cometh"]},{"verseId":"brenton_sirach_27_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":28,"text":"Mockery and reproach are from the proud; but vengeance, as a lion, shall lie in wait for him.","searchKeywords":["mockery","and","reproach","are","from","the","proud","but","vengeance","lion","shall","lie","wait","for","him"]},{"verseId":"brenton_sirach_27_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":29,"text":"They that rejoice at the fall of the righteous shall be taken in the snare; and anguish shall consume them before they die.","searchKeywords":["they","that","rejoice","the","fall","righteous","shall","taken","snare","and","anguish","consume","them","before","die"]},{"verseId":"brenton_sirach_27_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":27,"verse":30,"text":"Malice and wrath, even these are abominations; and the sinful man shall have them both.","searchKeywords":["malice","and","wrath","even","these","are","abominations","the","sinful","man","shall","have","them","both"]}]