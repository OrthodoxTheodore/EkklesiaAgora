[{"verseId":"brenton_sirach_48_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":1,"text":"Then stood up Elias the prophet as fire, and his word burned like a lamp.","searchKeywords":["then","stood","elias","the","prophet","fire","and","his","word","burned","like","lamp"]},{"verseId":"brenton_sirach_48_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":2,"text":"He brought a sore famine upon them, and by his zeal he diminished their number.","searchKeywords":["brought","sore","famine","upon","them","and","his","zeal","diminished","their","number"]},{"verseId":"brenton_sirach_48_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":3,"text":"By the word of the Lord he shut up the heaven, and also three times brought down fire.","searchKeywords":["the","word","lord","shut","heaven","and","also","three","times","brought","down","fire"]},{"verseId":"brenton_sirach_48_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":4,"text":"O Elias, how wast thou honoured in thy wondrous deeds! and who may glory like unto thee!","searchKeywords":["elias","how","wast","thou","honoured","thy","wondrous","deeds","and","who","may","glory","like","unto","thee"]},{"verseId":"brenton_sirach_48_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":5,"text":"Who didst raise up a dead man from death, and his soul from the place of the dead, by the word of the most High:","searchKeywords":["who","didst","raise","dead","man","from","death","and","his","soul","the","place","word","most","high"]},{"verseId":"brenton_sirach_48_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":6,"text":"who broughtest kings to destruction, and honourable men from their bed:","searchKeywords":["who","broughtest","kings","destruction","and","honourable","men","from","their","bed"]},{"verseId":"brenton_sirach_48_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":7,"text":"who heardest the rebuke of the Lord in Sinai, and in Horeb the judgment of vengeance:","searchKeywords":["who","heardest","the","rebuke","lord","sinai","and","horeb","judgment","vengeance"]},{"verseId":"brenton_sirach_48_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":8,"text":"who anointedst kings to take revenge, and prophets to succeed after him:","searchKeywords":["who","anointedst","kings","take","revenge","and","prophets","succeed","after","him"]},{"verseId":"brenton_sirach_48_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":9,"text":"who wast taken up in a whirlwind of fire, and in a chariot of fiery horses:","searchKeywords":["who","wast","taken","whirlwind","fire","and","chariot","fiery","horses"]},{"verseId":"brenton_sirach_48_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":10,"text":"who wast ordained for reproofs in their times, to pacify the wrath of the Lord's judgment, before it brake forth into fury, and to turn the heart of the father unto the son, and to restore the tribes of Jacob.","searchKeywords":["who","wast","ordained","for","reproofs","their","times","pacify","the","wrath","lord","judgment","before","brake","forth","into","fury","and","turn","heart","father","unto","son","restore","tribes","jacob"]},{"verseId":"brenton_sirach_48_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":11,"text":"Blessed are they that saw thee, and slept in love; for we shall surely live.","searchKeywords":["blessed","are","they","that","saw","thee","and","slept","love","for","shall","surely","live"]},{"verseId":"brenton_sirach_48_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":12,"text":"Elias it was, who was covered with a whirlwind; and Eliseus was filled with his spirit: whilst he lived, he was not moved of any prince, neither could any bring him into subjection.","searchKeywords":["elias","was","who","covered","with","whirlwind","and","eliseus","filled","his","spirit","whilst","lived","not","moved","any","prince","neither","could","bring","him","into","subjection"]},{"verseId":"brenton_sirach_48_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":13,"text":"No word could overcome him; and after his death his body prophesied.","searchKeywords":["word","could","overcome","him","and","after","his","death","body","prophesied"]},{"verseId":"brenton_sirach_48_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":14,"text":"He did wonders in his life, and at his death were his works marvellous.","searchKeywords":["did","wonders","his","life","and","death","were","works","marvellous"]},{"verseId":"brenton_sirach_48_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":15,"text":"For all this the people repented not, neither departed they from their sins, till they were spoiled and carried out of their land, and were scattered through all the earth: yet there remained a small people, and a ruler in the house of David:","searchKeywords":["for","all","this","the","people","repented","not","neither","departed","they","from","their","sins","till","were","spoiled","and","carried","out","land","scattered","through","earth","yet","there","remained","small","ruler","house","david"]},{"verseId":"brenton_sirach_48_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":16,"text":"of whom some did that which was pleasing , and some multiplied sins.","searchKeywords":["whom","some","did","that","which","was","pleasing","and","multiplied","sins"]},{"verseId":"brenton_sirach_48_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":17,"text":"Ezekias fortified his city, and brought in water into the midst thereof: he digged the hard rock with iron, and made wells for waters.","searchKeywords":["ezekias","fortified","his","city","and","brought","water","into","the","midst","thereof","digged","hard","rock","with","iron","made","wells","for","waters"]},{"verseId":"brenton_sirach_48_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":18,"text":"In his time Sennacherib came up, and sent Rabsaces, and lifted up his hand against Sion, and boasted proudly.","searchKeywords":["his","time","sennacherib","came","and","sent","rabsaces","lifted","hand","against","sion","boasted","proudly"]},{"verseId":"brenton_sirach_48_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":19,"text":"Then trembled their hearts and hands, and they were in pain, as women in travail.","searchKeywords":["then","trembled","their","hearts","and","hands","they","were","pain","women","travail"]},{"verseId":"brenton_sirach_48_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":20,"text":"But they called upon the Lord who is merciful, and stretched out their hands toward him: and immediately the Holy One heard them out of heaven, and delivered them by the ministry of Esay.","searchKeywords":["but","they","called","upon","the","lord","who","merciful","and","stretched","out","their","hands","toward","him","immediately","holy","one","heard","them","heaven","delivered","ministry","esay"]},{"verseId":"brenton_sirach_48_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":21,"text":"He smote the host of the Assyrians, and his angel destroyed them.","searchKeywords":["smote","the","host","assyrians","and","his","angel","destroyed","them"]},{"verseId":"brenton_sirach_48_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":22,"text":"For Ezekias had done the thing that pleased the Lord, and was strong in the ways of David his father, as Esay the prophet, who was great and faithful in his vision, had commanded him.","searchKeywords":["for","ezekias","had","done","the","thing","that","pleased","lord","and","was","strong","ways","david","his","father","esay","prophet","who","great","faithful","vision","commanded","him"]},{"verseId":"brenton_sirach_48_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":23,"text":"In his time the sun went backward, and he lengthened the king's life.","searchKeywords":["his","time","the","sun","went","backward","and","lengthened","king","life"]},{"verseId":"brenton_sirach_48_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":24,"text":"He saw by an excellent spirit what should come to pass at the last, and he comforted them that mourned in Sion.","searchKeywords":["saw","excellent","spirit","what","should","come","pass","the","last","and","comforted","them","that","mourned","sion"]},{"verseId":"brenton_sirach_48_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":48,"verse":25,"text":"He shewed what should come to pass for ever, and secret things or ever they came.","searchKeywords":["shewed","what","should","come","pass","for","ever","and","secret","things","they","came"]}]