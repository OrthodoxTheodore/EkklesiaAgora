[{"verseId":"brenton_sirach_25_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":1,"text":"In three things I was beautified, and stood up beautiful both before God and men: the unity of brethren, the love of neighbours, a man and a wife that agree together.","searchKeywords":["three","things","was","beautified","and","stood","beautiful","both","before","god","men","the","unity","brethren","love","neighbours","man","wife","that","agree","together"]},{"verseId":"brenton_sirach_25_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":2,"text":"Three sorts of men my soul hateth, and I am greatly offended at their life: a poor man that is proud, a rich man that is a liar, and an old adulterer that doateth.","searchKeywords":["three","sorts","men","soul","hateth","and","greatly","offended","their","life","poor","man","that","proud","rich","liar","old","adulterer","doateth"]},{"verseId":"brenton_sirach_25_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":3,"text":"If thou hast gathered nothing in thy youth, how canst thou find any thing in thine age?","searchKeywords":["thou","hast","gathered","nothing","thy","youth","how","canst","find","any","thing","thine","age"]},{"verseId":"brenton_sirach_25_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":4,"text":"O how comely a thing is judgment for grey hairs, and for ancient men to know counsel!","searchKeywords":["how","comely","thing","judgment","for","grey","hairs","and","ancient","men","know","counsel"]},{"verseId":"brenton_sirach_25_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":5,"text":"O how comely is the wisdom of old men, and understanding and counsel to men of honour!","searchKeywords":["how","comely","the","wisdom","old","men","and","understanding","counsel","honour"]},{"verseId":"brenton_sirach_25_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":6,"text":"Much experience is the crown of old men, and the fear of God is their glory.","searchKeywords":["much","experience","the","crown","old","men","and","fear","god","their","glory"]},{"verseId":"brenton_sirach_25_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":7,"text":"There be nine things which I have judged in mine heart to be happy, and the tenth I will utter with my tongue: A man that hath joy of his children; and he that liveth to see the fall of his enemy.","searchKeywords":["there","nine","things","which","have","judged","mine","heart","happy","and","the","tenth","will","utter","with","tongue","man","that","hath","joy","his","children","liveth","see","fall","enemy"]},{"verseId":"brenton_sirach_25_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":8,"text":"Well is he that dwelleth with a wife of understanding, and that hath not slipped with his tongue, and that hath not served a man more unworthy than himself.","searchKeywords":["well","that","dwelleth","with","wife","understanding","and","hath","not","slipped","his","tongue","served","man","more","unworthy","than","himself"]},{"verseId":"brenton_sirach_25_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":9,"text":"Well is he that hath found prudence, and he that speaketh in the ears of them that will hear:","searchKeywords":["well","that","hath","found","prudence","and","speaketh","the","ears","them","will","hear"]},{"verseId":"brenton_sirach_25_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":10,"text":"O how great is he that findeth wisdom! yet there is none above him that feareth the Lord.","searchKeywords":["how","great","that","findeth","wisdom","yet","there","none","above","him","feareth","the","lord"]},{"verseId":"brenton_sirach_25_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":11,"text":"But the love of the Lord passeth all things for illumination: he that holdeth it, whereto shall he be likened?","searchKeywords":["but","the","love","lord","passeth","all","things","for","illumination","that","holdeth","whereto","shall","likened"]},{"verseId":"brenton_sirach_25_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":13,"text":"[Give me] any plague, but the plague of the heart: and any wickedness, but the wickedness of a woman:","searchKeywords":["give","any","plague","but","the","heart","and","wickedness","woman"]},{"verseId":"brenton_sirach_25_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":14,"text":"and any affliction, but the affliction from them that hate me: and any revenge, but the revenge of enemies.","searchKeywords":["and","any","affliction","but","the","from","them","that","hate","revenge","enemies"]},{"verseId":"brenton_sirach_25_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":15,"text":"There is no head above the head of a serpent; and there is no wrath above the wrath of an enemy.","searchKeywords":["there","head","above","the","serpent","and","wrath","enemy"]},{"verseId":"brenton_sirach_25_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":16,"text":"I had rather dwell with a lion and a dragon, than to keep house with a wicked woman.","searchKeywords":["had","rather","dwell","with","lion","and","dragon","than","keep","house","wicked","woman"]},{"verseId":"brenton_sirach_25_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":17,"text":"The wickedness of a woman changeth her face, and darkeneth her countenance like sackcloth.","searchKeywords":["the","wickedness","woman","changeth","her","face","and","darkeneth","countenance","like","sackcloth"]},{"verseId":"brenton_sirach_25_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":18,"text":"Her husband shall sit among his neighbours; and when he heareth it shall sigh bitterly.","searchKeywords":["her","husband","shall","sit","among","his","neighbours","and","when","heareth","sigh","bitterly"]},{"verseId":"brenton_sirach_25_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":19,"text":"All wickedness is but little to the wickedness of a woman; let the portion of a sinner fall upon her.","searchKeywords":["all","wickedness","but","little","the","woman","let","portion","sinner","fall","upon","her"]},{"verseId":"brenton_sirach_25_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":20,"text":"As the climbing up a sandy way is to the feet of the aged, so is a wife full of words to a quiet man.","searchKeywords":["the","climbing","sandy","way","feet","aged","wife","full","words","quiet","man"]},{"verseId":"brenton_sirach_25_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":21,"text":"Stumble not at the beauty of a woman, and desire her not for pleasure.","searchKeywords":["stumble","not","the","beauty","woman","and","desire","her","for","pleasure"]},{"verseId":"brenton_sirach_25_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":22,"text":"A woman, if she maintain her husband, is full of anger, impudence, and much reproach.","searchKeywords":["woman","she","maintain","her","husband","full","anger","impudence","and","much","reproach"]},{"verseId":"brenton_sirach_25_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":23,"text":"A wicked woman abateth the courage, maketh an heavy countenance and a wounded heart: a woman that will not comfort her husband in distress maketh weak hands and feeble knees.","searchKeywords":["wicked","woman","abateth","the","courage","maketh","heavy","countenance","and","wounded","heart","that","will","not","comfort","her","husband","distress","weak","hands","feeble","knees"]},{"verseId":"brenton_sirach_25_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":24,"text":"Of the woman came the beginning of sin, and through her we all die.","searchKeywords":["the","woman","came","beginning","sin","and","through","her","all","die"]},{"verseId":"brenton_sirach_25_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":25,"text":"Give the water no passage; neither a wicked woman liberty to gad abroad.","searchKeywords":["give","the","water","passage","neither","wicked","woman","liberty","gad","abroad"]},{"verseId":"brenton_sirach_25_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":25,"verse":26,"text":"If she go not as thou wouldest have her, cut her off from thy flesh, and give her a bill of divorce, and let her go.","searchKeywords":["she","not","thou","wouldest","have","her","cut","off","from","thy","flesh","and","give","bill","divorce","let"]}]