[{"verseId":"brenton_sirach_47_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":1,"text":"And after him rose up Nathan to prophesy in the time of David.","searchKeywords":["and","after","him","rose","nathan","prophesy","the","time","david"]},{"verseId":"brenton_sirach_47_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":2,"text":"As is the fat taken away from the peace offering, so was David chosen out of the children of Israel.","searchKeywords":["the","fat","taken","away","from","peace","offering","was","david","chosen","out","children","israel"]},{"verseId":"brenton_sirach_47_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":3,"text":"He played with lions as with kids, and with bears as with lambs.","searchKeywords":["played","with","lions","kids","and","bears","lambs"]},{"verseId":"brenton_sirach_47_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":4,"text":"Slew he not a giant, when he was yet but young? and did he not take away reproach from the people, when he lifted up his hand with the stone in the sling, and beat down the boasting of Goliath?","searchKeywords":["slew","not","giant","when","was","yet","but","young","and","did","take","away","reproach","from","the","people","lifted","his","hand","with","stone","sling","beat","down","boasting","goliath"]},{"verseId":"brenton_sirach_47_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":5,"text":"for he called upon the most high Lord; and he gave him strength in his right hand to slay that mighty warrior, and set up the horn of his people.","searchKeywords":["for","called","upon","the","most","high","lord","and","gave","him","strength","his","right","hand","slay","that","mighty","warrior","set","horn","people"]},{"verseId":"brenton_sirach_47_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":6,"text":"So the people honoured him with ten thousands, and praised him in the blessings of the Lord in that he gave him a crown of glory.","searchKeywords":["the","people","honoured","him","with","ten","thousands","and","praised","blessings","lord","that","gave","crown","glory"]},{"verseId":"brenton_sirach_47_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":7,"text":"For he destroyed the enemies on every side, and brought to nought the Philistines his adversaries, and brake their horn in sunder unto this day.","searchKeywords":["for","destroyed","the","enemies","every","side","and","brought","nought","philistines","his","adversaries","brake","their","horn","sunder","unto","this","day"]},{"verseId":"brenton_sirach_47_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":8,"text":"In all his works he praised the Holy One most high with words of glory; with his whole heart he sang songs, and loved him that made him.","searchKeywords":["all","his","works","praised","the","holy","one","most","high","with","words","glory","whole","heart","sang","songs","and","loved","him","that","made"]},{"verseId":"brenton_sirach_47_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":9,"text":"He set singers also before the altar, that by their voices they might make sweet melody, and daily sing praises in their songs.","searchKeywords":["set","singers","also","before","the","altar","that","their","voices","they","might","make","sweet","melody","and","daily","sing","praises","songs"]},{"verseId":"brenton_sirach_47_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":10,"text":"He beautified their feasts, and set in order the solemn times until the end, that they might praise his holy name, and that the temple might sound from morning.","searchKeywords":["beautified","their","feasts","and","set","order","the","solemn","times","until","end","that","they","might","praise","his","holy","name","temple","sound","from","morning"]},{"verseId":"brenton_sirach_47_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":11,"text":"The Lord took away his sins, and exalted his horn for ever: he gave him a covenant of kings, and a throne of glory in Israel.","searchKeywords":["the","lord","took","away","his","sins","and","exalted","horn","for","ever","gave","him","covenant","kings","throne","glory","israel"]},{"verseId":"brenton_sirach_47_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":12,"text":"After him rose up a wise son, and for his sake he dwelt at large.","searchKeywords":["after","him","rose","wise","son","and","for","his","sake","dwelt","large"]},{"verseId":"brenton_sirach_47_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":13,"text":"Solomon reigned in a peaceable time, and was honoured; for God made all quiet round about him, that he might build an house in his name, and prepare his sanctuary for ever.","searchKeywords":["solomon","reigned","peaceable","time","and","was","honoured","for","god","made","all","quiet","round","about","him","that","might","build","house","his","name","prepare","sanctuary","ever"]},{"verseId":"brenton_sirach_47_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":14,"text":"How wise wast thou in thy youth, and, as a flood, filled with understanding!","searchKeywords":["how","wise","wast","thou","thy","youth","and","flood","filled","with","understanding"]},{"verseId":"brenton_sirach_47_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":15,"text":"Thy soul covered the whole earth, and thou filledst it with dark parables.","searchKeywords":["thy","soul","covered","the","whole","earth","and","thou","filledst","with","dark","parables"]},{"verseId":"brenton_sirach_47_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":16,"text":"Thy name went far unto the islands; and for thy peace thou wast beloved.","searchKeywords":["thy","name","went","far","unto","the","islands","and","for","peace","thou","wast","beloved"]},{"verseId":"brenton_sirach_47_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":17,"text":"The countries marvelled at thee for thy songs, and proverbs, and parables, and interpretations.","searchKeywords":["the","countries","marvelled","thee","for","thy","songs","and","proverbs","parables","interpretations"]},{"verseId":"brenton_sirach_47_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":18,"text":"By the name of the Lord God, which is called the Lord God of Israel, thou didst gather gold as tin, and didst multiply silver as lead.","searchKeywords":["the","name","lord","god","which","called","israel","thou","didst","gather","gold","tin","and","multiply","silver","lead"]},{"verseId":"brenton_sirach_47_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":19,"text":"Thou didst bow thy loins unto women, and by thy body thou wast brought into subjection.","searchKeywords":["thou","didst","bow","thy","loins","unto","women","and","body","wast","brought","into","subjection"]},{"verseId":"brenton_sirach_47_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":20,"text":"Thou didst stain thy honour, and pollute thy seed: so that thou broughtest wrath upon thy children, and wast grieved for thy folly.","searchKeywords":["thou","didst","stain","thy","honour","and","pollute","seed","that","broughtest","wrath","upon","children","wast","grieved","for","folly"]},{"verseId":"brenton_sirach_47_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":21,"text":"So the kingdom was divided, and out of Ephraim ruled a rebellious kingdom.","searchKeywords":["the","kingdom","was","divided","and","out","ephraim","ruled","rebellious"]},{"verseId":"brenton_sirach_47_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":22,"text":"But the Lord will never leave off his mercy, neither shall any of his works perish, neither will he abolish the posterity of his elect, and the seed of him that loveth him he will not take away: wherefore he gave a remnant unto Jacob, and out of him a root unto David.","searchKeywords":["but","the","lord","will","never","leave","off","his","mercy","neither","shall","any","works","perish","abolish","posterity","elect","and","seed","him","that","loveth","not","take","away","wherefore","gave","remnant","unto","jacob","out","root","david"]},{"verseId":"brenton_sirach_47_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":23,"text":"Thus rested Solomon with his fathers, and of his seed he left behind him Roboam, even the foolishness of the people, and one that had no understanding, who turned away the people through his counsel. There was also Jeroboam the son of Nebat, who caused Israel to sin, and shewed Ephraim the way of sin:","searchKeywords":["thus","rested","solomon","with","his","fathers","and","seed","left","behind","him","roboam","even","the","foolishness","people","one","that","had","understanding","who","turned","away","through","counsel","there","was","also","jeroboam","son","nebat","caused","israel","sin","shewed","ephraim","way"]},{"verseId":"brenton_sirach_47_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":24,"text":"and their sins were multiplied exceedingly, that they were driven out of the land.","searchKeywords":["and","their","sins","were","multiplied","exceedingly","that","they","driven","out","the","land"]},{"verseId":"brenton_sirach_47_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":47,"verse":25,"text":"For they sought out all wickedness, till the vengeance came upon them.","searchKeywords":["for","they","sought","out","all","wickedness","till","the","vengeance","came","upon","them"]}]