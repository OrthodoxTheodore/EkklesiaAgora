[{"verseId":"brenton_sirach_35_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":1,"text":"If thou be made the master [of a feast], lift not thyself up, but be among them as one of the rest; take diligent care for them, and so sit down.","searchKeywords":["thou","made","the","master","feast","lift","not","thyself","but","among","them","one","rest","take","diligent","care","for","and","sit","down"]},{"verseId":"brenton_sirach_35_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":2,"text":"And when thou hast done all thy office, take thy place, that thou mayest be merry with them, and receive a crown for thy well ordering of the feast.","searchKeywords":["and","when","thou","hast","done","all","thy","office","take","place","that","mayest","merry","with","them","receive","crown","for","well","ordering","the","feast"]},{"verseId":"brenton_sirach_35_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":3,"text":"Speak, thou that art the elder, for it becometh thee, but with sound judgment; and hinder not music.","searchKeywords":["speak","thou","that","art","the","elder","for","becometh","thee","but","with","sound","judgment","and","hinder","not","music"]},{"verseId":"brenton_sirach_35_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":4,"text":"Pour not out words where there is a musician, and shew not forth wisdom out of time.","searchKeywords":["pour","not","out","words","where","there","musician","and","shew","forth","wisdom","time"]},{"verseId":"brenton_sirach_35_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":5,"text":"A concert of music in a banquet of wine is as a signet of carbuncle set in gold.","searchKeywords":["concert","music","banquet","wine","signet","carbuncle","set","gold"]},{"verseId":"brenton_sirach_35_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":6,"text":"As a signet of an emerald set in a work of gold, so is the melody of music with pleasant wine.","searchKeywords":["signet","emerald","set","work","gold","the","melody","music","with","pleasant","wine"]},{"verseId":"brenton_sirach_35_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":7,"text":"Speak, young man, if there be need of thee: and yet scarcely when thou art twice asked.","searchKeywords":["speak","young","man","there","need","thee","and","yet","scarcely","when","thou","art","twice","asked"]},{"verseId":"brenton_sirach_35_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":8,"text":"Let thy speech be short, comprehending much in few words; be as one that knoweth and yet holdeth his tongue.","searchKeywords":["let","thy","speech","short","comprehending","much","few","words","one","that","knoweth","and","yet","holdeth","his","tongue"]},{"verseId":"brenton_sirach_35_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":9,"text":"If thou be among great men, make not thyself equal with them; and when ancient men are in place, use not many words.","searchKeywords":["thou","among","great","men","make","not","thyself","equal","with","them","and","when","ancient","are","place","use","many","words"]},{"verseId":"brenton_sirach_35_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":10,"text":"Before the thunder goeth lightning; and before a shamefaced man shall go favour.","searchKeywords":["before","the","thunder","goeth","lightning","and","shamefaced","man","shall","favour"]},{"verseId":"brenton_sirach_35_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":11,"text":"Rise up betimes, and be not the last; but get thee home without delay.","searchKeywords":["rise","betimes","and","not","the","last","but","get","thee","home","without","delay"]},{"verseId":"brenton_sirach_35_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":12,"text":"There take thy pastime, and do what thou wilt: but sin not by proud speech.","searchKeywords":["there","take","thy","pastime","and","what","thou","wilt","but","sin","not","proud","speech"]},{"verseId":"brenton_sirach_35_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":13,"text":"And for these things bless him that made thee, and hath replenished thee with his good things.","searchKeywords":["and","for","these","things","bless","him","that","made","thee","hath","replenished","with","his","good"]},{"verseId":"brenton_sirach_35_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":14,"text":"Whoso feareth the Lord will receive his discipline; and they that seek him early shall find favour.","searchKeywords":["whoso","feareth","the","lord","will","receive","his","discipline","and","they","that","seek","him","early","shall","find","favour"]},{"verseId":"brenton_sirach_35_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":15,"text":"He that seeketh the law shall be filled therewith: but the hypocrite will be offended thereat.","searchKeywords":["that","seeketh","the","law","shall","filled","therewith","but","hypocrite","will","offended","thereat"]},{"verseId":"brenton_sirach_35_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":16,"text":"They that fear the Lord shall find judgment, and shall kindle justice as a light.","searchKeywords":["they","that","fear","the","lord","shall","find","judgment","and","kindle","justice","light"]},{"verseId":"brenton_sirach_35_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":17,"text":"A sinful man will not be reproved, but findeth an excuse according to his will.","searchKeywords":["sinful","man","will","not","reproved","but","findeth","excuse","according","his"]},{"verseId":"brenton_sirach_35_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":18,"text":"A man of counsel will be considerate; but a strange and proud man is not daunted with fear, even when of himself he hath done without counsel.","searchKeywords":["man","counsel","will","considerate","but","strange","and","proud","not","daunted","with","fear","even","when","himself","hath","done","without"]},{"verseId":"brenton_sirach_35_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":19,"text":"Do nothing without advice; and when thou hast once done, repent not.","searchKeywords":["nothing","without","advice","and","when","thou","hast","once","done","repent","not"]},{"verseId":"brenton_sirach_35_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":20,"text":"Go not in a way wherein thou mayest fall, and stumble not among the stones.","searchKeywords":["not","way","wherein","thou","mayest","fall","and","stumble","among","the","stones"]},{"verseId":"brenton_sirach_35_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":21,"text":"Be not confident in a plain way.","searchKeywords":["not","confident","plain","way"]},{"verseId":"brenton_sirach_35_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":22,"text":"And beware of thine own children.","searchKeywords":["and","beware","thine","own","children"]},{"verseId":"brenton_sirach_35_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":23,"text":"In every good work trust thy own soul; for this is the keeping of the commandments.","searchKeywords":["every","good","work","trust","thy","own","soul","for","this","the","keeping","commandments"]},{"verseId":"brenton_sirach_35_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":35,"verse":24,"text":"He that believeth in the Lord taketh heed to the commandment; and he that trusteth in him shall fare never the worse.","searchKeywords":["that","believeth","the","lord","taketh","heed","commandment","and","trusteth","him","shall","fare","never","worse"]}]