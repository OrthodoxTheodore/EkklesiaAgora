[{"verseId":"brenton_sirach_38_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":1,"text":"Honour a physician with the honour due unto him for the uses which ye may have of him: for the Lord hath created him.","searchKeywords":["honour","physician","with","the","due","unto","him","for","uses","which","may","have","lord","hath","created"]},{"verseId":"brenton_sirach_38_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":2,"text":"For of the most High cometh healing, and he shall receive honour of the king.","searchKeywords":["for","the","most","high","cometh","healing","and","shall","receive","honour","king"]},{"verseId":"brenton_sirach_38_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":3,"text":"The skill of the physician shall lift up his head: and in the sight of great men he shall be in admiration.","searchKeywords":["the","skill","physician","shall","lift","his","head","and","sight","great","men","admiration"]},{"verseId":"brenton_sirach_38_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":4,"text":"The Lord hath created medicines out of the earth; and he that is wise will not abhor them.","searchKeywords":["the","lord","hath","created","medicines","out","earth","and","that","wise","will","not","abhor","them"]},{"verseId":"brenton_sirach_38_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":5,"text":"Was not the water made sweet with wood, that the virtue thereof might be known?","searchKeywords":["was","not","the","water","made","sweet","with","wood","that","virtue","thereof","might","known"]},{"verseId":"brenton_sirach_38_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":6,"text":"And he hath given men skill, that he might be honoured in his marvellous works.","searchKeywords":["and","hath","given","men","skill","that","might","honoured","his","marvellous","works"]},{"verseId":"brenton_sirach_38_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":7,"text":"With such doth he heal [men,] and taketh away their pains.","searchKeywords":["with","such","doth","heal","men","and","taketh","away","their","pains"]},{"verseId":"brenton_sirach_38_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":8,"text":"Of such doth the apothecary make a confection; and of his works there is no end; and from him is peace over all the earth.","searchKeywords":["such","doth","the","apothecary","make","confection","and","his","works","there","end","from","him","peace","over","all","earth"]},{"verseId":"brenton_sirach_38_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":9,"text":"My son, in thy sickness be not negligent: but pray unto the Lord, and he will make thee whole.","searchKeywords":["son","thy","sickness","not","negligent","but","pray","unto","the","lord","and","will","make","thee","whole"]},{"verseId":"brenton_sirach_38_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":10,"text":"Leave off from sin, and order thine hands aright, and cleanse thy heart from all wickedness.","searchKeywords":["leave","off","from","sin","and","order","thine","hands","aright","cleanse","thy","heart","all","wickedness"]},{"verseId":"brenton_sirach_38_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":11,"text":"Give a sweet savour, and a memorial of fine flour; and make a fat offering, as not being.","searchKeywords":["give","sweet","savour","and","memorial","fine","flour","make","fat","offering","not","being"]},{"verseId":"brenton_sirach_38_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":12,"text":"Then give place to the physician, for the Lord hath created him: let him not go from thee, for thou hast need of him.","searchKeywords":["then","give","place","the","physician","for","lord","hath","created","him","let","not","from","thee","thou","hast","need"]},{"verseId":"brenton_sirach_38_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":13,"text":"There is a time when in their hands there is good success.","searchKeywords":["there","time","when","their","hands","good","success"]},{"verseId":"brenton_sirach_38_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":14,"text":"For they shall also pray unto the Lord, that he would prosper that which they give for ease and remedy to prolong life.","searchKeywords":["for","they","shall","also","pray","unto","the","lord","that","would","prosper","which","give","ease","and","remedy","prolong","life"]},{"verseId":"brenton_sirach_38_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":15,"text":"He that sinneth before his Maker, let him fall into the hand of the physician.","searchKeywords":["that","sinneth","before","his","maker","let","him","fall","into","the","hand","physician"]},{"verseId":"brenton_sirach_38_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":16,"text":"My son, let tears fall down over the dead, and begin to lament, as if thou hadst suffered great harm thyself; and then cover his body according to the custom, and neglect not his burial.","searchKeywords":["son","let","tears","fall","down","over","the","dead","and","begin","lament","thou","hadst","suffered","great","harm","thyself","then","cover","his","body","according","custom","neglect","not","burial"]},{"verseId":"brenton_sirach_38_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":17,"text":"Weep bitterly, and make great moan, and use lamentation, as he is worthy, and that a day or two, lest thou be evil spoken of: and then comfort thyself for thy heaviness;","searchKeywords":["weep","bitterly","and","make","great","moan","use","lamentation","worthy","that","day","two","lest","thou","evil","spoken","then","comfort","thyself","for","thy","heaviness"]},{"verseId":"brenton_sirach_38_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":18,"text":"for of heaviness cometh death, and the heaviness of the heart breaketh strength.","searchKeywords":["for","heaviness","cometh","death","and","the","heart","breaketh","strength"]},{"verseId":"brenton_sirach_38_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":19,"text":"In affliction also sorrow remaineth: and the life of the poor is the curse of the heart.","searchKeywords":["affliction","also","sorrow","remaineth","and","the","life","poor","curse","heart"]},{"verseId":"brenton_sirach_38_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":20,"text":"Take no heaviness to heart: drive it away, and remember the last end.","searchKeywords":["take","heaviness","heart","drive","away","and","remember","the","last","end"]},{"verseId":"brenton_sirach_38_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":21,"text":"Forget him not, for there is no turning again: thou shalt not do him good, but hurt thyself.","searchKeywords":["forget","him","not","for","there","turning","again","thou","shalt","good","but","hurt","thyself"]},{"verseId":"brenton_sirach_38_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":22,"text":"Remember his judgment: for thine also shall be so; yesterday for me, and to day for thee.","searchKeywords":["remember","his","judgment","for","thine","also","shall","yesterday","and","day","thee"]},{"verseId":"brenton_sirach_38_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":23,"text":"When the dead is at rest, let his remembrance rest; and be comforted for him when his spirit is departed from him.","searchKeywords":["when","the","dead","rest","let","his","remembrance","and","comforted","for","him","spirit","departed","from"]},{"verseId":"brenton_sirach_38_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":24,"text":"The wisdom of a learned man cometh by opportunity of leisure: and he that hath little business shall become wise.","searchKeywords":["the","wisdom","learned","man","cometh","opportunity","leisure","and","that","hath","little","business","shall","become","wise"]},{"verseId":"brenton_sirach_38_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":25,"text":"How can he get wisdom that holdeth the plough, and that glorieth in the goad, that driveth oxen, and is occupied in their labours, and whose talk is of bullocks?","searchKeywords":["how","can","get","wisdom","that","holdeth","the","plough","and","glorieth","goad","driveth","oxen","occupied","their","labours","whose","talk","bullocks"]},{"verseId":"brenton_sirach_38_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":26,"text":"He giveth his mind to make furrows; and is diligent to give the kine fodder.","searchKeywords":["giveth","his","mind","make","furrows","and","diligent","give","the","kine","fodder"]},{"verseId":"brenton_sirach_38_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":27,"text":"So every carpenter and workmaster, that laboureth night and day: and they that cut and grave seals, and are diligent to make great variety, and give themselves to counterfeit imagery, and watch to finish a work:","searchKeywords":["every","carpenter","and","workmaster","that","laboureth","night","day","they","cut","grave","seals","are","diligent","make","great","variety","give","themselves","counterfeit","imagery","watch","finish","work"]},{"verseId":"brenton_sirach_38_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":28,"text":"The smith also sitting by the anvil, and considering the iron work, the vapour of the fire wasteth his flesh, and he fighteth with the heat of the furnace: the noise of the hammer and the anvil is ever in his ears, and his eyes look still upon the pattern of the thing that he maketh; he setteth his mind to finish his work, and watcheth to polish it perfectly:","searchKeywords":["the","smith","also","sitting","anvil","and","considering","iron","work","vapour","fire","wasteth","his","flesh","fighteth","with","heat","furnace","noise","hammer","ever","ears","eyes","look","still","upon","pattern","thing","that","maketh","setteth","mind","finish","watcheth","polish","perfectly"]},{"verseId":"brenton_sirach_38_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":29,"text":"So doth the potter sitting at his work, and turning the wheel about with his feet, who is alway carefully set at his work, and maketh all his work by number;","searchKeywords":["doth","the","potter","sitting","his","work","and","turning","wheel","about","with","feet","who","alway","carefully","set","maketh","all","number"]},{"verseId":"brenton_sirach_38_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":30,"text":"he fashioneth the clay with his arm, and boweth down his strength before his feet; he applieth himself to lead it over; and he is diligent to make clean the furnace:","searchKeywords":["fashioneth","the","clay","with","his","arm","and","boweth","down","strength","before","feet","applieth","himself","lead","over","diligent","make","clean","furnace"]},{"verseId":"brenton_sirach_38_31","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":31,"text":"all these trust to their hands; and every one is wise in his work.","searchKeywords":["all","these","trust","their","hands","and","every","one","wise","his","work"]},{"verseId":"brenton_sirach_38_32","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":32,"text":"Without these cannot a city be inhabited: and they shall not dwell where they will, nor go up and down:","searchKeywords":["without","these","cannot","city","inhabited","and","they","shall","not","dwell","where","will","nor","down"]},{"verseId":"brenton_sirach_38_33","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":33,"text":"they shall not be sought for in public counsel, nor sit high in the congregation: they shall not sit on the judges' seat, nor understand the sentence of judgment: they cannot declare justice and judgment; and they shall not be found where parables are spoken.","searchKeywords":["they","shall","not","sought","for","public","counsel","nor","sit","high","the","congregation","judges","seat","understand","sentence","judgment","cannot","declare","justice","and","found","where","parables","are","spoken"]},{"verseId":"brenton_sirach_38_34","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":38,"verse":34,"text":"But they will maintain the state of the world, and [all] their desire is in the work of their craft.","searchKeywords":["but","they","will","maintain","the","state","world","and","all","their","desire","work","craft"]}]