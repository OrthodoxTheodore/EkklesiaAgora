[{"verseId":"brenton_sirach_37_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":1,"text":"Every friend saith, I am his friend also: but there is a friend, which is only a friend in name.","searchKeywords":["every","friend","saith","his","also","but","there","which","only","name"]},{"verseId":"brenton_sirach_37_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":2,"text":"Is it not a grief unto death, when a companion and friend is turned to an enemy?","searchKeywords":["not","grief","unto","death","when","companion","and","friend","turned","enemy"]},{"verseId":"brenton_sirach_37_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":3,"text":"O wicked imagination, whence camest thou in to cover the earth with deceit?","searchKeywords":["wicked","imagination","whence","camest","thou","cover","the","earth","with","deceit"]},{"verseId":"brenton_sirach_37_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":4,"text":"There is a companion, which rejoiceth in the prosperity of a friend, but in the time of trouble will be against him.","searchKeywords":["there","companion","which","rejoiceth","the","prosperity","friend","but","time","trouble","will","against","him"]},{"verseId":"brenton_sirach_37_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":5,"text":"There is a companion, which helpeth his friend for the belly, and taketh up the buckler against the enemy.","searchKeywords":["there","companion","which","helpeth","his","friend","for","the","belly","and","taketh","buckler","against","enemy"]},{"verseId":"brenton_sirach_37_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":6,"text":"Forget not thy friend in thy mind, and be not unmindful of him in thy riches.","searchKeywords":["forget","not","thy","friend","mind","and","unmindful","him","riches"]},{"verseId":"brenton_sirach_37_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":7,"text":"Every counsellor extolleth counsel; but there is some that counselleth for himself.","searchKeywords":["every","counsellor","extolleth","counsel","but","there","some","that","counselleth","for","himself"]},{"verseId":"brenton_sirach_37_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":8,"text":"Beware of a counsellor, and know before what need he hath; for he will counsel for himself; lest he cast the lot upon thee,","searchKeywords":["beware","counsellor","and","know","before","what","need","hath","for","will","counsel","himself","lest","cast","the","lot","upon","thee"]},{"verseId":"brenton_sirach_37_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":9,"text":"and say unto thee, Thy way is good: and afterward he stand on the other side, to see what shall befall thee.","searchKeywords":["and","say","unto","thee","thy","way","good","afterward","stand","the","other","side","see","what","shall","befall"]},{"verseId":"brenton_sirach_37_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":10,"text":"Consult not with one that suspecteth thee: and hide thy counsel from such as envy thee.","searchKeywords":["consult","not","with","one","that","suspecteth","thee","and","hide","thy","counsel","from","such","envy"]},{"verseId":"brenton_sirach_37_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":11,"text":"Neither consult with a woman touching her of whom she is jealous; neither with a coward in matters of war; nor with a merchant concerning exchange; nor with a buyer of selling; nor with an envious man of thankfulness; nor with an unmerciful man touching kindness; nor with the slothful for any work; nor with an hireling for a year of finishing work; nor with an idle servant of much business: hearken not unto these in any matter of counsel.","searchKeywords":["neither","consult","with","woman","touching","her","whom","she","jealous","coward","matters","war","nor","merchant","concerning","exchange","buyer","selling","envious","man","thankfulness","unmerciful","kindness","the","slothful","for","any","work","hireling","year","finishing","idle","servant","much","business","hearken","not","unto","these","matter","counsel"]},{"verseId":"brenton_sirach_37_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":12,"text":"But be continually with a godly man, whom thou knowest to keep the commandments of the Lord, whose mind is according to thy mind, and will sorrow with thee, if thou shalt miscarry.","searchKeywords":["but","continually","with","godly","man","whom","thou","knowest","keep","the","commandments","lord","whose","mind","according","thy","and","will","sorrow","thee","shalt","miscarry"]},{"verseId":"brenton_sirach_37_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":13,"text":"And let the counsel of thine own heart stand: for there is no man more faithful unto thee than it;","searchKeywords":["and","let","the","counsel","thine","own","heart","stand","for","there","man","more","faithful","unto","thee","than"]},{"verseId":"brenton_sirach_37_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":14,"text":"for a man's mind is sometime wont to tell him more than seven watchmen, that sit above in an high tower.","searchKeywords":["for","man","mind","sometime","wont","tell","him","more","than","seven","watchmen","that","sit","above","high","tower"]},{"verseId":"brenton_sirach_37_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":15,"text":"And above all this pray to the most High, that he will direct thy way in truth.","searchKeywords":["and","above","all","this","pray","the","most","high","that","will","direct","thy","way","truth"]},{"verseId":"brenton_sirach_37_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":16,"text":"Let reason go before every enterprize, and counsel before every action.","searchKeywords":["let","reason","before","every","enterprize","and","counsel","action"]},{"verseId":"brenton_sirach_37_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":17,"text":"The countenance is a sign of changing of the heart.","searchKeywords":["the","countenance","sign","changing","heart"]},{"verseId":"brenton_sirach_37_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":18,"text":"Four manners of things appear: good and evil, life and death: but the tongue ruleth over them continually.","searchKeywords":["four","manners","things","appear","good","and","evil","life","death","but","the","tongue","ruleth","over","them","continually"]},{"verseId":"brenton_sirach_37_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":19,"text":"There is one that is wise and teacheth many, and yet is unprofitable to himself.","searchKeywords":["there","one","that","wise","and","teacheth","many","yet","unprofitable","himself"]},{"verseId":"brenton_sirach_37_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":20,"text":"There is one that sheweth wisdom in words, and is hated: he shall be destitute of all food.","searchKeywords":["there","one","that","sheweth","wisdom","words","and","hated","shall","destitute","all","food"]},{"verseId":"brenton_sirach_37_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":21,"text":"For grace is not given him from the Lord; because he is deprived of all wisdom.","searchKeywords":["for","grace","not","given","him","from","the","lord","because","deprived","all","wisdom"]},{"verseId":"brenton_sirach_37_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":22,"text":"Another is wise to himself; and the fruits of understanding are commendable in his mouth.","searchKeywords":["another","wise","himself","and","the","fruits","understanding","are","commendable","his","mouth"]},{"verseId":"brenton_sirach_37_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":23,"text":"A wise man instructeth his people; and the fruits of his understanding fail not.","searchKeywords":["wise","man","instructeth","his","people","and","the","fruits","understanding","fail","not"]},{"verseId":"brenton_sirach_37_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":24,"text":"A wise man shall be filled with blessing; and all they that see him shall count him happy.","searchKeywords":["wise","man","shall","filled","with","blessing","and","all","they","that","see","him","count","happy"]},{"verseId":"brenton_sirach_37_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":25,"text":"The days of the life of man may be numbered; but the days of Israel are innumerable.","searchKeywords":["the","days","life","man","may","numbered","but","israel","are","innumerable"]},{"verseId":"brenton_sirach_37_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":26,"text":"A wise man shall inherit glory among his people, and his name shall be perpetual.","searchKeywords":["wise","man","shall","inherit","glory","among","his","people","and","name","perpetual"]},{"verseId":"brenton_sirach_37_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":27,"text":"My son, prove thy soul in thy life, and see what is evil for it, and give not that unto it.","searchKeywords":["son","prove","thy","soul","life","and","see","what","evil","for","give","not","that","unto"]},{"verseId":"brenton_sirach_37_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":28,"text":"For all things are not profitable for all men, neither hath every soul pleasure in every thing.","searchKeywords":["for","all","things","are","not","profitable","men","neither","hath","every","soul","pleasure","thing"]},{"verseId":"brenton_sirach_37_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":29,"text":"Be not insatiable in any dainty thing, nor too greedy upon meats:","searchKeywords":["not","insatiable","any","dainty","thing","nor","too","greedy","upon","meats"]},{"verseId":"brenton_sirach_37_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":30,"text":"for excess of meats bringeth sickness, and surfeiting will turn into choler.","searchKeywords":["for","excess","meats","bringeth","sickness","and","surfeiting","will","turn","into","choler"]},{"verseId":"brenton_sirach_37_31","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":37,"verse":31,"text":"By surfeiting have many perished; but he that taketh heed prolongeth his life.","searchKeywords":["surfeiting","have","many","perished","but","that","taketh","heed","prolongeth","his","life"]}]