[{"verseId":"brenton_sirach_51_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":1,"text":"I will thank thee, O Lord and King, and praise thee, O God my Saviour: I do give praise unto thy name:","searchKeywords":["will","thank","thee","lord","and","king","praise","god","saviour","give","unto","thy","name"]},{"verseId":"brenton_sirach_51_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":2,"text":"for thou art my defender and helper, and hast preserved my body from destruction, and from the snare of the slanderous tongue, and from the lips that forge lies, and hast been mine helper against mine adversaries:","searchKeywords":["for","thou","art","defender","and","helper","hast","preserved","body","from","destruction","the","snare","slanderous","tongue","lips","that","forge","lies","been","mine","against","adversaries"]},{"verseId":"brenton_sirach_51_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":3,"text":"and hast delivered me, according to the multitude of thy mercies and greatness of thy name, from the teeth of them that were ready to devour me, and out of the hands of such as sought after my life, and from the manifold afflictions which I had;","searchKeywords":["and","hast","delivered","according","the","multitude","thy","mercies","greatness","name","from","teeth","them","that","were","ready","devour","out","hands","such","sought","after","life","manifold","afflictions","which","had"]},{"verseId":"brenton_sirach_51_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":4,"text":"from the choking of fire on every side, and from the midst of the fire which I kindled not;","searchKeywords":["from","the","choking","fire","every","side","and","midst","which","kindled","not"]},{"verseId":"brenton_sirach_51_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":5,"text":"from the depth of the belly of hell, from an unclean tongue, and from lying words.","searchKeywords":["from","the","depth","belly","hell","unclean","tongue","and","lying","words"]},{"verseId":"brenton_sirach_51_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":6,"text":"By an accusation to the king from an unrighteous tongue my soul drew near even unto death, my life was near to the hell beneath.","searchKeywords":["accusation","the","king","from","unrighteous","tongue","soul","drew","near","even","unto","death","life","was","hell","beneath"]},{"verseId":"brenton_sirach_51_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":7,"text":"They compassed me on every side, and there was no man to help me: I looked for the succour of men, but there was none.","searchKeywords":["they","compassed","every","side","and","there","was","man","help","looked","for","the","succour","men","but","none"]},{"verseId":"brenton_sirach_51_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":8,"text":"Then thought I upon thy mercy, O Lord, and upon thy acts of old, how thou deliverest such as wait for thee, and savest them out of the hands of the enemies.","searchKeywords":["then","thought","upon","thy","mercy","lord","and","acts","old","how","thou","deliverest","such","wait","for","thee","savest","them","out","the","hands","enemies"]},{"verseId":"brenton_sirach_51_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":9,"text":"Then lifted I up my supplication from the earth, and prayed for deliverance from death.","searchKeywords":["then","lifted","supplication","from","the","earth","and","prayed","for","deliverance","death"]},{"verseId":"brenton_sirach_51_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":10,"text":"I called upon the Lord, the Father of my Lord, that he would not leave me in the days of my trouble, and in the time of the proud, when there was no help.","searchKeywords":["called","upon","the","lord","father","that","would","not","leave","days","trouble","and","time","proud","when","there","was","help"]},{"verseId":"brenton_sirach_51_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":11,"text":"I will praise thy name continually, and will sing praise with thanksgiving; and so my prayer was heard:","searchKeywords":["will","praise","thy","name","continually","and","sing","with","thanksgiving","prayer","was","heard"]},{"verseId":"brenton_sirach_51_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":12,"text":"for thou savedst me from destruction, and deliveredst me from the evil time: therefore will I give thanks, and praise thee, and bless thy name, O Lord.","searchKeywords":["for","thou","savedst","from","destruction","and","deliveredst","the","evil","time","therefore","will","give","thanks","praise","thee","bless","thy","name","lord"]},{"verseId":"brenton_sirach_51_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":13,"text":"When I was yet young, or ever I went abroad, I desired wisdom openly in my prayer.","searchKeywords":["when","was","yet","young","ever","went","abroad","desired","wisdom","openly","prayer"]},{"verseId":"brenton_sirach_51_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":14,"text":"I prayed for her before the temple, and will seek her out even to the end.","searchKeywords":["prayed","for","her","before","the","temple","and","will","seek","out","even","end"]},{"verseId":"brenton_sirach_51_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":15,"text":"Even from the flower till the grape was ripe hath my heart delighted in her: my foot went the right way, from my youth up sought I after her.","searchKeywords":["even","from","the","flower","till","grape","was","ripe","hath","heart","delighted","her","foot","went","right","way","youth","sought","after"]},{"verseId":"brenton_sirach_51_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":16,"text":"I bowed down mine ear a little, and received her, and gat much learning.","searchKeywords":["bowed","down","mine","ear","little","and","received","her","gat","much","learning"]},{"verseId":"brenton_sirach_51_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":17,"text":"I profited therein, will I ascribe the glory unto him that giveth me wisdom.","searchKeywords":["profited","therein","will","ascribe","the","glory","unto","him","that","giveth","wisdom"]},{"verseId":"brenton_sirach_51_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":18,"text":"For I purposed to do after her, and earnestly I followed that which is good; so shall I not be confounded.","searchKeywords":["for","purposed","after","her","and","earnestly","followed","that","which","good","shall","not","confounded"]},{"verseId":"brenton_sirach_51_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":19,"text":"My soul hath wrestled with her, and in my doings I was exact: I stretched forth my hands to the heaven above, and bewailed my ignorances of her.","searchKeywords":["soul","hath","wrestled","with","her","and","doings","was","exact","stretched","forth","hands","the","heaven","above","bewailed","ignorances"]},{"verseId":"brenton_sirach_51_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":20,"text":"I directed my soul unto her, and I found her in pureness: I have had my heart joined with her from the beginning, therefore shall I not be forsaken.","searchKeywords":["directed","soul","unto","her","and","found","pureness","have","had","heart","joined","with","from","the","beginning","therefore","shall","not","forsaken"]},{"verseId":"brenton_sirach_51_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":21,"text":"My heart was troubled in seeking her: therefore have I gotten a good possession.","searchKeywords":["heart","was","troubled","seeking","her","therefore","have","gotten","good","possession"]},{"verseId":"brenton_sirach_51_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":22,"text":"The Lord hath given me a tongue for my reward, and I will praise him therewith.","searchKeywords":["the","lord","hath","given","tongue","for","reward","and","will","praise","him","therewith"]},{"verseId":"brenton_sirach_51_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":23,"text":"Draw near unto me, ye unlearned, and dwell in the house of learning.","searchKeywords":["draw","near","unto","unlearned","and","dwell","the","house","learning"]},{"verseId":"brenton_sirach_51_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":24,"text":"Wherefore are ye slow, and what say ye of these things, seeing your souls are very thirsty?","searchKeywords":["wherefore","are","slow","and","what","say","these","things","seeing","your","souls","very","thirsty"]},{"verseId":"brenton_sirach_51_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":25,"text":"I opened my mouth, and said, Buy her for yourselves without money.","searchKeywords":["opened","mouth","and","said","buy","her","for","yourselves","without","money"]},{"verseId":"brenton_sirach_51_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":26,"text":"Put your neck under the yoke, and let your soul receive instruction: she is hard at hand to find.","searchKeywords":["put","your","neck","under","the","yoke","and","let","soul","receive","instruction","she","hard","hand","find"]},{"verseId":"brenton_sirach_51_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":27,"text":"Behold with your eyes, how that I have had but little labour, and have gotten unto me much rest.","searchKeywords":["behold","with","your","eyes","how","that","have","had","but","little","labour","and","gotten","unto","much","rest"]},{"verseId":"brenton_sirach_51_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":28,"text":"Get learning with a great sum of money, and get much gold by her.","searchKeywords":["get","learning","with","great","sum","money","and","much","gold","her"]},{"verseId":"brenton_sirach_51_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":29,"text":"Let your soul rejoice in his mercy, and be not ashamed of his praise.","searchKeywords":["let","your","soul","rejoice","his","mercy","and","not","ashamed","praise"]},{"verseId":"brenton_sirach_51_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":51,"verse":30,"text":"Work your work betimes, and in his time he will give you your reward.","searchKeywords":["work","your","betimes","and","his","time","will","give","you","reward"]}]