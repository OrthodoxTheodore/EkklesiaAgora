[{"verseId":"brenton_sirach_17_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":1,"text":"The Lord created man of the earth, and turned him into it again.","searchKeywords":["the","lord","created","man","earth","and","turned","him","into","again"]},{"verseId":"brenton_sirach_17_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":2,"text":"He gave them few days, and a short time, and power also over the things therein.","searchKeywords":["gave","them","few","days","and","short","time","power","also","over","the","things","therein"]},{"verseId":"brenton_sirach_17_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":3,"text":"He endued them with strength by themselves, and made them according to his image,","searchKeywords":["endued","them","with","strength","themselves","and","made","according","his","image"]},{"verseId":"brenton_sirach_17_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":4,"text":"and put the fear of man upon all flesh, and gave him dominion over beasts and fowls.","searchKeywords":["and","put","the","fear","man","upon","all","flesh","gave","him","dominion","over","beasts","fowls"]},{"verseId":"brenton_sirach_17_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":6,"text":"Counsel, and a tongue, and eyes, ears, and a heart, gave he them to understand.","searchKeywords":["counsel","and","tongue","eyes","ears","heart","gave","them","understand"]},{"verseId":"brenton_sirach_17_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":7,"text":"Withal he filled them with the knowledge of understanding, and shewed them good and evil.","searchKeywords":["withal","filled","them","with","the","knowledge","understanding","and","shewed","good","evil"]},{"verseId":"brenton_sirach_17_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":8,"text":"He set his eye upon their hearts, that he might shew them the greatness of his works;","searchKeywords":["set","his","eye","upon","their","hearts","that","might","shew","them","the","greatness","works"]},{"verseId":"brenton_sirach_17_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":10,"text":"and they shall praise his holy name, that they may search out his marvellous works.","searchKeywords":["and","they","shall","praise","his","holy","name","that","may","search","out","marvellous","works"]},{"verseId":"brenton_sirach_17_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":11,"text":"Beside this he gave them knowledge, and the law of life for an heritage.","searchKeywords":["beside","this","gave","them","knowledge","and","the","law","life","for","heritage"]},{"verseId":"brenton_sirach_17_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":12,"text":"He made an everlasting covenant with them, and shewed them his judgments.","searchKeywords":["made","everlasting","covenant","with","them","and","shewed","his","judgments"]},{"verseId":"brenton_sirach_17_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":13,"text":"Their eyes saw the majesty of his glory, and their ears heard his glorious voice.","searchKeywords":["their","eyes","saw","the","majesty","his","glory","and","ears","heard","glorious","voice"]},{"verseId":"brenton_sirach_17_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":14,"text":"And he said unto them, Beware of all unrighteousness; and he gave every man commandment concerning his neighbour.","searchKeywords":["and","said","unto","them","beware","all","unrighteousness","gave","every","man","commandment","concerning","his","neighbour"]},{"verseId":"brenton_sirach_17_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":15,"text":"Their ways are ever before him, and shall not be hid from his eyes.","searchKeywords":["their","ways","are","ever","before","him","and","shall","not","hid","from","his","eyes"]},{"verseId":"brenton_sirach_17_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":17,"text":"For in the division of the nations of the whole earth he set a ruler over every people; but Israel is the Lord's portion:","searchKeywords":["for","the","division","nations","whole","earth","set","ruler","over","every","people","but","israel","lord","portion"]},{"verseId":"brenton_sirach_17_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":19,"text":"Therefore all their works are as the sun before him, and his eyes are continually upon their ways.","searchKeywords":["therefore","all","their","works","are","the","sun","before","him","and","his","eyes","continually","upon","ways"]},{"verseId":"brenton_sirach_17_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":20,"text":"None of their unrighteous deeds are hid from him, but all their sins are before the Lord.","searchKeywords":["none","their","unrighteous","deeds","are","hid","from","him","but","all","sins","before","the","lord"]},{"verseId":"brenton_sirach_17_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":22,"text":"The alms of a man is as a signet with him, and he will keep the good deeds of man as the apple of the eye, and give repentance to his sons and daughters.","searchKeywords":["the","alms","man","signet","with","him","and","will","keep","good","deeds","apple","eye","give","repentance","his","sons","daughters"]},{"verseId":"brenton_sirach_17_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":23,"text":"Afterwards he will rise up and reward them, and render their recompence upon their heads.","searchKeywords":["afterwards","will","rise","and","reward","them","render","their","recompence","upon","heads"]},{"verseId":"brenton_sirach_17_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":24,"text":"But unto them that repent, he granted them return, and comforted those that failed in patience.","searchKeywords":["but","unto","them","that","repent","granted","return","and","comforted","those","failed","patience"]},{"verseId":"brenton_sirach_17_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":25,"text":"Return unto the Lord, and forsake thy sins, make thy prayer before his face, and offend less.","searchKeywords":["return","unto","the","lord","and","forsake","thy","sins","make","prayer","before","his","face","offend","less"]},{"verseId":"brenton_sirach_17_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":26,"text":"Turn again to the most High, and turn away from iniquity: for he will lead thee out of darkness into the light of health, and hate thou abomination vehemently.","searchKeywords":["turn","again","the","most","high","and","away","from","iniquity","for","will","lead","thee","out","darkness","into","light","health","hate","thou","abomination","vehemently"]},{"verseId":"brenton_sirach_17_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":27,"text":"Who shall praise the most High in the grave, instead of them which live and give thanks?","searchKeywords":["who","shall","praise","the","most","high","grave","instead","them","which","live","and","give","thanks"]},{"verseId":"brenton_sirach_17_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":28,"text":"Thanksgiving perisheth from the dead, as from one that is not: the living and sound in heart shall praise the Lord.","searchKeywords":["thanksgiving","perisheth","from","the","dead","one","that","not","living","and","sound","heart","shall","praise","lord"]},{"verseId":"brenton_sirach_17_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":29,"text":"How great is the lovingkindness of the Lord our God, and his compassion unto such as turn unto him in holiness!","searchKeywords":["how","great","the","lovingkindness","lord","our","god","and","his","compassion","unto","such","turn","him","holiness"]},{"verseId":"brenton_sirach_17_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":30,"text":"For all things cannot be in men, because the son of man is not immortal.","searchKeywords":["for","all","things","cannot","men","because","the","son","man","not","immortal"]},{"verseId":"brenton_sirach_17_31","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":31,"text":"What is brighter than the sun? yet the light thereof faileth: and flesh and blood will imagine evil.","searchKeywords":["what","brighter","than","the","sun","yet","light","thereof","faileth","and","flesh","blood","will","imagine","evil"]},{"verseId":"brenton_sirach_17_32","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":17,"verse":32,"text":"He vieweth the power of the height of heaven; and all men are but earth and ashes.","searchKeywords":["vieweth","the","power","height","heaven","and","all","men","are","but","earth","ashes"]}]