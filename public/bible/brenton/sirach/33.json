[{"verseId":"brenton_sirach_33_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":33,"verse":1,"text":"Have mercy upon us, O Lord God of all, and behold us:","searchKeywords":["have","mercy","upon","lord","god","all","and","behold"]},{"verseId":"brenton_sirach_33_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":33,"verse":2,"text":"and send thy fear upon all the nations that seek not after thee.","searchKeywords":["and","send","thy","fear","upon","all","the","nations","that","seek","not","after","thee"]},{"verseId":"brenton_sirach_33_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":33,"verse":3,"text":"Lift up thy hand against the strange nations, and let them see thy power.","searchKeywords":["lift","thy","hand","against","the","strange","nations","and","let","them","see","power"]},{"verseId":"brenton_sirach_33_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":33,"verse":4,"text":"As thou wast sanctified in us before them: so be thou magnified among them before us.","searchKeywords":["thou","wast","sanctified","before","them","magnified","among"]},{"verseId":"brenton_sirach_33_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":33,"verse":5,"text":"And let them know thee, as we have known thee, that there is no God but only thou, O God.","searchKeywords":["and","let","them","know","thee","have","known","that","there","god","but","only","thou"]},{"verseId":"brenton_sirach_33_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":33,"verse":6,"text":"Shew new signs, and make other strange wonders: glorify thy hand and thy right arm, that they may set forth thy wondrous works.","searchKeywords":["shew","new","signs","and","make","other","strange","wonders","glorify","thy","hand","right","arm","that","they","may","set","forth","wondrous","works"]},{"verseId":"brenton_sirach_33_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":33,"verse":7,"text":"Raise up indignation, and pour out wrath: take away the adversary, and destroy the enemy.","searchKeywords":["raise","indignation","and","pour","out","wrath","take","away","the","adversary","destroy","enemy"]},{"verseId":"brenton_sirach_33_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":33,"verse":8,"text":"Make the time short, remember the covenant, and let them declare thy wonderful works.","searchKeywords":["make","the","time","short","remember","covenant","and","let","them","declare","thy","wonderful","works"]},{"verseId":"brenton_sirach_33_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":33,"verse":9,"text":"Let him that escapeth be consumed by the rage of the fire; and let them perish that oppress the people.","searchKeywords":["let","him","that","escapeth","consumed","the","rage","fire","and","them","perish","oppress","people"]},{"verseId":"brenton_sirach_33_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":33,"verse":10,"text":"Smite in sunder the heads of the rulers of the heathen, that say, There is none other but we.","searchKeywords":["smite","sunder","the","heads","rulers","heathen","that","say","there","none","other","but"]},{"verseId":"brenton_sirach_33_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":33,"verse":11,"text":"Gather all the tribes of Jacob together.","searchKeywords":["gather","all","the","tribes","jacob","together"]},{"verseId":"brenton_sirach_33_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":33,"verse":12,"text":"A cheerful and good heart will have a care of his meat and diet.","searchKeywords":["cheerful","and","good","heart","will","have","care","his","meat","diet"]}]