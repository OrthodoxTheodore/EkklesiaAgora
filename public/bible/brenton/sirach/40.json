[{"verseId":"brenton_sirach_40_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":1,"text":"Great travail is created for every man, and an heavy yoke is upon the sons of Adam, from the day that they go out of their mother's womb, till the day that they return to the mother of all things.","searchKeywords":["great","travail","created","for","every","man","and","heavy","yoke","upon","the","sons","adam","from","day","that","they","out","their","mother","womb","till","return","all","things"]},{"verseId":"brenton_sirach_40_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":2,"text":"Their imagination of things to come, and the day of death, [trouble] their thoughts, and [cause] fear of heart;","searchKeywords":["their","imagination","things","come","and","the","day","death","trouble","thoughts","cause","fear","heart"]},{"verseId":"brenton_sirach_40_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":3,"text":"from him that sitteth on a throne of glory, unto him that is humbled in earth and ashes;","searchKeywords":["from","him","that","sitteth","throne","glory","unto","humbled","earth","and","ashes"]},{"verseId":"brenton_sirach_40_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":4,"text":"from him that weareth purple and a crown, unto frock.","searchKeywords":["from","him","that","weareth","purple","and","crown","unto","frock"]},{"verseId":"brenton_sirach_40_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":5,"text":"Wrath, and envy, trouble, and unquietness, fear of death, and anger, and strife, and in the time of rest upon his bed his night sleep, do change his knowledge.","searchKeywords":["wrath","and","envy","trouble","unquietness","fear","death","anger","strife","the","time","rest","upon","his","bed","night","sleep","change","knowledge"]},{"verseId":"brenton_sirach_40_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":6,"text":"Little or nothing is his rest, and afterward he is in his sleep as in a day of keeping watch, troubled in the vision of his heart, as if he were escaped out of a battle.","searchKeywords":["little","nothing","his","rest","and","afterward","sleep","day","keeping","watch","troubled","the","vision","heart","were","escaped","out","battle"]},{"verseId":"brenton_sirach_40_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":7,"text":"When all is safe, he awaketh, and marvelleth that the fear was nothing.","searchKeywords":["when","all","safe","awaketh","and","marvelleth","that","the","fear","was","nothing"]},{"verseId":"brenton_sirach_40_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":8,"text":"[Such things happen] unto all flesh, both man and beast, and sevenfold more upon sinners.","searchKeywords":["such","things","happen","unto","all","flesh","both","man","and","beast","sevenfold","more","upon","sinners"]},{"verseId":"brenton_sirach_40_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":9,"text":"Death, and bloodshed, strife, and sword, calamities, famine, tribulation, and the scourge;","searchKeywords":["death","and","bloodshed","strife","sword","calamities","famine","tribulation","the","scourge"]},{"verseId":"brenton_sirach_40_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":10,"text":"these things are created for the wicked, and through them came the flood.","searchKeywords":["these","things","are","created","for","the","wicked","and","through","them","came","flood"]},{"verseId":"brenton_sirach_40_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":11,"text":"All things that are of the earth do turn to the earth again: and that which is of the waters doth return into the sea.","searchKeywords":["all","things","that","are","the","earth","turn","again","and","which","waters","doth","return","into","sea"]},{"verseId":"brenton_sirach_40_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":12,"text":"All bribery and injustice shall be blotted out: but true dealing shall endure for ever.","searchKeywords":["all","bribery","and","injustice","shall","blotted","out","but","true","dealing","endure","for","ever"]},{"verseId":"brenton_sirach_40_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":13,"text":"The goods of the unjust shall be dried up like a river, and shall vanish with noise, like a great thunder in rain.","searchKeywords":["the","goods","unjust","shall","dried","like","river","and","vanish","with","noise","great","thunder","rain"]},{"verseId":"brenton_sirach_40_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":14,"text":"While he openeth his hand he shall rejoice: so shall transgressors come to nought.","searchKeywords":["while","openeth","his","hand","shall","rejoice","transgressors","come","nought"]},{"verseId":"brenton_sirach_40_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":15,"text":"The children of the ungodly shall not bring forth many branches: but are as unclean roots upon a hard rock.","searchKeywords":["the","children","ungodly","shall","not","bring","forth","many","branches","but","are","unclean","roots","upon","hard","rock"]},{"verseId":"brenton_sirach_40_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":16,"text":"The weed growing upon every water and bank of a river shall be pulled up before all grass.","searchKeywords":["the","weed","growing","upon","every","water","and","bank","river","shall","pulled","before","all","grass"]},{"verseId":"brenton_sirach_40_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":17,"text":"Bountifulness is as a most fruitful garden, and mercifulness endureth for ever.","searchKeywords":["bountifulness","most","fruitful","garden","and","mercifulness","endureth","for","ever"]},{"verseId":"brenton_sirach_40_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":18,"text":"To labour, and to be content with that a man hath, is a sweet life: but he that findeth a treasure is above them both.","searchKeywords":["labour","and","content","with","that","man","hath","sweet","life","but","findeth","treasure","above","them","both"]},{"verseId":"brenton_sirach_40_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":19,"text":"Children and the building of a city continue a man's name: but a blameless wife is counted above them both.","searchKeywords":["children","and","the","building","city","continue","man","name","but","blameless","wife","counted","above","them","both"]},{"verseId":"brenton_sirach_40_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":20,"text":"Wine and music rejoice the heart: but the love of wisdom is above them both.","searchKeywords":["wine","and","music","rejoice","the","heart","but","love","wisdom","above","them","both"]},{"verseId":"brenton_sirach_40_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":21,"text":"The pipe and the psaltery make sweet melody: but a pleasant tongue is above them both.","searchKeywords":["the","pipe","and","psaltery","make","sweet","melody","but","pleasant","tongue","above","them","both"]},{"verseId":"brenton_sirach_40_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":22,"text":"Thine eye desireth favour and beauty: but more than both the first sprouting of corn.","searchKeywords":["thine","eye","desireth","favour","and","beauty","but","more","than","both","the","first","sprouting","corn"]},{"verseId":"brenton_sirach_40_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":23,"text":"A friend and companion never meet amiss: but above both is a wife with her husband.","searchKeywords":["friend","and","companion","never","meet","amiss","but","above","both","wife","with","her","husband"]},{"verseId":"brenton_sirach_40_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":24,"text":"Brethren and help are against time of trouble: but alms shall deliver more than them both.","searchKeywords":["brethren","and","help","are","against","time","trouble","but","alms","shall","deliver","more","than","them","both"]},{"verseId":"brenton_sirach_40_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":25,"text":"Gold and silver make the foot stand sure; but counsel is esteemed above them both.","searchKeywords":["gold","and","silver","make","the","foot","stand","sure","but","counsel","esteemed","above","them","both"]},{"verseId":"brenton_sirach_40_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":26,"text":"Riches and strength lift up the heart: but the fear of the Lord is above them both: there is no want in the fear of the Lord, and it needeth not to seek help.","searchKeywords":["riches","and","strength","lift","the","heart","but","fear","lord","above","them","both","there","want","needeth","not","seek","help"]},{"verseId":"brenton_sirach_40_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":27,"text":"The fear of the Lord is a fruitful garden, and covereth him above all glory.","searchKeywords":["the","fear","lord","fruitful","garden","and","covereth","him","above","all","glory"]},{"verseId":"brenton_sirach_40_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":28,"text":"My son, lead not a beggar's life; for better it is to die than to beg.","searchKeywords":["son","lead","not","beggar","life","for","better","die","than","beg"]},{"verseId":"brenton_sirach_40_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":29,"text":"The life of him that dependeth on another man's table is not to be counted for a life; for he polluteth himself with other men's meat: but a wise man well nurtured will beware thereof.","searchKeywords":["the","life","him","that","dependeth","another","man","table","not","counted","for","polluteth","himself","with","other","men","meat","but","wise","well","nurtured","will","beware","thereof"]},{"verseId":"brenton_sirach_40_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":40,"verse":30,"text":"Begging is sweet in the mouth of the shameless: but in his belly there shall burn a fire.","searchKeywords":["begging","sweet","the","mouth","shameless","but","his","belly","there","shall","burn","fire"]}]