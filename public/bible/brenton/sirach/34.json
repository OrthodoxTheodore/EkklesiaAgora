[{"verseId":"brenton_sirach_34_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":1,"text":"Watching for riches consumeth the flesh, and the care thereof driveth away sleep.","searchKeywords":["watching","for","riches","consumeth","the","flesh","and","care","thereof","driveth","away","sleep"]},{"verseId":"brenton_sirach_34_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":2,"text":"Watching care will not let a man slumber, as a sore disease breaketh sleep.","searchKeywords":["watching","care","will","not","let","man","slumber","sore","disease","breaketh","sleep"]},{"verseId":"brenton_sirach_34_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":3,"text":"The rich hath great labour in gathering riches together; and when he resteth, he is filled with his delicacies.","searchKeywords":["the","rich","hath","great","labour","gathering","riches","together","and","when","resteth","filled","with","his","delicacies"]},{"verseId":"brenton_sirach_34_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":4,"text":"The poor laboureth in his poor estate; and when he leaveth off, he is still needy.","searchKeywords":["the","poor","laboureth","his","estate","and","when","leaveth","off","still","needy"]},{"verseId":"brenton_sirach_34_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":5,"text":"He that loveth gold shall not be justified, and he that followeth corruption shall have enough thereof.","searchKeywords":["that","loveth","gold","shall","not","justified","and","followeth","corruption","have","enough","thereof"]},{"verseId":"brenton_sirach_34_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":6,"text":"Gold hath been the ruin of many, and their destruction was present.","searchKeywords":["gold","hath","been","the","ruin","many","and","their","destruction","was","present"]},{"verseId":"brenton_sirach_34_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":7,"text":"It is a stumblingblock unto them that sacrifice unto it, and every fool shall be taken therewith.","searchKeywords":["stumblingblock","unto","them","that","sacrifice","and","every","fool","shall","taken","therewith"]},{"verseId":"brenton_sirach_34_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":8,"text":"Blessed is the rich that is found without blemish, and hath not gone after gold.","searchKeywords":["blessed","the","rich","that","found","without","blemish","and","hath","not","gone","after","gold"]},{"verseId":"brenton_sirach_34_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":9,"text":"Who is he? and we will call him blessed: for wonderful things hath he done among his people.","searchKeywords":["who","and","will","call","him","blessed","for","wonderful","things","hath","done","among","his","people"]},{"verseId":"brenton_sirach_34_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":10,"text":"Who hath been tried thereby, and found perfect? then let him glory. Who might offend, and hath not offended? or done evil, and hath not done it?","searchKeywords":["who","hath","been","tried","thereby","and","found","perfect","then","let","him","glory","might","offend","not","offended","done","evil"]},{"verseId":"brenton_sirach_34_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":11,"text":"His goods shall be established, and the congregation shall declare his alms.","searchKeywords":["his","goods","shall","established","and","the","congregation","declare","alms"]},{"verseId":"brenton_sirach_34_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":12,"text":"If thou sit at a bountiful table, be not greedy upon it, and say not, There is much meat on it.","searchKeywords":["thou","sit","bountiful","table","not","greedy","upon","and","say","there","much","meat"]},{"verseId":"brenton_sirach_34_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":13,"text":"Remember that a wicked eye is an evil thing: and what is created more wicked than an eye? therefore it weepeth upon every occasion.","searchKeywords":["remember","that","wicked","eye","evil","thing","and","what","created","more","than","therefore","weepeth","upon","every","occasion"]},{"verseId":"brenton_sirach_34_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":14,"text":"Stretch not thine hand whithersoever it looketh, and thrust it not with him into the dish.","searchKeywords":["stretch","not","thine","hand","whithersoever","looketh","and","thrust","with","him","into","the","dish"]},{"verseId":"brenton_sirach_34_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":15,"text":"Judge of thy neighbour by thyself: and be discreet in every point.","searchKeywords":["judge","thy","neighbour","thyself","and","discreet","every","point"]},{"verseId":"brenton_sirach_34_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":16,"text":"Eat, as it becometh a man, those things which are set before thee; and devour not, lest thou be hated.","searchKeywords":["eat","becometh","man","those","things","which","are","set","before","thee","and","devour","not","lest","thou","hated"]},{"verseId":"brenton_sirach_34_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":17,"text":"Leave off first for manners' sake; and be not unsatiable, lest thou offend.","searchKeywords":["leave","off","first","for","manners","sake","and","not","unsatiable","lest","thou","offend"]},{"verseId":"brenton_sirach_34_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":18,"text":"When thou sittest among many, reach not thine hand out first of all.","searchKeywords":["when","thou","sittest","among","many","reach","not","thine","hand","out","first","all"]},{"verseId":"brenton_sirach_34_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":19,"text":"A very little is sufficient for a man well nurtured, and he fetcheth not his wind short upon his bed.","searchKeywords":["very","little","sufficient","for","man","well","nurtured","and","fetcheth","not","his","wind","short","upon","bed"]},{"verseId":"brenton_sirach_34_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":20,"text":"Sound sleep cometh of moderate eating: he riseth early, and his wits are with him: but the pain of watching, and choler, and pangs of the belly, are with an unsatiable man.","searchKeywords":["sound","sleep","cometh","moderate","eating","riseth","early","and","his","wits","are","with","him","but","the","pain","watching","choler","pangs","belly","unsatiable","man"]},{"verseId":"brenton_sirach_34_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":21,"text":"And if thou hast been forced to eat, arise, go forth, vomit, and thou shalt have rest.","searchKeywords":["and","thou","hast","been","forced","eat","arise","forth","vomit","shalt","have","rest"]},{"verseId":"brenton_sirach_34_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":22,"text":"My son, hear me, and despise me not, and at the last thou shalt find as I told thee: in all thy works be quick, so shall there no sickness come unto thee.","searchKeywords":["son","hear","and","despise","not","the","last","thou","shalt","find","told","thee","all","thy","works","quick","shall","there","sickness","come","unto"]},{"verseId":"brenton_sirach_34_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":23,"text":"Whoso is liberal of his meat, men shall speak well of him; and the report of his good housekeeping will be believed.","searchKeywords":["whoso","liberal","his","meat","men","shall","speak","well","him","and","the","report","good","housekeeping","will","believed"]},{"verseId":"brenton_sirach_34_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":24,"text":"But against him that is a niggard of his meat the whole city shall murmur; and the testimonies of his niggardness shall not be doubted of.","searchKeywords":["but","against","him","that","niggard","his","meat","the","whole","city","shall","murmur","and","testimonies","niggardness","not","doubted"]},{"verseId":"brenton_sirach_34_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":25,"text":"Shew not thy valiantness in wine; for wine hath destroyed many.","searchKeywords":["shew","not","thy","valiantness","wine","for","hath","destroyed","many"]},{"verseId":"brenton_sirach_34_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":26,"text":"The furnace proveth the edge by dipping: so doth wine the hearts of the proud by drunkenness.","searchKeywords":["the","furnace","proveth","edge","dipping","doth","wine","hearts","proud","drunkenness"]},{"verseId":"brenton_sirach_34_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":27,"text":"Wine is as good as life to a man, if it be drunk moderately: what life is then to a man that is without wine? for it was made to make men glad.","searchKeywords":["wine","good","life","man","drunk","moderately","what","then","that","without","for","was","made","make","men","glad"]},{"verseId":"brenton_sirach_34_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":28,"text":"Wine measurably drunk and in season bringeth gladness of the heart, and cheerfulness of the mind:","searchKeywords":["wine","measurably","drunk","and","season","bringeth","gladness","the","heart","cheerfulness","mind"]},{"verseId":"brenton_sirach_34_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":29,"text":"but wine drunken with excess maketh bitterness of the mind, with brawling and quarrelling.","searchKeywords":["but","wine","drunken","with","excess","maketh","bitterness","the","mind","brawling","and","quarrelling"]},{"verseId":"brenton_sirach_34_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":30,"text":"Drunkenness increaseth the rage of a fool till he offend: it diminisheth strength, and maketh wounds.","searchKeywords":["drunkenness","increaseth","the","rage","fool","till","offend","diminisheth","strength","and","maketh","wounds"]},{"verseId":"brenton_sirach_34_31","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":34,"verse":31,"text":"Rebuke not thy neighbour at the wine, and despise him not in his mirth: give him no despiteful words, and press not upon him with urging him [to drink].","searchKeywords":["rebuke","not","thy","neighbour","the","wine","and","despise","him","his","mirth","give","despiteful","words","press","upon","with","urging","drink"]}]