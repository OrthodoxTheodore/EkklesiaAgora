[{"verseId":"brenton_sirach_12_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":1,"text":"When thou wilt do good, know to whom thou doest it; so shalt thou be thanked for thy benefits.","searchKeywords":["when","thou","wilt","good","know","whom","doest","shalt","thanked","for","thy","benefits"]},{"verseId":"brenton_sirach_12_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":2,"text":"Do good to the godly man, and thou shalt find a recompence; and if not from him, yet from the most High.","searchKeywords":["good","the","godly","man","and","thou","shalt","find","recompence","not","from","him","yet","most","high"]},{"verseId":"brenton_sirach_12_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":3,"text":"There can no good come to him that is always occupied in evil, nor to him that giveth no alms.","searchKeywords":["there","can","good","come","him","that","always","occupied","evil","nor","giveth","alms"]},{"verseId":"brenton_sirach_12_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":4,"text":"Give to the godly man, and help not a sinner.","searchKeywords":["give","the","godly","man","and","help","not","sinner"]},{"verseId":"brenton_sirach_12_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":5,"text":"Do well unto him that is lowly, but give not to the ungodly: hold back thy bread, and give it not unto him, lest he overmaster thee thereby: for [else] thou shalt receive twice as much evil for all the good thou shalt have done unto him.","searchKeywords":["well","unto","him","that","lowly","but","give","not","the","ungodly","hold","back","thy","bread","and","lest","overmaster","thee","thereby","for","else","thou","shalt","receive","twice","much","evil","all","good","have","done"]},{"verseId":"brenton_sirach_12_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":6,"text":"For the most High hateth sinners, and will repay vengeance unto the ungodly, and keepeth them against the mighty day of their punishment.","searchKeywords":["for","the","most","high","hateth","sinners","and","will","repay","vengeance","unto","ungodly","keepeth","them","against","mighty","day","their","punishment"]},{"verseId":"brenton_sirach_12_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":7,"text":"Give unto the good, and help not the sinner.","searchKeywords":["give","unto","the","good","and","help","not","sinner"]},{"verseId":"brenton_sirach_12_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":8,"text":"A friend cannot be known in prosperity: and an enemy cannot be hidden in adversity.","searchKeywords":["friend","cannot","known","prosperity","and","enemy","hidden","adversity"]},{"verseId":"brenton_sirach_12_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":9,"text":"In the prosperity of a man enemies will be grieved: but in his adversity even a friend will depart.","searchKeywords":["the","prosperity","man","enemies","will","grieved","but","his","adversity","even","friend","depart"]},{"verseId":"brenton_sirach_12_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":10,"text":"Never trust thine enemy: for like as iron rusteth, so is his wickedness.","searchKeywords":["never","trust","thine","enemy","for","like","iron","rusteth","his","wickedness"]},{"verseId":"brenton_sirach_12_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":11,"text":"Though he humble himself, and go crouching, yet take good heed and beware of him, and thou shalt be unto him as if thou hadst wiped a looking-glass, and thou shalt know that his rust hath not been altogether wiped away.","searchKeywords":["though","humble","himself","and","crouching","yet","take","good","heed","beware","him","thou","shalt","unto","hadst","wiped","looking","glass","know","that","his","rust","hath","not","been","altogether","away"]},{"verseId":"brenton_sirach_12_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":12,"text":"Set him not by thee, lest, when he hath overthrown thee, he stand up in thy place; neither let him sit at thy right hand, lest he seek to take thy seat, and thou at the last remember my words, and be pricked therewith.","searchKeywords":["set","him","not","thee","lest","when","hath","overthrown","stand","thy","place","neither","let","sit","right","hand","seek","take","seat","and","thou","the","last","remember","words","pricked","therewith"]},{"verseId":"brenton_sirach_12_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":13,"text":"Who will pity a charmer that is bitten with a serpent, or any such as come nigh wild beasts?","searchKeywords":["who","will","pity","charmer","that","bitten","with","serpent","any","such","come","nigh","wild","beasts"]},{"verseId":"brenton_sirach_12_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":14,"text":"So one that goeth to a sinner, and is defiled with him in his sins, who will pity?","searchKeywords":["one","that","goeth","sinner","and","defiled","with","him","his","sins","who","will","pity"]},{"verseId":"brenton_sirach_12_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":15,"text":"For a while he will abide with thee, but if thou begin to fall, he will not tarry.","searchKeywords":["for","while","will","abide","with","thee","but","thou","begin","fall","not","tarry"]},{"verseId":"brenton_sirach_12_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":16,"text":"An enemy speaketh sweetly with his lips, but in his heart he imagineth how to throw thee into a pit: he will weep with his eyes, but if he find opportunity, he will not be satisfied with blood.","searchKeywords":["enemy","speaketh","sweetly","with","his","lips","but","heart","imagineth","how","throw","thee","into","pit","will","weep","eyes","find","opportunity","not","satisfied","blood"]},{"verseId":"brenton_sirach_12_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":17,"text":"If adversity come upon thee, thou shalt find him there first; and though he pretend to help thee, yet shall he undermine thee.","searchKeywords":["adversity","come","upon","thee","thou","shalt","find","him","there","first","and","though","pretend","help","yet","shall","undermine"]},{"verseId":"brenton_sirach_12_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":12,"verse":18,"text":"He will shake his head, and clap his hands, and whisper much, and change his countenance.","searchKeywords":["will","shake","his","head","and","clap","hands","whisper","much","change","countenance"]}]