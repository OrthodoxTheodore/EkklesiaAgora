[{"verseId":"brenton_sirach_32_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":1,"text":"He that keepeth the law bringeth offerings enough: he that taketh heed to the commandment offereth a peace offering.","searchKeywords":["that","keepeth","the","law","bringeth","offerings","enough","taketh","heed","commandment","offereth","peace","offering"]},{"verseId":"brenton_sirach_32_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":2,"text":"He that requiteth a good turn offereth fine flour; and he that giveth alms sacrificeth praise.","searchKeywords":["that","requiteth","good","turn","offereth","fine","flour","and","giveth","alms","sacrificeth","praise"]},{"verseId":"brenton_sirach_32_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":3,"text":"To depart from wickedness is a thing pleasing to the Lord; and to forsake unrighteousness is a propitiation.","searchKeywords":["depart","from","wickedness","thing","pleasing","the","lord","and","forsake","unrighteousness","propitiation"]},{"verseId":"brenton_sirach_32_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":4,"text":"Thou shalt not appear empty before the Lord.","searchKeywords":["thou","shalt","not","appear","empty","before","the","lord"]},{"verseId":"brenton_sirach_32_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":5,"text":"For all these things [are to be done] because of the commandment.","searchKeywords":["for","all","these","things","are","done","because","the","commandment"]},{"verseId":"brenton_sirach_32_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":6,"text":"The offering of the righteous maketh the altar fat, and the sweet savour thereof before the most High.","searchKeywords":["the","offering","righteous","maketh","altar","fat","and","sweet","savour","thereof","before","most","high"]},{"verseId":"brenton_sirach_32_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":7,"text":"The sacrifice of a just man is acceptable, and the memorial thereof shall never be forgotten.","searchKeywords":["the","sacrifice","just","man","acceptable","and","memorial","thereof","shall","never","forgotten"]},{"verseId":"brenton_sirach_32_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":8,"text":"Give the Lord his honour with a good eye, and diminish not the firstfruits of thine hands.","searchKeywords":["give","the","lord","his","honour","with","good","eye","and","diminish","not","firstfruits","thine","hands"]},{"verseId":"brenton_sirach_32_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":9,"text":"In all thy gifts shew a cheerful countenance, and dedicate thy tithes with gladness.","searchKeywords":["all","thy","gifts","shew","cheerful","countenance","and","dedicate","tithes","with","gladness"]},{"verseId":"brenton_sirach_32_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":10,"text":"Give unto the most High according as he hath enriched thee; and as thou hast gotten, give with a cheerful eye.","searchKeywords":["give","unto","the","most","high","according","hath","enriched","thee","and","thou","hast","gotten","with","cheerful","eye"]},{"verseId":"brenton_sirach_32_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":11,"text":"For the Lord recompenseth, and will give thee seven times as much.","searchKeywords":["for","the","lord","recompenseth","and","will","give","thee","seven","times","much"]},{"verseId":"brenton_sirach_32_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":12,"text":"Do not think to corrupt with gifts: for such he will not receive: and trust not to unrighteous sacrifices; for the Lord is judge, and with him is no respect of persons.","searchKeywords":["not","think","corrupt","with","gifts","for","such","will","receive","and","trust","unrighteous","sacrifices","the","lord","judge","him","respect","persons"]},{"verseId":"brenton_sirach_32_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":13,"text":"He will not accept any person against a poor man, but will hear the prayer of the oppressed.","searchKeywords":["will","not","accept","any","person","against","poor","man","but","hear","the","prayer","oppressed"]},{"verseId":"brenton_sirach_32_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":14,"text":"He will not despise the supplication of the fatherless; nor the widow, when she poureth out her complaint.","searchKeywords":["will","not","despise","the","supplication","fatherless","nor","widow","when","she","poureth","out","her","complaint"]},{"verseId":"brenton_sirach_32_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":15,"text":"Do not the tears run down the widow's cheeks? and is not her cry against him that causeth them to fall?","searchKeywords":["not","the","tears","run","down","widow","cheeks","and","her","cry","against","him","that","causeth","them","fall"]},{"verseId":"brenton_sirach_32_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":16,"text":"He that serveth the Lord shall be accepted with favour, and his prayer shall reach unto the clouds.","searchKeywords":["that","serveth","the","lord","shall","accepted","with","favour","and","his","prayer","reach","unto","clouds"]},{"verseId":"brenton_sirach_32_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":17,"text":"The prayer of the humble pierceth the clouds: and till it come nigh, he will not be comforted; and will not depart, till the most High shall behold to judge righteously, and execute judgment.","searchKeywords":["the","prayer","humble","pierceth","clouds","and","till","come","nigh","will","not","comforted","depart","most","high","shall","behold","judge","righteously","execute","judgment"]},{"verseId":"brenton_sirach_32_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":18,"text":"For the Lord will not be slack, neither will the Mighty be patient toward them, till he have smitten in sunder the loins of the unmerciful, and repayed vengeance to the heathen; till he have taken away the multitude of the proud, and broken the sceptre of the unrighteous;","searchKeywords":["for","the","lord","will","not","slack","neither","mighty","patient","toward","them","till","have","smitten","sunder","loins","unmerciful","and","repayed","vengeance","heathen","taken","away","multitude","proud","broken","sceptre","unrighteous"]},{"verseId":"brenton_sirach_32_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":19,"text":"till he have rendered to every man according to his deeds, and to the works of men according to their devices; till he have judged the cause of his people, and made them to rejoice in his mercy.","searchKeywords":["till","have","rendered","every","man","according","his","deeds","and","the","works","men","their","devices","judged","cause","people","made","them","rejoice","mercy"]},{"verseId":"brenton_sirach_32_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":32,"verse":20,"text":"Mercy is seasonable in the time of affliction, as clouds of rain in the time of drought.","searchKeywords":["mercy","seasonable","the","time","affliction","clouds","rain","drought"]}]