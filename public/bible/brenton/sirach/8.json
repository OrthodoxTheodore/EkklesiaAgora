[{"verseId":"brenton_sirach_8_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":1,"text":"Strive not with a mighty man, lest thou fall into his hands.","searchKeywords":["strive","not","with","mighty","man","lest","thou","fall","into","his","hands"]},{"verseId":"brenton_sirach_8_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":2,"text":"Be not at variance with a rich man, lest he overweigh thee: for gold hath destroyed many, and perverted the hearts of kings.","searchKeywords":["not","variance","with","rich","man","lest","overweigh","thee","for","gold","hath","destroyed","many","and","perverted","the","hearts","kings"]},{"verseId":"brenton_sirach_8_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":3,"text":"Strive not with a man that is full of tongue, and heap not wood upon his fire.","searchKeywords":["strive","not","with","man","that","full","tongue","and","heap","wood","upon","his","fire"]},{"verseId":"brenton_sirach_8_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":4,"text":"Jest not with a rude man, lest thy ancestors be disgraced.","searchKeywords":["jest","not","with","rude","man","lest","thy","ancestors","disgraced"]},{"verseId":"brenton_sirach_8_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":5,"text":"Reproach not a man that turneth from sin, but remember that we are all worthy of punishment.","searchKeywords":["reproach","not","man","that","turneth","from","sin","but","remember","are","all","worthy","punishment"]},{"verseId":"brenton_sirach_8_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":6,"text":"Dishonour not a man in his old age: for even some of us wax old.","searchKeywords":["dishonour","not","man","his","old","age","for","even","some","wax"]},{"verseId":"brenton_sirach_8_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":7,"text":"Rejoice not over thy greatest enemy being dead, but remember that we die all.","searchKeywords":["rejoice","not","over","thy","greatest","enemy","being","dead","but","remember","that","die","all"]},{"verseId":"brenton_sirach_8_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":8,"text":"Despise not the discourse of the wise, but acquaint thyself with their proverbs: for of them thou shalt learn instruction, and how to serve great men with ease.","searchKeywords":["despise","not","the","discourse","wise","but","acquaint","thyself","with","their","proverbs","for","them","thou","shalt","learn","instruction","and","how","serve","great","men","ease"]},{"verseId":"brenton_sirach_8_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":9,"text":"Miss not the discourse of the elders: for they also learned of their fathers, and of them thou shalt learn understanding, and to give answer as need requireth.","searchKeywords":["miss","not","the","discourse","elders","for","they","also","learned","their","fathers","and","them","thou","shalt","learn","understanding","give","answer","need","requireth"]},{"verseId":"brenton_sirach_8_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":10,"text":"Kindle not the coals of a sinner, lest thou be burnt with the flame of his fire.","searchKeywords":["kindle","not","the","coals","sinner","lest","thou","burnt","with","flame","his","fire"]},{"verseId":"brenton_sirach_8_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":11,"text":"Rise not up [in anger] at the presence of an injurious person, lest he lie in wait to entrap thee in thy words.","searchKeywords":["rise","not","anger","the","presence","injurious","person","lest","lie","wait","entrap","thee","thy","words"]},{"verseId":"brenton_sirach_8_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":12,"text":"Lend not unto him that is mightier than thyself; for if thou lendest him, count it but lost.","searchKeywords":["lend","not","unto","him","that","mightier","than","thyself","for","thou","lendest","count","but","lost"]},{"verseId":"brenton_sirach_8_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":13,"text":"Be not surety above thy power: for if thou be surety, take care to pay it.","searchKeywords":["not","surety","above","thy","power","for","thou","take","care","pay"]},{"verseId":"brenton_sirach_8_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":14,"text":"Go not to law with a judge; for they will judge for him according to his honour.","searchKeywords":["not","law","with","judge","for","they","will","him","according","his","honour"]},{"verseId":"brenton_sirach_8_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":15,"text":"Travel not by the way with a bold fellow, lest he become grievous unto thee: for he will do according to his own will, and thou shalt perish with him through his folly.","searchKeywords":["travel","not","the","way","with","bold","fellow","lest","become","grievous","unto","thee","for","will","according","his","own","and","thou","shalt","perish","him","through","folly"]},{"verseId":"brenton_sirach_8_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":16,"text":"Strive not with an angry man, and go not with him into a solitary place: for blood is as nothing in his sight; and where there is no help, he will overthrow thee.","searchKeywords":["strive","not","with","angry","man","and","him","into","solitary","place","for","blood","nothing","his","sight","where","there","help","will","overthrow","thee"]},{"verseId":"brenton_sirach_8_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":17,"text":"Consult not with a fool; for he cannot keep counsel.","searchKeywords":["consult","not","with","fool","for","cannot","keep","counsel"]},{"verseId":"brenton_sirach_8_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":18,"text":"Do no secret thing before a stranger: for thou knowest not what he will bring forth.","searchKeywords":["secret","thing","before","stranger","for","thou","knowest","not","what","will","bring","forth"]},{"verseId":"brenton_sirach_8_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":8,"verse":19,"text":"Open not thine heart to every man, lest he requite thee with a shrewd turn.","searchKeywords":["open","not","thine","heart","every","man","lest","requite","thee","with","shrewd","turn"]}]