[{"verseId":"brenton_sirach_20_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":1,"text":"There is a reproof that is not comely: again, some man holdeth his tongue, and he is wise.","searchKeywords":["there","reproof","that","not","comely","again","some","man","holdeth","his","tongue","and","wise"]},{"verseId":"brenton_sirach_20_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":2,"text":"It is much better to reprove, than to be angry secretly:","searchKeywords":["much","better","reprove","than","angry","secretly"]},{"verseId":"brenton_sirach_20_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":3,"text":"and he that confesseth his fault shall be preserved from hurt.","searchKeywords":["and","that","confesseth","his","fault","shall","preserved","from","hurt"]},{"verseId":"brenton_sirach_20_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":4,"text":"As is the lust of an eunuch to deflower a virgin; so is he that executeth judgment with violence.","searchKeywords":["the","lust","eunuch","deflower","virgin","that","executeth","judgment","with","violence"]},{"verseId":"brenton_sirach_20_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":5,"text":"There is one that keepeth silence, and is found wise: and another by much babbling becometh hateful.","searchKeywords":["there","one","that","keepeth","silence","and","found","wise","another","much","babbling","becometh","hateful"]},{"verseId":"brenton_sirach_20_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":6,"text":"Some man holdeth his tongue, because he hath not to answer: and some keepeth silence, knowing his time.","searchKeywords":["some","man","holdeth","his","tongue","because","hath","not","answer","and","keepeth","silence","knowing","time"]},{"verseId":"brenton_sirach_20_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":7,"text":"A wise man will hold his tongue till he see opportunity: but a babbler and a fool will regard no time.","searchKeywords":["wise","man","will","hold","his","tongue","till","see","opportunity","but","babbler","and","fool","regard","time"]},{"verseId":"brenton_sirach_20_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":8,"text":"He that useth many words shall be abhorred; and he that taketh to himself authority therein shall be hated.","searchKeywords":["that","useth","many","words","shall","abhorred","and","taketh","himself","authority","therein","hated"]},{"verseId":"brenton_sirach_20_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":9,"text":"There is a sinner that hath good success in evil things; and there is a gain that turneth to loss.","searchKeywords":["there","sinner","that","hath","good","success","evil","things","and","gain","turneth","loss"]},{"verseId":"brenton_sirach_20_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":10,"text":"There is a gift that shall not profit thee; and there is a gift whose recompence is double.","searchKeywords":["there","gift","that","shall","not","profit","thee","and","whose","recompence","double"]},{"verseId":"brenton_sirach_20_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":11,"text":"There is an abasement because of glory; and there is that lifteth up his head from a low estate.","searchKeywords":["there","abasement","because","glory","and","that","lifteth","his","head","from","low","estate"]},{"verseId":"brenton_sirach_20_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":12,"text":"There is that buyeth much for a little, and repayeth it sevenfold.","searchKeywords":["there","that","buyeth","much","for","little","and","repayeth","sevenfold"]},{"verseId":"brenton_sirach_20_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":13,"text":"A wise man by his words maketh himself beloved: but the graces of fools shall be poured out.","searchKeywords":["wise","man","his","words","maketh","himself","beloved","but","the","graces","fools","shall","poured","out"]},{"verseId":"brenton_sirach_20_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":14,"text":"The gift of a fool shall do thee no good when thou hast it; neither yet of the envious for his necessity: for he looketh to receive many things for one.","searchKeywords":["the","gift","fool","shall","thee","good","when","thou","hast","neither","yet","envious","for","his","necessity","looketh","receive","many","things","one"]},{"verseId":"brenton_sirach_20_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":15,"text":"He giveth little, and upbraideth much; he openeth his mouth like a crier; to-day he lendeth, and to-morrow will he ask it again: such an one is to be hated of God and man.","searchKeywords":["giveth","little","and","upbraideth","much","openeth","his","mouth","like","crier","day","lendeth","morrow","will","ask","again","such","one","hated","god","man"]},{"verseId":"brenton_sirach_20_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":16,"text":"The fool saith, I have no friends, I have no thank for all my good deeds, and they that eat my bread speak evil of me.","searchKeywords":["the","fool","saith","have","friends","thank","for","all","good","deeds","and","they","that","eat","bread","speak","evil"]},{"verseId":"brenton_sirach_20_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":17,"text":"How oft, and of how many shall he be laughed to scorn!","searchKeywords":["how","oft","and","many","shall","laughed","scorn"]},{"verseId":"brenton_sirach_20_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":18,"text":"To slip upon a pavement is better than to slip with the tongue: so the fall of the wicked shall come speedily.","searchKeywords":["slip","upon","pavement","better","than","with","the","tongue","fall","wicked","shall","come","speedily"]},{"verseId":"brenton_sirach_20_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":19,"text":"An unseasonable tale will always be in the mouth of the unwise.","searchKeywords":["unseasonable","tale","will","always","the","mouth","unwise"]},{"verseId":"brenton_sirach_20_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":20,"text":"A wise sentence shall be rejected when it cometh out of a fool's mouth; for he will not speak it in due season.","searchKeywords":["wise","sentence","shall","rejected","when","cometh","out","fool","mouth","for","will","not","speak","due","season"]},{"verseId":"brenton_sirach_20_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":21,"text":"There is that is hindered from sinning through want: and when he taketh rest, he shall not be troubled.","searchKeywords":["there","that","hindered","from","sinning","through","want","and","when","taketh","rest","shall","not","troubled"]},{"verseId":"brenton_sirach_20_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":22,"text":"There is that destroyeth his own soul through bashfulness, and by accepting of persons overthroweth himself.","searchKeywords":["there","that","destroyeth","his","own","soul","through","bashfulness","and","accepting","persons","overthroweth","himself"]},{"verseId":"brenton_sirach_20_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":23,"text":"There is that for bashfulness promiseth to his friend, and maketh him his enemy for nothing.","searchKeywords":["there","that","for","bashfulness","promiseth","his","friend","and","maketh","him","enemy","nothing"]},{"verseId":"brenton_sirach_20_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":24,"text":"A lie is a foul blot in a man, yet it is continually in the mouth of the untaught.","searchKeywords":["lie","foul","blot","man","yet","continually","the","mouth","untaught"]},{"verseId":"brenton_sirach_20_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":25,"text":"A thief is better than a man that is accustomed to lie: but they both shall have destruction to heritage.","searchKeywords":["thief","better","than","man","that","accustomed","lie","but","they","both","shall","have","destruction","heritage"]},{"verseId":"brenton_sirach_20_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":26,"text":"The disposition of a liar is dishonourable, and his shame is ever with him.","searchKeywords":["the","disposition","liar","dishonourable","and","his","shame","ever","with","him"]},{"verseId":"brenton_sirach_20_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":27,"text":"A wise man shall promote himself with his words: and he that hath understanding will please great men.","searchKeywords":["wise","man","shall","promote","himself","with","his","words","and","that","hath","understanding","will","please","great","men"]},{"verseId":"brenton_sirach_20_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":28,"text":"He that tilleth his land shall increase his heap: and he that pleaseth great men shall get pardon for iniquity.","searchKeywords":["that","tilleth","his","land","shall","increase","heap","and","pleaseth","great","men","get","pardon","for","iniquity"]},{"verseId":"brenton_sirach_20_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":29,"text":"Presents and gifts blind the eyes of the wise, and stop up his mouth that he cannot reprove.","searchKeywords":["presents","and","gifts","blind","the","eyes","wise","stop","his","mouth","that","cannot","reprove"]},{"verseId":"brenton_sirach_20_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":30,"text":"Wisdom that is hid, and treasure that is hoarded up, what profit is in them both?","searchKeywords":["wisdom","that","hid","and","treasure","hoarded","what","profit","them","both"]},{"verseId":"brenton_sirach_20_31","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":20,"verse":31,"text":"Better is he that hideth his folly than a man that hideth his wisdom.","searchKeywords":["better","that","hideth","his","folly","than","man","wisdom"]}]