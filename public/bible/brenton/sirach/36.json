[{"verseId":"brenton_sirach_36_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":1,"text":"There shall no evil happen unto him that feareth the Lord; but in temptation even again he will deliver him.","searchKeywords":["there","shall","evil","happen","unto","him","that","feareth","the","lord","but","temptation","even","again","will","deliver"]},{"verseId":"brenton_sirach_36_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":2,"text":"A wise man hateth not the law; but he that is an hypocrite therein is as a ship in a storm.","searchKeywords":["wise","man","hateth","not","the","law","but","that","hypocrite","therein","ship","storm"]},{"verseId":"brenton_sirach_36_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":3,"text":"A man of understanding trusteth in the law; and the law is faithful unto him, as an oracle.","searchKeywords":["man","understanding","trusteth","the","law","and","faithful","unto","him","oracle"]},{"verseId":"brenton_sirach_36_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":4,"text":"Prepare what to say, and so thou shalt be heard: and bind up instruction, and then make answer.","searchKeywords":["prepare","what","say","and","thou","shalt","heard","bind","instruction","then","make","answer"]},{"verseId":"brenton_sirach_36_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":5,"text":"The heart of the foolish is like a cartwheel; and his thoughts are like a rolling axle-tree.","searchKeywords":["the","heart","foolish","like","cartwheel","and","his","thoughts","are","rolling","axle","tree"]},{"verseId":"brenton_sirach_36_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":6,"text":"A stallion horse is as a mocking friend, he neigheth under every one that sitteth upon him.","searchKeywords":["stallion","horse","mocking","friend","neigheth","under","every","one","that","sitteth","upon","him"]},{"verseId":"brenton_sirach_36_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":7,"text":"Why doth one day excel another, when as all the light of every day in the year is of the sun?","searchKeywords":["why","doth","one","day","excel","another","when","all","the","light","every","year","sun"]},{"verseId":"brenton_sirach_36_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":8,"text":"By the knowledge of the Lord they were distinguished: and he altered seasons and feasts.","searchKeywords":["the","knowledge","lord","they","were","distinguished","and","altered","seasons","feasts"]},{"verseId":"brenton_sirach_36_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":9,"text":"Some of them hath he made high days, and hallowed , and some of them hath he made ordinary days.","searchKeywords":["some","them","hath","made","high","days","and","hallowed","ordinary"]},{"verseId":"brenton_sirach_36_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":10,"text":"And all men are from the ground, and Adam was created of earth.","searchKeywords":["and","all","men","are","from","the","ground","adam","was","created","earth"]},{"verseId":"brenton_sirach_36_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":11,"text":"In much knowledge the Lord hath divided them, and made their ways diverse.","searchKeywords":["much","knowledge","the","lord","hath","divided","them","and","made","their","ways","diverse"]},{"verseId":"brenton_sirach_36_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":12,"text":"Some of them hath he blessed and exalted, and some of them hath he sanctified, and set near himself: but some of them hath he cursed and brought low, and turned out of their places.","searchKeywords":["some","them","hath","blessed","and","exalted","sanctified","set","near","himself","but","cursed","brought","low","turned","out","their","places"]},{"verseId":"brenton_sirach_36_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":13,"text":"As the clay is in the potter's hand, to fashion it at his pleasure: so man is in the hand of him that made him, to render to them as liketh him best.","searchKeywords":["the","clay","potter","hand","fashion","his","pleasure","man","him","that","made","render","them","liketh","best"]},{"verseId":"brenton_sirach_36_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":14,"text":"Good is set against evil, and life against death: so is the godly against the sinner, and the sinner against the godly.","searchKeywords":["good","set","against","evil","and","life","death","the","godly","sinner"]},{"verseId":"brenton_sirach_36_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":15,"text":"So look upon all the works of the most High; and there are two and two, one against another.","searchKeywords":["look","upon","all","the","works","most","high","and","there","are","two","one","against","another"]},{"verseId":"brenton_sirach_36_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":16,"text":"Though I was the last to wake up, yet I received their inheritance as from the beginning.","searchKeywords":["though","was","the","last","wake","yet","received","their","inheritance","from","beginning"]},{"verseId":"brenton_sirach_36_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":17,"text":"O Lord have mercy upon the people that is called by thy name, and upon Israel, whom thou hast named thy firstborn.","searchKeywords":["lord","have","mercy","upon","the","people","that","called","thy","name","and","israel","whom","thou","hast","named","firstborn"]},{"verseId":"brenton_sirach_36_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":18,"text":"O be merciful unto Jerusalem, thy holy city, the place of thy rest.","searchKeywords":["merciful","unto","jerusalem","thy","holy","city","the","place","rest"]},{"verseId":"brenton_sirach_36_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":19,"text":"Fill Sion with thine unspeakable oracles, and thy people with thy glory.","searchKeywords":["fill","sion","with","thine","unspeakable","oracles","and","thy","people","glory"]},{"verseId":"brenton_sirach_36_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":20,"text":"Give testimony unto those that thou hast possessed from the beginning, and raise up prophets that have been in thy name.","searchKeywords":["give","testimony","unto","those","that","thou","hast","possessed","from","the","beginning","and","raise","prophets","have","been","thy","name"]},{"verseId":"brenton_sirach_36_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":21,"text":"Reward them that wait for thee, and let thy prophets be found faithful.","searchKeywords":["reward","them","that","wait","for","thee","and","let","thy","prophets","found","faithful"]},{"verseId":"brenton_sirach_36_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":22,"text":"O Lord, hear the prayer of thy servants, according to the blessing of Aaron over thy people, that all they which dwell upon the earth may know that thou art the Lord, the eternal God.","searchKeywords":["lord","hear","the","prayer","thy","servants","according","blessing","aaron","over","people","that","all","they","which","dwell","upon","earth","may","know","thou","art","eternal","god"]},{"verseId":"brenton_sirach_36_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":23,"text":"The belly devoureth all meats, yet is one meat better than another.","searchKeywords":["the","belly","devoureth","all","meats","yet","one","meat","better","than","another"]},{"verseId":"brenton_sirach_36_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":24,"text":"As the palate tasteth divers kinds of venison: so doth an heart of understanding false speeches.","searchKeywords":["the","palate","tasteth","divers","kinds","venison","doth","heart","understanding","false","speeches"]},{"verseId":"brenton_sirach_36_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":25,"text":"A froward heart causeth heaviness: but a man of experience will recompense him.","searchKeywords":["froward","heart","causeth","heaviness","but","man","experience","will","recompense","him"]},{"verseId":"brenton_sirach_36_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":26,"text":"A woman will receive every man, yet is one daughter better than another.","searchKeywords":["woman","will","receive","every","man","yet","one","daughter","better","than","another"]},{"verseId":"brenton_sirach_36_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":27,"text":"The beauty of a woman cheereth the countenance, and a man loveth nothing better.","searchKeywords":["the","beauty","woman","cheereth","countenance","and","man","loveth","nothing","better"]},{"verseId":"brenton_sirach_36_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":28,"text":"If there be kindness, meekness, and comfort, in her tongue, then is not her husband like other men.","searchKeywords":["there","kindness","meekness","and","comfort","her","tongue","then","not","husband","like","other","men"]},{"verseId":"brenton_sirach_36_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":29,"text":"He that getteth a wife beginneth a possession, a help like unto himself, and a pillar of rest.","searchKeywords":["that","getteth","wife","beginneth","possession","help","like","unto","himself","and","pillar","rest"]},{"verseId":"brenton_sirach_36_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":30,"text":"Where no hedge is, there the possession is spoiled: and he that hath no wife will wander up and down mourning.","searchKeywords":["where","hedge","there","the","possession","spoiled","and","that","hath","wife","will","wander","down","mourning"]},{"verseId":"brenton_sirach_36_31","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":36,"verse":31,"text":"Who will trust a thief well appointed, that skippeth from city to city? so [who will believe] a man that hath no house, and lodgeth wheresoever the night taketh him?","searchKeywords":["who","will","trust","thief","well","appointed","that","skippeth","from","city","believe","man","hath","house","and","lodgeth","wheresoever","the","night","taketh","him"]}]