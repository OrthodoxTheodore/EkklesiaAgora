[{"verseId":"brenton_sirach_30_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":1,"text":"He that loveth his son causeth him oft to feel the rod, that he may have joy of him in the end.","searchKeywords":["that","loveth","his","son","causeth","him","oft","feel","the","rod","may","have","joy","end"]},{"verseId":"brenton_sirach_30_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":2,"text":"He that chastiseth his son shall have joy in him, and shall rejoice of him among his acquaintance.","searchKeywords":["that","chastiseth","his","son","shall","have","joy","him","and","rejoice","among","acquaintance"]},{"verseId":"brenton_sirach_30_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":3,"text":"He that teacheth his son grieveth the enemy: and before his friends he shall rejoice of him.","searchKeywords":["that","teacheth","his","son","grieveth","the","enemy","and","before","friends","shall","rejoice","him"]},{"verseId":"brenton_sirach_30_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":4,"text":"Though his father die, yet he is as though he were not dead: for he hath left one behind him that is like himself.","searchKeywords":["though","his","father","die","yet","were","not","dead","for","hath","left","one","behind","him","that","like","himself"]},{"verseId":"brenton_sirach_30_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":5,"text":"While he lived, he saw and rejoiced in him: and when he died, he was not sorrowful.","searchKeywords":["while","lived","saw","and","rejoiced","him","when","died","was","not","sorrowful"]},{"verseId":"brenton_sirach_30_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":6,"text":"He left behind him an avenger against his enemies, and one that shall requite kindness to his friends.","searchKeywords":["left","behind","him","avenger","against","his","enemies","and","one","that","shall","requite","kindness","friends"]},{"verseId":"brenton_sirach_30_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":7,"text":"He that maketh too much of his son shall bind up his wounds; and his bowels will be troubled at every cry.","searchKeywords":["that","maketh","too","much","his","son","shall","bind","wounds","and","bowels","will","troubled","every","cry"]},{"verseId":"brenton_sirach_30_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":8,"text":"An horse not broken becometh headstrong: and a child left to himself will be wilful.","searchKeywords":["horse","not","broken","becometh","headstrong","and","child","left","himself","will","wilful"]},{"verseId":"brenton_sirach_30_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":9,"text":"Cocker thy child, and he shall make thee afraid: play with him, and he will bring thee to heaviness.","searchKeywords":["cocker","thy","child","and","shall","make","thee","afraid","play","with","him","will","bring","heaviness"]},{"verseId":"brenton_sirach_30_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":10,"text":"Laugh not with him, lest thou have sorrow with him, and lest thou gnash thy teeth in the end.","searchKeywords":["laugh","not","with","him","lest","thou","have","sorrow","and","gnash","thy","teeth","the","end"]},{"verseId":"brenton_sirach_30_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":11,"text":"Give him not liberty in youth.","searchKeywords":["give","him","not","liberty","youth"]},{"verseId":"brenton_sirach_30_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":12,"text":"Beat his sides while he is still young, lest becoming stubborn, he disobey thee.","searchKeywords":["beat","his","sides","while","still","young","lest","becoming","stubborn","disobey","thee"]},{"verseId":"brenton_sirach_30_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":13,"text":"Train up thy son, and exercise him with work, lest by thy looseness thou stumble.","searchKeywords":["train","thy","son","and","exercise","him","with","work","lest","looseness","thou","stumble"]},{"verseId":"brenton_sirach_30_33","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":30,"verse":33,"text":"for the ass; and bread, correction, and work, for a servant.","searchKeywords":["for","the","ass","and","bread","correction","work","servant"]}]