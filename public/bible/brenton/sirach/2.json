[{"verseId":"brenton_sirach_2_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":1,"text":"My son, if thou come to serve the Lord God, prepare thy soul for temptation.","searchKeywords":["son","thou","come","serve","the","lord","god","prepare","thy","soul","for","temptation"]},{"verseId":"brenton_sirach_2_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":2,"text":"Set thy heart aright, and constantly endure, and make not haste in time of trouble.","searchKeywords":["set","thy","heart","aright","and","constantly","endure","make","not","haste","time","trouble"]},{"verseId":"brenton_sirach_2_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":3,"text":"Cleave unto him, and depart not away, that thou mayest be increased at thy last end.","searchKeywords":["cleave","unto","him","and","depart","not","away","that","thou","mayest","increased","thy","last","end"]},{"verseId":"brenton_sirach_2_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":4,"text":"Whatsoever is brought upon thee take cheerfully, and be patient when thou art changed to a low estate.","searchKeywords":["whatsoever","brought","upon","thee","take","cheerfully","and","patient","when","thou","art","changed","low","estate"]},{"verseId":"brenton_sirach_2_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":5,"text":"For gold is tried in the fire, and acceptable men in the furnace of adversity.","searchKeywords":["for","gold","tried","the","fire","and","acceptable","men","furnace","adversity"]},{"verseId":"brenton_sirach_2_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":6,"text":"Believe in him, and he will help thee; order thy way aright, and trust in him.","searchKeywords":["believe","him","and","will","help","thee","order","thy","way","aright","trust"]},{"verseId":"brenton_sirach_2_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":7,"text":"Ye that fear the Lord, wait for his mercy; and go not aside, lest ye fall.","searchKeywords":["that","fear","the","lord","wait","for","his","mercy","and","not","aside","lest","fall"]},{"verseId":"brenton_sirach_2_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":8,"text":"Ye that fear the Lord, believe him; and your reward shall not fail.","searchKeywords":["that","fear","the","lord","believe","him","and","your","reward","shall","not","fail"]},{"verseId":"brenton_sirach_2_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":9,"text":"Ye that fear the Lord, hope for good, and for everlasting joy and mercy.","searchKeywords":["that","fear","the","lord","hope","for","good","and","everlasting","joy","mercy"]},{"verseId":"brenton_sirach_2_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":10,"text":"Look at the generations of old, and see; did ever any trust in the Lord, and was confounded? or did any abide in his fear, and was forsaken? or whom did he ever despise, that called upon him?","searchKeywords":["look","the","generations","old","and","see","did","ever","any","trust","lord","was","confounded","abide","his","fear","forsaken","whom","despise","that","called","upon","him"]},{"verseId":"brenton_sirach_2_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":11,"text":"For the Lord is full of compassion and mercy, longsuffering, and very pitiful, and forgiveth sins, and saveth in time of affliction.","searchKeywords":["for","the","lord","full","compassion","and","mercy","longsuffering","very","pitiful","forgiveth","sins","saveth","time","affliction"]},{"verseId":"brenton_sirach_2_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":12,"text":"Woe be to fearful hearts, and faint hands, and the sinner that goeth two ways!","searchKeywords":["woe","fearful","hearts","and","faint","hands","the","sinner","that","goeth","two","ways"]},{"verseId":"brenton_sirach_2_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":13,"text":"Woe unto him that is fainthearted! for he believeth not; therefore shall he not be defended.","searchKeywords":["woe","unto","him","that","fainthearted","for","believeth","not","therefore","shall","defended"]},{"verseId":"brenton_sirach_2_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":14,"text":"Woe unto you that have lost patience! and what will ye do when the Lord shall visit you?","searchKeywords":["woe","unto","you","that","have","lost","patience","and","what","will","when","the","lord","shall","visit"]},{"verseId":"brenton_sirach_2_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":15,"text":"They that fear the Lord will not disobey his word; and they that love him will keep his ways.","searchKeywords":["they","that","fear","the","lord","will","not","disobey","his","word","and","love","him","keep","ways"]},{"verseId":"brenton_sirach_2_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":16,"text":"They that fear the Lord will seek that which is wellpleasing unto him; and they that love him shall be filled with the law.","searchKeywords":["they","that","fear","the","lord","will","seek","which","wellpleasing","unto","him","and","love","shall","filled","with","law"]},{"verseId":"brenton_sirach_2_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":17,"text":"They that fear the Lord will prepare their hearts, and humble their souls in his sight,","searchKeywords":["they","that","fear","the","lord","will","prepare","their","hearts","and","humble","souls","his","sight"]},{"verseId":"brenton_sirach_2_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":2,"verse":18,"text":", We will fall into the hands of the Lord, and not into the hands of men: for as his majesty is, so is his mercy.","searchKeywords":["will","fall","into","the","hands","lord","and","not","men","for","his","majesty","mercy"]}]