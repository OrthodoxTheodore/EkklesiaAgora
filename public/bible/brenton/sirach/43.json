[{"verseId":"brenton_sirach_43_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":1,"text":"The pride of the height, the clear firmament, the beauty of heaven, with his glorious shew;","searchKeywords":["the","pride","height","clear","firmament","beauty","heaven","with","his","glorious","shew"]},{"verseId":"brenton_sirach_43_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":2,"text":"the sun when it appeareth, declaring at his rising a marvellous instrument, the work of the most High:","searchKeywords":["the","sun","when","appeareth","declaring","his","rising","marvellous","instrument","work","most","high"]},{"verseId":"brenton_sirach_43_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":3,"text":"at noon it parcheth the country, and who can abide the burning heat thereof?","searchKeywords":["noon","parcheth","the","country","and","who","can","abide","burning","heat","thereof"]},{"verseId":"brenton_sirach_43_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":4,"text":"A man blowing a furnace is in works of heat, but the sun burneth the mountains three times more; breathing out fiery vapours, and sending forth bright beams, it dimmeth the eyes.","searchKeywords":["man","blowing","furnace","works","heat","but","the","sun","burneth","mountains","three","times","more","breathing","out","fiery","vapours","and","sending","forth","bright","beams","dimmeth","eyes"]},{"verseId":"brenton_sirach_43_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":5,"text":"Great is the Lord that made it; and at his commandment it runneth hastily.","searchKeywords":["great","the","lord","that","made","and","his","commandment","runneth","hastily"]},{"verseId":"brenton_sirach_43_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":6,"text":"He made the moon also to serve in her season for a declaration of times, and a sign of the world.","searchKeywords":["made","the","moon","also","serve","her","season","for","declaration","times","and","sign","world"]},{"verseId":"brenton_sirach_43_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":7,"text":"From the moon is the sign of feasts, a light that decreaseth in her perfection.","searchKeywords":["from","the","moon","sign","feasts","light","that","decreaseth","her","perfection"]},{"verseId":"brenton_sirach_43_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":8,"text":"The month is called after her name, increasing wonderfully in her changing, being an instrument of the armies above, shining in the firmament of heaven;","searchKeywords":["the","month","called","after","her","name","increasing","wonderfully","changing","being","instrument","armies","above","shining","firmament","heaven"]},{"verseId":"brenton_sirach_43_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":9,"text":"the beauty of heaven, the glory of the stars, an ornament giving light in the highest places of the Lord.","searchKeywords":["the","beauty","heaven","glory","stars","ornament","giving","light","highest","places","lord"]},{"verseId":"brenton_sirach_43_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":10,"text":"At the commandment of the Holy One they will stand in their order, and never faint in their watches.","searchKeywords":["the","commandment","holy","one","they","will","stand","their","order","and","never","faint","watches"]},{"verseId":"brenton_sirach_43_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":11,"text":"Look upon the rainbow, and praise him that made it; very beautiful it is in the brightness thereof.","searchKeywords":["look","upon","the","rainbow","and","praise","him","that","made","very","beautiful","brightness","thereof"]},{"verseId":"brenton_sirach_43_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":12,"text":"It compasseth the heaven about with a glorious circle, and the hands of the most High have bended it.","searchKeywords":["compasseth","the","heaven","about","with","glorious","circle","and","hands","most","high","have","bended"]},{"verseId":"brenton_sirach_43_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":13,"text":"By his commandment he maketh the snow to fall apace, and sendeth swiftly the lightnings of his judgment.","searchKeywords":["his","commandment","maketh","the","snow","fall","apace","and","sendeth","swiftly","lightnings","judgment"]},{"verseId":"brenton_sirach_43_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":14,"text":"Through this the treasures are opened: and clouds fly forth as fowls.","searchKeywords":["through","this","the","treasures","are","opened","and","clouds","fly","forth","fowls"]},{"verseId":"brenton_sirach_43_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":15,"text":"By his great power he maketh the clouds firm, and the hailstones are broken small.","searchKeywords":["his","great","power","maketh","the","clouds","firm","and","hailstones","are","broken","small"]},{"verseId":"brenton_sirach_43_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":16,"text":"At his sight the mountains are shaken, and at his will the south wind bloweth.","searchKeywords":["his","sight","the","mountains","are","shaken","and","will","south","wind","bloweth"]},{"verseId":"brenton_sirach_43_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":17,"text":"The noise of the thunder maketh the earth to tremble: so doth the northern storm and the whirlwind: as birds flying he scattereth the snow, and the falling down thereof is as the lighting of grasshoppers:","searchKeywords":["the","noise","thunder","maketh","earth","tremble","doth","northern","storm","and","whirlwind","birds","flying","scattereth","snow","falling","down","thereof","lighting","grasshoppers"]},{"verseId":"brenton_sirach_43_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":18,"text":"the eye marvelleth at the beauty of the whiteness thereof, and the heart is astonished at the raining of it.","searchKeywords":["the","eye","marvelleth","beauty","whiteness","thereof","and","heart","astonished","raining"]},{"verseId":"brenton_sirach_43_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":19,"text":"The hoarfrost also as salt he poureth on the earth, and being congealed, it becometh sharp peaks.","searchKeywords":["the","hoarfrost","also","salt","poureth","earth","and","being","congealed","becometh","sharp","peaks"]},{"verseId":"brenton_sirach_43_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":20,"text":"When the cold north wind bloweth, and the water is congealed into ice, it abideth upon every gathering together of water, and clotheth the water as with a breastplate.","searchKeywords":["when","the","cold","north","wind","bloweth","and","water","congealed","into","ice","abideth","upon","every","gathering","together","clotheth","with","breastplate"]},{"verseId":"brenton_sirach_43_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":21,"text":"It devoureth the mountains, and burneth the wilderness, and consumeth the grass as fire.","searchKeywords":["devoureth","the","mountains","and","burneth","wilderness","consumeth","grass","fire"]},{"verseId":"brenton_sirach_43_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":22,"text":"A present remedy of all is a mist coming speedily: a dew coming after heat refresheth.","searchKeywords":["present","remedy","all","mist","coming","speedily","dew","after","heat","refresheth"]},{"verseId":"brenton_sirach_43_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":23,"text":"By his counsel he appeaseth the deep, and planteth islands therein.","searchKeywords":["his","counsel","appeaseth","the","deep","and","planteth","islands","therein"]},{"verseId":"brenton_sirach_43_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":24,"text":"They that sail on the sea tell of the danger thereof; and when we hear it with our ears, we marvel thereat.","searchKeywords":["they","that","sail","the","sea","tell","danger","thereof","and","when","hear","with","our","ears","marvel","thereat"]},{"verseId":"brenton_sirach_43_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":25,"text":"For therein be strange and wondrous works, variety of all kinds of beasts, the race of whales.","searchKeywords":["for","therein","strange","and","wondrous","works","variety","all","kinds","beasts","the","race","whales"]},{"verseId":"brenton_sirach_43_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":26,"text":"By him the end of them hath prosperous success, and by his word all things consist.","searchKeywords":["him","the","end","them","hath","prosperous","success","and","his","word","all","things","consist"]},{"verseId":"brenton_sirach_43_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":27,"text":"We may speak much, and yet come short; wherefore in sum, he is all.","searchKeywords":["may","speak","much","and","yet","come","short","wherefore","sum","all"]},{"verseId":"brenton_sirach_43_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":28,"text":"How shall we be able to magnify him? for he is great above all his works.","searchKeywords":["how","shall","able","magnify","him","for","great","above","all","his","works"]},{"verseId":"brenton_sirach_43_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":29,"text":"The Lord is terrible and very great, and marvellous is his power.","searchKeywords":["the","lord","terrible","and","very","great","marvellous","his","power"]},{"verseId":"brenton_sirach_43_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":30,"text":"When ye glorify the Lord, exalt him as much as ye can; for even yet will he far exceed: and when ye exalt him, put forth all your strength, and be not weary; for ye can never go far enough.","searchKeywords":["when","glorify","the","lord","exalt","him","much","can","for","even","yet","will","far","exceed","and","put","forth","all","your","strength","not","weary","never","enough"]},{"verseId":"brenton_sirach_43_31","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":31,"text":"Who hath seen him, that he might tell us? and who can magnify him as he is?","searchKeywords":["who","hath","seen","him","that","might","tell","and","can","magnify"]},{"verseId":"brenton_sirach_43_32","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":32,"text":"There are yet hid greater things than these be, for we have seen but a few of his works.","searchKeywords":["there","are","yet","hid","greater","things","than","these","for","have","seen","but","few","his","works"]},{"verseId":"brenton_sirach_43_33","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":43,"verse":33,"text":"For the Lord hath made all things; and to the godly hath he given wisdom.","searchKeywords":["for","the","lord","hath","made","all","things","and","godly","given","wisdom"]}]