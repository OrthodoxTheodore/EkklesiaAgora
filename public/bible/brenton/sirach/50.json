[{"verseId":"brenton_sirach_50_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":1,"text":"Simon the high priest, the son of Onias, who in his life repaired the house again, and in his days fortified the temple:","searchKeywords":["simon","the","high","priest","son","onias","who","his","life","repaired","house","again","and","days","fortified","temple"]},{"verseId":"brenton_sirach_50_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":2,"text":"and by him was built from the foundation the double height, the high fortress of the wall about the temple:","searchKeywords":["and","him","was","built","from","the","foundation","double","height","high","fortress","wall","about","temple"]},{"verseId":"brenton_sirach_50_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":3,"text":"in his days the cistern to receive water, being in compass as the sea, was covered with plates of brass:","searchKeywords":["his","days","the","cistern","receive","water","being","compass","sea","was","covered","with","plates","brass"]},{"verseId":"brenton_sirach_50_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":4,"text":"he took care of the temple that it should not fall, and fortified the city against besieging:","searchKeywords":["took","care","the","temple","that","should","not","fall","and","fortified","city","against","besieging"]},{"verseId":"brenton_sirach_50_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":5,"text":"how was he honoured in the midst of the people in his coming out of the sanctuary!","searchKeywords":["how","was","honoured","the","midst","people","his","coming","out","sanctuary"]},{"verseId":"brenton_sirach_50_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":6,"text":"He was as the morning star in the midst of a cloud, and as the moon at the full:","searchKeywords":["was","the","morning","star","midst","cloud","and","moon","full"]},{"verseId":"brenton_sirach_50_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":7,"text":"as the sun shining upon the temple of the most High, and as the rainbow giving light in the bright clouds:","searchKeywords":["the","sun","shining","upon","temple","most","high","and","rainbow","giving","light","bright","clouds"]},{"verseId":"brenton_sirach_50_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":8,"text":"and as the flower of roses in the spring of the year, as lilies by the rivers of waters, and as the branches of the frankincense tree in the time of summer:","searchKeywords":["and","the","flower","roses","spring","year","lilies","rivers","waters","branches","frankincense","tree","time","summer"]},{"verseId":"brenton_sirach_50_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":9,"text":"as fire and incense in the censer, and as a vessel of beaten gold set with all manner of precious stones:","searchKeywords":["fire","and","incense","the","censer","vessel","beaten","gold","set","with","all","manner","precious","stones"]},{"verseId":"brenton_sirach_50_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":10,"text":"and as a fair olive tree budding forth fruit, and as a cypress tree which groweth up to the clouds.","searchKeywords":["and","fair","olive","tree","budding","forth","fruit","cypress","which","groweth","the","clouds"]},{"verseId":"brenton_sirach_50_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":11,"text":"When he put on the robe of honour, and was clothed with the perfection of glory, when he went up to the holy altar, he made the garment of holiness honourable.","searchKeywords":["when","put","the","robe","honour","and","was","clothed","with","perfection","glory","went","holy","altar","made","garment","holiness","honourable"]},{"verseId":"brenton_sirach_50_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":12,"text":"When he took the portions out of the priests' hands, he himself stood by the hearth of the altar, compassed with his brethren round about, as a young cedar in Libanus; and as palm trees compassed they him round about.","searchKeywords":["when","took","the","portions","out","priests","hands","himself","stood","hearth","altar","compassed","with","his","brethren","round","about","young","cedar","libanus","and","palm","trees","they","him"]},{"verseId":"brenton_sirach_50_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":13,"text":"So were all the sons of Aaron in their glory, and the oblations of the Lord in their hands, before all the congregation of Israel.","searchKeywords":["were","all","the","sons","aaron","their","glory","and","oblations","lord","hands","before","congregation","israel"]},{"verseId":"brenton_sirach_50_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":14,"text":"And finishing the service at the altar, that he might adorn the offering of the most high Almighty,","searchKeywords":["and","finishing","the","service","altar","that","might","adorn","offering","most","high","almighty"]},{"verseId":"brenton_sirach_50_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":15,"text":"he stretched out his hand to the cup, and poured of the blood of the grape, he poured out at the foot of the altar a sweetsmelling savour unto the most high King of all.","searchKeywords":["stretched","out","his","hand","the","cup","and","poured","blood","grape","foot","altar","sweetsmelling","savour","unto","most","high","king","all"]},{"verseId":"brenton_sirach_50_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":16,"text":"Then shouted the sons of Aaron, and sounded the silver trumpets, and made a great noise to be heard, for a remembrance before the most High.","searchKeywords":["then","shouted","the","sons","aaron","and","sounded","silver","trumpets","made","great","noise","heard","for","remembrance","before","most","high"]},{"verseId":"brenton_sirach_50_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":17,"text":"Then all the people together hasted, and fell down to the earth upon their faces to worship their Lord God Almighty, the most High.","searchKeywords":["then","all","the","people","together","hasted","and","fell","down","earth","upon","their","faces","worship","lord","god","almighty","most","high"]},{"verseId":"brenton_sirach_50_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":18,"text":"The singers also sang praises with their voices, with great variety of sounds was there made sweet melody.","searchKeywords":["the","singers","also","sang","praises","with","their","voices","great","variety","sounds","was","there","made","sweet","melody"]},{"verseId":"brenton_sirach_50_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":19,"text":"And the people besought the Lord, the most High, by prayer before him that is merciful, till the solemnity of the Lord was ended, and they had finished his service.","searchKeywords":["and","the","people","besought","lord","most","high","prayer","before","him","that","merciful","till","solemnity","was","ended","they","had","finished","his","service"]},{"verseId":"brenton_sirach_50_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":20,"text":"Then he went down, and lifted up his hands over the whole congregation of the children of Israel, to give the blessing of the Lord with his lips, and to rejoice in his name.","searchKeywords":["then","went","down","and","lifted","his","hands","over","the","whole","congregation","children","israel","give","blessing","lord","with","lips","rejoice","name"]},{"verseId":"brenton_sirach_50_21","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":21,"text":"And they bowed themselves down to worship the second time, that they might receive a blessing from the most High.","searchKeywords":["and","they","bowed","themselves","down","worship","the","second","time","that","might","receive","blessing","from","most","high"]},{"verseId":"brenton_sirach_50_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":22,"text":"Now therefore bless ye the God of all, which only doeth wondrous things every where, which exalteth our days from the womb, and dealeth with us according to his mercy.","searchKeywords":["now","therefore","bless","the","god","all","which","only","doeth","wondrous","things","every","where","exalteth","our","days","from","womb","and","dealeth","with","according","his","mercy"]},{"verseId":"brenton_sirach_50_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":23,"text":"He grant us joyfulness of heart, and that peace may be in our days in Israel for ever:","searchKeywords":["grant","joyfulness","heart","and","that","peace","may","our","days","israel","for","ever"]},{"verseId":"brenton_sirach_50_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":24,"text":"that he would confirm his mercy with us, and deliver us at his time!","searchKeywords":["that","would","confirm","his","mercy","with","and","deliver","time"]},{"verseId":"brenton_sirach_50_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":25,"text":"There be two manner of nations which my heart abhorreth, and the third is no nation:","searchKeywords":["there","two","manner","nations","which","heart","abhorreth","and","the","third","nation"]},{"verseId":"brenton_sirach_50_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":26,"text":"they that sit upon the mountain of Samaria, and they that dwell among the Philistines, and that foolish people that dwell in Sichem.","searchKeywords":["they","that","sit","upon","the","mountain","samaria","and","dwell","among","philistines","foolish","people","sichem"]},{"verseId":"brenton_sirach_50_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":27,"text":"Jesus the son of Sirach of Jerusalem hath written in this book the instruction of understanding and knowledge, who out of his heart poured forth wisdom.","searchKeywords":["jesus","the","son","sirach","jerusalem","hath","written","this","book","instruction","understanding","and","knowledge","who","out","his","heart","poured","forth","wisdom"]},{"verseId":"brenton_sirach_50_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":28,"text":"Blessed is he that shall be exercised in these things: and he that layeth them up in his heart shall become wise.","searchKeywords":["blessed","that","shall","exercised","these","things","and","layeth","them","his","heart","become","wise"]},{"verseId":"brenton_sirach_50_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":50,"verse":29,"text":"For if he do them, he shall be strong to all things: for the light of the Lord is his path.","searchKeywords":["for","them","shall","strong","all","things","the","light","lord","his","path"]}]