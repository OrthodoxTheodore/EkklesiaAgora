[{"verseId":"brenton_sirach_5_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":1,"text":"Set not thy heart upon thy goods; and say not, I have enough for my life.","searchKeywords":["set","not","thy","heart","upon","goods","and","say","have","enough","for","life"]},{"verseId":"brenton_sirach_5_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":2,"text":"Follow not thine own mind and thy strength, to walk in the ways of thy heart:","searchKeywords":["follow","not","thine","own","mind","and","thy","strength","walk","the","ways","heart"]},{"verseId":"brenton_sirach_5_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":3,"text":"and say not, Who shall control me for my works? for the Lord will surely revenge thy pride.","searchKeywords":["and","say","not","who","shall","control","for","works","the","lord","will","surely","revenge","thy","pride"]},{"verseId":"brenton_sirach_5_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":4,"text":"Say not, I have sinned, and what harm hath happened unto me? for the Lord is longsuffering, he will in no wise let thee go.","searchKeywords":["say","not","have","sinned","and","what","harm","hath","happened","unto","for","the","lord","longsuffering","will","wise","let","thee"]},{"verseId":"brenton_sirach_5_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":5,"text":"Concerning propitiation, be not without fear to add sin unto sin:","searchKeywords":["concerning","propitiation","not","without","fear","add","sin","unto"]},{"verseId":"brenton_sirach_5_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":6,"text":"and say not, His mercy is great; he will be pacified for the multitude of my sins: for mercy and wrath come from him, and his indignation resteth upon sinners.","searchKeywords":["and","say","not","his","mercy","great","will","pacified","for","the","multitude","sins","wrath","come","from","him","indignation","resteth","upon","sinners"]},{"verseId":"brenton_sirach_5_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":7,"text":"Make no tarrying to turn to the Lord, and put not off from day to day: for suddenly shall the wrath of the Lord come forth, and in thy security thou shalt be destroyed, and perish in the day of vengeance.","searchKeywords":["make","tarrying","turn","the","lord","and","put","not","off","from","day","for","suddenly","shall","wrath","come","forth","thy","security","thou","shalt","destroyed","perish","vengeance"]},{"verseId":"brenton_sirach_5_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":8,"text":"Set not thine heart upon goods unjustly gotten; for they shall not profit thee in the day of calamity.","searchKeywords":["set","not","thine","heart","upon","goods","unjustly","gotten","for","they","shall","profit","thee","the","day","calamity"]},{"verseId":"brenton_sirach_5_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":9,"text":"Winnow not with every wind, and go not into every way: for so doth the sinner that hath a double tongue.","searchKeywords":["winnow","not","with","every","wind","and","into","way","for","doth","the","sinner","that","hath","double","tongue"]},{"verseId":"brenton_sirach_5_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":10,"text":"Be stedfast in thy understanding; and let thy word be the same.","searchKeywords":["stedfast","thy","understanding","and","let","word","the","same"]},{"verseId":"brenton_sirach_5_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":11,"text":"Be swift to hear; and let thy life be sincere; and with patience give answer.","searchKeywords":["swift","hear","and","let","thy","life","sincere","with","patience","give","answer"]},{"verseId":"brenton_sirach_5_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":12,"text":"If thou hast understanding, answer thy neighbour; if not, lay thy hand upon thy mouth.","searchKeywords":["thou","hast","understanding","answer","thy","neighbour","not","lay","hand","upon","mouth"]},{"verseId":"brenton_sirach_5_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":13,"text":"Honour and shame is in talk: and the tongue of man is his fall.","searchKeywords":["honour","and","shame","talk","the","tongue","man","his","fall"]},{"verseId":"brenton_sirach_5_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":14,"text":"Be not called a whisperer, and lie not in wait with thy tongue: for a foul shame is upon the thief, and an evil condemnation upon the double tongue.","searchKeywords":["not","called","whisperer","and","lie","wait","with","thy","tongue","for","foul","shame","upon","the","thief","evil","condemnation","double"]},{"verseId":"brenton_sirach_5_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":5,"verse":15,"text":"Be not ignorant of any thing in a great matter or a small.","searchKeywords":["not","ignorant","any","thing","great","matter","small"]}]