[{"verseId":"brenton_sirach_49_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":1,"text":"The remembrance of Josias is like the composition of the perfume that is made by the art of the apothecary: it is sweet as honey in all mouths, and as music at a banquet of wine.","searchKeywords":["the","remembrance","josias","like","composition","perfume","that","made","art","apothecary","sweet","honey","all","mouths","and","music","banquet","wine"]},{"verseId":"brenton_sirach_49_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":2,"text":"He behaved himself uprightly in the conversion of the people, and took away the abominations of iniquity.","searchKeywords":["behaved","himself","uprightly","the","conversion","people","and","took","away","abominations","iniquity"]},{"verseId":"brenton_sirach_49_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":3,"text":"He directed his heart unto the Lord, and in the time of the ungodly he established the worship of God.","searchKeywords":["directed","his","heart","unto","the","lord","and","time","ungodly","established","worship","god"]},{"verseId":"brenton_sirach_49_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":4,"text":"All, except David and Ezekias and Josias, were defective: for they forsook the law of the most High, the kings of Juda failed;","searchKeywords":["all","except","david","and","ezekias","josias","were","defective","for","they","forsook","the","law","most","high","kings","juda","failed"]},{"verseId":"brenton_sirach_49_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":5,"text":"for they gave their power unto others, and their glory to a strange nation.","searchKeywords":["for","they","gave","their","power","unto","others","and","glory","strange","nation"]},{"verseId":"brenton_sirach_49_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":6,"text":"They burnt the chosen city of the sanctuary, and made the streets desolate, according to the prophecy of Jeremias.","searchKeywords":["they","burnt","the","chosen","city","sanctuary","and","made","streets","desolate","according","prophecy","jeremias"]},{"verseId":"brenton_sirach_49_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":7,"text":"For they entreated him evil, who nevertheless was a prophet, sanctified in his mother's womb, that he might root out, and afflict, and destroy; and that he might build up also, and plant.","searchKeywords":["for","they","entreated","him","evil","who","nevertheless","was","prophet","sanctified","his","mother","womb","that","might","root","out","and","afflict","destroy","build","also","plant"]},{"verseId":"brenton_sirach_49_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":8,"text":"It was Ezekiel who saw the glorious vision, which was shewed him upon the chariot of the cherubim.","searchKeywords":["was","ezekiel","who","saw","the","glorious","vision","which","shewed","him","upon","chariot","cherubim"]},{"verseId":"brenton_sirach_49_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":9,"text":"For he made mention of the enemies under the rain, and directed them that went right.","searchKeywords":["for","made","mention","the","enemies","under","rain","and","directed","them","that","went","right"]},{"verseId":"brenton_sirach_49_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":10,"text":"And of the twelve prophets let the memorial be blessed, and let their bones flourish again out of their place: for they comforted Jacob, and delivered them by assured hope.","searchKeywords":["and","the","twelve","prophets","let","memorial","blessed","their","bones","flourish","again","out","place","for","they","comforted","jacob","delivered","them","assured","hope"]},{"verseId":"brenton_sirach_49_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":11,"text":"How shall we magnify Zorobabel? he was even as a signet on the right hand:","searchKeywords":["how","shall","magnify","zorobabel","was","even","signet","the","right","hand"]},{"verseId":"brenton_sirach_49_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":12,"text":"So was Jesus the son of Josedec: who in their time builded the house, and set up an holy temple to the Lord, which was prepared for everlasting glory.","searchKeywords":["was","jesus","the","son","josedec","who","their","time","builded","house","and","set","holy","temple","lord","which","prepared","for","everlasting","glory"]},{"verseId":"brenton_sirach_49_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":13,"text":"And among the elect was Neemias, whose renown is great, who raised up for us the walls that were fallen, and set up the gates and the bars, and raised up our ruins again.","searchKeywords":["and","among","the","elect","was","neemias","whose","renown","great","who","raised","for","walls","that","were","fallen","set","gates","bars","our","ruins","again"]},{"verseId":"brenton_sirach_49_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":14,"text":"But upon the earth was no man created like Enoch; for he was taken from the earth.","searchKeywords":["but","upon","the","earth","was","man","created","like","enoch","for","taken","from"]},{"verseId":"brenton_sirach_49_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":15,"text":"Neither was there a man born like unto Joseph, a governor of his brethren, a stay of the people, whose bones were regarded of the Lord.","searchKeywords":["neither","was","there","man","born","like","unto","joseph","governor","his","brethren","stay","the","people","whose","bones","were","regarded","lord"]},{"verseId":"brenton_sirach_49_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":49,"verse":16,"text":"Sem and Seth were in great honour among men, and so was Adam above every living thing in the creation.","searchKeywords":["sem","and","seth","were","great","honour","among","men","was","adam","above","every","living","thing","the","creation"]}]