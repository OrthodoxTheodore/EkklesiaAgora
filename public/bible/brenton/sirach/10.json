[{"verseId":"brenton_sirach_10_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":1,"text":"A wise judge will instruct his people; and the government of a prudent man is well ordered.","searchKeywords":["wise","judge","will","instruct","his","people","and","the","government","prudent","man","well","ordered"]},{"verseId":"brenton_sirach_10_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":2,"text":"As the judge of the people is himself, so are his officers; and what manner of man the ruler of the city is, such are all they that dwell therein.","searchKeywords":["the","judge","people","himself","are","his","officers","and","what","manner","man","ruler","city","such","all","they","that","dwell","therein"]},{"verseId":"brenton_sirach_10_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":3,"text":"An unwise king destroyeth his people; but through the prudence of them which are in authority the city shall be inhabited.","searchKeywords":["unwise","king","destroyeth","his","people","but","through","the","prudence","them","which","are","authority","city","shall","inhabited"]},{"verseId":"brenton_sirach_10_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":4,"text":"The power of the earth is in the hand of the Lord, and in due time he will set over it one that is profitable.","searchKeywords":["the","power","earth","hand","lord","and","due","time","will","set","over","one","that","profitable"]},{"verseId":"brenton_sirach_10_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":5,"text":"In the hand of God is the prosperity of man: and upon the person of the scribe shall he lay his honour.","searchKeywords":["the","hand","god","prosperity","man","and","upon","person","scribe","shall","lay","his","honour"]},{"verseId":"brenton_sirach_10_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":6,"text":"Bear not hatred to thy neighbour for every wrong; and do nothing at all by injurious practices.","searchKeywords":["bear","not","hatred","thy","neighbour","for","every","wrong","and","nothing","all","injurious","practices"]},{"verseId":"brenton_sirach_10_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":7,"text":"Pride is hateful before God and man: and by both doth one commit iniquity.","searchKeywords":["pride","hateful","before","god","and","man","both","doth","one","commit","iniquity"]},{"verseId":"brenton_sirach_10_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":8,"text":"Because of unrighteous dealings, injuries, and riches got by deceit, the kingdom is translated from one people to another.","searchKeywords":["because","unrighteous","dealings","injuries","and","riches","got","deceit","the","kingdom","translated","from","one","people","another"]},{"verseId":"brenton_sirach_10_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":9,"text":"Why is earth and ashes proud? There is not a more wicked thing than a covetous man: for such an one setteth his own soul to sale; because while he liveth he casteth away his bowels.","searchKeywords":["why","earth","and","ashes","proud","there","not","more","wicked","thing","than","covetous","man","for","such","one","setteth","his","own","soul","sale","because","while","liveth","casteth","away","bowels"]},{"verseId":"brenton_sirach_10_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":10,"text":"The physician cutteth off a long disease: and he that is to day a king to morrow shall die.","searchKeywords":["the","physician","cutteth","off","long","disease","and","that","day","king","morrow","shall","die"]},{"verseId":"brenton_sirach_10_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":11,"text":"For when a man is dead, he shall inherit creeping things, beasts, and worms.","searchKeywords":["for","when","man","dead","shall","inherit","creeping","things","beasts","and","worms"]},{"verseId":"brenton_sirach_10_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":12,"text":"The beginning of pride is when one departeth from God, and his heart is turned away from his Maker.","searchKeywords":["the","beginning","pride","when","one","departeth","from","god","and","his","heart","turned","away","maker"]},{"verseId":"brenton_sirach_10_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":13,"text":"For pride is the beginning of sin, and he that hath it shall pour out abomination: and therefore the Lord brought upon them strange calamities, and overthrew them utterly.","searchKeywords":["for","pride","the","beginning","sin","and","that","hath","shall","pour","out","abomination","therefore","lord","brought","upon","them","strange","calamities","overthrew","utterly"]},{"verseId":"brenton_sirach_10_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":14,"text":"The Lord hath cast down the thrones of proud princes, and set up the meek in their stead.","searchKeywords":["the","lord","hath","cast","down","thrones","proud","princes","and","set","meek","their","stead"]},{"verseId":"brenton_sirach_10_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":15,"text":"The Lord hath plucked up the roots of the proud nations, and planted the lowly in their place.","searchKeywords":["the","lord","hath","plucked","roots","proud","nations","and","planted","lowly","their","place"]},{"verseId":"brenton_sirach_10_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":16,"text":"The Lord overthrew countries of the heathen, and destroyed them to the foundations of the earth.","searchKeywords":["the","lord","overthrew","countries","heathen","and","destroyed","them","foundations","earth"]},{"verseId":"brenton_sirach_10_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":17,"text":"He took some of them away, and destroyed them, and hath made their memorial to cease from the earth.","searchKeywords":["took","some","them","away","and","destroyed","hath","made","their","memorial","cease","from","the","earth"]},{"verseId":"brenton_sirach_10_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":18,"text":"Pride was not made for men, nor furious anger for them that are born of a woman.","searchKeywords":["pride","was","not","made","for","men","nor","furious","anger","them","that","are","born","woman"]},{"verseId":"brenton_sirach_10_19","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":19,"text":"They that fear the Lord are a sure seed, and they that love him an honourable plant: they that regard not the law are a dishonourable seed; they that transgress the commandments are a deceivable seed.","searchKeywords":["they","that","fear","the","lord","are","sure","seed","and","love","him","honourable","plant","regard","not","law","dishonourable","transgress","commandments","deceivable"]},{"verseId":"brenton_sirach_10_20","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":20,"text":"Among brethren he that is chief is honourable; so are they that fear the Lord in his eyes.","searchKeywords":["among","brethren","that","chief","honourable","are","they","fear","the","lord","his","eyes"]},{"verseId":"brenton_sirach_10_22","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":22,"text":"Whether he be rich, noble or poor, their glory is the fear of the Lord.","searchKeywords":["whether","rich","noble","poor","their","glory","the","fear","lord"]},{"verseId":"brenton_sirach_10_23","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":23,"text":"It is not meet to despise the poor man that hath understanding; neither is it convenient to magnify a sinful man.","searchKeywords":["not","meet","despise","the","poor","man","that","hath","understanding","neither","convenient","magnify","sinful"]},{"verseId":"brenton_sirach_10_24","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":24,"text":"Great men, and judges, and potentates, shall be honoured; yet is there none of them greater than he that feareth the Lord.","searchKeywords":["great","men","and","judges","potentates","shall","honoured","yet","there","none","them","greater","than","that","feareth","the","lord"]},{"verseId":"brenton_sirach_10_25","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":25,"text":"Unto the servant that is wise shall they that are free do service: and he that hath knowledge will not grudge when he is reformed.","searchKeywords":["unto","the","servant","that","wise","shall","they","are","free","service","and","hath","knowledge","will","not","grudge","when","reformed"]},{"verseId":"brenton_sirach_10_26","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":26,"text":"Be not overwise in doing thy business; and boast not thyself in the time of thy distress.","searchKeywords":["not","overwise","doing","thy","business","and","boast","thyself","the","time","distress"]},{"verseId":"brenton_sirach_10_27","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":27,"text":"Better is he that laboureth, and aboundeth in all things, than he that boasteth himself, and wanteth bread.","searchKeywords":["better","that","laboureth","and","aboundeth","all","things","than","boasteth","himself","wanteth","bread"]},{"verseId":"brenton_sirach_10_28","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":28,"text":"My son, glorify thy soul in meekness, and give it honour according to the dignity thereof.","searchKeywords":["son","glorify","thy","soul","meekness","and","give","honour","according","the","dignity","thereof"]},{"verseId":"brenton_sirach_10_29","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":29,"text":"Who will justify him that sinneth against his own soul? and who will honour him that dishonoureth his own life?","searchKeywords":["who","will","justify","him","that","sinneth","against","his","own","soul","and","honour","dishonoureth","life"]},{"verseId":"brenton_sirach_10_30","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":30,"text":"The poor man is honoured for his skill, and the rich man is honoured for his riches.","searchKeywords":["the","poor","man","honoured","for","his","skill","and","rich","riches"]},{"verseId":"brenton_sirach_10_31","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":10,"verse":31,"text":"He that is honoured in poverty, how much more in riches? and he that is dishonourable in riches, how much more in poverty?","searchKeywords":["that","honoured","poverty","how","much","more","riches","and","dishonourable"]}]