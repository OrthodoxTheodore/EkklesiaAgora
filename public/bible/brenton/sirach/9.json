[{"verseId":"brenton_sirach_9_1","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":1,"text":"Be not jealous over the wife of thy bosom, and teach her not an evil lesson against thyself.","searchKeywords":["not","jealous","over","the","wife","thy","bosom","and","teach","her","evil","lesson","against","thyself"]},{"verseId":"brenton_sirach_9_2","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":2,"text":"Give not thy soul unto a woman to set her foot upon thy substance.","searchKeywords":["give","not","thy","soul","unto","woman","set","her","foot","upon","substance"]},{"verseId":"brenton_sirach_9_3","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":3,"text":"Meet not with an harlot, lest thou fall into her snares.","searchKeywords":["meet","not","with","harlot","lest","thou","fall","into","her","snares"]},{"verseId":"brenton_sirach_9_4","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":4,"text":"Use not much the company of a woman that is a singer, lest thou be taken with her attempts.","searchKeywords":["use","not","much","the","company","woman","that","singer","lest","thou","taken","with","her","attempts"]},{"verseId":"brenton_sirach_9_5","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":5,"text":"Gaze not on a maid, that thou fall not by those things that are precious in her.","searchKeywords":["gaze","not","maid","that","thou","fall","those","things","are","precious","her"]},{"verseId":"brenton_sirach_9_6","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":6,"text":"Give not thy soul unto harlots, that thou lose not thine inheritance.","searchKeywords":["give","not","thy","soul","unto","harlots","that","thou","lose","thine","inheritance"]},{"verseId":"brenton_sirach_9_7","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":7,"text":"Look not round about thee in the streets of the city, neither wander thou in the solitary places thereof.","searchKeywords":["look","not","round","about","thee","the","streets","city","neither","wander","thou","solitary","places","thereof"]},{"verseId":"brenton_sirach_9_8","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":8,"text":"Turn away thine eye from a beautiful woman, and look not upon another's beauty; for many have been deceived by the beauty of a woman; for herewith love is kindled as a fire.","searchKeywords":["turn","away","thine","eye","from","beautiful","woman","and","look","not","upon","another","beauty","for","many","have","been","deceived","the","herewith","love","kindled","fire"]},{"verseId":"brenton_sirach_9_9","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":9,"text":"Sit not at all with another man's wife, nor sit down with her in thine arms, and spend not thy money with her at the wine; lest thine heart incline unto her, and so through thy desire thou fall into destruction.","searchKeywords":["sit","not","all","with","another","man","wife","nor","down","her","thine","arms","and","spend","thy","money","the","wine","lest","heart","incline","unto","through","desire","thou","fall","into","destruction"]},{"verseId":"brenton_sirach_9_10","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":10,"text":"Forsake not an old friend; for the new is not comparable to him: a new friend is as new wine; when it is old, thou shalt drink it with pleasure.","searchKeywords":["forsake","not","old","friend","for","the","new","comparable","him","wine","when","thou","shalt","drink","with","pleasure"]},{"verseId":"brenton_sirach_9_11","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":11,"text":"Envy not the glory of a sinner: for thou knowest not what shall be his end.","searchKeywords":["envy","not","the","glory","sinner","for","thou","knowest","what","shall","his","end"]},{"verseId":"brenton_sirach_9_12","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":12,"text":"Delight not in the thing that the ungodly have pleasure in; but remember they shall not go unpunished unto their grave.","searchKeywords":["delight","not","the","thing","that","ungodly","have","pleasure","but","remember","they","shall","unpunished","unto","their","grave"]},{"verseId":"brenton_sirach_9_13","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":13,"text":"Keep thee far from the man that hath power to kill: so shalt thou not doubt the fear of death: and if thou come unto him, make no fault, lest he take away thy life presently: remember that thou goest in the midst of snares, and that thou walkest upon the battlements of the city.","searchKeywords":["keep","thee","far","from","the","man","that","hath","power","kill","shalt","thou","not","doubt","fear","death","and","come","unto","him","make","fault","lest","take","away","thy","life","presently","remember","goest","midst","snares","walkest","upon","battlements","city"]},{"verseId":"brenton_sirach_9_14","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":14,"text":"As near as thou canst, guess at thy neighbour, and consult with the wise.","searchKeywords":["near","thou","canst","guess","thy","neighbour","and","consult","with","the","wise"]},{"verseId":"brenton_sirach_9_15","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":15,"text":"Let thy talk be with the wise, and all thy communication in the law of the most High.","searchKeywords":["let","thy","talk","with","the","wise","and","all","communication","law","most","high"]},{"verseId":"brenton_sirach_9_16","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":16,"text":"And let just men eat and drink with thee; and let thy glorying be in the fear of the Lord.","searchKeywords":["and","let","just","men","eat","drink","with","thee","thy","glorying","the","fear","lord"]},{"verseId":"brenton_sirach_9_17","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":17,"text":"For the hand of the artificer the work shall be commended; and the wise ruler of the people for his speech.","searchKeywords":["for","the","hand","artificer","work","shall","commended","and","wise","ruler","people","his","speech"]},{"verseId":"brenton_sirach_9_18","translationId":"brenton","testament":"OT","bookIndex":31,"bookName":"Sirach","bookAbbrev":"sirach","chapter":9,"verse":18,"text":"A man of an ill tongue is dangerous in his city; and he that is rash in his talk shall be hated.","searchKeywords":["man","ill","tongue","dangerous","his","city","and","that","rash","talk","shall","hated"]}]