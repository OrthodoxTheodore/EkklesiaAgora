[{"verseId":"brenton_song-of-solomon_5_1","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":1,"text":"Let my kinsman come down into his garden, and eat the fruit of his choice berries. I am come into my garden, my sister, spouse: I have gathered my myrrh with my spices; I have eaten my bread with my honey; I have drunk my wine with my milk. Eat, O friends, and drink; yea, brethren, drink abundantly.","searchKeywords":["let","kinsman","come","down","into","his","garden","and","eat","the","fruit","choice","berries","sister","spouse","have","gathered","myrrh","with","spices","eaten","bread","honey","drunk","wine","milk","friends","drink","yea","brethren","abundantly"]},{"verseId":"brenton_song-of-solomon_5_2","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":2,"text":"I sleep, but my heart is awake: the voice of my kinsman knocks at the door, , Open, open to me, my companion, my sister, my dove, my perfect one: for my head is filled with dew, and my locks with the drops of the night.","searchKeywords":["sleep","but","heart","awake","the","voice","kinsman","knocks","door","open","companion","sister","dove","perfect","one","for","head","filled","with","dew","and","locks","drops","night"]},{"verseId":"brenton_song-of-solomon_5_3","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":3,"text":"I have put off my coat; how shall I put it on? I have washed my feet, how shall I defile them?","searchKeywords":["have","put","off","coat","how","shall","washed","feet","defile","them"]},{"verseId":"brenton_song-of-solomon_5_4","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":4,"text":"My kinsman put forth his hand by the hole , and my belly was moved for him.","searchKeywords":["kinsman","put","forth","his","hand","the","hole","and","belly","was","moved","for","him"]},{"verseId":"brenton_song-of-solomon_5_5","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":5,"text":"I rose up to open to my kinsman; my hands dropped myrrh, my fingers choice myrrh, on the handles of the lock.","searchKeywords":["rose","open","kinsman","hands","dropped","myrrh","fingers","choice","the","handles","lock"]},{"verseId":"brenton_song-of-solomon_5_6","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":6,"text":"I opened to my kinsman; my kinsman was gone: my soul failed at his speech: I sought him, but found him not; I called him, but he answered me not.","searchKeywords":["opened","kinsman","was","gone","soul","failed","his","speech","sought","him","but","found","not","called","answered"]},{"verseId":"brenton_song-of-solomon_5_7","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":7,"text":"The watchmen that go their rounds in the city found me, they smote me, they wounded me; the keepers of the walls took away my veil from me.","searchKeywords":["the","watchmen","that","their","rounds","city","found","they","smote","wounded","keepers","walls","took","away","veil","from"]},{"verseId":"brenton_song-of-solomon_5_8","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":8,"text":"I have charged you, O daughters of Jerusalem, by the powers and the virtues of the field: if ye should find my kinsman, what are ye to say to him? That I am wounded with love.","searchKeywords":["have","charged","you","daughters","jerusalem","the","powers","and","virtues","field","should","find","kinsman","what","are","say","him","that","wounded","with","love"]},{"verseId":"brenton_song-of-solomon_5_9","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":9,"text":"What is thy kinsman than kinsman, O thou beautiful among women? what is thy kinsman than kinsman, that thou hast so charged us?","searchKeywords":["what","thy","kinsman","than","thou","beautiful","among","women","that","hast","charged"]},{"verseId":"brenton_song-of-solomon_5_10","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":10,"text":"My kinsman is white and ruddy, chosen out from myriads.","searchKeywords":["kinsman","white","and","ruddy","chosen","out","from","myriads"]},{"verseId":"brenton_song-of-solomon_5_11","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":11,"text":"His head is very fine gold, his locks are flowing, black as a raven.","searchKeywords":["his","head","very","fine","gold","locks","are","flowing","black","raven"]},{"verseId":"brenton_song-of-solomon_5_12","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":12,"text":"His eyes are as doves, by the pools of waters, washed with milk, sitting by the pools.","searchKeywords":["his","eyes","are","doves","the","pools","waters","washed","with","milk","sitting"]},{"verseId":"brenton_song-of-solomon_5_13","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":13,"text":"His cheeks are as bowls of spices pouring forth perfumes: his lips are lilies, dropping choice myrrh.","searchKeywords":["his","cheeks","are","bowls","spices","pouring","forth","perfumes","lips","lilies","dropping","choice","myrrh"]},{"verseId":"brenton_song-of-solomon_5_14","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":14,"text":"His hands are as turned gold set with beryl: his belly is an ivory tablet on a sapphire stone.","searchKeywords":["his","hands","are","turned","gold","set","with","beryl","belly","ivory","tablet","sapphire","stone"]},{"verseId":"brenton_song-of-solomon_5_15","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":15,"text":"His legs are marble pillars set on golden sockets: his form is as Libanus, choice as the cedars.","searchKeywords":["his","legs","are","marble","pillars","set","golden","sockets","form","libanus","choice","the","cedars"]},{"verseId":"brenton_song-of-solomon_5_16","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":5,"verse":16,"text":"His throat is most sweet, and altogether desirable. This is my kinsman, and this is my companion, O daughters of Jerusalem.","searchKeywords":["his","throat","most","sweet","and","altogether","desirable","this","kinsman","companion","daughters","jerusalem"]}]