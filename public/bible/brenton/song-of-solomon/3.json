[{"verseId":"brenton_song-of-solomon_3_1","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":3,"verse":1,"text":"By night on my bed I sought him whom my soul loves: I sought him, but found him not; I called him, but he hearkened not to me.","searchKeywords":["night","bed","sought","him","whom","soul","loves","but","found","not","called","hearkened"]},{"verseId":"brenton_song-of-solomon_3_2","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":3,"verse":2,"text":"I will rise now, and go about in the city, in the market-places, and in the streets, and I will seek him whom my soul loves: I sought him, but I found him not.","searchKeywords":["will","rise","now","and","about","the","city","market","places","streets","seek","him","whom","soul","loves","sought","but","found","not"]},{"verseId":"brenton_song-of-solomon_3_3","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":3,"verse":3,"text":"The watchmen who go their rounds in the city found me. , Have ye seen him whom my soul loves?","searchKeywords":["the","watchmen","who","their","rounds","city","found","have","seen","him","whom","soul","loves"]},{"verseId":"brenton_song-of-solomon_3_4","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":3,"verse":4,"text":"as a little after I parted from them, that I found him whom my soul loves: I held him, and did not let him go, until I brought him into my mother's house, and into the chamber of her that conceived me.","searchKeywords":["little","after","parted","from","them","that","found","him","whom","soul","loves","held","and","did","not","let","until","brought","into","mother","house","the","chamber","her","conceived"]},{"verseId":"brenton_song-of-solomon_3_5","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":3,"verse":5,"text":"I have charged you, O daughters of Jerusalem, by the powers and by the virtues of the field, that ye rouse not nor awake love, until he please.","searchKeywords":["have","charged","you","daughters","jerusalem","the","powers","and","virtues","field","that","rouse","not","nor","awake","love","until","please"]},{"verseId":"brenton_song-of-solomon_3_6","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":3,"verse":6,"text":"Who is this that comes up from the wilderness as pillars of smoke, perfumed with myrrh and frankincense, with all powders of the perfumer?","searchKeywords":["who","this","that","comes","from","the","wilderness","pillars","smoke","perfumed","with","myrrh","and","frankincense","all","powders","perfumer"]},{"verseId":"brenton_song-of-solomon_3_7","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":3,"verse":7,"text":"Behold Solomon's bed; sixty mighty men of the mighty ones of Israel are round about it.","searchKeywords":["behold","solomon","bed","sixty","mighty","men","the","ones","israel","are","round","about"]},{"verseId":"brenton_song-of-solomon_3_8","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":3,"verse":8,"text":"They all hold a sword, being expert in war: every man his sword upon his thigh because of fear by night.","searchKeywords":["they","all","hold","sword","being","expert","war","every","man","his","upon","thigh","because","fear","night"]},{"verseId":"brenton_song-of-solomon_3_9","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":3,"verse":9,"text":"King Solomon made himself a litter of woods of Lebanon.","searchKeywords":["king","solomon","made","himself","litter","woods","lebanon"]},{"verseId":"brenton_song-of-solomon_3_10","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":3,"verse":10,"text":"He made the pillars of it silver, the bottom of it gold, the covering of it scarlet, in the midst of it a pavement of love, for the daughters of Jerusalem.","searchKeywords":["made","the","pillars","silver","bottom","gold","covering","scarlet","midst","pavement","love","for","daughters","jerusalem"]},{"verseId":"brenton_song-of-solomon_3_11","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":3,"verse":11,"text":"Go forth, ye daughters of Sion, and behold king Solomon, with the crown wherewith his mother crowned him, in the day of his espousals, and in the day of the gladness of his heart.","searchKeywords":["forth","daughters","sion","and","behold","king","solomon","with","the","crown","wherewith","his","mother","crowned","him","day","espousals","gladness","heart"]}]