[{"verseId":"brenton_song-of-solomon_8_1","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":1,"text":"I would that thou, O my kinsman, wert he that sucked the breasts of my mother; when I found thee without, I would kiss thee; yea, they should not despise me.","searchKeywords":["would","that","thou","kinsman","wert","sucked","the","breasts","mother","when","found","thee","without","kiss","yea","they","should","not","despise"]},{"verseId":"brenton_song-of-solomon_8_2","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":2,"text":"I would take thee, I would bring thee into my mother's house, and into the chamber of her that conceived me; I would make thee to drink of spiced wine, of the juice of my pomegranates.","searchKeywords":["would","take","thee","bring","into","mother","house","and","the","chamber","her","that","conceived","make","drink","spiced","wine","juice","pomegranates"]},{"verseId":"brenton_song-of-solomon_8_3","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":3,"text":"His left hand under my head, and his right hand should embrace me.","searchKeywords":["his","left","hand","under","head","and","right","should","embrace"]},{"verseId":"brenton_song-of-solomon_8_4","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":4,"text":"I have charged you, ye daughters of Jerusalem, by the virtues of the field, that ye stir not up, nor awake love, until he please.","searchKeywords":["have","charged","you","daughters","jerusalem","the","virtues","field","that","stir","not","nor","awake","love","until","please"]},{"verseId":"brenton_song-of-solomon_8_5","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":5,"text":"Who is this that comes up all white, leaning on her kinsman? I raised thee up under an apple-tree; there thy mother brought thee forth; there she that bore thee brought thee forth.","searchKeywords":["who","this","that","comes","all","white","leaning","her","kinsman","raised","thee","under","apple","tree","there","thy","mother","brought","forth","she","bore"]},{"verseId":"brenton_song-of-solomon_8_6","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":6,"text":"Set me as a seal upon thy heart, as a seal upon thine arm; for love is strong as death; jealousy is cruel as the grave, her shafts are shafts of fire, the flames thereof.","searchKeywords":["set","seal","upon","thy","heart","thine","arm","for","love","strong","death","jealousy","cruel","the","grave","her","shafts","are","fire","flames","thereof"]},{"verseId":"brenton_song-of-solomon_8_7","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":7,"text":"Much water will not be able to quench love, and rivers shall not drown it; if a man would give all his substance for love, would utterly despise it.","searchKeywords":["much","water","will","not","able","quench","love","and","rivers","shall","drown","man","would","give","all","his","substance","for","utterly","despise"]},{"verseId":"brenton_song-of-solomon_8_8","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":8,"text":"Our sister is little, and has no breasts; what shall we do for our sister, in the day wherein she shall be spoken for?","searchKeywords":["our","sister","little","and","has","breasts","what","shall","for","the","day","wherein","she","spoken"]},{"verseId":"brenton_song-of-solomon_8_9","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":9,"text":"If she is a wall, let us build upon her silver bulwarks; and if she is a door, let us carve for her cedar panels.","searchKeywords":["she","wall","let","build","upon","her","silver","bulwarks","and","door","carve","for","cedar","panels"]},{"verseId":"brenton_song-of-solomon_8_10","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":10,"text":"I am a wall, and my breasts are as towers; I was in their eyes as one that found peace.","searchKeywords":["wall","and","breasts","are","towers","was","their","eyes","one","that","found","peace"]},{"verseId":"brenton_song-of-solomon_8_11","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":11,"text":"Solomon had a vineyard in Beelamon; he let his vineyard to keepers; every one was to bring for its fruit a thousand of silver.","searchKeywords":["solomon","had","vineyard","beelamon","let","his","keepers","every","one","was","bring","for","its","fruit","thousand","silver"]},{"verseId":"brenton_song-of-solomon_8_12","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":12,"text":"My vineyard, even mine, is before me; Solomon a thousand, and they that keep its fruit two hundred.","searchKeywords":["vineyard","even","mine","before","solomon","thousand","and","they","that","keep","its","fruit","two","hundred"]},{"verseId":"brenton_song-of-solomon_8_13","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":13,"text":"Thou that dwellest in the gardens, the companions hearken to thy voice: make me hear .","searchKeywords":["thou","that","dwellest","the","gardens","companions","hearken","thy","voice","make","hear"]},{"verseId":"brenton_song-of-solomon_8_14","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":8,"verse":14,"text":"Away, my kinsman, and be like a doe or a fawn on the mountains of spices.","searchKeywords":["away","kinsman","and","like","doe","fawn","the","mountains","spices"]}]