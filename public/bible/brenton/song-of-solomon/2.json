[{"verseId":"brenton_song-of-solomon_2_1","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":1,"text":"I am a flower of the plain, a lily of the valleys.","searchKeywords":["flower","the","plain","lily","valleys"]},{"verseId":"brenton_song-of-solomon_2_2","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":2,"text":"As a lily among thorns, so is my companion among the daughters.","searchKeywords":["lily","among","thorns","companion","the","daughters"]},{"verseId":"brenton_song-of-solomon_2_3","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":3,"text":"As the apple among the trees of the wood, so is my kinsman among the sons. I desired his shadow, and sat down, and his fruit was sweet in my throat.","searchKeywords":["the","apple","among","trees","wood","kinsman","sons","desired","his","shadow","and","sat","down","fruit","was","sweet","throat"]},{"verseId":"brenton_song-of-solomon_2_4","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":4,"text":"Bring me into the wine house; set love before me.","searchKeywords":["bring","into","the","wine","house","set","love","before"]},{"verseId":"brenton_song-of-solomon_2_5","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":5,"text":"Strengthen me with perfumes, stay me with apples: for I wounded with love.","searchKeywords":["strengthen","with","perfumes","stay","apples","for","wounded","love"]},{"verseId":"brenton_song-of-solomon_2_6","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":6,"text":"His left under my head, and his right hand shall embrace me.","searchKeywords":["his","left","under","head","and","right","hand","shall","embrace"]},{"verseId":"brenton_song-of-solomon_2_7","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":7,"text":"I have charged you, ye daughters of Jerusalem, by the powers and by the virtues of the field, that ye do not rouse or wake love, until he please.","searchKeywords":["have","charged","you","daughters","jerusalem","the","powers","and","virtues","field","that","not","rouse","wake","love","until","please"]},{"verseId":"brenton_song-of-solomon_2_8","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":8,"text":"The voice of my kinsman! behold, he comes leaping over the mountains, bounding over the hills.","searchKeywords":["the","voice","kinsman","behold","comes","leaping","over","mountains","bounding","hills"]},{"verseId":"brenton_song-of-solomon_2_9","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":9,"text":"My kinsman is like a roe or a young hart on the mountains of Bæthel: behold, he is behind our wall, looking through the windows, peeping through the lattices.","searchKeywords":["kinsman","like","roe","young","hart","the","mountains","thel","behold","behind","our","wall","looking","through","windows","peeping","lattices"]},{"verseId":"brenton_song-of-solomon_2_10","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":10,"text":"My kinsman answers, and says to me, Rise up, come, my companion, my fair one, my dove.","searchKeywords":["kinsman","answers","and","says","rise","come","companion","fair","one","dove"]},{"verseId":"brenton_song-of-solomon_2_11","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":11,"text":"For, behold, the winter is past, the rain is gone, it has departed.","searchKeywords":["for","behold","the","winter","past","rain","gone","has","departed"]},{"verseId":"brenton_song-of-solomon_2_12","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":12,"text":"The flowers are seen in the land; the time of pruning has arrived; the voice of the turtle-dove has been heard in our land.","searchKeywords":["the","flowers","are","seen","land","time","pruning","has","arrived","voice","turtle","dove","been","heard","our"]},{"verseId":"brenton_song-of-solomon_2_13","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":13,"text":"The fig-tree has put forth its young figs, the vines put forth the tender grape, they yield a smell: arise, come, my companion, my fair one, my dove; yea, come.","searchKeywords":["the","fig","tree","has","put","forth","its","young","figs","vines","tender","grape","they","yield","smell","arise","come","companion","fair","one","dove","yea"]},{"verseId":"brenton_song-of-solomon_2_14","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":14,"text":"my dove, in the shelter of the rock, near the wall: shew me thy face, and cause me to hear thy voice; for thy voice is sweet, and thy countenance is beautiful.","searchKeywords":["dove","the","shelter","rock","near","wall","shew","thy","face","and","cause","hear","voice","for","sweet","countenance","beautiful"]},{"verseId":"brenton_song-of-solomon_2_15","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":15,"text":"Take us the little foxes that spoil the vines: for our vines put forth tender grapes.","searchKeywords":["take","the","little","foxes","that","spoil","vines","for","our","put","forth","tender","grapes"]},{"verseId":"brenton_song-of-solomon_2_16","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":16,"text":"My kinsman is mine, and I am his: he feeds among the lilies.","searchKeywords":["kinsman","mine","and","his","feeds","among","the","lilies"]},{"verseId":"brenton_song-of-solomon_2_17","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":2,"verse":17,"text":"Until the day dawn, and the shadows depart, turn, my kinsman, be thou like to a roe or young hart on the mountains of the ravines.","searchKeywords":["until","the","day","dawn","and","shadows","depart","turn","kinsman","thou","like","roe","young","hart","mountains","ravines"]}]