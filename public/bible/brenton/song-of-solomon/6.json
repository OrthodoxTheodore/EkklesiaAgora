[{"verseId":"brenton_song-of-solomon_6_1","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":6,"verse":1,"text":"Whither is thy kinsman gone, thou beautiful among women? whither has thy kinsman turned aside? , and we will seek him with thee.","searchKeywords":["whither","thy","kinsman","gone","thou","beautiful","among","women","has","turned","aside","and","will","seek","him","with","thee"]},{"verseId":"brenton_song-of-solomon_6_2","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":6,"verse":2,"text":"My kinsman is gone down to his garden, to the beds of spice, to feed in the gardens, and to gather lilies.","searchKeywords":["kinsman","gone","down","his","garden","the","beds","spice","feed","gardens","and","gather","lilies"]},{"verseId":"brenton_song-of-solomon_6_3","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":6,"verse":3,"text":"I am my kinsman's, and my kinsman is mine, who feeds among the lilies.","searchKeywords":["kinsman","and","mine","who","feeds","among","the","lilies"]},{"verseId":"brenton_song-of-solomon_6_4","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":6,"verse":4,"text":"Thou art fair, my companion, as Pleasure, beautiful as Jerusalem, terrible as set in array.","searchKeywords":["thou","art","fair","companion","pleasure","beautiful","jerusalem","terrible","set","array"]},{"verseId":"brenton_song-of-solomon_6_5","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":6,"verse":5,"text":"Turn away thine eyes from before me, for they have ravished me: thy hair is as flocks of goats which have appeared from Galaad.","searchKeywords":["turn","away","thine","eyes","from","before","for","they","have","ravished","thy","hair","flocks","goats","which","appeared","galaad"]},{"verseId":"brenton_song-of-solomon_6_6","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":6,"verse":6,"text":"Thy teeth are as flocks of shorn , that have gone up from the washing, all of them bearing twins, and there is none barren among them: thy lips are as a thread of scarlet, and thy speech is comely.","searchKeywords":["thy","teeth","are","flocks","shorn","that","have","gone","from","the","washing","all","them","bearing","twins","and","there","none","barren","among","lips","thread","scarlet","speech","comely"]},{"verseId":"brenton_song-of-solomon_6_7","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":6,"verse":7,"text":"Thy cheek is like the rind of a pomegranate, without thy veil.","searchKeywords":["thy","cheek","like","the","rind","pomegranate","without","veil"]},{"verseId":"brenton_song-of-solomon_6_8","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":6,"verse":8,"text":"There are sixty queens, and eighty concubines, and maidens without number.","searchKeywords":["there","are","sixty","queens","and","eighty","concubines","maidens","without","number"]},{"verseId":"brenton_song-of-solomon_6_9","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":6,"verse":9,"text":"My dove, my perfect one is one; she is the one of her mother; she is the choice of her that bore her. The daughters saw her, and the queens will pronounce her blessed, yea, and the concubines, and they will praise her.","searchKeywords":["dove","perfect","one","she","the","her","mother","choice","that","bore","daughters","saw","and","queens","will","pronounce","blessed","yea","concubines","they","praise"]},{"verseId":"brenton_song-of-solomon_6_10","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":6,"verse":10,"text":"Who is this that looks forth as the morning, fair as the moon, choice as the sun, terrible as set in array?","searchKeywords":["who","this","that","looks","forth","the","morning","fair","moon","choice","sun","terrible","set","array"]},{"verseId":"brenton_song-of-solomon_6_11","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":6,"verse":11,"text":"I went down to the garden of nuts, to look at the fruits of the valley, to see if the vine flowered, the pomegranates blossomed.","searchKeywords":["went","down","the","garden","nuts","look","fruits","valley","see","vine","flowered","pomegranates","blossomed"]},{"verseId":"brenton_song-of-solomon_6_12","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":6,"verse":12,"text":"There I will give thee my breasts: my soul knew not: it made me as the chariots of Aminadab.","searchKeywords":["there","will","give","thee","breasts","soul","knew","not","made","the","chariots","aminadab"]}]