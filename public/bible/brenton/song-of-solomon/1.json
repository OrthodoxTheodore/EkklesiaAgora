[{"verseId":"brenton_song-of-solomon_1_1","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":1,"text":"Song of songs, which is Solomon's.","searchKeywords":["song","songs","which","solomon"]},{"verseId":"brenton_song-of-solomon_1_2","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":2,"text":"Let him kiss me with the kisses of his mouth: for thy breasts are better than wine.","searchKeywords":["let","him","kiss","with","the","kisses","his","mouth","for","thy","breasts","are","better","than","wine"]},{"verseId":"brenton_song-of-solomon_1_3","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":3,"text":"And the smell of thine ointments is better than all spices: thy name is ointment poured forth; therefore do the young maidens love thee.","searchKeywords":["and","the","smell","thine","ointments","better","than","all","spices","thy","name","ointment","poured","forth","therefore","young","maidens","love","thee"]},{"verseId":"brenton_song-of-solomon_1_4","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":4,"text":"They have drawn thee: we will run after thee, for the smell of thine ointments: the king has brought me into his closet: let us rejoice and be glad in thee; we will love thy breasts more than wine: righteousness loves thee.","searchKeywords":["they","have","drawn","thee","will","run","after","for","the","smell","thine","ointments","king","has","brought","into","his","closet","let","rejoice","and","glad","love","thy","breasts","more","than","wine","righteousness","loves"]},{"verseId":"brenton_song-of-solomon_1_5","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":5,"text":"I am black, but beautiful, ye daughters of Jerusalem, as the tents of Kedar, as the curtains of Solomon.","searchKeywords":["black","but","beautiful","daughters","jerusalem","the","tents","kedar","curtains","solomon"]},{"verseId":"brenton_song-of-solomon_1_6","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":6,"text":"Look not upon me, because I am dark, because the sun has looked unfavourably upon me: my mother's sons strove with me; they made me keeper in the vineyards; I have not kept my own vineyard.","searchKeywords":["look","not","upon","because","dark","the","sun","has","looked","unfavourably","mother","sons","strove","with","they","made","keeper","vineyards","have","kept","own","vineyard"]},{"verseId":"brenton_song-of-solomon_1_7","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":7,"text":"Tell me, whom my soul loves, where thou tendest thy flock, where thou causest to rest at noon, lest I become as one that is veiled by the flocks of thy companions.","searchKeywords":["tell","whom","soul","loves","where","thou","tendest","thy","flock","causest","rest","noon","lest","become","one","that","veiled","the","flocks","companions"]},{"verseId":"brenton_song-of-solomon_1_8","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":8,"text":"If thou know not thyself, thou fair one among women, go thou forth by the footsteps of the flocks, and feed thy kids by the shepherds' tents.","searchKeywords":["thou","know","not","thyself","fair","one","among","women","forth","the","footsteps","flocks","and","feed","thy","kids","shepherds","tents"]},{"verseId":"brenton_song-of-solomon_1_9","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":9,"text":"I have likened thee, my companion, to my horses in the chariots of Pharao.","searchKeywords":["have","likened","thee","companion","horses","the","chariots","pharao"]},{"verseId":"brenton_song-of-solomon_1_10","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":10,"text":"How are thy cheeks beautiful as of a dove, thy neck as chains!","searchKeywords":["how","are","thy","cheeks","beautiful","dove","neck","chains"]},{"verseId":"brenton_song-of-solomon_1_11","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":11,"text":"We will make thee figures of gold with studs of silver.","searchKeywords":["will","make","thee","figures","gold","with","studs","silver"]},{"verseId":"brenton_song-of-solomon_1_12","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":12,"text":"So long as the king was at table, my spikenard gave forth its smell.","searchKeywords":["long","the","king","was","table","spikenard","gave","forth","its","smell"]},{"verseId":"brenton_song-of-solomon_1_13","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":13,"text":"My kinsman is to me a bundle of myrrh; he shall lie between my breasts.","searchKeywords":["kinsman","bundle","myrrh","shall","lie","between","breasts"]},{"verseId":"brenton_song-of-solomon_1_14","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":14,"text":"My kinsman is to me a cluster of camphor in the vineyards of Engaddi.","searchKeywords":["kinsman","cluster","camphor","the","vineyards","engaddi"]},{"verseId":"brenton_song-of-solomon_1_15","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":15,"text":"Behold, thou art fair, my companion; behold, thou art fair; thine eyes are doves.","searchKeywords":["behold","thou","art","fair","companion","thine","eyes","are","doves"]},{"verseId":"brenton_song-of-solomon_1_16","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":16,"text":"Behold, thou art fair, my kinsman, yea, beautiful, overshadowing our bed.","searchKeywords":["behold","thou","art","fair","kinsman","yea","beautiful","overshadowing","our","bed"]},{"verseId":"brenton_song-of-solomon_1_17","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":1,"verse":17,"text":"The beams of our house are cedars, our ceilings are of cypress.","searchKeywords":["the","beams","our","house","are","cedars","ceilings","cypress"]}]