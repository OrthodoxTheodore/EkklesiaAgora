[{"verseId":"brenton_song-of-solomon_7_1","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":1,"text":"Return, return, O Sunamite; return, return, and we will look at thee.","searchKeywords":["return","sunamite","and","will","look","thee"]},{"verseId":"brenton_song-of-solomon_7_2","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":2,"text":"Thy steps are beautiful in shoes, O daughter of the prince: the joints of thighs are like chains, the work of the craftsman.","searchKeywords":["thy","steps","are","beautiful","shoes","daughter","the","prince","joints","thighs","like","chains","work","craftsman"]},{"verseId":"brenton_song-of-solomon_7_3","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":3,"text":"Thy navel is a turned bowl, not wanting liquor; thy belly is a heap of wheat set about with lilies.","searchKeywords":["thy","navel","turned","bowl","not","wanting","liquor","belly","heap","wheat","set","about","with","lilies"]},{"verseId":"brenton_song-of-solomon_7_4","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":4,"text":"Thy two breasts are as two twin fawns.","searchKeywords":["thy","two","breasts","are","twin","fawns"]},{"verseId":"brenton_song-of-solomon_7_5","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":5,"text":"Thy neck is as an ivory tower; thine eyes are as pools in Esebon, by the gates of the daughter of many: thy nose is as the tower of Libanus, looking toward Damascus.","searchKeywords":["thy","neck","ivory","tower","thine","eyes","are","pools","esebon","the","gates","daughter","many","nose","libanus","looking","toward","damascus"]},{"verseId":"brenton_song-of-solomon_7_6","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":6,"text":"Thy head upon thee is as Carmel, and the curls of thy hair like scarlet; the king is bound in the galleries.","searchKeywords":["thy","head","upon","thee","carmel","and","the","curls","hair","like","scarlet","king","bound","galleries"]},{"verseId":"brenton_song-of-solomon_7_7","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":7,"text":"How beautiful art thou, and how sweet art thou, love!","searchKeywords":["how","beautiful","art","thou","and","sweet","love"]},{"verseId":"brenton_song-of-solomon_7_8","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":8,"text":"This is thy greatness in thy delights: thou wast made like a palm tree, and thy breasts to clusters.","searchKeywords":["this","thy","greatness","delights","thou","wast","made","like","palm","tree","and","breasts","clusters"]},{"verseId":"brenton_song-of-solomon_7_9","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":9,"text":"I said, I will go up to the palm tree, I will take hold of its high boughs: and now shall thy breasts be as clusters of the vine, and the smell of thy nose as apples;","searchKeywords":["said","will","the","palm","tree","take","hold","its","high","boughs","and","now","shall","thy","breasts","clusters","vine","smell","nose","apples"]},{"verseId":"brenton_song-of-solomon_7_10","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":10,"text":"and thy throat as good wine, going well with my kinsman, suiting my lips and teeth.","searchKeywords":["and","thy","throat","good","wine","going","well","with","kinsman","suiting","lips","teeth"]},{"verseId":"brenton_song-of-solomon_7_11","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":11,"text":"I am my kinsman's, and his desire is toward me.","searchKeywords":["kinsman","and","his","desire","toward"]},{"verseId":"brenton_song-of-solomon_7_12","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":12,"text":"Come, my kinsman, let us go forth into the field; let us lodge in the villages.","searchKeywords":["come","kinsman","let","forth","into","the","field","lodge","villages"]},{"verseId":"brenton_song-of-solomon_7_13","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":13,"text":"Let us go early into the vineyards; let us see if the vine has flowered, the blossoms have appeared, if the pomegranates have blossomed; there will I give thee my breasts.","searchKeywords":["let","early","into","the","vineyards","see","vine","has","flowered","blossoms","have","appeared","pomegranates","blossomed","there","will","give","thee","breasts"]},{"verseId":"brenton_song-of-solomon_7_14","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":7,"verse":14,"text":"The mandrakes have given a smell, and at our doors all kinds of choice fruits, new and old. O my kinsman, I have kept for thee.","searchKeywords":["the","mandrakes","have","given","smell","and","our","doors","all","kinds","choice","fruits","new","old","kinsman","kept","for","thee"]}]