[{"verseId":"brenton_song-of-solomon_4_1","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":1,"text":"Behold, thou art fair, my companion; behold, thou art fair; thine eyes are doves, beside thy veil: thy hair is as flocks of goats, that have appeared from Galaad.","searchKeywords":["behold","thou","art","fair","companion","thine","eyes","are","doves","beside","thy","veil","hair","flocks","goats","that","have","appeared","from","galaad"]},{"verseId":"brenton_song-of-solomon_4_2","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":2,"text":"Thy teeth are as flocks of shorn , that have gone up from the washing; all of them bearing twins, and there is not a barren one among them.","searchKeywords":["thy","teeth","are","flocks","shorn","that","have","gone","from","the","washing","all","them","bearing","twins","and","there","not","barren","one","among"]},{"verseId":"brenton_song-of-solomon_4_3","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":3,"text":"Thy lips are as a thread of scarlet, and thy speech is comely: like the rind of a pomegranate is thy cheek without thy veil.","searchKeywords":["thy","lips","are","thread","scarlet","and","speech","comely","like","the","rind","pomegranate","cheek","without","veil"]},{"verseId":"brenton_song-of-solomon_4_4","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":4,"text":"Thy neck is as the tower of David, that was built for an armoury: a thousand shields hang upon it, all darts of mighty men.","searchKeywords":["thy","neck","the","tower","david","that","was","built","for","armoury","thousand","shields","hang","upon","all","darts","mighty","men"]},{"verseId":"brenton_song-of-solomon_4_5","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":5,"text":"Thy two breasts are as two twin fawns, that feed among the lilies.","searchKeywords":["thy","two","breasts","are","twin","fawns","that","feed","among","the","lilies"]},{"verseId":"brenton_song-of-solomon_4_6","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":6,"text":"Until the day dawn, and the shadows depart, I will betake me to the mountain of myrrh, and to the hill of frankincense.","searchKeywords":["until","the","day","dawn","and","shadows","depart","will","betake","mountain","myrrh","hill","frankincense"]},{"verseId":"brenton_song-of-solomon_4_7","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":7,"text":"Thou art all fair, my companion, and there is no spot in thee.","searchKeywords":["thou","art","all","fair","companion","and","there","spot","thee"]},{"verseId":"brenton_song-of-solomon_4_8","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":8,"text":"Come from Libanus, bride, come from Libanus: thou shalt come and pass from the top of Faith, from the top of Sanir and Hermon, from the lions' dens, from the mountains of the leopards.","searchKeywords":["come","from","libanus","bride","thou","shalt","and","pass","the","top","faith","sanir","hermon","lions","dens","mountains","leopards"]},{"verseId":"brenton_song-of-solomon_4_9","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":9,"text":"My sister, spouse, thou hast ravished my heart; thou hast ravished my heart with one of thine eyes, with one chain of thy neck.","searchKeywords":["sister","spouse","thou","hast","ravished","heart","with","one","thine","eyes","chain","thy","neck"]},{"verseId":"brenton_song-of-solomon_4_10","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":10,"text":"How beautiful are thy breasts, my sister, my spouse! how much more beautiful are thy breasts than wine, and the smell of thy garments than all spices!","searchKeywords":["how","beautiful","are","thy","breasts","sister","spouse","much","more","than","wine","and","the","smell","garments","all","spices"]},{"verseId":"brenton_song-of-solomon_4_11","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":11,"text":"Thy lips drop honeycomb, my spouse: honey and milk are under thy tongue; and the smell of thy garments is as the smell of Libanus.","searchKeywords":["thy","lips","drop","honeycomb","spouse","honey","and","milk","are","under","tongue","the","smell","garments","libanus"]},{"verseId":"brenton_song-of-solomon_4_12","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":12,"text":"My sister, spouse is a garden enclosed; a garden enclosed, a fountain sealed.","searchKeywords":["sister","spouse","garden","enclosed","fountain","sealed"]},{"verseId":"brenton_song-of-solomon_4_13","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":13,"text":"Thy shoots are a garden of pomegranates, with the fruit of choice berries; camphor, with spikenard:","searchKeywords":["thy","shoots","are","garden","pomegranates","with","the","fruit","choice","berries","camphor","spikenard"]},{"verseId":"brenton_song-of-solomon_4_14","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":14,"text":"spikenard and saffron, calamus and cinnamon; with all woods of Libanus, myrrh, aloes, with all chief spices:","searchKeywords":["spikenard","and","saffron","calamus","cinnamon","with","all","woods","libanus","myrrh","aloes","chief","spices"]},{"verseId":"brenton_song-of-solomon_4_15","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":15,"text":"a fountain of a garden, and a well of water springing and gurgling from Libanus.","searchKeywords":["fountain","garden","and","well","water","springing","gurgling","from","libanus"]},{"verseId":"brenton_song-of-solomon_4_16","translationId":"brenton","testament":"OT","bookIndex":28,"bookName":"Song of Solomon","bookAbbrev":"song-of-solomon","chapter":4,"verse":16,"text":"Awake, O north wind; and come, O south; and blow through my garden, and let my spices flow out.","searchKeywords":["awake","north","wind","and","come","south","blow","through","garden","let","spices","flow","out"]}]