[{"verseId":"brenton_isaiah_40_1","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":1,"text":"Comfort ye, comfort ye my people, saith God.","searchKeywords":["comfort","people","saith","god"]},{"verseId":"brenton_isaiah_40_2","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":2,"text":"Speak, ye priests, to the heart of Jerusalem; comfort her, for her humiliation is accomplished, her sin is put away: for she has received of the Lord's hand double her sins.","searchKeywords":["speak","priests","the","heart","jerusalem","comfort","her","for","humiliation","accomplished","sin","put","away","she","has","received","lord","hand","double","sins"]},{"verseId":"brenton_isaiah_40_3","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":3,"text":"The voice of one crying in the wilderness, Prepare ye the way of the Lord, make straight the paths of our God.","searchKeywords":["the","voice","one","crying","wilderness","prepare","way","lord","make","straight","paths","our","god"]},{"verseId":"brenton_isaiah_40_4","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":4,"text":"Every valley shall be filled, and every mountain and hill shall be brought low: and all the crooked shall become straight, and the rough plains.","searchKeywords":["every","valley","shall","filled","and","mountain","hill","brought","low","all","the","crooked","become","straight","rough","plains"]},{"verseId":"brenton_isaiah_40_5","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":5,"text":"And the glory of the Lord shall appear, and all flesh shall see the salvation of God: for the Lord has spoken .","searchKeywords":["and","the","glory","lord","shall","appear","all","flesh","see","salvation","god","for","has","spoken"]},{"verseId":"brenton_isaiah_40_6","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":6,"text":"The voice of one saying, Cry; and I said, What shall I cry? All flesh is grass, and all the glory of man as the flower of grass.","searchKeywords":["the","voice","one","saying","cry","and","said","what","shall","all","flesh","grass","glory","man","flower"]},{"verseId":"brenton_isaiah_40_7","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":7,"text":"The grass withers, and the flower fades:","searchKeywords":["the","grass","withers","and","flower","fades"]},{"verseId":"brenton_isaiah_40_8","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":8,"text":"but the word of our God abides for ever.","searchKeywords":["but","the","word","our","god","abides","for","ever"]},{"verseId":"brenton_isaiah_40_9","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":9,"text":"O thou that bringest glad tidings to Zion, go up on the high mountain; lift up thy voice with strength, thou that bringest glad tidings to Jerusalem; lift it up, fear not; say unto the cities of Juda, Behold your God!","searchKeywords":["thou","that","bringest","glad","tidings","zion","the","high","mountain","lift","thy","voice","with","strength","jerusalem","fear","not","say","unto","cities","juda","behold","your","god"]},{"verseId":"brenton_isaiah_40_10","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":10,"text":"Behold the Lord! The Lord is coming with strength, and arm is with power: behold, his reward is with him, and work before him.","searchKeywords":["behold","the","lord","coming","with","strength","and","arm","power","his","reward","him","work","before"]},{"verseId":"brenton_isaiah_40_11","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":11,"text":"He shall tend his flock as a shepherd, and he shall gather the lambs with his arm, and shall soothe them that are with young.","searchKeywords":["shall","tend","his","flock","shepherd","and","gather","the","lambs","with","arm","soothe","them","that","are","young"]},{"verseId":"brenton_isaiah_40_12","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":12,"text":"Who has measured the water in his hand, and the heaven with a span, and all the earth in a handful? Who has weighed the mountains in scales, and the forests in a balance?","searchKeywords":["who","has","measured","the","water","his","hand","and","heaven","with","span","all","earth","handful","weighed","mountains","scales","forests","balance"]},{"verseId":"brenton_isaiah_40_13","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":13,"text":"Who has known the mind of the Lord? and who has been his counsellor, to instruct him?","searchKeywords":["who","has","known","the","mind","lord","and","been","his","counsellor","instruct","him"]},{"verseId":"brenton_isaiah_40_14","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":14,"text":"Or with whom has he taken counsel, and he has instructed him? or who has taught him judgment, or who has taught him the way of understanding;","searchKeywords":["with","whom","has","taken","counsel","and","instructed","him","who","taught","judgment","the","way","understanding"]},{"verseId":"brenton_isaiah_40_15","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":15,"text":"since all the nations are counted as a drop from a bucket, and as the turning of a balance, shall be counted as spittle?","searchKeywords":["since","all","the","nations","are","counted","drop","from","bucket","and","turning","balance","shall","spittle"]},{"verseId":"brenton_isaiah_40_16","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":16,"text":"And Libanus is not enough to burn, nor all beasts enough for a whole-burnt offering:","searchKeywords":["and","libanus","not","enough","burn","nor","all","beasts","for","whole","burnt","offering"]},{"verseId":"brenton_isaiah_40_17","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":17,"text":"and all the nations are as nothing, and counted as nothing.","searchKeywords":["and","all","the","nations","are","nothing","counted"]},{"verseId":"brenton_isaiah_40_18","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":18,"text":"To whom have ye compared the Lord? and with what likeness have ye compared him?","searchKeywords":["whom","have","compared","the","lord","and","with","what","likeness","him"]},{"verseId":"brenton_isaiah_40_19","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":19,"text":"Has not the artificer made an image, or the goldsmith having melted gold, gilt it over, made it a similitude?","searchKeywords":["has","not","the","artificer","made","image","goldsmith","having","melted","gold","gilt","over","similitude"]},{"verseId":"brenton_isaiah_40_20","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":20,"text":"For the artificer chooses out a wood that will not rot, and will wisely enquire how he shall set up his image, and that it should not be moved.","searchKeywords":["for","the","artificer","chooses","out","wood","that","will","not","rot","and","wisely","enquire","how","shall","set","his","image","should","moved"]},{"verseId":"brenton_isaiah_40_21","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":21,"text":"Will ye not know? will ye not hear? has it not been told you of old? Have ye not known the foundations of the earth?","searchKeywords":["will","not","know","hear","has","been","told","you","old","have","known","the","foundations","earth"]},{"verseId":"brenton_isaiah_40_22","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":22,"text":"he that comprehends the circle of the earth, and the inhabitants in it are as grasshoppers; he that set up the heaven as a chamber, and stretched out as a tent to dwell in:","searchKeywords":["that","comprehends","the","circle","earth","and","inhabitants","are","grasshoppers","set","heaven","chamber","stretched","out","tent","dwell"]},{"verseId":"brenton_isaiah_40_23","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":23,"text":"he that appoints princes to rule as nothing, and has made the earth as nothing.","searchKeywords":["that","appoints","princes","rule","nothing","and","has","made","the","earth"]},{"verseId":"brenton_isaiah_40_24","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":24,"text":"For they shall not plant, neither shall they sow, neither shall their root be fixed in the ground: he has blown upon them, and they are withered, and a storm shall carry them away like sticks.","searchKeywords":["for","they","shall","not","plant","neither","sow","their","root","fixed","the","ground","has","blown","upon","them","and","are","withered","storm","carry","away","like","sticks"]},{"verseId":"brenton_isaiah_40_25","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":25,"text":"Now then to whom have ye compared me, that I may be exalted? saith the Holy One.","searchKeywords":["now","then","whom","have","compared","that","may","exalted","saith","the","holy","one"]},{"verseId":"brenton_isaiah_40_26","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":26,"text":"Lift up your eyes on high, and see, who has displayed all these things? he that brings forth his host by number: he shall call them all by name by great glory, and by the power of his might: nothing has escaped thee.","searchKeywords":["lift","your","eyes","high","and","see","who","has","displayed","all","these","things","that","brings","forth","his","host","number","shall","call","them","name","great","glory","the","power","might","nothing","escaped","thee"]},{"verseId":"brenton_isaiah_40_27","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":27,"text":"For say not thou, O Jacob, and why hast thou spoken, Israel, , My way is hid from God, and my God has taken away judgment, and has departed?","searchKeywords":["for","say","not","thou","jacob","and","why","hast","spoken","israel","way","hid","from","god","has","taken","away","judgment","departed"]},{"verseId":"brenton_isaiah_40_28","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":28,"text":"And now, hast thou not known? hast thou not heard? the eternal God, the God that formed the ends of the earth, shall not hunger, nor be weary, and there is no searching of his understanding.","searchKeywords":["and","now","hast","thou","not","known","heard","the","eternal","god","that","formed","ends","earth","shall","hunger","nor","weary","there","searching","his","understanding"]},{"verseId":"brenton_isaiah_40_29","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":29,"text":"He gives strength to the hungry, and sorrow to them that are not suffering.","searchKeywords":["gives","strength","the","hungry","and","sorrow","them","that","are","not","suffering"]},{"verseId":"brenton_isaiah_40_30","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":30,"text":"For the young shall hunger, and the youths shall be weary, and the choice shall be powerless:","searchKeywords":["for","the","young","shall","hunger","and","youths","weary","choice","powerless"]},{"verseId":"brenton_isaiah_40_31","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":40,"verse":31,"text":"but they that wait on God shall renew strength; they shall put forth new feathers like eagles; they shall run, and not be weary; they shall walk, and not hunger.","searchKeywords":["but","they","that","wait","god","shall","renew","strength","put","forth","new","feathers","like","eagles","run","and","not","weary","walk","hunger"]}]