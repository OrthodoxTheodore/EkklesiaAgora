[{"verseId":"brenton_isaiah_12_1","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":12,"verse":1,"text":"And in that day thou shalt say, I bless thee, O Lord; for thou wast angry with me, but thou hast turned aside thy wrath, and hast pitied me.","searchKeywords":["and","that","day","thou","shalt","say","bless","thee","lord","for","wast","angry","with","but","hast","turned","aside","thy","wrath","pitied"]},{"verseId":"brenton_isaiah_12_2","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":12,"verse":2,"text":"Behold, my God is my Saviour; I will trust in him, and not be afraid: for the Lord is my glory and my praise, and is become my salvation.","searchKeywords":["behold","god","saviour","will","trust","him","and","not","afraid","for","the","lord","glory","praise","become","salvation"]},{"verseId":"brenton_isaiah_12_3","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":12,"verse":3,"text":"Draw ye therefore water with joy out of the wells of salvation.","searchKeywords":["draw","therefore","water","with","joy","out","the","wells","salvation"]},{"verseId":"brenton_isaiah_12_4","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":12,"verse":4,"text":"And in that day thou shalt say, Sing to the Lord, call aloud upon his name, proclaim his glorious among the Gentiles; make mention that his name is exalted.","searchKeywords":["and","that","day","thou","shalt","say","sing","the","lord","call","aloud","upon","his","name","proclaim","glorious","among","gentiles","make","mention","exalted"]},{"verseId":"brenton_isaiah_12_5","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":12,"verse":5,"text":"Sing praise to the name of the Lord; for he has done great : declare this in all the earth.","searchKeywords":["sing","praise","the","name","lord","for","has","done","great","declare","this","all","earth"]},{"verseId":"brenton_isaiah_12_6","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":12,"verse":6,"text":"Exalt and rejoice, ye that dwell in Sion: for the Holy One of Israel is exalted in the midst of her.","searchKeywords":["exalt","and","rejoice","that","dwell","sion","for","the","holy","one","israel","exalted","midst","her"]}]