[{"verseId":"brenton_isaiah_23_1","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":1,"text":"no longer arrive from the land of the Citians: she is led captive.","searchKeywords":["longer","arrive","from","the","land","citians","she","led","captive"]},{"verseId":"brenton_isaiah_23_2","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":2,"text":"To whom are the dwellers in the island become like, the merchants of Phœnice, passing over the sea","searchKeywords":["whom","are","the","dwellers","island","become","like","merchants","nice","passing","over","sea"]},{"verseId":"brenton_isaiah_23_3","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":3,"text":"in great waters, a generation of merchants? as when the harvest is gathered in, these traders with the nations.","searchKeywords":["great","waters","generation","merchants","when","the","harvest","gathered","these","traders","with","nations"]},{"verseId":"brenton_isaiah_23_4","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":4,"text":"Be ashamed, O Sidon: the sea has said, yea, the strength of the sea has said, I have not travailed, nor brought forth, nor have I brought up young men, nor reared virgins.","searchKeywords":["ashamed","sidon","the","sea","has","said","yea","strength","have","not","travailed","nor","brought","forth","young","men","reared","virgins"]},{"verseId":"brenton_isaiah_23_5","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":5,"text":"Moreover when it shall be heard in Egypt, sorrow shall seize them for Tyre.","searchKeywords":["moreover","when","shall","heard","egypt","sorrow","seize","them","for","tyre"]},{"verseId":"brenton_isaiah_23_6","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":6,"text":"Depart ye to Carthage; howl, ye that dwell in this island.","searchKeywords":["depart","carthage","howl","that","dwell","this","island"]},{"verseId":"brenton_isaiah_23_7","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":7,"text":"Was not this your pride from the beginning, before she was given up?","searchKeywords":["was","not","this","your","pride","from","the","beginning","before","she","given"]},{"verseId":"brenton_isaiah_23_8","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":8,"text":"Who has devised this counsel against Tyre? Is she inferior? or has she no strength? her merchants were the glorious princes of the earth.","searchKeywords":["who","has","devised","this","counsel","against","tyre","she","inferior","strength","her","merchants","were","the","glorious","princes","earth"]},{"verseId":"brenton_isaiah_23_9","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":9,"text":"The Lord of hosts has purposed to bring down all the pride of the glorious ones, and to disgrace every glorious thing on the earth.","searchKeywords":["the","lord","hosts","has","purposed","bring","down","all","pride","glorious","ones","and","disgrace","every","thing","earth"]},{"verseId":"brenton_isaiah_23_10","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":10,"text":"Till thy land; for ships no more come out of Carthage.","searchKeywords":["till","thy","land","for","ships","more","come","out","carthage"]},{"verseId":"brenton_isaiah_23_11","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":11,"text":"And thy hand prevails no more by sea, which troubled kings: the Lord of hosts has given a command concerning Chanaan, to destroy the strength thereof.","searchKeywords":["and","thy","hand","prevails","more","sea","which","troubled","kings","the","lord","hosts","has","given","command","concerning","chanaan","destroy","strength","thereof"]},{"verseId":"brenton_isaiah_23_12","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":12,"text":"And shall say, Ye shall no longer at all continue to insult and injure the daughter of Sidon: and if thou depart to the Citians, neither there shalt thou have rest.","searchKeywords":["and","shall","say","longer","all","continue","insult","injure","the","daughter","sidon","thou","depart","citians","neither","there","shalt","have","rest"]},{"verseId":"brenton_isaiah_23_13","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":13,"text":"And to the land of the Chaldeans, this also is laid waste by the Assyrians, for her wall is fallen.","searchKeywords":["and","the","land","chaldeans","this","also","laid","waste","assyrians","for","her","wall","fallen"]},{"verseId":"brenton_isaiah_23_14","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":14,"text":"Howl, ye ships of Carthage: for your strong hold is destroyed.","searchKeywords":["howl","ships","carthage","for","your","strong","hold","destroyed"]},{"verseId":"brenton_isaiah_23_15","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":15,"text":"And it shall come to pass in that day, Tyre shall be left seventy years, as the time of a king, as the time of a man: and it shall come to pass after seventy years, Tyre shall be as the song of a harlot.","searchKeywords":["and","shall","come","pass","that","day","tyre","left","seventy","years","the","time","king","man","after","song","harlot"]},{"verseId":"brenton_isaiah_23_16","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":16,"text":"Take a harp, go about, O city, thou harlot that hast been forgotten; play well on the harp, sing many , that thou mayest be remembered.","searchKeywords":["take","harp","about","city","thou","harlot","that","hast","been","forgotten","play","well","the","sing","many","mayest","remembered"]},{"verseId":"brenton_isaiah_23_17","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":17,"text":"And it shall come to pass after the seventy years, God will visit Tyre, and she shall be again restored to her primitive state, and she shall be a mart for all the kingdoms of the world on the face of the earth.","searchKeywords":["and","shall","come","pass","after","the","seventy","years","god","will","visit","tyre","she","again","restored","her","primitive","state","mart","for","all","kingdoms","world","face","earth"]},{"verseId":"brenton_isaiah_23_18","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":23,"verse":18,"text":"And her trade and her gain shall be holiness to the Lord: it shall not be gathered for them, but for those that dwell before the Lord, all her trade, to eat and drink and be filled, and for a covenant a memorial before the Lord.","searchKeywords":["and","her","trade","gain","shall","holiness","the","lord","not","gathered","for","them","but","those","that","dwell","before","all","eat","drink","filled","covenant","memorial"]}]