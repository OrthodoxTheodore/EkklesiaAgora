[{"verseId":"brenton_isaiah_43_1","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":1,"text":"And now thus saith the Lord God that made thee, O Jacob, and formed thee, O Israel, Fear not: for I have redeemed thee, I have called thee thy name; thou art mine.","searchKeywords":["and","now","thus","saith","the","lord","god","that","made","thee","jacob","formed","israel","fear","not","for","have","redeemed","called","thy","name","thou","art","mine"]},{"verseId":"brenton_isaiah_43_2","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":2,"text":"And if thou pass through water, I am with thee; and the rivers shall not overflow thee: and if thou go through fire, thou shalt not be burned; the flame shall not burn thee.","searchKeywords":["and","thou","pass","through","water","with","thee","the","rivers","shall","not","overflow","fire","shalt","burned","flame","burn"]},{"verseId":"brenton_isaiah_43_3","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":3,"text":"For I am the Lord thy God, the Holy One of Israel, that saves thee: I have made Egypt and Ethiopia thy ransom, and Soene for thee.","searchKeywords":["for","the","lord","thy","god","holy","one","israel","that","saves","thee","have","made","egypt","and","ethiopia","ransom","soene"]},{"verseId":"brenton_isaiah_43_4","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":4,"text":"Since thou becamest precious in my sight, thou hast become glorious, and I have loved thee: and I will give men for thee, and princes for thy life.","searchKeywords":["since","thou","becamest","precious","sight","hast","become","glorious","and","have","loved","thee","will","give","men","for","princes","thy","life"]},{"verseId":"brenton_isaiah_43_5","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":5,"text":"Fear not; for I am with thee: I will bring thy seed from the east, and will gather thee from the west.","searchKeywords":["fear","not","for","with","thee","will","bring","thy","seed","from","the","east","and","gather","west"]},{"verseId":"brenton_isaiah_43_6","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":6,"text":"I will say to the north, Bring; and to the south, Keep not back; bring my sons from the afar off, and my daughters from the ends of the earth;","searchKeywords":["will","say","the","north","bring","and","south","keep","not","back","sons","from","afar","off","daughters","ends","earth"]},{"verseId":"brenton_isaiah_43_7","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":7,"text":"all who are called by my name: for I have prepared him for my glory, and I have formed him, and have made him:","searchKeywords":["all","who","are","called","name","for","have","prepared","him","glory","and","formed","made"]},{"verseId":"brenton_isaiah_43_8","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":8,"text":"and I have brought forth the blind people; for eyes are alike blind, and they that have ears are deaf.","searchKeywords":["and","have","brought","forth","the","blind","people","for","eyes","are","alike","they","that","ears","deaf"]},{"verseId":"brenton_isaiah_43_9","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":9,"text":"All the nations are gathered together, and princes shall be gathered out of them: who will declare these things? or who will declare to you things from the beginning? let them bring forth their witnesses, and be justified; and let them hear, and declare the truth.","searchKeywords":["all","the","nations","are","gathered","together","and","princes","shall","out","them","who","will","declare","these","things","you","from","beginning","let","bring","forth","their","witnesses","justified","hear","truth"]},{"verseId":"brenton_isaiah_43_10","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":10,"text":"Be ye my witnesses, and I a witness, saith the Lord God, and my servant whom I have chosen: that ye may know, and believe, and understand that I am : before me there was no other God, and after me there shall be none.","searchKeywords":["witnesses","and","witness","saith","the","lord","god","servant","whom","have","chosen","that","may","know","believe","understand","before","there","was","other","after","shall","none"]},{"verseId":"brenton_isaiah_43_11","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":11,"text":"I am God; and beside me there is no Saviour.","searchKeywords":["god","and","beside","there","saviour"]},{"verseId":"brenton_isaiah_43_12","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":12,"text":"I have declared, and have saved; I have reproached, and there was no strange among you: ye are my witnesses, and I am the Lord God,","searchKeywords":["have","declared","and","saved","reproached","there","was","strange","among","you","are","witnesses","the","lord","god"]},{"verseId":"brenton_isaiah_43_13","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":13,"text":"even from the beginning; and there is none that can deliver out of my hands: I will work, and who shall turn it back?","searchKeywords":["even","from","the","beginning","and","there","none","that","can","deliver","out","hands","will","work","who","shall","turn","back"]},{"verseId":"brenton_isaiah_43_14","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":14,"text":"Thus saith the Lord God that redeems you, the Holy One of Israel; For your sakes I will send to Babylon, and I will stir up all that flee, and the Chaldeans shall be bound in ships.","searchKeywords":["thus","saith","the","lord","god","that","redeems","you","holy","one","israel","for","your","sakes","will","send","babylon","and","stir","all","flee","chaldeans","shall","bound","ships"]},{"verseId":"brenton_isaiah_43_15","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":15,"text":"I am the Lord God, your Holy One, who have appointed for Israel your king.","searchKeywords":["the","lord","god","your","holy","one","who","have","appointed","for","israel","king"]},{"verseId":"brenton_isaiah_43_16","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":16,"text":"Thus saith the Lord, who makes a way in the sea, and a path in the mighty water;","searchKeywords":["thus","saith","the","lord","who","makes","way","sea","and","path","mighty","water"]},{"verseId":"brenton_isaiah_43_17","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":17,"text":"who brought forth chariots and horse, and a mighty multitude: but they have lain down, and shall not rise: they are extinct, as quenched flax.","searchKeywords":["who","brought","forth","chariots","and","horse","mighty","multitude","but","they","have","lain","down","shall","not","rise","are","extinct","quenched","flax"]},{"verseId":"brenton_isaiah_43_18","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":18,"text":"Remember ye not the former things, and consider not the ancient things.","searchKeywords":["remember","not","the","former","things","and","consider","ancient"]},{"verseId":"brenton_isaiah_43_19","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":19,"text":"Behold, I do new things, which shall presently spring forth, and ye shall know them: and I will make a way in the wilderness, and rivers in the dry land.","searchKeywords":["behold","new","things","which","shall","presently","spring","forth","and","know","them","will","make","way","the","wilderness","rivers","dry","land"]},{"verseId":"brenton_isaiah_43_20","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":20,"text":"The beasts of the field shall bless me, the owls and young ostriches; for I have given water in the wilderness, and rivers in the dry land, to give drink to my chosen race,","searchKeywords":["the","beasts","field","shall","bless","owls","and","young","ostriches","for","have","given","water","wilderness","rivers","dry","land","give","drink","chosen","race"]},{"verseId":"brenton_isaiah_43_21","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":21,"text":"my people whom I have preserved to tell forth my praises.","searchKeywords":["people","whom","have","preserved","tell","forth","praises"]},{"verseId":"brenton_isaiah_43_22","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":22,"text":"I have not now called thee, O Jacob; neither have I made thee weary, O Israel.","searchKeywords":["have","not","now","called","thee","jacob","neither","made","weary","israel"]},{"verseId":"brenton_isaiah_43_23","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":23,"text":"Thou hast not brought me the sheep of thy whole-burnt-offering; neither hast thou glorified me with thy sacrifices. I have not caused thee to serve with sacrifices, neither have I wearied thee with frankincense.","searchKeywords":["thou","hast","not","brought","the","sheep","thy","whole","burnt","offering","neither","glorified","with","sacrifices","have","caused","thee","serve","wearied","frankincense"]},{"verseId":"brenton_isaiah_43_24","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":24,"text":"Neither hast thou purchased for me victims for silver, neither have I desired the fat of thy sacrifices: but thou didst stand before me in thy sins, and in thine iniquities.","searchKeywords":["neither","hast","thou","purchased","for","victims","silver","have","desired","the","fat","thy","sacrifices","but","didst","stand","before","sins","and","thine","iniquities"]},{"verseId":"brenton_isaiah_43_25","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":25,"text":"I, I, am he that blots out thy transgressions for mine own sake, and thy sins; and I will not remember .","searchKeywords":["that","blots","out","thy","transgressions","for","mine","own","sake","and","sins","will","not","remember"]},{"verseId":"brenton_isaiah_43_26","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":26,"text":"But do thou remember, and let us plead : do thou first confess thy transgressions, that thou mayest be justified.","searchKeywords":["but","thou","remember","and","let","plead","first","confess","thy","transgressions","that","mayest","justified"]},{"verseId":"brenton_isaiah_43_27","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":27,"text":"Your fathers first, and your princes have transgressed against me.","searchKeywords":["your","fathers","first","and","princes","have","transgressed","against"]},{"verseId":"brenton_isaiah_43_28","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":43,"verse":28,"text":"And the princes have defiled my sanctuaries: so I gave Jacob to destroy, and Israel to reproach.","searchKeywords":["and","the","princes","have","defiled","sanctuaries","gave","jacob","destroy","israel","reproach"]}]