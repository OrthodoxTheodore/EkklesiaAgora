[{"verseId":"brenton_isaiah_21_1","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":1,"text":"from such a land,","searchKeywords":["from","such","land"]},{"verseId":"brenton_isaiah_21_2","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":2,"text":"a fearful and a grievous vision was declared to me: he that is treacherous deals treacherously, the transgressor transgresses. The Elamites are upon me, and the ambassadors of the Persians come against me: now will I groan and comfort myself.","searchKeywords":["fearful","and","grievous","vision","was","declared","that","treacherous","deals","treacherously","the","transgressor","transgresses","elamites","are","upon","ambassadors","persians","come","against","now","will","groan","comfort","myself"]},{"verseId":"brenton_isaiah_21_3","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":3,"text":"Therefore are my loins filled with feebleness, and pangs have seized me as a travailing woman: I dealt wrongfully that I might not hear; I hasted that I might not see.","searchKeywords":["therefore","are","loins","filled","with","feebleness","and","pangs","have","seized","travailing","woman","dealt","wrongfully","that","might","not","hear","hasted","see"]},{"verseId":"brenton_isaiah_21_4","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":4,"text":"My heart wanders, and transgression overwhelms me; my soul is occupied with fear.","searchKeywords":["heart","wanders","and","transgression","overwhelms","soul","occupied","with","fear"]},{"verseId":"brenton_isaiah_21_5","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":5,"text":"Prepare the table, eat, drink: arise, ye princes, and prepare shields.","searchKeywords":["prepare","the","table","eat","drink","arise","princes","and","shields"]},{"verseId":"brenton_isaiah_21_6","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":6,"text":"For thus said the Lord to me, Go and station a watchman for thyself, and declare whatever thou shalt see.","searchKeywords":["for","thus","said","the","lord","and","station","watchman","thyself","declare","whatever","thou","shalt","see"]},{"verseId":"brenton_isaiah_21_7","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":7,"text":"And I saw two mounted horsemen, and a rider on an ass, and a rider on a camel.","searchKeywords":["and","saw","two","mounted","horsemen","rider","ass","camel"]},{"verseId":"brenton_isaiah_21_8","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":8,"text":"Hearken with great attention, and call thou Urias to the watch-tower: the Lord has spoken. I stood continually during the day, and I stood in the camp all the night:","searchKeywords":["hearken","with","great","attention","and","call","thou","urias","the","watch","tower","lord","has","spoken","stood","continually","during","day","camp","all","night"]},{"verseId":"brenton_isaiah_21_9","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":9,"text":"and, behold, he comes riding in a chariot and pair: and he answered and said, Babylon is fallen, is fallen; and all her images and her idols have been crushed to the ground.","searchKeywords":["and","behold","comes","riding","chariot","pair","answered","said","babylon","fallen","all","her","images","idols","have","been","crushed","the","ground"]},{"verseId":"brenton_isaiah_21_10","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":10,"text":"Hear, ye that are left, and ye that are in pain, hear what things I have heard of the Lord of hosts the God of Israel has declared to us.","searchKeywords":["hear","that","are","left","and","pain","what","things","have","heard","the","lord","hosts","god","israel","has","declared"]},{"verseId":"brenton_isaiah_21_12","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":12,"text":"I watch in the morning and the night: if thou wouldest enquire, enquire, and dwell by me.","searchKeywords":["watch","the","morning","and","night","thou","wouldest","enquire","dwell"]},{"verseId":"brenton_isaiah_21_13","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":13,"text":"Thou mayest lodge in the forest in the evening, or in the way of Dædan.","searchKeywords":["thou","mayest","lodge","the","forest","evening","way","dan"]},{"verseId":"brenton_isaiah_21_14","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":14,"text":"Ye that dwell in the country of Thæman, bring water to meet him that is thirsty;","searchKeywords":["that","dwell","the","country","man","bring","water","meet","him","thirsty"]},{"verseId":"brenton_isaiah_21_15","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":15,"text":"meet the fugitives with bread, because of the multitude of the slain, and because of the multitude of them that lose their way, and because of the multitude of swords, and because of the multitude of bent bows, and because of the multitude of them that have fallen in war.","searchKeywords":["meet","the","fugitives","with","bread","because","multitude","slain","and","them","that","lose","their","way","swords","bent","bows","have","fallen","war"]},{"verseId":"brenton_isaiah_21_16","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":16,"text":"For thus said the Lord to me, Yet a year, as the year of an hireling, the glory of the sons of Kedar shall fail:","searchKeywords":["for","thus","said","the","lord","yet","year","hireling","glory","sons","kedar","shall","fail"]},{"verseId":"brenton_isaiah_21_17","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":21,"verse":17,"text":"and the remnant of the strong bows of the sons of Kedar shall be small: for the Lord God of Israel has spoken .","searchKeywords":["and","the","remnant","strong","bows","sons","kedar","shall","small","for","lord","god","israel","has","spoken"]}]