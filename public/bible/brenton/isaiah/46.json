[{"verseId":"brenton_isaiah_46_1","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":46,"verse":1,"text":"Bel has fallen, Nabo is broken to pieces, their graven images are gone to the wild beasts and the cattle: ye take them packed up as a burden to the weary, exhausted, hungry, and helpless man;","searchKeywords":["bel","has","fallen","nabo","broken","pieces","their","graven","images","are","gone","the","wild","beasts","and","cattle","take","them","packed","burden","weary","exhausted","hungry","helpless","man"]},{"verseId":"brenton_isaiah_46_2","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":46,"verse":2,"text":"who will not be able to save themselves from war, but they themselves are led captive.","searchKeywords":["who","will","not","able","save","themselves","from","war","but","they","are","led","captive"]},{"verseId":"brenton_isaiah_46_3","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":46,"verse":3,"text":"Hear me, O house of Jacob, and all the remnant of Israel, who are borne from the womb, and taught from infancy, to old age:","searchKeywords":["hear","house","jacob","and","all","the","remnant","israel","who","are","borne","from","womb","taught","infancy","old","age"]},{"verseId":"brenton_isaiah_46_4","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":46,"verse":4,"text":"I am ; and until ye shall have grown old, I am : I bear you, I have made, and I will relieve, I will take up and save you.","searchKeywords":["and","until","shall","have","grown","old","bear","you","made","will","relieve","take","save"]},{"verseId":"brenton_isaiah_46_5","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":46,"verse":5,"text":"To whom have ye compared me? see, consider, ye that go astray.","searchKeywords":["whom","have","compared","see","consider","that","astray"]},{"verseId":"brenton_isaiah_46_6","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":46,"verse":6,"text":"They that furnish gold out of a purse, and silver by weight, will weigh it in a scale, and they hire a goldsmith and make idols, and bow down, and worship them.","searchKeywords":["they","that","furnish","gold","out","purse","and","silver","weight","will","weigh","scale","hire","goldsmith","make","idols","bow","down","worship","them"]},{"verseId":"brenton_isaiah_46_7","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":46,"verse":7,"text":"They bear it upon the shoulder, and go; and if they put it upon its place, it remains, it cannot move: and whosoever shall cry to it, it cannot hear; it cannot save him from trouble.","searchKeywords":["they","bear","upon","the","shoulder","and","put","its","place","remains","cannot","move","whosoever","shall","cry","hear","save","him","from","trouble"]},{"verseId":"brenton_isaiah_46_8","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":46,"verse":8,"text":"Remember ye these things, and groan: repent, ye that have gone astray, return in your heart;","searchKeywords":["remember","these","things","and","groan","repent","that","have","gone","astray","return","your","heart"]},{"verseId":"brenton_isaiah_46_9","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":46,"verse":9,"text":"and remember the former things of old: for I am God, and there is none other beside me,","searchKeywords":["and","remember","the","former","things","old","for","god","there","none","other","beside"]},{"verseId":"brenton_isaiah_46_10","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":46,"verse":10,"text":"telling beforehand the latter events before they come to pass, and they are accomplished together: and I said, All my counsel shall stand, and I will do all things that I have planned:","searchKeywords":["telling","beforehand","the","latter","events","before","they","come","pass","and","are","accomplished","together","said","all","counsel","shall","stand","will","things","that","have","planned"]},{"verseId":"brenton_isaiah_46_11","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":46,"verse":11,"text":"calling a bird from the east, and from a land afar off, for the things which I have planned: I have spoken, and brought ; I have created and made ; I have brought him, and prospered his way.","searchKeywords":["calling","bird","from","the","east","and","land","afar","off","for","things","which","have","planned","spoken","brought","created","made","him","prospered","his","way"]},{"verseId":"brenton_isaiah_46_12","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":46,"verse":12,"text":"Hearken to me, ye senseless ones, that are far from righteousness:","searchKeywords":["hearken","senseless","ones","that","are","far","from","righteousness"]},{"verseId":"brenton_isaiah_46_13","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":46,"verse":13,"text":"I have brought near my righteousness, and I will not be slow with the salvation that is from me: I have given salvation in Sion to Israel for glory.","searchKeywords":["have","brought","near","righteousness","and","will","not","slow","with","the","salvation","that","from","given","sion","israel","for","glory"]}]