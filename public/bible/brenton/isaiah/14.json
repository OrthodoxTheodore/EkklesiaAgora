[{"verseId":"brenton_isaiah_14_1","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":1,"text":"And the Lord will have mercy on Jacob, and will yet choose Israel, and they shall rest on their land: and the stranger shall be added to them, yea, shall be added to the house of Jacob.","searchKeywords":["and","the","lord","will","have","mercy","jacob","yet","choose","israel","they","shall","rest","their","land","stranger","added","them","yea","house"]},{"verseId":"brenton_isaiah_14_2","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":2,"text":"And the Gentiles shall take them, and bring them into their place: and they shall inherit them, and they shall be multiplied upon the land for servants and handmaidens: and they that took them captives shall become captives ; and they that had lordship over them shall be under rule.","searchKeywords":["and","the","gentiles","shall","take","them","bring","into","their","place","they","inherit","multiplied","upon","land","for","servants","handmaidens","that","took","captives","become","had","lordship","over","under","rule"]},{"verseId":"brenton_isaiah_14_3","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":3,"text":"And it shall come to pass in that day, the Lord shall give thee rest from thy sorrow and vexation, thy hard servitude wherein thou didst serve them.","searchKeywords":["and","shall","come","pass","that","day","the","lord","give","thee","rest","from","thy","sorrow","vexation","hard","servitude","wherein","thou","didst","serve","them"]},{"verseId":"brenton_isaiah_14_4","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":4,"text":"And thou shalt take up this lamentation against the king of Babylon, How has the extortioner ceased, and the taskmaster ceased!","searchKeywords":["and","thou","shalt","take","this","lamentation","against","the","king","babylon","how","has","extortioner","ceased","taskmaster"]},{"verseId":"brenton_isaiah_14_5","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":5,"text":"The Lord has broken the yoke of sinners, the yoke of princes.","searchKeywords":["the","lord","has","broken","yoke","sinners","princes"]},{"verseId":"brenton_isaiah_14_6","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":6,"text":"Having smitten a nation in wrath, with an incurable plague, smiting a nation with a wrathful plague, which spared not, he rested in quiet.","searchKeywords":["having","smitten","nation","wrath","with","incurable","plague","smiting","wrathful","which","spared","not","rested","quiet"]},{"verseId":"brenton_isaiah_14_7","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":7,"text":"All the earth cries aloud with joy:","searchKeywords":["all","the","earth","cries","aloud","with","joy"]},{"verseId":"brenton_isaiah_14_8","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":8,"text":"the trees also of Libanus rejoice against thee, and the cedar of Libanus, , From the time that thou hast been laid low, no one has come up to cut us down.","searchKeywords":["the","trees","also","libanus","rejoice","against","thee","and","cedar","from","time","that","thou","hast","been","laid","low","one","has","come","cut","down"]},{"verseId":"brenton_isaiah_14_9","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":9,"text":"Hell from beneath is provoked to meet thee: all the great ones that have ruled over the earth have risen up together against thee, they that have raised up from their thrones all the kings of the nations.","searchKeywords":["hell","from","beneath","provoked","meet","thee","all","the","great","ones","that","have","ruled","over","earth","risen","together","against","they","raised","their","thrones","kings","nations"]},{"verseId":"brenton_isaiah_14_10","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":10,"text":"All shall answer and say to thee, Thou also hast been taken, even as we; and thou art numbered amongst us.","searchKeywords":["all","shall","answer","and","say","thee","thou","also","hast","been","taken","even","art","numbered","amongst"]},{"verseId":"brenton_isaiah_14_11","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":11,"text":"Thy glory has come down to Hades, and thy great mirth: under thee they shall spread corruption, and the worm shall be thy covering.","searchKeywords":["thy","glory","has","come","down","hades","and","great","mirth","under","thee","they","shall","spread","corruption","the","worm","covering"]},{"verseId":"brenton_isaiah_14_12","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":12,"text":"How has Lucifer, that rose in the morning, fallen from heaven! He that sent to all the nations is crushed to the earth.","searchKeywords":["how","has","lucifer","that","rose","the","morning","fallen","from","heaven","sent","all","nations","crushed","earth"]},{"verseId":"brenton_isaiah_14_13","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":13,"text":"But thou saidst in thine heart, I will go up to heaven, I will set my throne above the stars of heaven: I will sit on a lofty mount, on the lofty mountains toward the north:","searchKeywords":["but","thou","saidst","thine","heart","will","heaven","set","throne","above","the","stars","sit","lofty","mount","mountains","toward","north"]},{"verseId":"brenton_isaiah_14_14","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":14,"text":"I will go up above the clouds; I will be like the Most High.","searchKeywords":["will","above","the","clouds","like","most","high"]},{"verseId":"brenton_isaiah_14_15","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":15,"text":"But now thou shalt go down to hell, even to the foundations of the earth.","searchKeywords":["but","now","thou","shalt","down","hell","even","the","foundations","earth"]},{"verseId":"brenton_isaiah_14_16","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":16,"text":"They that see thee shall wonder at thee, and say, This is the man that troubled the earth, that made kings to shake;","searchKeywords":["they","that","see","thee","shall","wonder","and","say","this","the","man","troubled","earth","made","kings","shake"]},{"verseId":"brenton_isaiah_14_17","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":17,"text":"that made the whole world desolate, and destroyed its cities; he loosed not those who were in captivity.","searchKeywords":["that","made","the","whole","world","desolate","and","destroyed","its","cities","loosed","not","those","who","were","captivity"]},{"verseId":"brenton_isaiah_14_18","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":18,"text":"All the kings of the nations lie in honour, man in his house.","searchKeywords":["all","the","kings","nations","lie","honour","man","his","house"]},{"verseId":"brenton_isaiah_14_19","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":19,"text":"But thou shalt be cast forth on the mountains, as a loathed carcase, with many dead who have been pierced with swords, going down to the grave.","searchKeywords":["but","thou","shalt","cast","forth","the","mountains","loathed","carcase","with","many","dead","who","have","been","pierced","swords","going","down","grave"]},{"verseId":"brenton_isaiah_14_20","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":20,"text":"As a garment defiled with blood shall not be pure, so neither shalt thou be pure; because thou hast destroyed my land, and hast slain my people: thou shalt not endure for ever,— an evil seed.","searchKeywords":["garment","defiled","with","blood","shall","not","pure","neither","shalt","thou","because","hast","destroyed","land","and","slain","people","endure","for","ever","evil","seed"]},{"verseId":"brenton_isaiah_14_21","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":21,"text":"Prepare thy children to be slain for the sins of their father; that they arise not, and inherit the earth, nor fill the earth with wars.","searchKeywords":["prepare","thy","children","slain","for","the","sins","their","father","that","they","arise","not","and","inherit","earth","nor","fill","with","wars"]},{"verseId":"brenton_isaiah_14_22","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":22,"text":"And I will rise up against them, saith the Lord of hosts, and I will destroy their name, and remnant, and seed: thus saith the Lord.","searchKeywords":["and","will","rise","against","them","saith","the","lord","hosts","destroy","their","name","remnant","seed","thus"]},{"verseId":"brenton_isaiah_14_23","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":23,"text":"And I will make the region of Babylon desert, so that hedgehogs shall dwell , and it shall come to nothing: and I will make it a pit of clay for destruction.","searchKeywords":["and","will","make","the","region","babylon","desert","that","hedgehogs","shall","dwell","come","nothing","pit","clay","for","destruction"]},{"verseId":"brenton_isaiah_14_24","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":24,"text":"Thus saith the Lord of hosts, As I have said, so it shall be: and as I have purposed, so shall remain:","searchKeywords":["thus","saith","the","lord","hosts","have","said","shall","and","purposed","remain"]},{"verseId":"brenton_isaiah_14_25","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":25,"text":"to destroy the Assyrians upon my land, and upon my mountains: and they shall be for trampling; and their yoke shall be taken away from them, and their glory shall be taken away from their shoulders.","searchKeywords":["destroy","the","assyrians","upon","land","and","mountains","they","shall","for","trampling","their","yoke","taken","away","from","them","glory","shoulders"]},{"verseId":"brenton_isaiah_14_26","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":26,"text":"This is the purpose which the Lord has purposed upon the whole earth: and this the hand that is uplifted against all the nations.","searchKeywords":["this","the","purpose","which","lord","has","purposed","upon","whole","earth","and","hand","that","uplifted","against","all","nations"]},{"verseId":"brenton_isaiah_14_27","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":27,"text":"For what the Holy God has purposed, who shall frustrate? and who shall turn back his uplifted hand?","searchKeywords":["for","what","the","holy","god","has","purposed","who","shall","frustrate","and","turn","back","his","uplifted","hand"]},{"verseId":"brenton_isaiah_14_28","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":28,"text":"In the year in which king Achaz died this word came.","searchKeywords":["the","year","which","king","achaz","died","this","word","came"]},{"verseId":"brenton_isaiah_14_29","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":29,"text":"Rejoice not, all ye Philistines, because the yoke of him that smote you is broken: for out of the seed of the serpent shall come forth the young of asps, and their young shall come forth flying serpents.","searchKeywords":["rejoice","not","all","philistines","because","the","yoke","him","that","smote","you","broken","for","out","seed","serpent","shall","come","forth","young","asps","and","their","flying","serpents"]},{"verseId":"brenton_isaiah_14_30","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":30,"text":"And the poor shall be fed by him, and poor men shall rest in peace: but he shall destroy thy seed with hunger, and shall destroy thy remnant.","searchKeywords":["and","the","poor","shall","fed","him","men","rest","peace","but","destroy","thy","seed","with","hunger","remnant"]},{"verseId":"brenton_isaiah_14_31","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":31,"text":"Howl, ye gates of cities; let the cities be troubled and cry, all the Philistines: for smoke is coming from the north, and there is no of living.","searchKeywords":["howl","gates","cities","let","the","troubled","and","cry","all","philistines","for","smoke","coming","from","north","there","living"]},{"verseId":"brenton_isaiah_14_32","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":14,"verse":32,"text":"And what shall the kings of the nations answer? That the Lord has founded Sion, and by him the poor of the people shall be saved.","searchKeywords":["and","what","shall","the","kings","nations","answer","that","lord","has","founded","sion","him","poor","people","saved"]}]