[{"verseId":"brenton_isaiah_10_1","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":1,"text":"Woe to them that write wickedness; for when they write they do write wickedness,","searchKeywords":["woe","them","that","write","wickedness","for","when","they"]},{"verseId":"brenton_isaiah_10_2","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":2,"text":"perverting the cause of the poor, violently wresting the judgment of the needy ones of my people, that the widow may be a prey to them, and the orphan a spoil.","searchKeywords":["perverting","the","cause","poor","violently","wresting","judgment","needy","ones","people","that","widow","may","prey","them","and","orphan","spoil"]},{"verseId":"brenton_isaiah_10_3","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":3,"text":"And what will they do in the day of visitation? for affliction shall come to you from afar: and to whom will ye flee for help? and where will ye leave your glory,","searchKeywords":["and","what","will","they","the","day","visitation","for","affliction","shall","come","you","from","afar","whom","flee","help","where","leave","your","glory"]},{"verseId":"brenton_isaiah_10_4","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":4,"text":"that ye may not fall into captivity? wrath is not turned away, but hand is yet exalted.","searchKeywords":["that","may","not","fall","into","captivity","wrath","turned","away","but","hand","yet","exalted"]},{"verseId":"brenton_isaiah_10_5","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":5,"text":"Woe to the Assyrians; the rod of my wrath, and anger are in their hands.","searchKeywords":["woe","the","assyrians","rod","wrath","and","anger","are","their","hands"]},{"verseId":"brenton_isaiah_10_6","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":6,"text":"I will send my wrath against a sinful nation, and I will charge my people to take plunder and spoil, and to trample the cities, and to make them dust.","searchKeywords":["will","send","wrath","against","sinful","nation","and","charge","people","take","plunder","spoil","trample","the","cities","make","them","dust"]},{"verseId":"brenton_isaiah_10_7","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":7,"text":"But he meant not thus, neither did he devise thus in his soul: but his mind shall change, and to destroy nations not a few.","searchKeywords":["but","meant","not","thus","neither","did","devise","his","soul","mind","shall","change","and","destroy","nations","few"]},{"verseId":"brenton_isaiah_10_8","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":8,"text":"And if they should say to him, Thou alone art ruler;","searchKeywords":["and","they","should","say","him","thou","alone","art","ruler"]},{"verseId":"brenton_isaiah_10_9","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":9,"text":"then shall he say, Have I not taken the country above Babylon and Chalanes, where the tower was built? and have I taken Arabia, and Damascus, and Samaria?","searchKeywords":["then","shall","say","have","not","taken","the","country","above","babylon","and","chalanes","where","tower","was","built","arabia","damascus","samaria"]},{"verseId":"brenton_isaiah_10_10","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":10,"text":"As I have taken them, I will also take all the kingdoms: howl, ye idols in Jerusalem, and in Samaria.","searchKeywords":["have","taken","them","will","also","take","all","the","kingdoms","howl","idols","jerusalem","and","samaria"]},{"verseId":"brenton_isaiah_10_11","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":11,"text":"For as I did to Samaria and her idols, so will I do also to Jerusalem and her idols.","searchKeywords":["for","did","samaria","and","her","idols","will","also","jerusalem"]},{"verseId":"brenton_isaiah_10_12","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":12,"text":"And it shall come to pass, when the Lord shall have finished doing all things on mount Sion and Jerusalem, I will visit upon the proud heart, upon the ruler of the Assyrians, and upon the boastful haughtiness of his eyes.","searchKeywords":["and","shall","come","pass","when","the","lord","have","finished","doing","all","things","mount","sion","jerusalem","will","visit","upon","proud","heart","ruler","assyrians","boastful","haughtiness","his","eyes"]},{"verseId":"brenton_isaiah_10_13","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":13,"text":"For he said, I will act in strength, and in the wisdom of understanding I will remove the boundaries of nations, and will spoil their strength.","searchKeywords":["for","said","will","act","strength","and","the","wisdom","understanding","remove","boundaries","nations","spoil","their"]},{"verseId":"brenton_isaiah_10_14","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":14,"text":"And I will shake the inhabited cities: and I will take with my hand all the world as a nest: and I will even take them as eggs that have been left; and there is none that shall escape me, or contradict me.","searchKeywords":["and","will","shake","the","inhabited","cities","take","with","hand","all","world","nest","even","them","eggs","that","have","been","left","there","none","shall","escape","contradict"]},{"verseId":"brenton_isaiah_10_15","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":15,"text":"Shall the axe glorify itself without him that hews with it? or shall the saw lift up itself without him that uses it, as if one should lift a rod or staff? but it shall not be so;","searchKeywords":["shall","the","axe","glorify","itself","without","him","that","hews","with","saw","lift","uses","one","should","rod","staff","but","not"]},{"verseId":"brenton_isaiah_10_16","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":16,"text":"but the Lord of hosts shall send dishonour upon thine honour, and burning fire shall be kindled upon thy glory.","searchKeywords":["but","the","lord","hosts","shall","send","dishonour","upon","thine","honour","and","burning","fire","kindled","thy","glory"]},{"verseId":"brenton_isaiah_10_17","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":17,"text":"And the light of Israel shall be for a fire, and he shall sanctify him with burning fire, and it shall devour the wood as grass.","searchKeywords":["and","the","light","israel","shall","for","fire","sanctify","him","with","burning","devour","wood","grass"]},{"verseId":"brenton_isaiah_10_18","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":18,"text":"In that day the mountains shall be consumed, and the hills, and the forests, and shall devour soul and body: and he that flees shall be as one fleeing from burning flame.","searchKeywords":["that","day","the","mountains","shall","consumed","and","hills","forests","devour","soul","body","flees","one","fleeing","from","burning","flame"]},{"verseId":"brenton_isaiah_10_19","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":19,"text":"And they that are left of them shall be a number, and a child shall write them.","searchKeywords":["and","they","that","are","left","them","shall","number","child","write"]},{"verseId":"brenton_isaiah_10_20","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":20,"text":"And it shall come to pass in that day the remnant of Israel shall no more join themselves with, and the saved of Jacob shall no more trust in, them that injured them; but they shall trust in the Holy God of Israel, in truth.","searchKeywords":["and","shall","come","pass","that","day","the","remnant","israel","more","join","themselves","with","saved","jacob","trust","them","injured","but","they","holy","god","truth"]},{"verseId":"brenton_isaiah_10_21","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":21,"text":"And the remnant of Jacob shall on the mighty God.","searchKeywords":["and","the","remnant","jacob","shall","mighty","god"]},{"verseId":"brenton_isaiah_10_22","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":22,"text":"And though the people of Israel be as the sand of the sea, a remnant of them shall be saved.","searchKeywords":["and","though","the","people","israel","sand","sea","remnant","them","shall","saved"]},{"verseId":"brenton_isaiah_10_23","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":23,"text":"He will finish the work, and cut it short in righteousness: because the Lord will make a short work in all the world.","searchKeywords":["will","finish","the","work","and","cut","short","righteousness","because","lord","make","all","world"]},{"verseId":"brenton_isaiah_10_24","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":24,"text":"Therefore thus saith the Lord of hosts, Be not afraid, my people who dwell in Sion, of the Assyrians, because he shall smite thee with a rod: for I am bringing a stroke upon thee, that mayest see the way of Egypt.","searchKeywords":["therefore","thus","saith","the","lord","hosts","not","afraid","people","who","dwell","sion","assyrians","because","shall","smite","thee","with","rod","for","bringing","stroke","upon","that","mayest","see","way","egypt"]},{"verseId":"brenton_isaiah_10_25","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":25,"text":"For yet a little while, and the indignation shall cease: but my wrath shall be against their council.","searchKeywords":["for","yet","little","while","and","the","indignation","shall","cease","but","wrath","against","their","council"]},{"verseId":"brenton_isaiah_10_26","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":26,"text":"And God will stir up against them, according to the stroke of Madiam in the place of affliction: and his wrath shall be by the way of the sea, to the way that leads to Egypt.","searchKeywords":["and","god","will","stir","against","them","according","the","stroke","madiam","place","affliction","his","wrath","shall","way","sea","that","leads","egypt"]},{"verseId":"brenton_isaiah_10_27","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":27,"text":"And it shall come to pass in that day, his yoke shall be taken away from thy shoulder, and his fear from thee, and the yoke shall be destroyed from off your shoulders.","searchKeywords":["and","shall","come","pass","that","day","his","yoke","taken","away","from","thy","shoulder","fear","thee","the","destroyed","off","your","shoulders"]},{"verseId":"brenton_isaiah_10_28","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":28,"text":"For he shall arrive at the city of Angai, and shall pass on to Maggedo, and shall lay up his stores in Machmas.","searchKeywords":["for","shall","arrive","the","city","angai","and","pass","maggedo","lay","his","stores","machmas"]},{"verseId":"brenton_isaiah_10_29","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":29,"text":"And he shall pass by the valley, and shall arrive at Angai: fear shall seize upon Rama, the city of Saul.","searchKeywords":["and","shall","pass","the","valley","arrive","angai","fear","seize","upon","rama","city","saul"]},{"verseId":"brenton_isaiah_10_30","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":30,"text":"The daughter of Gallim shall flee; Laisa shall hear; one shall hear in Anathoth.","searchKeywords":["the","daughter","gallim","shall","flee","laisa","hear","one","anathoth"]},{"verseId":"brenton_isaiah_10_31","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":31,"text":"Madebena also is amazed, and the inhabitants of Gibbir.","searchKeywords":["madebena","also","amazed","and","the","inhabitants","gibbir"]},{"verseId":"brenton_isaiah_10_32","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":32,"text":"Exhort ye to-day to remain in the way: exhort ye with the hand the mountain, the daughter of Sion, even ye hills that are in Jerusalem.","searchKeywords":["exhort","day","remain","the","way","with","hand","mountain","daughter","sion","even","hills","that","are","jerusalem"]},{"verseId":"brenton_isaiah_10_33","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":33,"text":"Behold, the Lord, the Lord of hosts, will mightily confound the glorious ones; and the haughty in pride shall be crushed, and the lofty shall be brought low:","searchKeywords":["behold","the","lord","hosts","will","mightily","confound","glorious","ones","and","haughty","pride","shall","crushed","lofty","brought","low"]},{"verseId":"brenton_isaiah_10_34","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":10,"verse":34,"text":"and the lofty ones shall fall by the sword, and Libanus shall fall with his lofty ones.","searchKeywords":["and","the","lofty","ones","shall","fall","sword","libanus","with","his"]}]