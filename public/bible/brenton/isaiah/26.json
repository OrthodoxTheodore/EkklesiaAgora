[{"verseId":"brenton_isaiah_26_1","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":1,"text":"In that day they shall sing this song in the land of Judea; Behold a strong city; and he shall make salvation wall and bulwark.","searchKeywords":["that","day","they","shall","sing","this","song","the","land","judea","behold","strong","city","and","make","salvation","wall","bulwark"]},{"verseId":"brenton_isaiah_26_2","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":2,"text":"Open ye the gates, let the nation enter that keeps righteousness, and keeps truth,","searchKeywords":["open","the","gates","let","nation","enter","that","keeps","righteousness","and","truth"]},{"verseId":"brenton_isaiah_26_3","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":3,"text":"supporting truth, and keeping peace: for on thee, O Lord,","searchKeywords":["supporting","truth","and","keeping","peace","for","thee","lord"]},{"verseId":"brenton_isaiah_26_4","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":4,"text":"they have trusted with confidence for ever, the great, the eternal God;","searchKeywords":["they","have","trusted","with","confidence","for","ever","the","great","eternal","god"]},{"verseId":"brenton_isaiah_26_5","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":5,"text":"who hast humbled and brought down them that dwell on high, thou shalt cast down strong cities, and bring them to the ground.","searchKeywords":["who","hast","humbled","and","brought","down","them","that","dwell","high","thou","shalt","cast","strong","cities","bring","the","ground"]},{"verseId":"brenton_isaiah_26_6","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":6,"text":"And the feet of the meek and lowly shall trample them.","searchKeywords":["and","the","feet","meek","lowly","shall","trample","them"]},{"verseId":"brenton_isaiah_26_7","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":7,"text":"The way of the godly is made straight: the way of the godly is also prepared.","searchKeywords":["the","way","godly","made","straight","also","prepared"]},{"verseId":"brenton_isaiah_26_8","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":8,"text":"For the way of the Lord is judgment: we have hoped in thy name, and on the remembrance ,","searchKeywords":["for","the","way","lord","judgment","have","hoped","thy","name","and","remembrance"]},{"verseId":"brenton_isaiah_26_9","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":9,"text":"which our soul longs for: my spirit seeks thee very early in the morning, O God, for thy commandments are a light on the earth: learn righteousness, ye that dwell upon the earth.","searchKeywords":["which","our","soul","longs","for","spirit","seeks","thee","very","early","the","morning","god","thy","commandments","are","light","earth","learn","righteousness","that","dwell","upon"]},{"verseId":"brenton_isaiah_26_10","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":10,"text":"For the ungodly one is put down: no one who will not learn righteousness on the earth, shall be able to do the truth: let the ungodly be taken away, that he see not the glory of the Lord.","searchKeywords":["for","the","ungodly","one","put","down","who","will","not","learn","righteousness","earth","shall","able","truth","let","taken","away","that","see","glory","lord"]},{"verseId":"brenton_isaiah_26_11","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":11,"text":"O Lord, thine arm is exalted, yet they knew it not: but when they know they shall be ashamed: jealousy shall seize upon an untaught nation, and now fire shall devour the adversaries.","searchKeywords":["lord","thine","arm","exalted","yet","they","knew","not","but","when","know","shall","ashamed","jealousy","seize","upon","untaught","nation","and","now","fire","devour","the","adversaries"]},{"verseId":"brenton_isaiah_26_12","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":12,"text":"O Lord our God, give us peace: for thou hast rendered to us all things.","searchKeywords":["lord","our","god","give","peace","for","thou","hast","rendered","all","things"]},{"verseId":"brenton_isaiah_26_13","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":13,"text":"O Lord our God, take possession of us: O Lord, we know not other beside thee: we name thy name.","searchKeywords":["lord","our","god","take","possession","know","not","other","beside","thee","name","thy"]},{"verseId":"brenton_isaiah_26_14","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":14,"text":"But the dead shall not see life, neither shall physicians by any means raise up: therefore thou hast brought upon , and slain , and hast taken away every male of them. Bring more evils upon them, O Lord;","searchKeywords":["but","the","dead","shall","not","see","life","neither","physicians","any","means","raise","therefore","thou","hast","brought","upon","and","slain","taken","away","every","male","them","bring","more","evils","lord"]},{"verseId":"brenton_isaiah_26_15","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":15,"text":"bring more evils on the glorious ones of the earth.","searchKeywords":["bring","more","evils","the","glorious","ones","earth"]},{"verseId":"brenton_isaiah_26_16","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":16,"text":"Lord, in affliction I remembered thee; thy chastening was to us with small affliction.","searchKeywords":["lord","affliction","remembered","thee","thy","chastening","was","with","small"]},{"verseId":"brenton_isaiah_26_17","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":17,"text":"And as a woman in travail draws nigh to be delivered, cries out in her pain; so have we been to thy beloved.","searchKeywords":["and","woman","travail","draws","nigh","delivered","cries","out","her","pain","have","been","thy","beloved"]},{"verseId":"brenton_isaiah_26_18","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":18,"text":"We have conceived, O Lord, because of thy fear, and have been in pain, and have brought forth the breath of thy salvation, which we have wrought upon the earth: we shall not fall, but all that dwell upon the land shall fall.","searchKeywords":["have","conceived","lord","because","thy","fear","and","been","pain","brought","forth","the","breath","salvation","which","wrought","upon","earth","shall","not","fall","but","all","that","dwell","land"]},{"verseId":"brenton_isaiah_26_19","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":19,"text":"The dead shall rise, and they that are in the tombs shall be raised, and they that are in the earth shall rejoice: for the dew from thee is healing to them: but the land of the ungodly shall perish.","searchKeywords":["the","dead","shall","rise","and","they","that","are","tombs","raised","earth","rejoice","for","dew","from","thee","healing","them","but","land","ungodly","perish"]},{"verseId":"brenton_isaiah_26_20","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":20,"text":"Go, my people, enter into thy closets, shut thy door, hide thyself for a little season, until the anger of the Lord have passed away.","searchKeywords":["people","enter","into","thy","closets","shut","door","hide","thyself","for","little","season","until","the","anger","lord","have","passed","away"]},{"verseId":"brenton_isaiah_26_21","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":26,"verse":21,"text":"For, behold, the Lord is bringing wrath from holy place upon the dwellers on the earth: the earth also shall disclose her blood, and shall not cover her slain.","searchKeywords":["for","behold","the","lord","bringing","wrath","from","holy","place","upon","dwellers","earth","also","shall","disclose","her","blood","and","not","cover","slain"]}]