[{"verseId":"brenton_isaiah_32_1","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":1,"text":"For, behold, a righteous king shall reign, and princes shall govern with judgment.","searchKeywords":["for","behold","righteous","king","shall","reign","and","princes","govern","with","judgment"]},{"verseId":"brenton_isaiah_32_2","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":2,"text":"And a man shall hide his words, and be hidden, as from rushing water, and shall appear in Sion as a rushing river, glorious in a thirsty land.","searchKeywords":["and","man","shall","hide","his","words","hidden","from","rushing","water","appear","sion","river","glorious","thirsty","land"]},{"verseId":"brenton_isaiah_32_3","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":3,"text":"And they shall no more trust in men, but they shall incline their ears to hear.","searchKeywords":["and","they","shall","more","trust","men","but","incline","their","ears","hear"]},{"verseId":"brenton_isaiah_32_4","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":4,"text":"And the heart of the weak ones shall attend to hear, and the stammering tongues shall soon learn to speak peace.","searchKeywords":["and","the","heart","weak","ones","shall","attend","hear","stammering","tongues","soon","learn","speak","peace"]},{"verseId":"brenton_isaiah_32_5","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":5,"text":"And they shall no more at all tell a fool to rule, and thy servants shall no more at all say, Be silent.","searchKeywords":["and","they","shall","more","all","tell","fool","rule","thy","servants","say","silent"]},{"verseId":"brenton_isaiah_32_6","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":6,"text":"For the fool shall speak foolish words, and his heart shall meditate vanities, and to perform lawless deeds and to speak error against the Lord, to scatter hungry souls, and he will cause the thirsty souls to be empty.","searchKeywords":["for","the","fool","shall","speak","foolish","words","and","his","heart","meditate","vanities","perform","lawless","deeds","error","against","lord","scatter","hungry","souls","will","cause","thirsty","empty"]},{"verseId":"brenton_isaiah_32_7","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":7,"text":"For the counsel of the wicked will devise iniquity, to destroy the poor with unjust words, and ruin the cause of the poor in judgment.","searchKeywords":["for","the","counsel","wicked","will","devise","iniquity","destroy","poor","with","unjust","words","and","ruin","cause","judgment"]},{"verseId":"brenton_isaiah_32_8","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":8,"text":"But the godly have devised wise , and this counsel shall stand.","searchKeywords":["but","the","godly","have","devised","wise","and","this","counsel","shall","stand"]},{"verseId":"brenton_isaiah_32_9","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":9,"text":"Rise up, ye rich women, and hear my voice; ye confident daughters, hearken to my words.","searchKeywords":["rise","rich","women","and","hear","voice","confident","daughters","hearken","words"]},{"verseId":"brenton_isaiah_32_10","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":10,"text":"Remember for a full year in pain, yet with hope: the vintage has been cut off, it has ceased, it shall by no means come again.","searchKeywords":["remember","for","full","year","pain","yet","with","hope","the","vintage","has","been","cut","off","ceased","shall","means","come","again"]},{"verseId":"brenton_isaiah_32_11","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":11,"text":"Be amazed, be pained, ye confident ones: strip you, bare yourselves, gird your loins;","searchKeywords":["amazed","pained","confident","ones","strip","you","bare","yourselves","gird","your","loins"]},{"verseId":"brenton_isaiah_32_12","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":12,"text":"and beat on your breasts, because of the pleasant field, and the fruit of the vine.","searchKeywords":["and","beat","your","breasts","because","the","pleasant","field","fruit","vine"]},{"verseId":"brenton_isaiah_32_13","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":13,"text":"the land of my people, the thorn and grass shall come upon , and joy shall be removed from every house.","searchKeywords":["the","land","people","thorn","and","grass","shall","come","upon","joy","removed","from","every","house"]},{"verseId":"brenton_isaiah_32_14","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":14,"text":"the rich city, the houses are deserted; they shall abandon the wealth of the city, the pleasant houses: and the villages shall be caves for ever, the joy of wild asses, shepherds' pastures;","searchKeywords":["the","rich","city","houses","are","deserted","they","shall","abandon","wealth","pleasant","and","villages","caves","for","ever","joy","wild","asses","shepherds","pastures"]},{"verseId":"brenton_isaiah_32_15","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":15,"text":"until the Spirit shall come upon you from on high, and Chermel shall be desert, and Chermel shall be counted for a forest.","searchKeywords":["until","the","spirit","shall","come","upon","you","from","high","and","chermel","desert","counted","for","forest"]},{"verseId":"brenton_isaiah_32_16","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":16,"text":"Then judgment shall abide in the wilderness, and righteousness shall dwell in Carmel.","searchKeywords":["then","judgment","shall","abide","the","wilderness","and","righteousness","dwell","carmel"]},{"verseId":"brenton_isaiah_32_17","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":17,"text":"And the works of righteousness shall be peace; and righteousness shall ensure rest, and shall be confident for ever.","searchKeywords":["and","the","works","righteousness","shall","peace","ensure","rest","confident","for","ever"]},{"verseId":"brenton_isaiah_32_18","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":18,"text":"And his people shall inhabit a city of peace, and dwell in in confidence, and they shall rest with wealth.","searchKeywords":["and","his","people","shall","inhabit","city","peace","dwell","confidence","they","rest","with","wealth"]},{"verseId":"brenton_isaiah_32_19","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":19,"text":"And if the hail should come down, it shall not come upon you; and they that dwell in the forests shall be in confidence, as those in the plain country.","searchKeywords":["and","the","hail","should","come","down","shall","not","upon","you","they","that","dwell","forests","confidence","those","plain","country"]},{"verseId":"brenton_isaiah_32_20","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":32,"verse":20,"text":"Blessed are they that sow by every water, where the ox and ass tread.","searchKeywords":["blessed","are","they","that","sow","every","water","where","the","and","ass","tread"]}]