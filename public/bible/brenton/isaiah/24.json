[{"verseId":"brenton_isaiah_24_1","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":1,"text":"Behold, the Lord is about to lay waste the world, and will make it desolate, and will lay bare the surface of it, and scatter them that dwell therein.","searchKeywords":["behold","the","lord","about","lay","waste","world","and","will","make","desolate","bare","surface","scatter","them","that","dwell","therein"]},{"verseId":"brenton_isaiah_24_2","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":2,"text":"And the people shall be as the priest, and the servant as the lord, and the maid as the mistress; the buyer shall be as the seller, the lender as the borrower, and the debtor as his creditor.","searchKeywords":["and","the","people","shall","priest","servant","lord","maid","mistress","buyer","seller","lender","borrower","debtor","his","creditor"]},{"verseId":"brenton_isaiah_24_3","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":3,"text":"The earth shall be completely laid waste, and the earth shall be utterly spoiled: for the mouth of the Lord has spoken these things.","searchKeywords":["the","earth","shall","completely","laid","waste","and","utterly","spoiled","for","mouth","lord","has","spoken","these","things"]},{"verseId":"brenton_isaiah_24_4","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":4,"text":"The earth mourns, and the world is ruined, the lofty ones of the earth are mourning.","searchKeywords":["the","earth","mourns","and","world","ruined","lofty","ones","are","mourning"]},{"verseId":"brenton_isaiah_24_5","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":5,"text":"And she has sinned by reason of her inhabitants; because they have transgressed the law, and changed the ordinances, the everlasting covenant.","searchKeywords":["and","she","has","sinned","reason","her","inhabitants","because","they","have","transgressed","the","law","changed","ordinances","everlasting","covenant"]},{"verseId":"brenton_isaiah_24_6","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":6,"text":"Therefore a curse shall consume the earth, because the inhabitants thereof have sinned: therefore the dwellers in the earth shall be poor, and few men shall be left.","searchKeywords":["therefore","curse","shall","consume","the","earth","because","inhabitants","thereof","have","sinned","dwellers","poor","and","few","men","left"]},{"verseId":"brenton_isaiah_24_7","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":7,"text":"The wine shall mourn, the vine shall mourn, all the merry-hearted shall sigh.","searchKeywords":["the","wine","shall","mourn","vine","all","merry","hearted","sigh"]},{"verseId":"brenton_isaiah_24_8","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":8,"text":"The mirth of timbrels has ceased, the sound of the harp has ceased.","searchKeywords":["the","mirth","timbrels","has","ceased","sound","harp"]},{"verseId":"brenton_isaiah_24_9","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":9,"text":"They are ashamed, they have not drunk wine; strong drink has become bitter to them that drink .","searchKeywords":["they","are","ashamed","have","not","drunk","wine","strong","drink","has","become","bitter","them","that"]},{"verseId":"brenton_isaiah_24_10","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":10,"text":"All the city has become desolate: one shall shut his house so that none shall enter.","searchKeywords":["all","the","city","has","become","desolate","one","shall","shut","his","house","that","none","enter"]},{"verseId":"brenton_isaiah_24_11","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":11,"text":"There is a howling for the wine everywhere; all the mirth of the land has ceased, all the mirth of the land has departed.","searchKeywords":["there","howling","for","the","wine","everywhere","all","mirth","land","has","ceased","departed"]},{"verseId":"brenton_isaiah_24_12","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":12,"text":"And cities shall be left desolate, and houses being left shall fall to ruin.","searchKeywords":["and","cities","shall","left","desolate","houses","being","fall","ruin"]},{"verseId":"brenton_isaiah_24_13","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":13,"text":"All this shall be in the land in the midst of the nations, as if one should strip an olive tree, so shall they strip them; but when the vintage is done,","searchKeywords":["all","this","shall","the","land","midst","nations","one","should","strip","olive","tree","they","them","but","when","vintage","done"]},{"verseId":"brenton_isaiah_24_14","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":14,"text":"these shall cry aloud; and they that are left on the land shall rejoice together in the glory of the Lord: the water of the sea shall be troubled.","searchKeywords":["these","shall","cry","aloud","and","they","that","are","left","the","land","rejoice","together","glory","lord","water","sea","troubled"]},{"verseId":"brenton_isaiah_24_15","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":15,"text":"Therefore shall the glory of the Lord be in the isles of the sea; the name of the Lord shall be glorious.","searchKeywords":["therefore","shall","the","glory","lord","isles","sea","name","glorious"]},{"verseId":"brenton_isaiah_24_16","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":16,"text":"O Lord God of Israel, from the ends of the earth we have heard wonderful things, hope to the godly: but they shall say, Woe to the despisers, that despise the law.","searchKeywords":["lord","god","israel","from","the","ends","earth","have","heard","wonderful","things","hope","godly","but","they","shall","say","woe","despisers","that","despise","law"]},{"verseId":"brenton_isaiah_24_17","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":17,"text":"Fear, and a pit, and a snare, are upon you that dwell on the earth.","searchKeywords":["fear","and","pit","snare","are","upon","you","that","dwell","the","earth"]},{"verseId":"brenton_isaiah_24_18","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":18,"text":"And it shall come to pass, he that flees from the fear shall fall into the pit; and he that comes up out of the pit shall be caught by the snare: for windows have been opened in heaven, and the foundations of the earth shall be shaken,","searchKeywords":["and","shall","come","pass","that","flees","from","the","fear","fall","into","pit","comes","out","caught","snare","for","windows","have","been","opened","heaven","foundations","earth","shaken"]},{"verseId":"brenton_isaiah_24_19","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":19,"text":"the earth shall be utterly confounded, and the earth shall be completely perplexed.","searchKeywords":["the","earth","shall","utterly","confounded","and","completely","perplexed"]},{"verseId":"brenton_isaiah_24_20","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":20,"text":"It reels as a drunkard and one oppressed with wine, and the earth shall be shaken as a storehouse of fruits; for iniquity has prevailed upon it, and it shall fall, and shall not be able to rise.","searchKeywords":["reels","drunkard","and","one","oppressed","with","wine","the","earth","shall","shaken","storehouse","fruits","for","iniquity","has","prevailed","upon","fall","not","able","rise"]},{"verseId":"brenton_isaiah_24_21","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":21,"text":"And God shall bring hand upon the host of heaven, and upon the kings of the earth.","searchKeywords":["and","god","shall","bring","hand","upon","the","host","heaven","kings","earth"]},{"verseId":"brenton_isaiah_24_22","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":22,"text":"And they shall gather the multitude thereof into prisons, and they shall shut them into a strong hold: after many generations they shall be visited.","searchKeywords":["and","they","shall","gather","the","multitude","thereof","into","prisons","shut","them","strong","hold","after","many","generations","visited"]},{"verseId":"brenton_isaiah_24_23","translationId":"brenton","testament":"OT","bookIndex":45,"bookName":"Isaiah","bookAbbrev":"isaiah","chapter":24,"verse":23,"text":"And the brick shall decay, and the wall shall fall; for the Lord shall reign from out of Sion, and out of Jerusalem, and shall be glorified before elders.","searchKeywords":["and","the","brick","shall","decay","wall","fall","for","lord","reign","from","out","sion","jerusalem","glorified","before","elders"]}]