[{"verseId":"brenton_joshua_21_1","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":1,"text":"And the heads of the families of the sons of Levi drew near to Eleazar the priest, and to Joshua the of Naue, and to the heads of families of the tribes of Israel.","searchKeywords":["and","the","heads","families","sons","levi","drew","near","eleazar","priest","joshua","naue","tribes","israel"]},{"verseId":"brenton_joshua_21_2","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":2,"text":"And they spoke to them in Selo in the land of Chanaan, saying, The Lord gave commandment by Moses to give us cities to dwell in, and the country round about for our cattle.","searchKeywords":["and","they","spoke","them","selo","the","land","chanaan","saying","lord","gave","commandment","moses","give","cities","dwell","country","round","about","for","our","cattle"]},{"verseId":"brenton_joshua_21_3","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":3,"text":"So the children of Israel gave to the Levites in their inheritance by the command of the Lord the cities and the country round.","searchKeywords":["the","children","israel","gave","levites","their","inheritance","command","lord","cities","and","country","round"]},{"verseId":"brenton_joshua_21_4","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":4,"text":"And the lot came out for the children of Caath; and the sons of Aaron, the priests the Levites, had by lot thirteen cities out of the tribe of Juda, and out of the tribe of Symeon, and out of the tribe of Benjamin.","searchKeywords":["and","the","lot","came","out","for","children","caath","sons","aaron","priests","levites","had","thirteen","cities","tribe","juda","symeon","benjamin"]},{"verseId":"brenton_joshua_21_5","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":5,"text":"And to the sons of Caath that were left by lot ten cities, out of the tribe of Ephraim, and out of the tribe of Dan, and out of the half tribe of Manasse.","searchKeywords":["and","the","sons","caath","that","were","left","lot","ten","cities","out","tribe","ephraim","dan","half","manasse"]},{"verseId":"brenton_joshua_21_6","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":6,"text":"And the sons of Gedson had thirteen cities, out of the tribe of Issachar, and out of the tribe of Aser, and out of the tribe of Nephthali, and out of the half tribe of Manasse in Basan.","searchKeywords":["and","the","sons","gedson","had","thirteen","cities","out","tribe","issachar","aser","nephthali","half","manasse","basan"]},{"verseId":"brenton_joshua_21_7","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":7,"text":"And the sons of Merari according to their families had by lot twelve cities, out of the tribe of Ruben, and out of the tribe of Gad, and out of the tribe of Zabulon.","searchKeywords":["and","the","sons","merari","according","their","families","had","lot","twelve","cities","out","tribe","ruben","gad","zabulon"]},{"verseId":"brenton_joshua_21_8","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":8,"text":"And the children of Israel gave to the Levites the cities and their suburbs, as the Lord commanded Moses, by lot.","searchKeywords":["and","the","children","israel","gave","levites","cities","their","suburbs","lord","commanded","moses","lot"]},{"verseId":"brenton_joshua_21_9","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":9,"text":"And the tribe of the children of Juda, and the tribe of the children of Symeon, and of the tribe of the children of Benjamin gave these cities, and they were assigned","searchKeywords":["and","the","tribe","children","juda","symeon","benjamin","gave","these","cities","they","were","assigned"]},{"verseId":"brenton_joshua_21_10","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":10,"text":"to the sons of Aaron of the family of Caath of the sons of Levi, for the lot fell to these.","searchKeywords":["the","sons","aaron","family","caath","levi","for","lot","fell","these"]},{"verseId":"brenton_joshua_21_11","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":11,"text":"And they gave to them Cariatharboc the metropolis of the sons of Enac; this is Chebron in the mountain of Juda, and the suburbs round it.","searchKeywords":["and","they","gave","them","cariatharboc","the","metropolis","sons","enac","this","chebron","mountain","juda","suburbs","round"]},{"verseId":"brenton_joshua_21_12","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":12,"text":"But the lands of the city, and its villages Joshua gave to the sons of Chaleb the son of Jephonne for a possession.","searchKeywords":["but","the","lands","city","and","its","villages","joshua","gave","sons","chaleb","son","jephonne","for","possession"]},{"verseId":"brenton_joshua_21_13","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":13,"text":"And to the sons of Aaron he gave the city of refuge for the slayer, Chebron, and the suburbs belonging to it; and Lemna and the suburbs belonging to it;","searchKeywords":["and","the","sons","aaron","gave","city","refuge","for","slayer","chebron","suburbs","belonging","lemna"]},{"verseId":"brenton_joshua_21_14","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":14,"text":"and Ælom and its suburbs; and Tema and its suburbs;","searchKeywords":["and","lom","its","suburbs","tema"]},{"verseId":"brenton_joshua_21_15","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":15,"text":"and Gella and its suburbs; and Dabir and its suburbs;","searchKeywords":["and","gella","its","suburbs","dabir"]},{"verseId":"brenton_joshua_21_16","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":16,"text":"and Asa and its suburbs; and Tany and its suburbs; and Bæthsamys and its suburbs: nine cities from these two tribes.","searchKeywords":["and","asa","its","suburbs","tany","thsamys","nine","cities","from","these","two","tribes"]},{"verseId":"brenton_joshua_21_17","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":17,"text":"And from the tribe of Benjamin, Gabaon and its suburbs; and Gatheth and its suburbs;","searchKeywords":["and","from","the","tribe","benjamin","gabaon","its","suburbs","gatheth"]},{"verseId":"brenton_joshua_21_18","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":18,"text":"and Anathoth and its suburbs; and Gamala and its suburbs; four cities.","searchKeywords":["and","anathoth","its","suburbs","gamala","four","cities"]},{"verseId":"brenton_joshua_21_19","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":19,"text":"All the cities of the sons of Aaron the priests, thirteen.","searchKeywords":["all","the","cities","sons","aaron","priests","thirteen"]},{"verseId":"brenton_joshua_21_20","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":20,"text":"And to the families, the sons of Caath the Levites, that were left of the sons of Caath, there was their priests' city,","searchKeywords":["and","the","families","sons","caath","levites","that","were","left","there","was","their","priests","city"]},{"verseId":"brenton_joshua_21_21","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":21,"text":"out of the tribe of Ephraim; and they gave them the slayer's city of refuge, Sychem, and its suburbs, and Gazara and its appendages, and its suburbs;","searchKeywords":["out","the","tribe","ephraim","and","they","gave","them","slayer","city","refuge","sychem","its","suburbs","gazara","appendages"]},{"verseId":"brenton_joshua_21_22","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":22,"text":"and Bæthoron and its suburbs: four cities:","searchKeywords":["and","thoron","its","suburbs","four","cities"]},{"verseId":"brenton_joshua_21_23","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":23,"text":"and of the tribe of Dan, Helcothaim and its suburbs; and Gethedan and its suburbs:","searchKeywords":["and","the","tribe","dan","helcothaim","its","suburbs","gethedan"]},{"verseId":"brenton_joshua_21_24","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":24,"text":"and Ælon and its suburbs; and Getheremmon and its suburbs: four cities.","searchKeywords":["and","lon","its","suburbs","getheremmon","four","cities"]},{"verseId":"brenton_joshua_21_25","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":25,"text":"And out of the half tribe of Manasse, Tanach and its suburbs; and Jebatha and its suburbs; two cities.","searchKeywords":["and","out","the","half","tribe","manasse","tanach","its","suburbs","jebatha","two","cities"]},{"verseId":"brenton_joshua_21_26","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":26,"text":"In all ten cities, and the suburbs of each belonging to them, to the families of the sons of Caath that remained.","searchKeywords":["all","ten","cities","and","the","suburbs","each","belonging","them","families","sons","caath","that","remained"]},{"verseId":"brenton_joshua_21_27","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":27,"text":"And to the sons of Gedson the Levites out of the other half tribe of Manasse cities set apart for the slayers, Gaulon in the country of Basan, and its suburbs; and Bosora and its suburbs; two cities.","searchKeywords":["and","the","sons","gedson","levites","out","other","half","tribe","manasse","cities","set","apart","for","slayers","gaulon","country","basan","its","suburbs","bosora","two"]},{"verseId":"brenton_joshua_21_28","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":28,"text":"And out of the tribe of Issachar, Kison and its suburbs; and Debba and its suburbs;","searchKeywords":["and","out","the","tribe","issachar","kison","its","suburbs","debba"]},{"verseId":"brenton_joshua_21_29","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":29,"text":"and Remmath and its suburbs; and the well of Letters, and its suburbs; four cities.","searchKeywords":["and","remmath","its","suburbs","the","well","letters","four","cities"]},{"verseId":"brenton_joshua_21_30","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":30,"text":"And out of the tribe of Aser, Basella and its suburbs; and Dabbon and its suburbs;","searchKeywords":["and","out","the","tribe","aser","basella","its","suburbs","dabbon"]},{"verseId":"brenton_joshua_21_31","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":31,"text":"and Chelcat and its suburbs; and Raab and its suburbs; four cities.","searchKeywords":["and","chelcat","its","suburbs","raab","four","cities"]},{"verseId":"brenton_joshua_21_32","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":32,"text":"And of the tribe of Nephthali, the city set apart for the slayer, Cades in Galilee, and its suburbs; and Nemmath, and its suburbs; and Themmon and its suburbs; three cities.","searchKeywords":["and","the","tribe","nephthali","city","set","apart","for","slayer","cades","galilee","its","suburbs","nemmath","themmon","three","cities"]},{"verseId":"brenton_joshua_21_33","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":33,"text":"All the cities of Gedson according to their families thirteen cities.","searchKeywords":["all","the","cities","gedson","according","their","families","thirteen"]},{"verseId":"brenton_joshua_21_34","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":34,"text":"And to the family of the sons of Merari the Levites that remained, out of the tribe of Zabulon, Maan and its suburbs; and Cades and its suburbs,","searchKeywords":["and","the","family","sons","merari","levites","that","remained","out","tribe","zabulon","maan","its","suburbs","cades"]},{"verseId":"brenton_joshua_21_35","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":35,"text":"and Sella and its suburbs: three cities.","searchKeywords":["and","sella","its","suburbs","three","cities"]},{"verseId":"brenton_joshua_21_36","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":36,"text":"And beyond Jordan over against Jericho, out of the tribe of Ruben, the city of refuge for the slayer, Bosor in the wilderness; Miso and its suburbs; and Jazer and its suburbs;","searchKeywords":["and","beyond","jordan","over","against","jericho","out","the","tribe","ruben","city","refuge","for","slayer","bosor","wilderness","miso","its","suburbs","jazer"]},{"verseId":"brenton_joshua_21_37","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":37,"text":"and Decmon and its suburbs; and Mapha and its suburbs; four cities.","searchKeywords":["and","decmon","its","suburbs","mapha","four","cities"]},{"verseId":"brenton_joshua_21_38","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":38,"text":"And out of the tribe of Gad the city of refuge for the slayer, both Ramoth in Galaad, and its suburbs; Camin and its suburbs;","searchKeywords":["and","out","the","tribe","gad","city","refuge","for","slayer","both","ramoth","galaad","its","suburbs","camin"]},{"verseId":"brenton_joshua_21_39","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":39,"text":"and Esbon and its suburbs; and Jazer and its suburbs: the cities four in all.","searchKeywords":["and","esbon","its","suburbs","jazer","the","cities","four","all"]},{"verseId":"brenton_joshua_21_40","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":40,"text":"All cities to the sons of Merari according to the families of them that were left out of the tribe of Levi; and their limits were the twelve cities.","searchKeywords":["all","cities","the","sons","merari","according","families","them","that","were","left","out","tribe","levi","and","their","limits","twelve"]},{"verseId":"brenton_joshua_21_41","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":41,"text":"All the cities of the Levites in the midst of the possession of the children of Israel, forty-eight cities,","searchKeywords":["all","the","cities","levites","midst","possession","children","israel","forty","eight"]},{"verseId":"brenton_joshua_21_42","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":21,"verse":42,"text":"and their suburbs round about these cities: a city and the suburbs round about the city to all these cities:","searchKeywords":["and","their","suburbs","round","about","these","cities","city","the","all"]}]