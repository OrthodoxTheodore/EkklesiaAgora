verseId":"brenton_joshua_19_12","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":12,"text":"And the border returned from Sedduc in a contrary direction eastward from Bæthsamys, to the borders of Chaselothaith, and shall pass on to Dabiroth, and shall proceed upward to Phangai.","searchKeywords":["and","the","border","returned","from","sedduc","contrary","direction","eastward","thsamys","borders","chaselothaith","shall","pass","dabiroth","proceed","upward","phangai"]},{"verseId":"brenton_joshua_19_13","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":13,"text":"And thence it shall come round in the opposite direction eastward to Gebere to the city of Catasem, and shall go on to Remmonaa Matharaoza.","searchKeywords":["and","thence","shall","come","round","the","opposite","direction","eastward","gebere","city","catasem","remmonaa","matharaoza"]},{"verseId":"brenton_joshua_19_14","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":14,"text":"And the borders shall come round northward to Amoth, and their going out shall be at Gæphael,","searchKeywords":["and","the","borders","shall","come","round","northward","amoth","their","going","out","phael"]},{"verseId":"brenton_joshua_19_15","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":15,"text":"and Catanath, and Nabaal, and Symoön, and Jericho, and Bæthman.","searchKeywords":["and","catanath","nabaal","symo","jericho","thman"]},{"verseId":"brenton_joshua_19_16","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":16,"text":"This the inheritance of the tribe of the sons of Zabulon according to their families, cities and their villages.","searchKeywords":["this","the","inheritance","tribe","sons","zabulon","according","their","families","cities","and","villages"]},{"verseId":"brenton_joshua_19_17","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":17,"text":"And the fourth lot came out to Issachar.","searchKeywords":["and","the","fourth","lot","came","out","issachar"]},{"verseId":"brenton_joshua_19_18","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":18,"text":"And their borders were Jazel, and Chasaloth, and Sunam,","searchKeywords":["and","their","borders","were","jazel","chasaloth","sunam"]},{"verseId":"brenton_joshua_19_19","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":19,"text":"and Agin, and Siona, and Reeroth,","searchKeywords":["and","agin","siona","reeroth"]},{"verseId":"brenton_joshua_19_20","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":20,"text":"and Anachereth, and Dabiron, and Kison, and Rebes,","searchKeywords":["and","anachereth","dabiron","kison","rebes"]},{"verseId":"brenton_joshua_19_21","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":21,"text":"and Remmas, and Jeon, and Tomman, and Æmarec, and Bersaphes.","searchKeywords":["and","remmas","jeon","tomman","marec","bersaphes"]},{"verseId":"brenton_joshua_19_22","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":22,"text":"And the boundaries shall border upon Gæthbor, and upon Salim westward, and Bæthsamys; and the extremity of his bounds shall be Jordan.","searchKeywords":["and","the","boundaries","shall","border","upon","thbor","salim","westward","thsamys","extremity","his","bounds","jordan"]},{"verseId":"brenton_joshua_19_23","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":23,"text":"This the inheritance of the tribe of the children of Issachar according to their families, the cities and their villages.","searchKeywords":["this","the","inheritance","tribe","children","issachar","according","their","families","cities","and","villages"]},{"verseId":"brenton_joshua_19_24","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":24,"text":"And the fifth lot came out to Aser according to their families.","searchKeywords":["and","the","fifth","lot","came","out","aser","according","their","families"]},{"verseId":"brenton_joshua_19_25","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":25,"text":"And their borders were Exeleketh, and Aleph, and Bæthok, and Keaph,","searchKeywords":["and","their","borders","were","exeleketh","aleph","thok","keaph"]},{"verseId":"brenton_joshua_19_26","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":26,"text":"and Elimelech, and Amiel, and Maasa, and the lot will border on Carmel westward, and on Sion, and Labanath.","searchKeywords":["and","elimelech","amiel","maasa","the","lot","will","border","carmel","westward","sion","labanath"]},{"verseId":"brenton_joshua_19_27","translationId":"brenton","testament":"OT","bookIndex":6,"bookName":"Joshua","bookAbbrev":"joshua","chapter":19,"verse":27,"text":"And it will return westward from Bæthegeneth, and will join Zabulon and Ekgai, and Phthæel northwards, and the borders will come to Saphthæbæthme, and Inael, and will go on to Chobamasomel,","searchKeywords":["and","will","return","westward","from","thegeneth","join","zabulon","ekgai","phth","northwards","the","borders","come","saphth","thme","inael","chobamasomel"]},{"verseId":"brenton_joshua_19_28","translationId":"brenton","testame