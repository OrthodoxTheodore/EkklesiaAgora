[{"verseId":"brenton_1-samuel_8_1","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":1,"text":"And it came to pass when Samuel was old, that he made his sons judges over Israel.","searchKeywords":["and","came","pass","when","samuel","was","old","that","made","his","sons","judges","over","israel"]},{"verseId":"brenton_1-samuel_8_2","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":2,"text":"And these the names of his sons; Joel the first-born, and the name of the second Abia, judges in Bersabee.","searchKeywords":["and","these","the","names","his","sons","joel","first","born","name","second","abia","judges","bersabee"]},{"verseId":"brenton_1-samuel_8_3","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":3,"text":"And his sons did not walk in his way; and they turned aside after gain, and took gifts, and perverted judgments.","searchKeywords":["and","his","sons","did","not","walk","way","they","turned","aside","after","gain","took","gifts","perverted","judgments"]},{"verseId":"brenton_1-samuel_8_4","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":4,"text":"And the men of Israel gather themselves together, and come to Armathaim to Samuel,","searchKeywords":["and","the","men","israel","gather","themselves","together","come","armathaim","samuel"]},{"verseId":"brenton_1-samuel_8_5","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":5,"text":"and they said to him, Behold, thou art grown old, and thy sons walk not in thy way; and now set over us a king to judge us, as also the other nations .","searchKeywords":["and","they","said","him","behold","thou","art","grown","old","thy","sons","walk","not","way","now","set","over","king","judge","also","the","other","nations"]},{"verseId":"brenton_1-samuel_8_6","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":6,"text":"And the thing evil in the eyes of Samuel, when they said, Give us a king to judge us: and Samuel prayed to the Lord.","searchKeywords":["and","the","thing","evil","eyes","samuel","when","they","said","give","king","judge","prayed","lord"]},{"verseId":"brenton_1-samuel_8_7","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":7,"text":"And the Lord said to Samuel, Hear the voice of the people, in whatever they shall say to thee; for they have not rejected thee, but they have rejected me from reigning over them.","searchKeywords":["and","the","lord","said","samuel","hear","voice","people","whatever","they","shall","say","thee","for","have","not","rejected","but","from","reigning","over","them"]},{"verseId":"brenton_1-samuel_8_8","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":8,"text":"According to all their doings which they have done to me, from the day that I brought them out of Egypt until this day, even they have deserted me, and served other gods, so they do also to thee.","searchKeywords":["according","all","their","doings","which","they","have","done","from","the","day","that","brought","them","out","egypt","until","this","even","deserted","and","served","other","gods","also","thee"]},{"verseId":"brenton_1-samuel_8_9","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":9,"text":"And now hearken to their voice; only thou shalt solemnly testify to them, and thou shalt describe to them the manner of the king who shall reign over them.","searchKeywords":["and","now","hearken","their","voice","only","thou","shalt","solemnly","testify","them","describe","the","manner","king","who","shall","reign","over"]},{"verseId":"brenton_1-samuel_8_10","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":10,"text":"And Samuel spoke every word of the Lord to the people who asked of him a king.","searchKeywords":["and","samuel","spoke","every","word","the","lord","people","who","asked","him","king"]},{"verseId":"brenton_1-samuel_8_11","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":11,"text":"And he said, This shall be the manner of the king that shall rule over you: he shall take your sons, and put them in his chariots, and among his horsemen, and running before his chariots,","searchKeywords":["and","said","this","shall","the","manner","king","that","rule","over","you","take","your","sons","put","them","his","chariots","among","horsemen","running","before"]},{"verseId":"brenton_1-samuel_8_12","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":12,"text":"and to make them to himself captains of hundreds and captains of thousands; and to reap his harvest, and gather his vintage, and prepare his instruments of war, and the implements of his chariots.","searchKeywords":["and","make","them","himself","captains","hundreds","thousands","reap","his","harvest","gather","vintage","prepare","instruments","war","the","implements","chariots"]},{"verseId":"brenton_1-samuel_8_13","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":13,"text":"And he will take your daughters to be perfumers, and cooks, and bakers.","searchKeywords":["and","will","take","your","daughters","perfumers","cooks","bakers"]},{"verseId":"brenton_1-samuel_8_14","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":14,"text":"And he will take your fields, and your vineyards, and your good oliveyards, and give them to his servants.","searchKeywords":["and","will","take","your","fields","vineyards","good","oliveyards","give","them","his","servants"]},{"verseId":"brenton_1-samuel_8_15","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":15,"text":"And he will take the tithe of your seeds and your vineyards, and give to his eunuchs, and to his servants.","searchKeywords":["and","will","take","the","tithe","your","seeds","vineyards","give","his","eunuchs","servants"]},{"verseId":"brenton_1-samuel_8_16","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":16,"text":"And he will take your servants, and your handmaids, and your good herds and your asses, and will take the tenth of them for his works.","searchKeywords":["and","will","take","your","servants","handmaids","good","herds","asses","the","tenth","them","for","his","works"]},{"verseId":"brenton_1-samuel_8_17","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":17,"text":"And he will tithe your flocks; and ye shall be his servants.","searchKeywords":["and","will","tithe","your","flocks","shall","his","servants"]},{"verseId":"brenton_1-samuel_8_18","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":18,"text":"And ye shall cry out in that day because of your king whom ye have chosen to yourselves, and the Lord shall not hear you in those days, because ye have chosen to yourselves a king.","searchKeywords":["and","shall","cry","out","that","day","because","your","king","whom","have","chosen","yourselves","the","lord","not","hear","you","those","days"]},{"verseId":"brenton_1-samuel_8_19","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":19,"text":"But the people would not hearken to Samuel; and they said to him, Nay, but there shall be a king over us.","searchKeywords":["but","the","people","would","not","hearken","samuel","and","they","said","him","nay","there","shall","king","over"]},{"verseId":"brenton_1-samuel_8_20","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":20,"text":"And we also will be like all the nations; and our king shall judge us, and shall go out before us, and fight our battles.","searchKeywords":["and","also","will","like","all","the","nations","our","king","shall","judge","out","before","fight","battles"]},{"verseId":"brenton_1-samuel_8_21","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":21,"text":"And Samuel heard all the words of the people, and spoke them in the ears of the Lord.","searchKeywords":["and","samuel","heard","all","the","words","people","spoke","them","ears","lord"]},{"verseId":"brenton_1-samuel_8_22","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":8,"verse":22,"text":"And the Lord said to Samuel, Hearken to their voice, and appoint them a king. And Samuel said to the men of Israel, Let each man depart to his city.","searchKeywords":["and","the","lord","said","samuel","hearken","their","voice","appoint","them","king","men","israel","let","each","man","depart","his","city"]}]