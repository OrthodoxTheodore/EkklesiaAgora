[{"verseId":"brenton_1-samuel_18_6","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":6,"text":"And there came out women in dances to meet David out of all the cities of Israel, with timbrels, and with rejoicing, and with cymbals.","searchKeywords":["and","there","came","out","women","dances","meet","david","all","the","cities","israel","with","timbrels","rejoicing","cymbals"]},{"verseId":"brenton_1-samuel_18_7","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":7,"text":"And the women began , and said, Saul has smitten his thousands, and David his ten thousands.","searchKeywords":["and","the","women","began","said","saul","has","smitten","his","thousands","david","ten"]},{"verseId":"brenton_1-samuel_18_8","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":8,"text":"And it seemed evil in the eyes of Saul concerning this matter, and he said, To David they have given ten thousands, and to me they have given thousands.","searchKeywords":["and","seemed","evil","the","eyes","saul","concerning","this","matter","said","david","they","have","given","ten","thousands"]},{"verseId":"brenton_1-samuel_18_12","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":12,"text":"And Saul was alarmed on account of David.","searchKeywords":["and","saul","was","alarmed","account","david"]},{"verseId":"brenton_1-samuel_18_13","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":13,"text":"And he removed him from him, and made him a captain of a thousand for himself; and he went out and came in before the people.","searchKeywords":["and","removed","him","from","made","captain","thousand","for","himself","went","out","came","before","the","people"]},{"verseId":"brenton_1-samuel_18_14","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":14,"text":"And David was prudent in all his ways, and the Lord was with him.","searchKeywords":["and","david","was","prudent","all","his","ways","the","lord","with","him"]},{"verseId":"brenton_1-samuel_18_15","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":15,"text":"And Saul saw that he was very wise, and he was afraid of him.","searchKeywords":["and","saul","saw","that","was","very","wise","afraid","him"]},{"verseId":"brenton_1-samuel_18_16","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":16,"text":"And all Israel and Juda loved David, because he came in and went out before the people.","searchKeywords":["and","all","israel","juda","loved","david","because","came","went","out","before","the","people"]},{"verseId":"brenton_1-samuel_18_20","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":20,"text":"And Melchol the daughter of Saul loved David; and it was told Saul, and the thing was pleasing in his eyes.","searchKeywords":["and","melchol","the","daughter","saul","loved","david","was","told","thing","pleasing","his","eyes"]},{"verseId":"brenton_1-samuel_18_21","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":21,"text":"And Saul said, I will give her to him, and she shall be a stumbling-block to him. Now the hand of the Philistines was against Saul.","searchKeywords":["and","saul","said","will","give","her","him","she","shall","stumbling","block","now","the","hand","philistines","was","against"]},{"verseId":"brenton_1-samuel_18_22","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":22,"text":"And Saul charged his servants, saying, Speak ye privately to David, saying, Behold, the king delights in thee, and all his servants love thee, and do thou become the king's son-in-law.","searchKeywords":["and","saul","charged","his","servants","saying","speak","privately","david","behold","the","king","delights","thee","all","love","thou","become","son","law"]},{"verseId":"brenton_1-samuel_18_23","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":23,"text":"And the servants of Saul spoke these words in the ears of David; and David said, a light thing in your eyes to become son-in-law to the king? whereas I an humble man, and not honourable?","searchKeywords":["and","the","servants","saul","spoke","these","words","ears","david","said","light","thing","your","eyes","become","son","law","king","whereas","humble","man","not","honourable"]},{"verseId":"brenton_1-samuel_18_24","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":24,"text":"And the servants of Saul reported to him according to these words, which David spoke.","searchKeywords":["and","the","servants","saul","reported","him","according","these","words","which","david","spoke"]},{"verseId":"brenton_1-samuel_18_25","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":25,"text":"And Saul said, Thus shall ye speak to David, The king wants no gift but a hundred foreskins of the Philistines, to avenge himself on the king's enemies. Now Saul thought to cast him into the hands of the Philistines.","searchKeywords":["and","saul","said","thus","shall","speak","david","the","king","wants","gift","but","hundred","foreskins","philistines","avenge","himself","enemies","now","thought","cast","him","into","hands"]},{"verseId":"brenton_1-samuel_18_26","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":26,"text":"And the servants of Saul report these words to David, and David was well pleased to become the son-in-law to the king.","searchKeywords":["and","the","servants","saul","report","these","words","david","was","well","pleased","become","son","law","king"]},{"verseId":"brenton_1-samuel_18_27","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":27,"text":"And David arose, and went, he and his men, and smote among the Philistines a hundred men: and he brought their foreskins, and he becomes the king's son-in-law, and gives him Melchol his daughter to wife.","searchKeywords":["and","david","arose","went","his","men","smote","among","the","philistines","hundred","brought","their","foreskins","becomes","king","son","law","gives","him","melchol","daughter","wife"]},{"verseId":"brenton_1-samuel_18_28","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":28,"text":"And Saul saw that the Lord with David, and all Israel loved him.","searchKeywords":["and","saul","saw","that","the","lord","with","david","all","israel","loved","him"]},{"verseId":"brenton_1-samuel_18_29","translationId":"brenton","testament":"OT","bookIndex":9,"bookName":"1 Samuel","bookAbbrev":"1-samuel","chapter":18,"verse":29,"text":"And he was yet more afraid of David.","searchKeywords":["and","was","yet","more","afraid","david"]}]