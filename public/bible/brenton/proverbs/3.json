[{"verseId":"brenton_proverbs_3_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":1,"text":"son, forget not my laws; but let thine heart keep my words:","searchKeywords":["son","forget","not","laws","but","let","thine","heart","keep","words"]},{"verseId":"brenton_proverbs_3_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":2,"text":"for length of existence, and years of life, and peace, shall they add to thee.","searchKeywords":["for","length","existence","and","years","life","peace","shall","they","add","thee"]},{"verseId":"brenton_proverbs_3_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":3,"text":"Let not mercy and truth forsake thee; but bind them about thy neck:","searchKeywords":["let","not","mercy","and","truth","forsake","thee","but","bind","them","about","thy","neck"]},{"verseId":"brenton_proverbs_3_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":4,"text":"so shalt thou find favour: and do thou provide things honest in the sight of the Lord, and of men.","searchKeywords":["shalt","thou","find","favour","and","provide","things","honest","the","sight","lord","men"]},{"verseId":"brenton_proverbs_3_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":5,"text":"Trust in God with all thine heart; and be not exalted in thine own wisdom.","searchKeywords":["trust","god","with","all","thine","heart","and","not","exalted","own","wisdom"]},{"verseId":"brenton_proverbs_3_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":6,"text":"In all thy ways acquaint thyself with her, that she may rightly direct thy paths.","searchKeywords":["all","thy","ways","acquaint","thyself","with","her","that","she","may","rightly","direct","paths"]},{"verseId":"brenton_proverbs_3_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":7,"text":"Be not wise in thine own conceit; but fear God, and depart from all evil.","searchKeywords":["not","wise","thine","own","conceit","but","fear","god","and","depart","from","all","evil"]},{"verseId":"brenton_proverbs_3_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":8,"text":"Then shall there be health to thy body, and good keeping to thy bones.","searchKeywords":["then","shall","there","health","thy","body","and","good","keeping","bones"]},{"verseId":"brenton_proverbs_3_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":9,"text":"Honour the Lord with thy just labours, and give him the first of thy fruits of righteousness:","searchKeywords":["honour","the","lord","with","thy","just","labours","and","give","him","first","fruits","righteousness"]},{"verseId":"brenton_proverbs_3_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":10,"text":"that thy storehouses may be completely filled with corn, and that thy presses may burst forth with wine.","searchKeywords":["that","thy","storehouses","may","completely","filled","with","corn","and","presses","burst","forth","wine"]},{"verseId":"brenton_proverbs_3_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":11,"text":"son, despise not the chastening of the Lord; nor faint when thou art rebuked of him:","searchKeywords":["son","despise","not","the","chastening","lord","nor","faint","when","thou","art","rebuked","him"]},{"verseId":"brenton_proverbs_3_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":12,"text":"for whom the Lord loves, he rebukes, and scourges every son whom he receives.","searchKeywords":["for","whom","the","lord","loves","rebukes","and","scourges","every","son","receives"]},{"verseId":"brenton_proverbs_3_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":13,"text":"Blessed is the man who has found wisdom, and the mortal who knows prudence.","searchKeywords":["blessed","the","man","who","has","found","wisdom","and","mortal","knows","prudence"]},{"verseId":"brenton_proverbs_3_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":14,"text":"For it is better to traffic for her, than for treasures of gold and silver.","searchKeywords":["for","better","traffic","her","than","treasures","gold","and","silver"]},{"verseId":"brenton_proverbs_3_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":15,"text":"And she is more valuable than precious stones: no evil thing shall resist her: she is well known to all that approach her, and no precious thing is equal to her in value.","searchKeywords":["and","she","more","valuable","than","precious","stones","evil","thing","shall","resist","her","well","known","all","that","approach","equal","value"]},{"verseId":"brenton_proverbs_3_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":16,"text":"For length of existence and years of life are in her right hand; and in her left hand are wealth and glory:","searchKeywords":["for","length","existence","and","years","life","are","her","right","hand","left","wealth","glory"]},{"verseId":"brenton_proverbs_3_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":18,"text":"secure to all that stay themselves on her, as on the Lord.","searchKeywords":["secure","all","that","stay","themselves","her","the","lord"]},{"verseId":"brenton_proverbs_3_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":21,"text":"son, let not pass from , but keep my counsel and understanding:","searchKeywords":["son","let","not","pass","from","but","keep","counsel","and","understanding"]},{"verseId":"brenton_proverbs_3_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":24,"text":"rest, thou shalt be undismayed; and if thou sleep, thou shalt slumber sweetly.","searchKeywords":["rest","thou","shalt","undismayed","and","sleep","slumber","sweetly"]},{"verseId":"brenton_proverbs_3_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":27,"text":"to help .","searchKeywords":["help"]},{"verseId":"brenton_proverbs_3_28","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":28,"text":"good: for thou knowest not what the next day will bring forth.","searchKeywords":["good","for","thou","knowest","not","what","the","next","day","will","bring","forth"]},{"verseId":"brenton_proverbs_3_34","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":34,"text":"The Lord resists the proud; but he gives grace to the humble.","searchKeywords":["the","lord","resists","proud","but","gives","grace","humble"]},{"verseId":"brenton_proverbs_3_35","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":3,"verse":35,"text":"dishonour.","searchKeywords":["dishonour"]}]