[{"verseId":"brenton_proverbs_12_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":1,"text":"He that loves instruction loves sense, but he that hates reproofs is a fool.","searchKeywords":["that","loves","instruction","sense","but","hates","reproofs","fool"]},{"verseId":"brenton_proverbs_12_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":2,"text":"He that has found favour with the Lord better; but a transgressor shall be passed over in silence.","searchKeywords":["that","has","found","favour","with","the","lord","better","but","transgressor","shall","passed","over","silence"]},{"verseId":"brenton_proverbs_12_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":3,"text":"A man shall not prosper by wickedness; but the roots of the righteous shall not be taken up.","searchKeywords":["man","shall","not","prosper","wickedness","but","the","roots","righteous","taken"]},{"verseId":"brenton_proverbs_12_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":4,"text":"A virtuous woman is a crown to her husband; but as a worm in wood, so a bad woman destroys her husband.","searchKeywords":["virtuous","woman","crown","her","husband","but","worm","wood","bad","destroys"]},{"verseId":"brenton_proverbs_12_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":5,"text":"The thoughts of the righteous judgments; but ungodly men devise deceits.","searchKeywords":["the","thoughts","righteous","judgments","but","ungodly","men","devise","deceits"]},{"verseId":"brenton_proverbs_12_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":6,"text":"The words of ungodly men are crafty; but the mouth of the upright shall deliver them.","searchKeywords":["the","words","ungodly","men","are","crafty","but","mouth","upright","shall","deliver","them"]},{"verseId":"brenton_proverbs_12_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":7,"text":"When the ungodly is overthrown, he vanishes away; but the houses of the just remain.","searchKeywords":["when","the","ungodly","overthrown","vanishes","away","but","houses","just","remain"]},{"verseId":"brenton_proverbs_12_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":8,"text":"The mouth of an understanding is praised by a man; but he that is dull of heart is had in derision.","searchKeywords":["the","mouth","understanding","praised","man","but","that","dull","heart","had","derision"]},{"verseId":"brenton_proverbs_12_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":9,"text":"Better is a man in dishonour serving himself, than one honouring himself and wanting bread.","searchKeywords":["better","man","dishonour","serving","himself","than","one","honouring","and","wanting","bread"]},{"verseId":"brenton_proverbs_12_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":10,"text":"A righteous man has pity for the lives of his cattle; but the bowels of the ungodly are unmerciful.","searchKeywords":["righteous","man","has","pity","for","the","lives","his","cattle","but","bowels","ungodly","are","unmerciful"]},{"verseId":"brenton_proverbs_12_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":11,"text":"He that tills his own land shall be satisfied with bread; but they that pursue vanities are void of understanding.","searchKeywords":["that","tills","his","own","land","shall","satisfied","with","bread","but","they","pursue","vanities","are","void","understanding"]},{"verseId":"brenton_proverbs_12_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":13,"text":"lips a sinner falls into snares; but a righteous man escapes from them.","searchKeywords":["lips","sinner","falls","into","snares","but","righteous","man","escapes","from","them"]},{"verseId":"brenton_proverbs_12_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":18,"text":"swords; but the tongues of the wise heal.","searchKeywords":["swords","but","the","tongues","wise","heal"]},{"verseId":"brenton_proverbs_12_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":20,"text":"deceit in the heart of him that imagines evil; but they that love peace shall rejoice.","searchKeywords":["deceit","the","heart","him","that","imagines","evil","but","they","love","peace","shall","rejoice"]},{"verseId":"brenton_proverbs_12_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":27,"text":"blameless man is a precious possession.","searchKeywords":["blameless","man","precious","possession"]},{"verseId":"brenton_proverbs_12_28","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":12,"verse":28,"text":"to death.","searchKeywords":["death"]}]