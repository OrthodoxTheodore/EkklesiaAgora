[{"verseId":"brenton_proverbs_22_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":1,"text":"A fair name is better than much wealth, and good favour is above silver and gold.","searchKeywords":["fair","name","better","than","much","wealth","and","good","favour","above","silver","gold"]},{"verseId":"brenton_proverbs_22_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":2,"text":"The rich and the poor meet together; but the Lord made them both.","searchKeywords":["the","rich","and","poor","meet","together","but","lord","made","them","both"]},{"verseId":"brenton_proverbs_22_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":3,"text":"An intelligent man seeing a bad man severely punished is himself instructed, but fools pass by and are punished.","searchKeywords":["intelligent","man","seeing","bad","severely","punished","himself","instructed","but","fools","pass","and","are"]},{"verseId":"brenton_proverbs_22_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":4,"text":"The fear of the Lord is the offspring of wisdom, and wealth, and glory, and life.","searchKeywords":["the","fear","lord","offspring","wisdom","and","wealth","glory","life"]},{"verseId":"brenton_proverbs_22_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":5,"text":"Thistles and snares are in perverse ways; but he that keeps his soul will refrain from them.","searchKeywords":["thistles","and","snares","are","perverse","ways","but","that","keeps","his","soul","will","refrain","from","them"]},{"verseId":"brenton_proverbs_22_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":7,"text":"The rich will rule over the poor, and servants will lend to their own masters.","searchKeywords":["the","rich","will","rule","over","poor","and","servants","lend","their","own","masters"]},{"verseId":"brenton_proverbs_22_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":8,"text":"He that sows wickedness shall reap troubles; and shall fully receive the punishment of his deeds. God loves a cheerful and liberal man; but shall fully prove the folly of his works.","searchKeywords":["that","sows","wickedness","shall","reap","troubles","and","fully","receive","the","punishment","his","deeds","god","loves","cheerful","liberal","man","but","prove","folly","works"]},{"verseId":"brenton_proverbs_22_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":9,"text":".","searchKeywords":[]},{"verseId":"brenton_proverbs_22_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":12,"text":"words.","searchKeywords":["words"]},{"verseId":"brenton_proverbs_22_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":13,"text":"a lion in the ways, and murderers in the streets.","searchKeywords":["lion","the","ways","and","murderers","streets"]},{"verseId":"brenton_proverbs_22_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":15,"text":"far from him.","searchKeywords":["far","from","him"]},{"verseId":"brenton_proverbs_22_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":21,"text":"question thee.","searchKeywords":["question","thee"]},{"verseId":"brenton_proverbs_22_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":22,"text":"in the gates.","searchKeywords":["the","gates"]},{"verseId":"brenton_proverbs_22_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":27,"text":"under thee.","searchKeywords":["under","thee"]},{"verseId":"brenton_proverbs_22_28","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":28,"text":"landmarks, which thy fathers placed.","searchKeywords":["landmarks","which","thy","fathers","placed"]},{"verseId":"brenton_proverbs_22_29","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":22,"verse":29,"text":"diligent in his business should attend on kings, and not attend on slothful men.","searchKeywords":["diligent","his","business","should","attend","kings","and","not","slothful","men"]}]