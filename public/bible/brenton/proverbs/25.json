[{"verseId":"brenton_proverbs_25_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":1,"text":"These are the miscellaneous instructions of Solomon, which the friends of Ezekias king of Judea copied out.","searchKeywords":["these","are","the","miscellaneous","instructions","solomon","which","friends","ezekias","king","judea","copied","out"]},{"verseId":"brenton_proverbs_25_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":2,"text":"The glory of God conceals a matter: but the glory of a king honours business.","searchKeywords":["the","glory","god","conceals","matter","but","king","honours","business"]},{"verseId":"brenton_proverbs_25_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":3,"text":"Heaven is high, and earth is deep, and a king's heart is unsearchable.","searchKeywords":["heaven","high","and","earth","deep","king","heart","unsearchable"]},{"verseId":"brenton_proverbs_25_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":4,"text":"Beat the drossy silver, and it shall be made entirely pure.","searchKeywords":["beat","the","drossy","silver","and","shall","made","entirely","pure"]},{"verseId":"brenton_proverbs_25_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":5,"text":"Slay the ungodly from before the king, and his throne shall prosper in righteousness.","searchKeywords":["slay","the","ungodly","from","before","king","and","his","throne","shall","prosper","righteousness"]},{"verseId":"brenton_proverbs_25_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":6,"text":"Be not boastful in the presence of the king, and remain not in the places of princes;","searchKeywords":["not","boastful","the","presence","king","and","remain","places","princes"]},{"verseId":"brenton_proverbs_25_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":7,"text":"for better for thee that it should be said, Come up to me, than that should humble thee in the presence of the prince; speak of that which thine eyes have seen.","searchKeywords":["for","better","thee","that","should","said","come","than","humble","the","presence","prince","speak","which","thine","eyes","have","seen"]},{"verseId":"brenton_proverbs_25_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":8,"text":"Get not suddenly into a quarrel, lest thou repent at last.","searchKeywords":["get","not","suddenly","into","quarrel","lest","thou","repent","last"]},{"verseId":"brenton_proverbs_25_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":9,"text":"Whenever thy friend shall reproach thee, retreat backward, despise not;","searchKeywords":["whenever","thy","friend","shall","reproach","thee","retreat","backward","despise","not"]},{"verseId":"brenton_proverbs_25_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":10,"text":"lest thy friend continue to reproach thee, so thy quarrel and enmity shall not depart, but shall be to thee like death. free, which do thou keep for thyself, lest thou be made liable to reproach; but take heed to thy ways peaceably.","searchKeywords":["lest","thy","friend","continue","reproach","thee","quarrel","and","enmity","shall","not","depart","but","like","death","free","which","thou","keep","for","thyself","made","liable","take","heed","ways","peaceably"]},{"verseId":"brenton_proverbs_25_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":11,"text":"a golden apple in a necklace of sardius, so to speak a word.","searchKeywords":["golden","apple","necklace","sardius","speak","word"]},{"verseId":"brenton_proverbs_25_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":12,"text":"a wise word to an obedient ear.","searchKeywords":["wise","word","obedient","ear"]},{"verseId":"brenton_proverbs_25_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":13,"text":"those that send him; for he helps the souls of his employers.","searchKeywords":["those","that","send","him","for","helps","the","souls","his","employers"]},{"verseId":"brenton_proverbs_25_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":14,"text":", so is he that boasts of a false gift.","searchKeywords":["that","boasts","false","gift"]},{"verseId":"brenton_proverbs_25_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":16,"text":"what is enough, lest haply thou be filled, and vomit it up.","searchKeywords":["what","enough","lest","haply","thou","filled","and","vomit"]},{"verseId":"brenton_proverbs_25_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":18,"text":"a club, and a dagger, and a pointed arrow, so also is a man who bears false witness against his friend.","searchKeywords":["club","and","dagger","pointed","arrow","also","man","who","bears","false","witness","against","his","friend"]},{"verseId":"brenton_proverbs_25_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":22,"text":"good.","searchKeywords":["good"]},{"verseId":"brenton_proverbs_25_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":24,"text":"better to dwell on a corner of the roof, than with a railing woman in an open house.","searchKeywords":["better","dwell","corner","the","roof","than","with","railing","woman","open","house"]},{"verseId":"brenton_proverbs_25_26","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":26,"text":"unseemly for a righteous man to fall before an ungodly man.","searchKeywords":["unseemly","for","righteous","man","fall","before","ungodly"]},{"verseId":"brenton_proverbs_25_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":25,"verse":27,"text":"not good to eat much honey; but it is right to honour venerable sayings.","searchKeywords":["not","good","eat","much","honey","but","right","honour","venerable","sayings"]}]