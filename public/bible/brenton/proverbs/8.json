[{"verseId":"brenton_proverbs_8_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":1,"text":"Thou shalt proclaim wisdom, that understanding may be obedient to thee.","searchKeywords":["thou","shalt","proclaim","wisdom","that","understanding","may","obedient","thee"]},{"verseId":"brenton_proverbs_8_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":2,"text":"For she is on lofty eminences, and stands in the midst of the ways.","searchKeywords":["for","she","lofty","eminences","and","stands","the","midst","ways"]},{"verseId":"brenton_proverbs_8_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":3,"text":"For she sits by the gates of princes, and sings in the entrances, ,","searchKeywords":["for","she","sits","the","gates","princes","and","sings","entrances"]},{"verseId":"brenton_proverbs_8_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":4,"text":"You, O men, I exhort; and utter my voice to the sons of men.","searchKeywords":["you","men","exhort","and","utter","voice","the","sons"]},{"verseId":"brenton_proverbs_8_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":5,"text":"O ye simple, understand subtlety, and ye that are untaught, imbibe knowledge.","searchKeywords":["simple","understand","subtlety","and","that","are","untaught","imbibe","knowledge"]},{"verseId":"brenton_proverbs_8_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":6,"text":"Hearken to me; for I will speak solemn ; and will produce right from my lips.","searchKeywords":["hearken","for","will","speak","solemn","and","produce","right","from","lips"]},{"verseId":"brenton_proverbs_8_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":7,"text":"For my throat shall meditate truth; and false lips are an abomination before me.","searchKeywords":["for","throat","shall","meditate","truth","and","false","lips","are","abomination","before"]},{"verseId":"brenton_proverbs_8_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":8,"text":"All the words of my mouth are in righteousness; there is nothing in them wrong or perverse.","searchKeywords":["all","the","words","mouth","are","righteousness","there","nothing","them","wrong","perverse"]},{"verseId":"brenton_proverbs_8_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":9,"text":"They are all evident to those that understand, and right to those that find knowledge.","searchKeywords":["they","are","all","evident","those","that","understand","and","right","find","knowledge"]},{"verseId":"brenton_proverbs_8_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":10,"text":"Receive instruction, and not silver; and knowledge rather than tried gold.","searchKeywords":["receive","instruction","and","not","silver","knowledge","rather","than","tried","gold"]},{"verseId":"brenton_proverbs_8_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":11,"text":"For wisdom is better than precious stones; and no valuable substance is of equal worth with it.","searchKeywords":["for","wisdom","better","than","precious","stones","and","valuable","substance","equal","worth","with"]},{"verseId":"brenton_proverbs_8_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":12,"text":"I wisdom have dwelt counsel and knowledge, and I have called upon understanding.","searchKeywords":["wisdom","have","dwelt","counsel","and","knowledge","called","upon","understanding"]},{"verseId":"brenton_proverbs_8_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":13,"text":"The fear of the Lord hates unrighteousness, and insolence, and pride, and the ways of wicked men; and I hate the perverse ways of bad men.","searchKeywords":["the","fear","lord","hates","unrighteousness","and","insolence","pride","ways","wicked","men","hate","perverse","bad"]},{"verseId":"brenton_proverbs_8_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":14,"text":"Counsel and safety are mine: prudence is mine, and strength is mine.","searchKeywords":["counsel","and","safety","are","mine","prudence","strength"]},{"verseId":"brenton_proverbs_8_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":15,"text":"By me kings reign, and princes decree justice.","searchKeywords":["kings","reign","and","princes","decree","justice"]},{"verseId":"brenton_proverbs_8_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":16,"text":"By me nobles become great, and monarchs by me rule over the earth.","searchKeywords":["nobles","become","great","and","monarchs","rule","over","the","earth"]},{"verseId":"brenton_proverbs_8_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":17,"text":"I love those that love me; and they that seek me shall find .","searchKeywords":["love","those","that","and","they","seek","shall","find"]},{"verseId":"brenton_proverbs_8_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":18,"text":"Wealth and glory belong to me; yea, abundant possessions and righteousness.","searchKeywords":["wealth","and","glory","belong","yea","abundant","possessions","righteousness"]},{"verseId":"brenton_proverbs_8_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":19,"text":"better to have my fruit than gold and precious stones; and my produce is better than choice silver.","searchKeywords":["better","have","fruit","than","gold","and","precious","stones","produce","choice","silver"]},{"verseId":"brenton_proverbs_8_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":20,"text":"I walk in ways of righteousness, and conversant with the paths of judgment;","searchKeywords":["walk","ways","righteousness","and","conversant","with","the","paths","judgment"]},{"verseId":"brenton_proverbs_8_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":21,"text":"that I may divide substance to them that love me, and may fill their treasures with good things. to recount the things of old.","searchKeywords":["that","may","divide","substance","them","love","and","fill","their","treasures","with","good","things","recount","the","old"]},{"verseId":"brenton_proverbs_8_23","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":23,"text":"before time in the beginning, before he made the earth:","searchKeywords":["before","time","the","beginning","made","earth"]},{"verseId":"brenton_proverbs_8_26","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":26,"text":", and the highest inhabited parts of the world.","searchKeywords":["and","the","highest","inhabited","parts","world"]},{"verseId":"brenton_proverbs_8_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":27,"text":"prepared his throne upon the winds:","searchKeywords":["prepared","his","throne","upon","the","winds"]},{"verseId":"brenton_proverbs_8_29","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":29,"text":"and when he strengthened the foundations of the earth:","searchKeywords":["and","when","strengthened","the","foundations","earth"]},{"verseId":"brenton_proverbs_8_30","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":30,"text":"suiting , I was that wherein he took delight; and daily I rejoiced in his presence continually.","searchKeywords":["suiting","was","that","wherein","took","delight","and","daily","rejoiced","his","presence","continually"]},{"verseId":"brenton_proverbs_8_32","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":32,"text":"son, hear me: blessed is the man who shall hearken to me, and the mortal who shall keep my ways;","searchKeywords":["son","hear","blessed","the","man","who","shall","hearken","and","mortal","keep","ways"]},{"verseId":"brenton_proverbs_8_35","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":8,"verse":35,"text":"is prepared favour from the Lord.","searchKeywords":["prepared","favour","from","the","lord"]}]