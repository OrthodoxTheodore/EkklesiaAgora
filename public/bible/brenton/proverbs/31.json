[{"verseId":"brenton_proverbs_31_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":10,"text":"Who shall find a virtuous woman? for such a one is more valuable than precious stones.","searchKeywords":["who","shall","find","virtuous","woman","for","such","one","more","valuable","than","precious","stones"]},{"verseId":"brenton_proverbs_31_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":11,"text":"The heart of her husband trusts in her: such a one shall stand in no need of fine spoils.","searchKeywords":["the","heart","her","husband","trusts","such","one","shall","stand","need","fine","spoils"]},{"verseId":"brenton_proverbs_31_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":12,"text":"For she employs all her living for her husband's good.","searchKeywords":["for","she","employs","all","her","living","husband","good"]},{"verseId":"brenton_proverbs_31_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":13,"text":"Gathering wool and flax, she makes it serviceable with her hands.","searchKeywords":["gathering","wool","and","flax","she","makes","serviceable","with","her","hands"]},{"verseId":"brenton_proverbs_31_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":14,"text":"She is like a ship trading from a distance: so she procures her livelihood.","searchKeywords":["she","like","ship","trading","from","distance","procures","her","livelihood"]},{"verseId":"brenton_proverbs_31_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":15,"text":"And she rises by night, and gives food to her household, and tasks to her maidens.","searchKeywords":["and","she","rises","night","gives","food","her","household","tasks","maidens"]},{"verseId":"brenton_proverbs_31_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":16,"text":"She views a farm, and buys it: and with the fruit of her hands she plants a possession.","searchKeywords":["she","views","farm","and","buys","with","the","fruit","her","hands","plants","possession"]},{"verseId":"brenton_proverbs_31_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":17,"text":"She strongly girds her loins, and strengthens her arms for work.","searchKeywords":["she","strongly","girds","her","loins","and","strengthens","arms","for","work"]},{"verseId":"brenton_proverbs_31_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":18,"text":"And she finds by experience that working is good; and her candle goes not out all night.","searchKeywords":["and","she","finds","experience","that","working","good","her","candle","goes","not","out","all","night"]},{"verseId":"brenton_proverbs_31_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":19,"text":"She reaches forth her arms to needful , and applies her hands to the spindle.","searchKeywords":["she","reaches","forth","her","arms","needful","and","applies","hands","the","spindle"]},{"verseId":"brenton_proverbs_31_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":20,"text":"And she opens her hands to the needy, and reaches out fruit to the poor.","searchKeywords":["and","she","opens","her","hands","the","needy","reaches","out","fruit","poor"]},{"verseId":"brenton_proverbs_31_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":21,"text":"Her husband is not anxious about those at home when he tarries anywhere abroad: for all her household are clothed.","searchKeywords":["her","husband","not","anxious","about","those","home","when","tarries","anywhere","abroad","for","all","household","are","clothed"]},{"verseId":"brenton_proverbs_31_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":22,"text":"She makes for her husband clothes of double texture, and garments for herself of fine linen and scarlet.","searchKeywords":["she","makes","for","her","husband","clothes","double","texture","and","garments","herself","fine","linen","scarlet"]},{"verseId":"brenton_proverbs_31_23","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":23,"text":"And her husband becomes a distinguished in the gates, when he sits in council with the old inhabitants of the land.","searchKeywords":["and","her","husband","becomes","distinguished","the","gates","when","sits","council","with","old","inhabitants","land"]},{"verseId":"brenton_proverbs_31_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":24,"text":"She makes fine linens, and sells girdles to the Chananites: she opens her mouth heedfully and with propriety, and controls her tongue.","searchKeywords":["she","makes","fine","linens","and","sells","girdles","the","chananites","opens","her","mouth","heedfully","with","propriety","controls","tongue"]},{"verseId":"brenton_proverbs_31_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":25,"text":"She puts on strength and honour; and rejoices in the last days.","searchKeywords":["she","puts","strength","and","honour","rejoices","the","last","days"]},{"verseId":"brenton_proverbs_31_26","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":26,"text":"The ways of her household are careful, and she eats not the bread of idleness.","searchKeywords":["the","ways","her","household","are","careful","and","she","eats","not","bread","idleness"]},{"verseId":"brenton_proverbs_31_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":27,"text":"But she opens her mouth wisely, and according to law.","searchKeywords":["but","she","opens","her","mouth","wisely","and","according","law"]},{"verseId":"brenton_proverbs_31_28","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":28,"text":"And kindness to them sets up her children for them, and they grow rich, and her husband praises her.","searchKeywords":["and","kindness","them","sets","her","children","for","they","grow","rich","husband","praises"]},{"verseId":"brenton_proverbs_31_29","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":29,"text":"Many daughters have obtained wealth, many have wrought valiantly; but thou hast exceeded, thou hast surpassed all.","searchKeywords":["many","daughters","have","obtained","wealth","wrought","valiantly","but","thou","hast","exceeded","surpassed","all"]},{"verseId":"brenton_proverbs_31_30","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":30,"text":"Charms are false, and woman's beauty is vain: for it is a wise woman that is blessed, and let her praise the fear of the Lord.","searchKeywords":["charms","are","false","and","woman","beauty","vain","for","wise","that","blessed","let","her","praise","the","fear","lord"]},{"verseId":"brenton_proverbs_31_31","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":31,"verse":31,"text":"Give her of the fruit of her lips; and let her husband be praised in the gates.","searchKeywords":["give","her","the","fruit","lips","and","let","husband","praised","gates"]}]