[{"verseId":"brenton_proverbs_2_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":1,"text":"son, if thou wilt receive the utterance of my commandment, and hide it with thee;","searchKeywords":["son","thou","wilt","receive","the","utterance","commandment","and","hide","with","thee"]},{"verseId":"brenton_proverbs_2_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":2,"text":"thine ear shall hearken to wisdom; thou shalt also apply thine heart to understanding, and shalt apply it to the instruction of thy son.","searchKeywords":["thine","ear","shall","hearken","wisdom","thou","shalt","also","apply","heart","understanding","and","the","instruction","thy","son"]},{"verseId":"brenton_proverbs_2_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":3,"text":"For if thou shalt call to wisdom, and utter thy voice for understanding;","searchKeywords":["for","thou","shalt","call","wisdom","and","utter","thy","voice","understanding"]},{"verseId":"brenton_proverbs_2_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":4,"text":"and if thou shalt seek it as silver, and search diligently for it as for treasures;","searchKeywords":["and","thou","shalt","seek","silver","search","diligently","for","treasures"]},{"verseId":"brenton_proverbs_2_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":5,"text":"then shalt thou understand the fear of the Lord, and find the knowledge of God.","searchKeywords":["then","shalt","thou","understand","the","fear","lord","and","find","knowledge","god"]},{"verseId":"brenton_proverbs_2_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":6,"text":"For the Lord gives wisdom; and from his presence knowledge and understanding,","searchKeywords":["for","the","lord","gives","wisdom","and","from","his","presence","knowledge","understanding"]},{"verseId":"brenton_proverbs_2_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":7,"text":"and he treasures up salvation for them that walk uprightly: he will protect their way;","searchKeywords":["and","treasures","salvation","for","them","that","walk","uprightly","will","protect","their","way"]},{"verseId":"brenton_proverbs_2_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":8,"text":"that he may guard the righteous ways: and he will preserve the way of them that fear him.","searchKeywords":["that","may","guard","the","righteous","ways","and","will","preserve","way","them","fear","him"]},{"verseId":"brenton_proverbs_2_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":9,"text":"Then shalt thou understand righteousness, and judgment; and shalt direct all thy course aright.","searchKeywords":["then","shalt","thou","understand","righteousness","and","judgment","direct","all","thy","course","aright"]},{"verseId":"brenton_proverbs_2_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":10,"text":"For if wisdom shall come into thine understanding, and discernment shall seem pleasing to thy soul,","searchKeywords":["for","wisdom","shall","come","into","thine","understanding","and","discernment","seem","pleasing","thy","soul"]},{"verseId":"brenton_proverbs_2_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":11,"text":"good counsel shall guard thee, and holy understanding shall keep thee;","searchKeywords":["good","counsel","shall","guard","thee","and","holy","understanding","keep"]},{"verseId":"brenton_proverbs_2_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":12,"text":"to deliver thee from the evil way, and from the man that speaks nothing faithfully.","searchKeywords":["deliver","thee","from","the","evil","way","and","man","that","speaks","nothing","faithfully"]},{"verseId":"brenton_proverbs_2_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":13,"text":"Alas who forsake right paths, to walk in ways of darkness;","searchKeywords":["alas","who","forsake","right","paths","walk","ways","darkness"]},{"verseId":"brenton_proverbs_2_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":14,"text":"who rejoice in evils, and delight in wicked perverseness;","searchKeywords":["who","rejoice","evils","and","delight","wicked","perverseness"]},{"verseId":"brenton_proverbs_2_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":15,"text":"whose paths are crooked, and their courses winding;","searchKeywords":["whose","paths","are","crooked","and","their","courses","winding"]},{"verseId":"brenton_proverbs_2_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":16,"text":"to remove thee far from the straight way, and to estrange thee from a righteous purpose. son, let not evil counsel overtake thee,","searchKeywords":["remove","thee","far","from","the","straight","way","and","estrange","righteous","purpose","son","let","not","evil","counsel","overtake"]},{"verseId":"brenton_proverbs_2_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":17,"text":"who has forsaken the instruction of her youth, and forgotten the covenant of God.","searchKeywords":["who","has","forsaken","the","instruction","her","youth","and","forgotten","covenant","god"]},{"verseId":"brenton_proverbs_2_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":18,"text":"For she has fixed her house near death, and her wheels near Hades with the giants.","searchKeywords":["for","she","has","fixed","her","house","near","death","and","wheels","hades","with","the","giants"]},{"verseId":"brenton_proverbs_2_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":19,"text":"None that go by her shall return, neither shall they take hold of right paths, for they are not apprehended of the years of life.","searchKeywords":["none","that","her","shall","return","neither","they","take","hold","right","paths","for","are","not","apprehended","the","years","life"]},{"verseId":"brenton_proverbs_2_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":20,"text":"For had they gone in good paths, they would have found the paths of righteousness easy.","searchKeywords":["for","had","they","gone","good","paths","would","have","found","the","righteousness","easy"]},{"verseId":"brenton_proverbs_2_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":21,"text":"For the upright shall dwell in the earth, and the holy shall be left behind in it.","searchKeywords":["for","the","upright","shall","dwell","earth","and","holy","left","behind"]},{"verseId":"brenton_proverbs_2_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":2,"verse":22,"text":"The paths of the ungodly shall perish out of the earth, and transgressors shall be driven away from it.","searchKeywords":["the","paths","ungodly","shall","perish","out","earth","and","transgressors","driven","away","from"]}]