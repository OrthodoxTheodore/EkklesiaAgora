[{"verseId":"brenton_proverbs_5_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":1,"text":"son, attend to my wisdom, and apply thine ear to my words;","searchKeywords":["son","attend","wisdom","and","apply","thine","ear","words"]},{"verseId":"brenton_proverbs_5_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":2,"text":"that thou mayest keep good understanding, and the discretion of my lips gives thee a charge.","searchKeywords":["that","thou","mayest","keep","good","understanding","and","the","discretion","lips","gives","thee","charge"]},{"verseId":"brenton_proverbs_5_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":3,"text":"for honey drops from the lips of a harlot, who for a season pleases thy palate:","searchKeywords":["for","honey","drops","from","the","lips","harlot","who","season","pleases","thy","palate"]},{"verseId":"brenton_proverbs_5_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":4,"text":"but afterwards thou wilt find her more bitter than gall, and sharper than a two-edged sword.","searchKeywords":["but","afterwards","thou","wilt","find","her","more","bitter","than","gall","and","sharper","two","edged","sword"]},{"verseId":"brenton_proverbs_5_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":5,"text":"For the feet of folly lead those who deal with her down to the grave with death; and her steps are not established.","searchKeywords":["for","the","feet","folly","lead","those","who","deal","with","her","down","grave","death","and","steps","are","not","established"]},{"verseId":"brenton_proverbs_5_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":6,"text":"For she goes not upon the paths of life; but her ways are slippery, and not easily known.","searchKeywords":["for","she","goes","not","upon","the","paths","life","but","her","ways","are","slippery","and","easily","known"]},{"verseId":"brenton_proverbs_5_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":7,"text":"Now then, son, hear me, and make not my words of none effect.","searchKeywords":["now","then","son","hear","and","make","not","words","none","effect"]},{"verseId":"brenton_proverbs_5_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":8,"text":"Remove thy way far from her; draw not near to the doors of her house:","searchKeywords":["remove","thy","way","far","from","her","draw","not","near","the","doors","house"]},{"verseId":"brenton_proverbs_5_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":9,"text":"lest thou give away thy life to others, and thy substance to the merciless:","searchKeywords":["lest","thou","give","away","thy","life","others","and","substance","the","merciless"]},{"verseId":"brenton_proverbs_5_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":10,"text":"lest strangers be filled with thy strength, and thy labours come into the houses of strangers;","searchKeywords":["lest","strangers","filled","with","thy","strength","and","labours","come","into","the","houses"]},{"verseId":"brenton_proverbs_5_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":11,"text":"and thou repent at last, when the flesh of thy body is consumed,","searchKeywords":["and","thou","repent","last","when","the","flesh","thy","body","consumed"]},{"verseId":"brenton_proverbs_5_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":12,"text":"and thou shalt say, How have I hated instruction, and my heart avoided reproofs!","searchKeywords":["and","thou","shalt","say","how","have","hated","instruction","heart","avoided","reproofs"]},{"verseId":"brenton_proverbs_5_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":13,"text":"I heard not the voice of him that instructed me, and taught me, neither did I apply mine ear.","searchKeywords":["heard","not","the","voice","him","that","instructed","and","taught","neither","did","apply","mine","ear"]},{"verseId":"brenton_proverbs_5_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":14,"text":"I was almost in all evil in the midst of the congregation and assembly.","searchKeywords":["was","almost","all","evil","the","midst","congregation","and","assembly"]},{"verseId":"brenton_proverbs_5_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":15,"text":"Drink waters out of thine own vessels, and out of thine own springing wells.","searchKeywords":["drink","waters","out","thine","own","vessels","and","springing","wells"]},{"verseId":"brenton_proverbs_5_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":16,"text":"Let not waters out of thy fountain be spilt by thee, but let thy waters go into thy streets.","searchKeywords":["let","not","waters","out","thy","fountain","spilt","thee","but","into","streets"]},{"verseId":"brenton_proverbs_5_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":17,"text":"Let them be only thine own, and let no stranger partake with thee.","searchKeywords":["let","them","only","thine","own","and","stranger","partake","with","thee"]},{"verseId":"brenton_proverbs_5_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":18,"text":"Let thy fountain of water be thine own; and rejoice with the wife of thy youth.","searchKeywords":["let","thy","fountain","water","thine","own","and","rejoice","with","the","wife","youth"]},{"verseId":"brenton_proverbs_5_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":19,"text":"Let loving hart and thy graceful colt company with thee, and let her be considered thine own, and be with thee at all times; for ravished with her love thou shalt be greatly increased.","searchKeywords":["let","loving","hart","and","thy","graceful","colt","company","with","thee","her","considered","thine","own","all","times","for","ravished","love","thou","shalt","greatly","increased"]},{"verseId":"brenton_proverbs_5_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":20,"text":"Be not intimate with a strange woman, neither fold thyself in the arms of a woman not thine own.","searchKeywords":["not","intimate","with","strange","woman","neither","fold","thyself","the","arms","thine","own"]},{"verseId":"brenton_proverbs_5_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":21,"text":"For the ways of a man are before the eyes of God, and he looks on all his paths.","searchKeywords":["for","the","ways","man","are","before","eyes","god","and","looks","all","his","paths"]},{"verseId":"brenton_proverbs_5_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":22,"text":"Iniquities ensnare a man, and every one is bound in the chains of his own sins.","searchKeywords":["iniquities","ensnare","man","and","every","one","bound","the","chains","his","own","sins"]},{"verseId":"brenton_proverbs_5_23","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":5,"verse":23,"text":"Such a man dies with the uninstructed; and he is cast forth from the abundance of his own substance, and has perished through folly.","searchKeywords":["such","man","dies","with","the","uninstructed","and","cast","forth","from","abundance","his","own","substance","has","perished","through","folly"]}]