[{"verseId":"brenton_proverbs_18_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":1,"text":"A man who wishes to separate from friends seeks excuses; but at all times he will be liable to reproach.","searchKeywords":["man","who","wishes","separate","from","friends","seeks","excuses","but","all","times","will","liable","reproach"]},{"verseId":"brenton_proverbs_18_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":2,"text":"A senseless man feels no need of wisdom, for he is rather led by folly.","searchKeywords":["senseless","man","feels","need","wisdom","for","rather","led","folly"]},{"verseId":"brenton_proverbs_18_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":3,"text":"When an ungodly man comes into a depth of evils, he despises ; but dishonour and reproach come upon him.","searchKeywords":["when","ungodly","man","comes","into","depth","evils","despises","but","dishonour","and","reproach","come","upon","him"]},{"verseId":"brenton_proverbs_18_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":4,"text":"A word in the heart of a man is a deep water, and a river and fountain of life spring forth.","searchKeywords":["word","the","heart","man","deep","water","and","river","fountain","life","spring","forth"]},{"verseId":"brenton_proverbs_18_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":5,"text":"not good to accept the person of the ungodly, nor holy to pervert justice in judgment.","searchKeywords":["not","good","accept","the","person","ungodly","nor","holy","pervert","justice","judgment"]},{"verseId":"brenton_proverbs_18_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":6,"text":"The lips of a fool bring into troubles, and his bold mouth calls for death.","searchKeywords":["the","lips","fool","bring","into","troubles","and","his","bold","mouth","calls","for","death"]},{"verseId":"brenton_proverbs_18_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":7,"text":"A fool's mouth is ruin to him, and his lips are a snare to his soul.","searchKeywords":["fool","mouth","ruin","him","and","his","lips","are","snare","soul"]},{"verseId":"brenton_proverbs_18_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":8,"text":"Fear casts down the slothful; and the souls of the effeminate shall hunger.","searchKeywords":["fear","casts","down","the","slothful","and","souls","effeminate","shall","hunger"]},{"verseId":"brenton_proverbs_18_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":9,"text":"A man who helps not himself by his labour is brother of him that ruins himself.","searchKeywords":["man","who","helps","not","himself","his","labour","brother","him","that","ruins"]},{"verseId":"brenton_proverbs_18_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":10,"text":"The name of the Lord is of great strength; and the righteous running to it are exalted.","searchKeywords":["the","name","lord","great","strength","and","righteous","running","are","exalted"]},{"verseId":"brenton_proverbs_18_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":11,"text":"The wealth of a rich man is a strong city; and its glory casts a broad shadow.","searchKeywords":["the","wealth","rich","man","strong","city","and","its","glory","casts","broad","shadow"]},{"verseId":"brenton_proverbs_18_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":12,"text":"Before ruin a man's heart is exalted, and before honour it is humble.","searchKeywords":["before","ruin","man","heart","exalted","and","honour","humble"]},{"verseId":"brenton_proverbs_18_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":13,"text":"Whoso answers a word before he hears , it is folly and reproach to him.","searchKeywords":["whoso","answers","word","before","hears","folly","and","reproach","him"]},{"verseId":"brenton_proverbs_18_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":14,"text":"A wise servant calms a man's anger; but who can endure a faint-hearted man?","searchKeywords":["wise","servant","calms","man","anger","but","who","can","endure","faint","hearted"]},{"verseId":"brenton_proverbs_18_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":15,"text":"The heart of the sensible purchases discretion; and the ears of the wise seek understanding.","searchKeywords":["the","heart","sensible","purchases","discretion","and","ears","wise","seek","understanding"]},{"verseId":"brenton_proverbs_18_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":16,"text":"A man's gift enlarges him, and seats him among princes.","searchKeywords":["man","gift","enlarges","him","and","seats","among","princes"]},{"verseId":"brenton_proverbs_18_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":17,"text":"A righteous man accuses himself at the beginning of his speech, but when he has entered upon the attack, the adversary is reproved.","searchKeywords":["righteous","man","accuses","himself","the","beginning","his","speech","but","when","has","entered","upon","attack","adversary","reproved"]},{"verseId":"brenton_proverbs_18_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":18,"text":"A silent quells strifes, and determines between great powers.","searchKeywords":["silent","quells","strifes","and","determines","between","great","powers"]},{"verseId":"brenton_proverbs_18_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":19,"text":"A brother helped by a brother is as a strong and high city; and is strong as a -founded palace.","searchKeywords":["brother","helped","strong","and","high","city","founded","palace"]},{"verseId":"brenton_proverbs_18_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":20,"text":"A man fills his belly with the fruits of his mouth; and he shall be satisfied with the fruits of his lips.","searchKeywords":["man","fills","his","belly","with","the","fruits","mouth","and","shall","satisfied","lips"]},{"verseId":"brenton_proverbs_18_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":21,"text":"Life and death are in the power of the tongue; and they that rule it shall eat the fruits thereof.","searchKeywords":["life","and","death","are","the","power","tongue","they","that","rule","shall","eat","fruits","thereof"]},{"verseId":"brenton_proverbs_18_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":18,"verse":22,"text":"He that has found a good wife has found favours, and has received gladness from God. He that puts away a good wife, puts away a good thing, and he that keeps an adulteress is foolish and ungodly.]","searchKeywords":["that","has","found","good","wife","favours","and","received","gladness","from","god","puts","away","thing","keeps","adulteress","foolish","ungodly"]}]