[{"verseId":"brenton_proverbs_24_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":1,"text":"son, envy not bad men, nor desire to be with them.","searchKeywords":["son","envy","not","bad","men","nor","desire","with","them"]},{"verseId":"brenton_proverbs_24_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":2,"text":"For their heart meditates falsehoods, and their lips speak mischiefs.","searchKeywords":["for","their","heart","meditates","falsehoods","and","lips","speak","mischiefs"]},{"verseId":"brenton_proverbs_24_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":3,"text":"A house is built by wisdom, and is set up by understanding.","searchKeywords":["house","built","wisdom","and","set","understanding"]},{"verseId":"brenton_proverbs_24_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":4,"text":"By discretion the chambers are filled with all precious and excellent wealth.","searchKeywords":["discretion","the","chambers","are","filled","with","all","precious","and","excellent","wealth"]},{"verseId":"brenton_proverbs_24_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":5,"text":"A wise man is better than a strong man; and a man who has prudence than a large estate.","searchKeywords":["wise","man","better","than","strong","and","who","has","prudence","large","estate"]},{"verseId":"brenton_proverbs_24_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":6,"text":"War is carried on with generalship, and aid is supplied to the heart of a counsellor.","searchKeywords":["war","carried","with","generalship","and","aid","supplied","the","heart","counsellor"]},{"verseId":"brenton_proverbs_24_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":7,"text":"Wisdom and good understanding are in the gates of the wise: the wise turn not aside from the mouth of the Lord,","searchKeywords":["wisdom","and","good","understanding","are","the","gates","wise","turn","not","aside","from","mouth","lord"]},{"verseId":"brenton_proverbs_24_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":8,"text":"but deliberate in council. Death befalls uninstructed .","searchKeywords":["but","deliberate","council","death","befalls","uninstructed"]},{"verseId":"brenton_proverbs_24_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":9,"text":"The fool also dies in sins; and uncleanness to a pestilent man.","searchKeywords":["the","fool","also","dies","sins","and","uncleanness","pestilent","man"]},{"verseId":"brenton_proverbs_24_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":10,"text":"He shall be defiled in the evil day, and in the day of affliction, until he be utterly consumed.","searchKeywords":["shall","defiled","the","evil","day","and","affliction","until","utterly","consumed"]},{"verseId":"brenton_proverbs_24_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":11,"text":"Deliver them that are led away to death, and redeem them that are appointed to be slain; spare not .","searchKeywords":["deliver","them","that","are","led","away","death","and","redeem","appointed","slain","spare","not"]},{"verseId":"brenton_proverbs_24_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":12,"text":"But if thou shouldest say, I know not this man; know that the Lord knows the hearts of all; and he that formed breath for all, he knows all things, who renders to every man according to his works.","searchKeywords":["but","thou","shouldest","say","know","not","this","man","that","the","lord","knows","hearts","all","and","formed","breath","for","things","who","renders","every","according","his","works"]},{"verseId":"brenton_proverbs_24_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":13,"text":"son, eat honey, for the honeycomb is good, that thy throat may be sweetened.","searchKeywords":["son","eat","honey","for","the","honeycomb","good","that","thy","throat","may","sweetened"]},{"verseId":"brenton_proverbs_24_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":14,"text":"Thus shalt thou perceive wisdom in thy soul: for if thou find it, thine end shall be good, and hope shall not fail thee.","searchKeywords":["thus","shalt","thou","perceive","wisdom","thy","soul","for","find","thine","end","shall","good","and","hope","not","fail","thee"]},{"verseId":"brenton_proverbs_24_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":15,"text":"Bring not an ungodly man into the dwelling of the righteous: neither be deceived by the feeding of the belly.","searchKeywords":["bring","not","ungodly","man","into","the","dwelling","righteous","neither","deceived","feeding","belly"]},{"verseId":"brenton_proverbs_24_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":16,"text":"For a righteous man will fall seven times, and rise : but the ungodly shall be without strength in troubles.","searchKeywords":["for","righteous","man","will","fall","seven","times","and","rise","but","the","ungodly","shall","without","strength","troubles"]},{"verseId":"brenton_proverbs_24_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":17,"text":"If thine enemy should fall, rejoice not over him, neither be elated at his overthrow.","searchKeywords":["thine","enemy","should","fall","rejoice","not","over","him","neither","elated","his","overthrow"]},{"verseId":"brenton_proverbs_24_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":18,"text":"For the Lord will see , and it will not please him, and he will turn away his wrath from him.","searchKeywords":["for","the","lord","will","see","and","not","please","him","turn","away","his","wrath","from"]},{"verseId":"brenton_proverbs_24_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":19,"text":"Rejoice not in evil-doers, neither be envious of sinners.","searchKeywords":["rejoice","not","evil","doers","neither","envious","sinners"]},{"verseId":"brenton_proverbs_24_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":20,"text":"For the evil man shall have no posterity: and the light of the wicked shall be put out.","searchKeywords":["for","the","evil","man","shall","have","posterity","and","light","wicked","put","out"]},{"verseId":"brenton_proverbs_24_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":21,"text":"son, fear God and the king; and do not disobey either of them.","searchKeywords":["son","fear","god","and","the","king","not","disobey","either","them"]},{"verseId":"brenton_proverbs_24_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":22,"text":"For they will suddenly punish the ungodly, and who can know the vengeance by both? [A son that keeps the commandment shall escape destruction; for has fully received it. shall be destroyed: fit to be eaten by the young eagles. son, reverence my words, and receive them, and repent.] poverty; but appoint me what is needful and sufficient: by the name of God. teeth and jaw-teeth knives, so as to destroy and devour the lowly from the earth, and the poor of them from among men.","searchKeywords":["for","they","will","suddenly","punish","the","ungodly","and","who","can","know","vengeance","both","son","that","keeps","commandment","shall","escape","destruction","has","fully","received","destroyed","fit","eaten","young","eagles","reverence","words","receive","them","repent","poverty","but","appoint","what","needful","sufficient","name","god","teeth","jaw","knives","destroy","devour","lowly","from","earth","poor","among","men"]},{"verseId":"brenton_proverbs_24_23","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":23,"text":"to learn: It is not good to have respect of persons in judgment.","searchKeywords":["learn","not","good","have","respect","persons","judgment"]},{"verseId":"brenton_proverbs_24_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":25,"text":"shall appear more excellent, and blessing shall come upon them;","searchKeywords":["shall","appear","more","excellent","and","blessing","come","upon","them"]},{"verseId":"brenton_proverbs_24_26","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":26,"text":"will kiss lips that answer well.","searchKeywords":["will","kiss","lips","that","answer","well"]},{"verseId":"brenton_proverbs_24_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":27,"text":"going forth, and prepare thyself for the field; and come after me, and thou shalt rebuild thine house.","searchKeywords":["going","forth","and","prepare","thyself","for","the","field","come","after","thou","shalt","rebuild","thine","house"]},{"verseId":"brenton_proverbs_24_28","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":28,"text":"citizen, neither exaggerate with thy lips.","searchKeywords":["citizen","neither","exaggerate","with","thy","lips"]},{"verseId":"brenton_proverbs_24_31","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":31,"text":"and he becomes destitute, and his stone walls are broken down.","searchKeywords":["and","becomes","destitute","his","stone","walls","are","broken","down"]},{"verseId":"brenton_proverbs_24_33","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":33,"text":", I slumber a little, and I sleep a little, and for a little while I fold my arms across breast.","searchKeywords":["slumber","little","and","sleep","for","while","fold","arms","across","breast"]},{"verseId":"brenton_proverbs_24_44","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":44,"text":"four very little things upon the earth, but these are wiser than the wise:","searchKeywords":["four","very","little","things","upon","the","earth","but","these","are","wiser","than","wise"]},{"verseId":"brenton_proverbs_24_45","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":45,"text":"prepare food in summer;","searchKeywords":["prepare","food","summer"]},{"verseId":"brenton_proverbs_24_46","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":46,"text":"a feeble race, who make their houses in the rocks.","searchKeywords":["feeble","race","who","make","their","houses","the","rocks"]},{"verseId":"brenton_proverbs_24_47","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":47,"text":"march orderly at one command.","searchKeywords":["march","orderly","one","command"]},{"verseId":"brenton_proverbs_24_48","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":48,"text":"hands, and is easily taken, dwells in the fortresses of kings.","searchKeywords":["hands","and","easily","taken","dwells","the","fortresses","kings"]},{"verseId":"brenton_proverbs_24_50","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":50,"text":"beasts, which turns not away, nor fears beast;","searchKeywords":["beasts","which","turns","not","away","nor","fears","beast"]},{"verseId":"brenton_proverbs_24_53","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":24,"verse":53,"text":"nostrils there shall come out blood: so if thou extort words, there will come forth quarrels and strifes.","searchKeywords":["nostrils","there","shall","come","out","blood","thou","extort","words","will","forth","quarrels","and","strifes"]}]