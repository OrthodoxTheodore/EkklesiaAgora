[{"verseId":"brenton_proverbs_19_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":3,"text":"The folly of a man spoils his ways: and he blames God in his heart.","searchKeywords":["the","folly","man","spoils","his","ways","and","blames","god","heart"]},{"verseId":"brenton_proverbs_19_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":4,"text":"Wealth acquires many friends; but the poor is deserted even of the friend he has.","searchKeywords":["wealth","acquires","many","friends","but","the","poor","deserted","even","friend","has"]},{"verseId":"brenton_proverbs_19_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":5,"text":"A false witness shall not be unpunished, and he that accuses unjustly shall not escape.","searchKeywords":["false","witness","shall","not","unpunished","and","that","accuses","unjustly","escape"]},{"verseId":"brenton_proverbs_19_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":6,"text":"Many court the favour of kings; but every bad man becomes a reproach to man.","searchKeywords":["many","court","the","favour","kings","but","every","bad","man","becomes","reproach"]},{"verseId":"brenton_proverbs_19_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":7,"text":"Every one who hates poor brother shall also be far from friendship. Good understanding will draw near to them that know it, and a sensible man will find it. He that does much harm perfects mischief; and he that uses provoking words shall not escape.","searchKeywords":["every","one","who","hates","poor","brother","shall","also","far","from","friendship","good","understanding","will","draw","near","them","that","know","and","sensible","man","find","does","much","harm","perfects","mischief","uses","provoking","words","not","escape"]},{"verseId":"brenton_proverbs_19_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":8,"text":"He that procures wisdom loves himself; and he that keeps wisdom shall find good.","searchKeywords":["that","procures","wisdom","loves","himself","and","keeps","shall","find","good"]},{"verseId":"brenton_proverbs_19_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":9,"text":"A false witness shall not be unpunished; and whosoever shall kindle mischief shall perish by it.","searchKeywords":["false","witness","shall","not","unpunished","and","whosoever","kindle","mischief","perish"]},{"verseId":"brenton_proverbs_19_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":10,"text":"Delight does not suit a fool, nor if a servant should begin to rule with haughtiness.","searchKeywords":["delight","does","not","suit","fool","nor","servant","should","begin","rule","with","haughtiness"]},{"verseId":"brenton_proverbs_19_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":11,"text":"A merciful man is long-suffering; and his triumph overtakes transgressors.","searchKeywords":["merciful","man","long","suffering","and","his","triumph","overtakes","transgressors"]},{"verseId":"brenton_proverbs_19_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":12,"text":"The threatening of a king is like the roaring of a lion; but as dew on the grass, so is his favour.","searchKeywords":["the","threatening","king","like","roaring","lion","but","dew","grass","his","favour"]},{"verseId":"brenton_proverbs_19_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":13,"text":"A foolish son is a disgrace to his father: vows of the hire of a harlot are not pure.","searchKeywords":["foolish","son","disgrace","his","father","vows","the","hire","harlot","are","not","pure"]},{"verseId":"brenton_proverbs_19_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":14,"text":"Fathers divide house and substance to children: but a wife is suited to a man by the Lord.","searchKeywords":["fathers","divide","house","and","substance","children","but","wife","suited","man","the","lord"]},{"verseId":"brenton_proverbs_19_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":15,"text":"Cowardice possesses the effeminate ; and the soul of the sluggard shall hunger.","searchKeywords":["cowardice","possesses","the","effeminate","and","soul","sluggard","shall","hunger"]},{"verseId":"brenton_proverbs_19_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":16,"text":"He that keeps the commandment keeps his own soul; but he that despises his ways shall perish.","searchKeywords":["that","keeps","the","commandment","his","own","soul","but","despises","ways","shall","perish"]},{"verseId":"brenton_proverbs_19_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":17,"text":"He that has pity on the poor lends to the Lord; and he will recompense to him according to his gift.","searchKeywords":["that","has","pity","the","poor","lends","lord","and","will","recompense","him","according","his","gift"]},{"verseId":"brenton_proverbs_19_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":18,"text":"Chasten thy son, for so he shall be hopeful; and be not exalted in thy soul to haughtiness.","searchKeywords":["chasten","thy","son","for","shall","hopeful","and","not","exalted","soul","haughtiness"]},{"verseId":"brenton_proverbs_19_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":19,"text":"A malicious man shall be severely punished, and if he commit injury, he shall also lose his life.","searchKeywords":["malicious","man","shall","severely","punished","and","commit","injury","also","lose","his","life"]},{"verseId":"brenton_proverbs_19_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":20,"text":"Hear, son, the instruction of thy father, that thou mayest be wise at thy latter end.","searchKeywords":["hear","son","the","instruction","thy","father","that","thou","mayest","wise","latter","end"]},{"verseId":"brenton_proverbs_19_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":21,"text":"many thoughts in a man's heart; but the counsel of the Lord abides for ever.","searchKeywords":["many","thoughts","man","heart","but","the","counsel","lord","abides","for","ever"]},{"verseId":"brenton_proverbs_19_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":22,"text":"Mercy is a fruit to a man: and a poor man is better than a rich liar.","searchKeywords":["mercy","fruit","man","and","poor","better","than","rich","liar"]},{"verseId":"brenton_proverbs_19_23","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":23,"text":"The fear of the Lord is life to a man: and he shall lodge without fear in places where knowledge is not seen.","searchKeywords":["the","fear","lord","life","man","and","shall","lodge","without","places","where","knowledge","not","seen"]},{"verseId":"brenton_proverbs_19_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":24,"text":"He that unjustly hides his hands in his bosom, will not even them up to his mouth.","searchKeywords":["that","unjustly","hides","his","hands","bosom","will","not","even","them","mouth"]},{"verseId":"brenton_proverbs_19_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":25,"text":"When a pestilent character is scourged, a simple man is made wiser: and if thou reprove a wise man, he will understand discretion.","searchKeywords":["when","pestilent","character","scourged","simple","man","made","wiser","and","thou","reprove","wise","will","understand","discretion"]},{"verseId":"brenton_proverbs_19_26","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":26,"text":"He that dishonours his father, and drives away his mother, shall be disgraced and shall be exposed to reproach.","searchKeywords":["that","dishonours","his","father","and","drives","away","mother","shall","disgraced","exposed","reproach"]},{"verseId":"brenton_proverbs_19_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":27,"text":"A son who ceases to attend to the instruction of a father will cherish evil designs.","searchKeywords":["son","who","ceases","attend","the","instruction","father","will","cherish","evil","designs"]},{"verseId":"brenton_proverbs_19_28","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":28,"text":"He that becomes surety for a foolish child will despise the ordinance: and the mouth of ungodly men shall drink down judgments.","searchKeywords":["that","becomes","surety","for","foolish","child","will","despise","the","ordinance","and","mouth","ungodly","men","shall","drink","down","judgments"]},{"verseId":"brenton_proverbs_19_29","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":19,"verse":29,"text":"Scourges are preparing for the intemperate, and punishments likewise for fools.","searchKeywords":["scourges","are","preparing","for","the","intemperate","and","punishments","likewise","fools"]}]