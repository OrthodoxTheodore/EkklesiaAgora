[{"verseId":"brenton_proverbs_11_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":1,"text":"False balances are an abomination before the Lord: but a just weight is acceptable unto him.","searchKeywords":["false","balances","are","abomination","before","the","lord","but","just","weight","acceptable","unto","him"]},{"verseId":"brenton_proverbs_11_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":2,"text":"Wherever pride enters, there will be also disgrace: but the mouth of the lowly meditates wisdom.","searchKeywords":["wherever","pride","enters","there","will","also","disgrace","but","the","mouth","lowly","meditates","wisdom"]},{"verseId":"brenton_proverbs_11_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":3,"text":"When a just man dies he leaves regret: but the destruction of the ungodly is speedy, and causes joy.","searchKeywords":["when","just","man","dies","leaves","regret","but","the","destruction","ungodly","speedy","and","causes","joy"]},{"verseId":"brenton_proverbs_11_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":5,"text":"Righteousness traces out blameless paths: but ungodliness encounters unjust dealing.","searchKeywords":["righteousness","traces","out","blameless","paths","but","ungodliness","encounters","unjust","dealing"]},{"verseId":"brenton_proverbs_11_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":6,"text":"The righteousness of upright men delivers them: but transgressors are caught in their own destruction.","searchKeywords":["the","righteousness","upright","men","delivers","them","but","transgressors","are","caught","their","own","destruction"]},{"verseId":"brenton_proverbs_11_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":7,"text":"At the death of a just man his hope does not perish: but the boast of the ungodly perishes.","searchKeywords":["the","death","just","man","his","hope","does","not","perish","but","boast","ungodly","perishes"]},{"verseId":"brenton_proverbs_11_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":8,"text":"A righteous man escapes from a snare, and the ungodly man is delivered up in his place.","searchKeywords":["righteous","man","escapes","from","snare","and","the","ungodly","delivered","his","place"]},{"verseId":"brenton_proverbs_11_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":9,"text":"In the mouth of ungodly men is a snare to citizens: but the understanding of righteous men is prosperous.","searchKeywords":["the","mouth","ungodly","men","snare","citizens","but","understanding","righteous","prosperous"]},{"verseId":"brenton_proverbs_11_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":10,"text":"In the prosperity of righteous men a city prospers:","searchKeywords":["the","prosperity","righteous","men","city","prospers"]},{"verseId":"brenton_proverbs_11_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":11,"text":"but by the mouths of ungodly men it is overthrown.","searchKeywords":["but","the","mouths","ungodly","men","overthrown"]},{"verseId":"brenton_proverbs_11_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":12,"text":"A man void of understanding sneers at citizens: but a sensible man is quiet.","searchKeywords":["man","void","understanding","sneers","citizens","but","sensible","quiet"]},{"verseId":"brenton_proverbs_11_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":13,"text":"A double-tongued man discloses the counsels of an assembly: but he that is faithful in spirit conceals matters.","searchKeywords":["double","tongued","man","discloses","the","counsels","assembly","but","that","faithful","spirit","conceals","matters"]},{"verseId":"brenton_proverbs_11_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":14,"text":"They that have no guidance fall like leaves: but in much counsel there is safety.","searchKeywords":["they","that","have","guidance","fall","like","leaves","but","much","counsel","there","safety"]},{"verseId":"brenton_proverbs_11_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":15,"text":"A bad man does harm wherever he meets a just man: and he hates the sound of safety.","searchKeywords":["bad","man","does","harm","wherever","meets","just","and","hates","the","sound","safety"]},{"verseId":"brenton_proverbs_11_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":16,"text":"A gracious wife brings glory to her husband: but a woman hating righteousness is a theme of dishonour. The slothful come to want: but the diligent support themselves with wealth.","searchKeywords":["gracious","wife","brings","glory","her","husband","but","woman","hating","righteousness","theme","dishonour","the","slothful","come","want","diligent","support","themselves","with","wealth"]},{"verseId":"brenton_proverbs_11_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":17,"text":"A merciful man does good to his own soul: but the merciless destroys his own body.","searchKeywords":["merciful","man","does","good","his","own","soul","but","the","merciless","destroys","body"]},{"verseId":"brenton_proverbs_11_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":18,"text":"An ungodly man performs unrighteous works: but the seed of the righteous is a reward of truth.","searchKeywords":["ungodly","man","performs","unrighteous","works","but","the","seed","righteous","reward","truth"]},{"verseId":"brenton_proverbs_11_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":19,"text":"A righteous son is born for life: but the persecution of the ungodly in death.","searchKeywords":["righteous","son","born","for","life","but","the","persecution","ungodly","death"]},{"verseId":"brenton_proverbs_11_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":20,"text":"Perverse ways are an abomination to the Lord: but all they that are blameless in their ways are acceptable to him.","searchKeywords":["perverse","ways","are","abomination","the","lord","but","all","they","that","blameless","their","acceptable","him"]},{"verseId":"brenton_proverbs_11_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":21,"text":"He that unjustly strikes hands shall not be unpunished: but he that sows righteousness shall receive a faithful reward.","searchKeywords":["that","unjustly","strikes","hands","shall","not","unpunished","but","sows","righteousness","receive","faithful","reward"]},{"verseId":"brenton_proverbs_11_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":22,"text":"As an ornament in a swine's snout, so is beauty to an ill-minded woman.","searchKeywords":["ornament","swine","snout","beauty","ill","minded","woman"]},{"verseId":"brenton_proverbs_11_23","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":23,"text":"All the desire of the righteous is good: but the hope of the ungodly shall perish.","searchKeywords":["all","the","desire","righteous","good","but","hope","ungodly","shall","perish"]},{"verseId":"brenton_proverbs_11_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":24,"text":"There are who scatter their own, and make it more: and there are also who gather, have less.","searchKeywords":["there","are","who","scatter","their","own","and","make","more","also","gather","have","less"]},{"verseId":"brenton_proverbs_11_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":25,"text":"Every sincere soul is blessed: but a passionate man is not graceful.","searchKeywords":["every","sincere","soul","blessed","but","passionate","man","not","graceful"]},{"verseId":"brenton_proverbs_11_26","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":26,"text":"May he that hoards corn leave it to the nation: but blessing be on the head of him that gives .","searchKeywords":["may","that","hoards","corn","leave","the","nation","but","blessing","head","him","gives"]},{"verseId":"brenton_proverbs_11_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":27,"text":"He that devises good seeks good favour: but him that seeks after evil, shall overtake him.","searchKeywords":["that","devises","good","seeks","favour","but","him","after","evil","shall","overtake"]},{"verseId":"brenton_proverbs_11_28","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":28,"text":"He that trusts in wealth shall fall; but he that helps righteous men shall rise.","searchKeywords":["that","trusts","wealth","shall","fall","but","helps","righteous","men","rise"]},{"verseId":"brenton_proverbs_11_29","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":29,"text":"He that deals not graciously with his own house shall inherit the wind; and the fool shall be servant to the wise man.","searchKeywords":["that","deals","not","graciously","with","his","own","house","shall","inherit","the","wind","and","fool","servant","wise","man"]},{"verseId":"brenton_proverbs_11_30","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":30,"text":"Out of the fruit of righteousness grows a tree of life; but the souls of transgressors are cut off before their time.","searchKeywords":["out","the","fruit","righteousness","grows","tree","life","but","souls","transgressors","are","cut","off","before","their","time"]},{"verseId":"brenton_proverbs_11_31","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":11,"verse":31,"text":"If the righteous scarcely be saved, where shall the ungodly and the sinner appear?","searchKeywords":["the","righteous","scarcely","saved","where","shall","ungodly","and","sinner","appear"]}]