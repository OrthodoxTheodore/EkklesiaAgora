[{"verseId":"brenton_proverbs_16_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":2,"text":"All the works of the humble are manifest with God; but the ungodly shall perish in an evil day.","searchKeywords":["all","the","works","humble","are","manifest","with","god","but","ungodly","shall","perish","evil","day"]},{"verseId":"brenton_proverbs_16_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":5,"text":"Every one that is proud in heart is unclean before God, and he that unjustly strikes hands with hand shall not be held guiltless.","searchKeywords":["every","one","that","proud","heart","unclean","before","god","and","unjustly","strikes","hands","with","hand","shall","not","held","guiltless"]},{"verseId":"brenton_proverbs_16_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":7,"text":"The beginning of a good way is to do justly; and it is more acceptable with God than to offer sacrifices.","searchKeywords":["the","beginning","good","way","justly","and","more","acceptable","with","god","than","offer","sacrifices"]},{"verseId":"brenton_proverbs_16_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":8,"text":"He that seeks the Lord shall find knowledge with righteousness: and they that rightly seek him shall find peace.","searchKeywords":["that","seeks","the","lord","shall","find","knowledge","with","righteousness","and","they","rightly","seek","him","peace"]},{"verseId":"brenton_proverbs_16_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":9,"text":"All the works of the Lord with righteousness; and the ungodly is kept for the evil day.","searchKeywords":["all","the","works","lord","with","righteousness","and","ungodly","kept","for","evil","day"]},{"verseId":"brenton_proverbs_16_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":10,"text":"an oracle upon the lips of a king; and his mouth shall not err in judgment.","searchKeywords":["oracle","upon","the","lips","king","and","his","mouth","shall","not","err","judgment"]},{"verseId":"brenton_proverbs_16_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":11,"text":"The poise of the balance is righteousness with the Lord; and his works are righteous measures.","searchKeywords":["the","poise","balance","righteousness","with","lord","and","his","works","are","righteous","measures"]},{"verseId":"brenton_proverbs_16_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":12,"text":"An evil-doer is an abomination to a king; for the throne of rule is established by righteousness.","searchKeywords":["evil","doer","abomination","king","for","the","throne","rule","established","righteousness"]},{"verseId":"brenton_proverbs_16_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":13,"text":"Righteous lips are acceptable to a king; and he loves right words.","searchKeywords":["righteous","lips","are","acceptable","king","and","loves","right","words"]},{"verseId":"brenton_proverbs_16_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":14,"text":"The anger of a king is a messenger of death; but a wise man will pacify him.","searchKeywords":["the","anger","king","messenger","death","but","wise","man","will","pacify","him"]},{"verseId":"brenton_proverbs_16_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":15,"text":"The son of a king is in the light of life; and they that are in favour with him are as a cloud of latter rain.","searchKeywords":["the","son","king","light","life","and","they","that","are","favour","with","him","cloud","latter","rain"]},{"verseId":"brenton_proverbs_16_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":16,"text":"The brood of wisdom is more to be chosen than gold, and the brood of prudence more to be chosen than silver.","searchKeywords":["the","brood","wisdom","more","chosen","than","gold","and","prudence","silver"]},{"verseId":"brenton_proverbs_16_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":17,"text":"The paths of life turn aside from evil; and the ways of righteousness are length of life. He that receives instruction shall be in prosperity; and he that regards reproofs shall be made wise. He that keeps his ways, preserves his own soul; and he that loves his life will spare his mouth.","searchKeywords":["the","paths","life","turn","aside","from","evil","and","ways","righteousness","are","length","that","receives","instruction","shall","prosperity","regards","reproofs","made","wise","keeps","his","preserves","own","soul","loves","will","spare","mouth"]},{"verseId":"brenton_proverbs_16_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":18,"text":"Pride goes before destruction, and folly before a fall.","searchKeywords":["pride","goes","before","destruction","and","folly","fall"]},{"verseId":"brenton_proverbs_16_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":19,"text":"Better is a meek-spirited with lowliness, than one who divides spoils with the proud.","searchKeywords":["better","meek","spirited","with","lowliness","than","one","who","divides","spoils","the","proud"]},{"verseId":"brenton_proverbs_16_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":20,"text":"skilful in business finds good: but he that trusts in God is most blessed.","searchKeywords":["skilful","business","finds","good","but","that","trusts","god","most","blessed"]},{"verseId":"brenton_proverbs_16_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":21,"text":"call the wise and understanding evil: but they that are pleasing in speech shall hear more.","searchKeywords":["call","the","wise","and","understanding","evil","but","they","that","are","pleasing","speech","shall","hear","more"]},{"verseId":"brenton_proverbs_16_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":22,"text":"Understanding is a fountain of life to its possessors; but the instruction of fools is evil.","searchKeywords":["understanding","fountain","life","its","possessors","but","the","instruction","fools","evil"]},{"verseId":"brenton_proverbs_16_23","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":23,"text":"The heart of the wise will discern the from his own mouth; and on his lips he will wear knowledge.","searchKeywords":["the","heart","wise","will","discern","from","his","own","mouth","and","lips","wear","knowledge"]},{"verseId":"brenton_proverbs_16_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":24,"text":"Good words are honeycombs, and the sweetness thereof is a healing of the soul.","searchKeywords":["good","words","are","honeycombs","and","the","sweetness","thereof","healing","soul"]},{"verseId":"brenton_proverbs_16_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":25,"text":"There are ways that seem to be right to a man, but the end of them looks to the depth of hell.","searchKeywords":["there","are","ways","that","seem","right","man","but","the","end","them","looks","depth","hell"]},{"verseId":"brenton_proverbs_16_26","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":26,"text":"A man who labours, labours for himself, and drives from his own ruin.","searchKeywords":["man","who","labours","for","himself","and","drives","from","his","own","ruin"]},{"verseId":"brenton_proverbs_16_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":27,"text":"But the perverse bears destruction upon his own mouth: a foolish man digs up evil for himself, and treasures fire on his own lips.","searchKeywords":["but","the","perverse","bears","destruction","upon","his","own","mouth","foolish","man","digs","evil","for","himself","and","treasures","fire","lips"]},{"verseId":"brenton_proverbs_16_28","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":28,"text":"A perverse man spreads mischief, and will kindle a torch of deceit with mischiefs; and he separates friends.","searchKeywords":["perverse","man","spreads","mischief","and","will","kindle","torch","deceit","with","mischiefs","separates","friends"]},{"verseId":"brenton_proverbs_16_29","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":29,"text":"A transgressor tries friends, and leads them in ways not good.","searchKeywords":["transgressor","tries","friends","and","leads","them","ways","not","good"]},{"verseId":"brenton_proverbs_16_30","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":30,"text":"And the man that fixes his eyes devises perverse things, and marks out with his lips all evils: he is a furnace of wickedness.","searchKeywords":["and","the","man","that","fixes","his","eyes","devises","perverse","things","marks","out","with","lips","all","evils","furnace","wickedness"]},{"verseId":"brenton_proverbs_16_31","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":31,"text":"Old age is a crown of honour, but it is found in the ways of righteousness.","searchKeywords":["old","age","crown","honour","but","found","the","ways","righteousness"]},{"verseId":"brenton_proverbs_16_32","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":32,"text":"A man slow to anger is better than a strong ; and he that governs temper better than he that takes a city.","searchKeywords":["man","slow","anger","better","than","strong","and","that","governs","temper","takes","city"]},{"verseId":"brenton_proverbs_16_33","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":16,"verse":33,"text":"All come upon the ungodly into bosoms; but all righteous things of the Lord.","searchKeywords":["all","come","upon","the","ungodly","into","bosoms","but","righteous","things","lord"]}]