[{"verseId":"brenton_proverbs_9_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":9,"verse":1,"text":"Wisdom has built a house for herself, and set up seven pillars.","searchKeywords":["wisdom","has","built","house","for","herself","and","set","seven","pillars"]},{"verseId":"brenton_proverbs_9_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":9,"verse":2,"text":"She has killed her beasts; she has mingled her wine in a bowl, and prepared her table.","searchKeywords":["she","has","killed","her","beasts","mingled","wine","bowl","and","prepared","table"]},{"verseId":"brenton_proverbs_9_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":9,"verse":3,"text":"She has sent forth her servants, calling with a loud proclamation to the feast, saying,","searchKeywords":["she","has","sent","forth","her","servants","calling","with","loud","proclamation","the","feast","saying"]},{"verseId":"brenton_proverbs_9_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":9,"verse":4,"text":"Whoso is foolish, let him turn aside to me: and to them that want understanding she says,","searchKeywords":["whoso","foolish","let","him","turn","aside","and","them","that","want","understanding","she","says"]},{"verseId":"brenton_proverbs_9_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":9,"verse":5,"text":"Come, eat of my bread, and drink wine which I have mingled for you.","searchKeywords":["come","eat","bread","and","drink","wine","which","have","mingled","for","you"]},{"verseId":"brenton_proverbs_9_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":9,"verse":6,"text":"Leave folly, that ye may reign for ever; and seek wisdom, and improve understanding by knowledge.","searchKeywords":["leave","folly","that","may","reign","for","ever","and","seek","wisdom","improve","understanding","knowledge"]},{"verseId":"brenton_proverbs_9_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":9,"verse":7,"text":"He that reproves evil shall get dishonour to himself; and he that rebukes an ungodly shall disgrace himself.","searchKeywords":["that","reproves","evil","shall","get","dishonour","himself","and","rebukes","ungodly","disgrace"]},{"verseId":"brenton_proverbs_9_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":9,"verse":8,"text":"Rebuke not evil , lest they should hate thee: rebuke a wise , and he will love thee.","searchKeywords":["rebuke","not","evil","lest","they","should","hate","thee","wise","and","will","love"]},{"verseId":"brenton_proverbs_9_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":9,"verse":9,"text":"Give an opportunity to a wise , and he will be wiser: instruct a just man, and he will receive more .","searchKeywords":["give","opportunity","wise","and","will","wiser","instruct","just","man","receive","more"]},{"verseId":"brenton_proverbs_9_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":9,"verse":10,"text":"The fear of the Lord is the beginning of wisdom, and the counsel of saints is understanding: of a sound mind.","searchKeywords":["the","fear","lord","beginning","wisdom","and","counsel","saints","understanding","sound","mind"]},{"verseId":"brenton_proverbs_9_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":9,"verse":12,"text":"He that stays himself upon falsehoods, attempts to rule the winds, and the same will pursue birds in their flight: appointed to drought, and he gathers barrenness with his hands.","searchKeywords":["that","stays","himself","upon","falsehoods","attempts","rule","the","winds","and","same","will","pursue","birds","their","flight","appointed","drought","gathers","barrenness","with","his","hands"]},{"verseId":"brenton_proverbs_9_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":9,"verse":16,"text":", Whoso is most senseless of you, let him turn aside to me; and I exhort those that want prudence, saying,","searchKeywords":["whoso","most","senseless","you","let","him","turn","aside","and","exhort","those","that","want","prudence","saying"]}]