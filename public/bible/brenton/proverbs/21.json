[{"verseId":"brenton_proverbs_21_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":1,"text":"As a rush of water, so is the king's heart in God's hand: he turns it whithersoever he may desire to point out.","searchKeywords":["rush","water","the","king","heart","god","hand","turns","whithersoever","may","desire","point","out"]},{"verseId":"brenton_proverbs_21_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":2,"text":"Every man seems to himself righteous; but the Lord directs the hearts.","searchKeywords":["every","man","seems","himself","righteous","but","the","lord","directs","hearts"]},{"verseId":"brenton_proverbs_21_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":3,"text":"To do justly and to speak truth, are more pleasing to God than the blood of sacrifices.","searchKeywords":["justly","and","speak","truth","are","more","pleasing","god","than","the","blood","sacrifices"]},{"verseId":"brenton_proverbs_21_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":4,"text":"A high-minded man is stout-hearted in pride; and the lamp of the wicked is sin.","searchKeywords":["high","minded","man","stout","hearted","pride","and","the","lamp","wicked","sin"]},{"verseId":"brenton_proverbs_21_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":6,"text":"He that gathers treasures with a lying tongue pursues vanity to the snares of death.","searchKeywords":["that","gathers","treasures","with","lying","tongue","pursues","vanity","the","snares","death"]},{"verseId":"brenton_proverbs_21_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":7,"text":"Destruction shall lodge with the ungodly; for they refuse to do justly.","searchKeywords":["destruction","shall","lodge","with","the","ungodly","for","they","refuse","justly"]},{"verseId":"brenton_proverbs_21_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":8,"text":"To the froward God sends froward ways; for his works are pure and right.","searchKeywords":["the","froward","god","sends","ways","for","his","works","are","pure","and","right"]},{"verseId":"brenton_proverbs_21_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":9,"text":"better to dwell in a corner on the house-top, than in plastered with unrighteousness, and in an open house.","searchKeywords":["better","dwell","corner","the","house","top","than","plastered","with","unrighteousness","and","open"]},{"verseId":"brenton_proverbs_21_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":10,"text":"The soul of the ungodly shall not be pitied by any man.","searchKeywords":["the","soul","ungodly","shall","not","pitied","any","man"]},{"verseId":"brenton_proverbs_21_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":11,"text":"When an intemperate man is punished the simple becomes wiser: and a wise man understanding will receive knowledge.","searchKeywords":["when","intemperate","man","punished","the","simple","becomes","wiser","and","wise","understanding","will","receive","knowledge"]},{"verseId":"brenton_proverbs_21_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":12,"text":"A righteous man understands the hearts of the ungodly: and despises the ungodly for their wickedness.","searchKeywords":["righteous","man","understands","the","hearts","ungodly","and","despises","for","their","wickedness"]},{"verseId":"brenton_proverbs_21_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":13,"text":"He that stops his ears from hearing the poor, himself also shall cry, and there shall be none to hear .","searchKeywords":["that","stops","his","ears","from","hearing","the","poor","himself","also","shall","cry","and","there","none","hear"]},{"verseId":"brenton_proverbs_21_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":14,"text":"A secret gift calms anger: but he that forbears to give stirs up strong wrath.","searchKeywords":["secret","gift","calms","anger","but","that","forbears","give","stirs","strong","wrath"]},{"verseId":"brenton_proverbs_21_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":15,"text":"the joy of the righteous to do judgment: but a holy is abominable with evil-doers.","searchKeywords":["the","joy","righteous","judgment","but","holy","abominable","with","evil","doers"]},{"verseId":"brenton_proverbs_21_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":16,"text":"A man that wanders out of the way of righteousness, shall rest in the congregation of giants.","searchKeywords":["man","that","wanders","out","the","way","righteousness","shall","rest","congregation","giants"]},{"verseId":"brenton_proverbs_21_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":17,"text":"A poor man loves mirth, loving wine and oil in abundance;","searchKeywords":["poor","man","loves","mirth","loving","wine","and","oil","abundance"]},{"verseId":"brenton_proverbs_21_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":18,"text":"and a transgressor is the abomination of a righteous man.","searchKeywords":["and","transgressor","the","abomination","righteous","man"]},{"verseId":"brenton_proverbs_21_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":19,"text":"better to dwell in a wilderness than with a quarrelsome and talkative and passionate woman.","searchKeywords":["better","dwell","wilderness","than","with","quarrelsome","and","talkative","passionate","woman"]},{"verseId":"brenton_proverbs_21_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":20,"text":"A desirable treasure will rest on the mouth of the wise; but foolish men will swallow it up.","searchKeywords":["desirable","treasure","will","rest","the","mouth","wise","but","foolish","men","swallow"]},{"verseId":"brenton_proverbs_21_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":21,"text":"The way of righteousness and mercy will find life and glory.","searchKeywords":["the","way","righteousness","and","mercy","will","find","life","glory"]},{"verseId":"brenton_proverbs_21_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":22,"text":"A wise man assaults strong cities, and demolishes the fortress in which the ungodly trusted.","searchKeywords":["wise","man","assaults","strong","cities","and","demolishes","the","fortress","which","ungodly","trusted"]},{"verseId":"brenton_proverbs_21_23","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":23,"text":"He that keeps his mouth and his tongue keeps his soul from trouble.","searchKeywords":["that","keeps","his","mouth","and","tongue","soul","from","trouble"]},{"verseId":"brenton_proverbs_21_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":24,"text":"A bold and self-willed and insolent is called a pest: and he that remembers injuries is a transgressor.","searchKeywords":["bold","and","self","willed","insolent","called","pest","that","remembers","injuries","transgressor"]},{"verseId":"brenton_proverbs_21_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":25,"text":"Desires kill the sluggard; for his hands do not choose to do anything.","searchKeywords":["desires","kill","the","sluggard","for","his","hands","not","choose","anything"]},{"verseId":"brenton_proverbs_21_26","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":26,"text":"An ungodly man entertains evil desires all the day: but the righteous is unsparingly merciful and compassionate.","searchKeywords":["ungodly","man","entertains","evil","desires","all","the","day","but","righteous","unsparingly","merciful","and","compassionate"]},{"verseId":"brenton_proverbs_21_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":27,"text":"The sacrifices of the ungodly are abomination to the Lord, for they offer them wickedly.","searchKeywords":["the","sacrifices","ungodly","are","abomination","lord","for","they","offer","them","wickedly"]},{"verseId":"brenton_proverbs_21_28","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":28,"text":"A false witness shall perish; but an obedient man will speak cautiously.","searchKeywords":["false","witness","shall","perish","but","obedient","man","will","speak","cautiously"]},{"verseId":"brenton_proverbs_21_29","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":29,"text":"An ungodly man impudently withstands with his face; but the upright man himself understands his ways.","searchKeywords":["ungodly","man","impudently","withstands","with","his","face","but","the","upright","himself","understands","ways"]},{"verseId":"brenton_proverbs_21_30","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":30,"text":"There is no wisdom, there is no courage, there is no counsel against the ungodly.","searchKeywords":["there","wisdom","courage","counsel","against","the","ungodly"]},{"verseId":"brenton_proverbs_21_31","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":21,"verse":31,"text":"A horse is prepared for the day of battle; but help is of the Lord.","searchKeywords":["horse","prepared","for","the","day","battle","but","help","lord"]}]