[{"verseId":"brenton_proverbs_26_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":1,"text":"As dew in harvest, and as rain in summer, so honour is not for a fool.","searchKeywords":["dew","harvest","and","rain","summer","honour","not","for","fool"]},{"verseId":"brenton_proverbs_26_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":2,"text":"As birds and sparrows fly, so a curse shall not come upon any one without a cause.","searchKeywords":["birds","and","sparrows","fly","curse","shall","not","come","upon","any","one","without","cause"]},{"verseId":"brenton_proverbs_26_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":3,"text":"As a whip for a horse, and a goad for an ass, so a rod for a simple nation.","searchKeywords":["whip","for","horse","and","goad","ass","rod","simple","nation"]},{"verseId":"brenton_proverbs_26_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":4,"text":"Answer not a fool according to his folly, lest thou become like him.","searchKeywords":["answer","not","fool","according","his","folly","lest","thou","become","like","him"]},{"verseId":"brenton_proverbs_26_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":5,"text":"Yet answer a fool according to his folly, lest he seem wise in his own conceit.","searchKeywords":["yet","answer","fool","according","his","folly","lest","seem","wise","own","conceit"]},{"verseId":"brenton_proverbs_26_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":6,"text":"He that sends a message by a foolish messenger procures for himself a reproach from his own ways.","searchKeywords":["that","sends","message","foolish","messenger","procures","for","himself","reproach","from","his","own","ways"]},{"verseId":"brenton_proverbs_26_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":7,"text":"take away the motion of the legs, as transgression from the mouth of fools.","searchKeywords":["take","away","the","motion","legs","transgression","from","mouth","fools"]},{"verseId":"brenton_proverbs_26_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":8,"text":"He that binds up a stone in a sling, is like one that gives glory to a fool.","searchKeywords":["that","binds","stone","sling","like","one","gives","glory","fool"]},{"verseId":"brenton_proverbs_26_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":9,"text":"Thorns grow in the hand of a drunkard, and servitude in the hand of fools.","searchKeywords":["thorns","grow","the","hand","drunkard","and","servitude","fools"]},{"verseId":"brenton_proverbs_26_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":10,"text":"All the flesh of fools endures much hardship; for their fury is brought to nought.","searchKeywords":["all","the","flesh","fools","endures","much","hardship","for","their","fury","brought","nought"]},{"verseId":"brenton_proverbs_26_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":11,"text":"As when a dog goes to his own vomit, and becomes abominable, so is a fool who returns in his wickedness to his own sin. glory and grace.]","searchKeywords":["when","dog","goes","his","own","vomit","and","becomes","abominable","fool","who","returns","wickedness","sin","glory","grace"]},{"verseId":"brenton_proverbs_26_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":12,"text":"to himself to be wise; but a fool had more hope than he.","searchKeywords":["himself","wise","but","fool","had","more","hope","than"]},{"verseId":"brenton_proverbs_26_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":13,"text":"a lion in the ways, and murderers in the streets.","searchKeywords":["lion","the","ways","and","murderers","streets"]},{"verseId":"brenton_proverbs_26_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":16,"text":"most satisfactorily brings back a message.","searchKeywords":["most","satisfactorily","brings","back","message"]},{"verseId":"brenton_proverbs_26_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":18,"text":"words to men, and he that first falls in with the proposal will be overthrown;","searchKeywords":["words","men","and","that","first","falls","with","the","proposal","will","overthrown"]},{"verseId":"brenton_proverbs_26_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":22,"text":"to the inmost parts of the bowels.","searchKeywords":["the","inmost","parts","bowels"]},{"verseId":"brenton_proverbs_26_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":26,"verse":25,"text":"enemy intreat thee with a loud voice, consent not: for there are seven abominations in his heart.","searchKeywords":["enemy","intreat","thee","with","loud","voice","consent","not","for","there","are","seven","abominations","his","heart"]}]