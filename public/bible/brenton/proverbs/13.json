[{"verseId":"brenton_proverbs_13_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":13,"verse":1,"text":"A wise son is obedient to his father: but a disobedient son will be destroyed.","searchKeywords":["wise","son","obedient","his","father","but","disobedient","will","destroyed"]},{"verseId":"brenton_proverbs_13_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":13,"verse":2,"text":"A good shall eat of the fruits of righteousness: but the lives of transgressors shall perish before their time.","searchKeywords":["good","shall","eat","the","fruits","righteousness","but","lives","transgressors","perish","before","their","time"]},{"verseId":"brenton_proverbs_13_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":13,"verse":3,"text":"He that keeps his own mouth keeps his own life: but he that is hasty with his lips shall bring terror upon himself.","searchKeywords":["that","keeps","his","own","mouth","life","but","hasty","with","lips","shall","bring","terror","upon","himself"]},{"verseId":"brenton_proverbs_13_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":13,"verse":4,"text":"Every slothful man desires, but the hands of the active are diligent.","searchKeywords":["every","slothful","man","desires","but","the","hands","active","are","diligent"]},{"verseId":"brenton_proverbs_13_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":13,"verse":5,"text":"A righteous man hates an unjust word: but an ungodly man is ashamed, and will have no confidence.","searchKeywords":["righteous","man","hates","unjust","word","but","ungodly","ashamed","and","will","have","confidence"]},{"verseId":"brenton_proverbs_13_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":13,"verse":7,"text":"There are who, having nothing, enrich themselves: and there are who bring themselves down in much wealth.","searchKeywords":["there","are","who","having","nothing","enrich","themselves","and","bring","down","much","wealth"]},{"verseId":"brenton_proverbs_13_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":13,"verse":8,"text":"A man's own wealth is the ransom of his life: but the poor endures not threatening.","searchKeywords":["man","own","wealth","the","ransom","his","life","but","poor","endures","not","threatening"]},{"verseId":"brenton_proverbs_13_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":13,"verse":9,"text":"The righteous always have light: but the light of the ungodly is quenched.","searchKeywords":["the","righteous","always","have","light","but","ungodly","quenched"]},{"verseId":"brenton_proverbs_13_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":13,"verse":12,"text":"to hope: for a good desire is a tree of life.","searchKeywords":["hope","for","good","desire","tree","life"]},{"verseId":"brenton_proverbs_13_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":13,"verse":13,"text":".","searchKeywords":[]},{"verseId":"brenton_proverbs_13_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":13,"verse":24,"text":".","searchKeywords":[]},{"verseId":"brenton_proverbs_13_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":13,"verse":25,"text":"eats and satisfies his soul: but the souls of the ungodly are in want.","searchKeywords":["eats","and","satisfies","his","soul","but","the","souls","ungodly","are","want"]}]