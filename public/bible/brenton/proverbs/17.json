[{"verseId":"brenton_proverbs_17_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":17,"verse":1,"text":"Better is a morsel with pleasure in peace, than a house of many good things and unjust sacrifices, with strife.","searchKeywords":["better","morsel","with","pleasure","peace","than","house","many","good","things","and","unjust","sacrifices","strife"]},{"verseId":"brenton_proverbs_17_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":17,"verse":2,"text":"A wise servant shall have rule over foolish masters, and shall divide portions among brethren.","searchKeywords":["wise","servant","shall","have","rule","over","foolish","masters","and","divide","portions","among","brethren"]},{"verseId":"brenton_proverbs_17_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":17,"verse":3,"text":"As silver and gold are tried in a furnace, so are choice hearts with the Lord.","searchKeywords":["silver","and","gold","are","tried","furnace","choice","hearts","with","the","lord"]},{"verseId":"brenton_proverbs_17_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":17,"verse":4,"text":"A bad man hearkens to the tongue of transgressors: but a righteous man attends not to false lips.","searchKeywords":["bad","man","hearkens","the","tongue","transgressors","but","righteous","attends","not","false","lips"]},{"verseId":"brenton_proverbs_17_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":17,"verse":5,"text":"He that laughs at the poor provokes him that made him; and he that rejoices at the destruction of another shall not be held guiltless: but he that has compassion shall find mercy.","searchKeywords":["that","laughs","the","poor","provokes","him","made","and","rejoices","destruction","another","shall","not","held","guiltless","but","has","compassion","find","mercy"]},{"verseId":"brenton_proverbs_17_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":17,"verse":6,"text":"Children's children are the crown of old men; and their fathers are the glory of children.","searchKeywords":["children","are","the","crown","old","men","and","their","fathers","glory"]},{"verseId":"brenton_proverbs_17_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":17,"verse":9,"text":"separates friends and kindred.","searchKeywords":["separates","friends","and","kindred"]},{"verseId":"brenton_proverbs_17_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":17,"verse":18,"text":"also that becomes surety would make himself responsible for his own friends.","searchKeywords":["also","that","becomes","surety","would","make","himself","responsible","for","his","own","friends"]},{"verseId":"brenton_proverbs_17_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":17,"verse":20,"text":"comes not in for good. A man of a changeful tongue will fall into mischiefs;","searchKeywords":["comes","not","for","good","man","changeful","tongue","will","fall","into","mischiefs"]},{"verseId":"brenton_proverbs_17_23","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":17,"verse":23,"text":"bosom do not prosper; and an ungodly man perverts the ways of righteousness.","searchKeywords":["bosom","not","prosper","and","ungodly","man","perverts","the","ways","righteousness"]},{"verseId":"brenton_proverbs_17_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":17,"verse":24,"text":"to the ends of the earth.","searchKeywords":["the","ends","earth"]},{"verseId":"brenton_proverbs_17_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":17,"verse":25,"text":"anger to his father, and grief to her that bore him.","searchKeywords":["anger","his","father","and","grief","her","that","bore","him"]},{"verseId":"brenton_proverbs_17_26","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":17,"verse":26,"text":"not right to punish a righteous man, nor holy to plot against righteous princes.","searchKeywords":["not","right","punish","righteous","man","nor","holy","plot","against","princes"]}]