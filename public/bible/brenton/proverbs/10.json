[{"verseId":"brenton_proverbs_10_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":10,"verse":1,"text":"A wise son makes father glad: but a foolish son is a grief to his mother.","searchKeywords":["wise","son","makes","father","glad","but","foolish","grief","his","mother"]},{"verseId":"brenton_proverbs_10_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":10,"verse":2,"text":"Treasures shall not profit the lawless: but righteousness shall deliver from death.","searchKeywords":["treasures","shall","not","profit","the","lawless","but","righteousness","deliver","from","death"]},{"verseId":"brenton_proverbs_10_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":10,"verse":3,"text":"The Lord will not famish a righteous soul: but he will overthrow the life of the ungodly.","searchKeywords":["the","lord","will","not","famish","righteous","soul","but","overthrow","life","ungodly"]},{"verseId":"brenton_proverbs_10_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":10,"verse":4,"text":"Poverty brings a man low: but the hands of the vigorous make rich.","searchKeywords":["poverty","brings","man","low","but","the","hands","vigorous","make","rich"]},{"verseId":"brenton_proverbs_10_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":10,"verse":7,"text":"is extinguished.","searchKeywords":["extinguished"]},{"verseId":"brenton_proverbs_10_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":10,"verse":11,"text":"a fountain of life in the hand of a righteous man; but destruction shall cover the mouth of the ungodly.","searchKeywords":["fountain","life","the","hand","righteous","man","but","destru