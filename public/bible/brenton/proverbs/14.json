[{"verseId":"brenton_proverbs_14_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":1,"text":"Wise women build houses: but a foolish one digs down with her hands.","searchKeywords":["wise","women","build","houses","but","foolish","one","digs","down","with","her","hands"]},{"verseId":"brenton_proverbs_14_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":2,"text":"He that walks uprightly fears the Lord; but he that is perverse in his ways shall be dishonoured.","searchKeywords":["that","walks","uprightly","fears","the","lord","but","perverse","his","ways","shall","dishonoured"]},{"verseId":"brenton_proverbs_14_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":3,"text":"Out of the mouth of fools a rod of pride; but the lips of the wise preserve them.","searchKeywords":["out","the","mouth","fools","rod","pride","but","lips","wise","preserve","them"]},{"verseId":"brenton_proverbs_14_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":4,"text":"Where no oxen are, the cribs are clean; but where there is abundant produce, the strength of the ox is apparent.","searchKeywords":["where","oxen","are","the","cribs","clean","but","there","abundant","produce","strength","apparent"]},{"verseId":"brenton_proverbs_14_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":5,"text":"A faithful witness does not lie; but an unjust witness kindles falsehoods.","searchKeywords":["faithful","witness","does","not","lie","but","unjust","kindles","falsehoods"]},{"verseId":"brenton_proverbs_14_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":6,"text":"Thou shalt seek wisdom with bad men, and shalt not find it; but discretion is easily available with the prudent.","searchKeywords":["thou","shalt","seek","wisdom","with","bad","men","and","not","find","but","discretion","easily","available","the","prudent"]},{"verseId":"brenton_proverbs_14_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":7,"text":"All things are adverse to a foolish man; but wise lips are the weapons of discretion.","searchKeywords":["all","things","are","adverse","foolish","man","but","wise","lips","the","weapons","discretion"]},{"verseId":"brenton_proverbs_14_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":8,"text":"The wisdom of the prudent will understand their ways; but the folly of fools leads astray.","searchKeywords":["the","wisdom","prudent","will","understand","their","ways","but","folly","fools","leads","astray"]},{"verseId":"brenton_proverbs_14_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":9,"text":"The houses of transgressors will need purification; but the houses of the just are acceptable.","searchKeywords":["the","houses","transgressors","will","need","purification","but","just","are","acceptable"]},{"verseId":"brenton_proverbs_14_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":10,"text":"a man's mind is intelligent, his soul is sorrowful; and when he rejoices, he has no fellowship with pride.","searchKeywords":["man","mind","intelligent","his","soul","sorrowful","and","when","rejoices","has","fellowship","with","pride"]},{"verseId":"brenton_proverbs_14_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":11,"text":"The houses of ungodly men shall be utterly destroyed; but the tabernacles of them that walk uprightly shall stand.","searchKeywords":["the","houses","ungodly","men","shall","utterly","destroyed","but","tabernacles","them","that","walk","uprightly","stand"]},{"verseId":"brenton_proverbs_14_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":12,"text":"There is a way which seems to be right with men, but the ends of it reach to the depth of hell.","searchKeywords":["there","way","which","seems","right","with","men","but","the","ends","reach","depth","hell"]},{"verseId":"brenton_proverbs_14_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":13,"text":"Grief mingles not with mirth; and joy in the end comes to grief.","searchKeywords":["grief","mingles","not","with","mirth","and","joy","the","end","comes"]},{"verseId":"brenton_proverbs_14_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":14,"text":"A stout-hearted shall be filled with his own ways; and a good man with his own thoughts.","searchKeywords":["stout","hearted","shall","filled","with","his","own","ways","and","good","man","thoughts"]},{"verseId":"brenton_proverbs_14_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":15,"text":"The simple believes every word: but the prudent man betakes himself to after-thought.","searchKeywords":["the","simple","believes","every","word","but","prudent","man","betakes","himself","after","thought"]},{"verseId":"brenton_proverbs_14_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":16,"text":"A wise man fears, and departs from evil; but the fool trusts in himself, and joins himself with the transgressor.","searchKeywords":["wise","man","fears","and","departs","from","evil","but","the","fool","trusts","himself","joins","with","transgressor"]},{"verseId":"brenton_proverbs_14_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":17,"text":"A passionate man acts inconsiderately; but a sensible man bears up under many things.","searchKeywords":["passionate","man","acts","inconsiderately","but","sensible","bears","under","many","things"]},{"verseId":"brenton_proverbs_14_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":18,"text":"Fools shall have mischief for their portion; but the prudent shall take fast hold of understanding.","searchKeywords":["fools","shall","have","mischief","for","their","portion","but","the","prudent","take","fast","hold","understanding"]},{"verseId":"brenton_proverbs_14_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":19,"text":"Evil men shall fall before the good; and the ungodly shall attend at the gates of the righteous.","searchKeywords":["evil","men","shall","fall","before","the","good","and","ungodly","attend","gates","righteous"]},{"verseId":"brenton_proverbs_14_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":20,"text":"Friends will hate poor friends; but the friends of the rich are many.","searchKeywords":["friends","will","hate","poor","but","the","rich","are","many"]},{"verseId":"brenton_proverbs_14_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":21,"text":"He that dishonours the needy sins: but he that has pity on the poor is most blessed.","searchKeywords":["that","dishonours","the","needy","sins","but","has","pity","poor","most","blessed"]},{"verseId":"brenton_proverbs_14_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":22,"text":"They that go astray devise evils: but the good devise mercy and truth. The framers of evil do not understand mercy and truth: but compassion and faithfulness are with the framers of good.","searchKeywords":["they","that","astray","devise","evils","but","the","good","mercy","and","truth","framers","evil","not","understand","compassion","faithfulness","are","with"]},{"verseId":"brenton_proverbs_14_23","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":23,"text":"With every one careful there is abundance: but the pleasure-taking and indolent shall be in want.","searchKeywords":["with","every","one","careful","there","abundance","but","the","pleasure","taking","and","indolent","shall","want"]},{"verseId":"brenton_proverbs_14_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":24,"text":"A prudent man is the crown of the wise: but the occupation of fools is evil.","searchKeywords":["prudent","man","the","crown","wise","but","occupation","fools","evil"]},{"verseId":"brenton_proverbs_14_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":25,"text":"A faithful witness shall deliver a soul from evil: but a deceitful kindles falsehoods.","searchKeywords":["faithful","witness","shall","deliver","soul","from","evil","but","deceitful","kindles","falsehoods"]},{"verseId":"brenton_proverbs_14_26","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":26,"text":"In the fear of the Lord is strong confidence: and he leaves his children a support.","searchKeywords":["the","fear","lord","strong","confidence","and","leaves","his","children","support"]},{"verseId":"brenton_proverbs_14_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":27,"text":"The commandment of the Lord is a fountain of life; and it causes to turn aside from the snare of death.","searchKeywords":["the","commandment","lord","fountain","life","and","causes","turn","aside","from","snare","death"]},{"verseId":"brenton_proverbs_14_28","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":28,"text":"In a populous nation is the glory of a king: but in the failure of people is the ruin of a prince.","searchKeywords":["populous","nation","the","glory","king","but","failure","people","ruin","prince"]},{"verseId":"brenton_proverbs_14_29","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":29,"text":"A man slow to wrath abounds in wisdom: but a man of impatient spirit is very foolish.","searchKeywords":["man","slow","wrath","abounds","wisdom","but","impatient","spirit","very","foolish"]},{"verseId":"brenton_proverbs_14_30","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":30,"text":"A meek-spirited man is a healer of the heart: but a sensitive heart is a corruption of the bones.","searchKeywords":["meek","spirited","man","healer","the","heart","but","sensitive","corruption","bones"]},{"verseId":"brenton_proverbs_14_31","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":31,"text":"He that oppresses the needy provokes his Maker: but he that honours him has pity upon the poor.","searchKeywords":["that","oppresses","the","needy","provokes","his","maker","but","honours","him","has","pity","upon","poor"]},{"verseId":"brenton_proverbs_14_32","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":32,"text":"The ungodly shall be driven away in his wickedness: but he who is secure in his own holiness is just.","searchKeywords":["the","ungodly","shall","driven","away","his","wickedness","but","who","secure","own","holiness","just"]},{"verseId":"brenton_proverbs_14_33","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":33,"text":"There is wisdom in the good heart of a man: but in the heart of fools it is not discerned.","searchKeywords":["there","wisdom","the","good","heart","man","but","fools","not","discerned"]},{"verseId":"brenton_proverbs_14_34","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":34,"text":"Righteousness exalts a nation: but sins diminish tribes.","searchKeywords":["righteousness","exalts","nation","but","sins","diminish","tribes"]},{"verseId":"brenton_proverbs_14_35","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":14,"verse":35,"text":"An understanding servant is acceptable to a king; and by his good behaviour he removes disgrace.","searchKeywords":["understanding","servant","acceptable","king","and","his","good","behaviour","removes","disgrace"]}]