[{"verseId":"brenton_proverbs_20_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":1,"text":"Wine is an intemperate thing, and strong drink full of violence: but every fool is entangled with them.","searchKeywords":["wine","intemperate","thing","and","strong","drink","full","violence","but","every","fool","entangled","with","them"]},{"verseId":"brenton_proverbs_20_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":2,"text":"The threat of a king differs not from the rage of a lion; and he that provokes him sins against his own soul.","searchKeywords":["the","threat","king","differs","not","from","rage","lion","and","that","provokes","him","sins","against","his","own","soul"]},{"verseId":"brenton_proverbs_20_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":3,"text":"a glory to a man to turn aside from railing; but every fool is entangled with such matters.","searchKeywords":["glory","man","turn","aside","from","railing","but","every","fool","entangled","with","such","matters"]},{"verseId":"brenton_proverbs_20_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":4,"text":"A sluggard when reproached is not ashamed: so also he who borrows corn in harvest.","searchKeywords":["sluggard","when","reproached","not","ashamed","also","who","borrows","corn","harvest"]},{"verseId":"brenton_proverbs_20_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":5,"text":"Counsel in a man's heart is deep water; but a prudent man will draw it out.","searchKeywords":["counsel","man","heart","deep","water","but","prudent","will","draw","out"]},{"verseId":"brenton_proverbs_20_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":6,"text":"A man is valuable, and a merciful man precious: but hard to find a faithful man.","searchKeywords":["man","valuable","and","merciful","precious","but","hard","find","faithful"]},{"verseId":"brenton_proverbs_20_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":7,"text":"He that walks blameless in justice, shall leave his children blessed.","searchKeywords":["that","walks","blameless","justice","shall","leave","his","children","blessed"]},{"verseId":"brenton_proverbs_20_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":8,"text":"Whenever a righteous king sits on the throne, no evil thing can stand before his presence.","searchKeywords":["whenever","righteous","king","sits","the","throne","evil","thing","can","stand","before","his","presence"]},{"verseId":"brenton_proverbs_20_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":9,"text":"Who will boast that he has a pure heart? or who will boldly say that he is pure from sins?","searchKeywords":["who","will","boast","that","has","pure","heart","boldly","say","from","sins"]},{"verseId":"brenton_proverbs_20_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":10,"text":"divers measures, are even both of them unclean before the Lord; and he that makes them.","searchKeywords":["divers","measures","are","even","both","them","unclean","before","the","lord","and","that","makes"]},{"verseId":"brenton_proverbs_20_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":11,"text":"with a godly man, will be restrained in his devices, and his way will be straight.","searchKeywords":["with","godly","man","will","restrained","his","devices","and","way","straight"]},{"verseId":"brenton_proverbs_20_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":25,"text":"repentance comes after vowing.","searchKeywords":["repentance","comes","after","vowing"]},{"verseId":"brenton_proverbs_20_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":27,"text":"spirit of man is a light of the Lord, who searches the inmost parts of the belly.","searchKeywords":["spirit","man","light","the","lord","who","searches","inmost","parts","belly"]},{"verseId":"brenton_proverbs_20_29","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":29,"text":"are the glory of old men.","searchKeywords":["are","the","glory","old","men"]},{"verseId":"brenton_proverbs_20_30","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":20,"verse":30,"text":"into the inward parts of belly.","searchKeywords":["into","the","inward","parts","belly"]}]