[{"verseId":"brenton_proverbs_1_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":1,"text":"Proverbs of Solomon son of David, who reigned in Israel;","searchKeywords":["proverbs","solomon","son","david","who","reigned","israel"]},{"verseId":"brenton_proverbs_1_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":2,"text":"to know wisdom and instruction, and to perceive words of understanding;","searchKeywords":["know","wisdom","and","instruction","perceive","words","understanding"]},{"verseId":"brenton_proverbs_1_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":3,"text":"to receive also hard sayings, and to understand true justice, and to direct judgment;","searchKeywords":["receive","also","hard","sayings","and","understand","true","justice","direct","judgment"]},{"verseId":"brenton_proverbs_1_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":4,"text":"that he might give subtlety to the simple, and to the young man discernment and understanding.","searchKeywords":["that","might","give","subtlety","the","simple","and","young","man","discernment","understanding"]},{"verseId":"brenton_proverbs_1_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":5,"text":"For by the hearing of these a wise man will be wiser, and the man of understanding will gain direction;","searchKeywords":["for","the","hearing","these","wise","man","will","wiser","and","understanding","gain","direction"]},{"verseId":"brenton_proverbs_1_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":6,"text":"and will understand a parable, and a dark speech; the sayings of the wise also, and riddles.","searchKeywords":["and","will","understand","parable","dark","speech","the","sayings","wise","also","riddles"]},{"verseId":"brenton_proverbs_1_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":7,"text":"The fear of the Lord is the beginning of wisdom; and good understanding to all that practise it: and piety toward God is the beginning of discernment; but the ungodly will set at nought wisdom and instruction.","searchKeywords":["the","fear","lord","beginning","wisdom","and","good","understanding","all","that","practise","piety","toward","god","discernment","but","ungodly","will","set","nought","instruction"]},{"verseId":"brenton_proverbs_1_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":8,"text":"Hear, son, the instruction of thy father, and reject not the rules of thy mother.","searchKeywords":["hear","son","the","instruction","thy","father","and","reject","not","rules","mother"]},{"verseId":"brenton_proverbs_1_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":9,"text":"For thou shalt receive for thine head a crown of graces, and a chain of gold round thy neck.","searchKeywords":["for","thou","shalt","receive","thine","head","crown","graces","and","chain","gold","round","thy","neck"]},{"verseId":"brenton_proverbs_1_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":10,"text":"son, let not ungodly men lead thee astray, neither consent thou .","searchKeywords":["son","let","not","ungodly","men","lead","thee","astray","neither","consent","thou"]},{"verseId":"brenton_proverbs_1_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":11,"text":"If they should exhort thee, saying, Come with us, partake in blood, and let us unjustly hide the just man in the earth:","searchKeywords":["they","should","exhort","thee","saying","come","with","partake","blood","and","let","unjustly","hide","the","just","man","earth"]},{"verseId":"brenton_proverbs_1_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":12,"text":"and let us swallow him alive, as Hades , and remove the memorial of him from the earth:","searchKeywords":["and","let","swallow","him","alive","hades","remove","the","memorial","from","earth"]},{"verseId":"brenton_proverbs_1_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":13,"text":"let us seize on his valuable property, and let us fill our houses with spoils:","searchKeywords":["let","seize","his","valuable","property","and","fill","our","houses","with","spoils"]},{"verseId":"brenton_proverbs_1_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":14,"text":"but do thou cast in thy lot with us, and let us all provide a common purse, and let us have one pouch:","searchKeywords":["but","thou","cast","thy","lot","with","and","let","all","provide","common","purse","have","one","pouch"]},{"verseId":"brenton_proverbs_1_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":15,"text":"go not in the way with them, but turn aside thy foot from their paths:","searchKeywords":["not","the","way","with","them","but","turn","aside","thy","foot","from","their","paths"]},{"verseId":"brenton_proverbs_1_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":17,"text":"for nets are not without cause spread for birds.","searchKeywords":["for","nets","are","not","without","cause","spread","birds"]},{"verseId":"brenton_proverbs_1_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":18,"text":"For they that are concerned in murder store up evils for themselves; and the overthrow of transgressors is evil.","searchKeywords":["for","they","that","are","concerned","murder","store","evils","themselves","and","the","overthrow","transgressors","evil"]},{"verseId":"brenton_proverbs_1_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":19,"text":"These are the ways of all that perform lawless deeds; for by ungodliness they destroy their own life.","searchKeywords":["these","are","the","ways","all","that","perform","lawless","deeds","for","ungodliness","they","destroy","their","own","life"]},{"verseId":"brenton_proverbs_1_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":20,"text":"Wisdom sings aloud in passages, and in the broad places speaks boldly.","searchKeywords":["wisdom","sings","aloud","passages","and","the","broad","places","speaks","boldly"]},{"verseId":"brenton_proverbs_1_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":21,"text":"And she makes proclamation on the top of the walls, and sits by the gates of princes; and at the gates of the city boldly says,","searchKeywords":["and","she","makes","proclamation","the","top","walls","sits","gates","princes","city","boldly","says"]},{"verseId":"brenton_proverbs_1_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":22,"text":"So long as the simple cleave to justice, they shall not be ashamed: but the foolish being lovers of haughtiness, having become ungodly have hated knowledge, and are become subject to reproofs.","searchKeywords":["long","the","simple","cleave","justice","they","shall","not","ashamed","but","foolish","being","lovers","haughtiness","having","become","ungodly","have","hated","knowledge","and","are","subject","reproofs"]},{"verseId":"brenton_proverbs_1_23","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":23,"text":"Behold, I will bring forth to you the utterance of my breath, and I will instruct you in my speech.","searchKeywords":["behold","will","bring","forth","you","the","utterance","breath","and","instruct","speech"]},{"verseId":"brenton_proverbs_1_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":24,"text":"Since I called, and ye did not hearken; and I spoke at length, and ye gave no heed;","searchKeywords":["since","called","and","did","not","hearken","spoke","length","gave","heed"]},{"verseId":"brenton_proverbs_1_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":25,"text":"but ye set at nought my counsels, and disregarded my reproofs;","searchKeywords":["but","set","nought","counsels","and","disregarded","reproofs"]},{"verseId":"brenton_proverbs_1_26","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":26,"text":"therefore I also will laugh at your destruction; and I will rejoice against when ruin comes upon you:","searchKeywords":["therefore","also","will","laugh","your","destruction","and","rejoice","against","when","ruin","comes","upon","you"]},{"verseId":"brenton_proverbs_1_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":27,"text":"yea when dismay suddenly comes upon you, and overthrow shall arrive like a tempest; and when tribulation and distress shall come upon you, or when ruin shall come upon you.","searchKeywords":["yea","when","dismay","suddenly","comes","upon","you","and","overthrow","shall","arrive","like","tempest","tribulation","distress","come","ruin"]},{"verseId":"brenton_proverbs_1_28","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":28,"text":"For it shall be that when ye call upon me, I will not hearken to you: wicked men shall seek me, but shall not find .","searchKeywords":["for","shall","that","when","call","upon","will","not","hearken","you","wicked","men","seek","but","find"]},{"verseId":"brenton_proverbs_1_29","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":29,"text":"For they hated wisdom, and did not choose the word of the Lord:","searchKeywords":["for","they","hated","wisdom","and","did","not","choose","the","word","lord"]},{"verseId":"brenton_proverbs_1_30","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":30,"text":"neither would they attend to my counsels, but derided my reproofs.","searchKeywords":["neither","would","they","attend","counsels","but","derided","reproofs"]},{"verseId":"brenton_proverbs_1_31","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":31,"text":"Therefore shall they eat the fruits of their own way, and shall be filled with their own ungodliness.","searchKeywords":["therefore","shall","they","eat","the","fruits","their","own","way","and","filled","with","ungodliness"]},{"verseId":"brenton_proverbs_1_32","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":32,"text":"For because they wronged the simple, they shall be slain; and an inquisition shall ruin the ungodly.","searchKeywords":["for","because","they","wronged","the","simple","shall","slain","and","inquisition","ruin","ungodly"]},{"verseId":"brenton_proverbs_1_33","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":1,"verse":33,"text":"But he that hearkens to me shall dwell in confidence, and shall rest securely from all evil.","searchKeywords":["but","that","hearkens","shall","dwell","confidence","and","rest","securely","from","all","evil"]}]