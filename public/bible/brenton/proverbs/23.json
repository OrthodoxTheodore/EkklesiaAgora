[{"verseId":"brenton_proverbs_23_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":1,"text":"If thou sit to sup at the table of a prince, consider attentively the things set before thee:","searchKeywords":["thou","sit","sup","the","table","prince","consider","attentively","things","set","before","thee"]},{"verseId":"brenton_proverbs_23_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":2,"text":"and apply thine hand, knowing that it behoves thee to prepare such : but if thou art very insatiable,","searchKeywords":["and","apply","thine","hand","knowing","that","behoves","thee","prepare","such","but","thou","art","very","insatiable"]},{"verseId":"brenton_proverbs_23_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":3,"text":"desire not his provisions; for these belong to a false life.","searchKeywords":["desire","not","his","provisions","for","these","belong","false","life"]},{"verseId":"brenton_proverbs_23_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":4,"text":"If thou art poor, measure not thyself with a rich man; but refrain thyself in thy wisdom.","searchKeywords":["thou","art","poor","measure","not","thyself","with","rich","man","but","refrain","thy","wisdom"]},{"verseId":"brenton_proverbs_23_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":5,"text":"If thou shouldest fix thine eye upon him, he will disappear; for wings like an eagle's are prepared for him, and he returns to the house of his master.","searchKeywords":["thou","shouldest","fix","thine","eye","upon","him","will","disappear","for","wings","like","eagle","are","prepared","and","returns","the","house","his","master"]},{"verseId":"brenton_proverbs_23_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":6,"text":"Sup not with an envious man, neither desire thou his meats:","searchKeywords":["sup","not","with","envious","man","neither","desire","thou","his","meats"]},{"verseId":"brenton_proverbs_23_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":7,"text":"so he eats and drinks as if any one should swallow a hair, and do not bring him in to thyself, nor eat thy morsel with him:","searchKeywords":["eats","and","drinks","any","one","should","swallow","hair","not","bring","him","thyself","nor","eat","thy","morsel","with"]},{"verseId":"brenton_proverbs_23_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":8,"text":"for he will vomit it up, and spoil thy fair words.","searchKeywords":["for","will","vomit","and","spoil","thy","fair","words"]},{"verseId":"brenton_proverbs_23_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":9,"text":"Say nothing in the ears of a fool, lest at any time he sneer at thy wise words.","searchKeywords":["say","nothing","the","ears","fool","lest","any","time","sneer","thy","wise","words"]},{"verseId":"brenton_proverbs_23_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":10,"text":"Remove not the ancient landmarks; and enter not upon the possession of the fatherless:","searchKeywords":["remove","not","the","ancient","landmarks","and","enter","upon","possession","fatherless"]},{"verseId":"brenton_proverbs_23_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":11,"text":"for the Lord is their redeemer; he is mighty, and will plead their cause with thee.","searchKeywords":["for","the","lord","their","redeemer","mighty","and","will","plead","cause","with","thee"]},{"verseId":"brenton_proverbs_23_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":12,"text":"Apply thine heart to instruction, and prepare thine ears for words of discretion.","searchKeywords":["apply","thine","heart","instruction","and","prepare","ears","for","words","discretion"]},{"verseId":"brenton_proverbs_23_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":13,"text":"Refrain not from chastening a child; for if thou beat him with the rod, he shall not die.","searchKeywords":["refrain","not","from","chastening","child","for","thou","beat","him","with","the","rod","shall","die"]},{"verseId":"brenton_proverbs_23_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":14,"text":"For thou shalt beat him with the rod, and shalt deliver his soul from death.","searchKeywords":["for","thou","shalt","beat","him","with","the","rod","and","deliver","his","soul","from","death"]},{"verseId":"brenton_proverbs_23_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":15,"text":"Son, if thy heart be wise, thou shalt also gladden my heart;","searchKeywords":["son","thy","heart","wise","thou","shalt","also","gladden"]},{"verseId":"brenton_proverbs_23_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":16,"text":"and thy lips shall converse with my lips, if they be right.","searchKeywords":["and","thy","lips","shall","converse","with","they","right"]},{"verseId":"brenton_proverbs_23_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":17,"text":"Let not thine heart envy sinners: but be thou in the fear of the Lord all the day.","searchKeywords":["let","not","thine","heart","envy","sinners","but","thou","the","fear","lord","all","day"]},{"verseId":"brenton_proverbs_23_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":18,"text":"For if thou shouldest keep these things, thou shalt have posterity; and thine hope shall not be removed.","searchKeywords":["for","thou","shouldest","keep","these","things","shalt","have","posterity","and","thine","hope","shall","not","removed"]},{"verseId":"brenton_proverbs_23_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":19,"text":"Hear, son, and be wise, and rightly direct the thoughts of thine heart.","searchKeywords":["hear","son","and","wise","rightly","direct","the","thoughts","thine","heart"]},{"verseId":"brenton_proverbs_23_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":20,"text":"Be not a wine-bibber, neither continue long at feasts, and purchases of flesh:","searchKeywords":["not","wine","bibber","neither","continue","long","feasts","and","purchases","flesh"]},{"verseId":"brenton_proverbs_23_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":21,"text":"for every drunkard and whoremonger shall be poor; and every sluggard shall clothe himself with tatters and ragged garments.","searchKeywords":["for","every","drunkard","and","whoremonger","shall","poor","sluggard","clothe","himself","with","tatters","ragged","garments"]},{"verseId":"brenton_proverbs_23_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":22,"text":"Hearken, son, to thy father which begot thee, and despise not because she is grown old.","searchKeywords":["hearken","son","thy","father","which","begot","thee","and","despise","not","because","she","grown","old"]},{"verseId":"brenton_proverbs_23_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":24,"text":"A righteous father brings up well; and his soul rejoices over a wise son.","searchKeywords":["righteous","father","brings","well","and","his","soul","rejoices","over","wise","son"]},{"verseId":"brenton_proverbs_23_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":25,"text":"Let thy father and thy mother rejoice over thee, and let her that bore thee be glad.","searchKeywords":["let","thy","father","and","mother","rejoice","over","thee","her","that","bore","glad"]},{"verseId":"brenton_proverbs_23_26","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":26,"text":"son, give me thine heart, and let thine eyes observe my ways.","searchKeywords":["son","give","thine","heart","and","let","eyes","observe","ways"]},{"verseId":"brenton_proverbs_23_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":27,"text":"For a strange house is a vessel full of holes; and a strange well is narrow.","searchKeywords":["for","strange","house","vessel","full","holes","and","well","narrow"]},{"verseId":"brenton_proverbs_23_28","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":28,"text":"For such a one shall perish suddenly; and every transgressor shall be cut off.","searchKeywords":["for","such","one","shall","perish","suddenly","and","every","transgressor","cut","off"]},{"verseId":"brenton_proverbs_23_29","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":29,"text":"Who woe? who trouble? who quarrels? and who vexations and disputes? who bruises without a cause? whose eyes are livid?","searchKeywords":["who","woe","trouble","quarrels","and","vexations","disputes","bruises","without","cause","whose","eyes","are","livid"]},{"verseId":"brenton_proverbs_23_30","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":30,"text":"Are not those of them that stay long at wine? not of them that haunt where banquets are? Be not drunk with wine; but converse with just men, and converse openly.","searchKeywords":["are","not","those","them","that","stay","long","wine","haunt","where","banquets","drunk","with","but","converse","just","men","and","openly"]},{"verseId":"brenton_proverbs_23_31","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":31,"text":"For if thou shouldest set thine eyes on bowls and cups, thou shalt afterwards go more naked than a pestle.","searchKeywords":["for","thou","shouldest","set","thine","eyes","bowls","and","cups","shalt","afterwards","more","naked","than","pestle"]},{"verseId":"brenton_proverbs_23_32","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":32,"text":"But at last stretches himself out as one smitten by a serpent, and venom is diffused through him as by a horned serpent.","searchKeywords":["but","last","stretches","himself","out","one","smitten","serpent","and","venom","diffused","through","him","horned"]},{"verseId":"brenton_proverbs_23_33","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":33,"text":"Whenever thine eyes shall behold a strange woman, then thy mouth shall speak perverse things.","searchKeywords":["whenever","thine","eyes","shall","behold","strange","woman","then","thy","mouth","speak","perverse","things"]},{"verseId":"brenton_proverbs_23_34","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":34,"text":"And thou shalt lie as in the midst of the sea, and as a pilot in a great storm.","searchKeywords":["and","thou","shalt","lie","the","midst","sea","pilot","great","storm"]},{"verseId":"brenton_proverbs_23_35","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":23,"verse":35,"text":"And thou shalt say, They smote me, and I was not pained; and they mocked me, and I knew it not: when will it be morning, that I may go and seek those with whom I may go in company?","searchKeywords":["and","thou","shalt","say","they","smote","was","not","pained","mocked","knew","when","will","morning","that","may","seek","those","with","whom","company"]}]