[{"verseId":"brenton_proverbs_29_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":1,"text":"A reprover is better than a stiff-necked man: for when the latter is suddenly set on fire, there shall be no remedy.","searchKeywords":["reprover","better","than","stiff","necked","man","for","when","the","latter","suddenly","set","fire","there","shall","remedy"]},{"verseId":"brenton_proverbs_29_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":2,"text":"When the righteous are praised, the people will rejoice: but when the ungodly rule, men mourn.","searchKeywords":["when","the","righteous","are","praised","people","will","rejoice","but","ungodly","rule","men","mourn"]},{"verseId":"brenton_proverbs_29_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":3,"text":"When a man loves wisdom, his father rejoices: but he that keeps harlots will waste wealth.","searchKeywords":["when","man","loves","wisdom","his","father","rejoices","but","that","keeps","harlots","will","waste","wealth"]},{"verseId":"brenton_proverbs_29_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":4,"text":"A righteous king establishes a country: but a transgressor destroys .","searchKeywords":["righteous","king","establishes","country","but","transgressor","destroys"]},{"verseId":"brenton_proverbs_29_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":5,"text":"He that prepares a net in the way of his own friend, entangles his own feet in it.","searchKeywords":["that","prepares","net","the","way","his","own","friend","entangles","feet"]},{"verseId":"brenton_proverbs_29_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":6,"text":"A great snare for a sinner: but the righteous shall be in joy and gladness.","searchKeywords":["great","snare","for","sinner","but","the","righteous","shall","joy","and","gladness"]},{"verseId":"brenton_proverbs_29_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":7,"text":"A righteous man knows how to judge for the poor: but the ungodly understands not knowledge; and the poor man has not an understanding mind.","searchKeywords":["righteous","man","knows","how","judge","for","the","poor","but","ungodly","understands","not","knowledge","and","has","understanding","mind"]},{"verseId":"brenton_proverbs_29_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":8,"text":"Lawless men burn down a city: but wise men turn away wrath.","searchKeywords":["lawless","men","burn","down","city","but","wise","turn","away","wrath"]},{"verseId":"brenton_proverbs_29_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":9,"text":"A wise man shall judge nations: but a worthless man being angry laughs and fears not.","searchKeywords":["wise","man","shall","judge","nations","but","worthless","being","angry","laughs","and","fears","not"]},{"verseId":"brenton_proverbs_29_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":10,"text":"Bloody men hate a holy , but the upright will seek his soul.","searchKeywords":["bloody","men","hate","holy","but","the","upright","will","seek","his","soul"]},{"verseId":"brenton_proverbs_29_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":11,"text":"A fool utters all his mind: but the wise reserves his in part.","searchKeywords":["fool","utters","all","his","mind","but","the","wise","reserves","part"]},{"verseId":"brenton_proverbs_29_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":12,"text":"When a king hearkens to unjust language, all his subjects are transgressors.","searchKeywords":["when","king","hearkens","unjust","language","all","his","subjects","are","transgressors"]},{"verseId":"brenton_proverbs_29_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":13,"text":"When the creditor and debtor meet together, the Lord oversees them both.","searchKeywords":["when","the","creditor","and","debtor","meet","together","lord","oversees","them","both"]},{"verseId":"brenton_proverbs_29_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":14,"text":"When a king judges the poor in truth, his throne shall be established for a testimony.","searchKeywords":["when","king","judges","the","poor","truth","his","throne","shall","established","for","testimony"]},{"verseId":"brenton_proverbs_29_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":15,"text":"Stripes and reproofs give wisdom: but an erring child disgraces his parents.","searchKeywords":["stripes","and","reproofs","give","wisdom","but","erring","child","disgraces","his","parents"]},{"verseId":"brenton_proverbs_29_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":16,"text":"When the ungodly abound, sins abound: but when they fall, the righteous are warned.","searchKeywords":["when","the","ungodly","abound","sins","but","they","fall","righteous","are","warned"]},{"verseId":"brenton_proverbs_29_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":17,"text":"Chasten thy son, and he shall give thee rest; and he shall give honour to thy soul.","searchKeywords":["chasten","thy","son","and","shall","give","thee","rest","honour","soul"]},{"verseId":"brenton_proverbs_29_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":18,"text":"There shall be no interpreter to a sinful nation: but he that observes the law is blessed.","searchKeywords":["there","shall","interpreter","sinful","nation","but","that","observes","the","law","blessed"]},{"verseId":"brenton_proverbs_29_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":19,"text":"A stubborn servant will not be reproved by words: for even if he understand, still he will not obey.","searchKeywords":["stubborn","servant","will","not","reproved","words","for","even","understand","still","obey"]},{"verseId":"brenton_proverbs_29_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":20,"text":"If thou see a man hasty in words, know that the fool has hope rather than he.","searchKeywords":["thou","see","man","hasty","words","know","that","the","fool","has","hope","rather","than"]},{"verseId":"brenton_proverbs_29_21","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":21,"text":"He that lives wantonly from a child, shall be a servant, and in the end shall grieve over himself.","searchKeywords":["that","lives","wantonly","from","child","shall","servant","and","the","end","grieve","over","himself"]},{"verseId":"brenton_proverbs_29_22","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":22,"text":"A furious man stirs up strife, and a passionate man digs up sin.","searchKeywords":["furious","man","stirs","strife","and","passionate","digs","sin"]},{"verseId":"brenton_proverbs_29_23","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":23,"text":"Pride brings a man low, but the Lord upholds the humble-minded with honour.","searchKeywords":["pride","brings","man","low","but","the","lord","upholds","humble","minded","with","honour"]},{"verseId":"brenton_proverbs_29_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":24,"text":"He that shares with a thief, hates his own soul: and if any having heard an oath uttered tell not of it,","searchKeywords":["that","shares","with","thief","hates","his","own","soul","and","any","having","heard","oath","uttered","tell","not"]},{"verseId":"brenton_proverbs_29_25","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":25,"text":"fearing and reverencing men have been overthrown, but he that trusts in the Lord shall rejoice. Ungodliness causes a man to stumble: but he that trusts in his master shall be safe.","searchKeywords":["fearing","and","reverencing","men","have","been","overthrown","but","that","trusts","the","lord","shall","rejoice","ungodliness","causes","man","stumble","his","master","safe"]},{"verseId":"brenton_proverbs_29_26","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":26,"text":"Many wait on the favour of rulers; but justice comes to a man from the Lord.","searchKeywords":["many","wait","the","favour","rulers","but","justice","comes","man","from","lord"]},{"verseId":"brenton_proverbs_29_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":29,"verse":27,"text":"A righteous man is an abomination to an unrighteous man, and the direct way is an abomination to the sinner.","searchKeywords":["righteous","man","abomination","unrighteous","and","the","direct","way","sinner"]}]