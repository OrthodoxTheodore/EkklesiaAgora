[{"verseId":"brenton_proverbs_15_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":1,"text":"Anger slays even wise men; yet a submissive answer turns away wrath: but a grievous word stirs up anger.","searchKeywords":["anger","slays","even","wise","men","yet","submissive","answer","turns","away","wrath","but","grievous","word","stirs"]},{"verseId":"brenton_proverbs_15_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":2,"text":"The tongue of the wise knows what is good: but the mouth of the foolish tells out evil things.","searchKeywords":["the","tongue","wise","knows","what","good","but","mouth","foolish","tells","out","evil","things"]},{"verseId":"brenton_proverbs_15_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":3,"text":"The eyes of the Lord behold both the evil and the good in every place.","searchKeywords":["the","eyes","lord","behold","both","evil","and","good","every","place"]},{"verseId":"brenton_proverbs_15_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":4,"text":"The wholesome tongue is a tree of life, and he that keeps it shall be filled with understanding.","searchKeywords":["the","wholesome","tongue","tree","life","and","that","keeps","shall","filled","with","understanding"]},{"verseId":"brenton_proverbs_15_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":5,"text":"A fool scorns his father's instruction: but he that keeps his commandments is more prudent. In abounding righteousness is great strength: but the ungodly shall utterly perish from the earth.","searchKeywords":["fool","scorns","his","father","instruction","but","that","keeps","commandments","more","prudent","abounding","righteousness","great","strength","the","ungodly","shall","utterly","perish","from","earth"]},{"verseId":"brenton_proverbs_15_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":6,"text":"In the houses of the righteous is much strength: but the fruits of the ungodly shall perish.","searchKeywords":["the","houses","righteous","much","strength","but","fruits","ungodly","shall","perish"]},{"verseId":"brenton_proverbs_15_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":7,"text":"The lips of the wise are bound by discretion: but the hearts of the foolish are not safe.","searchKeywords":["the","lips","wise","are","bound","discretion","but","hearts","foolish","not","safe"]},{"verseId":"brenton_proverbs_15_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":8,"text":"The sacrifices of the ungodly are an abomination to the Lord; but the prayers of them that walk honestly are acceptable with him.","searchKeywords":["the","sacrifices","ungodly","are","abomination","lord","but","prayers","them","that","walk","honestly","acceptable","with","him"]},{"verseId":"brenton_proverbs_15_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":9,"text":"The ways of an ungodly are an abomination to the Lord; but he loves those that follow after righteousness.","searchKeywords":["the","ways","ungodly","are","abomination","lord","but","loves","those","that","follow","after","righteousness"]},{"verseId":"brenton_proverbs_15_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":10,"text":"The instruction of the simple is known by them that pass by; but they that hate reproofs die disgracefully.","searchKeywords":["the","instruction","simple","known","them","that","pass","but","they","hate","reproofs","die","disgracefully"]},{"verseId":"brenton_proverbs_15_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":11,"text":"Hell and destruction are manifest to the Lord; how shall not also be the hearts of men?","searchKeywords":["hell","and","destruction","are","manifest","the","lord","how","shall","not","also","hearts","men"]},{"verseId":"brenton_proverbs_15_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":12,"text":"An uninstructed person will not love those that reprove him; neither will he associate with the wise.","searchKeywords":["uninstructed","person","will","not","love","those","that","reprove","him","neither","associate","with","the","wise"]},{"verseId":"brenton_proverbs_15_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":13,"text":"When the heart rejoices the countenance is cheerful; but when it is in sorrow, is sad.","searchKeywords":["when","the","heart","rejoices","countenance","cheerful","but","sorrow","sad"]},{"verseId":"brenton_proverbs_15_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":14,"text":"An upright heart seeks discretion; but the mouth of the uninstructed will experience evils.","searchKeywords":["upright","heart","seeks","discretion","but","the","mouth","uninstructed","will","experience","evils"]},{"verseId":"brenton_proverbs_15_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":15,"text":"The eyes of the wicked are always looking for evil things; but the good are always quiet.","searchKeywords":["the","eyes","wicked","are","always","looking","for","evil","things","but","good","quiet"]},{"verseId":"brenton_proverbs_15_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":16,"text":"Better is a small portion with the fear of the Lord, than great treasures without the fear .","searchKeywords":["better","small","portion","with","the","fear","lord","than","great","treasures","without"]},{"verseId":"brenton_proverbs_15_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":17,"text":"Better is an entertainment of herbs with friendliness and kindness, than a feast of calves, with enmity.","searchKeywords":["better","entertainment","herbs","with","friendliness","and","kindness","than","feast","calves","enmity"]},{"verseId":"brenton_proverbs_15_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":18,"text":"A passionate man stirs up strife; but slow to anger appeases even a rising one. up.","searchKeywords":["passionate","man","stirs","strife","but","slow","anger","appeases","even","rising","one"]},{"verseId":"brenton_proverbs_15_20","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":20,"text":"father; but a foolish son sneers at his mother.","searchKeywords":["father","but","foolish","son","sneers","his","mother"]},{"verseId":"brenton_proverbs_15_23","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":23,"text":"attend to counsel; neither will he say anything seasonable, or good for the common .","searchKeywords":["attend","counsel","neither","will","say","anything","seasonable","good","for","the","common"]},{"verseId":"brenton_proverbs_15_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":15,"verse":27,"text":"sins are purged away;] but by the fear of the Lord every one departs from evil.","searchKeywords":["sins","are","purged","away","but","the","fear","lord","every","one","departs","from","evil"]}]