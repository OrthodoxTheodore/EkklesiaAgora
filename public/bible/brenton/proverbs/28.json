[{"verseId":"brenton_proverbs_28_1","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":1,"text":"The ungodly flees when no one pursues: but the righteous is confident as a lion.","searchKeywords":["the","ungodly","flees","when","one","pursues","but","righteous","confident","lion"]},{"verseId":"brenton_proverbs_28_2","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":2,"text":"By reason of the sins of ungodly men quarrels arise; but a wise man will quell them.","searchKeywords":["reason","the","sins","ungodly","men","quarrels","arise","but","wise","man","will","quell","them"]},{"verseId":"brenton_proverbs_28_3","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":3,"text":"A bold man oppresses the poor by ungodly deeds. As an impetuous and unprofitable rain,","searchKeywords":["bold","man","oppresses","the","poor","ungodly","deeds","impetuous","and","unprofitable","rain"]},{"verseId":"brenton_proverbs_28_4","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":4,"text":"so they that forsake the law praise ungodliness; but they that love the law fortify themselves with a wall.","searchKeywords":["they","that","forsake","the","law","praise","ungodliness","but","love","fortify","themselves","with","wall"]},{"verseId":"brenton_proverbs_28_5","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":5,"text":"Evil men will not understand judgment: but they that seek the Lord will understand everything.","searchKeywords":["evil","men","will","not","understand","judgment","but","they","that","seek","the","lord","everything"]},{"verseId":"brenton_proverbs_28_6","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":6,"text":"A poor man walking in truth is better than a rich liar.","searchKeywords":["poor","man","walking","truth","better","than","rich","liar"]},{"verseId":"brenton_proverbs_28_7","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":7,"text":"A wise son keeps the law: but he that keeps up debauchery dishonours his father.","searchKeywords":["wise","son","keeps","the","law","but","that","debauchery","dishonours","his","father"]},{"verseId":"brenton_proverbs_28_8","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":8,"text":"He that increases his wealth by usuries and gains, gathers it for him that pities the poor.","searchKeywords":["that","increases","his","wealth","usuries","and","gains","gathers","for","him","pities","the","poor"]},{"verseId":"brenton_proverbs_28_9","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":9,"text":"He that turns away his ear from hearing the law, even he has made his prayer abominable.","searchKeywords":["that","turns","away","his","ear","from","hearing","the","law","even","has","made","prayer","abominable"]},{"verseId":"brenton_proverbs_28_10","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":10,"text":"He that causes upright men to err in an evil way, himself shall fall into destruction: transgressors also shall pass by prosperity, but shall not enter into it.","searchKeywords":["that","causes","upright","men","err","evil","way","himself","shall","fall","into","destruction","transgressors","also","pass","prosperity","but","not","enter"]},{"verseId":"brenton_proverbs_28_11","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":11,"text":"A rich man is wise in his own conceit; but an intelligent poor man will condemn him.","searchKeywords":["rich","man","wise","his","own","conceit","but","intelligent","poor","will","condemn","him"]},{"verseId":"brenton_proverbs_28_12","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":12,"text":"By reason of the help of righteous men great glory arises: but in the places of the ungodly men are caught.","searchKeywords":["reason","the","help","righteous","men","great","glory","arises","but","places","ungodly","are","caught"]},{"verseId":"brenton_proverbs_28_13","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":13,"text":"He that covers his own ungodliness shall not prosper: but he that blames shall be loved.","searchKeywords":["that","covers","his","own","ungodliness","shall","not","prosper","but","blames","loved"]},{"verseId":"brenton_proverbs_28_14","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":14,"text":"Blessed is the man who religiously fears always: but the hard of heart shall fall into mischiefs.","searchKeywords":["blessed","the","man","who","religiously","fears","always","but","hard","heart","shall","fall","into","mischiefs"]},{"verseId":"brenton_proverbs_28_15","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":15,"text":"A hungry lion and a thirsty wolf , who, being poor, rules over a poor nation.","searchKeywords":["hungry","lion","and","thirsty","wolf","who","being","poor","rules","over","nation"]},{"verseId":"brenton_proverbs_28_16","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":16,"text":"A king in need of revenues is a great oppressor: but he that hates injustice shall live a long time.","searchKeywords":["king","need","revenues","great","oppressor","but","that","hates","injustice","shall","live","long","time"]},{"verseId":"brenton_proverbs_28_17","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":17,"text":"He that becomes surety for a man charged with murder shall be an exile, and not in safety.","searchKeywords":["that","becomes","surety","for","man","charged","with","murder","shall","exile","and","not","safety"]},{"verseId":"brenton_proverbs_28_18","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":18,"text":".","searchKeywords":[]},{"verseId":"brenton_proverbs_28_19","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":19,"text":"bread: but he that follows idleness shall have plenty of poverty.","searchKeywords":["bread","but","that","follows","idleness","shall","have","plenty","poverty"]},{"verseId":"brenton_proverbs_28_24","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":24,"text":"He that casts off father or mother, and thinks he sins not; the same is partaker with an ungodly man.","searchKeywords":["that","casts","off","father","mother","and","thinks","sins","not","the","same","partaker","with","ungodly","man"]},{"verseId":"brenton_proverbs_28_27","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":27,"text":"shall be in great distress.","searchKeywords":["shall","great","distress"]},{"verseId":"brenton_proverbs_28_28","translationId":"brenton","testament":"OT","bookIndex":26,"bookName":"Proverbs","bookAbbrev":"proverbs","chapter":28,"verse":28,"text":"the righteous mourn: but in their destruction the righteous shall be multiplied.","searchKeywords":["the","righteous","mourn","but","their","destruction","shall","multiplied"]}]