[{"verseId":"brenton_ezra_10_1","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":1,"text":"So when Esdras prayed, and when he confessed, weeping and praying before the house of God, a very great assembly of Israel came together to him, men and women and youths; for the people wept, and wept aloud.","searchKeywords":["when","esdras","prayed","and","confessed","weeping","praying","before","the","house","god","very","great","assembly","israel","came","together","him","men","women","youths","for","people","wept","aloud"]},{"verseId":"brenton_ezra_10_2","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":2,"text":"And Sechenias the son of Jeel, of the sons of Elam, answered and said to Esdras, We have broken covenant with our God, and have taken strange wives of the nations of the land: yet now there is patience to Israel concerning this thing.","searchKeywords":["and","sechenias","the","son","jeel","sons","elam","answered","said","esdras","have","broken","covenant","with","our","god","taken","strange","wives","nations","land","yet","now","there","patience","israel","concerning","this","thing"]},{"verseId":"brenton_ezra_10_3","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":3,"text":"Now then let us make a covenant with our God to put away all the wives, and their offspring, as thou shalt advise:","searchKeywords":["now","then","let","make","covenant","with","our","god","put","away","all","the","wives","and","their","offspring","thou","shalt","advise"]},{"verseId":"brenton_ezra_10_4","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":4,"text":"arise, and alarm them with the commands of our God; and let be done according to the law. Rise up, for the matter upon thee; and we with thee: be strong and do.","searchKeywords":["arise","and","alarm","them","with","the","commands","our","god","let","done","according","law","rise","for","matter","upon","thee","strong"]},{"verseId":"brenton_ezra_10_5","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":5,"text":"Then Esdras arose, and caused the rulers, the priests, and Levites, and all Israel, to swear that they would do according to this word: and they swore.","searchKeywords":["then","esdras","arose","and","caused","the","rulers","priests","levites","all","israel","swear","that","they","would","according","this","word","swore"]},{"verseId":"brenton_ezra_10_6","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":6,"text":"And Esdras rose up from before the house of God, and went to the treasury of Joanan the son of Elisub; he even went thither: he ate no bread, and drank no water; for he mourned over the unfaithfulness of the captivity.","searchKeywords":["and","esdras","rose","from","before","the","house","god","went","treasury","joanan","son","elisub","even","thither","ate","bread","drank","water","for","mourned","over","unfaithfulness","captivity"]},{"verseId":"brenton_ezra_10_7","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":7,"text":"And they made proclamation throughout Juda and Jerusalem to all the children of the captivity, that they should assemble at Jerusalem, ,","searchKeywords":["and","they","made","proclamation","throughout","juda","jerusalem","all","the","children","captivity","that","should","assemble"]},{"verseId":"brenton_ezra_10_8","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":8,"text":"Every one who shall not arrive within three days, as the counsel of the rulers and the elders, all his substance shall be forfeited, and he shall be separated from the congregation of the captivity.","searchKeywords":["every","one","who","shall","not","arrive","within","three","days","the","counsel","rulers","and","elders","all","his","substance","forfeited","separated","from","congregation","captivity"]},{"verseId":"brenton_ezra_10_9","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":9,"text":"So all the men of Juda and Benjamin assembled at Jerusalem within the three days. This the ninth month: on the twentieth day of the month all the people sat down in the street of the house of the Lord, because of their alarm concerning the word, and because of the storm.","searchKeywords":["all","the","men","juda","and","benjamin","assembled","jerusalem","within","three","days","this","ninth","month","twentieth","day","people","sat","down","street","house","lord","because","their","alarm","concerning","word","storm"]},{"verseId":"brenton_ezra_10_10","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":10,"text":"And Esdras the priest arose, and said to them, Ye have broken covenant, and have taken strange wives, to add to the trespass of Israel.","searchKeywords":["and","esdras","the","priest","arose","said","them","have","broken","covenant","taken","strange","wives","add","trespass","israel"]},{"verseId":"brenton_ezra_10_11","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":11,"text":"Now therefore give praise to the Lord God of our fathers, and do that which is pleasing in his sight: and separate yourselves from the peoples of the land, and from the strange wives.","searchKeywords":["now","therefore","give","praise","the","lord","god","our","fathers","and","that","which","pleasing","his","sight","separate","yourselves","from","peoples","land","strange","wives"]},{"verseId":"brenton_ezra_10_12","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":12,"text":"Then all the congregation answered and said, This thy word powerful upon us to do it.","searchKeywords":["then","all","the","congregation","answered","and","said","this","thy","word","powerful","upon"]},{"verseId":"brenton_ezra_10_13","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":13,"text":"But the people numerous, and the season stormy, and there is no power to stand without, and the work is more than enough for one day or for two; for we have greatly sinned in this matter.","searchKeywords":["but","the","people","numerous","and","season","stormy","there","power","stand","without","work","more","than","enough","for","one","day","two","have","greatly","sinned","this","matter"]},{"verseId":"brenton_ezra_10_14","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":14,"text":"Let now our rulers stand, and for all those in our cities who have taken strange wives, let them come at appointed times, and with them elders from every several city, and judges, to turn away the fierce wrath of our God from us concerning this matter.","searchKeywords":["let","now","our","rulers","stand","and","for","all","those","cities","who","have","taken","strange","wives","them","come","appointed","times","with","elders","from","every","several","city","judges","turn","away","the","fierce","wrath","god","concerning","this","matter"]},{"verseId":"brenton_ezra_10_15","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":15,"text":"Only Jonathan the son of Asael, and Jazias the son of Thecoe with me concerning this; and Mesollam, and Sabbathai the Levite helped them.","searchKeywords":["only","jonathan","the","son","asael","and","jazias","thecoe","with","concerning","this","mesollam","sabbathai","levite","helped","them"]},{"verseId":"brenton_ezra_10_16","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":16,"text":"And the children of the captivity did thus: and Esdras the priest, and heads of families according to house were separated, and all by their names, for they returned in the first day of the tenth month to search out the matter.","searchKeywords":["and","the","children","captivity","did","thus","esdras","priest","heads","families","according","house","were","separated","all","their","names","for","they","returned","first","day","tenth","month","search","out","matter"]},{"verseId":"brenton_ezra_10_17","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":17,"text":"And they made an end with all the men who had taken strange wives by the first day of the first month.","searchKeywords":["and","they","made","end","with","all","the","men","who","had","taken","strange","wives","first","day","month"]},{"verseId":"brenton_ezra_10_18","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":18,"text":"And there were found of the sons of the priests who had taken strange wives: of the sons of Jesus the son of Josedec, and his brethren; Maasia, and Eliezer, and Jarib, and Gadalia.","searchKeywords":["and","there","were","found","the","sons","priests","who","had","taken","strange","wives","jesus","son","josedec","his","brethren","maasia","eliezer","jarib","gadalia"]},{"verseId":"brenton_ezra_10_19","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":19,"text":"And they pledged themselves to put away their wives, and a ram of the flock for a trespass-offering because of their trespass.","searchKeywords":["and","they","pledged","themselves","put","away","their","wives","ram","the","flock","for","trespass","offering","because"]},{"verseId":"brenton_ezra_10_20","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":20,"text":"And of the sons of Emmer; Anani, and Zabdia.","searchKeywords":["and","the","sons","emmer","anani","zabdia"]},{"verseId":"brenton_ezra_10_21","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":21,"text":"And of the sons of Eram; Masael, and Elia, and Samaia, and Jeel, and Ozia.","searchKeywords":["and","the","sons","eram","masael","elia","samaia","jeel","ozia"]},{"verseId":"brenton_ezra_10_22","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":22,"text":"And of the sons of Phasur; Elionai, Maasia, and Ismael, and Nathanael, and Jozabad, and Elasa.","searchKeywords":["and","the","sons","phasur","elionai","maasia","ismael","nathanael","jozabad","elasa"]},{"verseId":"brenton_ezra_10_23","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":23,"text":"And of the Levites; Jozabad, and Samu, and Colia (he Colitas,) and Phetheia, and Judas, and Eliezer.","searchKeywords":["and","the","levites","jozabad","samu","colia","colitas","phetheia","judas","eliezer"]},{"verseId":"brenton_ezra_10_24","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":24,"text":"And of the singers; Elisab: and of the porters; Solmen, and Telmen, and Oduth.","searchKeywords":["and","the","singers","elisab","porters","solmen","telmen","oduth"]},{"verseId":"brenton_ezra_10_25","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":25,"text":"Also of Israel: of the sons of Phoros; Ramia, and Azia, and Melchia, and Meamin, and Eleazar, and Asabia, and Banaia.","searchKeywords":["also","israel","the","sons","phoros","ramia","and","azia","melchia","meamin","eleazar","asabia","banaia"]},{"verseId":"brenton_ezra_10_26","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":26,"text":"And of the sons of Helam; Matthania, and Zacharia, and Jaïel, and Abdia, and Jarimoth, and Elia.","searchKeywords":["and","the","sons","helam","matthania","zacharia","abdia","jarimoth","elia"]},{"verseId":"brenton_ezra_10_27","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":27,"text":"And of the sons of Zathua; Elionai, Elisub, Matthanai, and Armoth, and Zabad, and Oziza.","searchKeywords":["and","the","sons","zathua","elionai","elisub","matthanai","armoth","zabad","oziza"]},{"verseId":"brenton_ezra_10_28","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":28,"text":"And of the sons of Babei; Joanan, Anania, and Zabu, and Thali.","searchKeywords":["and","the","sons","babei","joanan","anania","zabu","thali"]},{"verseId":"brenton_ezra_10_29","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":29,"text":"And of the sons of Banui; Mosollam, Maluch, Adaias, Jasub, and Saluia, and Remoth.","searchKeywords":["and","the","sons","banui","mosollam","maluch","adaias","jasub","saluia","remoth"]},{"verseId":"brenton_ezra_10_30","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":30,"text":"And of the sons of Phaath Moab; Edne, and Chalel, and Banaia, Maasia, Matthania, Beseleel, and Banui, and Manasse.","searchKeywords":["and","the","sons","phaath","moab","edne","chalel","banaia","maasia","matthania","beseleel","banui","manasse"]},{"verseId":"brenton_ezra_10_31","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":31,"text":"And of the sons of Eram; Eliezer, Jesia, Melchia, Samaias, Semeon,","searchKeywords":["and","the","sons","eram","eliezer","jesia","melchia","samaias","semeon"]},{"verseId":"brenton_ezra_10_32","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":32,"text":"Benjamin, Baluch, Samaria.","searchKeywords":["benjamin","baluch","samaria"]},{"verseId":"brenton_ezra_10_33","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":33,"text":"And of the sons of Asem; Metthania, Matthatha, Zadab, Eliphalet, Jerami, Manasse, Semei.","searchKeywords":["and","the","sons","asem","metthania","matthatha","zadab","eliphalet","jerami","manasse","semei"]},{"verseId":"brenton_ezra_10_34","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":34,"text":"And of the sons of Bani; Moodia, Amram, Uel,","searchKeywords":["and","the","sons","bani","moodia","amram","uel"]},{"verseId":"brenton_ezra_10_35","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":35,"text":"Banaia, Badaia, Chelkia,","searchKeywords":["banaia","badaia","chelkia"]},{"verseId":"brenton_ezra_10_36","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":36,"text":"Uvania, Marimoth, Eliasiph,","searchKeywords":["uvania","marimoth","eliasiph"]},{"verseId":"brenton_ezra_10_37","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":37,"text":"Matthania, Matthanai:","searchKeywords":["matthania","matthanai"]},{"verseId":"brenton_ezra_10_38","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":38,"text":"and did the children of Banui, and the children of Semei,","searchKeywords":["and","did","the","children","banui","semei"]},{"verseId":"brenton_ezra_10_39","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":39,"text":"and Selemia, and Nathan, and Adaia,","searchKeywords":["and","selemia","nathan","adaia"]},{"verseId":"brenton_ezra_10_40","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":40,"text":"Machadnabu, Sesei, Sariu,","searchKeywords":["machadnabu","sesei","sariu"]},{"verseId":"brenton_ezra_10_41","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":41,"text":"Ezriel, and Selemia, and Samaria,","searchKeywords":["ezriel","and","selemia","samaria"]},{"verseId":"brenton_ezra_10_42","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":42,"text":"and Sellum, Amaria, Joseph.","searchKeywords":["and","sellum","amaria","joseph"]},{"verseId":"brenton_ezra_10_43","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":43,"text":"Of the sons of Nabu; Jael, Matthanias, Zabad, Zebennas, Jadai, and Joel, and Banaia.","searchKeywords":["the","sons","nabu","jael","matthanias","zabad","zebennas","jadai","and","joel","banaia"]},{"verseId":"brenton_ezra_10_44","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":10,"verse":44,"text":"All these had taken strange wives, and had begotten sons of them.","searchKeywords":["all","these","had","taken","strange","wives","and","begotten","sons","them"]}]