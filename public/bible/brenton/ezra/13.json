[{"verseId":"brenton_ezra_13_1","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":1,"text":"Then Eliasub the high priest, and his brethren the priests, rose up, and built the sheep-gate; they sanctified it, and set up the doors of it; even to the tower of the hundred they sanctified , to the tower of Anameel.","searchKeywords":["then","eliasub","the","high","priest","and","his","brethren","priests","rose","built","sheep","gate","they","sanctified","set","doors","even","tower","hundred","anameel"]},{"verseId":"brenton_ezra_13_2","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":2,"text":"And by the side of the men of Jericho, and by the side of the sons of Zacchur, the son of Amari.","searchKeywords":["and","the","side","men","jericho","sons","zacchur","son","amari"]},{"verseId":"brenton_ezra_13_3","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":3,"text":"And the sons of Asana built the fish-gate; they roofed it, and covered in its doors, and bolts, and bars.","searchKeywords":["and","the","sons","asana","built","fish","gate","they","roofed","covered","its","doors","bolts","bars"]},{"verseId":"brenton_ezra_13_4","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":4,"text":"And next to them reached to Ramoth the son of Uria, the son of Accos, and next to them Mosollam son of Barachias the son of Mazebel took place: and next to them Sadoc the son of Baana took place.","searchKeywords":["and","next","them","reached","ramoth","the","son","uria","accos","mosollam","barachias","mazebel","took","place","sadoc","baana"]},{"verseId":"brenton_ezra_13_5","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":5,"text":"And next to them the Thecoim took place; but the Adorim applied not their neck to their service.","searchKeywords":["and","next","them","the","thecoim","took","place","but","adorim","applied","not","their","neck","service"]},{"verseId":"brenton_ezra_13_6","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":6,"text":"And Joida the son of Phasec, and Mesulam son of Basodia, repaired the old gate; they covered it in, and set up its doors, and its bolts, and its bars.","searchKeywords":["and","joida","the","son","phasec","mesulam","basodia","repaired","old","gate","they","covered","set","its","doors","bolts","bars"]},{"verseId":"brenton_ezra_13_10","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":10,"text":"in front of his house: and next to him repaired Attuth son of Asabania.","searchKeywords":["front","his","house","and","next","him","repaired","attuth","son","asabania"]},{"verseId":"brenton_ezra_13_11","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":11,"text":"repaired Melchias son of Heram, and Asub son of Phaat Moab, even to the tower of the furnaces.","searchKeywords":["repaired","melchias","son","heram","and","asub","phaat","moab","even","the","tower","furnaces"]},{"verseId":"brenton_ezra_13_17","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":17,"text":"Raum the son of Bani: next to him repaired Asabia, ruler of half the district round about Keila, in his district.","searchKeywords":["raum","the","son","bani","next","him","repaired","asabia","ruler","half","district","round","about","keila","his"]},{"verseId":"brenton_ezra_13_23","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":23,"text":"near to his house.","searchKeywords":["near","his","house"]},{"verseId":"brenton_ezra_13_25","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":25,"text":"also the tower that projects from the king's house, even the upper one of the prison-house: and after him Phadæa the son of Phoros.","searchKeywords":["also","the","tower","that","projects","from","king","house","even","upper","one","prison","and","after","him","phad","son","phoros"]},{"verseId":"brenton_ezra_13_26","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":26,"text":"the projecting tower.","searchKeywords":["the","projecting","tower"]},{"verseId":"brenton_ezra_13_28","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":28,"text":"man over against his own house.","searchKeywords":["man","over","against","his","own","house"]},{"verseId":"brenton_ezra_13_32","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":32,"text":"the sheep-gate the smiths and chapmen repaired.","searchKeywords":["the","sheep","gate","smiths","and","chapmen","repaired"]},{"verseId":"brenton_ezra_13_34","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":34,"text":"the army of the Samaritans) that these Jews are building their city? do they indeed offer sacrifices? will they prevail? and will they this day restore the stones, after they have been burnt and made a heap of rubbish?","searchKeywords":["the","army","samaritans","that","these","jews","are","building","their","city","they","indeed","offer","sacrifices","will","prevail","and","this","day","restore","stones","after","have","been","burnt","made","heap","rubbish"]},{"verseId":"brenton_ezra_13_37","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":13,"verse":37,"text":"iniquity.","searchKeywords":["iniquity"]}]