[{"verseId":"brenton_ezra_22_1","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":22,"verse":1,"text":"Now these the priests and the Levites that went up with Zorobabel the son of Salathiel and Jesus: Saraia, Jeremia, Esdra,","searchKeywords":["now","these","the","priests","and","levites","that","went","with","zorobabel","son","salathiel","jesus","saraia","jeremia","esdra"]},{"verseId":"brenton_ezra_22_2","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":22,"verse":2,"text":"Amaria, Maluch,","searchKeywords":["amaria","maluch"]},{"verseId":"brenton_ezra_22_3","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":22,"verse":3,"text":"Sechenia.","searchKeywords":["sechenia"]},{"verseId":"brenton_ezra_22_7","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":22,"verse":7,"text":"These the chiefs of the priests, and their brethren in the days of Jesus.","searchKeywords":["these","the","chiefs","priests","and","their","brethren","days","jesus"]},{"verseId":"brenton_ezra_22_8","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":22,"verse":8,"text":"And the Levites , Jesus, Banui, Cadmiel, Sarabia, Jodae, Matthania: he over the bands, and his brethren","searchKeywords":["and","the","levites","jesus","banui","cadmiel","sarabia","jodae","matthania","over","bands","his","brethren"]},{"verseId":"brenton_ezra_22_9","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":22,"verse":9,"text":"to the daily courses.","searchKeywords":["the","daily","courses"]},{"verseId":"brenton_ezra_22_10","translationId":"brenton","testament":"OT","bookIndex":16,"bookName":"Ezra","bookAbbrev":"ezra","chapter":22,"verse":10,"text":"And Jesus begot Joakim, and Joakim begot Eliasib,