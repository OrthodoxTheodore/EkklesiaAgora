[{"verseId":"brenton_baruch_5_1","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":5,"verse":1,"text":"Put off, O Jerusalem, the garment of thy mourning and affliction, and put on the comeliness of the glory that cometh from God for ever.","searchKeywords":["put","off","jerusalem","the","garment","thy","mourning","and","affliction","comeliness","glory","that","cometh","from","god","for","ever"]},{"verseId":"brenton_baruch_5_2","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":5,"verse":2,"text":"Cast about thee a double garment of the righteousness which cometh from God; and set a diadem on thine head of the glory of the Everlasting.","searchKeywords":["cast","about","thee","double","garment","the","righteousness","which","cometh","from","god","and","set","diadem","thine","head","glory","everlasting"]},{"verseId":"brenton_baruch_5_3","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":5,"verse":3,"text":"For God will shew thy brightness unto every country under heaven.","searchKeywords":["for","god","will","shew","thy","brightness","unto","every","country","under","heaven"]},{"verseId":"brenton_baruch_5_4","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":5,"verse":4,"text":"For thy name shall be called of God for ever The peace of righteousness, and The glory of God's worship.","searchKeywords":["for","thy","name","shall","called","god","ever","the","peace","righteousness","and","glory","worship"]},{"verseId":"brenton_baruch_5_5","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":5,"verse":5,"text":"Arise, O Jerusalem, and stand on high, and look about toward the east, and behold thy children gathered from the west unto the east by the word of the Holy One, rejoicing in the remembrance of God.","searchKeywords":["arise","jerusalem","and","stand","high","look","about","toward","the","east","behold","thy","children","gathered","from","west","unto","word","holy","one","rejoicing","remembrance","god"]},{"verseId":"brenton_baruch_5_6","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":5,"verse":6,"text":"For they departed from thee on foot, and were led away of their enemies: but God bringeth them unto thee exalted with glory, as children of the kingdom.","searchKeywords":["for","they","departed","from","thee","foot","and","were","led","away","their","enemies","but","god","bringeth","them","unto","exalted","with","glory","children","the","kingdom"]},{"verseId":"brenton_baruch_5_7","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":5,"verse":7,"text":"For God hath appointed that every high hill, and banks of long continuance, should be cast down, and vallies filled up, to make even the ground, that Israel may go safely in the glory of God.","searchKeywords":["for","god","hath","appointed","that","every","high","hill","and","banks","long","continuance","should","cast","down","vallies","filled","make","even","the","ground","israel","may","safely","glory"]},{"verseId":"brenton_baruch_5_8","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":5,"verse":8,"text":"Moreover even the woods and every sweetsmelling tree shall overshadow Israel by the commandment of God.","searchKeywords":["moreover","even","the","woods","and","every","sweetsmelling","tree","shall","overshadow","israel","commandment","god"]},{"verseId":"brenton_baruch_5_9","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":5,"verse":9,"text":"For God shall lead Israel with joy in the light of his glory with the mercy and righteousness that cometh from him.","searchKeywords":["for","god","shall","lead","israel","with","joy","the","light","his","glory","mercy","and","righteousness","that","cometh","from","him"]}]