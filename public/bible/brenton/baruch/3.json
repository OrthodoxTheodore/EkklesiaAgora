[{"verseId":"brenton_baruch_3_1","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":1,"text":"O Lord Almighty, God of Israel, the soul in anguish, the troubled spirit, crieth unto thee.","searchKeywords":["lord","almighty","god","israel","the","soul","anguish","troubled","spirit","crieth","unto","thee"]},{"verseId":"brenton_baruch_3_2","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":2,"text":"Hear, O Lord, and have mercy; for thou art merciful: and have pity upon us, because we have sinned before thee.","searchKeywords":["hear","lord","and","have","mercy","for","thou","art","merciful","pity","upon","because","sinned","before","thee"]},{"verseId":"brenton_baruch_3_3","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":3,"text":"For thou endurest for ever, and we perish utterly.","searchKeywords":["for","thou","endurest","ever","and","perish","utterly"]},{"verseId":"brenton_baruch_3_4","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":4,"text":"O Lord Almighty, thou God of Israel, hear now the prayers of the dead Israelites, and of their children, which have sinned before thee, and not hearkened unto the voice of thee their God: for the which cause these plagues cleave unto us.","searchKeywords":["lord","almighty","thou","god","israel","hear","now","the","prayers","dead","israelites","and","their","children","which","have","sinned","before","thee","not","hearkened","unto","voice","for","cause","these","plagues","cleave"]},{"verseId":"brenton_baruch_3_5","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":5,"text":"Remember not the iniquities of our forefathers: but think upon thy power and thy name now at this time.","searchKeywords":["remember","not","the","iniquities","our","forefathers","but","think","upon","thy","power","and","name","now","this","time"]},{"verseId":"brenton_baruch_3_6","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":6,"text":"For thou art the Lord our God, and thee, O Lord, will we praise.","searchKeywords":["for","thou","art","the","lord","our","god","and","thee","will","praise"]},{"verseId":"brenton_baruch_3_7","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":7,"text":"And for this cause thou hast put thy fear in our hearts, to the intent that we should call upon thy name, and praise thee in our captivity: for we have called to mind all the iniquity of our forefathers, that sinned before thee.","searchKeywords":["and","for","this","cause","thou","hast","put","thy","fear","our","hearts","the","intent","that","should","call","upon","name","praise","thee","captivity","have","called","mind","all","iniquity","forefathers","sinned","before"]},{"verseId":"brenton_baruch_3_8","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":8,"text":"Behold, we are yet this day in our captivity, where thou hast scattered us, for a reproach and a curse, and to be subject to payments, according to all the iniquities of our fathers, which departed from the Lord our God.","searchKeywords":["behold","are","yet","this","day","our","captivity","where","thou","hast","scattered","for","reproach","and","curse","subject","payments","according","all","the","iniquities","fathers","which","departed","from","lord","god"]},{"verseId":"brenton_baruch_3_9","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":9,"text":"Hear, Israel, the commandments of life: give ear to understand wisdom.","searchKeywords":["hear","israel","the","commandments","life","give","ear","understand","wisdom"]},{"verseId":"brenton_baruch_3_10","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":10,"text":"How happeneth it, Israel, that thou art in thine enemies' land, that thou art waxen old in a strange country, that thou art defiled with the dead,","searchKeywords":["how","happeneth","israel","that","thou","art","thine","enemies","land","waxen","old","strange","country","defiled","with","the","dead"]},{"verseId":"brenton_baruch_3_11","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":11,"text":"that thou art counted with them that go down into the grave?","searchKeywords":["that","thou","art","counted","with","them","down","into","the","grave"]},{"verseId":"brenton_baruch_3_12","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":12,"text":"Thou hast forsaken the fountain of wisdom.","searchKeywords":["thou","hast","forsaken","the","fountain","wisdom"]},{"verseId":"brenton_baruch_3_13","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":13,"text":"For if thou hadst walked in the way of God, thou shouldest have dwelled in peace for ever.","searchKeywords":["for","thou","hadst","walked","the","way","god","shouldest","have","dwelled","peace","ever"]},{"verseId":"brenton_baruch_3_14","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":14,"text":"Learn where is wisdom, where is strength, where is understanding; that thou mayest know also where is length of days, and life, where is the light of the eyes, and peace.","searchKeywords":["learn","where","wisdom","strength","understanding","that","thou","mayest","know","also","length","days","and","life","the","light","eyes","peace"]},{"verseId":"brenton_baruch_3_15","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":15,"text":"Who hath found out her place? or who hath come into her treasures?","searchKeywords":["who","hath","found","out","her","place","come","into","treasures"]},{"verseId":"brenton_baruch_3_16","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":16,"text":"Where are the princes of the heathen, and such as ruled the beasts upon the earth;","searchKeywords":["where","are","the","princes","heathen","and","such","ruled","beasts","upon","earth"]},{"verseId":"brenton_baruch_3_17","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":17,"text":"they that had their pastime with the fowls of the air, and they that hoarded up silver and gold, wherein men trust, and made no end of their getting?","searchKeywords":["they","that","had","their","pastime","with","the","fowls","air","and","hoarded","silver","gold","wherein","men","trust","made","end","getting"]},{"verseId":"brenton_baruch_3_18","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":18,"text":"For they that wrought in silver, and were so careful, and whose works are unsearchable,","searchKeywords":["for","they","that","wrought","silver","and","were","careful","whose","works","are","unsearchable"]},{"verseId":"brenton_baruch_3_19","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":19,"text":"they are vanished and gone down to the grave, and others are come up in their stead.","searchKeywords":["they","are","vanished","and","gone","down","the","grave","others","come","their","stead"]},{"verseId":"brenton_baruch_3_20","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":20,"text":"Young men have seen light, and dwelt upon the earth; but the way of knowledge have they not known,","searchKeywords":["young","men","have","seen","light","and","dwelt","upon","the","earth","but","way","knowledge","they","not","known"]},{"verseId":"brenton_baruch_3_21","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":21,"text":"nor understood the paths thereof, nor laid hold of it: their children were far off from that way.","searchKeywords":["nor","understood","the","paths","thereof","laid","hold","their","children","were","far","off","from","that","way"]},{"verseId":"brenton_baruch_3_22","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":22,"text":"It hath not been heard of in Chanaan, neither hath it been seen in Theman.","searchKeywords":["hath","not","been","heard","chanaan","neither","seen","theman"]},{"verseId":"brenton_baruch_3_23","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":23,"text":"The Agarenes that seek wisdom upon earth, the merchants of Meran and of Theman, the authors of fables, and searchers out of understanding; none of these have known the way of wisdom, or remembered her paths.","searchKeywords":["the","agarenes","that","seek","wisdom","upon","earth","merchants","meran","and","theman","authors","fables","searchers","out","understanding","none","these","have","known","way","remembered","her","paths"]},{"verseId":"brenton_baruch_3_24","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":24,"text":"O Israel, how great is the house of God! and how large is the place of his possession!","searchKeywords":["israel","how","great","the","house","god","and","large","place","his","possession"]},{"verseId":"brenton_baruch_3_25","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":25,"text":"Great, and hath none end; high, and unmeasurable.","searchKeywords":["great","and","hath","none","end","high","unmeasurable"]},{"verseId":"brenton_baruch_3_26","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":26,"text":"There were the giants famous from the beginning, that were of so great stature, and so expert in war.","searchKeywords":["there","were","the","giants","famous","from","beginning","that","great","stature","and","expert","war"]},{"verseId":"brenton_baruch_3_27","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":27,"text":"Those did not the Lord choose, neither gave he the way of knowledge unto them:","searchKeywords":["those","did","not","the","lord","choose","neither","gave","way","knowledge","unto","them"]},{"verseId":"brenton_baruch_3_28","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":28,"text":"but they were destroyed, because they had no wisdom, and perished through their own foolishness.","searchKeywords":["but","they","were","destroyed","because","had","wisdom","and","perished","through","their","own","foolishness"]},{"verseId":"brenton_baruch_3_29","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":29,"text":"Who hath gone up into heaven, and taken her, and brought her down from the clouds?","searchKeywords":["who","hath","gone","into","heaven","and","taken","her","brought","down","from","the","clouds"]},{"verseId":"brenton_baruch_3_30","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":30,"text":"Who hath gone over the sea, and found her, and will bring her for pure gold?","searchKeywords":["who","hath","gone","over","the","sea","and","found","her","will","bring","for","pure","gold"]},{"verseId":"brenton_baruch_3_31","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":31,"text":"No man knoweth her way, nor thinketh of her path.","searchKeywords":["man","knoweth","her","way","nor","thinketh","path"]},{"verseId":"brenton_baruch_3_32","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":32,"text":"But he that knoweth all things knoweth her, and hath found her out with his understanding: he that prepared the earth for evermore hath filled it with fourfooted beasts:","searchKeywords":["but","that","knoweth","all","things","her","and","hath","found","out","with","his","understanding","prepared","the","earth","for","evermore","filled","fourfooted","beasts"]},{"verseId":"brenton_baruch_3_33","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":33,"text":"he that sendeth forth light, and it goeth, calleth it , and it obeyeth him with fear.","searchKeywords":["that","sendeth","forth","light","and","goeth","calleth","obeyeth","him","with","fear"]},{"verseId":"brenton_baruch_3_34","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":34,"text":"The stars shined in their watches, and rejoiced: when he calleth them, they say, Here we be; and so with cheerfulness they shewed light unto him that made them.","searchKeywords":["the","stars","shined","their","watches","and","rejoiced","when","calleth","them","they","say","here","with","cheerfulness","shewed","light","unto","him","that","made"]},{"verseId":"brenton_baruch_3_35","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":35,"text":"This is our God, and there shall none other be accounted of in comparison of him.","searchKeywords":["this","our","god","and","there","shall","none","other","accounted","comparison","him"]},{"verseId":"brenton_baruch_3_36","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":36,"text":"He hath found out all the way of knowledge, and hath given it unto Jacob his servant, and to Israel his beloved.","searchKeywords":["hath","found","out","all","the","way","knowledge","and","given","unto","jacob","his","servant","israel","beloved"]},{"verseId":"brenton_baruch_3_37","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":3,"verse":37,"text":"Afterward did he shew himself upon earth, and conversed with men.","searchKeywords":["afterward","did","shew","himself","upon","earth","and","conversed","with","men"]}]