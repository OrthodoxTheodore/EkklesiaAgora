[{"verseId":"brenton_baruch_4_1","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":1,"text":"This is the book of the commandments of God, and the law that endureth for ever: all they that keep it to life; but such as leave it shall die.","searchKeywords":["this","the","book","commandments","god","and","law","that","endureth","for","ever","all","they","keep","life","but","such","leave","shall","die"]},{"verseId":"brenton_baruch_4_2","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":2,"text":"Turn thee, O Jacob, and take hold of it: walk in the presence of the light thereof, that thou mayest be illuminated.","searchKeywords":["turn","thee","jacob","and","take","hold","walk","the","presence","light","thereof","that","thou","mayest","illuminated"]},{"verseId":"brenton_baruch_4_3","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":3,"text":"Give not thine honour to another, nor the things that are profitable unto thee to a strange nation.","searchKeywords":["give","not","thine","honour","another","nor","the","things","that","are","profitable","unto","thee","strange","nation"]},{"verseId":"brenton_baruch_4_4","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":4,"text":"O Israel, happy are we: for things that are pleasing to God are made known unto us.","searchKeywords":["israel","happy","are","for","things","that","pleasing","god","made","known","unto"]},{"verseId":"brenton_baruch_4_5","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":5,"text":"Be of good cheer, my people, the memorial of Israel.","searchKeywords":["good","cheer","people","the","memorial","israel"]},{"verseId":"brenton_baruch_4_6","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":6,"text":"Ye were sold to the nations, not for [your] destruction: but because ye moved God to wrath, ye were delivered unto the enemies.","searchKeywords":["were","sold","the","nations","not","for","your","destruction","but","because","moved","god","wrath","delivered","unto","enemies"]},{"verseId":"brenton_baruch_4_7","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":7,"text":"For ye provoked him that made you by sacrificing unto devils and not to God.","searchKeywords":["for","provoked","him","that","made","you","sacrificing","unto","devils","and","not","god"]},{"verseId":"brenton_baruch_4_8","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":8,"text":"Ye have forgotten the everlasting God, that brought you up; and ye have grieved Jerusalem, that nursed you.","searchKeywords":["have","forgotten","the","everlasting","god","that","brought","you","and","grieved","jerusalem","nursed"]},{"verseId":"brenton_baruch_4_9","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":9,"text":"For when she saw the wrath of God coming upon you, she said, Hearken, O ye that dwell about Sion: God hath brought upon me great mourning;","searchKeywords":["for","when","she","saw","the","wrath","god","coming","upon","you","said","hearken","that","dwell","about","sion","hath","brought","great","mourning"]},{"verseId":"brenton_baruch_4_10","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":10,"text":"for I saw the captivity of my sons and daughters, which the Everlasting brought upon them.","searchKeywords":["for","saw","the","captivity","sons","and","daughters","which","everlasting","brought","upon","them"]},{"verseId":"brenton_baruch_4_11","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":11,"text":"With joy did I nourish them; but sent them away with weeping and mourning.","searchKeywords":["with","joy","did","nourish","them","but","sent","away","weeping","and","mourning"]},{"verseId":"brenton_baruch_4_12","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":12,"text":"Let no man rejoice over me, a widow, and forsaken of many, who for the sins of my children am left desolate; because they departed from the law of God.","searchKeywords":["let","man","rejoice","over","widow","and","forsaken","many","who","for","the","sins","children","left","desolate","because","they","departed","from","law","god"]},{"verseId":"brenton_baruch_4_13","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":13,"text":"They knew not his statutes, nor walked in the ways of his commandments, nor trod in the paths of discipline in his righteousness.","searchKeywords":["they","knew","not","his","statutes","nor","walked","the","ways","commandments","trod","paths","discipline","righteousness"]},{"verseId":"brenton_baruch_4_14","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":14,"text":"Let them that dwell about Sion come, and remember ye the captivity of my sons and daughters, which the Everlasting hath brought upon them.","searchKeywords":["let","them","that","dwell","about","sion","come","and","remember","the","captivity","sons","daughters","which","everlasting","hath","brought","upon"]},{"verseId":"brenton_baruch_4_15","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":15,"text":"For he hath brought a nation upon them from far, a shameless nation, and of a strange language, who neither reverenced old man, nor pitied child,","searchKeywords":["for","hath","brought","nation","upon","them","from","far","shameless","and","strange","language","who","neither","reverenced","old","man","nor","pitied","child"]},{"verseId":"brenton_baruch_4_16","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":16,"text":"and they have carried away the dear beloved children of the widow, and left her that was alone desolate without daughters.","searchKeywords":["and","they","have","carried","away","the","dear","beloved","children","widow","left","her","that","was","alone","desolate","without","daughters"]},{"verseId":"brenton_baruch_4_17","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":17,"text":"But what can I help you?","searchKeywords":["but","what","can","help","you"]},{"verseId":"brenton_baruch_4_18","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":18,"text":"For he that brought these plagues upon you will deliver you from the hands of your enemies.","searchKeywords":["for","that","brought","these","plagues","upon","you","will","deliver","from","the","hands","your","enemies"]},{"verseId":"brenton_baruch_4_19","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":19,"text":"Go your way, O my children, go your way: for I am left desolate.","searchKeywords":["your","way","children","for","left","desolate"]},{"verseId":"brenton_baruch_4_20","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":20,"text":"I have put off the clothing of peace, and put upon me the sackcloth of my prayer: I will cry unto the Everlasting in my days.","searchKeywords":["have","put","off","the","clothing","peace","and","upon","sackcloth","prayer","will","cry","unto","everlasting","days"]},{"verseId":"brenton_baruch_4_21","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":21,"text":"Be of good cheer, O my children, cry unto the Lord, and he shall deliver you from the power and hand of the enemies.","searchKeywords":["good","cheer","children","cry","unto","the","lord","and","shall","deliver","you","from","power","hand","enemies"]},{"verseId":"brenton_baruch_4_22","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":22,"text":"For my hope is in the Everlasting, that he will save you: and joy is come unto me from the Holy One, because of the mercy which shall soon come unto you from the Everlasting your Saviour.","searchKeywords":["for","hope","the","everlasting","that","will","save","you","and","joy","come","unto","from","holy","one","because","mercy","which","shall","soon","your","saviour"]},{"verseId":"brenton_baruch_4_23","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":23,"text":"For I sent you out with mourning and weeping: but God will give you to me again with joy and gladness for ever.","searchKeywords":["for","sent","you","out","with","mourning","and","weeping","but","god","will","give","again","joy","gladness","ever"]},{"verseId":"brenton_baruch_4_24","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":24,"text":"Like as now the neighbours of Sion have seen your captivity: so shall they see shortly your salvation from your God, which shall come upon you with great glory, and brightness of the Everlasting.","searchKeywords":["like","now","the","neighbours","sion","have","seen","your","captivity","shall","they","see","shortly","salvation","from","god","which","come","upon","you","with","great","glory","and","brightness","everlasting"]},{"verseId":"brenton_baruch_4_25","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":25,"text":"My children, suffer patiently the wrath that is come upon you from God: for thine enemy hath persecuted thee; but shortly thou shalt see his destruction, and shalt tread upon his neck.","searchKeywords":["children","suffer","patiently","the","wrath","that","come","upon","you","from","god","for","thine","enemy","hath","persecuted","thee","but","shortly","thou","shalt","see","his","destruction","and","tread","neck"]},{"verseId":"brenton_baruch_4_26","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":26,"text":"My delicate ones have gone rough ways, and were taken away as a flock caught of the enemies.","searchKeywords":["delicate","ones","have","gone","rough","ways","and","were","taken","away","flock","caught","the","enemies"]},{"verseId":"brenton_baruch_4_27","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":27,"text":"Be of good comfort, O my children, and cry unto God: for ye shall be remembered of him that brought these things upon you.","searchKeywords":["good","comfort","children","and","cry","unto","god","for","shall","remembered","him","that","brought","these","things","upon","you"]},{"verseId":"brenton_baruch_4_28","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":28,"text":"For as it was your mind to go astray from God: so, being returned, seek him ten times more.","searchKeywords":["for","was","your","mind","astray","from","god","being","returned","seek","him","ten","times","more"]},{"verseId":"brenton_baruch_4_29","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":29,"text":"For he that hath brought these plagues upon you shall bring you everlasting joy again with your salvation.","searchKeywords":["for","that","hath","brought","these","plagues","upon","you","shall","bring","everlasting","joy","again","with","your","salvation"]},{"verseId":"brenton_baruch_4_30","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":30,"text":"Take a good heart, O Jerusalem: for he that gave thee that name will comfort thee.","searchKeywords":["take","good","heart","jerusalem","for","that","gave","thee","name","will","comfort"]},{"verseId":"brenton_baruch_4_31","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":31,"text":"Miserable are they that afflicted thee, and rejoiced at thy fall.","searchKeywords":["miserable","are","they","that","afflicted","thee","and","rejoiced","thy","fall"]},{"verseId":"brenton_baruch_4_32","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":32,"text":"Miserable are the cities which thy children served: miserable is she that received thy sons.","searchKeywords":["miserable","are","the","cities","which","thy","children","served","she","that","received","sons"]},{"verseId":"brenton_baruch_4_33","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":33,"text":"For as she rejoiced at thy ruin, and was glad of thy fall: so shall she be grieved for her own desolation.","searchKeywords":["for","she","rejoiced","thy","ruin","and","was","glad","fall","shall","grieved","her","own","desolation"]},{"verseId":"brenton_baruch_4_34","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":34,"text":"For I will take away the rejoicing of her great multitude, and her pride shall be turned into mourning.","searchKeywords":["for","will","take","away","the","rejoicing","her","great","multitude","and","pride","shall","turned","into","mourning"]},{"verseId":"brenton_baruch_4_35","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":35,"text":"For fire shall come upon her from the Everlasting, long to endure; and she shall be inhabited of devils for a great time.","searchKeywords":["for","fire","shall","come","upon","her","from","the","everlasting","long","endure","and","she","inhabited","devils","great","time"]},{"verseId":"brenton_baruch_4_36","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":36,"text":"O Jerusalem, look about thee toward the east, and behold the joy that cometh unto thee from God.","searchKeywords":["jerusalem","look","about","thee","toward","the","east","and","behold","joy","that","cometh","unto","from","god"]},{"verseId":"brenton_baruch_4_37","translationId":"brenton","testament":"OT","bookIndex":47,"bookName":"Baruch","bookAbbrev":"baruch","chapter":4,"verse":37,"text":"Lo, thy sons come, whom thou sentest away, they come gathered together from the east to the west by the word of the Holy One, rejoicing in the glory of God.","searchKeywords":["thy","sons","come","whom","thou","sentest","away","they","gathered","together","from","the","east","west","word","holy","one","rejoicing","glory","god"]}]