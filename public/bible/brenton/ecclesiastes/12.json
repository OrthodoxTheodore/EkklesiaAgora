[{"verseId":"brenton_ecclesiastes_12_1","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":1,"text":"And remember thy Creator in the days of thy youth, before the days of evil come, and the years overtake in which thou shalt say, I have no pleasure in them.","searchKeywords":["and","remember","thy","creator","the","days","youth","before","evil","come","years","overtake","which","thou","shalt","say","have","pleasure","them"]},{"verseId":"brenton_ecclesiastes_12_2","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":2,"text":"While the sun and light are not darkened, nor the moon and the stars; nor the clouds return after the rain:","searchKeywords":["while","the","sun","and","light","are","not","darkened","nor","moon","stars","clouds","return","after","rain"]},{"verseId":"brenton_ecclesiastes_12_3","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":3,"text":"in the day wherein the keepers of the house shall tremble, and the mighty men shall become bent, and the grinding cease because they have become few, and the looking out at the windows be dark;","searchKeywords":["the","day","wherein","keepers","house","shall","tremble","and","mighty","men","become","bent","grinding","cease","because","they","have","few","looking","out","windows","dark"]},{"verseId":"brenton_ecclesiastes_12_4","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":4,"text":"and they shall shut the doors in the market-place, because of the weakness of the voice of her that grinds ; and he shall rise up at the voice of the sparrow, and all the daughters of song shall be brought low;","searchKeywords":["and","they","shall","shut","the","doors","market","place","because","weakness","voice","her","that","grinds","rise","sparrow","all","daughters","song","brought","low"]},{"verseId":"brenton_ecclesiastes_12_5","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":5,"text":"and they shall look up, and fears in the way, and the almond tree shall blossom, and the locust shall increase, and the caper shall be scattered: because man has gone to his eternal home, and the mourners have gone about the market:","searchKeywords":["and","they","shall","look","fears","the","way","almond","tree","blossom","locust","increase","caper","scattered","because","man","has","gone","his","eternal","home","mourners","have","about","market"]},{"verseId":"brenton_ecclesiastes_12_6","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":6,"text":"before the silver cord be , or the choice gold be broken, or the pitcher be broken at the fountain, or the wheel run down to the cistern;","searchKeywords":["before","the","silver","cord","choice","gold","broken","pitcher","fountain","wheel","run","down","cistern"]},{"verseId":"brenton_ecclesiastes_12_7","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":7,"text":"the dust also return to the earth as it was, and the spirit return to God who gave it.","searchKeywords":["the","dust","also","return","earth","was","and","spirit","god","who","gave"]},{"verseId":"brenton_ecclesiastes_12_8","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":8,"text":"Vanity of vanities, said the Preacher; all is vanity.","searchKeywords":["vanity","vanities","said","the","preacher","all"]},{"verseId":"brenton_ecclesiastes_12_9","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":9,"text":"And because the Preacher was wise above that he taught man excellent knowledge, and the ear will trace out the parables.","searchKeywords":["and","because","the","preacher","was","wise","above","that","taught","man","excellent","knowledge","ear","will","trace","out","parables"]},{"verseId":"brenton_ecclesiastes_12_10","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":10,"text":"The Preacher sought diligently to find out acceptable words, and a correct writing, words of truth.","searchKeywords":["the","preacher","sought","diligently","find","out","acceptable","words","and","correct","writing","truth"]},{"verseId":"brenton_ecclesiastes_12_11","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":11,"text":"The words of the wise are as goads, and as nails firmly fastened, which have been given from one shepherd by agreement.","searchKeywords":["the","words","wise","are","goads","and","nails","firmly","fastened","which","have","been","given","from","one","shepherd","agreement"]},{"verseId":"brenton_ecclesiastes_12_12","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":12,"text":"And moreover, my son, guard thyself by means of them: of making many books there is no end; and much study is a weariness of the flesh.","searchKeywords":["and","moreover","son","guard","thyself","means","them","making","many","books","there","end","much","study","weariness","the","flesh"]},{"verseId":"brenton_ecclesiastes_12_13","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":13,"text":"Hear the end of the matter, the sum: Fear God, and keep his commandments: for this is the whole man.","searchKeywords":["hear","the","end","matter","sum","fear","god","and","keep","his","commandments","for","this","whole","man"]},{"verseId":"brenton_ecclesiastes_12_14","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":12,"verse":14,"text":"For God will bring every work into judgment, with everything that has been overlooked, whether good, or whether evil.","searchKeywords":["for","god","will","bring","every","work","into","judgment","with","everything","that","has","been","overlooked","whether","good","evil"]}]