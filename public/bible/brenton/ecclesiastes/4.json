[{"verseId":"brenton_ecclesiastes_4_1","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":1,"text":"So I returned, and saw all the oppressions that were done under the sun: and behold the tear of the oppressed, and they had no comforter; and on the side of them that oppressed them was power; but they had no comforter:","searchKeywords":["returned","and","saw","all","the","oppressions","that","were","done","under","sun","behold","tear","oppressed","they","had","comforter","side","them","was","power","but"]},{"verseId":"brenton_ecclesiastes_4_2","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":2,"text":"and I praised all the dead that had already died more than the living, as many as are alive until now.","searchKeywords":["and","praised","all","the","dead","that","had","already","died","more","than","living","many","are","alive","until","now"]},{"verseId":"brenton_ecclesiastes_4_3","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":3,"text":"Better also than both these is he who has not yet been, who has not seen all the evil work that is done under the sun.","searchKeywords":["better","also","than","both","these","who","has","not","yet","been","seen","all","the","evil","work","that","done","under","sun"]},{"verseId":"brenton_ecclesiastes_4_4","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":4,"text":"And I saw all labour, and all the diligent work, that this is a man's envy from his neighbour. This is also vanity and waywardness of spirit.","searchKeywords":["and","saw","all","labour","the","diligent","work","that","this","man","envy","from","his","neighbour","also","vanity","waywardness","spirit"]},{"verseId":"brenton_ecclesiastes_4_5","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":5,"text":"The fool folds his hands together, and eats his own flesh.","searchKeywords":["the","fool","folds","his","hands","together","and","eats","own","flesh"]},{"verseId":"brenton_ecclesiastes_4_6","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":6,"text":"Better is a handful of rest than two handfuls of trouble and waywardness of spirit.","searchKeywords":["better","handful","rest","than","two","handfuls","trouble","and","waywardness","spirit"]},{"verseId":"brenton_ecclesiastes_4_7","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":7,"text":"So I returned, and saw vanity under the sun.","searchKeywords":["returned","and","saw","vanity","under","the","sun"]},{"verseId":"brenton_ecclesiastes_4_8","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":8,"text":"There is one , and there is not a second; yea, he has neither son nor brother: yet there is no end to all his labour; neither is his eye satisfied with wealth; and for whom do I labour, and deprive my soul of good? this is also vanity, and an evil trouble.","searchKeywords":["there","one","and","not","second","yea","has","neither","son","nor","brother","yet","end","all","his","labour","eye","satisfied","with","wealth","for","whom","deprive","soul","good","this","also","vanity","evil","trouble"]},{"verseId":"brenton_ecclesiastes_4_9","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":9,"text":"Two better than one, they have a good reward for their labour.","searchKeywords":["two","better","than","one","they","have","good","reward","for","their","labour"]},{"verseId":"brenton_ecclesiastes_4_10","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":10,"text":"For if they fall, the one will lift up his fellow: but woe to him that is alone when he falls, and there is not a second to lift him up.","searchKeywords":["for","they","fall","the","one","will","lift","his","fellow","but","woe","him","that","alone","when","falls","and","there","not","second"]},{"verseId":"brenton_ecclesiastes_4_11","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":11,"text":"Also if two should lie together, they also get heat: but how shall one be warmed ?","searchKeywords":["also","two","should","lie","together","they","get","heat","but","how","shall","one","warmed"]},{"verseId":"brenton_ecclesiastes_4_12","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":12,"text":"And if one should prevail against , the two shall withstand him; and a threefold cord shall not be quickly broken.","searchKeywords":["and","one","should","prevail","against","the","two","shall","withstand","him","threefold","cord","not","quickly","broken"]},{"verseId":"brenton_ecclesiastes_4_13","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":13,"text":"Better is a poor and wise child than an old and foolish king, who knows not how to take heed any longer.","searchKeywords":["better","poor","and","wise","child","than","old","foolish","king","who","knows","not","how","take","heed","any","longer"]},{"verseId":"brenton_ecclesiastes_4_14","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":14,"text":"For he shall come forth out of the house of the prisoners to reign, because also that was in his kingdom has become poor.","searchKeywords":["for","shall","come","forth","out","the","house","prisoners","reign","because","also","that","was","his","kingdom","has","become","poor"]},{"verseId":"brenton_ecclesiastes_4_15","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":15,"text":"I beheld all the living who were walking under the sun, with the second youth who shall stand up in each one's place.","searchKeywords":["beheld","all","the","living","who","were","walking","under","sun","with","second","youth","shall","stand","each","one","place"]},{"verseId":"brenton_ecclesiastes_4_16","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":16,"text":"There is no end to all the people, to all who were before them: and the last shall not rejoice in him: for this also is vanity and waywardness of spirit.","searchKeywords":["there","end","all","the","people","who","were","before","them","and","last","shall","not","rejoice","him","for","this","also","vanity","waywardness","spirit"]},{"verseId":"brenton_ecclesiastes_4_17","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":4,"verse":17,"text":"Keep thy foot, whensoever thou goest to the house of God; and near to hear, let thy sacrifice better than the gift of fools: for they know not that they are doing evil.","searchKeywords":["keep","thy","foot","whensoever","thou","goest","the","house","god","and","near","hear","let","sacrifice","better","than","gift","fools","for","they","know","not","that","are","doing","evil"]}]