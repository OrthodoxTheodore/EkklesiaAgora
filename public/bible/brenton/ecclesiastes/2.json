[{"verseId":"brenton_ecclesiastes_2_1","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":1,"text":"I said in my heart, Come now, I will prove thee with mirth, and behold thou good: and, behold, this is also vanity.","searchKeywords":["said","heart","come","now","will","prove","thee","with","mirth","and","behold","thou","good","this","also","vanity"]},{"verseId":"brenton_ecclesiastes_2_2","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":2,"text":"I said to laughter, Madness: and to mirth, Why doest thou this?","searchKeywords":["said","laughter","madness","and","mirth","why","doest","thou","this"]},{"verseId":"brenton_ecclesiastes_2_3","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":3,"text":"And I examined whether my heart would excite my flesh as wine, (though my heart guided in wisdom,) and to lay hold of mirth, until I should see of what kind is the good to the sons of men, which they should do under the sun all the days of their life.","searchKeywords":["and","examined","whether","heart","would","excite","flesh","wine","though","guided","wisdom","lay","hold","mirth","until","should","see","what","kind","the","good","sons","men","which","they","under","sun","all","days","their","life"]},{"verseId":"brenton_ecclesiastes_2_4","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":4,"text":"I enlarged my work; I built me houses; I planted me vineyards.","searchKeywords":["enlarged","work","built","houses","planted","vineyards"]},{"verseId":"brenton_ecclesiastes_2_5","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":5,"text":"I made me gardens and orchards, and planted in them every kind of fruit-tree.","searchKeywords":["made","gardens","and","orchards","planted","them","every","kind","fruit","tree"]},{"verseId":"brenton_ecclesiastes_2_6","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":6,"text":"I made me pools of water, to water from them the timber-bearing wood.","searchKeywords":["made","pools","water","from","them","the","timber","bearing","wood"]},{"verseId":"brenton_ecclesiastes_2_7","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":7,"text":"I got servants and maidens, and servants were born to me in the house: also I had abundant possession of flocks and herds, beyond all who were before me in Jerusalem.","searchKeywords":["got","servants","and","maidens","were","born","the","house","also","had","abundant","possession","flocks","herds","beyond","all","who","before","jerusalem"]},{"verseId":"brenton_ecclesiastes_2_8","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":8,"text":"Moreover I collected for myself both silver and gold also, and the peculiar treasures of kings and provinces: I procured me singing men and singing women, and delights of the sons of men, a butler and female cupbearers.","searchKeywords":["moreover","collected","for","myself","both","silver","and","gold","also","the","peculiar","treasures","kings","provinces","procured","singing","men","women","delights","sons","butler","female","cupbearers"]},{"verseId":"brenton_ecclesiastes_2_9","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":9,"text":"So I became great, and advanced beyond all that were before me in Jerusalem: also my wisdom was established to me.","searchKeywords":["became","great","and","advanced","beyond","all","that","were","before","jerusalem","also","wisdom","was","established"]},{"verseId":"brenton_ecclesiastes_2_10","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":10,"text":"And whatever mine eyes desired, I withheld not from them, I withheld not my heart from all my mirth: for my heart rejoiced in all my labour; and this was my portion of all my labour.","searchKeywords":["and","whatever","mine","eyes","desired","withheld","not","from","them","heart","all","mirth","for","rejoiced","labour","this","was","portion"]},{"verseId":"brenton_ecclesiastes_2_11","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":11,"text":"And I looked on all my works which my hands had wrought, and on my labour which I laboured to perform: and, behold, all was vanity and waywardness of spirit, and there is no advantage under the sun.","searchKeywords":["and","looked","all","works","which","hands","had","wrought","labour","laboured","perform","behold","was","vanity","waywardness","spirit","there","advantage","under","the","sun"]},{"verseId":"brenton_ecclesiastes_2_12","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":12,"text":"Then I looked on to see wisdom, and madness, and folly: for who is the man who will follow after counsel, in all things wherein he employs it?","searchKeywords":["then","looked","see","wisdom","and","madness","folly","for","who","the","man","will","follow","after","counsel","all","things","wherein","employs"]},{"verseId":"brenton_ecclesiastes_2_13","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":13,"text":"And I saw that wisdom excels folly, as much as light excels darkness.","searchKeywords":["and","saw","that","wisdom","excels","folly","much","light","darkness"]},{"verseId":"brenton_ecclesiastes_2_14","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":14,"text":"The wise man's eyes are in his head; but the fool walks in darkness: and I perceived, even I, that one event shall happen to them all.","searchKeywords":["the","wise","man","eyes","are","his","head","but","fool","walks","darkness","and","perceived","even","that","one","event","shall","happen","them","all"]},{"verseId":"brenton_ecclesiastes_2_15","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":15,"text":"And I said in my heart, As the event of the fool is, so shall it be to me, even to me; and to what purpose have I gained wisdom? I said moreover in my heart, This is also vanity, because the fool speaks of his abundance.","searchKeywords":["and","said","heart","the","event","fool","shall","even","what","purpose","have","gained","wisdom","moreover","this","also","vanity","because","speaks","his","abundance"]},{"verseId":"brenton_ecclesiastes_2_16","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":16,"text":"For there is no remembrance of the wise man with the fool for ever; forasmuch as now the coming days all things are forgotten: and how shall the wise man die with the fool?","searchKeywords":["for","there","remembrance","the","wise","man","with","fool","ever","forasmuch","now","coming","days","all","things","are","forgotten","and","how","shall","die"]},{"verseId":"brenton_ecclesiastes_2_17","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":17,"text":"So I hated life; because the work that was wrought under the sun was evil before me: for all is vanity and waywardness of spirit.","searchKeywords":["hated","life","because","the","work","that","was","wrought","under","sun","evil","before","for","all","vanity","and","waywardness","spirit"]},{"verseId":"brenton_ecclesiastes_2_18","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":18,"text":"And I hated the whole of my labour which I took under the sun; because I must leave it to the man who will come after me.","searchKeywords":["and","hated","the","whole","labour","which","took","under","sun","because","must","leave","man","who","will","come","after"]},{"verseId":"brenton_ecclesiastes_2_19","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":19,"text":"And who knows whether he will be a wise or a fool? and whether he will have power over all my labour in which I laboured, and wherein I grew wise under the sun? this is also vanity.","searchKeywords":["and","who","knows","whether","will","wise","fool","have","power","over","all","labour","which","laboured","wherein","grew","under","the","sun","this","also","vanity"]},{"verseId":"brenton_ecclesiastes_2_20","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":20,"text":"So I went about to dismiss from my heart all my labour wherein I had laboured under the sun.","searchKeywords":["went","about","dismiss","from","heart","all","labour","wherein","had","laboured","under","the","sun"]},{"verseId":"brenton_ecclesiastes_2_21","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":21,"text":"For there is a man that his labour is in wisdom, and in knowledge, and in fortitude; yet man shall give his portion to one who has not laboured therein. This is also vanity and great evil.","searchKeywords":["for","there","man","that","his","labour","wisdom","and","knowledge","fortitude","yet","shall","give","portion","one","who","has","not","laboured","therein","this","also","vanity","great","evil"]},{"verseId":"brenton_ecclesiastes_2_22","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":22,"text":"For it happens to a man in all his labour, and in the purpose of his heart wherein he labours under the sun.","searchKeywords":["for","happens","man","all","his","labour","and","the","purpose","heart","wherein","labours","under","sun"]},{"verseId":"brenton_ecclesiastes_2_23","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":23,"text":"For all his days of sorrows, and vexation of spirit is his; in the night also his heart rests not. This is also vanity.","searchKeywords":["for","all","his","days","sorrows","and","vexation","spirit","the","night","also","heart","rests","not","this","vanity"]},{"verseId":"brenton_ecclesiastes_2_24","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":24,"text":"A man has nothing good to eat, and to drink, and to shew his soul good in his trouble. This also I saw, that it is from the hand of God.","searchKeywords":["man","has","nothing","good","eat","and","drink","shew","his","soul","trouble","this","also","saw","that","from","the","hand","god"]},{"verseId":"brenton_ecclesiastes_2_25","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":25,"text":"For who shall eat, or who shall drink, without him?","searchKeywords":["for","who","shall","eat","drink","without","him"]},{"verseId":"brenton_ecclesiastes_2_26","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":2,"verse":26,"text":"For has given to the man who is good in his sight, wisdom, and knowledge, and joy: but he has given to the sinner trouble, to add and to heap up, that he may give to him that is good before God; for this is also vanity and waywardness of spirit.","searchKeywords":["for","has","given","the","man","who","good","his","sight","wisdom","and","knowledge","joy","but","sinner","trouble","add","heap","that","may","give","him","before","god","this","also","vanity","waywardness","spirit"]}]