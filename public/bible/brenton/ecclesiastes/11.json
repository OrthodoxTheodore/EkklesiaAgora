[{"verseId":"brenton_ecclesiastes_11_1","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":11,"verse":1,"text":"Send forth thy bread upon the face of the water: for thou shalt find it after many days.","searchKeywords":["send","forth","thy","bread","upon","the","face","water","for","thou","shalt","find","after","many","days"]},{"verseId":"brenton_ecclesiastes_11_2","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":11,"verse":2,"text":"Give a portion to seven, and also to eight; for thou knowest not what evil there shall be upon the earth.","searchKeywords":["give","portion","seven","and","also","eight","for","thou","knowest","not","what","evil","there","shall","upon","the","earth"]},{"verseId":"brenton_ecclesiastes_11_3","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":11,"verse":3,"text":"If the clouds be filled with rain, they pour out upon the earth: and if a tree fall southward, or if it fall northward, in the place where the tree shall fall, there it shall be.","searchKeywords":["the","clouds","filled","with","rain","they","pour","out","upon","earth","and","tree","fall","southward","northward","place","where","shall","there"]},{"verseId":"brenton_ecclesiastes_11_4","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":11,"verse":4,"text":"He that observes the wind sows not; and he that looks at the clouds will not reap.","searchKeywords":["that","observes","the","wind","sows","not","and","looks","clouds","will","reap"]},{"verseId":"brenton_ecclesiastes_11_5","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":11,"verse":5,"text":"Among whom none knows what is the way of the wind: as the bones in the womb of a pregnant , so thou shalt not know the works of God, all things whatsoever he shall do.","searchKeywords":["among","whom","none","knows","what","the","way","wind","bones","womb","pregnant","thou","shalt","not","know","works","god","all","things","whatsoever","shall"]},{"verseId":"brenton_ecclesiastes_11_6","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":11,"verse":6,"text":"In the morning sow thy seed, and in the evening let not thine hand be slack: for thou knowest not what sort shall prosper, whether this or that, or whether both shall be good alike.","searchKeywords":["the","morning","sow","thy","seed","and","evening","let","not","thine","hand","slack","for","thou","knowest","what","sort","shall","prosper","whether","this","that","both","good","alike"]},{"verseId":"brenton_ecclesiastes_11_7","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":11,"verse":7,"text":"Moreover the light is sweet, and it is good for the eyes to see the sun.","searchKeywords":["moreover","the","light","sweet","and","good","for","eyes","see","sun"]},{"verseId":"brenton_ecclesiastes_11_8","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":11,"verse":8,"text":"For even if a man should live many years, rejoice in them all; yet let him remember the days of darkness; for they shall be many. All that comes is vanity.","searchKeywords":["for","even","man","should","live","many","years","rejoice","them","all","yet","let","him","remember","the","days","darkness","they","shall","that","comes","vanity"]},{"verseId":"brenton_ecclesiastes_11_9","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":11,"verse":9,"text":"Rejoice, O young man, in thy youth; and let thy heart cheer thee in the days of thy youth, and walk in the ways of thy heart blameless, but not in the sight of thine eyes: yet know that for all these things God will bring thee into judgment.","searchKeywords":["rejoice","young","man","thy","youth","and","let","heart","cheer","thee","the","days","walk","ways","blameless","but","not","sight","thine","eyes","yet","know","that","for","all","these","things","god","will","bring","into","judgment"]},{"verseId":"brenton_ecclesiastes_11_10","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":11,"verse":10,"text":"Therefore remove sorrow from thy heart, and put away evil from thy flesh: for youth and folly are vanity.","searchKeywords":["therefore","remove","sorrow","from","thy","heart","and","put","away","evil","flesh","for","youth","folly","are","vanity"]}]