[{"verseId":"brenton_ecclesiastes_10_1","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":1,"text":"Pestilent flies will corrupt a preparation of sweet ointment: a little wisdom is more precious than great glory of folly.","searchKeywords":["pestilent","flies","will","corrupt","preparation","sweet","ointment","little","wisdom","more","precious","than","great","glory","folly"]},{"verseId":"brenton_ecclesiastes_10_2","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":2,"text":"A wise man's heart is at his right hand; but a fool's heart at his left.","searchKeywords":["wise","man","heart","his","right","hand","but","fool","left"]},{"verseId":"brenton_ecclesiastes_10_3","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":3,"text":"Yea, and whenever a fool walks by the way, his heart will fail him, and all that he thinks of is folly.","searchKeywords":["yea","and","whenever","fool","walks","the","way","his","heart","will","fail","him","all","that","thinks","folly"]},{"verseId":"brenton_ecclesiastes_10_4","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":4,"text":"If the spirit of the ruler rise up against thee, leave not thy place; for soothing will put an end to great offences.","searchKeywords":["the","spirit","ruler","rise","against","thee","leave","not","thy","place","for","soothing","will","put","end","great","offences"]},{"verseId":"brenton_ecclesiastes_10_5","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":5,"text":"There is an evil which I have seen under the sun, wherein an error has proceeded from the ruler.","searchKeywords":["there","evil","which","have","seen","under","the","sun","wherein","error","has","proceeded","from","ruler"]},{"verseId":"brenton_ecclesiastes_10_6","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":6,"text":"The fool has been set in very high places, while rich men would sit in a low one.","searchKeywords":["the","fool","has","been","set","very","high","places","while","rich","men","would","sit","low","one"]},{"verseId":"brenton_ecclesiastes_10_7","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":7,"text":"I have seen servants upon horses, and princes walking as servants on the earth.","searchKeywords":["have","seen","servants","upon","horses","and","princes","walking","the","earth"]},{"verseId":"brenton_ecclesiastes_10_8","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":8,"text":"He that digs a pit shall fall into it; and him that breaks down a hedge a serpent shall bite.","searchKeywords":["that","digs","pit","shall","fall","into","and","him","breaks","down","hedge","serpent","bite"]},{"verseId":"brenton_ecclesiastes_10_9","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":9,"text":"He that removes stones shall be troubled thereby; he that cleaves wood shall be endangered thereby.","searchKeywords":["that","removes","stones","shall","troubled","thereby","cleaves","wood","endangered"]},{"verseId":"brenton_ecclesiastes_10_10","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":10,"text":"If the axe-head should fall off, then the man troubles his countenance, and he must put forth more strength: and skill is of no advantage to a man.","searchKeywords":["the","axe","head","should","fall","off","then","man","troubles","his","countenance","and","must","put","forth","more","strength","skill","advantage"]},{"verseId":"brenton_ecclesiastes_10_11","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":11,"text":"If a serpent bite when there is no whisper, then there is no advantage to the charmer.","searchKeywords":["serpent","bite","when","there","whisper","then","advantage","the","charmer"]},{"verseId":"brenton_ecclesiastes_10_12","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":12,"text":"The words of a wise mouth are gracious: but the lips of a fool will swallow him up.","searchKeywords":["the","words","wise","mouth","are","gracious","but","lips","fool","will","swallow","him"]},{"verseId":"brenton_ecclesiastes_10_13","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":13,"text":"The beginning of the words of his mouth is folly: and the end of his talk mischievous madness.","searchKeywords":["the","beginning","words","his","mouth","folly","and","end","talk","mischievous","madness"]},{"verseId":"brenton_ecclesiastes_10_14","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":14,"text":"A fool moreover multiplies words: man knows not what has been, nor what will be: who shall tell him what will come after him?","searchKeywords":["fool","moreover","multiplies","words","man","knows","not","what","has","been","nor","will","who","shall","tell","him","come","after"]},{"verseId":"brenton_ecclesiastes_10_15","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":15,"text":"The labour of fools will afflict them, who knows not to go to the city.","searchKeywords":["the","labour","fools","will","afflict","them","who","knows","not","city"]},{"verseId":"brenton_ecclesiastes_10_16","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":16,"text":"Woe to thee, O city, whose king is young, and thy princes eat in the morning!","searchKeywords":["woe","thee","city","whose","king","young","and","thy","princes","eat","the","morning"]},{"verseId":"brenton_ecclesiastes_10_17","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":17,"text":"Blessed art thou, O land, whose king is a son of nobles, and whose princes shall eat seasonably, for strength, and shall not be ashamed.","searchKeywords":["blessed","art","thou","land","whose","king","son","nobles","and","princes","shall","eat","seasonably","for","strength","not","ashamed"]},{"verseId":"brenton_ecclesiastes_10_18","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":18,"text":"By slothful neglect a building will be brought low: and by idleness of the hands the house will fall to pieces.","searchKeywords":["slothful","neglect","building","will","brought","low","and","idleness","the","hands","house","fall","pieces"]},{"verseId":"brenton_ecclesiastes_10_19","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":19,"text":"Men prepare bread for laughter, and wine and oil that the living should rejoice: but to money all things will humbly yield obedience.","searchKeywords":["men","prepare","bread","for","laughter","and","wine","oil","that","the","living","should","rejoice","but","money","all","things","will","humbly","yield","obedience"]},{"verseId":"brenton_ecclesiastes_10_20","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":10,"verse":20,"text":"Even in thy conscience, curse not the king; and curse not the rich in thy bedchamber: for a bird of the air shall carry thy voice, and that which has wings shall report thy speech.","searchKeywords":["even","thy","conscience","curse","not","the","king","and","rich","bedchamber","for","bird","air","shall","carry","voice","that","which","has","wings","report","speech"]}]