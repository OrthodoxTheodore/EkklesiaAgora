[{"verseId":"brenton_ecclesiastes_3_1","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":1,"text":"To all things there is a time, and a season for every matter under heaven.","searchKeywords":["all","things","there","time","and","season","for","every","matter","under","heaven"]},{"verseId":"brenton_ecclesiastes_3_2","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":2,"text":"A time of birth, and a time to die; a time to plant, and a time to pluck up what has been planted;","searchKeywords":["time","birth","and","die","plant","pluck","what","has","been","planted"]},{"verseId":"brenton_ecclesiastes_3_3","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":3,"text":"a time to kill, and a time to heal; a time to pull down, and a time to build up;","searchKeywords":["time","kill","and","heal","pull","down","build"]},{"verseId":"brenton_ecclesiastes_3_4","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":4,"text":"a time to weep, and a time to laugh; a time to lament, and a time to dance;","searchKeywords":["time","weep","and","laugh","lament","dance"]},{"verseId":"brenton_ecclesiastes_3_5","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":5,"text":"a time to throw stones, and a time to gather stones together; a time to embrace, and a time to abstain from embracing;","searchKeywords":["time","throw","stones","and","gather","together","embrace","abstain","from","embracing"]},{"verseId":"brenton_ecclesiastes_3_6","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":6,"text":"a time to seek, and a time to lose; a time to keep, and a time to cast away;","searchKeywords":["time","seek","and","lose","keep","cast","away"]},{"verseId":"brenton_ecclesiastes_3_7","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":7,"text":"a time to rend, and a time to sew; a time to be silent, and a time to speak;","searchKeywords":["time","rend","and","sew","silent","speak"]},{"verseId":"brenton_ecclesiastes_3_8","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":8,"text":"a time to love, and a time to hate; a time of war, and a time of peace.","searchKeywords":["time","love","and","hate","war","peace"]},{"verseId":"brenton_ecclesiastes_3_9","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":9,"text":"What advantage he that works in those things wherein he labours?","searchKeywords":["what","advantage","that","works","those","things","wherein","labours"]},{"verseId":"brenton_ecclesiastes_3_10","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":10,"text":"I have seen all the trouble, which God has given to the sons of men to be troubled with.","searchKeywords":["have","seen","all","the","trouble","which","god","has","given","sons","men","troubled","with"]},{"verseId":"brenton_ecclesiastes_3_11","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":11,"text":"All the things which he has made are beautiful in his time: he has also set the whole world in their heart, that man might not find out the work which God has wrought from the beginning even to the end.","searchKeywords":["all","the","things","which","has","made","are","beautiful","his","time","also","set","whole","world","their","heart","that","man","might","not","find","out","work","god","wrought","from","beginning","even","end"]},{"verseId":"brenton_ecclesiastes_3_12","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":12,"text":"I know that there is no good in them, except to rejoice, and to do good in his life.","searchKeywords":["know","that","there","good","them","except","rejoice","and","his","life"]},{"verseId":"brenton_ecclesiastes_3_13","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":13,"text":"Also every man who shall eat and drink, and see good in all his labour, is a gift of God.","searchKeywords":["also","every","man","who","shall","eat","and","drink","see","good","all","his","labour","gift","god"]},{"verseId":"brenton_ecclesiastes_3_14","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":14,"text":"I know that whatsoever things God has done, they shall be for ever: it is impossible to add to it, and it is impossible to take away from it: and God has done , that may fear before him.","searchKeywords":["know","that","whatsoever","things","god","has","done","they","shall","for","ever","impossible","add","and","take","away","from","may","fear","before","him"]},{"verseId":"brenton_ecclesiastes_3_15","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":15,"text":"That which has been is now; and whatever things to be have already been; and God will seek out that which is past.","searchKeywords":["that","which","has","been","now","and","whatever","things","have","already","god","will","seek","out","past"]},{"verseId":"brenton_ecclesiastes_3_16","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":16,"text":"And moreover I saw under the sun the place of judgment, there was the ungodly one; and the place of righteousness, there was the godly one.","searchKeywords":["and","moreover","saw","under","the","sun","place","judgment","there","was","ungodly","one","righteousness","godly"]},{"verseId":"brenton_ecclesiastes_3_17","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":17,"text":"And I said in my heart, God will judge the righteous and the ungodly: for there is a time there for every action and for every work.","searchKeywords":["and","said","heart","god","will","judge","the","righteous","ungodly","for","there","time","every","action","work"]},{"verseId":"brenton_ecclesiastes_3_18","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":18,"text":"I said in my heart, concerning the speech of the sons of man, God will judge them, and that to shew that they are beasts.","searchKeywords":["said","heart","concerning","the","speech","sons","man","god","will","judge","them","and","that","shew","they","are","beasts"]},{"verseId":"brenton_ecclesiastes_3_19","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":19,"text":"Also to them is the event of the sons of man, and the event of the brute; one event befalls them: as is the death of the one, so also the death of the other; and there is one breath to all: and what has the man more than the brute? nothing; for all is vanity.","searchKeywords":["also","them","the","event","sons","man","and","brute","one","befalls","death","other","there","breath","all","what","has","more","than","nothing","for","vanity"]},{"verseId":"brenton_ecclesiastes_3_20","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":20,"text":"All to one place; all were formed of the dust, and all will return to dust.","searchKeywords":["all","one","place","were","formed","the","dust","and","will","return"]},{"verseId":"brenton_ecclesiastes_3_21","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":21,"text":"And who has seen the spirit of the sons of man, whether it goes upward? and the spirit of the beast, whether it goes downward to the earth?","searchKeywords":["and","who","has","seen","the","spirit","sons","man","whether","goes","upward","beast","downward","earth"]},{"verseId":"brenton_ecclesiastes_3_22","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":3,"verse":22,"text":"And I saw that there was no good, but that wherein a man shall rejoice in his works, for it is his portion, for who shall bring him to see any thing of that which shall be after him?","searchKeywords":["and","saw","that","there","was","good","but","wherein","man","shall","rejoice","his","works","for","portion","who","bring","him","see","any","thing","which","after"]}]