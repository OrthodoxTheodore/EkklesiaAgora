[{"verseId":"brenton_ecclesiastes_7_1","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":1,"text":"A good name is better than good oil; and the day of death than the day of birth.","searchKeywords":["good","name","better","than","oil","and","the","day","death","birth"]},{"verseId":"brenton_ecclesiastes_7_2","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":2,"text":"better to go to the house of mourning, than to go to the banquet house: since this is the end of every man; and the living man will apply good to his heart.","searchKeywords":["better","the","house","mourning","than","banquet","since","this","end","every","man","and","living","will","apply","good","his","heart"]},{"verseId":"brenton_ecclesiastes_7_3","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":3,"text":"Sorrow is better than laughter: for by the sadness of the countenance the heart will be made better.","searchKeywords":["sorrow","better","than","laughter","for","the","sadness","countenance","heart","will","made"]},{"verseId":"brenton_ecclesiastes_7_4","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":4,"text":"The heart of the wise is in the house of mourning; but the heart of fools is in the house of mirth.","searchKeywords":["the","heart","wise","house","mourning","but","fools","mirth"]},{"verseId":"brenton_ecclesiastes_7_5","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":5,"text":"better to hear a reproof of a wise man, than for a man to hear the song of fools.","searchKeywords":["better","hear","reproof","wise","man","than","for","the","song","fools"]},{"verseId":"brenton_ecclesiastes_7_6","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":6,"text":"As the sound of thorns under a caldron, so is the laughter of fools: this is also vanity.","searchKeywords":["the","sound","thorns","under","caldron","laughter","fools","this","also","vanity"]},{"verseId":"brenton_ecclesiastes_7_7","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":7,"text":"For oppression makes a wise man mad, and destroys his noble heart.","searchKeywords":["for","oppression","makes","wise","man","mad","and","destroys","his","noble","heart"]},{"verseId":"brenton_ecclesiastes_7_8","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":8,"text":"The end of a matter is better than the beginning thereof: the patient is better than the high-minded.","searchKeywords":["the","end","matter","better","than","beginning","thereof","patient","high","minded"]},{"verseId":"brenton_ecclesiastes_7_9","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":9,"text":"Be not hasty in thy spirit to be angry: for anger will rest in the bosom of fools.","searchKeywords":["not","hasty","thy","spirit","angry","for","anger","will","rest","the","bosom","fools"]},{"verseId":"brenton_ecclesiastes_7_10","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":10,"text":"Say not, What has happened, that the former days were better than these? for thou dost not enquire in wisdom concerning this.","searchKeywords":["say","not","what","has","happened","that","the","former","days","were","better","than","these","for","thou","dost","enquire","wisdom","concerning","this"]},{"verseId":"brenton_ecclesiastes_7_11","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":11,"text":"Wisdom is good with an inheritance: and an advantage to them that see the sun.","searchKeywords":["wisdom","good","with","inheritance","and","advantage","them","that","see","the","sun"]},{"verseId":"brenton_ecclesiastes_7_12","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":12,"text":"For wisdom in its shadow is as the shadow of silver: and the excellence of the knowledge of wisdom will give life to him that has it.","searchKeywords":["for","wisdom","its","shadow","the","silver","and","excellence","knowledge","will","give","life","him","that","has"]},{"verseId":"brenton_ecclesiastes_7_13","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":13,"text":"Behold the works of God: for who shall be able to straighten him whom God has made crooked?","searchKeywords":["behold","the","works","god","for","who","shall","able","straighten","him","whom","has","made","crooked"]},{"verseId":"brenton_ecclesiastes_7_14","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":14,"text":"In the day of prosperity live joyfully, and consider in the day of adversity: consider, , God also has caused the one to agree with the other for reason, that man should find nothing after him.","searchKeywords":["the","day","prosperity","live","joyfully","and","consider","adversity","god","also","has","caused","one","agree","with","other","for","reason","that","man","should","find","nothing","after","him"]},{"verseId":"brenton_ecclesiastes_7_15","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":15,"text":"I have seen all things in the days of my vanity: there is a just man perishing in his justice, and there is an ungodly man remaining in his wickedness.","searchKeywords":["have","seen","all","things","the","days","vanity","there","just","man","perishing","his","justice","and","ungodly","remaining","wickedness"]},{"verseId":"brenton_ecclesiastes_7_16","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":16,"text":"Be not very just; neither be very wise: lest thou be confounded.","searchKeywords":["not","very","just","neither","wise","lest","thou","confounded"]},{"verseId":"brenton_ecclesiastes_7_17","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":17,"text":"Be not very wicked; and be not stubborn: lest thou shouldest die before thy time.","searchKeywords":["not","very","wicked","and","stubborn","lest","thou","shouldest","die","before","thy","time"]},{"verseId":"brenton_ecclesiastes_7_18","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":18,"text":"It is well for thee to hold fast by this; also by this defile not thine hand: for to them that fear God all things shall come forth .","searchKeywords":["well","for","thee","hold","fast","this","also","defile","not","thine","hand","them","that","fear","god","all","things","shall","come","forth"]},{"verseId":"brenton_ecclesiastes_7_19","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":19,"text":"Wisdom will help the wise man more than ten mighty men which are in the city.","searchKeywords":["wisdom","will","help","the","wise","man","more","than","ten","mighty","men","which","are","city"]},{"verseId":"brenton_ecclesiastes_7_20","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":20,"text":"For there is not a righteous man in the earth, who will do good, and not sin.","searchKeywords":["for","there","not","righteous","man","the","earth","who","will","good","and","sin"]},{"verseId":"brenton_ecclesiastes_7_21","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":21,"text":"Also take no heed to all the words which ungodly men shall speak; lest thou hear thy servant cursing thee.","searchKeywords":["also","take","heed","all","the","words","which","ungodly","men","shall","speak","lest","thou","hear","thy","servant","cursing","thee"]},{"verseId":"brenton_ecclesiastes_7_22","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":22,"text":"For many times he shall trespass against thee, and repeatedly shall he afflict thine heart; for thus also hast thou cursed others.","searchKeywords":["for","many","times","shall","trespass","against","thee","and","repeatedly","afflict","thine","heart","thus","also","hast","thou","cursed","others"]},{"verseId":"brenton_ecclesiastes_7_23","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":23,"text":"All these things have I proved in wisdom: I said, I will be wise; but it was far from me.","searchKeywords":["all","these","things","have","proved","wisdom","said","will","wise","but","was","far","from"]},{"verseId":"brenton_ecclesiastes_7_24","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":24,"text":"far beyond what was, and a great depth, who shall find it out?","searchKeywords":["far","beyond","what","was","and","great","depth","who","shall","find","out"]},{"verseId":"brenton_ecclesiastes_7_25","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":25,"text":"I and my heart went round about to know, and to examine, and to seek wisdom, and the account , and to know the folly and trouble and madness of the ungodly man.","searchKeywords":["and","heart","went","round","about","know","examine","seek","wisdom","the","account","folly","trouble","madness","ungodly","man"]},{"verseId":"brenton_ecclesiastes_7_26","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":26,"text":"And I find her , and I will pronounce more bitter than death the woman which is a snare, and her heart nets, a band in her hands: good in the sight of God shall be delivered from her; but the sinner shall be caught by her.","searchKeywords":["and","find","her","will","pronounce","more","bitter","than","death","the","woman","which","snare","heart","nets","band","hands","good","sight","god","shall","delivered","from","but","sinner","caught"]},{"verseId":"brenton_ecclesiastes_7_27","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":27,"text":"Behold, this have I found, said the Preacher, by one at a time to find out the account,","searchKeywords":["behold","this","have","found","said","the","preacher","one","time","find","out","account"]},{"verseId":"brenton_ecclesiastes_7_28","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":28,"text":"which my soul sought after, but I found not: for I have found one man of a thousand; but a woman in all these I have not found.","searchKeywords":["which","soul","sought","after","but","found","not","for","have","one","man","thousand","woman","all","these"]},{"verseId":"brenton_ecclesiastes_7_29","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":7,"verse":29,"text":"But, behold, this have I found, that God made man upright; but they have sought out many devices.","searchKeywords":["but","behold","this","have","found","that","god","made","man","upright","they","sought","out","many","devices"]}]