[{"verseId":"brenton_ecclesiastes_6_1","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":6,"verse":1,"text":"There is an evil which I have seen under the sun, and it is abundant with man:","searchKeywords":["there","evil","which","have","seen","under","the","sun","and","abundant","with","man"]},{"verseId":"brenton_ecclesiastes_6_2","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":6,"verse":2,"text":"a man to whom God shall give wealth, and substance, and honour, and he wants nothing for his soul of all things that he shall desire, yet God shall not give him power to eat of it, for a stranger shall devour it: this is vanity, and an evil infirmity.","searchKeywords":["man","whom","god","shall","give","wealth","and","substance","honour","wants","nothing","for","his","soul","all","things","that","desire","yet","not","him","power","eat","stranger","devour","this","vanity","evil","infirmity"]},{"verseId":"brenton_ecclesiastes_6_3","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":6,"verse":3,"text":"If a man beget a hundred , and live many years, yea, however abundant the days of his years shall be, yet his soul shall not be satisfied with good, and also he have no burial; I said, An untimely birth is better than he.","searchKeywords":["man","beget","hundred","and","live","many","years","yea","however","abundant","the","days","his","shall","yet","soul","not","satisfied","with","good","also","have","burial","said","untimely","birth","better","than"]},{"verseId":"brenton_ecclesiastes_6_4","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":6,"verse":4,"text":"For he came in vanity, and departs in darkness, and his name shall be covered in darkness.","searchKeywords":["for","came","vanity","and","departs","darkness","his","name","shall","covered"]},{"verseId":"brenton_ecclesiastes_6_5","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":6,"verse":5,"text":"Moreover he has not seen the sun, nor known rest: there is to this one than another.","searchKeywords":["moreover","has","not","seen","the","sun","nor","known","rest","there","this","one","than","another"]},{"verseId":"brenton_ecclesiastes_6_6","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":6,"verse":6,"text":"Though he has lived to the return of a thousand years, yet he has seen no good: do not all go to one place?","searchKeywords":["though","has","lived","the","return","thousand","years","yet","seen","good","not","all","one","place"]},{"verseId":"brenton_ecclesiastes_6_7","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":6,"verse":7,"text":"All the labour of a man is for his mouth, and yet the appetite shall not be satisfied.","searchKeywords":["all","the","labour","man","for","his","mouth","and","yet","appetite","shall","not","satisfied"]},{"verseId":"brenton_ecclesiastes_6_8","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":6,"verse":8,"text":"For advantage has the wise man over the fool, since the poor knows how to walk in the direction of life?","searchKeywords":["for","advantage","has","the","wise","man","over","fool","since","poor","knows","how","walk","direction","life"]},{"verseId":"brenton_ecclesiastes_6_9","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":6,"verse":9,"text":"The sight of the eyes is better than that which wanders in soul: this is also vanity, and waywardness of spirit.","searchKeywords":["the","sight","eyes","better","than","that","which","wanders","soul","this","also","vanity","and","waywardness","spirit"]},{"verseId":"brenton_ecclesiastes_6_10","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":6,"verse":10,"text":"If anything has been, its name has already been called: and it is known what man is; neither can he contend with him who is stronger than he.","searchKeywords":["anything","has","been","its","name","already","called","and","known","what","man","neither","can","contend","with","him","who","stronger","than"]},{"verseId":"brenton_ecclesiastes_6_11","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":6,"verse":11,"text":"For there are many things which increase vanity.","searchKeywords":["for","there","are","many","things","which","increase","vanity"]},{"verseId":"brenton_ecclesiastes_6_12","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":6,"verse":12,"text":"What advantage has a man? for who knows good for a man in his life, the number of the life of the days of his vanity? and he has spent them as a shadow; for who shall tell a man what shall be after him under the sun?","searchKeywords":["what","advantage","has","man","for","who","knows","good","his","life","the","number","days","vanity","and","spent","them","shadow","shall","tell","after","him","under","sun"]}]