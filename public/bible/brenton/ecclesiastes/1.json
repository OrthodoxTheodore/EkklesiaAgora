[{"verseId":"brenton_ecclesiastes_1_1","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":1,"text":"words of the Preacher, the son of David, king of Israel in Jerusalem.","searchKeywords":["words","the","preacher","son","david","king","israel","jerusalem"]},{"verseId":"brenton_ecclesiastes_1_2","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":2,"text":"Vanity of vanities, said the Preacher, vanity of vanities; all is vanity.","searchKeywords":["vanity","vanities","said","the","preacher","all"]},{"verseId":"brenton_ecclesiastes_1_3","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":3,"text":"What advantage to a man in all his labour that he takes under the sun?","searchKeywords":["what","advantage","man","all","his","labour","that","takes","under","the","sun"]},{"verseId":"brenton_ecclesiastes_1_4","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":4,"text":"A generation goes, and a generation comes: but the earth stands for ever.","searchKeywords":["generation","goes","and","comes","but","the","earth","stands","for","ever"]},{"verseId":"brenton_ecclesiastes_1_5","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":5,"text":"And the sun arises, and the sun goes down and draws toward its place;","searchKeywords":["and","the","sun","arises","goes","down","draws","toward","its","place"]},{"verseId":"brenton_ecclesiastes_1_6","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":6,"text":"arising there it proceeds southward, and goes round toward the north. The wind goes round and round, and the wind returns to its circuits.","searchKeywords":["arising","there","proceeds","southward","and","goes","round","toward","the","north","wind","returns","its","circuits"]},{"verseId":"brenton_ecclesiastes_1_7","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":7,"text":"All the rivers run into the sea; and yet the sea is not filled: to the place whence the rivers come, thither they return again.","searchKeywords":["all","the","rivers","run","into","sea","and","yet","not","filled","place","whence","come","thither","they","return","again"]},{"verseId":"brenton_ecclesiastes_1_8","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":8,"text":"All things are full of labour; a man will not be able to speak : neither shall the eye be satisfied with seeing, neither shall the ear be filled with hearing.","searchKeywords":["all","things","are","full","labour","man","will","not","able","speak","neither","shall","the","eye","satisfied","with","seeing","ear","filled","hearing"]},{"verseId":"brenton_ecclesiastes_1_9","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":9,"text":"What is that which has been? the very thing which shall be: and what is that which has been done? the very thing which shall be done: and there is no new thing under the sun.","searchKeywords":["what","that","which","has","been","the","very","thing","shall","and","done","there","new","under","sun"]},{"verseId":"brenton_ecclesiastes_1_10","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":10,"text":"that shall speak and say, Behold, this is new? it has already been in the ages that have passed before us.","searchKeywords":["that","shall","speak","and","say","behold","this","new","has","already","been","the","ages","have","passed","before"]},{"verseId":"brenton_ecclesiastes_1_11","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":11,"text":"There is no memorial to the first things; neither to the things that have been last shall their memorial be with them that shall be at the last .","searchKeywords":["there","memorial","the","first","things","neither","that","have","been","last","shall","their","with","them"]},{"verseId":"brenton_ecclesiastes_1_12","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":12,"text":"I the Preacher was king over Israel in Jerusalem.","searchKeywords":["the","preacher","was","king","over","israel","jerusalem"]},{"verseId":"brenton_ecclesiastes_1_13","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":13,"text":"And I applied my heart to seek out and examine by wisdom concerning all things that are done under heaven, for God has given to the sons of men an evil trouble to be troubled therewith.","searchKeywords":["and","applied","heart","seek","out","examine","wisdom","concerning","all","things","that","are","done","under","heaven","for","god","has","given","the","sons","men","evil","trouble","troubled","therewith"]},{"verseId":"brenton_ecclesiastes_1_14","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":14,"text":"I beheld all the works that were wrought under the sun; and, behold, all were vanity and waywardness of spirit.","searchKeywords":["beheld","all","the","works","that","were","wrought","under","sun","and","behold","vanity","waywardness","spirit"]},{"verseId":"brenton_ecclesiastes_1_15","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":15,"text":"That which is crooked cannot be made straight: and deficiency cannot be numbered.","searchKeywords":["that","which","crooked","cannot","made","straight","and","deficiency","numbered"]},{"verseId":"brenton_ecclesiastes_1_16","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":16,"text":"I spoke in my heart, saying, Behold, I am increased, and have acquired wisdom beyond all who were before me in Jerusalem: also I applied my heart to know wisdom and knowledge.","searchKeywords":["spoke","heart","saying","behold","increased","and","have","acquired","wisdom","beyond","all","who","were","before","jerusalem","also","applied","know","knowledge"]},{"verseId":"brenton_ecclesiastes_1_17","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":17,"text":"And my heart knew much—wisdom, and knowledge, parables and understanding: I perceived that this also is waywardness of spirit.","searchKeywords":["and","heart","knew","much","wisdom","knowledge","parables","understanding","perceived","that","this","also","waywardness","spirit"]},{"verseId":"brenton_ecclesiastes_1_18","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":1,"verse":18,"text":"For in the abundance of wisdom is abundance of knowledge; and he that increases knowledge will increase sorrow.","searchKeywords":["for","the","abundance","wisdom","knowledge","and","that","increases","will","increase","sorrow"]}]