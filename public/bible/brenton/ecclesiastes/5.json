[{"verseId":"brenton_ecclesiastes_5_1","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":1,"text":"Be not hasty with thy mouth, and let not thine heart be swift to utter anything before God; for God is in heaven above, and thou upon earth: therefore let thy words be few.","searchKeywords":["not","hasty","with","thy","mouth","and","let","thine","heart","swift","utter","anything","before","god","for","heaven","above","thou","upon","earth","therefore","words","few"]},{"verseId":"brenton_ecclesiastes_5_2","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":2,"text":"For through the multitude of trial a dream comes; and a fool's voice is with a multitude of words.","searchKeywords":["for","through","the","multitude","trial","dream","comes","and","fool","voice","with","words"]},{"verseId":"brenton_ecclesiastes_5_3","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":3,"text":"Whenever thou shalt vow a vow to God, defer not to pay it; for no pleasure in fools: pay thou therefore whatsoever thou shalt have vowed.","searchKeywords":["whenever","thou","shalt","vow","god","defer","not","pay","for","pleasure","fools","therefore","whatsoever","have","vowed"]},{"verseId":"brenton_ecclesiastes_5_4","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":4,"text":"better that thou shouldest not vow, than that thou shouldest vow and not pay.","searchKeywords":["better","that","thou","shouldest","not","vow","than","and","pay"]},{"verseId":"brenton_ecclesiastes_5_5","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":5,"text":"Suffer not thy mouth to lead thy flesh to sin; and say not in the presence of God, It was an error: lest God be angry at thy voice, and destroy the works of thy hands.","searchKeywords":["suffer","not","thy","mouth","lead","flesh","sin","and","say","the","presence","god","was","error","lest","angry","voice","destroy","works","hands"]},{"verseId":"brenton_ecclesiastes_5_6","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":6,"text":"For in a multitude of dreams and vanities and many words: but fear thou God.","searchKeywords":["for","multitude","dreams","and","vanities","many","words","but","fear","thou","god"]},{"verseId":"brenton_ecclesiastes_5_7","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":7,"text":"If thou shouldest see the oppression of the poor, and the wresting of judgment and of justice in the land, wonder not at the matter: for a high one to watch over him that is high, and high ones over them.","searchKeywords":["thou","shouldest","see","the","oppression","poor","and","wresting","judgment","justice","land","wonder","not","matter","for","high","one","watch","over","him","that","ones","them"]},{"verseId":"brenton_ecclesiastes_5_8","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":8,"text":"Also the abundance of the earth is for every one: the king the tilled field.","searchKeywords":["also","the","abundance","earth","for","every","one","king","tilled","field"]},{"verseId":"brenton_ecclesiastes_5_9","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":9,"text":"He that loves silver shall not be satisfied with silver: and who has loved gain, in the abundance thereof? this is also vanity.","searchKeywords":["that","loves","silver","shall","not","satisfied","with","and","who","has","loved","gain","the","abundance","thereof","this","also","vanity"]},{"verseId":"brenton_ecclesiastes_5_10","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":10,"text":"In the multitude of good they are increased that eat it: and what virtue has the owner, but the right of beholding with his eyes?","searchKeywords":["the","multitude","good","they","are","increased","that","eat","and","what","virtue","has","owner","but","right","beholding","with","his","eyes"]},{"verseId":"brenton_ecclesiastes_5_11","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":11,"text":"The sleep of a servant is sweet, whether he eat little or much: but to one who is satiated with wealth, there is none that suffers him to sleep.","searchKeywords":["the","sleep","servant","sweet","whether","eat","little","much","but","one","who","satiated","with","wealth","there","none","that","suffers","him"]},{"verseId":"brenton_ecclesiastes_5_12","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":12,"text":"There is an infirmity which I have seen under the sun, , wealth kept for its owner to his hurt.","searchKeywords":["there","infirmity","which","have","seen","under","the","sun","wealth","kept","for","its","owner","his","hurt"]},{"verseId":"brenton_ecclesiastes_5_13","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":13,"text":"And that wealth shall perish in an evil trouble: and begets a son, and there is nothing in his hand.","searchKeywords":["and","that","wealth","shall","perish","evil","trouble","begets","son","there","nothing","his","hand"]},{"verseId":"brenton_ecclesiastes_5_14","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":14,"text":"As he came forth naked from his mother's womb, he shall return back as he came, and he shall receive nothing for his labour, that it should go in his hand.","searchKeywords":["came","forth","naked","from","his","mother","womb","shall","return","back","and","receive","nothing","for","labour","that","should","hand"]},{"verseId":"brenton_ecclesiastes_5_15","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":15,"text":"And this is also an evil infirmity: for as he came, so also shall he return: and what is his gain, for which he vainly labours?","searchKeywords":["and","this","also","evil","infirmity","for","came","shall","return","what","his","gain","which","vainly","labours"]},{"verseId":"brenton_ecclesiastes_5_16","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":16,"text":"Yea, all his days are in darkness, and in mourning, and much sorrow, and infirmity, and wrath.","searchKeywords":["yea","all","his","days","are","darkness","and","mourning","much","sorrow","infirmity","wrath"]},{"verseId":"brenton_ecclesiastes_5_17","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":17,"text":"Behold, I have seen good, that it is a fine thing to eat and to drink, and to see good in all his labour in which he may labour under the sun, the number of the days of his life which God has given to him: for it is his portion.","searchKeywords":["behold","have","seen","good","that","fine","thing","eat","and","drink","see","all","his","labour","which","may","under","the","sun","number","days","life","god","has","given","him","for","portion"]},{"verseId":"brenton_ecclesiastes_5_18","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":18,"text":"Yea, and every man to whom God has given wealth and possessions, and has given him power to eat thereof, and to receive his portion, and to rejoice in his labour; this is the gift of God.","searchKeywords":["yea","and","every","man","whom","god","has","given","wealth","possessions","him","power","eat","thereof","receive","his","portion","rejoice","labour","this","the","gift"]},{"verseId":"brenton_ecclesiastes_5_19","translationId":"brenton","testament":"OT","bookIndex":27,"bookName":"Ecclesiastes","bookAbbrev":"ecclesiastes","chapter":5,"verse":19,"text":"For he shall not much remember the days of his life; for God troubles him in the mirth of his heart.","searchKeywords":["for","shall","not","much","remember","the","days","his","life","god","troubles","him","mirth","heart"]}]