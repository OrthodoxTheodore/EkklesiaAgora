[{"verseId":"brenton_zechariah_3_1","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":3,"verse":1,"text":"And the Lord shewed me Jesus the high priest standing before the angel of the Lord, and the Devil stood on his right hand to resist him. And the Lord said to the Devil,","searchKeywords":["and","the","lord","shewed","jesus","high","priest","standing","before","angel","devil","stood","his","right","hand","resist","him","said"]},{"verseId":"brenton_zechariah_3_2","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":3,"verse":2,"text":"The Lord rebuke thee, O Devil, even the Lord that has chosen Jerusalem rebuke thee: behold! is not this as a brand plucked from the fire?","searchKeywords":["the","lord","rebuke","thee","devil","even","that","has","chosen","jerusalem","behold","not","this","brand","plucked","from","fire"]},{"verseId":"brenton_zechariah_3_3","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":3,"verse":3,"text":"Now Jesus was clothed in filthy raiment, and stood before the angel.","searchKeywords":["now","jesus","was","clothed","filthy","raiment","and","stood","before","the","angel"]},{"verseId":"brenton_zechariah_3_4","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":3,"verse":4,"text":"And answered and spoke to those who stood before him, saying, Take away the filthy raiment from him: and he said to him, Behold, I have taken away thine iniquities: and clothe ye him with a long robe,","searchKeywords":["and","answered","spoke","those","who","stood","before","him","saying","take","away","the","filthy","raiment","from","said","behold","have","taken","thine","iniquities","clothe","with","long","robe"]},{"verseId":"brenton_zechariah_3_5","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":3,"verse":5,"text":"and place a pure mitre upon his head. So they placed a pure mitre upon his head, and clothed him with garments: and the angel of the Lord stood .","searchKeywords":["and","place","pure","mitre","upon","his","head","they","placed","clothed","him","with","garments","the","angel","lord","stood"]},{"verseId":"brenton_zechariah_3_6","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":3,"verse":6,"text":"And the angel of the Lord testified to Jesus, saying,","searchKeywords":["and","the","angel","lord","testified","jesus","saying"]},{"verseId":"brenton_zechariah_3_7","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":3,"verse":7,"text":"Thus saith the Lord Almighty; .","searchKeywords":["thus","saith","the","lord","almighty"]},{"verseId":"brenton_zechariah_3_8","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":3,"verse":8,"text":"Hear now, Jesus the high priest, thou, and thy neighbours that are sitting before : for they are diviners, for, behold, I bring forth my servant The Branch.","searchKeywords":["hear","now","jesus","the","high","priest","thou","and","thy","neighbours","that","are","sitting","before","for","they","diviners","behold","bring","forth","servant","branch"]},{"verseId":"brenton_zechariah_3_9","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":3,"verse":9,"text":"For the stone which I have set before the face of Jesus, on the one stone are seven eyes: behold, I am digging a trench, saith the Lord Almighty, and I will search out all the iniquity of that land in one day.","searchKeywords":["for","the","stone","which","have","set","before","face","jesus","one","are","seven","eyes","behold","digging","trench","saith","lord","almighty","and","will","search","out","all","iniquity","that","land","day"]},{"verseId":"brenton_zechariah_3_10","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":3,"verse":10,"text":"In that day, saith the Lord Almighty, ye shall call together every man his neighbour under the vine and under the fig-tree.","searchKeywords":["that","day","saith","the","lord","almighty","shall","call","together","every","man","his","neighbour","under","vine","and","fig","tree"]}]