[{"verseId":"brenton_zechariah_7_1","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":1,"text":"And it came to pass in the fourth year of Darius the king, the word of the Lord came to Zacharias on the fourth of the ninth month, which is Chaseleu.","searchKeywords":["and","came","pass","the","fourth","year","darius","king","word","lord","zacharias","ninth","month","which","chaseleu"]},{"verseId":"brenton_zechariah_7_2","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":2,"text":"And Sarasar and Arbeseer the king and his men sent to Bæthel, and to propitiate the Lord,","searchKeywords":["and","sarasar","arbeseer","the","king","his","men","sent","thel","propitiate","lord"]},{"verseId":"brenton_zechariah_7_3","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":3,"text":"speaking to the priests that were in the house of the Lord Almighty, and to the prophets, saying, The holy offering has come in hither in the fifth month, as it has done already many years.","searchKeywords":["speaking","the","priests","that","were","house","lord","almighty","and","prophets","saying","holy","offering","has","come","hither","fifth","month","done","already","many","years"]},{"verseId":"brenton_zechariah_7_4","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":4,"text":"And the word of the Lord of hosts came to me, saying,","searchKeywords":["and","the","word","lord","hosts","came","saying"]},{"verseId":"brenton_zechariah_7_5","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":5,"text":"Speak to the whole people of the land, and to the priests, saying, Though ye fasted or lamented in the fifth or seventh (yea, behold, these seventy years) have ye at all fasted to me?","searchKeywords":["speak","the","whole","people","land","and","priests","saying","though","fasted","lamented","fifth","seventh","yea","behold","these","seventy","years","have","all"]},{"verseId":"brenton_zechariah_7_6","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":6,"text":"And if ye eat or drink, do ye not eat and drink for yourselves?","searchKeywords":["and","eat","drink","not","for","yourselves"]},{"verseId":"brenton_zechariah_7_7","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":7,"text":"Are not these the words which the Lord spoke by the former prophets, when Jerusalem was inhabited and in prosperity, and her cities round about her, and the hill country and the low country was inhabited?","searchKeywords":["are","not","these","the","words","which","lord","spoke","former","prophets","when","jerusalem","was","inhabited","and","prosperity","her","cities","round","about","hill","country","low"]},{"verseId":"brenton_zechariah_7_8","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":8,"text":"And the word of the Lord came to Zacharias, saying,","searchKeywords":["and","the","word","lord","came","zacharias","saying"]},{"verseId":"brenton_zechariah_7_9","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":9,"text":"Thus saith the Lord Almighty;","searchKeywords":["thus","saith","the","lord","almighty"]},{"verseId":"brenton_zechariah_7_10","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":10,"text":"and oppress not the widow, or the fatherless, or the stranger, or the poor; and let not one of you remember in his heart the injury of his brother.","searchKeywords":["and","oppress","not","the","widow","fatherless","stranger","poor","let","one","you","remember","his","heart","injury","brother"]},{"verseId":"brenton_zechariah_7_11","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":11,"text":"But they refused to attend, and madly turned their back, and made their ears heavy, so that they should not hear.","searchKeywords":["but","they","refused","attend","and","madly","turned","their","back","made","ears","heavy","that","should","not","hear"]},{"verseId":"brenton_zechariah_7_12","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":12,"text":"And they made their heart disobedient, so as not to hearken to my law, and the words which the Lord Almighty sent forth by his Spirit by the former prophets: so there was great wrath from the Lord Almighty.","searchKeywords":["and","they","made","their","heart","disobedient","not","hearken","law","the","words","which","lord","almighty","sent","forth","his","spirit","former","prophets","there","was","great","wrath","from"]},{"verseId":"brenton_zechariah_7_13","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":13,"text":"And it shall come to pass, as he spoke, and they hearkened not, so they shall cry, and I will not hearken, saith the Lord Almighty.","searchKeywords":["and","shall","come","pass","spoke","they","hearkened","not","cry","will","hearken","saith","the","lord","almighty"]},{"verseId":"brenton_zechariah_7_14","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":7,"verse":14,"text":"And I will cast them out among all the nations, whom they know not; and the land behind them shall be made utterly destitute of any going through or returning: yea they have made the choice land a desolation.","