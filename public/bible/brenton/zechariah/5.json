[{"verseId":"brenton_zechariah_5_1","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":5,"verse":1,"text":"And I turned, and lifted up mine eyes, and looked and behold a flying sickle.","searchKeywords":["and","turned","lifted","mine","eyes","looked","behold","flying","sickle"]},{"verseId":"brenton_zechariah_5_2","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":5,"verse":2,"text":"And he said to me, What seest thou? And I said, I see a flying sickle, of the length of twenty cubits, and of the breadth of ten cubits.","searchKeywords":["and","said","what","seest","thou","see","flying","sickle","the","length","twenty","cubits","breadth","ten"]},{"verseId":"brenton_zechariah_5_3","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":5,"verse":3,"text":"And he said to me,","searchKeywords":["and","said"]},{"verseId":"brenton_zechariah_5_4","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":5,"verse":4,"text":"And I will bring it forth, saith the Lord Almighty, and it shall enter into the house of the thief, and into the house of him that swears falsely by my name: and it shall rest in the midst of his house, and shall consume it, and the timber of it, and the stones of it.","searchKeywords":["and","will","bring","forth","saith","the","lord","almighty","shall","enter","into","house","thief","him","that","swears","falsely","name","rest","midst","his","consume","timber","stones"]},{"verseId":"brenton_zechariah_5_5","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":5,"verse":5,"text":"And the angel that talked with me went forth, and said to me, Lift up thine eyes, and see this that goes forth.","searchKeywords":["and","the","angel","that","talked","with","went","forth","said","lift","thine","eyes","see","this","goes"]},{"verseId":"brenton_zechariah_5_6","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":5,"verse":6,"text":"And I said, What is it? And he said, This is the measure that goes forth. And he said, This is their iniquity in all the earth.","searchKeywords":["and","said","what","this","the","measure","that","goes","forth","their","iniquity","all","earth"]},{"verseId":"brenton_zechariah_5_7","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":5,"verse":7,"text":"And behold a talent of lead lifted up: and behold a woman sat in the midst of the measure.","searchKeywords":["and","behold","talent","lead","lifted","woman","sat","the","midst","measure"]},{"verseId":"brenton_zechariah_5_8","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":5,"verse":8,"text":"And he said, This is iniquity. And he cast it into the midst of the measure, and cast the weight of lead on the mouth of it.","searchKeywords":["and","said","this","iniquity","cast","into","the","midst","measure","weight","lead","mouth"]},{"verseId":"brenton_zechariah_5_9","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":5,"verse":9,"text":"And I lifted up mine eyes, and saw, and, behold, two women coming forth, and the wind was in their wings; and they had stork's wings: and they lifted up the measure between the earth and the sky.","searchKeywords":["and","lifted","mine","eyes","saw","behold","two","women","coming","forth","the","wind","was","their","wings","they","had","stork","measure","between","earth","sky"]},{"verseId":"brenton_zechariah_5_10","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":5,"verse":10,"text":"And I said to the angel that spoke with me, Whither do these carry away the measure?","searchKeywords":["and","said","the","angel","that","spoke","with","whither","these","carry","away","measure"]},{"verseId":"brenton_zechariah_5_11","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":5,"verse":11,"text":"And he said to me, To build it a house in the land of Babylon, and to prepare ; and they shall set it there on its own base.","searchKeywords":["and","said","build","house","the","land","babylon","prepare","they","shall","set","there","its","own","base"]}]