[{"verseId":"brenton_zechariah_2_1","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":1,"text":"And I lifted up mine eyes and looked, and behold four horns.","searchKeywords":["and","lifted","mine","eyes","looked","behold","four","horns"]},{"verseId":"brenton_zechariah_2_2","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":2,"text":"And I said to the angel that spoke with me, What are these things, lord? And he said to me, These are the horns that have scattered Juda, and Israel, and Jerusalem.","searchKeywords":["and","said","the","angel","that","spoke","with","what","are","these","things","lord","horns","have","scattered","juda","israel","jerusalem"]},{"verseId":"brenton_zechariah_2_3","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":3,"text":"And the Lord shewed me four artificers.","searchKeywords":["and","the","lord","shewed","four","artificers"]},{"verseId":"brenton_zechariah_2_4","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":4,"text":"And I said, What are these coming to do? And he said, These are the horns that scattered Juda, and they broke Israel in pieces, and none of them lifted up his head: and these are come forth to sharpen them for their hands, the four horns, the nations that lifted up the horn against the land of the Lord to scatter it.","searchKeywords":["and","said","what","are","these","coming","the","horns","that","scattered","juda","they","broke","israel","pieces","none","them","lifted","his","head","come","forth","sharpen","for","their","hands","four","nations","horn","against","land","lord","scatter"]},{"verseId":"brenton_zechariah_2_5","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":5,"text":"And I lifted up mine eyes, and looked, and behold a man, and in his hand a measuring line.","searchKeywords":["and","lifted","mine","eyes","looked","behold","man","his","hand","measuring","line"]},{"verseId":"brenton_zechariah_2_6","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":6,"text":"And I said to him, Whither goest thou? And he said to me, To measure Jerusalem, to see what is the breadth of it, and what is the length of it.","searchKeywords":["and","said","him","whither","goest","thou","measure","jerusalem","see","what","the","breadth","length"]},{"verseId":"brenton_zechariah_2_7","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":7,"text":"And, behold, the angel that spoke with me stood , and another angel went forth to meet him,","searchKeywords":["and","behold","the","angel","that","spoke","with","stood","another","went","forth","meet","him"]},{"verseId":"brenton_zechariah_2_8","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":8,"text":"and spoke to him, saying, Run and speak to that young man, saying,","searchKeywords":["and","spoke","him","saying","run","speak","that","young","man"]},{"verseId":"brenton_zechariah_2_9","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":9,"text":"And I will be to her, saith the Lord, a wall of fire round about, and I will be for a glory in the midst of her.","searchKeywords":["and","will","her","saith","the","lord","wall","fire","round","about","for","glory","midst"]},{"verseId":"brenton_zechariah_2_10","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":10,"text":"Ho, ho, flee from the land of the north, saith the Lord: for I will gather you from the four winds of heaven, saith the Lord,","searchKeywords":["flee","from","the","land","north","saith","lord","for","will","gather","you","four","winds","heaven"]},{"verseId":"brenton_zechariah_2_11","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":11,"text":"to Sion: deliver yourselves, ye that dwell the daughter of Babylon.","searchKeywords":["sion","deliver","yourselves","that","dwell","the","daughter","babylon"]},{"verseId":"brenton_zechariah_2_12","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":12,"text":"For thus saith the Lord Almighty; After the glory has he sent me to the nations that spoiled you: for he that touches you is as one that touches the apple of his eye.","searchKeywords":["for","thus","saith","the","lord","almighty","after","glory","has","sent","nations","that","spoiled","you","touches","one","apple","his","eye"]},{"verseId":"brenton_zechariah_2_13","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":13,"text":"For, behold, I bring my hand upon them, and they shall be a spoil to them that serve them: and ye shall know that the Lord Almighty has sent me.","searchKeywords":["for","behold","bring","hand","upon","them","and","they","shall","spoil","that","serve","know","the","lord","almighty","has","sent"]},{"verseId":"brenton_zechariah_2_14","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":14,"text":"Rejoice and be glad, O daughter of Sion: for, behold, I come, and will dwell in the midst of thee, saith the Lord.","searchKeywords":["rejoice","and","glad","daughter","sion","for","behold","come","will","dwell","the","midst","thee","saith","lord"]},{"verseId":"brenton_zechariah_2_15","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":15,"text":"And many nations shall flee for refuge to the Lord in that day, and they shall be for a people to him, and they shall dwell in the midst of thee: and thou shalt know that the Lord Almighty has sent me to thee.","searchKeywords":["and","many","nations","shall","flee","for","refuge","the","lord","that","day","they","people","him","dwell","midst","thee","thou","shalt","know","almighty","has","sent"]},{"verseId":"brenton_zechariah_2_16","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":16,"text":"And the Lord shall inherit Juda his portion in the holy , and he will yet choose Jerusalem.","searchKeywords":["and","the","lord","shall","inherit","juda","his","portion","holy","will","yet","choose","jerusalem"]},{"verseId":"brenton_zechariah_2_17","translationId":"brenton","testament":"OT","bookIndex":43,"bookName":"Zechariah","bookAbbrev":"zechariah","chapter":2,"verse":17,"text":"Let all flesh fear before the Lord: for he has risen up from his holy clouds.","searchKeywords":["let","all","flesh","fear","before","the","lord","for","has","risen","from","his","holy","clouds"]}]