[{"verseId":"brenton_deuteronomy_18_1","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":1,"text":"The priests, the Levites, even the whole tribe of Levi, shall have no part nor inheritance with Israel; the burnt-offerings of the Lord their inheritance, they shall eat them.","searchKeywords":["the","priests","levites","even","whole","tribe","levi","shall","have","part","nor","inheritance","with","israel","burnt","offerings","lord","their","they","eat","them"]},{"verseId":"brenton_deuteronomy_18_2","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":2,"text":"And they shall have no inheritance among their brethren; the Lord himself his portion, as he said to him.","searchKeywords":["and","they","shall","have","inheritance","among","their","brethren","the","lord","himself","his","portion","said","him"]},{"verseId":"brenton_deuteronomy_18_3","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":3,"text":"And this the due of the priests in the things coming from the people from those who offer sacrifices, whether it be a calf or a sheep; and thou shalt give the shoulder to the priest, and the cheeks, and the great intestine:","searchKeywords":["and","this","the","due","priests","things","coming","from","people","those","who","offer","sacrifices","whether","calf","sheep","thou","shalt","give","shoulder","priest","cheeks","great","intestine"]},{"verseId":"brenton_deuteronomy_18_4","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":4,"text":"and the first-fruits of thy corn, and of thy wine, and of thine oil; and thou shalt give to him the first-fruits of the fleeces of thy sheep:","searchKeywords":["and","the","first","fruits","thy","corn","wine","thine","oil","thou","shalt","give","him","fleeces","sheep"]},{"verseId":"brenton_deuteronomy_18_5","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":5,"text":"because the Lord has chosen him out of all thy tribes, to stand before the Lord thy God, to minister and bless in his name, himself and his sons among the children of Israel.","searchKeywords":["because","the","lord","has","chosen","him","out","all","thy","tribes","stand","before","god","minister","and","bless","his","name","himself","sons","among","children","israel"]},{"verseId":"brenton_deuteronomy_18_6","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":6,"text":"And if a Levite come from one of the cities of all the children of Israel, where he himself dwells, accordingly as his mind desires, to the place which he shall have chosen,","searchKeywords":["and","levite","come","from","one","the","cities","all","children","israel","where","himself","dwells","accordingly","his","mind","desires","place","which","shall","have","chosen"]},{"verseId":"brenton_deuteronomy_18_7","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":7,"text":"he shall minister to the name of the Lord his God, as all his brethren the Levites, who stand there present before the Lord thy God.","searchKeywords":["shall","minister","the","name","lord","his","god","all","brethren","levites","who","stand","there","present","before","thy"]},{"verseId":"brenton_deuteronomy_18_8","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":8,"text":"He shall eat an allotted portion, besides the sale of his hereditary property.","searchKeywords":["shall","eat","allotted","portion","besides","the","sale","his","hereditary","property"]},{"verseId":"brenton_deuteronomy_18_9","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":9,"text":"And when thou shalt have entered into the land which the Lord thy God gives thee, thou shalt not learn to do according to the abominations of those nations.","searchKeywords":["and","when","thou","shalt","have","entered","into","the","land","which","lord","thy","god","gives","thee","not","learn","according","abominations","those","nations"]},{"verseId":"brenton_deuteronomy_18_10","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":10,"text":"There shall not be found in thee one who purges his son or his daughter with fire, one who uses divination, who deals with omens, and augury,","searchKeywords":["there","shall","not","found","thee","one","who","purges","his","son","daughter","with","fire","uses","divination","deals","omens","and","augury"]},{"verseId":"brenton_deuteronomy_18_11","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":11,"text":"a sorcerer employing incantation, one who has in him a divining spirit, an observer of signs, questioning the dead.","searchKeywords":["sorcerer","employing","incantation","one","who","has","him","divining","spirit","observer","signs","questioning","the","dead"]},{"verseId":"brenton_deuteronomy_18_12","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":12,"text":"For every one that does these things is an abomination to the Lord thy God; for because of these abominations the Lord will destroy them from before thy face.","searchKeywords":["for","every","one","that","does","these","things","abomination","the","lord","thy","god","because","abominations","will","destroy","them","from","before","face"]},{"verseId":"brenton_deuteronomy_18_13","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":13,"text":"Thou shalt be perfect before the Lord thy God.","searchKeywords":["thou","shalt","perfect","before","the","lord","thy","god"]},{"verseId":"brenton_deuteronomy_18_14","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":14,"text":"For all these nations whose thou shalt inherit, they will listen to omens and divinations; but the Lord thy God has not permitted thee so .","searchKeywords":["for","all","these","nations","whose","thou","shalt","inherit","they","will","listen","omens","and","divinations","but","the","lord","thy","god","has","not","permitted","thee"]},{"verseId":"brenton_deuteronomy_18_15","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":15,"text":"The Lord thy God shall raise up to thee a prophet of thy brethren, like me; him shall ye hear:","searchKeywords":["the","lord","thy","god","shall","raise","thee","prophet","brethren","like","him","hear"]},{"verseId":"brenton_deuteronomy_18_16","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":16,"text":"according to all things which thou didst desire of the Lord thy God in Choreb in the day of the assembly, saying, We will not again hear the voice of the Lord thy God, and we will not any more see this great fire, and we shall not die.","searchKeywords":["according","all","things","which","thou","didst","desire","the","lord","thy","god","choreb","day","assembly","saying","will","not","again","hear","voice","and","any","more","see","this","great","fire","shall","die"]},{"verseId":"brenton_deuteronomy_18_17","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":17,"text":"And the Lord said to me, They have spoken rightly all that they have said to thee.","searchKeywords":["and","the","lord","said","they","have","spoken","rightly","all","that","thee"]},{"verseId":"brenton_deuteronomy_18_18","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":18,"text":"I will raise up to them a prophet of their brethren, like thee; and I will put my words in his mouth, and he shall speak to them as I shall command him.","searchKeywords":["will","raise","them","prophet","their","brethren","like","thee","and","put","words","his","mouth","shall","speak","command","him"]},{"verseId":"brenton_deuteronomy_18_19","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":19,"text":"And whatever man shall not hearken to whatsoever words that prophet shall speak in my name, I will take vengeance on him.","searchKeywords":["and","whatever","man","shall","not","hearken","whatsoever","words","that","prophet","speak","name","will","take","vengeance","him"]},{"verseId":"brenton_deuteronomy_18_20","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":20,"text":"But the prophet whosoever shall impiously speak in my name a word which I have not commanded him to speak, and whosoever shall speak in the name of other gods, that prophet shall die.","searchKeywords":["but","the","prophet","whosoever","shall","impiously","speak","name","word","which","have","not","commanded","him","and","other","gods","that","die"]},{"verseId":"brenton_deuteronomy_18_21","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":21,"text":"But if thou shalt say in thine heart, How shall we know the word which the Lord has not spoken?","searchKeywords":["but","thou","shalt","say","thine","heart","how","shall","know","the","word","which","lord","has","not","spoken"]},{"verseId":"brenton_deuteronomy_18_22","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":18,"verse":22,"text":"Whatsoever words that prophet shall speak in the name of the Lord, and they shall not come true, and not come to pass, this the thing which the Lord has not spoken; that prophet has spoken wickedly: ye shall not spare him.","searchKeywords":["whatsoever","words","that","prophet","shall","speak","the","name","lord","and","they","not","come","true","pass","this","thing","which","has","spoken","wickedly","spare","him"]}]