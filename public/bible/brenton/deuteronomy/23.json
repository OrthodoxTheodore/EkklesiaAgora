[{"verseId":"brenton_deuteronomy_23_1","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":1,"text":"A man shall not take his father's wife, and shall not uncover his father's skirt.","searchKeywords":["man","shall","not","take","his","father","wife","and","uncover","skirt"]},{"verseId":"brenton_deuteronomy_23_2","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":2,"text":"He that is fractured or mutilated in his private parts shall not enter into the assembly of the Lord.","searchKeywords":["that","fractured","mutilated","his","private","parts","shall","not","enter","into","the","assembly","lord"]},{"verseId":"brenton_deuteronomy_23_3","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":3,"text":"of a harlot shall not enter into the assembly of the Lord.","searchKeywords":["harlot","shall","not","enter","into","the","assembly","lord"]},{"verseId":"brenton_deuteronomy_23_4","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":4,"text":"The Ammanite and Moabite shall not enter into the assembly of the Lord, even until the tenth generation he shall not enter into the assembly of the Lord, even for ever:","searchKeywords":["the","ammanite","and","moabite","shall","not","enter","into","assembly","lord","even","until","tenth","generation","for","ever"]},{"verseId":"brenton_deuteronomy_23_5","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":5,"text":"because they met you not with bread and water by the way, when ye went out of Egypt; and because they hired against thee Balaam the son of Beor of Mesopotamia to curse thee.","searchKeywords":["because","they","met","you","not","with","bread","and","water","the","way","when","went","out","egypt","hired","against","thee","balaam","son","beor","mesopotamia","curse"]},{"verseId":"brenton_deuteronomy_23_6","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":6,"text":"But the Lord thy God would not hearken to Balaam; and the Lord thy God changed the curses into blessings, because the Lord thy God loved thee.","searchKeywords":["but","the","lord","thy","god","would","not","hearken","balaam","and","changed","curses","into","blessings","because","loved","thee"]},{"verseId":"brenton_deuteronomy_23_7","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":7,"text":"Thou shalt not speak peaceably or profitably to them all thy days for ever.","searchKeywords":["thou","shalt","not","speak","peaceably","profitably","them","all","thy","days","for","ever"]},{"verseId":"brenton_deuteronomy_23_8","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":8,"text":"Thou shalt not abhor an Edomite, because he is thy brother; thou shalt not abhor an Egyptian, because thou wast a stranger in his land.","searchKeywords":["thou","shalt","not","abhor","edomite","because","thy","brother","egyptian","wast","stranger","his","land"]},{"verseId":"brenton_deuteronomy_23_9","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":9,"text":"If sons be born to them, in the third generation they shall enter into the assembly of the Lord.","searchKeywords":["sons","born","them","the","third","generation","they","shall","enter","into","assembly","lord"]},{"verseId":"brenton_deuteronomy_23_10","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":10,"text":"And if thou shouldest go forth to engage with thine enemies, then thou shalt keep thee from every wicked thing.","searchKeywords":["and","thou","shouldest","forth","engage","with","thine","enemies","then","shalt","keep","thee","from","every","wicked","thing"]},{"verseId":"brenton_deuteronomy_23_11","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":11,"text":"If there should be in thee a man who is not clean by reason of his issue by night, then he shall go forth out of the camp, and he shall not enter into the camp.","searchKeywords":["there","should","thee","man","who","not","clean","reason","his","issue","night","then","shall","forth","out","the","camp","and","enter","into"]},{"verseId":"brenton_deuteronomy_23_12","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":12,"text":"And it shall come to pass toward evening he shall wash his body with water, and when the sun has gone down, he shall go into the camp.","searchKeywords":["and","shall","come","pass","toward","evening","wash","his","body","with","water","when","the","sun","has","gone","down","into","camp"]},{"verseId":"brenton_deuteronomy_23_13","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":13,"text":"And thou shalt have a place outside of the camp, and thou shalt go out thither,","searchKeywords":["and","thou","shalt","have","place","outside","the","camp","out","thither"]},{"verseId":"brenton_deuteronomy_23_14","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":14,"text":"and thou shalt have a trowel on thy girdle; and it shall come to pass when thou wouldest relieve thyself abroad, that thou shalt dig with it, and shalt bring back the earth and cover thy nuisance.","searchKeywords":["and","thou","shalt","have","trowel","thy","girdle","shall","come","pass","when","wouldest","relieve","thyself","abroad","that","dig","with","bring","back","the","earth","cover","nuisance"]},{"verseId":"brenton_deuteronomy_23_15","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":15,"text":"Because the Lord thy God walks in thy camp to deliver thee, and to give up thine enemy before thy face; and thy camp shall be holy, and there shall not appear in thee a disgraceful thing, and he shall turn away from thee.","searchKeywords":["because","the","lord","thy","god","walks","camp","deliver","thee","and","give","thine","enemy","before","face","shall","holy","there","not","appear","disgraceful","thing","turn","away","from"]},{"verseId":"brenton_deuteronomy_23_16","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":16,"text":"Thou shalt not deliver a servant to his master, who from his master attaches himself to thee.","searchKeywords":["thou","shalt","not","deliver","servant","his","master","who","from","attaches","himself","thee"]},{"verseId":"brenton_deuteronomy_23_17","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":17,"text":"He shall dwell with thee, he shall dwell among you where he shall please; thou shalt not afflict him.","searchKeywords":["shall","dwell","with","thee","among","you","where","please","thou","shalt","not","afflict","him"]},{"verseId":"brenton_deuteronomy_23_18","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":18,"text":"There shall not be a harlot of the daughters of Israel, and there shall not be a fornicator of the sons of Israel; there shall not be an idolatress of the daughters of Israel, and there shall not be an initiated person of the sons of Israel.","searchKeywords":["there","shall","not","harlot","the","daughters","israel","and","fornicator","sons","idolatress","initiated","person"]},{"verseId":"brenton_deuteronomy_23_19","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":19,"text":"Thou shalt not bring the hire of a harlot, nor the price of a dog into the house of the Lord thy God, for any vow; because even both are an abomination to the Lord thy God.","searchKeywords":["thou","shalt","not","bring","the","hire","harlot","nor","price","dog","into","house","lord","thy","god","for","any","vow","because","even","both","are","abomination"]},{"verseId":"brenton_deuteronomy_23_20","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":20,"text":"Thou shalt not lend to thy brother on usury of silver, or usury of meat, or usury of any thing which thou mayest lend out.","searchKeywords":["thou","shalt","not","lend","thy","brother","usury","silver","meat","any","thing","which","mayest","out"]},{"verseId":"brenton_deuteronomy_23_21","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":21,"text":"Thou mayest lend on usury to a stranger, but to thy brother thou shalt not lend on usury; that the Lord thy God may bless thee in all thy works upon the land, into which thou art entering to inherit it.","searchKeywords":["thou","mayest","lend","usury","stranger","but","thy","brother","shalt","not","that","the","lord","god","may","bless","thee","all","works","upon","land","into","which","art","entering","inherit"]},{"verseId":"brenton_deuteronomy_23_22","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":22,"text":"And if thou wilt vow a vow to the Lord thy God, thou shalt not delay to pay it; for the Lord thy God will surely require it of thee, and it shall be sin in thee.","searchKeywords":["and","thou","wilt","vow","the","lord","thy","god","shalt","not","delay","pay","for","will","surely","require","thee","shall","sin"]},{"verseId":"brenton_deuteronomy_23_23","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":23,"text":"But if thou shouldest be unwilling to vow, it is not sin in thee.","searchKeywords":["but","thou","shouldest","unwilling","vow","not","sin","thee"]},{"verseId":"brenton_deuteronomy_23_24","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":24,"text":"Thou shalt observe the words that proceed from between thy lips; and as thou hast vowed a gift to the Lord God, shalt thou do that which thou hast spoken with thy mouth.","searchKeywords":["thou","shalt","observe","the","words","that","proceed","from","between","thy","lips","and","hast","vowed","gift","lord","god","which","spoken","with","mouth"]},{"verseId":"brenton_deuteronomy_23_25","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":25,"text":"And if thou shouldest go into the corn field of thy neighbour, then thou mayest gather the ears with thy hands; but thou shalt not put the sickle to thy neighbour's corn.","searchKeywords":["and","thou","shouldest","into","the","corn","field","thy","neighbour","then","mayest","gather","ears","with","hands","but","shalt","not","put","sickle"]},{"verseId":"brenton_deuteronomy_23_26","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":23,"verse":26,"text":"And if thou shouldest go into the vineyard of thy neighbour, thou shalt eat grapes sufficient to satisfy thy desire; but thou mayest not put them into a vessel.","searchKeywords":["and","thou","shouldest","into","the","vineyard","thy","neighbour","shalt","eat","grapes","sufficient","satisfy","desire","but","mayest","not","put","them","vessel"]}]