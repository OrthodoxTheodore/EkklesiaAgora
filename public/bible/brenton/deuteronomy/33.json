[{"verseId":"brenton_deuteronomy_33_1","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":1,"text":"And this the blessing with which Moses the man of God blessed the children of Israel before his death.","searchKeywords":["and","this","the","blessing","with","which","moses","man","god","blessed","children","israel","before","his","death"]},{"verseId":"brenton_deuteronomy_33_2","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":2,"text":"And he said, The Lord is come from Sina, and has appeared from Seir to us, and has hasted out of the mount of Pharan, with the ten thousands of Cades; on his right hand his angels with him.","searchKeywords":["and","said","the","lord","come","from","sina","has","appeared","seir","hasted","out","mount","pharan","with","ten","thousands","cades","his","right","hand","angels","him"]},{"verseId":"brenton_deuteronomy_33_3","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":3,"text":"And he spared his people, and all his sanctified ones under thy hands; and they are under thee; and he received of his words","searchKeywords":["and","spared","his","people","all","sanctified","ones","under","thy","hands","they","are","thee","received","words"]},{"verseId":"brenton_deuteronomy_33_4","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":4,"text":"the law which Moses charged us, an inheritance to the assemblies of Jacob.","searchKeywords":["the","law","which","moses","charged","inheritance","assemblies","jacob"]},{"verseId":"brenton_deuteronomy_33_5","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":5,"text":"And he shall be prince with the beloved one, when the princes of the people are gathered together with the tribes of Israel.","searchKeywords":["and","shall","prince","with","the","beloved","one","when","princes","people","are","gathered","together","tribes","israel"]},{"verseId":"brenton_deuteronomy_33_6","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":6,"text":"Let Ruben live, and not die; and let him be many in number.","searchKeywords":["let","ruben","live","and","not","die","him","many","number"]},{"verseId":"brenton_deuteronomy_33_7","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":7,"text":"And this of Juda; Hear, Lord, the voice of Juda, and do thou visit his people: his hands shall contend for him, and thou shalt be a help from his enemies.","searchKeywords":["and","this","juda","hear","lord","the","voice","thou","visit","his","people","hands","shall","contend","for","him","shalt","help","from","enemies"]},{"verseId":"brenton_deuteronomy_33_8","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":8,"text":"And to Levi he said, Give to Levi his manifestations, and his truth to the holy man, whom they tempted in the temptation; they reviled him at the water of strife.","searchKeywords":["and","levi","said","give","his","manifestations","truth","the","holy","man","whom","they","tempted","temptation","reviled","him","water","strife"]},{"verseId":"brenton_deuteronomy_33_9","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":9,"text":"Who says to his father and mother, I have not seen thee; and he knew not his brethren, and he refused to know his sons: he kept thine oracles, and observed thy covenant.","searchKeywords":["who","says","his","father","and","mother","have","not","seen","thee","knew","brethren","refused","know","sons","kept","thine","oracles","observed","thy","covenant"]},{"verseId":"brenton_deuteronomy_33_10","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":10,"text":"They shall declare thine ordinances to Jacob, and thy law to Israel: they shall place incense in thy wrath continually upon thine altar.","searchKeywords":["they","shall","declare","thine","ordinances","jacob","and","thy","law","israel","place","incense","wrath","continually","upon","altar"]},{"verseId":"brenton_deuteronomy_33_11","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":11,"text":"Bless, Lord, his strength, and accept the works of his hands; break the loins of his enemies that have risen up against him, and let not them that hate him rise up.","searchKeywords":["bless","lord","his","strength","and","accept","the","works","hands","break","loins","enemies","that","have","risen","against","him","let","not","them","hate","rise"]},{"verseId":"brenton_deuteronomy_33_12","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":12,"text":"And to Benjamin he said, The beloved of the Lord shall dwell in confidence, and God overshadows him always, and he rested between his shoulders.","searchKeywords":["and","benjamin","said","the","beloved","lord","shall","dwell","confidence","god","overshadows","him","always","rested","between","his","shoulders"]},{"verseId":"brenton_deuteronomy_33_13","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":13,"text":"And to Joseph he said, His land of the blessing of the Lord, of the seasons of sky and dew, and of the deeps of wells below,","searchKeywords":["and","joseph","said","his","land","the","blessing","lord","seasons","sky","dew","deeps","wells","below"]},{"verseId":"brenton_deuteronomy_33_14","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":14,"text":"and of the fruits of the changes of the sun in season, and of the produce of the months,","searchKeywords":["and","the","fruits","changes","sun","season","produce","months"]},{"verseId":"brenton_deuteronomy_33_15","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":15,"text":"from the top of the ancient mountains, and from the top of the everlasting hills,","searchKeywords":["from","the","top","ancient","mountains","and","everlasting","hills"]},{"verseId":"brenton_deuteronomy_33_16","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":16,"text":"and of the fulness of the land in season: and let the things pleasing to him that dwelt in the bush come on the head of Joseph, and on the crown glorified above his brethren.","searchKeywords":["and","the","fulness","land","season","let","things","pleasing","him","that","dwelt","bush","come","head","joseph","crown","glorified","above","his","brethren"]},{"verseId":"brenton_deuteronomy_33_17","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":17,"text":"His beauty the firstling of his bull, his horns the horns of a unicorn; with them he shall thrust the nations at once, even from the end of the earth: these the ten thousands of Ephraim, and these the thousands of Manasse.","searchKeywords":["his","beauty","the","firstling","bull","horns","unicorn","with","them","shall","thrust","nations","once","even","from","end","earth","these","ten","thousands","ephraim","and","manasse"]},{"verseId":"brenton_deuteronomy_33_18","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":18,"text":"And to Zabulon he said, Rejoice, Zabulon, in thy going out, and Issachar in his tents.","searchKeywords":["and","zabulon","said","rejoice","thy","going","out","issachar","his","tents"]},{"verseId":"brenton_deuteronomy_33_19","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":19,"text":"They shall utterly destroy the nations, and ye shall call there, and there offer the sacrifice of righteousness; for the wealth of the sea shall suckle thee, and so shall the marts of them that dwell by the sea-coast.","searchKeywords":["they","shall","utterly","destroy","the","nations","and","call","there","offer","sacrifice","righteousness","for","wealth","sea","suckle","thee","marts","them","that","dwell","coast"]},{"verseId":"brenton_deuteronomy_33_20","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":20,"text":"And to Gad he said, Blessed he that enlarges Gad: as a lion he rested, having broken the arm and the ruler.","searchKeywords":["and","gad","said","blessed","that","enlarges","lion","rested","having","broken","the","arm","ruler"]},{"verseId":"brenton_deuteronomy_33_21","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":21,"text":"And he saw his first-fruits, that there the land of the princes gathered with the chiefs of the people was divided; the Lord wrought righteousness, and his judgment with Israel.","searchKeywords":["and","saw","his","first","fruits","that","there","the","land","princes","gathered","with","chiefs","people","was","divided","lord","wrought","righteousness","judgment","israel"]},{"verseId":"brenton_deuteronomy_33_22","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":22,"text":"And to Dan he said, Dan a lion's whelp, and shall leap out of Basan.","searchKeywords":["and","dan","said","lion","whelp","shall","leap","out","basan"]},{"verseId":"brenton_deuteronomy_33_23","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":23,"text":"And to Nephthali he said, Nephthali the fulness of good things; and let him be filled with blessing from the Lord: he shall inherit the west and the south.","searchKeywords":["and","nephthali","said","the","fulness","good","things","let","him","filled","with","blessing","from","lord","shall","inherit","west","south"]},{"verseId":"brenton_deuteronomy_33_24","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":24,"text":"And to Aser he said, Aser blessed with children; and he shall be acceptable to his brethren: he shall dip his foot in oil.","searchKeywords":["and","aser","said","blessed","with","children","shall","acceptable","his","brethren","dip","foot","oil"]},{"verseId":"brenton_deuteronomy_33_25","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":25,"text":"His sandal shall be iron and brass; as thy days, so thy strength.","searchKeywords":["his","sandal","shall","iron","and","brass","thy","days","strength"]},{"verseId":"brenton_deuteronomy_33_26","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":26,"text":"There is not as the God of the beloved; he who rides upon the heaven thy helper, and the magnificent One of the firmament.","searchKeywords":["there","not","the","god","beloved","who","rides","upon","heaven","thy","helper","and","magnificent","one","firmament"]},{"verseId":"brenton_deuteronomy_33_27","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":27,"text":"And the rule of God shall protect thee, and under the strength of the everlasting arms; and he shall cast forth the enemy from before thy face, saying, Perish.","searchKeywords":["and","the","rule","god","shall","protect","thee","under","strength","everlasting","arms","cast","forth","enemy","from","before","thy","face","saying","perish"]},{"verseId":"brenton_deuteronomy_33_28","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":28,"text":"And Israel shall dwell in confidence alone on the land of Jacob, with corn and wine; and the sky misty with dew upon thee.","searchKeywords":["and","israel","shall","dwell","confidence","alone","the","land","jacob","with","corn","wine","sky","misty","dew","upon","thee"]},{"verseId":"brenton_deuteronomy_33_29","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":33,"verse":29,"text":"Blessed thou, O Israel; who like to thee, O people saved by the Lord? thy helper shall hold his shield over thee, and sword thy boast; and thine enemies shall speak falsely to thee, and thou shalt tread upon their neck.","searchKeywords":["blessed","thou","israel","who","like","thee","people","saved","the","lord","thy","helper","shall","hold","his","shield","over","and","sword","boast","thine","enemies","speak","falsely","shalt","tread","upon","their","neck"]}]