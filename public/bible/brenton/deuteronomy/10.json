[{"verseId":"brenton_deuteronomy_10_1","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":1,"text":"At that time the Lord said to me, Hew for thyself two stone tables as the first, and come up to me into the mountain, and thou shalt make for thyself an ark of wood.","searchKeywords":["that","time","the","lord","said","hew","for","thyself","two","stone","tables","first","and","come","into","mountain","thou","shalt","make","ark","wood"]},{"verseId":"brenton_deuteronomy_10_2","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":2,"text":"And thou shalt write upon the tables the words which were on the first tables which thou didst break, and thou shalt put them into the ark.","searchKeywords":["and","thou","shalt","write","upon","the","tables","words","which","were","first","didst","break","put","them","into","ark"]},{"verseId":"brenton_deuteronomy_10_3","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":3,"text":"So I made an ark of boards of incorruptible wood, and I hewed tables of stone like the first, and I went up to the mountain, and the two tables were in my hand.","searchKeywords":["made","ark","boards","incorruptible","wood","and","hewed","tables","stone","like","the","first","went","mountain","two","were","hand"]},{"verseId":"brenton_deuteronomy_10_4","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":4,"text":"And he wrote upon the tables according to the first writing the ten commandments, which the Lord spoke to you in the mountain out of the midst of the fire, and the Lord gave them to me.","searchKeywords":["and","wrote","upon","the","tables","according","first","writing","ten","commandments","which","lord","spoke","you","mountain","out","midst","fire","gave","them"]},{"verseId":"brenton_deuteronomy_10_5","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":5,"text":"And I turned and came down from the mountain, and I put the tables into the ark which I had made; and there they were, as the Lord commanded me.","searchKeywords":["and","turned","came","down","from","the","mountain","put","tables","into","ark","which","had","made","there","they","were","lord","commanded"]},{"verseId":"brenton_deuteronomy_10_6","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":6,"text":"And the children of Israel departed from Beeroth of the sons of Jakim Misadai: there Aaron died, and there he was buried, and Eleazar his son was priest in his stead.","searchKeywords":["and","the","children","israel","departed","from","beeroth","sons","jakim","misadai","there","aaron","died","was","buried","eleazar","his","son","priest","stead"]},{"verseId":"brenton_deuteronomy_10_7","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":7,"text":"Thence they departed to Gadgad; and from Gadgad to Etebatha, a land torrents of water.","searchKeywords":["thence","they","departed","gadgad","and","from","etebatha","land","torrents","water"]},{"verseId":"brenton_deuteronomy_10_8","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":8,"text":"At that time the Lord separated the tribe of Levi, to bear the ark of the covenant of the Lord, to stand near before the Lord, to minister and bless in his name to this day.","searchKeywords":["that","time","the","lord","separated","tribe","levi","bear","ark","covenant","stand","near","before","minister","and","bless","his","name","this","day"]},{"verseId":"brenton_deuteronomy_10_9","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":9,"text":"Therefore the Levites have no part nor inheritance among their brethren; the Lord himself their inheritance, as he said to them.","searchKeywords":["therefore","the","levites","have","part","nor","inheritance","among","their","brethren","lord","himself","said","them"]},{"verseId":"brenton_deuteronomy_10_10","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":10,"text":"And I remained in the mount forty days and forty nights: and the Lord heard me at that time also, and the Lord would not destroy you.","searchKeywords":["and","remained","the","mount","forty","days","nights","lord","heard","that","time","also","would","not","destroy","you"]},{"verseId":"brenton_deuteronomy_10_11","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":11,"text":"And the Lord said to me, Go, set out before this people, and let them go in and inherit the land, which I sware to their fathers to give to them.","searchKeywords":["and","the","lord","said","set","out","before","this","people","let","them","inherit","land","which","sware","their","fathers","give"]},{"verseId":"brenton_deuteronomy_10_12","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":12,"text":"And now, Israel, what does the Lord thy God require of thee, but to fear the Lord thy God, and to walk in all his ways, and to love him, and to serve the Lord thy God with all thy heart, and with all thy soul;","searchKeywords":["and","now","israel","what","does","the","lord","thy","god","require","thee","but","fear","walk","all","his","ways","love","him","serve","with","heart","soul"]},{"verseId":"brenton_deuteronomy_10_13","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":13,"text":"to keep the commandments of the Lord thy God, and his ordinances, all that I charge thee to-day, that it may be well with thee?","searchKeywords":["keep","the","commandments","lord","thy","god","and","his","ordinances","all","that","charge","thee","day","may","well","with"]},{"verseId":"brenton_deuteronomy_10_14","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":14,"text":"Behold, the heaven and the heaven of heavens belong to the Lord thy God, the earth and all things that are in it.","searchKeywords":["behold","the","heaven","and","heavens","belong","lord","thy","god","earth","all","things","that","are"]},{"verseId":"brenton_deuteronomy_10_15","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":15,"text":"Only the Lord chose your fathers to love them, and he chose out their seed after them, you, beyond all nations, as at this day.","searchKeywords":["only","the","lord","chose","your","fathers","love","them","and","out","their","seed","after","you","beyond","all","nations","this","day"]},{"verseId":"brenton_deuteronomy_10_16","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":16,"text":"Therefore ye shall circumcise the hardness of your heart, and ye shall not harden your neck.","searchKeywords":["therefore","shall","circumcise","the","hardness","your","heart","and","not","harden","neck"]},{"verseId":"brenton_deuteronomy_10_17","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":17,"text":"For the Lord your God, he God of gods, and Lord of lords, the great, and strong, and terrible God, who does not accept persons, nor will he by any means accept a bribe:","searchKeywords":["for","the","lord","your","god","gods","and","lords","great","strong","terrible","who","does","not","accept","persons","nor","will","any","means","bribe"]},{"verseId":"brenton_deuteronomy_10_18","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":18,"text":"executing judgment for the stranger and orphan and widow, and he loves the stranger to give him food and raiment.","searchKeywords":["executing","judgment","for","the","stranger","and","orphan","widow","loves","give","him","food","raiment"]},{"verseId":"brenton_deuteronomy_10_19","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":19,"text":"And ye shall love the stranger; for ye were strangers in the land of Egypt.","searchKeywords":["and","shall","love","the","stranger","for","were","strangers","land","egypt"]},{"verseId":"brenton_deuteronomy_10_20","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":20,"text":"Thou shalt fear the Lord thy God, and serve him, and shalt cleave to him, and shalt swear by his name.","searchKeywords":["thou","shalt","fear","the","lord","thy","god","and","serve","him","cleave","swear","his","name"]},{"verseId":"brenton_deuteronomy_10_21","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":21,"text":"He thy boast, and he thy God, who has wrought in the midst of thee these great and glorious things, which thine eyes have seen.","searchKeywords":["thy","boast","and","god","who","has","wrought","the","midst","thee","these","great","glorious","things","which","thine","eyes","have","seen"]},{"verseId":"brenton_deuteronomy_10_22","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":10,"verse":22,"text":"With seventy souls your fathers went down into Egypt; but the Lord thy God has made thee as the stars of heaven in multitude.","searchKeywords":["with","seventy","souls","your","fathers","went","down","into","egypt","but","the","lord","thy","god","has","made","thee","stars","heaven","multitude"]}]