[{"verseId":"brenton_deuteronomy_2_1","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":1,"text":"And we turned and departed into the wilderness, by the way of the Red Sea, as the Lord spoke to me, and we compassed mount Seir many days.","searchKeywords":["and","turned","departed","into","the","wilderness","way","red","sea","lord","spoke","compassed","mount","seir","many","days"]},{"verseId":"brenton_deuteronomy_2_2","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":2,"text":"And the Lord said to me,","searchKeywords":["and","the","lord","said"]},{"verseId":"brenton_deuteronomy_2_3","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":3,"text":"Ye have compassed this mount long enough; turn therefore toward the north.","searchKeywords":["have","compassed","this","mount","long","enough","turn","therefore","toward","the","north"]},{"verseId":"brenton_deuteronomy_2_4","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":4,"text":"And charge the people, saying, Ye are going through the borders of your brethren the children of Esau, who dwell in Seir; and they shall fear you, and dread you greatly.","searchKeywords":["and","charge","the","people","saying","are","going","through","borders","your","brethren","children","esau","who","dwell","seir","they","shall","fear","you","dread","greatly"]},{"verseId":"brenton_deuteronomy_2_5","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":5,"text":"Do not engage in war against them, for I will not give you of their land even enough to set your foot upon, for I have given mount Seir to the children of Esau as an inheritance.","searchKeywords":["not","engage","war","against","them","for","will","give","you","their","land","even","enough","set","your","foot","upon","have","given","mount","seir","the","children","esau","inheritance"]},{"verseId":"brenton_deuteronomy_2_6","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":6,"text":"Buy food of them for money and eat, and ye shall receive water of them by measure for money, and drink.","searchKeywords":["buy","food","them","for","money","and","eat","shall","receive","water","measure","drink"]},{"verseId":"brenton_deuteronomy_2_7","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":7,"text":"For the Lord our God has blessed thee in every work of thy hands. Consider how thou wentest through that great and terrible wilderness: behold, the Lord thy God with thee forty years; thou didst not lack any thing.","searchKeywords":["for","the","lord","our","god","has","blessed","thee","every","work","thy","hands","consider","how","thou","wentest","through","that","great","and","terrible","wilderness","behold","with","forty","years","didst","not","lack","any","thing"]},{"verseId":"brenton_deuteronomy_2_8","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":8,"text":"And we passed by our brethren the children of Esau, who dwelt in Seir, by the way of Araba from Ælon and from Gesion Gaber; and we turned and passed by the way of the desert of Moab.","searchKeywords":["and","passed","our","brethren","the","children","esau","who","dwelt","seir","way","araba","from","lon","gesion","gaber","turned","desert","moab"]},{"verseId":"brenton_deuteronomy_2_9","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":9,"text":"And the Lord said to me, Do not ye quarrel with the Moabites, and do not engage in war with them; for I will not give you of their land for an inheritance, for I have given Aroer to the children of Lot to inherit.","searchKeywords":["and","the","lord","said","not","quarrel","with","moabites","engage","war","them","for","will","give","you","their","land","inheritance","have","given","aroer","children","lot","inherit"]},{"verseId":"brenton_deuteronomy_2_10","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":10,"text":"Formerly the Ommin dwelt in it, a great and numerous nation and powerful, like the Enakim.","searchKeywords":["formerly","the","ommin","dwelt","great","and","numerous","nation","powerful","like","enakim"]},{"verseId":"brenton_deuteronomy_2_11","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":11,"text":"These also shall be accounted Raphain like the Enakim; and the Moabites call them Ommin.","searchKeywords":["these","also","shall","accounted","raphain","like","the","enakim","and","moabites","call","them","ommin"]},{"verseId":"brenton_deuteronomy_2_12","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":12,"text":"And the Chorrhite dwelt in Seir before, and the sons of Esau destroyed them, and utterly consumed them from before them; and they dwelt in their place, as Israel did to the land of his inheritance, which the Lord gave to them.","searchKeywords":["and","the","chorrhite","dwelt","seir","before","sons","esau","destroyed","them","utterly","consumed","from","they","their","place","israel","did","land","his","inheritance","which","lord","gave"]},{"verseId":"brenton_deuteronomy_2_13","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":13,"text":"Now then, arise ye, , and depart, and cross the valley of Zaret.","searchKeywords":["now","then","arise","and","depart","cross","the","valley","zaret"]},{"verseId":"brenton_deuteronomy_2_14","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":14,"text":"And the days in which we travelled from Cades Barne till we crossed the valley of Zaret, thirty and eight years, until the whole generation of the men of war failed, dying out of the camp, as the Lord God sware to them.","searchKeywords":["and","the","days","which","travelled","from","cades","barne","till","crossed","valley","zaret","thirty","eight","years","until","whole","generation","men","war","failed","dying","out","camp","lord","god","sware","them"]},{"verseId":"brenton_deuteronomy_2_15","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":15,"text":"And the hand of the Lord was upon them to destroy them out of the midst of the camp, until they were consumed.","searchKeywords":["and","the","hand","lord","was","upon","them","destroy","out","midst","camp","until","they","were","consumed"]},{"verseId":"brenton_deuteronomy_2_16","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":16,"text":"And it came to pass when all the men of war dying out of the midst of the people had fallen,","searchKeywords":["and","came","pass","when","all","the","men","war","dying","out","midst","people","had","fallen"]},{"verseId":"brenton_deuteronomy_2_17","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":17,"text":"that the Lord spoke to me, saying,","searchKeywords":["that","the","lord","spoke","saying"]},{"verseId":"brenton_deuteronomy_2_18","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":18,"text":"Thou shalt pass over this day the borders of Moab to Aroer;","searchKeywords":["thou","shalt","pass","over","this","day","the","borders","moab","aroer"]},{"verseId":"brenton_deuteronomy_2_19","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":19,"text":"and ye shall draw nigh to the children of Amman: do not quarrel with them, nor wage war with them; for I will not give thee of the land of the children of Amman for an inheritance, because I have given it to the children of Lot for an inheritance.","searchKeywords":["and","shall","draw","nigh","the","children","amman","not","quarrel","with","them","nor","wage","war","for","will","give","thee","land","inheritance","because","have","given","lot"]},{"verseId":"brenton_deuteronomy_2_20","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":20,"text":"It shall be accounted a land of Raphain, for the Raphain dwelt there before, and the Ammanites call them Zochommin.","searchKeywords":["shall","accounted","land","raphain","for","the","dwelt","there","before","and","ammanites","call","them","zochommin"]},{"verseId":"brenton_deuteronomy_2_21","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":21,"text":"A great nation and populous, and mightier than you, as also the Enakim: yet the Lord destroyed them from before them, and they inherited , and they dwelt instead of them until this day.","searchKeywords":["great","nation","and","populous","mightier","than","you","also","the","enakim","yet","lord","destroyed","them","from","before","they","inherited","dwelt","instead","until","this","day"]},{"verseId":"brenton_deuteronomy_2_22","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":22,"text":"As they did to the children of Esau that dwell in Seir, even as they destroyed the Chorrhite from before them, and inherited their country, and dwelt instead of them until this day.","searchKeywords":["they","did","the","children","esau","that","dwell","seir","even","destroyed","chorrhite","from","before","them","and","inherited","their","country","dwelt","instead","until","this","day"]},{"verseId":"brenton_deuteronomy_2_23","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":23,"text":"And the Evites who dwell in Asedoth to Gaza, and the Cappadocians who came out of Cappadocia, destroyed them, and dwelt in their room.","searchKeywords":["and","the","evites","who","dwell","asedoth","gaza","cappadocians","came","out","cappadocia","destroyed","them","dwelt","their","room"]},{"verseId":"brenton_deuteronomy_2_24","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":24,"text":"Now then arise and depart, and pass over the valley of Arnon: behold, I have delivered into thy hands Seon the king of Esebon the Amorite, and his land: begin to inherit : engage in war with him this day.","searchKeywords":["now","then","arise","and","depart","pass","over","the","valley","arnon","behold","have","delivered","into","thy","hands","seon","king","esebon","amorite","his","land","begin","inherit","engage","war","with","him","this","day"]},{"verseId":"brenton_deuteronomy_2_25","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":25,"text":"Begin to put thy terror and thy fear on the face of all the nations under heaven, who shall be troubled when they have heard thy name, and shall be in anguish before thee.","searchKeywords":["begin","put","thy","terror","and","fear","the","face","all","nations","under","heaven","who","shall","troubled","when","they","have","heard","name","anguish","before","thee"]},{"verseId":"brenton_deuteronomy_2_26","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":26,"text":"And I sent ambassadors from the wilderness of Kedamoth to Seon king of Esebon with peaceable words, saying,","searchKeywords":["and","sent","ambassadors","from","the","wilderness","kedamoth","seon","king","esebon","with","peaceable","words","saying"]},{"verseId":"brenton_deuteronomy_2_27","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":27,"text":"I will pass through thy land: I will go by the road, I will not turn aside to the right hand or to the left.","searchKeywords":["will","pass","through","thy","land","the","road","not","turn","aside","right","hand","left"]},{"verseId":"brenton_deuteronomy_2_28","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":28,"text":"Thou shalt give me food for money, and I will eat; and thou shalt give me water for money, and I will drink; I will only go through on my feet:","searchKeywords":["thou","shalt","give","food","for","money","and","will","eat","water","drink","only","through","feet"]},{"verseId":"brenton_deuteronomy_2_29","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":29,"text":"as the sons of Esau did to me, who dwelt in Seir, and the Moabites who dwelt in Aroer, until I shall have passed Jordan into the land which the Lord our God gives us.","searchKeywords":["the","sons","esau","did","who","dwelt","seir","and","moabites","aroer","until","shall","have","passed","jordan","into","land","which","lord","our","god","gives"]},{"verseId":"brenton_deuteronomy_2_30","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":30,"text":"And Seon king of Esebon would not that we should pass by him, because the Lord our God hardened his spirit, and made his heart stubborn, that he might be delivered into thy hands, as on this day.","searchKeywords":["and","seon","king","esebon","would","not","that","should","pass","him","because","the","lord","our","god","hardened","his","spirit","made","heart","stubborn","might","delivered","into","thy","hands","this","day"]},{"verseId":"brenton_deuteronomy_2_31","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":31,"text":"And the Lord said to me, Behold, I have begun to deliver before thee Seon the king of Esebon the Amorite, and his land, and do thou begin to inherit his land.","searchKeywords":["and","the","lord","said","behold","have","begun","deliver","before","thee","seon","king","esebon","amorite","his","land","thou","begin","inherit"]},{"verseId":"brenton_deuteronomy_2_32","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":32,"text":"And Seon the king of Esebon came forth to meet us, he and all his people to war at Jassa.","searchKeywords":["and","seon","the","king","esebon","came","forth","meet","all","his","people","war","jassa"]},{"verseId":"brenton_deuteronomy_2_33","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":33,"text":"And the Lord our God delivered him before our face, and we smote him, and his sons, and all his people.","searchKeywords":["and","the","lord","our","god","delivered","him","before","face","smote","his","sons","all","people"]},{"verseId":"brenton_deuteronomy_2_34","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":34,"text":"And we took possession of all his cities at that time, and we utterly destroyed every city in succession, and their wives, and their children; we left no living prey.","searchKeywords":["and","took","possession","all","his","cities","that","time","utterly","destroyed","every","city","succession","their","wives","children","left","living","prey"]},{"verseId":"brenton_deuteronomy_2_35","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":35,"text":"Only we took the cattle captive, and took the spoil of the cities.","searchKeywords":["only","took","the","cattle","captive","and","spoil","cities"]},{"verseId":"brenton_deuteronomy_2_36","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":36,"text":"From Aroer, which is by the brink of the brook of Arnon, and the city which is in the valley, and as far as the mount of Galaad; there was not a city which escaped us: the Lord our God delivered all of them into our hands.","searchKeywords":["from","aroer","which","the","brink","brook","arnon","and","city","valley","far","mount","galaad","there","was","not","escaped","lord","our","god","delivered","all","them","into","hands"]},{"verseId":"brenton_deuteronomy_2_37","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":2,"verse":37,"text":"Only we did not draw near to the children of Amman, even all the parts bordering on the brook Jaboc, and the cities in the mountain country, as the Lord our God charged us.","searchKeywords":["only","did","not","draw","near","the","children","amman","even","all","parts","bordering","brook","jaboc","and","cities","mountain","country","lord","our","god","charged"]}]