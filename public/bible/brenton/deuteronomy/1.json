[{"verseId":"brenton_deuteronomy_1_1","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":1,"text":"the words which Moses spoke to all Israel on this side Jordan in the desert towards the west near the Red Sea, between Pharan Tophol, and Lobon, and Aulon, and the gold works.","searchKeywords":["the","words","which","moses","spoke","all","israel","this","side","jordan","desert","towards","west","near","red","sea","between","pharan","tophol","and","lobon","aulon","gold","works"]},{"verseId":"brenton_deuteronomy_1_2","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":2,"text":"a journey of eleven days from Choreb to mount Seir as far as Cades Barne.","searchKeywords":["journey","eleven","days","from","choreb","mount","seir","far","cades","barne"]},{"verseId":"brenton_deuteronomy_1_3","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":3,"text":"And it came to pass in the fortieth year, in the eleventh month, on the first of the month, Moses spoke to all the children of Israel, according to all things which the Lord commanded him for them:","searchKeywords":["and","came","pass","the","fortieth","year","eleventh","month","first","moses","spoke","all","children","israel","according","things","which","lord","commanded","him","for","them"]},{"verseId":"brenton_deuteronomy_1_4","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":4,"text":"after he had smitten Seon king of the Amorites who dwelt in Esebon, and Og the king of Basan who dwelt in Astaroth and in Edrain;","searchKeywords":["after","had","smitten","seon","king","the","amorites","who","dwelt","esebon","and","basan","astaroth","edrain"]},{"verseId":"brenton_deuteronomy_1_5","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":5,"text":"beyond Jordan in the land of Moab, Moses began to declare this law, saying,","searchKeywords":["beyond","jordan","the","land","moab","moses","began","declare","this","law","saying"]},{"verseId":"brenton_deuteronomy_1_6","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":6,"text":"The Lord your God spoke to us in Choreb, saying, Let it suffice you to have dwelt in this mountain.","searchKeywords":["the","lord","your","god","spoke","choreb","saying","let","suffice","you","have","dwelt","this","mountain"]},{"verseId":"brenton_deuteronomy_1_7","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":7,"text":"Turn ye and depart and enter into the mountain of the Amorites, and to all that dwell near about Araba, to the mountain and the plain and to the south, and the land of the Chananites near the sea, and Antilibanus, as far as the great river, the river Euphrates.","searchKeywords":["turn","and","depart","enter","into","the","mountain","amorites","all","that","dwell","near","about","araba","plain","south","land","chananites","sea","antilibanus","far","great","river","euphrates"]},{"verseId":"brenton_deuteronomy_1_8","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":8,"text":"Behold, has delivered the land before you; go in and inherit the land, which I sware to your fathers, Abraam, and Isaac, and Jacob, to give it to them and to their seed after them.","searchKeywords":["behold","has","delivered","the","land","before","you","and","inherit","which","sware","your","fathers","abraam","isaac","jacob","give","them","their","seed","after"]},{"verseId":"brenton_deuteronomy_1_9","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":9,"text":"And I spoke to you at that time, saying, I shall not be able by myself to bear you.","searchKeywords":["and","spoke","you","that","time","saying","shall","not","able","myself","bear"]},{"verseId":"brenton_deuteronomy_1_10","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":10,"text":"The Lord your God has multiplied you, and, behold, ye are to-day as the stars of heaven for multitude.","searchKeywords":["the","lord","your","god","has","multiplied","you","and","behold","are","day","stars","heaven","for","multitude"]},{"verseId":"brenton_deuteronomy_1_11","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":11,"text":"The Lord God of your fathers add to you a thousand-fold more than you are, and bless you as he has spoken to you.","searchKeywords":["the","lord","god","your","fathers","add","you","thousand","fold","more","than","are","and","bless","has","spoken"]},{"verseId":"brenton_deuteronomy_1_12","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":12,"text":"How shall I alone be able to bear your labour, and your burden, and your gainsayings?","searchKeywords":["how","shall","alone","able","bear","your","labour","and","burden","gainsayings"]},{"verseId":"brenton_deuteronomy_1_13","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":13,"text":"Take to yourselves wise and understanding and prudent men for your tribes, and I will set your leaders over you.","searchKeywords":["take","yourselves","wise","and","understanding","prudent","men","for","your","tribes","will","set","leaders","over","you"]},{"verseId":"brenton_deuteronomy_1_14","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":14,"text":"And ye answered me and said, The thing which thou hast told us good to do.","searchKeywords":["and","answered","said","the","thing","which","thou","hast","told","good"]},{"verseId":"brenton_deuteronomy_1_15","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":15,"text":"So I took of you wise and understanding and prudent men, and I set them to rule over you as rulers of thousands, and rulers of hundreds, and rulers of fifties, and rulers of tens, and officers to your judges.","searchKeywords":["took","you","wise","and","understanding","prudent","men","set","them","rule","over","rulers","thousands","hundreds","fifties","tens","officers","your","judges"]},{"verseId":"brenton_deuteronomy_1_16","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":16,"text":"And I charged your judges at that time, saying, Hear between your brethren, and judge rightly between a man and brother, and the stranger that is with him.","searchKeywords":["and","charged","your","judges","that","time","saying","hear","between","brethren","judge","rightly","man","brother","the","stranger","with","him"]},{"verseId":"brenton_deuteronomy_1_17","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":17,"text":"Thou shalt not have respect to persons in judgment, thou shalt judge small and great equally; thou shalt not shrink from before the person of a man, for the judgment is God's; and whatsoever matter shall be too hard for you, ye shall bring it to me, and I will hear it.","searchKeywords":["thou","shalt","not","have","respect","persons","judgment","judge","small","and","great","equally","shrink","from","before","the","person","man","for","god","whatsoever","matter","shall","too","hard","you","bring","will","hear"]},{"verseId":"brenton_deuteronomy_1_18","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":18,"text":"And I charged upon you at that time all the commands which ye shall perform.","searchKeywords":["and","charged","upon","you","that","time","all","the","commands","which","shall","perform"]},{"verseId":"brenton_deuteronomy_1_19","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":19,"text":"And we departed from Choreb, and went through all that great wilderness and terrible, which ye saw, by the way of the mountain of the Amorite, as the Lord our God charged us, and we came as far as Cades Barne.","searchKeywords":["and","departed","from","choreb","went","through","all","that","great","wilderness","terrible","which","saw","the","way","mountain","amorite","lord","our","god","charged","came","far","cades","barne"]},{"verseId":"brenton_deuteronomy_1_20","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":20,"text":"And I said to you, Ye have come as far as the mountain of the Amorite, which the Lord our God gives to you:","searchKeywords":["and","said","you","have","come","far","the","mountain","amorite","which","lord","our","god","gives"]},{"verseId":"brenton_deuteronomy_1_21","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":21,"text":"behold, the Lord your God has delivered to us the land before you: go up and inherit it as the Lord God of your fathers said to you; fear not, neither be afraid.","searchKeywords":["behold","the","lord","your","god","has","delivered","land","before","you","and","inherit","fathers","said","fear","not","neither","afraid"]},{"verseId":"brenton_deuteronomy_1_22","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":22,"text":"And ye all came to me, and said, Let us send men before us, and let them go up to the land for us; and let them bring back to us a report of the way by which we shall go up, and of the cities into which we shall enter.","searchKeywords":["and","all","came","said","let","send","men","before","them","the","land","for","bring","back","report","way","which","shall","cities","into","enter"]},{"verseId":"brenton_deuteronomy_1_23","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":23,"text":"And the saying pleased me: and I took of you twelve men, one man of a tribe.","searchKeywords":["and","the","saying","pleased","took","you","twelve","men","one","man","tribe"]},{"verseId":"brenton_deuteronomy_1_24","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":24,"text":"And they turned and went up to the mountain, and they came as far as the valley of the cluster, and surveyed it.","searchKeywords":["and","they","turned","went","the","mountain","came","far","valley","cluster","surveyed"]},{"verseId":"brenton_deuteronomy_1_25","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":25,"text":"And they took in their hands of the fruit of the land, and brought it to you, and said, The land is good which the Lord our God gives us.","searchKeywords":["and","they","took","their","hands","the","fruit","land","brought","you","said","good","which","lord","our","god","gives"]},{"verseId":"brenton_deuteronomy_1_26","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":26,"text":"Yet ye would not go up, but rebelled against the words of the Lord our God.","searchKeywords":["yet","would","not","but","rebelled","against","the","words","lord","our","god"]},{"verseId":"brenton_deuteronomy_1_27","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":27,"text":"And ye murmured in your tents, and said, Because the Lord hated us, he has brought us out of the land of Egypt to deliver us into the hands of the Amorites, to destroy us.","searchKeywords":["and","murmured","your","tents","said","because","the","lord","hated","has","brought","out","land","egypt","deliver","into","hands","amorites","destroy"]},{"verseId":"brenton_deuteronomy_1_28","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":28,"text":"Whither do we go up? and your brethren drew away your heart, saying, great nation and populous, and mightier than we; and cities great and walled up to heaven: moreover we saw there the sons of the giants.","searchKeywords":["whither","and","your","brethren","drew","away","heart","saying","great","nation","populous","mightier","than","cities","walled","heaven","moreover","saw","there","the","sons","giants"]},{"verseId":"brenton_deuteronomy_1_29","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":29,"text":"And I said to you, Fear not, neither be ye afraid of them;","searchKeywords":["and","said","you","fear","not","neither","afraid","them"]},{"verseId":"brenton_deuteronomy_1_30","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":30,"text":"the Lord your God who goes before your face, he shall fight against them together with you effectually, according to all that he wrought for you in the land of Egypt;","searchKeywords":["the","lord","your","god","who","goes","before","face","shall","fight","against","them","together","with","you","effectually","according","all","that","wrought","for","land","egypt"]},{"verseId":"brenton_deuteronomy_1_31","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":31,"text":"and in this wilderness which ye saw, by the way of the mountain of the Amorite; how the Lord thy God will bear thee as a nursling, as if any man should nurse his child, through all the way which ye have gone until ye came to this place.","searchKeywords":["and","this","wilderness","which","saw","the","way","mountain","amorite","how","lord","thy","god","will","bear","thee","nursling","any","man","should","nurse","his","child","through","all","have","gone","until","came","place"]},{"verseId":"brenton_deuteronomy_1_32","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":32,"text":"And in this matter ye believed not the Lord our God,","searchKeywords":["and","this","matter","believed","not","the","lord","our","god"]},{"verseId":"brenton_deuteronomy_1_33","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":33,"text":"who goes before you in the way to choose you a place, guiding you in fire by night, shewing you the way by which ye go, and a cloud by day.","searchKeywords":["who","goes","before","you","the","way","choose","place","guiding","fire","night","shewing","which","and","cloud","day"]},{"verseId":"brenton_deuteronomy_1_34","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":34,"text":"And the Lord heard the voice of your words, and being greatly provoked he sware, saying,","searchKeywords":["and","the","lord","heard","voice","your","words","being","greatly","provoked","sware","saying"]},{"verseId":"brenton_deuteronomy_1_35","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":35,"text":"Not one of these men shall see this good land, which I sware to their fathers,","searchKeywords":["not","one","these","men","shall","see","this","good","land","which","sware","their","fathers"]},{"verseId":"brenton_deuteronomy_1_36","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":36,"text":"except Chaleb the son of Jephonne, he shall see it; and to him I will give the land on which he went up, and to his sons, because he attended to the things of the Lord.","searchKeywords":["except","chaleb","the","son","jephonne","shall","see","and","him","will","give","land","which","went","his","sons","because","attended","things","lord"]},{"verseId":"brenton_deuteronomy_1_37","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":37,"text":"And the Lord was angry with me for your sake, saying, Neither shalt thou by any means enter therein.","searchKeywords":["and","the","lord","was","angry","with","for","your","sake","saying","neither","shalt","thou","any","means","enter","therein"]},{"verseId":"brenton_deuteronomy_1_38","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":38,"text":"Joshua the son of Naue, who stands by thee, he shall enter in there; do thou strengthen him, for he shall cause Israel to inherit it.","searchKeywords":["joshua","the","son","naue","who","stands","thee","shall","enter","there","thou","strengthen","him","for","cause","israel","inherit"]},{"verseId":"brenton_deuteronomy_1_39","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":39,"text":"And every young child who this day knows not good or evil,—they shall enter therein, and to them I will give it, and they shall inherit it.","searchKeywords":["and","every","young","child","who","this","day","knows","not","good","evil","they","shall","enter","therein","them","will","give","inherit"]},{"verseId":"brenton_deuteronomy_1_40","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":40,"text":"And ye turned and marched into the wilderness, in the way by the Red Sea.","searchKeywords":["and","turned","marched","into","the","wilderness","way","red","sea"]},{"verseId":"brenton_deuteronomy_1_41","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":41,"text":"And ye answered and said, We have sinned before the Lord our God; we will go up and fight according to all that the Lord our God has commanded us: and having taken every one his weapons of war, and being gathered together, ye went up to the mountain.","searchKeywords":["and","answered","said","have","sinned","before","the","lord","our","god","will","fight","according","all","that","has","commanded","having","taken","every","one","his","weapons","war","being","gathered","together","went","mountain"]},{"verseId":"brenton_deuteronomy_1_42","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":42,"text":"And the Lord said to me, Tell them, Ye shall not go up, neither shall ye fight, for I am not with you; thus shall ye not be destroyed before your enemies.","searchKeywords":["and","the","lord","said","tell","them","shall","not","neither","fight","for","with","you","thus","destroyed","before","your","enemies"]},{"verseId":"brenton_deuteronomy_1_43","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":43,"text":"And I spoke to you, and ye did not hearken to me; and ye transgressed the commandment of the Lord; and ye forced your way and went up into the mountain.","searchKeywords":["and","spoke","you","did","not","hearken","transgressed","the","commandment","lord","forced","your","way","went","into","mountain"]},{"verseId":"brenton_deuteronomy_1_44","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":44,"text":"And the Amorite who dwelt in that mountain came out to meet you, and pursued you as bees do, and wounded you from Seir to Herma.","searchKeywords":["and","the","amorite","who","dwelt","that","mountain","came","out","meet","you","pursued","bees","wounded","from","seir","herma"]},{"verseId":"brenton_deuteronomy_1_45","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":45,"text":"And ye sat down and wept before the Lord our God, and the Lord hearkened not to your voice, neither did he take heed to you.","searchKeywords":["and","sat","down","wept","before","the","lord","our","god","hearkened","not","your","voice","neither","did","take","heed","you"]},{"verseId":"brenton_deuteronomy_1_46","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":1,"verse":46,"text":"And ye dwelt in Cades many days, as many days as ye dwelt .","searchKeywords":["and","dwelt","cades","many","days"]}]