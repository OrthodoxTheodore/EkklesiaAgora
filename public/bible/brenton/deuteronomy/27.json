[{"verseId":"brenton_deuteronomy_27_1","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":1,"text":"And Moses and the elders of Israel commanded, saying, Keep all these commands, all that I command you this day.","searchKeywords":["and","moses","the","elders","israel","commanded","saying","keep","all","these","commands","that","command","you","this","day"]},{"verseId":"brenton_deuteronomy_27_2","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":2,"text":"And it shall come to pass in the day when ye shall cross over Jordan into the land which the Lord thy God gives thee, that thou shalt set up for thyself great stones, and shalt plaster them with plaster.","searchKeywords":["and","shall","come","pass","the","day","when","cross","over","jordan","into","land","which","lord","thy","god","gives","thee","that","thou","shalt","set","for","thyself","great","stones","plaster","them","with"]},{"verseId":"brenton_deuteronomy_27_3","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":3,"text":"And thou shalt write on these stones all the words of this law, as soon as ye have crossed Jordan, when ye are entered into the land, which the Lord God of thy fathers gives thee, a land flowing with milk and honey, according as the Lord God of thy fathers said to thee.","searchKeywords":["and","thou","shalt","write","these","stones","all","the","words","this","law","soon","have","crossed","jordan","when","are","entered","into","land","which","lord","god","thy","fathers","gives","thee","flowing","with","milk","honey","according","said"]},{"verseId":"brenton_deuteronomy_27_4","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":4,"text":"And it shall be as soon as ye are gone over Jordan, ye shall set up these stones, which I command thee this day, on mount Gæbal, and thou shalt plaster them with plaster.","searchKeywords":["and","shall","soon","are","gone","over","jordan","set","these","stones","which","command","thee","this","day","mount","bal","thou","shalt","plaster","them","with"]},{"verseId":"brenton_deuteronomy_27_5","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":5,"text":"And thou shalt build there an altar to the Lord thy God, an altar of stones; thou shalt not lift up iron upon it.","searchKeywords":["and","thou","shalt","build","there","altar","the","lord","thy","god","stones","not","lift","iron","upon"]},{"verseId":"brenton_deuteronomy_27_6","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":6,"text":"Of whole stones shalt thou build an altar to the Lord thy God, and thou shalt offer upon it whole-burnt-offerings to the Lord thy God.","searchKeywords":["whole","stones","shalt","thou","build","altar","the","lord","thy","god","and","offer","upon","burnt","offerings"]},{"verseId":"brenton_deuteronomy_27_7","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":7,"text":"And thou shalt there offer a peace-offering; and thou shalt eat and be filled, and rejoice before the Lord thy God.","searchKeywords":["and","thou","shalt","there","offer","peace","offering","eat","filled","rejoice","before","the","lord","thy","god"]},{"verseId":"brenton_deuteronomy_27_8","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":8,"text":"And thou shalt write upon the stones all this law very plainly.","searchKeywords":["and","thou","shalt","write","upon","the","stones","all","this","law","very","plainly"]},{"verseId":"brenton_deuteronomy_27_9","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":9,"text":"And Moses and the priests the Levites spoke to all Israel, saying, Be silent and hear, O Israel; this day thou art become a people to the Lord thy God.","searchKeywords":["and","moses","the","priests","levites","spoke","all","israel","saying","silent","hear","this","day","thou","art","become","people","lord","thy","god"]},{"verseId":"brenton_deuteronomy_27_10","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":10,"text":"And thou shalt hearken to the voice of the Lord thy God, and shalt do all his commands, and his ordinances, as many as I command thee this day.","searchKeywords":["and","thou","shalt","hearken","the","voice","lord","thy","god","all","his","commands","ordinances","many","command","thee","this","day"]},{"verseId":"brenton_deuteronomy_27_11","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":11,"text":"And Moses charged the people on that day, saying,","searchKeywords":["and","moses","charged","the","people","that","day","saying"]},{"verseId":"brenton_deuteronomy_27_12","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":12,"text":"These shall stand to bless the people on mount Garizin having gone over Jordan; Symeon, Levi, Judas, Issachar, Joseph, and Benjamin.","searchKeywords":["these","shall","stand","bless","the","people","mount","garizin","having","gone","over","jordan","symeon","levi","judas","issachar","joseph","and","benjamin"]},{"verseId":"brenton_deuteronomy_27_13","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":13,"text":"And these shall stand for cursing on mount Gæbal; Ruben, Gad, and Aser, Zabulon, Dan, and Nephthali.","searchKeywords":["and","these","shall","stand","for","cursing","mount","bal","ruben","gad","aser","zabulon","dan","nephthali"]},{"verseId":"brenton_deuteronomy_27_14","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":14,"text":"And the Levites shall answer and say to all Israel with a loud voice,","searchKeywords":["and","the","levites","shall","answer","say","all","israel","with","loud","voice"]},{"verseId":"brenton_deuteronomy_27_15","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":15,"text":"Cursed the man whosoever shall make a graven or molten image, an abomination to the Lord, the work of the hands of craftsmen, and shall put it in a secret place: and all the people shall answer and say, So be it.","searchKeywords":["cursed","the","man","whosoever","shall","make","graven","molten","image","abomination","lord","work","hands","craftsmen","and","put","secret","place","all","people","answer","say"]},{"verseId":"brenton_deuteronomy_27_16","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":16,"text":"Cursed is the man that dishonours his father or his mother: and all the people shall say, So be it.","searchKeywords":["cursed","the","man","that","dishonours","his","father","mother","and","all","people","shall","say"]},{"verseId":"brenton_deuteronomy_27_17","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":17,"text":"Cursed is he that removes his neighbour's landmarks: and all the people shall say, So be it.","searchKeywords":["cursed","that","removes","his","neighbour","landmarks","and","all","the","people","shall","say"]},{"verseId":"brenton_deuteronomy_27_18","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":18,"text":"Cursed is he that makes the blind to wander in the way: and all the people shall say, So be it.","searchKeywords":["cursed","that","makes","the","blind","wander","way","and","all","people","shall","say"]},{"verseId":"brenton_deuteronomy_27_19","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":19,"text":"Cursed is every one that shall pervert the judgment of the stranger, and orphan, and widow: and all the people shall say, So be it.","searchKeywords":["cursed","every","one","that","shall","pervert","the","judgment","stranger","and","orphan","widow","all","people","say"]},{"verseId":"brenton_deuteronomy_27_20","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":20,"text":"Cursed is he that lies with his father's wife, because he has uncovered his father's skirt: and all the people shall say, So be it.","searchKeywords":["cursed","that","lies","with","his","father","wife","because","has","uncovered","skirt","and","all","the","people","shall","say"]},{"verseId":"brenton_deuteronomy_27_21","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":21,"text":"Cursed is he that lies with any beast: and all the people shall say, So be it.","searchKeywords":["cursed","that","lies","with","any","beast","and","all","the","people","shall","say"]},{"verseId":"brenton_deuteronomy_27_22","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":22,"text":"Cursed is he that lies with his sister by his father or his mother: and all the people shall say, So be it.","searchKeywords":["cursed","that","lies","with","his","sister","father","mother","and","all","the","people","shall","say"]},{"verseId":"brenton_deuteronomy_27_23","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":23,"text":"Cursed is he that lies with his daughter-in-law: and all the people shall say, So be it. Cursed is he that lies with his wife's sister: and all the people shall say, So be it.","searchKeywords":["cursed","that","lies","with","his","daughter","law","and","all","the","people","shall","say","wife","sister"]},{"verseId":"brenton_deuteronomy_27_24","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":24,"text":"Cursed is he that smites his neighbour secretly: and all the people shall say, So be it.","searchKeywords":["cursed","that","smites","his","neighbour","secretly","and","all","the","people","shall","say"]},{"verseId":"brenton_deuteronomy_27_25","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":25,"text":"Cursed is he whosoever shall have taken a bribe to slay an innocent man: and all the people shall say, So be it.","searchKeywords":["cursed","whosoever","shall","have","taken","bribe","slay","innocent","man","and","all","the","people","say"]},{"verseId":"brenton_deuteronomy_27_26","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":27,"verse":26,"text":"Cursed is every man that continues not in all the words of this law to do them: and all the people shall say, So be it.","searchKeywords":["cursed","every","man","that","continues","not","all","the","words","this","law","them","and","people","shall","say"]}]