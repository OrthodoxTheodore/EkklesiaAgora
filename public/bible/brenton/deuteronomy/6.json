[{"verseId":"brenton_deuteronomy_6_1","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":1,"text":"And these the commands, and the ordinances, and the judgments, as many as the Lord our God gave commandment to teach you to do so in the land on which ye enter to inherit it.","searchKeywords":["and","these","the","commands","ordinances","judgments","many","lord","our","god","gave","commandment","teach","you","land","which","enter","inherit"]},{"verseId":"brenton_deuteronomy_6_2","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":2,"text":"That ye may fear the Lord your God, keep ye all his ordinances, and his commandments, which I command thee to-day, thou, and thy sons, and thy sons' sons, all the days of thy life, that ye may live many days.","searchKeywords":["that","may","fear","the","lord","your","god","keep","all","his","ordinances","and","commandments","which","command","thee","day","thou","thy","sons","days","life","live","many"]},{"verseId":"brenton_deuteronomy_6_3","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":3,"text":"Hear, therefore, O Israel, and observe to do them, that it may be well with thee, and that ye may be greatly multiplied, as the Lord God of thy fathers said that he would give thee a land flowing with milk and honey: and these the ordinances, and the judgments, which the Lord commanded the children of Israel in the wilderness, when they had gone forth from the land of Egypt.","searchKeywords":["hear","therefore","israel","and","observe","them","that","may","well","with","thee","greatly","multiplied","the","lord","god","thy","fathers","said","would","give","land","flowing","milk","honey","these","ordinances","judgments","which","commanded","children","wilderness","when","they","had","gone","forth","from","egypt"]},{"verseId":"brenton_deuteronomy_6_4","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":4,"text":"Hear, O Israel, The Lord our God is one Lord.","searchKeywords":["hear","israel","the","lord","our","god","one"]},{"verseId":"brenton_deuteronomy_6_5","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":5,"text":"And thou shalt love the Lord thy God with all thy mind, and with all thy soul, and all thy strength.","searchKeywords":["and","thou","shalt","love","the","lord","thy","god","with","all","mind","soul","strength"]},{"verseId":"brenton_deuteronomy_6_6","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":6,"text":"And these words, all that I command thee this day, shall be in thy heart and in thy soul.","searchKeywords":["and","these","words","all","that","command","thee","this","day","shall","thy","heart","soul"]},{"verseId":"brenton_deuteronomy_6_7","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":7,"text":"And thou shalt teach them to thy children, and thou shalt speak of them sitting in the house, and walking by the way, and lying down, and rising up.","searchKeywords":["and","thou","shalt","teach","them","thy","children","speak","sitting","the","house","walking","way","lying","down","rising"]},{"verseId":"brenton_deuteronomy_6_8","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":8,"text":"And thou shalt fasten them for a sign upon thy hand, and it shall be immoveable before thine eyes.","searchKeywords":["and","thou","shalt","fasten","them","for","sign","upon","thy","hand","shall","immoveable","before","thine","eyes"]},{"verseId":"brenton_deuteronomy_6_9","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":9,"text":"And ye shall write them on the lintels of your houses and of your gates.","searchKeywords":["and","shall","write","them","the","lintels","your","houses","gates"]},{"verseId":"brenton_deuteronomy_6_10","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":10,"text":"And it shall come to pass when the Lord thy God shall have brought thee into the land which he sware to thy fathers, to Abraam, and to Isaac, and to Jacob, to give thee great and beautiful cities which thou didst not build,","searchKeywords":["and","shall","come","pass","when","the","lord","thy","god","have","brought","thee","into","land","which","sware","fathers","abraam","isaac","jacob","give","great","beautiful","cities","thou","didst","not","build"]},{"verseId":"brenton_deuteronomy_6_11","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":11,"text":"houses full of all good things which thou didst not fill, wells dug in the rock which thou didst not dig, vineyards and oliveyards which thou didst not plant, then having eaten and been filled,","searchKeywords":["houses","full","all","good","things","which","thou","didst","not","fill","wells","dug","the","rock","dig","vineyards","and","oliveyards","plant","then","having","eaten","been","filled"]},{"verseId":"brenton_deuteronomy_6_12","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":12,"text":"beware lest thou forget the Lord thy God that brought thee forth out of the land of Egypt, out of the house of bondage.","searchKeywords":["beware","lest","thou","forget","the","lord","thy","god","that","brought","thee","forth","out","land","egypt","house","bondage"]},{"verseId":"brenton_deuteronomy_6_13","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":13,"text":"Thou shalt fear the Lord thy God, and him only shalt thou serve; and thou shalt cleave to him, and by his name thou shalt swear.","searchKeywords":["thou","shalt","fear","the","lord","thy","god","and","him","only","serve","cleave","his","name","swear"]},{"verseId":"brenton_deuteronomy_6_14","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":14,"text":"Go ye not after other gods of the gods of the nations round about you;","searchKeywords":["not","after","other","gods","the","nations","round","about","you"]},{"verseId":"brenton_deuteronomy_6_15","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":15,"text":"for the Lord thy God in the midst of thee a jealous God, lest the Lord thy God be very angry with thee, and destroy thee from off the face of the earth.","searchKeywords":["for","the","lord","thy","god","midst","thee","jealous","lest","very","angry","with","and","destroy","from","off","face","earth"]},{"verseId":"brenton_deuteronomy_6_16","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":16,"text":"Thou shalt not tempt the Lord thy God, as ye tempted him in the temptation.","searchKeywords":["thou","shalt","not","tempt","the","lord","thy","god","tempted","him","temptation"]},{"verseId":"brenton_deuteronomy_6_17","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":17,"text":"Thou shalt by all means keep the commands of the Lord thy God, the testimonies, and the ordinances, which he commanded thee.","searchKeywords":["thou","shalt","all","means","keep","the","commands","lord","thy","god","testimonies","and","ordinances","which","commanded","thee"]},{"verseId":"brenton_deuteronomy_6_18","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":18,"text":"And thou shalt do that which is pleasing and good before the Lord thy God, that it may be well with thee, and that thou mayest go in and inherit the good land, which the Lord sware to your fathers,","searchKeywords":["and","thou","shalt","that","which","pleasing","good","before","the","lord","thy","god","may","well","with","thee","mayest","inherit","land","sware","your","fathers"]},{"verseId":"brenton_deuteronomy_6_19","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":19,"text":"to chase all thine enemies from before thy face, as the Lord said.","searchKeywords":["chase","all","thine","enemies","from","before","thy","face","the","lord","said"]},{"verseId":"brenton_deuteronomy_6_20","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":20,"text":"And it shall come to pass when thy son shall ask thee at a future time, saying, What are the testimonies, and the ordinances, and the judgments, which the Lord our God has commanded us?","searchKeywords":["and","shall","come","pass","when","thy","son","ask","thee","future","time","saying","what","are","the","testimonies","ordinances","judgments","which","lord","our","god","has","commanded"]},{"verseId":"brenton_deuteronomy_6_21","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":21,"text":"Then shalt thou say to thy son, We were slaves to Pharao in the land of Egypt, and the Lord brought us forth thence with a mighty hand, and with a high arm.","searchKeywords":["then","shalt","thou","say","thy","son","were","slaves","pharao","the","land","egypt","and","lord","brought","forth","thence","with","mighty","hand","high","arm"]},{"verseId":"brenton_deuteronomy_6_22","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":22,"text":"And the Lord wrought signs and great and grievous wonders in Egypt, on Pharao and on his house before us.","searchKeywords":["and","the","lord","wrought","signs","great","grievous","wonders","egypt","pharao","his","house","before"]},{"verseId":"brenton_deuteronomy_6_23","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":23,"text":"And he brought us out thence to give us this land, which he sware to give to our fathers.","searchKeywords":["and","brought","out","thence","give","this","land","which","sware","our","fathers"]},{"verseId":"brenton_deuteronomy_6_24","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":24,"text":"And the Lord charged us to observe all these ordinances; to fear the Lord our God, that it may be well with us for ever, that we may live, as even to-day.","searchKeywords":["and","the","lord","charged","observe","all","these","ordinances","fear","our","god","that","may","well","with","for","ever","live","even","day"]},{"verseId":"brenton_deuteronomy_6_25","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":6,"verse":25,"text":"And there shall be mercy to us, if we take heed to keep all these commands before the Lord our God, as he has commanded us.","searchKeywords":["and","there","shall","mercy","take","heed","keep","all","these","commands","before","the","lord","our","god","has","commanded"]}]