[{"verseId":"brenton_deuteronomy_34_1","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":34,"verse":1,"text":"And Moses went up from Araboth Moab to the mount of Nabau, to the top of Phasga, which is before Jericho; and the Lord shewed him all the mount of Galaad to Dan, and all the land of Nephthali,","searchKeywords":["and","moses","went","from","araboth","moab","the","mount","nabau","top","phasga","which","before","jericho","lord","shewed","him","all","galaad","dan","land","nephthali"]},{"verseId":"brenton_deuteronomy_34_2","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":34,"verse":2,"text":"and all the land of Ephraim and Manasse, and all the land of Juda to the farthest sea;","searchKeywords":["and","all","the","land","ephraim","manasse","juda","farthest","sea"]},{"verseId":"brenton_deuteronomy_34_3","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":34,"verse":3,"text":"and the wilderness, and the country round about Jericho, the city of palm-trees, to Segor.","searchKeywords":["and","the","wilderness","country","round","about","jericho","city","palm","trees","segor"]},{"verseId":"brenton_deuteronomy_34_4","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":34,"verse":4,"text":"And the Lord said to Moses, This the land of which I sware to Abraam, and Isaac, and Jacob, saying, To your seed will I give it: and I have shewed it to thine eyes, but thou shalt not go in thither.","searchKeywords":["and","the","lord","said","moses","this","land","which","sware","abraam","isaac","jacob","saying","your","seed","will","give","have","shewed","thine","eyes","but","thou","shalt","not","thither"]},{"verseId":"brenton_deuteronomy_34_5","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":34,"verse":5,"text":"So Moses the servant of the Lord died in the land of Moab by the word of the Lord.","searchKeywords":["moses","the","servant","lord","died","land","moab","word"]},{"verseId":"brenton_deuteronomy_34_6","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":34,"verse":6,"text":"And they buried him in Gai near the house of Phogor; and no one has seen his sepulchre to this day.","searchKeywords":["and","they","buried","him","gai","near","the","house","phogor","one","has","seen","his","sepulchre","this","day"]},{"verseId":"brenton_deuteronomy_34_7","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":34,"verse":7,"text":"And Moses was a hundred and twenty years old at his death; his eyes were not dimmed, nor were his natural powers destroyed.","searchKeywords":["and","moses","was","hundred","twenty","years","old","his","death","eyes","were","not","dimmed","nor","natural","powers","destroyed"]},{"verseId":"brenton_deuteronomy_34_8","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":34,"verse":8,"text":"And the children of Israel wept for Moses in Araboth of Moab at Jordan near Jericho thirty days; and the days of the sad mourning for Moses were completed.","searchKeywords":["and","the","children","israel","wept","for","moses","araboth","moab","jordan","near","jericho","thirty","days","sad","mourning","were","completed"]},{"verseId":"brenton_deuteronomy_34_9","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":34,"verse":9,"text":"And Joshua the son of Naue was filled with the spirit of knowledge, for Moses had laid his hands upon him; and the children of Israel hearkened to him; and they did as the Lord commanded Moses.","searchKeywords":["and","joshua","the","son","naue","was","filled","with","spirit","knowledge","for","moses","had","laid","his","hands","upon","him","children","israel","hearkened","they","did","lord","commanded"]},{"verseId":"brenton_deuteronomy_34_10","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":34,"verse":10,"text":"And there rose up no more a prophet in Israel like Moses, whom the Lord knew face to face,","searchKeywords":["and","there","rose","more","prophet","israel","like","moses","whom","the","lord","knew","face"]},{"verseId":"brenton_deuteronomy_34_11","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":34,"verse":11,"text":"in all the signs and wonders, which the Lord sent him to work in Egypt on Pharao, and his servants, and all his land;","searchKeywords":["all","the","signs","and","wonders","which","lord","sent","him","work","egypt","pharao","his","servants","land"]},{"verseId":"brenton_deuteronomy_34_12","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":34,"verse":12,"text":"the great wonders, and the mighty hand which Moses displayed before all Israel.","searchKeywords":["the","great","wonders","and","mighty","hand","which","moses","displayed","before","all","israel"]}]