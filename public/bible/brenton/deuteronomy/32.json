[{"verseId":"brenton_deuteronomy_32_1","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":1,"text":"Attend, O heaven, and I will speak; and let the earth hear the words out of my mouth.","searchKeywords":["attend","heaven","and","will","speak","let","the","earth","hear","words","out","mouth"]},{"verseId":"brenton_deuteronomy_32_2","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":2,"text":"Let my speech be looked for as the rain, and my words come down as dew, as the shower upon the herbage, and as snow upon the grass.","searchKeywords":["let","speech","looked","for","the","rain","and","words","come","down","dew","shower","upon","herbage","snow","grass"]},{"verseId":"brenton_deuteronomy_32_3","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":3,"text":"For I have called on the name of the Lord: assign ye greatness to our God.","searchKeywords":["for","have","called","the","name","lord","assign","greatness","our","god"]},{"verseId":"brenton_deuteronomy_32_4","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":4,"text":"God, his works true, and all his ways judgment: God faithful, and there is no unrighteousness ; just and holy the Lord.","searchKeywords":["god","his","works","true","and","all","ways","judgment","faithful","there","unrighteousness","just","holy","the","lord"]},{"verseId":"brenton_deuteronomy_32_5","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":5,"text":"They have sinned, not him; spotted children, a froward and perverse generation.","searchKeywords":["they","have","sinned","not","him","spotted","children","froward","and","perverse","generation"]},{"verseId":"brenton_deuteronomy_32_6","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":6,"text":"Do ye thus recompense the Lord? people thus foolish and unwise? did not he himself thy father purchase thee, and make thee, and form thee?","searchKeywords":["thus","recompense","the","lord","people","foolish","and","unwise","did","not","himself","thy","father","purchase","thee","make","form"]},{"verseId":"brenton_deuteronomy_32_7","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":7,"text":"Remember the days of old, consider the years for past ages: ask thy father, and he shall relate to thee, thine elders, and they shall tell thee.","searchKeywords":["remember","the","days","old","consider","years","for","past","ages","ask","thy","father","and","shall","relate","thee","thine","elders","they","tell"]},{"verseId":"brenton_deuteronomy_32_8","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":8,"text":"When the Most High divided the nations, when he separated the sons of Adam, he set the bounds of the nations according to the number of the angels of God.","searchKeywords":["when","the","most","high","divided","nations","separated","sons","adam","set","bounds","according","number","angels","god"]},{"verseId":"brenton_deuteronomy_32_9","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":9,"text":"And his people Jacob became the portion of the Lord, Israel was the line of his inheritance.","searchKeywords":["and","his","people","jacob","became","the","portion","lord","israel","was","line","inheritance"]},{"verseId":"brenton_deuteronomy_32_10","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":10,"text":"He maintained him in the wilderness, in burning thirst and a dry land: he led him about and instructed him, and kept him as the apple of an eye.","searchKeywords":["maintained","him","the","wilderness","burning","thirst","and","dry","land","led","about","instructed","kept","apple","eye"]},{"verseId":"brenton_deuteronomy_32_11","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":11,"text":"As an eagle would watch over his brood, and yearns over his young, receives them having spread his wings, and takes them up on his back:","searchKeywords":["eagle","would","watch","over","his","brood","and","yearns","young","receives","them","having","spread","wings","takes","back"]},{"verseId":"brenton_deuteronomy_32_12","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":12,"text":"the Lord alone led them, there was no strange god with them.","searchKeywords":["the","lord","alone","led","them","there","was","strange","god","with"]},{"verseId":"brenton_deuteronomy_32_13","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":13,"text":"He brought them up on the strength of the land; he fed them with the fruits of the fields; they sucked honey out of the rock, and oil out of the solid rock.","searchKeywords":["brought","them","the","strength","land","fed","with","fruits","fields","they","sucked","honey","out","rock","and","oil","solid"]},{"verseId":"brenton_deuteronomy_32_14","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":14,"text":"Butter of cows, and milk of sheep, with the fat of lambs and rams, of calves and kids, with fat of kidneys of wheat; and he drank wine, the blood of the grape.","searchKeywords":["butter","cows","and","milk","sheep","with","the","fat","lambs","rams","calves","kids","kidneys","wheat","drank","wine","blood","grape"]},{"verseId":"brenton_deuteronomy_32_15","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":15,"text":"So Jacob ate and was filled, and the beloved one kicked; he grew fat, he became thick and broad: then he forsook the God that made him, and departed from God his Saviour.","searchKeywords":["jacob","ate","and","was","filled","the","beloved","one","kicked","grew","fat","became","thick","broad","then","forsook","god","that","made","him","departed","from","his","saviour"]},{"verseId":"brenton_deuteronomy_32_16","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":16,"text":"They provoked me to anger with strange gods; with their abominations they bitterly angered me.","searchKeywords":["they","provoked","anger","with","strange","gods","their","abominations","bitterly","angered"]},{"verseId":"brenton_deuteronomy_32_17","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":17,"text":"They sacrificed to devils, and not to God; to gods whom they knew not: new and fresh came in, whom their fathers knew not.","searchKeywords":["they","sacrificed","devils","and","not","god","gods","whom","knew","new","fresh","came","their","fathers"]},{"verseId":"brenton_deuteronomy_32_18","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":18,"text":"Thou hast forsaken God that begot thee, and forgotten God who feeds thee.","searchKeywords":["thou","hast","forsaken","god","that","begot","thee","and","forgotten","who","feeds"]},{"verseId":"brenton_deuteronomy_32_19","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":19,"text":"And the Lord saw, and was jealous; and was provoked by the anger of his sons and daughters,","searchKeywords":["and","the","lord","saw","was","jealous","provoked","anger","his","sons","daughters"]},{"verseId":"brenton_deuteronomy_32_20","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":20,"text":"and said, I will turn away my face from them, and will show what shall happen to them in the last days; for it is a perverse generation, sons in whom is no faith.","searchKeywords":["and","said","will","turn","away","face","from","them","show","what","shall","happen","the","last","days","for","perverse","generation","sons","whom","faith"]},{"verseId":"brenton_deuteronomy_32_21","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":21,"text":"They have provoked me to jealousy with not God, they have exasperated me with their idols; and I will provoke them to jealousy with them that are no nation, I will anger them with a nation void of understanding.","searchKeywords":["they","have","provoked","jealousy","with","not","god","exasperated","their","idols","and","will","provoke","them","that","are","nation","anger","void","understanding"]},{"verseId":"brenton_deuteronomy_32_22","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":22,"text":"For a fire has been kindled out of my wrath, it shall burn to hell below; it shall devour the land, and the fruits of it; it shall set on fire the foundations of the mountains.","searchKeywords":["for","fire","has","been","kindled","out","wrath","shall","burn","hell","below","devour","the","land","and","fruits","set","foundations","mountains"]},{"verseId":"brenton_deuteronomy_32_23","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":23,"text":"I will gather evils upon them, and will fight with my weapons against them.","searchKeywords":["will","gather","evils","upon","them","and","fight","with","weapons","against"]},{"verseId":"brenton_deuteronomy_32_24","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":24,"text":"consumed with hunger and the devouring of birds, and there shall be irremediable destruction: I will send forth against them the teeth of wild beasts, with the rage of creeping on the ground.","searchKeywords":["consumed","with","hunger","and","the","devouring","birds","there","shall","irremediable","destruction","will","send","forth","against","them","teeth","wild","beasts","rage","creeping","ground"]},{"verseId":"brenton_deuteronomy_32_25","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":25,"text":"Without, the sword shall bereave them of children, and terror out of the secret chambers; the young man shall perish with the virgin, the suckling with him who has grown old.","searchKeywords":["without","the","sword","shall","bereave","them","children","and","terror","out","secret","chambers","young","man","perish","with","virgin","suckling","him","who","has","grown","old"]},{"verseId":"brenton_deuteronomy_32_26","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":26,"text":"I said, I will scatter them, and I will cause their memorial to cease from among men.","searchKeywords":["said","will","scatter","them","and","cause","their","memorial","cease","from","among","men"]},{"verseId":"brenton_deuteronomy_32_27","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":27,"text":"Were it not for the wrath of the enemy, lest they should live long, lest their enemies should combine against them; lest they should say, Our own high arm, and not the Lord, has done all these things.","searchKeywords":["were","not","for","the","wrath","enemy","lest","they","should","live","long","their","enemies","combine","against","them","say","our","own","high","arm","and","lord","has","done","all","these","things"]},{"verseId":"brenton_deuteronomy_32_28","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":28,"text":"It is a nation that has lost counsel, neither is there understanding in them.","searchKeywords":["nation","that","has","lost","counsel","neither","there","understanding","them"]},{"verseId":"brenton_deuteronomy_32_29","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":29,"text":"They had not sense to understand: let them reserve these things against the time to come.","searchKeywords":["they","had","not","sense","understand","let","them","reserve","these","things","against","the","time","come"]},{"verseId":"brenton_deuteronomy_32_30","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":30,"text":"How should one pursue a thousand, and two rout tens of thousands, if God had not sold them, and the Lord delivered them up?","searchKeywords":["how","should","one","pursue","thousand","and","two","rout","tens","thousands","god","had","not","sold","them","the","lord","delivered"]},{"verseId":"brenton_deuteronomy_32_31","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":31,"text":"For their gods are not as our God, but our enemies void of understanding.","searchKeywords":["for","their","gods","are","not","our","god","but","enemies","void","understanding"]},{"verseId":"brenton_deuteronomy_32_32","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":32,"text":"For their vine of the vine of Sodom, and their vine-branch of Gomorrha: their grape a grape of gall, their cluster one of bitterness.","searchKeywords":["for","their","vine","the","sodom","and","branch","gomorrha","grape","gall","cluster","one","bitterness"]},{"verseId":"brenton_deuteronomy_32_33","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":33,"text":"Their wine the rage of serpents, and the incurable rage of asps.","searchKeywords":["their","wine","the","rage","serpents","and","incurable","asps"]},{"verseId":"brenton_deuteronomy_32_34","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":34,"text":"Lo! are not these things stored up by me, and sealed among my treasures?","searchKeywords":["are","not","these","things","stored","and","sealed","among","treasures"]},{"verseId":"brenton_deuteronomy_32_35","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":35,"text":"In the day of vengeance I will recompense, whensoever their foot shall be tripped up; for the day of their destruction near to them, and the judgments at hand are close upon you.","searchKeywords":["the","day","vengeance","will","recompense","whensoever","their","foot","shall","tripped","for","destruction","near","them","and","judgments","hand","are","close","upon","you"]},{"verseId":"brenton_deuteronomy_32_36","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":36,"text":"For the Lord shall judge his people, and shall be comforted over his servants; for he saw that they were utterly weakened, and failed in the hostile invasion, and were become feeble:","searchKeywords":["for","the","lord","shall","judge","his","people","and","comforted","over","servants","saw","that","they","were","utterly","weakened","failed","hostile","invasion","become","feeble"]},{"verseId":"brenton_deuteronomy_32_37","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":37,"text":"and the Lord said, Where are their gods on whom they trusted?","searchKeywords":["and","the","lord","said","where","are","their","gods","whom","they","trusted"]},{"verseId":"brenton_deuteronomy_32_38","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":38,"text":"the fat of whose sacrifices ye ate, and ye drank the wine of their drink-offerings? let them arise and help you, and be your protectors.","searchKeywords":["the","fat","whose","sacrifices","ate","and","drank","wine","their","drink","offerings","let","them","arise","help","you","your","protectors"]},{"verseId":"brenton_deuteronomy_32_39","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":39,"text":"Behold, behold that I am , and there is no god beside me: I kill, and I will make to live: I will smite, and I will heal; and there is none who shall deliver out of my hands.","searchKeywords":["behold","that","and","there","god","beside","kill","will","make","live","smite","heal","none","who","shall","deliver","out","hands"]},{"verseId":"brenton_deuteronomy_32_40","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":40,"text":"For I will lift up my hand to heaven, and swear by my right hand, and I will say, I live for ever.","searchKeywords":["for","will","lift","hand","heaven","and","swear","right","say","live","ever"]},{"verseId":"brenton_deuteronomy_32_41","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":41,"text":"For I will sharpen my sword like lightning, and my hand shall take hold of judgment; and I will render judgment to my enemies, and will recompense them that hate me.","searchKeywords":["for","will","sharpen","sword","like","lightning","and","hand","shall","take","hold","judgment","render","enemies","recompense","them","that","hate"]},{"verseId":"brenton_deuteronomy_32_42","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":42,"text":"I will make my weapons drunk with blood, and my sword shall devour flesh, with the blood of the wounded, and from the captivity of the heads of enemies that rule over them.","searchKeywords":["will","make","weapons","drunk","with","blood","and","sword","shall","devour","flesh","the","wounded","from","captivity","heads","enemies","that","rule","over","them"]},{"verseId":"brenton_deuteronomy_32_43","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":43,"text":"Rejoice, ye heavens, with him, and let all the angels of God worship him; rejoice ye Gentiles, with his people, and let all the sons of God strengthen themselves in him; for he will avenge the blood of his sons, and he will render vengeance, and recompense justice to his enemies, and will reward them that hate him; and the Lord shall purge the land of his people.","searchKeywords":["rejoice","heavens","with","him","and","let","all","the","angels","god","worship","gentiles","his","people","sons","strengthen","themselves","for","will","avenge","blood","render","vengeance","recompense","justice","enemies","reward","them","that","hate","lord","shall","purge","land"]},{"verseId":"brenton_deuteronomy_32_44","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":44,"text":"And Moses wrote this song in that day, and taught it to the children of Israel; and Moses went in and spoke all the words of this law in the ears of the people, he and Joshua the of Naue.","searchKeywords":["and","moses","wrote","this","song","that","day","taught","the","children","israel","went","spoke","all","words","law","ears","people","joshua","naue"]},{"verseId":"brenton_deuteronomy_32_45","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":45,"text":"And Moses finished speaking to all Israel.","searchKeywords":["and","moses","finished","speaking","all","israel"]},{"verseId":"brenton_deuteronomy_32_46","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":46,"text":"And he said to them, Take heed with your heart to all these words, which I testify to you this day, which ye shall command your sons, to observe and do all the words of this law.","searchKeywords":["and","said","them","take","heed","with","your","heart","all","these","words","which","testify","you","this","day","shall","command","sons","observe","the","law"]},{"verseId":"brenton_deuteronomy_32_47","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":47,"text":"For this no vain word to you; for it your life, and because of this word ye shall live long upon the land, into which ye go over Jordan to inherit it.","searchKeywords":["for","this","vain","word","you","your","life","and","because","shall","live","long","upon","the","land","into","which","over","jordan","inherit"]},{"verseId":"brenton_deuteronomy_32_48","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":48,"text":"And the Lord spoke to Moses in this day, saying,","searchKeywords":["and","the","lord","spoke","moses","this","day","saying"]},{"verseId":"brenton_deuteronomy_32_49","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":49,"text":"Go up to the mount Abarim, this mountain Nabau which is in the land of Moab over against Jericho, and behold the land of Chanaan, which I give to the sons of Israel:","searchKeywords":["the","mount","abarim","this","mountain","nabau","which","land","moab","over","against","jericho","and","behold","chanaan","give","sons","israel"]},{"verseId":"brenton_deuteronomy_32_50","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":50,"text":"and die in the mount whither thou goest up, and be added to thy people; as Aaron thy brother died in mount Or, and was added to his people.","searchKeywords":["and","die","the","mount","whither","thou","goest","added","thy","people","aaron","brother","died","was","his"]},{"verseId":"brenton_deuteronomy_32_51","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":51,"text":"Because ye disobeyed my word among the children of Israel, at the waters of strife of Cades in the wilderness of Sin; because ye sanctified me not among the sons of Israel.","searchKeywords":["because","disobeyed","word","among","the","children","israel","waters","strife","cades","wilderness","sin","sanctified","not","sons"]},{"verseId":"brenton_deuteronomy_32_52","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":32,"verse":52,"text":"Thou shalt see the land before , but thou shalt not enter into it.","searchKeywords":["thou","shalt","see","the","land","before","but","not","enter","into"]}]