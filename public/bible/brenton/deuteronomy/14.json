[{"verseId":"brenton_deuteronomy_14_1","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":1,"text":"Ye are the children of the Lord your God: ye shall not make any baldness between your eyes for the dead.","searchKeywords":["are","the","children","lord","your","god","shall","not","make","any","baldness","between","eyes","for","dead"]},{"verseId":"brenton_deuteronomy_14_2","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":2,"text":"For thou art a holy people to the Lord thy God, and the Lord thy God has chosen thee to be a peculiar people to himself of all the nations on the face of the earth.","searchKeywords":["for","thou","art","holy","people","the","lord","thy","god","and","has","chosen","thee","peculiar","himself","all","nations","face","earth"]},{"verseId":"brenton_deuteronomy_14_3","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":3,"text":"Ye shall not eat any abominable thing.","searchKeywords":["shall","not","eat","any","abominable","thing"]},{"verseId":"brenton_deuteronomy_14_4","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":4,"text":"These the beasts which ye shall eat; the calf of the herd, and lamb of the sheep, and kid of the goats;","searchKeywords":["these","the","beasts","which","shall","eat","calf","herd","and","lamb","sheep","kid","goats"]},{"verseId":"brenton_deuteronomy_14_5","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":5,"text":"the stag, and doe, and pygarg, and wild goat, and camelopard.","searchKeywords":["the","stag","and","doe","pygarg","wild","goat","camelopard"]},{"verseId":"brenton_deuteronomy_14_6","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":6,"text":"Every beast that divides the hoofs, and makes claws of two divisions, and that chews the cud among beasts, these ye shall eat.","searchKeywords":["every","beast","that","divides","the","hoofs","and","makes","claws","two","divisions","chews","cud","among","beasts","these","shall","eat"]},{"verseId":"brenton_deuteronomy_14_7","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":7,"text":"And these ye shall not eat of them that chew the cud, and of those that divide the hoofs, and make distinct claws; the camel, and the hare, and the rabbit; because they chew the cud, and do not divide the hoof, these are unclean to you.","searchKeywords":["and","these","shall","not","eat","them","that","chew","the","cud","those","divide","hoofs","make","distinct","claws","camel","hare","rabbit","because","they","hoof","are","unclean","you"]},{"verseId":"brenton_deuteronomy_14_8","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":8,"text":"And as for the swine, because he divides the hoof, and makes claws of the hoof, yet he chews not the cud, he is unclean to you; ye shall not eat of their flesh, ye shall not touch their dead bodies.","searchKeywords":["and","for","the","swine","because","divides","hoof","makes","claws","yet","chews","not","cud","unclean","you","shall","eat","their","flesh","touch","dead","bodies"]},{"verseId":"brenton_deuteronomy_14_9","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":9,"text":"And these ye shall eat of all that are in the water, ye shall eat all that have fins and scales.","searchKeywords":["and","these","shall","eat","all","that","are","the","water","have","fins","scales"]},{"verseId":"brenton_deuteronomy_14_10","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":10,"text":"And all that have not fins and scales ye shall not eat; they are unclean to you.","searchKeywords":["and","all","that","have","not","fins","scales","shall","eat","they","are","unclean","you"]},{"verseId":"brenton_deuteronomy_14_11","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":11,"text":"Ye shall eat every clean bird.","searchKeywords":["shall","eat","every","clean","bird"]},{"verseId":"brenton_deuteronomy_14_12","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":12,"text":"And these of them ye shall not eat; the eagle, and the ossifrage, and the sea-eagle,","searchKeywords":["and","these","them","shall","not","eat","the","eagle","ossifrage","sea"]},{"verseId":"brenton_deuteronomy_14_13","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":13,"text":"and the vulture, and the kite and the like to it,","searchKeywords":["and","the","vulture","kite","like"]},{"verseId":"brenton_deuteronomy_14_15","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":15,"text":"and the sparrow, and the owl, and the sea-mew,","searchKeywords":["and","the","sparrow","owl","sea","mew"]},{"verseId":"brenton_deuteronomy_14_16","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":16,"text":"and the heron, and the swan, and the stork,","searchKeywords":["and","the","heron","swan","stork"]},{"verseId":"brenton_deuteronomy_14_17","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":17,"text":"and the cormorant, and the hawk, and its like, and the hoopoe, and the raven,","searchKeywords":["and","the","cormorant","hawk","its","like","hoopoe","raven"]},{"verseId":"brenton_deuteronomy_14_18","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":18,"text":"and the pelican, and the diver and the like to it, and the red-bill and the bat.","searchKeywords":["and","the","pelican","diver","like","red","bill","bat"]},{"verseId":"brenton_deuteronomy_14_19","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":19,"text":"All winged animals that creep are unclean to you; ye shall not eat of them.","searchKeywords":["all","winged","animals","that","creep","are","unclean","you","shall","not","eat","them"]},{"verseId":"brenton_deuteronomy_14_20","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":20,"text":"Ye shall eat every clean bird.","searchKeywords":["shall","eat","every","clean","bird"]},{"verseId":"brenton_deuteronomy_14_21","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":21,"text":"Ye shall eat nothing that dies of itself; it shall be given to the sojourner in thy cities and he shall eat it, or thou shalt sell it to a stranger, because thou art a holy people to the Lord thy God. Thou shalt not boil a lamb in his mother's milk.","searchKeywords":["shall","eat","nothing","that","dies","itself","given","the","sojourner","thy","cities","and","thou","shalt","sell","stranger","because","art","holy","people","lord","god","not","boil","lamb","his","mother","milk"]},{"verseId":"brenton_deuteronomy_14_22","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":22,"text":"Thou shalt tithe a tenth of all the produce of thy seed, the fruit of thy field year by year.","searchKeywords":["thou","shalt","tithe","tenth","all","the","produce","thy","seed","fruit","field","year"]},{"verseId":"brenton_deuteronomy_14_23","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":23,"text":"And thou shalt eat it in the place which the Lord thy God shall choose to have his name called there; ye shall bring the tithe of thy corn and of thy wine, and of thine oil, the first-born of thy herd and of thy flock, that thou mayest learn to fear the Lord thy God always.","searchKeywords":["and","thou","shalt","eat","the","place","which","lord","thy","god","shall","choose","have","his","name","called","there","bring","tithe","corn","wine","thine","oil","first","born","herd","flock","that","mayest","learn","fear","always"]},{"verseId":"brenton_deuteronomy_14_24","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":24,"text":"And if the journey be too far for thee, and thou art not able to bring them, because the place far from thee which the Lord thy God shall choose to have his name called there, because the Lord thy God will bless thee;","searchKeywords":["and","the","journey","too","far","for","thee","thou","art","not","able","bring","them","because","place","from","which","lord","thy","god","shall","choose","have","his","name","called","there","will","bless"]},{"verseId":"brenton_deuteronomy_14_25","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":25,"text":"then thou shalt sell them for money, and thou shalt take the money in thy hands, and thou shalt go to the place which the Lord thy God shall choose.","searchKeywords":["then","thou","shalt","sell","them","for","money","and","take","the","thy","hands","place","which","lord","god","shall","choose"]},{"verseId":"brenton_deuteronomy_14_26","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":26,"text":"And thou shalt give the money for whatsoever thy soul shall desire, for oxen or for sheep, or for wine, or on strong drink, or on whatsoever thy soul may desire, and thou shalt eat there before the Lord thy God, and thou shalt rejoice and thy house,","searchKeywords":["and","thou","shalt","give","the","money","for","whatsoever","thy","soul","shall","desire","oxen","sheep","wine","strong","drink","may","eat","there","before","lord","god","rejoice","house"]},{"verseId":"brenton_deuteronomy_14_27","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":27,"text":"and the Levite that is in thy cities, because he has not a portion or inheritance with thee.","searchKeywords":["and","the","levite","that","thy","cities","because","has","not","portion","inheritance","with","thee"]},{"verseId":"brenton_deuteronomy_14_28","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":28,"text":"After three years thou shalt bring out all the tithes of thy fruits, in that year thou shalt lay it up in thy cities.","searchKeywords":["after","three","years","thou","shalt","bring","out","all","the","tithes","thy","fruits","that","year","lay","cities"]},{"verseId":"brenton_deuteronomy_14_29","translationId":"brenton","testament":"OT","bookIndex":5,"bookName":"Deuteronomy","bookAbbrev":"deuteronomy","chapter":14,"verse":29,"text":"And the Levite shall come, because he has no part or lot with thee, and the stranger, and the orphan, and the widow which is in thy cities; and they shall eat and be filled, that the Lord thy God may bless thee in all the works which thou shalt do.","searchKeywords":["and","the","levite","shall","come","because","has","part","lot","with","thee","stranger","orphan","widow","which","thy","cities","they","eat","filled","that","lord","god","may","bless","all","works","thou","shalt"]}]