[{"verseId":"brenton_genesis_21_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":1,"text":"And the Lord visited Sarrha, as he said, and the Lord did to Sarrha, as he spoke.","searchKeywords":["and","the","lord","visited","sarrha","said","did","spoke"]},{"verseId":"brenton_genesis_21_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":2,"text":"And she conceived and bore to Abraam a son in old age, at the set time according as the Lord spoke to him.","searchKeywords":["and","she","conceived","bore","abraam","son","old","age","the","set","time","according","lord","spoke","him"]},{"verseId":"brenton_genesis_21_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":3,"text":"And Abraam called the name of his son that was born to him, whom Sarrha bore to him, Isaac.","searchKeywords":["and","abraam","called","the","name","his","son","that","was","born","him","whom","sarrha","bore","isaac"]},{"verseId":"brenton_genesis_21_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":4,"text":"And Abraam circumcised Isaac on the eighth day, as God commanded him.","searchKeywords":["and","abraam","circumcised","isaac","the","eighth","day","god","commanded","him"]},{"verseId":"brenton_genesis_21_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":5,"text":"And Abraam was a hundred years old when Isaac his son was born to him.","searchKeywords":["and","abraam","was","hundred","years","old","when","isaac","his","son","born","him"]},{"verseId":"brenton_genesis_21_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":6,"text":"And Sarrha said, The Lord has made laughter for me, for whoever shall hear shall rejoice with me.","searchKeywords":["and","sarrha","said","the","lord","has","made","laughter","for","whoever","shall","hear","rejoice","with"]},{"verseId":"brenton_genesis_21_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":7,"text":"And she said, Who shall say to Abraam that Sarrha suckles a child? for I have born a child in my old age.","searchKeywords":["and","she","said","who","shall","say","abraam","that","sarrha","suckles","child","for","have","born","old","age"]},{"verseId":"brenton_genesis_21_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":8,"text":"And the child grew and was weaned, and Abraam made a great feast the day that his son Isaac was weaned.","searchKeywords":["and","the","child","grew","was","weaned","abraam","made","great","feast","day","that","his","son","isaac"]},{"verseId":"brenton_genesis_21_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":9,"text":"And Sarrha having seen the son of Agar the Egyptian who was born to Abraam, sporting with Isaac her son,","searchKeywords":["and","sarrha","having","seen","the","son","agar","egyptian","who","was","born","abraam","sporting","with","isaac","her"]},{"verseId":"brenton_genesis_21_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":10,"text":"then she said to Abraam, Cast out this bondwoman and her son, for the son of this bondwoman shall not inherit with my son Isaac.","searchKeywords":["then","she","said","abraam","cast","out","this","bondwoman","and","her","son","for","the","shall","not","inherit","with","isaac"]},{"verseId":"brenton_genesis_21_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":11,"text":"But the word appeared very hard before Abraam concerning his son.","searchKeywords":["but","the","word","appeared","very","hard","before","abraam","concerning","his","son"]},{"verseId":"brenton_genesis_21_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":12,"text":"But God said to Abraam, Let it not be hard before thee concerning the child, and concerning the bondwoman; in all things whatsoever Sarrha shall say to thee, hear her voice, for in Isaac shall thy seed be called.","searchKeywords":["but","god","said","abraam","let","not","hard","before","thee","concerning","the","child","and","bondwoman","all","things","whatsoever","sarrha","shall","say","hear","her","voice","for","isaac","thy","seed","called"]},{"verseId":"brenton_genesis_21_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":13,"text":"And moreover I will make the son of this bondwoman a great nation, because he is thy seed.","searchKeywords":["and","moreover","will","make","the","son","this","bondwoman","great","nation","because","thy","seed"]},{"verseId":"brenton_genesis_21_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":14,"text":"And Abraam rose up in the morning and took loaves and a skin of water, and gave to Agar, and he put the child on her shoulder, and sent her away, and she having departed wandered in the wilderness near the well of the oath.","searchKeywords":["and","abraam","rose","the","morning","took","loaves","skin","water","gave","agar","put","child","her","shoulder","sent","away","she","having","departed","wandered","wilderness","near","well","oath"]},{"verseId":"brenton_genesis_21_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":15,"text":"And the water failed out of the skin, and she cast the child under a fir tree.","searchKeywords":["and","the","water","failed","out","skin","she","cast","child","under","fir","tree"]},{"verseId":"brenton_genesis_21_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":16,"text":"And she departed and sat down opposite him at a distance, as it were a bow-shot, for she said, Surely I cannot see the death of my child: and she sat opposite him, and the child cried aloud and wept.","searchKeywords":["and","she","departed","sat","down","opposite","him","distance","were","bow","shot","for","said","surely","cannot","see","the","death","child","cried","aloud","wept"]},{"verseId":"brenton_genesis_21_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":17,"text":"And God heard the voice of the child from the place where he was, and an angel of God called Agar out of heaven, and said to her, What is it, Agar? fear not, for God has heard the voice of the child from the place where he is.","searchKeywords":["and","god","heard","the","voice","child","from","place","where","was","angel","called","agar","out","heaven","said","her","what","fear","not","for","has"]},{"verseId":"brenton_genesis_21_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":18,"text":"Rise up, and take the child, and hold him in thine hand, for I will make him a great nation.","searchKeywords":["rise","and","take","the","child","hold","him","thine","hand","for","will","make","great","nation"]},{"verseId":"brenton_genesis_21_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":19,"text":"And God opened her eyes, and she saw a well of springing water; and she went and filled the skin with water, and gave the child drink.","searchKeywords":["and","god","opened","her","eyes","she","saw","well","springing","water","went","filled","the","skin","with","gave","child","drink"]},{"verseId":"brenton_genesis_21_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":20,"text":"And God was with the child, and he grew and dwelt in the wilderness, and became an archer.","searchKeywords":["and","god","was","with","the","child","grew","dwelt","wilderness","became","archer"]},{"verseId":"brenton_genesis_21_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":21,"text":"And he dwelt in the wilderness, and his mother took him a wife out of Pharan of Egypt.","searchKeywords":["and","dwelt","the","wilderness","his","mother","took","him","wife","out","pharan","egypt"]},{"verseId":"brenton_genesis_21_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":22,"text":"And it came to pass at that time that Abimelech spoke, and Ochozath his friend, and Phichol the chief captain of his host, to Abraam, saying, God is with thee in all things, whatsoever thou mayest do.","searchKeywords":["and","came","pass","that","time","abimelech","spoke","ochozath","his","friend","phichol","the","chief","captain","host","abraam","saying","god","with","thee","all","things","whatsoever","thou","mayest"]},{"verseId":"brenton_genesis_21_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":23,"text":"Now therefore swear to me by God that thou wilt not injure me, nor my seed, nor my name, but according to the righteousness which I have performed with thee thou shalt deal with me, and with the land in which thou hast sojourned.","searchKeywords":["now","therefore","swear","god","that","thou","wilt","not","injure","nor","seed","name","but","according","the","righteousness","which","have","performed","with","thee","shalt","deal","and","land","hast","sojourned"]},{"verseId":"brenton_genesis_21_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":24,"text":"And Abraam said, I will swear.","searchKeywords":["and","abraam","said","will","swear"]},{"verseId":"brenton_genesis_21_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":25,"text":"And Abraam reproved Abimelech because of the wells of water, which the servants of Abimelech took away.","searchKeywords":["and","abraam","reproved","abimelech","because","the","wells","water","which","servants","took","away"]},{"verseId":"brenton_genesis_21_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":26,"text":"And Abimelech said to him, I know not who has done this thing to thee, neither didst thou tell it me, neither heard I it but only to-day.","searchKeywords":["and","abimelech","said","him","know","not","who","has","done","this","thing","thee","neither","didst","thou","tell","heard","but","only","day"]},{"verseId":"brenton_genesis_21_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":27,"text":"And Abraam took sheep and calves, and gave them to Abimelech, and both made a covenant.","searchKeywords":["and","abraam","took","sheep","calves","gave","them","abimelech","both","made","covenant"]},{"verseId":"brenton_genesis_21_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":28,"text":"And Abraam set seven ewe-lambs by themselves.","searchKeywords":["and","abraam","set","seven","ewe","lambs","themselves"]},{"verseId":"brenton_genesis_21_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":29,"text":"And Abimelech said to Abraam, What are these seven ewe-lambs which thou hast set alone?","searchKeywords":["and","abimelech","said","abraam","what","are","these","seven","ewe","lambs","which","thou","hast","set","alone"]},{"verseId":"brenton_genesis_21_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":30,"text":"And Abraam said, Thou shalt receive the seven ewe-lambs of me, that they may be for me as a witness, that I dug this well.","searchKeywords":["and","abraam","said","thou","shalt","receive","the","seven","ewe","lambs","that","they","may","for","witness","dug","this","well"]},{"verseId":"brenton_genesis_21_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":31,"text":"Therefore he named the name of that place, The Well of the Oath, for there they both swore.","searchKeywords":["therefore","named","the","name","that","place","well","oath","for","there","they","both","swore"]},{"verseId":"brenton_genesis_21_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":32,"text":"And they made a covenant at the well of the oath. And there rose up Abimelech, Ochozath his friend, and Phichol the commander-in-chief of his army, and they returned to the land of the Phylistines.","searchKeywords":["and","they","made","covenant","the","well","oath","there","rose","abimelech","ochozath","his","friend","phichol","commander","chief","army","returned","land","phylistines"]},{"verseId":"brenton_genesis_21_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":33,"text":"And Abraam planted a field at the well of the oath, and called there on the name of the Lord, the everlasting God.","searchKeywords":["and","abraam","planted","field","the","well","oath","called","there","name","lord","everlasting","god"]},{"verseId":"brenton_genesis_21_34","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":21,"verse":34,"text":"And Abraam sojourned in the land of the Phylistines many days.","searchKeywords":["and","abraam","sojourned","the","land","phylistines","many","days"]}]