[{"verseId":"brenton_genesis_29_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":1,"text":"And Jacob started and went to the land of the east to Laban, the son of Bathuel the Syrian, and the brother of Rebecca, mother of Jacob and Esau.","searchKeywords":["and","jacob","started","went","the","land","east","laban","son","bathuel","syrian","brother","rebecca","mother","esau"]},{"verseId":"brenton_genesis_29_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":2,"text":"And he looks, and behold! a well in the plain; and there were there three flocks of sheep resting at it, for out of that well they watered the flocks, but there was a great stone at the mouth of the well.","searchKeywords":["and","looks","behold","well","the","plain","there","were","three","flocks","sheep","resting","for","out","that","they","watered","but","was","great","stone","mouth"]},{"verseId":"brenton_genesis_29_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":3,"text":"And there were all the flocks gathered, and they used to roll away the stone from the mouth of the well, and water the flocks, and set the stone again in its place on the mouth of the well.","searchKeywords":["and","there","were","all","the","flocks","gathered","they","used","roll","away","stone","from","mouth","well","water","set","again","its","place"]},{"verseId":"brenton_genesis_29_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":4,"text":"And Jacob said to them, Brethren, whence are ye? and they said, We are of Charrhan.","searchKeywords":["and","jacob","said","them","brethren","whence","are","they","charrhan"]},{"verseId":"brenton_genesis_29_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":5,"text":"And he said to them, Know ye Laban, the son of Nachor? and they said, We do know .","searchKeywords":["and","said","them","know","laban","the","son","nachor","they"]},{"verseId":"brenton_genesis_29_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":6,"text":"And he said to them, Is he well? And they said, He is well. And behold Rachel his daughter came with the sheep.","searchKeywords":["and","said","them","well","they","behold","rachel","his","daughter","came","with","the","sheep"]},{"verseId":"brenton_genesis_29_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":7,"text":"And Jacob said, It is yet high day, it is not yet time that the flocks be gathered together; water ye the flocks, and depart and feed them.","searchKeywords":["and","jacob","said","yet","high","day","not","time","that","the","flocks","gathered","together","water","depart","feed","them"]},{"verseId":"brenton_genesis_29_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":8,"text":"And they said, We shall not be able, until all the shepherds be gathered together, and they shall roll away the stone from the mouth of the well, then we will water the flocks.","searchKeywords":["and","they","said","shall","not","able","until","all","the","shepherds","gathered","together","roll","away","stone","from","mouth","well","then","will","water","flocks"]},{"verseId":"brenton_genesis_29_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":9,"text":"While he was yet speaking to them, behold, Rachel the daughter of Laban came with her father's sheep, for she fed the sheep of her father.","searchKeywords":["while","was","yet","speaking","them","behold","rachel","the","daughter","laban","came","with","her","father","sheep","for","she","fed"]},{"verseId":"brenton_genesis_29_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":10,"text":"And it came to pass when Jacob saw Rachel the daughter of Laban, his mother's brother, and the sheep of Laban, his mother's brother, that Jacob came and rolled away the stone from the mouth of the well, and watered the sheep of Laban, his mother's brother.","searchKeywords":["and","came","pass","when","jacob","saw","rachel","the","daughter","laban","his","mother","brother","sheep","that","rolled","away","stone","from","mouth","well","watered"]},{"verseId":"brenton_genesis_29_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":11,"text":"And Jacob kissed Rachel, and cried with a loud voice and wept.","searchKeywords":["and","jacob","kissed","rachel","cried","with","loud","voice","wept"]},{"verseId":"brenton_genesis_29_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":12,"text":"And he told Rachel that he was the near relative of her father, and the son of Rebecca; and she ran and reported to her father according to these words.","searchKeywords":["and","told","rachel","that","was","the","near","relative","her","father","son","rebecca","she","ran","reported","according","these","words"]},{"verseId":"brenton_genesis_29_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":13,"text":"And it came to pass when Laban heard the name of Jacob, his sister's son, he ran to meet him, and embraced and kissed him, and brought him into his house; and he told Laban all these sayings.","searchKeywords":["and","came","pass","when","laban","heard","the","name","jacob","his","sister","son","ran","meet","him","embraced","kissed","brought","into","house","told","all","these","sayings"]},{"verseId":"brenton_genesis_29_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":14,"text":"And Laban said to him, Thou art of my bones and of my flesh; and he was with him a full month.","searchKeywords":["and","laban","said","him","thou","art","bones","flesh","was","with","full","month"]},{"verseId":"brenton_genesis_29_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":15,"text":"And Laban said to Jacob, Surely thou shalt not serve me for nothing, because thou art my brother; tell me what thy reward is to be.","searchKeywords":["and","laban","said","jacob","surely","thou","shalt","not","serve","for","nothing","because","art","brother","tell","what","thy","reward"]},{"verseId":"brenton_genesis_29_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":16,"text":"Now Laban had two daughters, the name of the elder was Lea, and the name of the younger, Rachel.","searchKeywords":["now","laban","had","two","daughters","the","name","elder","was","lea","and","younger","rachel"]},{"verseId":"brenton_genesis_29_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":17,"text":"And the eyes of Lea were weak. But Rachel was beautiful in appearance, and exceedingly fair in countenance.","searchKeywords":["and","the","eyes","lea","were","weak","but","rachel","was","beautiful","appearance","exceedingly","fair","countenance"]},{"verseId":"brenton_genesis_29_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":18,"text":"And Jacob loved Rachel, and said, I will serve thee seven years for thy younger daughter Rachel.","searchKeywords":["and","jacob","loved","rachel","said","will","serve","thee","seven","years","for","thy","younger","daughter"]},{"verseId":"brenton_genesis_29_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":19,"text":"And Laban said to him, better that I should give her to thee, than that I should give her to another man; dwell with me.","searchKeywords":["and","laban","said","him","better","that","should","give","her","thee","than","another","man","dwell","with"]},{"verseId":"brenton_genesis_29_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":20,"text":"And Jacob served for Rachel seven years, and they were before him as a few days, by reason of his loving her.","searchKeywords":["and","jacob","served","for","rachel","seven","years","they","were","before","him","few","days","reason","his","loving","her"]},{"verseId":"brenton_genesis_29_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":21,"text":"And Jacob said to Laban, Give me my wife, for my days are fulfilled, that I may go in to her.","searchKeywords":["and","jacob","said","laban","give","wife","for","days","are","fulfilled","that","may","her"]},{"verseId":"brenton_genesis_29_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":22,"text":"And Laban gathered together all the men of the place, and made a marriage-feast.","searchKeywords":["and","laban","gathered","together","all","the","men","place","made","marriage","feast"]},{"verseId":"brenton_genesis_29_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":23,"text":"And it was even, and he took his daughter Lea, and brought her in to Jacob, and Jacob went in to her.","searchKeywords":["and","was","even","took","his","daughter","lea","brought","her","jacob","went"]},{"verseId":"brenton_genesis_29_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":24,"text":"And Laban gave to his daughter Lea, Zelpha his handmaid, as a handmaid for her.","searchKeywords":["and","laban","gave","his","daughter","lea","zelpha","handmaid","for","her"]},{"verseId":"brenton_genesis_29_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":25,"text":"And it was morning, and behold it was Lea; and Jacob said to Laban, What is this that thou hast done to me? did I not serve thee for Rachel? and wherefore hast thou deceived me?","searchKeywords":["and","was","morning","behold","lea","jacob","said","laban","what","this","that","thou","hast","done","did","not","serve","thee","for","rachel","wherefore","deceived"]},{"verseId":"brenton_genesis_29_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":26,"text":"And Laban answered, It is not done thus in our country, to give the younger before the elder.","searchKeywords":["and","laban","answered","not","done","thus","our","country","give","the","younger","before","elder"]},{"verseId":"brenton_genesis_29_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":27,"text":"Fulfil then her sevens, and I will give to thee her also in return for thy labour, which thou labourest with me, yet seven other years.","searchKeywords":["fulfil","then","her","sevens","and","will","give","thee","also","return","for","thy","labour","which","thou","labourest","with","yet","seven","other","years"]},{"verseId":"brenton_genesis_29_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":28,"text":"And Jacob did so, and fulfilled her sevens; and Laban gave him his daughter Rachel to wife.","searchKeywords":["and","jacob","did","fulfilled","her","sevens","laban","gave","him","his","daughter","rachel","wife"]},{"verseId":"brenton_genesis_29_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":29,"text":"And Laban gave to his daughter his handmaid Balla, for a handmaid to her.","searchKeywords":["and","laban","gave","his","daughter","handmaid","balla","for","her"]},{"verseId":"brenton_genesis_29_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":30,"text":"And he went in to Rachel; and he loved Rachel more than Lea; and he served him seven other years.","searchKeywords":["and","went","rachel","loved","more","than","lea","served","him","seven","other","years"]},{"verseId":"brenton_genesis_29_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":31,"text":"And when the Lord God saw that Lea was hated, he opened her womb; but Rachel was barren.","searchKeywords":["and","when","the","lord","god","saw","that","lea","was","hated","opened","her","womb","but","rachel","barren"]},{"verseId":"brenton_genesis_29_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":32,"text":"And Lea conceived and bore a son to Jacob; and she called his name, Ruben; saying, Because the Lord has looked on my humiliation, and has given me a son, now then my husband will love me.","searchKeywords":["and","lea","conceived","bore","son","jacob","she","called","his","name","ruben","saying","because","the","lord","has","looked","humiliation","given","now","then","husband","will","love"]},{"verseId":"brenton_genesis_29_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":33,"text":"And she conceived again, and bore a second son to Jacob; and she said, Because the Lord has heard that I am hated, he has given to me this one also; and she called his name, Simeon.","searchKeywords":["and","she","conceived","again","bore","second","son","jacob","said","because","the","lord","has","heard","that","hated","given","this","one","also","called","his","name","simeon"]},{"verseId":"brenton_genesis_29_34","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":34,"text":"And she conceived yet again, and bore a son, and said, In the present time my husband will be with me, for I have born him three sons; therefore she called his name, Levi.","searchKeywords":["and","she","conceived","yet","again","bore","son","said","the","present","time","husband","will","with","for","have","born","him","three","sons","therefore","called","his","name","levi"]},{"verseId":"brenton_genesis_29_35","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":29,"verse":35,"text":"And having conceived yet again, she bore a son, and said, Now yet again this time will I give thanks to the Lord; therefore she called his name, Juda; and ceased bearing.","searchKeywords":["and","having","conceived","yet","again","she","bore","son","said","now","this","time","will","give","thanks","the","lord","therefore","called","his","name","juda","ceased","bearing"]}]