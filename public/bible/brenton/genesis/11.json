[{"verseId":"brenton_genesis_11_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":11,"verse":1,"text":"And all the earth was one lip, and there was one language to all.","searchKeywords":["and","all","the","earth","was","one","lip","there","language"]},{"verseId":"brenton_genesis_11_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":11,"verse":2,"text":"And it came to pass as they moved from the east, they found a plain in the land of Senaar, and they dwelt there.","searchKeywords":["and","came","pass","they","moved","from","the","east","found","plain","land","senaar","dwelt","there"]},{"verseId":"brenton_genesis_11_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":11,"verse":3,"text":"And a man said to his neighbour, Come, let us make bricks and bake them with fire. And the brick was to them for stone, and their mortar was bitumen.","searchKeywords":["and","man","said","his","neighbour","come","let","make","bricks","bake","them","with","fire","the","brick","was","for","stone","their","mortar","bitumen"]},{"verseId":"brenton_genesis_11_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":11,"verse":4,"text":"And they said, Come, let us build to ourselves a city and tower, whose top shall be to heaven, and let us make to ourselves a name, before we are scattered abroad upon the face of all the earth.","searchKeywords":["and","they","said","come","let","build","ourselves","city","tower","whose","top","shall","heaven","make","name","before","are","scattered","abroad","upon","the","face","all","earth"]},{"verseId":"brenton_genesis_11_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":11,"verse":5,"text":"And the Lord came down to see the city and the tower, which the sons of men built.","searchKeywords":["and","the","lord","came","down","see","city","tower","which","sons","men","built"]},{"verseId":"brenton_genesis_11_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":11,"verse":6,"text":"And the Lord said, Behold, one race, and one lip of all, and they have begun to do this, and now nothing shall fail from them of all that they may have undertaken to do.","searchKeywords":["and","the","lord","said","behold","one","race","lip","all","they","have","begun","this","now","nothing","shall","fail","from","them","that","may","undertaken"]},{"verseId":"brenton_genesis_11_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":11,"verse":7,"text":"Come, and having gone down let us there confound their tongue, that they may not understand each the voice of his neighbour.","searchKeywords":["come","and","having","gone","down","let","there","confound","their","tongue","that","they","may","not","understand","each","the","voice","his","neighbour"]},{"verseId":"brenton_genesis_11_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":11,"verse":8,"text":"And the Lord scattered them thence over the face of all the earth, and they left off building the city and the tower.","searchKeywords":["and","the","lord","scattered","them","thence","over","face","all","earth","they","left","off","building","city","tower"]},{"verseId":"brenton_genesis_11_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":11,"verse":9,"text":"On this account its name was called Confusion, because there the Lord confounded the languages of all the earth, and thence the Lord scattered them upon the face of all the earth.","searchKeywords":["this","account","its","name","was","called","confusion","because","there","the","lord","confounded","languages","all","earth","and","thence","scattered","them","upon","face"]},{"verseId":"brenton_genesis_11_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":11,"verse":10,"text":"And these the generations of Sem: and Sem was a hundred years old when he begot Arphaxad, the second year after the flood.","searchKeywords":["and","these","the","generations","sem","was","hundred","years","old","when","begot","arphaxad","second","year","after","flood"]},{"verseId":"brenton_genesis_11_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":11,"verse":11,"text":"And Sem lived, after he had begotten Arphaxad, five hundred years, and begot sons and daughters, and died.","searchKeywords":["and","sem","lived","after","had","begotten","arphaxad","five","hundred","years","begot","sons","daughters","died"]},{"verseId":"brenton_genesis_11_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":11,"verse":12,"text":"And Arphaxad lived a hundred and thirty-five years, and begot Cainan.","searchKeywords":["and","arphaxad","lived","hundred","thirty","five","years","begot","cainan"]},{"verseId":"brenton_genesis_11_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":11,"verse":13,"text":"And Arphaxad lived after he had begotten Cainan, four hundred years, and begot sons and daughters, and died. And Cainan lived a hundred and thirty years and begot Sala; and Cainan lived after he had begotten Sala, three hundred and thirty years, and begot sons and daughters, and died.","searchKeywords":["and","arphaxad","lived","after","had","begotten","cainan","four","hundred","years","begot","sons","daughters","died","thirty","sala","three"]},{"verseId":"brenton_genesis_11_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","