[{"verseId":"brenton_genesis_23_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":1,"text":"And the life of Sarrha was an hundred and twenty-seven years.","searchKeywords":["and","the","life","sarrha","was","hundred","twenty","seven","years"]},{"verseId":"brenton_genesis_23_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":2,"text":"And Sarrha died in the city of Arboc, which is in the valley, this is Chebron in the land of Chanaan; and Abraam came to lament for Sarrha and to mourn.","searchKeywords":["and","sarrha","died","the","city","arboc","which","valley","this","chebron","land","chanaan","abraam","came","lament","for","mourn"]},{"verseId":"brenton_genesis_23_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":3,"text":"And Abraam stood up from before his dead; and Abraam spoke to the sons of Chet, saying,","searchKeywords":["and","abraam","stood","from","before","his","dead","spoke","the","sons","chet","saying"]},{"verseId":"brenton_genesis_23_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":4,"text":"I am a sojourner and a stranger among you, give me therefore possession of a burying-place among you, and I will bury my dead away from me.","searchKeywords":["sojourner","and","stranger","among","you","give","therefore","possession","burying","place","will","bury","dead","away","from"]},{"verseId":"brenton_genesis_23_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":5,"text":"And the sons of Chet answered to Abraam, saying, Not so, Sir,","searchKeywords":["and","the","sons","chet","answered","abraam","saying","not","sir"]},{"verseId":"brenton_genesis_23_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":6,"text":"but hear us; thou art in the midst of us a king from God; bury thy dead in our choice sepulchres, for not one of us will by any means withhold his sepulchre from thee, so that thou shouldest not bury thy dead there.","searchKeywords":["but","hear","thou","art","the","midst","king","from","god","bury","thy","dead","our","choice","sepulchres","for","not","one","will","any","means","withhold","his","sepulchre","thee","that","shouldest","there"]},{"verseId":"brenton_genesis_23_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":7,"text":"And Abraam rose up and did obeisance to the people of the land, to the sons of Chet.","searchKeywords":["and","abraam","rose","did","obeisance","the","people","land","sons","chet"]},{"verseId":"brenton_genesis_23_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":8,"text":"And Abraam spoke to them, saying, If ye have it in your mind that I should bury my dead out of my sight, hearken to me, and speak for me to Ephron the son of Saar.","searchKeywords":["and","abraam","spoke","them","saying","have","your","mind","that","should","bury","dead","out","sight","hearken","speak","for","ephron","the","son","saar"]},{"verseId":"brenton_genesis_23_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":9,"text":"And let him give me the double cave which he has, which is in a part of his field, let him give it me for the money it is worth for possession of a burying-place among you.","searchKeywords":["and","let","him","give","the","double","cave","which","has","part","his","field","for","money","worth","possession","burying","place","among","you"]},{"verseId":"brenton_genesis_23_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":10,"text":"Now Ephron was sitting in the midst of the children of Chet, and Ephron the Chettite answered Abraam and spoke in the hearing of the sons of Chet, and of all who entered the city, saying,","searchKeywords":["now","ephron","was","sitting","the","midst","children","chet","and","chettite","answered","abraam","spoke","hearing","sons","all","who","entered","city","saying"]},{"verseId":"brenton_genesis_23_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":11,"text":"Attend to me, my lord, and hear me, I give to thee the field and the cave which is in it; I have given it thee before all my countrymen; bury thy dead.","searchKeywords":["attend","lord","and","hear","give","thee","the","field","cave","which","have","given","before","all","countrymen","bury","thy","dead"]},{"verseId":"brenton_genesis_23_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":12,"text":"And Abraam did obeisance before the people of the land.","searchKeywords":["and","abraam","did","obeisance","before","the","people","land"]},{"verseId":"brenton_genesis_23_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":13,"text":"And he said in the ears of Ephron before the people of the land, Since thou art on my side, hear me; take the price of the field from me, and I will bury my dead there.","searchKeywords":["and","said","the","ears","ephron","before","people","land","since","thou","art","side","hear","take","price","field","from","will","bury","dead","there"]},{"verseId":"brenton_genesis_23_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":14,"text":"But Ephron answered Abraam, saying,","searchKeywords":["but","ephron","answered","abraam","saying"]},{"verseId":"brenton_genesis_23_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":15,"text":"Nay, my lord, I have heard indeed, the land four hundred silver didrachms, but what can this be between me and thee? nay, do thou bury thy dead.","searchKeywords":["nay","lord","have","heard","indeed","the","land","four","hundred","silver","didrachms","but","what","can","this","between","and","thee","thou","bury","thy","dead"]},{"verseId":"brenton_genesis_23_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":16,"text":"And Abraam hearkened to Ephron, and Abraam rendered to Ephron the money, which he mentioned in the ears of the sons of Chet, four hundred didrachms of silver approved with merchants.","searchKeywords":["and","abraam","hearkened","ephron","rendered","the","money","which","mentioned","ears","sons","chet","four","hundred","didrachms","silver","approved","with","merchants"]},{"verseId":"brenton_genesis_23_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":17,"text":"And the field of Ephron, which was in Double Cave, which is opposite Mambre, the field and the cave, which was in it, and every tree which was in the field, and whatever is in its borders round about, were made sure","searchKeywords":["and","the","field","ephron","which","was","double","cave","opposite","mambre","every","tree","whatever","its","borders","round","about","were","made","sure"]},{"verseId":"brenton_genesis_23_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":18,"text":"to Abraam for a possession, before the sons of Chet, and all that entered into the city.","searchKeywords":["abraam","for","possession","before","the","sons","chet","and","all","that","entered","into","city"]},{"verseId":"brenton_genesis_23_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":19,"text":"After this Abraam buried Sarrha his wife in the Double Cave of the field, which is opposite Mambre, this is Chebron in the land of Chanaan.","searchKeywords":["after","this","abraam","buried","sarrha","his","wife","the","double","cave","field","which","opposite","mambre","chebron","land","chanaan"]},{"verseId":"brenton_genesis_23_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":23,"verse":20,"text":"So the field and the cave which was in it were made sure to Abraam for possession of a burying place, by the sons of Chet.","searchKeywords":["the","field","and","cave","which","was","were","made","sure","abraam","for","possession","burying","place","sons","chet"]}]