[{"verseId":"brenton_genesis_9_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":1,"text":"And God blessed Noe and his sons, and said to them, Increase and multiply, and fill the earth and have dominion over it.","searchKeywords":["and","god","blessed","noe","his","sons","said","them","increase","multiply","fill","the","earth","have","dominion","over"]},{"verseId":"brenton_genesis_9_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":2,"text":"And the dread and the fear of you shall be upon all the wild beasts of the earth, on all the birds of the sky, and on all things moving upon the earth, and upon all the fishes of the sea, I have placed them under your power.","searchKeywords":["and","the","dread","fear","you","shall","upon","all","wild","beasts","earth","birds","sky","things","moving","fishes","sea","have","placed","them","under","your","power"]},{"verseId":"brenton_genesis_9_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":3,"text":"And every reptile which is living shall be to you for meat, I have given all things to you as the green herbs.","searchKeywords":["and","every","reptile","which","living","shall","you","for","meat","have","given","all","things","the","green","herbs"]},{"verseId":"brenton_genesis_9_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":4,"text":"But flesh with blood of life ye shall not eat.","searchKeywords":["but","flesh","with","blood","life","shall","not","eat"]},{"verseId":"brenton_genesis_9_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":5,"text":"For your blood of your lives will I require at the hand of all wild beasts, and I will require the life of man at the hand of brother man.","searchKeywords":["for","your","blood","lives","will","require","the","hand","all","wild","beasts","and","life","man","brother"]},{"verseId":"brenton_genesis_9_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":6,"text":"He that sheds man's blood, instead of that blood shall his own be shed, for in the image of God I made man.","searchKeywords":["that","sheds","man","blood","instead","shall","his","own","shed","for","the","image","god","made"]},{"verseId":"brenton_genesis_9_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":7,"text":"But do ye increase and multiply, and fill the earth, and have dominion over it.","searchKeywords":["but","increase","and","multiply","fill","the","earth","have","dominion","over"]},{"verseId":"brenton_genesis_9_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":8,"text":"And God spoke to Noe, and to his sons with him, saying,","searchKeywords":["and","god","spoke","noe","his","sons","with","him","saying"]},{"verseId":"brenton_genesis_9_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":9,"text":"And behold I establish my covenant with you, and with your seed after you,","searchKeywords":["and","behold","establish","covenant","with","you","your","seed","after"]},{"verseId":"brenton_genesis_9_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":10,"text":"and with every living creature with you, of birds and of beasts, and with all the wild beasts of the earth, as many as are with you, of all that come out of the ark.","searchKeywords":["and","with","every","living","creature","you","birds","beasts","all","the","wild","earth","many","are","that","come","out","ark"]},{"verseId":"brenton_genesis_9_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":11,"text":"And I will establish my covenant with you and all flesh shall not any more die by the water of the flood, and there shall no more be a flood of water to destroy all the earth.","searchKeywords":["and","will","establish","covenant","with","you","all","flesh","shall","not","any","more","die","the","water","flood","there","destroy","earth"]},{"verseId":"brenton_genesis_9_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":12,"text":"And the Lord God said to Noe, This the sign of the covenant which I set between me and you, and between every living creature which is with you for perpetual generations.","searchKeywords":["and","the","lord","god","said","noe","this","sign","covenant","which","set","between","you","every","living","creature","with","for","perpetual","generations"]},{"verseId":"brenton_genesis_9_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":13,"text":"I set my bow in the cloud, and it shall be for a sign of covenant between me and the earth.","searchKeywords":["set","bow","the","cloud","and","shall","for","sign","covenant","between","earth"]},{"verseId":"brenton_genesis_9_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":14,"text":"And it shall be when I gather clouds upon the earth, that my bow shall be seen in the cloud.","searchKeywords":["and","shall","when","gather","clouds","upon","the","earth","that","bow","seen","cloud"]},{"verseId":"brenton_genesis_9_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":15,"text":"And I will remember my covenant, which is between me and you, and between every living soul in all flesh, and there shall no longer be water for a deluge, so as to blot out all flesh.","searchKeywords":["and","will","remember","covenant","which","between","you","every","living","soul","all","flesh","there","shall","longer","water","for","deluge","blot","out"]},{"verseId":"brenton_genesis_9_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":16,"text":"And my bow shall be in the cloud, and I will look to remember the everlasting covenant between me and the earth, and between living soul in all flesh, which is upon the earth.","searchKeywords":["and","bow","shall","the","cloud","will","look","remember","everlasting","covenant","between","earth","living","soul","all","flesh","which","upon"]},{"verseId":"brenton_genesis_9_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":17,"text":"And God said to Noe, This the sign of the covenant, which I have made between me and all flesh, which is upon the earth.","searchKeywords":["and","god","said","noe","this","the","sign","covenant","which","have","made","between","all","flesh","upon","earth"]},{"verseId":"brenton_genesis_9_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":18,"text":"Now the sons of Noe which came out of the ark, were Sem, Cham, Japheth. And Cham was father of Chanaan.","searchKeywords":["now","the","sons","noe","which","came","out","ark","were","sem","cham","japheth","and","was","father","chanaan"]},{"verseId":"brenton_genesis_9_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":19,"text":"These three are the sons of Noe, of these were men scattered over all the earth.","searchKeywords":["these","three","are","the","sons","noe","were","men","scattered","over","all","earth"]},{"verseId":"brenton_genesis_9_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":20,"text":"And Noe began to be a husbandman, and he planted a vineyard.","searchKeywords":["and","noe","began","husbandman","planted","vineyard"]},{"verseId":"brenton_genesis_9_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":21,"text":"And he drank of the wine, and was drunk, and was naked in his house.","searchKeywords":["and","drank","the","wine","was","drunk","naked","his","house"]},{"verseId":"brenton_genesis_9_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":22,"text":"And Cham the father of Chanaan saw the nakedness of his father, and he went out and told his two brothers without.","searchKeywords":["and","cham","the","father","chanaan","saw","nakedness","his","went","out","told","two","brothers","without"]},{"verseId":"brenton_genesis_9_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":23,"text":"And Sem and Japheth having taken a garment, put it on both their backs and went backwards, and covered the nakedness of their father; and their face backward, and they saw not the nakedness of their father.","searchKeywords":["and","sem","japheth","having","taken","garment","put","both","their","backs","went","backwards","covered","the","nakedness","father","face","backward","they","saw","not"]},{"verseId":"brenton_genesis_9_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":24,"text":"And Noe recovered from the wine, and knew all that his younger son had done to him.","searchKeywords":["and","noe","recovered","from","the","wine","knew","all","that","his","younger","son","had","done","him"]},{"verseId":"brenton_genesis_9_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":25,"text":"And he said, Cursed be the servant Chanaan, a slave shall he be to his brethren.","searchKeywords":["and","said","cursed","the","servant","chanaan","slave","shall","his","brethren"]},{"verseId":"brenton_genesis_9_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":26,"text":"And he said, Blessed the Lord God of Sem, and Chanaan shall be his bond-servant.","searchKeywords":["and","said","blessed","the","lord","god","sem","chanaan","shall","his","bond","servant"]},{"verseId":"brenton_genesis_9_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":27,"text":"May God make room for Japheth, and let him dwell in the habitations of Sem, and let Chanaan be his servant.","searchKeywords":["may","god","make","room","for","japheth","and","let","him","dwell","the","habitations","sem","chanaan","his","servant"]},{"verseId":"brenton_genesis_9_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":28,"text":"And Noe lived after the flood three hundred and fifty years.","searchKeywords":["and","noe","lived","after","the","flood","three","hundred","fifty","years"]},{"verseId":"brenton_genesis_9_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":9,"verse":29,"text":"And all the days of Noe were nine hundred and fifty years, and he died.","searchKeywords":["and","all","the","days","noe","were","nine","hundred","fifty","years","died"]}]