[{"verseId":"brenton_genesis_33_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":1,"text":"And Jacob lifted up his eyes, and beheld, and lo! Esau his brother coming, and four hundred men with him; and Jacob divided the children to Lea and to Rachel, and the two handmaidens.","searchKeywords":["and","jacob","lifted","his","eyes","beheld","esau","brother","coming","four","hundred","men","with","him","divided","the","children","lea","rachel","two","handmaidens"]},{"verseId":"brenton_genesis_33_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":2,"text":"And he put the two handmaidens and their children with the first, and Lea and her children behind, and Rachel and Joseph last.","searchKeywords":["and","put","the","two","handmaidens","their","children","with","first","lea","her","behind","rachel","joseph","last"]},{"verseId":"brenton_genesis_33_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":3,"text":"But he advanced himself before them, and did reverence to the ground seven times, until he drew near to his brother.","searchKeywords":["but","advanced","himself","before","them","and","did","reverence","the","ground","seven","times","until","drew","near","his","brother"]},{"verseId":"brenton_genesis_33_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":4,"text":"And Esau ran on to meet him, and embraced him, and fell on his neck, and kissed him; and they both wept.","searchKeywords":["and","esau","ran","meet","him","embraced","fell","his","neck","kissed","they","both","wept"]},{"verseId":"brenton_genesis_33_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":5,"text":"And Esau looked up and saw the women and the children, and said, What are these to thee? And he said, The children with which God has mercifully blessed thy servant.","searchKeywords":["and","esau","looked","saw","the","women","children","said","what","are","these","thee","with","which","god","has","mercifully","blessed","thy","servant"]},{"verseId":"brenton_genesis_33_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":6,"text":"And the maid-servants and their children drew near and did reverence.","searchKeywords":["and","the","maid","servants","their","children","drew","near","did","reverence"]},{"verseId":"brenton_genesis_33_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":7,"text":"And Lea and her children drew near and did reverence; and after this drew near Rachel and Joseph, and did reverence.","searchKeywords":["and","lea","her","children","drew","near","did","reverence","after","this","rachel","joseph"]},{"verseId":"brenton_genesis_33_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":8,"text":"And he said, What are these things to thee, all these companies that I have met? And he said, That thy servant might find grace in thy sight, my lord.","searchKeywords":["and","said","what","are","these","things","thee","all","companies","that","have","met","thy","servant","might","find","grace","sight","lord"]},{"verseId":"brenton_genesis_33_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":9,"text":"And Esau said, I have much, my brother; keep thine own.","searchKeywords":["and","esau","said","have","much","brother","keep","thine","own"]},{"verseId":"brenton_genesis_33_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":10,"text":"And Jacob said, If I have found grace in thy sight, receive the gifts through my hands; therefore have I seen thy face, as if any one should see the face of God, and thou shalt be well-pleased with me.","searchKeywords":["and","jacob","said","have","found","grace","thy","sight","receive","the","gifts","through","hands","therefore","seen","face","any","one","should","see","god","thou","shalt","well","pleased","with"]},{"verseId":"brenton_genesis_33_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":11,"text":"Receive my blessings, which I have brought thee, because God has had mercy on me, and I have all things; and he constrained him, and he took .","searchKeywords":["receive","blessings","which","have","brought","thee","because","god","has","had","mercy","and","all","things","constrained","him","took"]},{"verseId":"brenton_genesis_33_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":12,"text":"And he said, Let us depart, and proceed right onward.","searchKeywords":["and","said","let","depart","proceed","right","onward"]},{"verseId":"brenton_genesis_33_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":13,"text":"And he said to him, My lord knows, that the children are very tender, and the flocks and the herds with me are with young; if then I shall drive them hard one day, all the cattle will die.","searchKeywords":["and","said","him","lord","knows","that","the","children","are","very","tender","flocks","herds","with","young","then","shall","drive","them","hard","one","day","all","cattle","will","die"]},{"verseId":"brenton_genesis_33_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":14,"text":"Let my lord go on before his servant, and I shall have strength on the road according to the ease of the journey before me, and according to the strength of the children, until I come to my lord to Seir.","searchKeywords":["let","lord","before","his","servant","and","shall","have","strength","the","road","according","ease","journey","children","until","come","seir"]},{"verseId":"brenton_genesis_33_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":15,"text":"And Esau said, I will leave with thee some of the people who are with me. And he said, Why so? it is enough that I have found favour before thee, lord.","searchKeywords":["and","esau","said","will","leave","with","thee","some","the","people","who","are","why","enough","that","have","found","favour","before","lord"]},{"verseId":"brenton_genesis_33_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":16,"text":"And Esau returned on that day on his journey to Seir.","searchKeywords":["and","esau","returned","that","day","his","journey","seir"]},{"verseId":"brenton_genesis_33_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":17,"text":"And Jacob departs to his tents; and he made for himself there habitations, and for his cattle he made booths; therefore he called the name of that place, Booths.","searchKeywords":["and","jacob","departs","his","tents","made","for","himself","there","habitations","cattle","booths","therefore","called","the","name","that","place"]},{"verseId":"brenton_genesis_33_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":18,"text":"And Jacob came to Salem, a city of Secima, which is in the land of Chanaan, when he departed out of Mesopotamia of Syria, and took up a position in front of the city.","searchKeywords":["and","jacob","came","salem","city","secima","which","the","land","chanaan","when","departed","out","mesopotamia","syria","took","position","front"]},{"verseId":"brenton_genesis_33_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":19,"text":"And he bought the portion of the field, where he pitched his tent, of Emmor the father of Sychem, for a hundred lambs.","searchKeywords":["and","bought","the","portion","field","where","pitched","his","tent","emmor","father","sychem","for","hundred","lambs"]},{"verseId":"brenton_genesis_33_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":33,"verse":20,"text":"And he set up there an altar, and called on the God of Israel.","searchKeywords":["and","set","there","altar","called","the","god","israel"]}]