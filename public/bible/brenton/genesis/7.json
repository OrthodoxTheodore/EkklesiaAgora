[{"verseId":"brenton_genesis_7_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":1,"text":"And the Lord God said to Noe, Enter thou and all thy family into the ark, for thee have I seen righteous before me in this generation.","searchKeywords":["and","the","lord","god","said","noe","enter","thou","all","thy","family","into","ark","for","thee","have","seen","righteous","before","this","generation"]},{"verseId":"brenton_genesis_7_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":2,"text":"And of the clean cattle take in to thee sevens, male and female, and of the unclean cattle pairs male and female.","searchKeywords":["and","the","clean","cattle","take","thee","sevens","male","female","unclean","pairs"]},{"verseId":"brenton_genesis_7_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":3,"text":"And of clean flying creatures of the sky sevens, male and female, and of all unclean flying creatures pairs, male and female, to maintain seed on all the earth.","searchKeywords":["and","clean","flying","creatures","the","sky","sevens","male","female","all","unclean","pairs","maintain","seed","earth"]},{"verseId":"brenton_genesis_7_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":4,"text":"For yet seven days I bring rain upon the earth forty days and forty nights, and I will blot out every offspring which I have made from the face of all the earth.","searchKeywords":["for","yet","seven","days","bring","rain","upon","the","earth","forty","and","nights","will","blot","out","every","offspring","which","have","made","from","face","all"]},{"verseId":"brenton_genesis_7_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":5,"text":"And Noe all things whatever the Lord God commanded him.","searchKeywords":["and","noe","all","things","whatever","the","lord","god","commanded","him"]},{"verseId":"brenton_genesis_7_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":6,"text":"And Noe was six hundred years old when the flood of water was upon the earth.","searchKeywords":["and","noe","was","six","hundred","years","old","when","the","flood","water","upon","earth"]},{"verseId":"brenton_genesis_7_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":7,"text":"And then went in Noe and his sons and his wife, and his sons' wives with him into the ark, because of the water of the flood.","searchKeywords":["and","then","went","noe","his","sons","wife","wives","with","him","into","the","ark","because","water","flood"]},{"verseId":"brenton_genesis_7_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":8,"text":"And of clean flying creatures and of unclean flying creatures, and of clean cattle and of unclean cattle, and of all things that creep upon the earth,","searchKeywords":["and","clean","flying","creatures","unclean","cattle","all","things","that","creep","upon","the","earth"]},{"verseId":"brenton_genesis_7_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":9,"text":"pairs went in to Noe into the ark, male and female, as God commanded Noe.","searchKeywords":["pairs","went","noe","into","the","ark","male","and","female","god","commanded"]},{"verseId":"brenton_genesis_7_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":10,"text":"And it came to pass after the seven days that the water of the flood came upon the earth.","searchKeywords":["and","came","pass","after","the","seven","days","that","water","flood","upon","earth"]},{"verseId":"brenton_genesis_7_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":11,"text":"In the six hundredth year of the life of Noe, in the second month, on the twenty-seventh day of the month, on this day all the fountains of the abyss were broken up, and the flood-gates of heaven were opened.","searchKeywords":["the","six","hundredth","year","life","noe","second","month","twenty","seventh","day","this","all","fountains","abyss","were","broken","and","flood","gates","heaven","opened"]},{"verseId":"brenton_genesis_7_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":12,"text":"And the rain was upon the earth forty days and forty nights.","searchKeywords":["and","the","rain","was","upon","earth","forty","days","nights"]},{"verseId":"brenton_genesis_7_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":13,"text":"On that very day entered Noe, Sem, Cham, Japheth, the sons of Noe, and the wife of Noe, and the three wives of his sons with him into the ark.","searchKeywords":["that","very","day","entered","noe","sem","cham","japheth","the","sons","and","wife","three","wives","his","with","him","into","ark"]},{"verseId":"brenton_genesis_7_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":14,"text":"And all the wild beasts after their kind, and all cattle after their kind, and every reptile moving itself on the earth after its kind, and every flying bird after its kind,","searchKeywords":["and","all","the","wild","beasts","after","their","kind","cattle","every","reptile","moving","itself","earth","its","flying","bird"]},{"verseId":"brenton_genesis_7_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":15,"text":"went in to Noe into the ark, pairs, male and female of all flesh in which is the breath of life.","searchKeywords":["went","noe","into","the","ark","pairs","male","and","female","all","flesh","which","breath","life"]},{"verseId":"brenton_genesis_7_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":16,"text":"And they that entered went in male and female of all flesh, as God commanded Noe, and the Lord God shut the ark outside of him.","searchKeywords":["and","they","that","entered","went","male","female","all","flesh","god","commanded","noe","the","lord","shut","ark","outside","him"]},{"verseId":"brenton_genesis_7_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":17,"text":"And the flood was upon the earth forty days and forty nights, and the water abounded greatly and bore up the ark, and it was lifted on high from off the earth.","searchKeywords":["and","the","flood","was","upon","earth","forty","days","nights","water","abounded","greatly","bore","ark","lifted","high","from","off"]},{"verseId":"brenton_genesis_7_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":18,"text":"And the water prevailed and abounded exceedingly upon the earth, and the ark was borne upon the water.","searchKeywords":["and","the","water","prevailed","abounded","exceedingly","upon","earth","ark","was","borne"]},{"verseId":"brenton_genesis_7_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":19,"text":"And the water prevailed exceedingly upon the earth, and covered all the high mountains which were under heaven.","searchKeywords":["and","the","water","prevailed","exceedingly","upon","earth","covered","all","high","mountains","which","were","under","heaven"]},{"verseId":"brenton_genesis_7_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":20,"text":"Fifteen cubits upwards was the water raised, and it covered all the high mountains.","searchKeywords":["fifteen","cubits","upwards","was","the","water","raised","and","covered","all","high","mountains"]},{"verseId":"brenton_genesis_7_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":21,"text":"And there died all flesh that moved upon the earth, of flying creatures and cattle, and of wild beasts, and every reptile moving upon the earth, and every man.","searchKeywords":["and","there","died","all","flesh","that","moved","upon","the","earth","flying","creatures","cattle","wild","beasts","every","reptile","moving","man"]},{"verseId":"brenton_genesis_7_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":22,"text":"And all things which have the breath of life, and whatever was on the dry land, died.","searchKeywords":["and","all","things","which","have","the","breath","life","whatever","was","dry","land","died"]},{"verseId":"brenton_genesis_7_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":23,"text":"And blotted out every offspring which was upon the face of the earth, both man and beast, and reptiles, and birds of the sky, and they were blotted out from the earth, and Noe was left alone, and those with him in the ark.","searchKeywords":["and","blotted","out","every","offspring","which","was","upon","the","face","earth","both","man","beast","reptiles","birds","sky","they","were","from","noe","left","alone","those","with","him","ark"]},{"verseId":"brenton_genesis_7_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":7,"verse":24,"text":"And the water was raised over the earth an hundred and fifty days.","searchKeywords":["and","the","water","was","raised","over","earth","hundred","fifty","days"]}]