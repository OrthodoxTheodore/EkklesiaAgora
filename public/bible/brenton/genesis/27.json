[{"verseId":"brenton_genesis_27_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":1,"text":"And it came to pass after Isaac was old, that his eyes were dimmed so that he could not see; and he called Esau, his elder son, and said to him, My son; and he said, Behold, I .","searchKeywords":["and","came","pass","after","isaac","was","old","that","his","eyes","were","dimmed","could","not","see","called","esau","elder","son","said","him","behold"]},{"verseId":"brenton_genesis_27_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":2,"text":"And he said, Behold, I am grown old, and know not the day of my death.","searchKeywords":["and","said","behold","grown","old","know","not","the","day","death"]},{"verseId":"brenton_genesis_27_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":3,"text":"Now then take thy weapons, both thy quiver and thy bow, and go into the plain, and get me venison,","searchKeywords":["now","then","take","thy","weapons","both","quiver","and","bow","into","the","plain","get","venison"]},{"verseId":"brenton_genesis_27_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":4,"text":"and make me meats, as I like them, and bring them to me that I may eat, that my soul may bless thee, before I die.","searchKeywords":["and","make","meats","like","them","bring","that","may","eat","soul","bless","thee","before","die"]},{"verseId":"brenton_genesis_27_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":5,"text":"And Rebecca heard Isaac speaking to Esau his son; and Esau went to the plain to procure venison for his father.","searchKeywords":["and","rebecca","heard","isaac","speaking","esau","his","son","went","the","plain","procure","venison","for","father"]},{"verseId":"brenton_genesis_27_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":6,"text":"And Rebecca said to Jacob her younger son, Behold, I heard thy father speaking to Esau thy brother, saying,","searchKeywords":["and","rebecca","said","jacob","her","younger","son","behold","heard","thy","father","speaking","esau","brother","saying"]},{"verseId":"brenton_genesis_27_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":7,"text":"Bring me venison, and prepare me meats, that I may eat and bless thee before the Lord before I die.","searchKeywords":["bring","venison","and","prepare","meats","that","may","eat","bless","thee","before","the","lord","die"]},{"verseId":"brenton_genesis_27_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":8,"text":"Now then, my son, hearken to me, as I command thee.","searchKeywords":["now","then","son","hearken","command","thee"]},{"verseId":"brenton_genesis_27_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":9,"text":"And go to the cattle and take for me thence two kids, tender and good, and I will make them meats for thy father, as he likes.","searchKeywords":["and","the","cattle","take","for","thence","two","kids","tender","good","will","make","them","meats","thy","father","likes"]},{"verseId":"brenton_genesis_27_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":10,"text":"And thou shalt bring them in to thy father, and he shall eat, that thy father may bless thee before he dies.","searchKeywords":["and","thou","shalt","bring","them","thy","father","shall","eat","that","may","bless","thee","before","dies"]},{"verseId":"brenton_genesis_27_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":11,"text":"And Jacob said to his mother Rebecca, Esau my brother is a hairy man, and I a smooth man.","searchKeywords":["and","jacob","said","his","mother","rebecca","esau","brother","hairy","man","smooth"]},{"verseId":"brenton_genesis_27_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":12,"text":"Peradventure my father may feel me, and I shall be before him as one ill-intentioned, and I shall bring upon me a curse, and not a blessing.","searchKeywords":["peradventure","father","may","feel","and","shall","before","him","one","ill","intentioned","bring","upon","curse","not","blessing"]},{"verseId":"brenton_genesis_27_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":13,"text":"And his mother said to him, On me be thy curse, son; only hearken to my voice, and go and bring me.","searchKeywords":["and","his","mother","said","him","thy","curse","son","only","hearken","voice","bring"]},{"verseId":"brenton_genesis_27_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":14,"text":"So he went and took and brought them to his mother; and his mother made meats, as his father liked .","searchKeywords":["went","and","took","brought","them","his","mother","made","meats","father","liked"]},{"verseId":"brenton_genesis_27_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":15,"text":"And Rebecca having taken the fine raiment of her elder son Esau which was with her in the house, put it on Jacob her younger son.","searchKeywords":["and","rebecca","having","taken","the","fine","raiment","her","elder","son","esau","which","was","with","house","put","jacob","younger"]},{"verseId":"brenton_genesis_27_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":16,"text":"And she put on his arms the skins of the kids, and on the bare parts of his neck.","searchKeywords":["and","she","put","his","arms","the","skins","kids","bare","parts","neck"]},{"verseId":"brenton_genesis_27_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":17,"text":"And she gave the meats, and the loaves which she had prepared, into the hands of Jacob her son.","searchKeywords":["and","she","gave","the","meats","loaves","which","had","prepared","into","hands","jacob","her","son"]},{"verseId":"brenton_genesis_27_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":18,"text":"And he brought to his father, and said, Father; and he said, Behold I ; who art thou, son?","searchKeywords":["and","brought","his","father","said","behold","who","art","thou","son"]},{"verseId":"brenton_genesis_27_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":19,"text":"And Jacob said to his father, I, Esau thy first-born, have done as thou toldest me; rise, sit, and eat of my venison, that thy soul may bless me.","searchKeywords":["and","jacob","said","his","father","esau","thy","first","born","have","done","thou","toldest","rise","sit","eat","venison","that","soul","may","bless"]},{"verseId":"brenton_genesis_27_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":20,"text":"And Isaac said to his son, What is this which thou hast quickly found? And he said, That which the Lord thy God presented before me.","searchKeywords":["and","isaac","said","his","son","what","this","which","thou","hast","quickly","found","that","the","lord","thy","god","presented","before"]},{"verseId":"brenton_genesis_27_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":21,"text":"And Isaac said to Jacob, Draw nigh to me, and I will feel thee, son, if thou art my son Esau or not.","searchKeywords":["and","isaac","said","jacob","draw","nigh","will","feel","thee","son","thou","art","esau","not"]},{"verseId":"brenton_genesis_27_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":22,"text":"And Jacob drew nigh to his father Isaac, and he felt him, and said, The voice Jacob's voice, but the hands the hands of Esau.","searchKeywords":["and","jacob","drew","nigh","his","father","isaac","felt","him","said","the","voice","but","hands","esau"]},{"verseId":"brenton_genesis_27_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":23,"text":"And he knew him not, for his hands were as the hands of his brother Esau, hairy; and he blessed him,","searchKeywords":["and","knew","him","not","for","his","hands","were","the","brother","esau","hairy","blessed"]},{"verseId":"brenton_genesis_27_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":24,"text":"and he said, Art thou my son Esau? and he said, I .","searchKeywords":["and","said","art","thou","son","esau"]},{"verseId":"brenton_genesis_27_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":25,"text":"And he said, Bring hither, and I will eat of thy venison, son, that my soul may bless thee; and he brought near to him, and he ate, and he brought him wine, and he drank.","searchKeywords":["and","said","bring","hither","will","eat","thy","venison","son","that","soul","may","bless","thee","brought","near","him","ate","wine","drank"]},{"verseId":"brenton_genesis_27_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":26,"text":"And Isaac his father said to him, Draw nigh to me, and kiss me, son.","searchKeywords":["and","isaac","his","father","said","him","draw","nigh","kiss","son"]},{"verseId":"brenton_genesis_27_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":27,"text":"And he drew nigh and kissed him, and smelled the smell of his garments, and blessed him, and said, Behold, the smell of my son is as the smell of an abundant field, which the Lord has blessed.","searchKeywords":["and","drew","nigh","kissed","him","smelled","the","smell","his","garments","blessed","said","behold","son","abundant","field","which","lord","has"]},{"verseId":"brenton_genesis_27_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":28,"text":"And may God give thee of the dew of heaven, and of the fatness of the earth, and abundance of corn and wine.","searchKeywords":["and","may","god","give","thee","the","dew","heaven","fatness","earth","abundance","corn","wine"]},{"verseId":"brenton_genesis_27_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":29,"text":"And let nations serve thee, and princes bow down to thee, and be thou lord of thy brother, and the sons of thy father shall do thee reverence; accursed is he that curses thee, and blessed is he that blesses thee.","searchKeywords":["and","let","nations","serve","thee","princes","bow","down","thou","lord","thy","brother","the","sons","father","shall","reverence","accursed","that","curses","blessed","blesses"]},{"verseId":"brenton_genesis_27_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":30,"text":"And it came to pass after Isaac had ceased blessing his son Jacob, it even came to pass, just when Jacob had gone out from the presence of Isaac his father, that Esau his brother came in from his hunting.","searchKeywords":["and","came","pass","after","isaac","had","ceased","blessing","his","son","jacob","even","just","when","gone","out","from","the","presence","father","that","esau","brother","hunting"]},{"verseId":"brenton_genesis_27_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":31,"text":"And he also had made meats and brought them to his father; and he said to his father, Let my father arise and eat of his son's venison, that thy soul may bless me.","searchKeywords":["and","also","had","made","meats","brought","them","his","father","said","let","arise","eat","son","venison","that","thy","soul","may","bless"]},{"verseId":"brenton_genesis_27_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":32,"text":"And Isaac his father said to him, Who art thou? And he said, I am thy first-born son Esau.","searchKeywords":["and","isaac","his","father","said","him","who","art","thou","thy","first","born","son","esau"]},{"verseId":"brenton_genesis_27_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":33,"text":"And Isaac was amazed with very great amazement, and said, Who then is it that has procured venison for me and brought it to me? and I have eaten of all before thou camest, and I have blessed him, and he shall be blessed.","searchKeywords":["and","isaac","was","amazed","with","very","great","amazement","said","who","then","that","has","procured","venison","for","brought","have","eaten","all","before","thou","camest","blessed","him","shall"]},{"verseId":"brenton_genesis_27_34","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":34,"text":"And it came to pass when Esau heard the words of his father Isaac, he cried out with a great and very bitter cry, and said, Bless, I pray thee, me also, father.","searchKeywords":["and","came","pass","when","esau","heard","the","words","his","father","isaac","cried","out","with","great","very","bitter","cry","said","bless","pray","thee","also"]},{"verseId":"brenton_genesis_27_35","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":35,"text":"And he said to him, Thy brother has come with subtlety, and taken thy blessing.","searchKeywords":["and","said","him","thy","brother","has","come","with","subtlety","taken","blessing"]},{"verseId":"brenton_genesis_27_36","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":36,"text":"And he said, Rightly was his name called Jacob, for lo! this second time has he supplanted me; he has both taken my birthright, and now he has taken my blessing; and Esau said to his father, Hast thou not left a blessing for me, father?","searchKeywords":["and","said","rightly","was","his","name","called","jacob","for","this","second","time","has","supplanted","both","taken","birthright","now","blessing","esau","father","hast","thou","not","left"]},{"verseId":"brenton_genesis_27_37","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":37,"text":"And Isaac answered and said to Esau, If I have made him thy lord, and have made all his brethren his servants, and have strengthened him with corn and wine, what then shall I do for thee, son?","searchKeywords":["and","isaac","answered","said","esau","have","made","him","thy","lord","all","his","brethren","servants","strengthened","with","corn","wine","what","then","shall","for","thee","son"]},{"verseId":"brenton_genesis_27_38","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":38,"text":"And Esau said to his father, Hast thou one blessing, father? Bless, I pray thee, me also, father. And Isaac being troubled, Esau cried aloud and wept.","searchKeywords":["and","esau","said","his","father","hast","thou","one","blessing","bless","pray","thee","also","isaac","being","troubled","cried","aloud","wept"]},{"verseId":"brenton_genesis_27_39","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":39,"text":"And Isaac his father answered and said to him, Behold, thy dwelling shall be of the fatness of the earth, and of the dew of heaven from above.","searchKeywords":["and","isaac","his","father","answered","said","him","behold","thy","dwelling","shall","the","fatness","earth","dew","heaven","from","above"]},{"verseId":"brenton_genesis_27_40","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":40,"text":"And thou shalt live by thy sword, and shalt serve thy brother; and there shall be when thou shalt break and loosen his yoke from off thy neck.","searchKeywords":["and","thou","shalt","live","thy","sword","serve","brother","there","shall","when","break","loosen","his","yoke","from","off","neck"]},{"verseId":"brenton_genesis_27_41","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":41,"text":"And Esau was angry with Jacob because of the blessing, with which his father blessed him; and Esau said in his mind, Let the days of my father's mourning draw nigh, that I may slay my brother Jacob.","searchKeywords":["and","esau","was","angry","with","jacob","because","the","blessing","which","his","father","blessed","him","said","mind","let","days","mourning","draw","nigh","that","may","slay","brother"]},{"verseId":"brenton_genesis_27_42","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":42,"text":"And the words of Esau her elder son were reported to Rebecca, and she sent and called Jacob her younger son, and said to him, Behold, Esau thy brother threatens thee to kill thee.","searchKeywords":["and","the","words","esau","her","elder","son","were","reported","rebecca","she","sent","called","jacob","younger","said","him","behold","thy","brother","threatens","thee","kill"]},{"verseId":"brenton_genesis_27_43","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":43,"text":"Now then, my son, hear my voice, and rise and depart quickly into Mesopotamia to Laban my brother into Charran.","searchKeywords":["now","then","son","hear","voice","and","rise","depart","quickly","into","mesopotamia","laban","brother","charran"]},{"verseId":"brenton_genesis_27_44","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":44,"text":"And dwell with him certain days, until thy brother's anger","searchKeywords":["and","dwell","with","him","certain","days","until","thy","brother","anger"]},{"verseId":"brenton_genesis_27_45","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":45,"text":"and rage depart from thee, and he forget what thou hast done to him; and I will send and fetch thee thence, lest at any time I should be bereaved of you both in one day.","searchKeywords":["and","rage","depart","from","thee","forget","what","thou","hast","done","him","will","send","fetch","thence","lest","any","time","should","bereaved","you","both","one","day"]},{"verseId":"brenton_genesis_27_46","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":27,"verse":46,"text":"And Rebecca said to Isaac, I am weary of my life, because of the daughters of the sons of Chet; if Jacob shall take a wife of the daughters of this land, wherefore should I live?","searchKeywords":["and","rebecca","said","isaac","weary","life","because","the","daughters","sons","chet","jacob","shall","take","wife","this","land","wherefore","should","live"]}]