[{"verseId":"brenton_genesis_36_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":36,"verse":1,"text":"And these the generations of Esau; this is Edom.","searchKeywords":["and","these","the","generations","esau","this","edom"]},{"verseId":"brenton_genesis_36_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":36,"verse":2,"text":"And Esau took to himself wives of the daughters of the Chananites; Ada, the daughter of Ælom the Chettite; and Olibema, daughter of Ana the son of Sebegon, the Evite;","searchKeywords":["and","esau","took","himself","wives","the","daughters","chananites","ada","daughter","lom","chettite","olibema","ana","son","sebegon","evite"]},{"verseId":"brenton_genesis_36_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":36,"verse":3,"text":"and Basemath, daughter of Ismael, sister of Nabaioth.","searchKeywords":["and","basemath","daughter","ismael","sister","nabaioth"]},{"verseId":"brenton_genesis_36_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":36,"verse":4,"text":"And Ada bore to him Eliphas; and Basemath bore Raguel.","searchKeywords":["and","ada","bore","him","eliphas","basemath","raguel"]},{"verseId":"brenton_genesis_36_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":36,"verse":5,"text":"And Olibema bore Jeus, and Jeglom, and Core; these the sons of Esau, which were born to him in the land of Chanaan.","searchKeywords":["and","olibema","bore","jeus","jeglom","core","these","the","sons","esau","which","were","born","him","land","chanaan"]},{"verseId":"brenton_genesis_36_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":36,"verse":6,"text":"And Esau took his wives, and his sons, and his daughters, and all the persons of his house, and all his possessions, and all his cattle, and all that he had got, and all things whatsoever he had acquired in the land of Chanaan; and Esau went forth from the land of Chanaan, from the face of his brother Jacob.","searchKeywords":["and","esau","took","his","wives","sons","daughters","all","the","persons","house","possessions","cattle","that","had","got","things","whatsoever","acquired","land","chanaan","went","forth","from","face","brother","jacob"]},{"verseId":"brenton_genesis_36_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":36,"verse":7,"text":"For their substance was too great for them to dwell together; and the land of their sojourning could not bear them, because of the abundance of their possessions.","searchKeywords":["for","their","substance","was","too","great","them","dwell","together","and","the","land","sojourning","could","not","bear","because","abundance","possessions"]},{"verseId":"brenton_genesis_36_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":36,"verse":8,"text":"And Esau dwelt in mount Seir; Esau, he is Edom.","searchKeywords":["and","esau","dwelt","mount","seir","edom"]},{"verseId":"brenton_genesis_36_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":36,"verse":9,"text":"And these the generations of Esau, the father of Edom in the mount Seir.","searchKeywords":["and","these","the","generations","esau","father","edom","mount","seir"]},{"verseId":"brenton_genesis_36_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":36,"verse":10,"text":"And these the names of the sons of Esau. Eliphas, the son of Ada, the wife of Esau; and Raguel, the son of Basemath, wife of Esau.","searchKeywords":["and","these","the","names","sons","