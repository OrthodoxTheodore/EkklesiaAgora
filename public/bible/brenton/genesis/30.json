[{"verseId":"brenton_genesis_30_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":1,"text":"And Rachel having perceived that she bore Jacob no children, was jealous of her sister; and said to Jacob, Give me children; and if not, I shall die.","searchKeywords":["and","rachel","having","perceived","that","she","bore","jacob","children","was","jealous","her","sister","said","give","not","shall","die"]},{"verseId":"brenton_genesis_30_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":2,"text":"And Jacob was angry with Rachel, and said to her, Am I in the place of God, who has deprived thee of the fruit of the womb?","searchKeywords":["and","jacob","was","angry","with","rachel","said","her","the","place","god","who","has","deprived","thee","fruit","womb"]},{"verseId":"brenton_genesis_30_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":3,"text":"And Rachel said to Jacob, Behold my handmaid Balla, go in to her, and she shall bear upon my knees, and I also shall have children by her.","searchKeywords":["and","rachel","said","jacob","behold","handmaid","balla","her","she","shall","bear","upon","knees","also","have","children"]},{"verseId":"brenton_genesis_30_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":4,"text":"And she gave him Balla her maid, for a wife to him; and Jacob went in to her.","searchKeywords":["and","she","gave","him","balla","her","maid","for","wife","jacob","went"]},{"verseId":"brenton_genesis_30_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":5,"text":"And Balla, Rachel's maid, conceived, and bore Jacob a son.","searchKeywords":["and","balla","rachel","maid","conceived","bore","jacob","son"]},{"verseId":"brenton_genesis_30_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":6,"text":"And Rachel said, God has given judgment for me, and hearkened to my voice, and has given me a son; therefore she called his name, Dan.","searchKeywords":["and","rachel","said","god","has","given","judgment","for","hearkened","voice","son","therefore","she","called","his","name","dan"]},{"verseId":"brenton_genesis_30_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":7,"text":"And Balla, Rachel's maid, conceived yet again, and bore a second son to Jacob.","searchKeywords":["and","balla","rachel","maid","conceived","yet","again","bore","second","son","jacob"]},{"verseId":"brenton_genesis_30_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":8,"text":"And Rachel said, God has helped me, and I contended with my sister and prevailed; and she called his name, Nephthalim.","searchKeywords":["and","rachel","said","god","has","helped","contended","with","sister","prevailed","she","called","his","name","nephthalim"]},{"verseId":"brenton_genesis_30_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":9,"text":"And Lea saw that she ceased from bearing, and she took Zelpha her maid, and gave her to Jacob for a wife; and he went in to her.","searchKeywords":["and","lea","saw","that","she","ceased","from","bearing","took","zelpha","her","maid","gave","jacob","for","wife","went"]},{"verseId":"brenton_genesis_30_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":10,"text":"And Zelpha the maid of Lea conceived, and bore Jacob a son.","searchKeywords":["and","zelpha","the","maid","lea","conceived","bore","jacob","son"]},{"verseId":"brenton_genesis_30_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":11,"text":"And Lea said, happily: and she called his name, Gad.","searchKeywords":["and","lea","said","happily","she","called","his","name","gad"]},{"verseId":"brenton_genesis_30_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":12,"text":"And Zelpha the maid of Lea conceived yet again, and bore Jacob a second son.","searchKeywords":["and","zelpha","the","maid","lea","conceived","yet","again","bore","jacob","second","son"]},{"verseId":"brenton_genesis_30_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":13,"text":"And Lea said, I am blessed, for the women will pronounce me blessed; and she called his name, Aser.","searchKeywords":["and","lea","said","blessed","for","the","women","will","pronounce","she","called","his","name","aser"]},{"verseId":"brenton_genesis_30_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":14,"text":"And Ruben went in the day of barley-harvest, and found apples of mandrakes in the field, and brought them to his mother Lea; and Rachel said to Lea her sister, Give me of thy son's mandrakes.","searchKeywords":["and","ruben","went","the","day","barley","harvest","found","apples","mandrakes","field","brought","them","his","mother","lea","rachel","said","her","sister","give","thy","son"]},{"verseId":"brenton_genesis_30_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":15,"text":"And Lea said, not enough for thee that thou hast taken my husband, wilt thou also take my son's mandrakes? And Rachel said, Not so: let him lie with thee to-night for thy son's mandrakes.","searchKeywords":["and","lea","said","not","enough","for","thee","that","thou","hast","taken","husband","wilt","also","take","son","mandrakes","rachel","let","him","lie","with","night","thy"]},{"verseId":"brenton_genesis_30_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":16,"text":"And Jacob came in out of the field at even; and Lea went forth to meet him, and said, Thou shalt come in to me this day, for I have hired thee for my son's mandrakes; and he lay with her that night.","searchKeywords":["and","jacob","came","out","the","field","even","lea","went","forth","meet","him","said","thou","shalt","come","this","day","for","have","hired","thee","son","mandrakes","lay","with","her","that","night"]},{"verseId":"brenton_genesis_30_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":17,"text":"And God hearkened to Lea, and she conceived, and bore Jacob a fifth son.","searchKeywords":["and","god","hearkened","lea","she","conceived","bore","jacob","fifth","son"]},{"verseId":"brenton_genesis_30_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":18,"text":"And Lea said, God has given me my reward, because I gave my maid to my husband; and she called his name Issachar, which is, Reward.","searchKeywords":["and","lea","said","god","has","given","reward","because","gave","maid","husband","she","called","his","name","issachar","which"]},{"verseId":"brenton_genesis_30_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":19,"text":"And Lea conceived again, and bore Jacob a sixth son.","searchKeywords":["and","lea","conceived","again","bore","jacob","sixth","son"]},{"verseId":"brenton_genesis_30_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":20,"text":"And Lea said, God has given me a good gift in this time; my husband will choose me, for I have born him six sons: and she called his name, Zabulon.","searchKeywords":["and","lea","said","god","has","given","good","gift","this","time","husband","will","choose","for","have","born","him","six","sons","she","called","his","name","zabulon"]},{"verseId":"brenton_genesis_30_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":21,"text":"And after this she bore a daughter; and she called her name, Dina.","searchKeywords":["and","after","this","she","bore","daughter","called","her","name","dina"]},{"verseId":"brenton_genesis_30_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":22,"text":"And God remembered Rachel, and God hearkened to her, and he opened her womb.","searchKeywords":["and","god","remembered","rachel","hearkened","her","opened","womb"]},{"verseId":"brenton_genesis_30_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":23,"text":"And she conceived, and bore Jacob a son; and Rachel said, God has taken away my reproach.","searchKeywords":["and","she","conceived","bore","jacob","son","rachel","said","god","has","taken","away","reproach"]},{"verseId":"brenton_genesis_30_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":24,"text":"And she called his name Joseph, saying, Let God add to me another son.","searchKeywords":["and","she","called","his","name","joseph","saying","let","god","add","another","son"]},{"verseId":"brenton_genesis_30_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":25,"text":"And it came to pass when Rachel had born Joseph, Jacob said to Laban, Send me away, that I may go to my place and to my land.","searchKeywords":["and","came","pass","when","rachel","had","born","joseph","jacob","said","laban","send","away","that","may","place","land"]},{"verseId":"brenton_genesis_30_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":26,"text":"Restore my wives and my children, for whom I have served thee, that I may depart, for thou knowest the service wherewith I have served thee.","searchKeywords":["restore","wives","and","children","for","whom","have","served","thee","that","may","depart","thou","knowest","the","service","wherewith"]},{"verseId":"brenton_genesis_30_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":27,"text":"And Laban said to him, If I have found grace in thy sight, I would augur , for the Lord has blessed me at thy coming in.","searchKeywords":["and","laban","said","him","have","found","grace","thy","sight","would","augur","for","the","lord","has","blessed","coming"]},{"verseId":"brenton_genesis_30_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":28,"text":"Appoint me thy wages, and I will give .","searchKeywords":["appoint","thy","wages","and","will","give"]},{"verseId":"brenton_genesis_30_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":29,"text":"And Jacob said, Thou knowest in what things I have served thee, and how many cattle of thine are with me.","searchKeywords":["and","jacob","said","thou","knowest","what","things","have","served","thee","how","many","cattle","thine","are","with"]},{"verseId":"brenton_genesis_30_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":30,"text":"For it was little thou hadst before my time, and it is increased to a multitude, and the Lord God has blessed thee since my coming; now then, when shall I set up also my own house?","searchKeywords":["for","was","little","thou","hadst","before","time","and","increased","multitude","the","lord","god","has","blessed","thee","since","coming","now","then","when","shall","set","also","own","house"]},{"verseId":"brenton_genesis_30_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":31,"text":"And Laban said to him, What shall I give thee? and Jacob said to him, Thou shalt not give me anything; if thou wilt do this thing for me, I will again tend thy flocks and keep them.","searchKeywords":["and","laban","said","him","what","shall","give","thee","jacob","thou","shalt","not","anything","wilt","this","thing","for","will","again","tend","thy","flocks","keep","them"]},{"verseId":"brenton_genesis_30_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":32,"text":"Let all thy sheep pass by to-day, and separate thence every grey sheep among the rams, and every one that is speckled and spotted among the goats— shall be my reward.","searchKeywords":["let","all","thy","sheep","pass","day","and","separate","thence","every","grey","among","the","rams","one","that","speckled","spotted","goats","shall","reward"]},{"verseId":"brenton_genesis_30_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":33,"text":"And my righteousness shall answer for me on the morrow, for it is my reward before thee: whatever shall not be spotted and speckled among the goats, and grey among the rams, shall be stolen with me.","searchKeywords":["and","righteousness","shall","answer","for","the","morrow","reward","before","thee","whatever","not","spotted","speckled","among","goats","grey","rams","stolen","with"]},{"verseId":"brenton_genesis_30_34","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":34,"text":"And Laban said to him, Let it be according to thy word.","searchKeywords":["and","laban","said","him","let","according","thy","word"]},{"verseId":"brenton_genesis_30_35","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":35,"text":"And he separated in that day the spotted and speckled he-goats, and all the spotted and speckled she-goats, and all that was grey among the rams, and every one that was white among them, and he gave them into the hand of his sons.","searchKeywords":["and","separated","that","day","the","spotted","speckled","goats","all","she","was","grey","among","rams","every","one","white","them","gave","into","hand","his","sons"]},{"verseId":"brenton_genesis_30_36","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":36,"text":"And he set a distance of a three days' journey between them and Jacob. And Jacob tended the cattle of Laban that were left behind.","searchKeywords":["and","set","distance","three","days","journey","between","them","jacob","tended","the","cattle","laban","that","were","left","behind"]},{"verseId":"brenton_genesis_30_37","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":37,"text":"And Jacob took to himself green rods of storax tree and walnut and plane-tree; and Jacob peeled in them white stripes; and as he drew off the green, the white stripe which he had made appeared alternate on the rods.","searchKeywords":["and","jacob","took","himself","green","rods","storax","tree","walnut","plane","peeled","them","white","stripes","drew","off","the","stripe","which","had","made","appeared","alternate"]},{"verseId":"brenton_genesis_30_38","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":38,"text":"And he laid the rods which he had peeled, in the hollows of the watering-troughs, that whensoever the cattle should come to drink, as they should have come to drink before the rods, the cattle might conceive at the rods.","searchKeywords":["and","laid","the","rods","which","had","peeled","hollows","watering","troughs","that","whensoever","cattle","should","come","drink","they","have","before","might","conceive"]},{"verseId":"brenton_genesis_30_39","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":39,"text":"So the cattle conceived at the rods, and the cattle brought forth speckled, and streaked and spotted with ash-coloured .","searchKeywords":["the","cattle","conceived","rods","and","brought","forth","speckled","streaked","spotted","with","ash","coloured"]},{"verseId":"brenton_genesis_30_40","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":40,"text":"And Jacob separated the lambs, and set before the sheep a speckled ram, and every variegated one among the lambs, and he separated flocks for himself alone, and did not mingle them with the sheep of Laban.","searchKeywords":["and","jacob","separated","the","lambs","set","before","sheep","speckled","ram","every","variegated","one","among","flocks","for","himself","alone","did","not","mingle","them","with","laban"]},{"verseId":"brenton_genesis_30_41","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":41,"text":"And it came to pass in the time wherein the cattle became pregnant, conceiving in the belly, Jacob put the rods before the cattle in the troughs, that they might conceive by the rods.","searchKeywords":["and","came","pass","the","time","wherein","cattle","became","pregnant","conceiving","belly","jacob","put","rods","before","troughs","that","they","might","conceive"]},{"verseId":"brenton_genesis_30_42","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":42,"text":"But he did not put them in whenever the cattle happened to bring forth, but the unmarked ones were Laban's, and the marked ones Jacob's.","searchKeywords":["but","did","not","put","them","whenever","the","cattle","happened","bring","forth","unmarked","ones","were","laban","and","marked","jacob"]},{"verseId":"brenton_genesis_30_43","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":30,"verse":43,"text":"And the man became very rich, and he had many cattle, and oxen, and servants, and maid-servants, and camels, and asses.","searchKeywords":["and","the","man","became","very","rich","had","many","cattle","oxen","servants","maid","camels","asses"]}]