[{"verseId":"brenton_genesis_50_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":1,"text":"And Joseph fell upon his father's face, and wept on him, and kissed him.","searchKeywords":["and","joseph","fell","upon","his","father","face","wept","him","kissed"]},{"verseId":"brenton_genesis_50_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":2,"text":"And Joseph commanded his servants the embalmers to embalm his father; and the embalmers embalmed Israel.","searchKeywords":["and","joseph","commanded","his","servants","the","embalmers","embalm","father","embalmed","israel"]},{"verseId":"brenton_genesis_50_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":3,"text":"And they fulfilled forty days for him, for so are the days of embalming numbered; and Egypt mourned for him seventy days.","searchKeywords":["and","they","fulfilled","forty","days","for","him","are","the","embalming","numbered","egypt","mourned","seventy"]},{"verseId":"brenton_genesis_50_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":4,"text":"And when the days of mourning were past, Joseph spoke to the princes of Pharao, saying, If I have found favour in your sight, speak concerning me in the ears of Pharao, saying,","searchKeywords":["and","when","the","days","mourning","were","past","joseph","spoke","princes","pharao","saying","have","found","favour","your","sight","speak","concerning","ears"]},{"verseId":"brenton_genesis_50_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":5,"text":"My father adjured me, saying, In the sepulchre which I dug for myself in the land of Chanaan, there thou shalt bury me; now then I will go up and bury my father, and return again.","searchKeywords":["father","adjured","saying","the","sepulchre","which","dug","for","myself","land","chanaan","there","thou","shalt","bury","now","then","will","and","return","again"]},{"verseId":"brenton_genesis_50_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":6,"text":"And Pharao said to Joseph, Go up, bury thy father, as he constrained thee to swear.","searchKeywords":["and","pharao","said","joseph","bury","thy","father","constrained","thee","swear"]},{"verseId":"brenton_genesis_50_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":7,"text":"So Joseph went up to bury his father; and all the servants of Pharao went up with him, and the elders of his house, and all the elders of the land of Egypt.","searchKeywords":["joseph","went","bury","his","father","and","all","the","servants","pharao","with","him","elders","house","land","egypt"]},{"verseId":"brenton_genesis_50_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":8,"text":"And all the household of Joseph, and his brethren, and all the house of his father, and his kindred; and they left behind the sheep and the oxen in the land of Gesem.","searchKeywords":["and","all","the","household","joseph","his","brethren","house","father","kindred","they","left","behind","sheep","oxen","land","gesem"]},{"verseId":"brenton_genesis_50_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":9,"text":"And there went up with him also chariots and horsemen; and there was a very great company.","searchKeywords":["and","there","went","with","him","also","chariots","horsemen","was","very","great","company"]},{"verseId":"brenton_genesis_50_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":10,"text":"And they came to the threshing-floor of Atad, which is beyond Jordan; and they bewailed him with a great and very sore lamentation; and he made a mourning for his father seven days.","searchKeywords":["and","they","came","the","threshing","floor","atad","which","beyond","jordan","bewailed","him","with","great","very","sore","lamentation","made","mourning","for","his","father","seven","days"]},{"verseId":"brenton_genesis_50_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":11,"text":"And the inhabitants of the land of Chanaan saw the mourning at the floor of Atad, and said, This is a great mourning to the Egyptians; therefore he called its name, The mourning of Egypt, which is beyond Jordan.","searchKeywords":["and","the","inhabitants","land","chanaan","saw","mourning","floor","atad","said","this","great","egyptians","therefore","called","its","name","egypt","which","beyond","jordan"]},{"verseId":"brenton_genesis_50_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":12,"text":"And thus his sons did to him.","searchKeywords":["and","thus","his","sons","did","him"]},{"verseId":"brenton_genesis_50_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":13,"text":"So his sons carried him up into the land of Chanaan, and buried him in the double cave, which cave Abraam bought for possession of a burying place, of Ephrom the Chettite, before Mambre.","searchKeywords":["his","sons","carried","him","into","the","land","chanaan","and","buried","double","cave","which","abraam","bought","for","possession","burying","place","ephrom","chettite","before","mambre"]},{"verseId":"brenton_genesis_50_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":14,"text":"And Joseph returned to Egypt, he and his brethren, and those that had gone up with him to bury his father.","searchKeywords":["and","joseph","returned","egypt","his","brethren","those","that","had","gone","with","him","bury","father"]},{"verseId":"brenton_genesis_50_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":15,"text":"And when the brethren of Joseph saw that their father was dead, they said, , lest at any time Joseph remember evil against us, and recompense to us all the evils which we have done against him.","searchKeywords":["and","when","the","brethren","joseph","saw","that","their","father","was","dead","they","said","lest","any","time","remember","evil","against","recompense","all","evils","which","have","done","him"]},{"verseId":"brenton_genesis_50_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":16,"text":"And they came to Joseph, and said, Thy father adjured before his death, saying,","searchKeywords":["and","they","came","joseph","said","thy","father","adjured","before","his","death","saying"]},{"verseId":"brenton_genesis_50_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":17,"text":"Thus say ye to Joseph, Forgive them their injustice and their sin, forasmuch as they have done thee evil; and now pardon the injustice of the servants of the God of thy father. And Joseph wept while they spoke to him.","searchKeywords":["thus","say","joseph","forgive","them","their","injustice","and","sin","forasmuch","they","have","done","thee","evil","now","pardon","the","servants","god","thy","father","wept","while","spoke","him"]},{"verseId":"brenton_genesis_50_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":18,"text":"And they came to him and said, We, these , are thy servants.","searchKeywords":["and","they","came","him","said","these","are","thy","servants"]},{"verseId":"brenton_genesis_50_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":19,"text":"And Joseph said to them, Fear not, for I am God's.","searchKeywords":["and","joseph","said","them","fear","not","for","god"]},{"verseId":"brenton_genesis_50_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":20,"text":"Ye took counsel against me for evil, but God took counsel for me for good, that might be as to-day, and much people might be fed.","searchKeywords":["took","counsel","against","for","evil","but","god","good","that","might","day","and","much","people","fed"]},{"verseId":"brenton_genesis_50_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":21,"text":"And he said to them, Fear not, I will maintain you, and your families: and he comforted them, and spoke kindly to them.","searchKeywords":["and","said","them","fear","not","will","maintain","you","your","families","comforted","spoke","kindly"]},{"verseId":"brenton_genesis_50_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":22,"text":"And Joseph dwelt in Egypt, he and his brethren, and all the family of his father; and Joseph lived a hundred and ten years.","searchKeywords":["and","joseph","dwelt","egypt","his","brethren","all","the","family","father","lived","hundred","ten","years"]},{"verseId":"brenton_genesis_50_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":23,"text":"And Joseph saw the children of Ephraim to the third generation; and the sons of Machir the son of Manasse were borne on the sides of Joseph.","searchKeywords":["and","joseph","saw","the","children","ephraim","third","generation","sons","machir","son","manasse","were","borne","sides"]},{"verseId":"brenton_genesis_50_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":24,"text":"And Joseph spoke to his brethren, saying, I die, and God will surely visit you, and will bring you out of this land to the land concerning which God sware to our fathers, Abraam, Isaac, and Jacob.","searchKeywords":["and","joseph","spoke","his","brethren","saying","die","god","will","surely","visit","you","bring","out","this","land","the","concerning","which","sware","our","fathers","abraam","isaac","jacob"]},{"verseId":"brenton_genesis_50_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":25,"text":"And Joseph adjured the sons of Israel, saying, At the visitation with which God shall visit you, then ye shall carry up my bones hence with you.","searchKeywords":["and","joseph","adjured","the","sons","israel","saying","visitation","with","which","god","shall","visit","you","then","carry","bones","hence"]},{"verseId":"brenton_genesis_50_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":50,"verse":26,"text":"And Joseph died, aged an hundred and ten years; and they prepared his corpse, and put him in a coffin in Egypt.","searchKeywords":["and","joseph","died","aged","hundred","ten","years","they","prepared","his","corpse","put","him","coffin","egypt"]}]