[{"verseId":"brenton_genesis_4_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":1,"text":"And Adam knew Eve his wife, and she conceived and brought forth Cain and said, I have gained a man through God.","searchKeywords":["and","adam","knew","eve","his","wife","she","conceived","brought","forth","cain","said","have","gained","man","through","god"]},{"verseId":"brenton_genesis_4_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":2,"text":"And she again bore his brother Abel. And Abel was a keeper of sheep, but Cain was a tiller of the ground.","searchKeywords":["and","she","again","bore","his","brother","abel","was","keeper","sheep","but","cain","tiller","the","ground"]},{"verseId":"brenton_genesis_4_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":3,"text":"And it was so after some time that Cain brought of the fruits of the earth a sacrifice to the Lord.","searchKeywords":["and","was","after","some","time","that","cain","brought","the","fruits","earth","sacrifice","lord"]},{"verseId":"brenton_genesis_4_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":4,"text":"And Abel also brought of the firstborn of his sheep and of his fatlings, and God looked upon Abel and his gifts,","searchKeywords":["and","abel","also","brought","the","firstborn","his","sheep","fatlings","god","looked","upon","gifts"]},{"verseId":"brenton_genesis_4_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":5,"text":"but Cain and his sacrifices he regarded not, and Cain was exceedingly sorrowful and his countenance fell.","searchKeywords":["but","cain","and","his","sacrifices","regarded","not","was","exceedingly","sorrowful","countenance","fell"]},{"verseId":"brenton_genesis_4_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":6,"text":"And the Lord God said to Cain, Why art thou become very sorrowful and why is thy countenance fallen?","searchKeywords":["and","the","lord","god","said","cain","why","art","thou","become","very","sorrowful","thy","countenance","fallen"]},{"verseId":"brenton_genesis_4_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":7,"text":"Hast thou not sinned if thou hast brought it rightly, but not rightly divided it? be still, to thee shall be his submission, and thou shalt rule over him.","searchKeywords":["hast","thou","not","sinned","brought","rightly","but","divided","still","thee","shall","his","submission","and","shalt","rule","over","him"]},{"verseId":"brenton_genesis_4_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":8,"text":"And Cain said to Abel his brother, Let us go out into the plain; and it came to pass that when they were in the plain Cain rose up against Abel his brother, and slew him.","searchKeywords":["and","cain","said","abel","his","brother","let","out","into","the","plain","came","pass","that","when","they","were","rose","against","slew","him"]},{"verseId":"brenton_genesis_4_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":9,"text":"And the Lord God said to Cain, Where is Abel thy brother? and he said, I know not, am I my brother's keeper?","searchKeywords":["and","the","lord","god","said","cain","where","abel","thy","brother","know","not","keeper"]},{"verseId":"brenton_genesis_4_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":10,"text":"And the Lord said, What hast thou done? the voice of thy brother's blood cries to me out of the ground.","searchKeywords":["and","the","lord","said","what","hast","thou","done","voice","thy","brother","blood","cries","out","ground"]},{"verseId":"brenton_genesis_4_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":11,"text":"And now thou cursed from the earth which has opened her mouth to receive thy brother's blood from thy hand.","searchKeywords":["and","now","thou","cursed","from","the","earth","which","has","opened","her","mouth","receive","thy","brother","blood","hand"]},{"verseId":"brenton_genesis_4_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":12,"text":"When thou tillest the earth, then it shall not continue to give its strength to thee: thou shalt be groaning and trembling on the earth.","searchKeywords":["when","thou","tillest","the","earth","then","shall","not","continue","give","its","strength","thee","shalt","groaning","and","trembling"]},{"verseId":"brenton_genesis_4_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":13,"text":"And Cain said to the Lord God, My crime too great for me to be forgiven.","searchKeywords":["and","cain","said","the","lord","god","crime","too","great","for","forgiven"]},{"verseId":"brenton_genesis_4_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":14,"text":"If thou castest me out this day from the face of the earth, and I shall be hidden from thy presence, and I shall be groaning and trembling upon the earth, then it will be that any one that finds me shall slay me.","searchKeywords":["thou","castest","out","this","day","from","the","face","earth","and","shall","hidden","thy","presence","groaning","trembling","upon","then","will","that","any","one","finds","slay"]},{"verseId":"brenton_genesis_4_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":15,"text":"And the Lord God said to him, Not so, any one that slays Cain shall suffer seven-fold vengeance; and the Lord God set a mark upon Cain that no one that found him might slay him.","searchKeywords":["and","the","lord","god","said","him","not","any","one","that","slays","cain","shall","suffer","seven","fold","vengeance","set","mark","upon","found","might","slay"]},{"verseId":"brenton_genesis_4_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":16,"text":"So Cain went forth from the presence of God and dwelt in the land of Nod over against Edem.","searchKeywords":["cain","went","forth","from","the","presence","god","and","dwelt","land","nod","over","against","edem"]},{"verseId":"brenton_genesis_4_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":17,"text":"And Cain knew his wife, and having conceived she bore Enoch; and he built a city; and he named the city after the name of his son, Enoch.","searchKeywords":["and","cain","knew","his","wife","having","conceived","she","bore","enoch","built","city","named","the","after","name","son"]},{"verseId":"brenton_genesis_4_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":18,"text":"And to Enoch was born Gaidad; and Gaidad begot Maleleel; and Maleleel begot Mathusala; and Mathusala begot Lamech.","searchKeywords":["and","enoch","was","born","gaidad","begot","maleleel","mathusala","lamech"]},{"verseId":"brenton_genesis_4_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":19,"text":"And Lamech took to himself two wives; the name of the one was Ada, and the name of the second Sella.","searchKeywords":["and","lamech","took","himself","two","wives","the","name","one","was","ada","second","sella"]},{"verseId":"brenton_genesis_4_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":20,"text":"And Ada bore Jobel; he was the father of those that dwell in tents, feeding cattle.","searchKeywords":["and","ada","bore","jobel","was","the","father","those","that","dwell","tents","feeding","cattle"]},{"verseId":"brenton_genesis_4_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":21,"text":"And the name of his brother was Jubal; he it was who invented the psaltery and harp.","searchKeywords":["and","the","name","his","brother","was","jubal","who","invented","psaltery","harp"]},{"verseId":"brenton_genesis_4_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":22,"text":"And Sella also bore Thobel; he was a smith, a manufacturer both of brass and iron; and the sister of Thobel was Noëma.","searchKeywords":["and","sella","also","bore","thobel","was","smith","manufacturer","both","brass","iron","the","sister"]},{"verseId":"brenton_genesis_4_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":23,"text":"And Lamech said to his wives, Ada and Sella, Hear my voice, ye wives of Lamech, consider my words, because I have slain a man to my sorrow and a youth to my grief.","searchKeywords":["and","lamech","said","his","wives","ada","sella","hear","voice","consider","words","because","have","slain","man","sorrow","youth","grief"]},{"verseId":"brenton_genesis_4_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":24,"text":"Because vengeance has been exacted seven times on Cain's behalf, on Lamech's seventy times seven.","searchKeywords":["because","vengeance","has","been","exacted","seven","times","cain","behalf","lamech","seventy"]},{"verseId":"brenton_genesis_4_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":25,"text":"And Adam knew Eve his wife, and she conceived and bore a son, and called his name Seth, saying, For God has raised up to me another seed instead of Abel, whom Cain slew.","searchKeywords":["and","adam","knew","eve","his","wife","she","conceived","bore","son","called","name","seth","saying","for","god","has","raised","another","seed","instead","abel","whom","cain","slew"]},{"verseId":"brenton_genesis_4_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":4,"verse":26,"text":"And Seth had a son, and he called his name Enos: he hoped to call on the name of the Lord God.","searchKeywords":["and","seth","had","son","called","his","name","enos","hoped","call","the","lord","god"]}]