[{"verseId":"brenton_genesis_18_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":1,"text":"And God appeared to him by the oak of Mambre, as he sat by the door of his tent at noon.","searchKeywords":["and","god","appeared","him","the","oak","mambre","sat","door","his","tent","noon"]},{"verseId":"brenton_genesis_18_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":2,"text":"And he lifted up his eyes and beheld, and lo! three men stood before him; and having seen them he ran to meet them from the door of his tent, and did obeisance to the ground.","searchKeywords":["and","lifted","his","eyes","beheld","three","men","stood","before","him","having","seen","them","ran","meet","from","the","door","tent","did","obeisance","ground"]},{"verseId":"brenton_genesis_18_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":3,"text":"And he said, Lord, if indeed I have found grace in thy sight, pass not by thy servant.","searchKeywords":["and","said","lord","indeed","have","found","grace","thy","sight","pass","not","servant"]},{"verseId":"brenton_genesis_18_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":4,"text":"Let water now be brought, and let them wash your feet, and do ye refresh under the tree.","searchKeywords":["let","water","now","brought","and","them","wash","your","feet","refresh","under","the","tree"]},{"verseId":"brenton_genesis_18_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":5,"text":"And I will bring bread, and ye shall eat, and after this ye shall depart on your journey, on account of which ye have turned aside to your servant. And he said, So do, as thou hast said.","searchKeywords":["and","will","bring","bread","shall","eat","after","this","depart","your","journey","account","which","have","turned","aside","servant","said","thou","hast"]},{"verseId":"brenton_genesis_18_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":6,"text":"And Abraam hasted to the tent to Sarrha, and said to her, Hasten, and knead three measures of fine flour, and make cakes.","searchKeywords":["and","abraam","hasted","the","tent","sarrha","said","her","hasten","knead","three","measures","fine","flour","make","cakes"]},{"verseId":"brenton_genesis_18_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":7,"text":"And Abraam ran to the kine, and took a young calf, tender and good, and gave it to his servant, and he hasted to dress it.","searchKeywords":["and","abraam","ran","the","kine","took","young","calf","tender","good","gave","his","servant","hasted","dress"]},{"verseId":"brenton_genesis_18_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":8,"text":"And he took butter and milk, and the calf which he had dressed; and he set them before them, and they did eat, and he stood by them under the tree.","searchKeywords":["and","took","butter","milk","the","calf","which","had","dressed","set","them","before","they","did","eat","stood","under","tree"]},{"verseId":"brenton_genesis_18_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":9,"text":"And he said to him, Where is Sarrha thy wife? And he answered and said, Behold! in the tent.","searchKeywords":["and","said","him","where","sarrha","thy","wife","answered","behold","the","tent"]},{"verseId":"brenton_genesis_18_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":10,"text":"And he said, I will return and come to thee according to this period seasonably, and Sarrha thy wife shall have a son; and Sarrha heard at the door of the tent, being behind him.","searchKeywords":["and","said","will","return","come","thee","according","this","period","seasonably","sarrha","thy","wife","shall","have","son","heard","the","door","tent","being","behind","him"]},{"verseId":"brenton_genesis_18_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":11,"text":"And Abraam and Sarrha were old, advanced in days, and the custom of women ceased with Sarrha.","searchKeywords":["and","abraam","sarrha","were","old","advanced","days","the","custom","women","ceased","with"]},{"verseId":"brenton_genesis_18_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":12,"text":"And Sarrha laughed in herself, saying, The thing has not as yet happened to me, even until now, and my lord is old.","searchKeywords":["and","sarrha","laughed","herself","saying","the","thing","has","not","yet","happened","even","until","now","lord","old"]},{"verseId":"brenton_genesis_18_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":13,"text":"And the Lord said to Abraam, Why is it that Sarrha has laughed in herself, saying, Shall I then indeed bear? but I am grown old.","searchKeywords":["and","the","lord","said","abraam","why","that","sarrha","has","laughed","herself","saying","shall","then","indeed","bear","but","grown","old"]},{"verseId":"brenton_genesis_18_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":14,"text":"Shall anything be impossible with the Lord? At this time I will return to thee seasonably, and Sarrha shall have a son.","searchKeywords":["shall","anything","impossible","with","the","lord","this","time","will","return","thee","seasonably","and","sarrha","have","son"]},{"verseId":"brenton_genesis_18_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":15,"text":"But Sarrha denied, saying, I did not laugh, for she was afraid. And he said to her, Nay, but thou didst laugh.","searchKeywords":["but","sarrha","denied","saying","did","not","laugh","for","she","was","afraid","and","said","her","nay","thou","didst"]},{"verseId":"brenton_genesis_18_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":16,"text":"And the men having risen up from thence looked towards Sodom and Gomorrha. And Abraam went with them, attending them on their journey.","searchKeywords":["and","the","men","having","risen","from","thence","looked","towards","sodom","gomorrha","abraam","went","with","them","attending","their","journey"]},{"verseId":"brenton_genesis_18_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":17,"text":"And the Lord said, Shall I hide from Abraam my servant what things I intend to do?","searchKeywords":["and","the","lord","said","shall","hide","from","abraam","servant","what","things","intend"]},{"verseId":"brenton_genesis_18_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":18,"text":"But Abraam shall become a great and populous nation, and in him shall all the nations of the earth be blest.","searchKeywords":["but","abraam","shall","become","great","and","populous","nation","him","all","the","nations","earth","blest"]},{"verseId":"brenton_genesis_18_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":19,"text":"For I know that he will order his sons, and his house after him, and they will keep the ways of the Lord, to do justice and judgment, that the Lord may bring upon Abraam all things whatsoever he has spoken to him.","searchKeywords":["for","know","that","will","order","his","sons","and","house","after","him","they","keep","the","ways","lord","justice","judgment","may","bring","upon","abraam","all","things","whatsoever","has","spoken"]},{"verseId":"brenton_genesis_18_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":20,"text":"And the Lord said, The cry of Sodom and Gomorrha has been increased towards me, and their sins are very great.","searchKeywords":["and","the","lord","said","cry","sodom","gomorrha","has","been","increased","towards","their","sins","are","very","great"]},{"verseId":"brenton_genesis_18_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":21,"text":"I will therefore go down and see, if they completely correspond with the cry which comes to me, and if not, that I may know.","searchKeywords":["will","therefore","down","and","see","they","completely","correspond","with","the","cry","which","comes","not","that","may","know"]},{"verseId":"brenton_genesis_18_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":22,"text":"And the men having departed thence, came to Sodom; and Abraam was still standing before the Lord.","searchKeywords":["and","the","men","having","departed","thence","came","sodom","abraam","was","still","standing","before","lord"]},{"verseId":"brenton_genesis_18_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":23,"text":"And Abraam drew nigh and said, Wouldest thou destroy the righteous with the wicked, and shall the righteous be as the wicked?","searchKeywords":["and","abraam","drew","nigh","said","wouldest","thou","destroy","the","righteous","with","wicked","shall"]},{"verseId":"brenton_genesis_18_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":24,"text":"Should there be fifty righteous in the city, wilt thou destroy them? wilt thou not spare the whole place for the sake of the fifty righteous, if they be in it?","searchKeywords":["should","there","fifty","righteous","the","city","wilt","thou","destroy","them","not","spare","whole","place","for","sake","they"]},{"verseId":"brenton_genesis_18_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":25,"text":"By no means shalt thou do as this thing so as to destroy the righteous with the wicked, so the righteous shall be as the wicked: by no means. Thou that judgest the whole earth, shalt thou not do right?","searchKeywords":["means","shalt","thou","this","thing","destroy","the","righteous","with","wicked","shall","that","judgest","whole","earth","not","right"]},{"verseId":"brenton_genesis_18_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":26,"text":"And the Lord said, If there should be in Sodom fifty righteous in the city, I will spare the whole city, and the whole place for their sakes.","searchKeywords":["and","the","lord","said","there","should","sodom","fifty","righteous","city","will","spare","whole","place","for","their","sakes"]},{"verseId":"brenton_genesis_18_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":27,"text":"And Abraam answered and said, Now I have begun to speak to my Lord, and I am earth and ashes.","searchKeywords":["and","abraam","answered","said","now","have","begun","speak","lord","earth","ashes"]},{"verseId":"brenton_genesis_18_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":28,"text":"But if the fifty righteous should be diminished to forty-five, wilt thou destroy the whole city because of the five ? And he said, I will not destroy it, if I should find there forty-five.","searchKeywords":["but","the","fifty","righteous","should","diminished","forty","five","wilt","thou","destroy","whole","city","because","and","said","will","not","find","there"]},{"verseId":"brenton_genesis_18_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":29,"text":"And he continued to speak to him still, and said, But if there should be found there forty? And he said, I will not destroy it for the forty's sake.","searchKeywords":["and","continued","speak","him","still","said","but","there","should","found","forty","will","not","destroy","for","the","sake"]},{"verseId":"brenton_genesis_18_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":30,"text":"And he said, Will there be anything , Lord, if I shall speak? but if there be found there thirty? And he said, I will not destroy it for the thirty's sake.","searchKeywords":["and","said","will","there","anything","lord","shall","speak","but","found","thirty","not","destroy","for","the","sake"]},{"verseId":"brenton_genesis_18_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":31,"text":"And he said, Since I am able to speak to the Lord, what if there should be found there twenty? And he said, I will not destroy it, if I should find there twenty.","searchKeywords":["and","said","since","able","speak","the","lord","what","there","should","found","twenty","will","not","destroy","find"]},{"verseId":"brenton_genesis_18_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":32,"text":"And he said, Will there be anything , Lord, if I speak yet once? but if there should be found there ten? And he said, I will not destroy it for the ten's sake.","searchKeywords":["and","said","will","there","anything","lord","speak","yet","once","but","should","found","ten","not","destroy","for","the","sake"]},{"verseId":"brenton_genesis_18_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":18,"verse":33,"text":"And the Lord departed, when he left off speaking to Abraam, and Abraam returned to his place.","searchKeywords":["and","the","lord","departed","when","left","off","speaking","abraam","returned","his","place"]}]