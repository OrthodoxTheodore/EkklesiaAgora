[{"verseId":"brenton_genesis_2_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":1,"text":"And the heavens and the earth were finished, and the whole world of them.","searchKeywords":["and","the","heavens","earth","were","finished","whole","world","them"]},{"verseId":"brenton_genesis_2_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":2,"text":"And God finished on the sixth day his works which he made, and he ceased on the seventh day from all his works which he made.","searchKeywords":["and","god","finished","the","sixth","day","his","works","which","made","ceased","seventh","from","all"]},{"verseId":"brenton_genesis_2_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":3,"text":"And God blessed the seventh day and sanctified it, because in it he ceased from all his works which God began to do.","searchKeywords":["and","god","blessed","the","seventh","day","sanctified","because","ceased","from","all","his","works","which","began"]},{"verseId":"brenton_genesis_2_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":4,"text":"This the book of the generation of heaven and earth, when they were made, in the day in which the Lord God made the heaven and the earth,","searchKeywords":["this","the","book","generation","heaven","and","earth","when","they","were","made","day","which","lord","god"]},{"verseId":"brenton_genesis_2_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":5,"text":"and every herb of the field before it was on the earth, and all the grass of the field before it sprang up, for God had not rained on the earth, and there was not a man to cultivate it.","searchKeywords":["and","every","herb","the","field","before","was","earth","all","grass","sprang","for","god","had","not","rained","there","man","cultivate"]},{"verseId":"brenton_genesis_2_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":6,"text":"But there rose a fountain out of the earth, and watered the whole face of the earth.","searchKeywords":["but","there","rose","fountain","out","the","earth","and","watered","whole","face"]},{"verseId":"brenton_genesis_2_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":7,"text":"And God formed the man dust of the earth, and breathed upon his face the breath of life, and the man became a living soul.","searchKeywords":["and","god","formed","the","man","dust","earth","breathed","upon","his","face","breath","life","became","living","soul"]},{"verseId":"brenton_genesis_2_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":8,"text":"And God planted a garden eastward in Edem, and placed there the man whom he had formed.","searchKeywords":["and","god","planted","garden","eastward","edem","placed","there","the","man","whom","had","formed"]},{"verseId":"brenton_genesis_2_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":9,"text":"And God made to spring up also out of the earth every tree beautiful to the eye and good for food, and the tree of life in the midst of the garden, and the tree of learning the knowledge of good and evil.","searchKeywords":["and","god","made","spring","also","out","the","earth","every","tree","beautiful","eye","good","for","food","life","midst","garden","learning","knowledge","evil"]},{"verseId":"brenton_genesis_2_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":10,"text":"And a river proceeds out of Edem to water the garden, thence it divides itself into four heads.","searchKeywords":["and","river","proceeds","out","edem","water","the","garden","thence","divides","itself","into","four","heads"]},{"verseId":"brenton_genesis_2_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":11,"text":"The name of the one, Phisom, this it is which encircles the whole land of Evilat, where there is gold.","searchKeywords":["the","name","one","phisom","this","which","encircles","whole","land","evilat","where","there","gold"]},{"verseId":"brenton_genesis_2_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":12,"text":"And the gold of that land is good, there also is carbuncle and emerald.","searchKeywords":["and","the","gold","that","land","good","there","also","carbuncle","emerald"]},{"verseId":"brenton_genesis_2_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":13,"text":"And the name of the second river is Geon, this it is which encircles the whole land of Ethiopia.","searchKeywords":["and","the","name","second","river","geon","this","which","encircles","whole","land","ethiopia"]},{"verseId":"brenton_genesis_2_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":14,"text":"And the third river is Tigris, this is that which flows forth over against the Assyrians. And the fourth river is Euphrates.","searchKeywords":["and","the","third","river","tigris","this","that","which","flows","forth","over","against","assyrians","fourth","euphrates"]},{"verseId":"brenton_genesis_2_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":15,"text":"And the Lord God took the man whom he had formed, and placed him in the garden of Delight, to cultivate and keep it.","searchKeywords":["and","the","lord","god","took","man","whom","had","formed","placed","him","garden","delight","cultivate","keep"]},{"verseId":"brenton_genesis_2_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":16,"text":"And the Lord God gave a charge to Adam, saying, Of every tree which is in the garden thou mayest freely eat,","searchKeywords":["and","the","lord","god","gave","charge","adam","saying","every","tree","which","garden","thou","mayest","freely","eat"]},{"verseId":"brenton_genesis_2_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":17,"text":"but of the tree of the knowledge of good and evil—of it ye shall not eat, but in whatsoever day ye eat of it, ye shall surely die.","searchKeywords":["but","the","tree","knowledge","good","and","evil","shall","not","eat","whatsoever","day","surely","die"]},{"verseId":"brenton_genesis_2_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":18,"text":"And the Lord God said, not good that the man should be alone, let us make for him a help suitable to him.","searchKeywords":["and","the","lord","god","said","not","good","that","man","should","alone","let","make","for","him","help","suitable"]},{"verseId":"brenton_genesis_2_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":19,"text":"And God formed yet farther out of the earth all the wild beasts of the field, and all the birds of the sky, and he brought them to Adam, to see what he would call them, and whatever Adam called any living creature, that was the name of it.","searchKeywords":["and","god","formed","yet","farther","out","the","earth","all","wild","beasts","field","birds","sky","brought","them","adam","see","what","would","call","whatever","called","any","living","creature","that","was","name"]},{"verseId":"brenton_genesis_2_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":20,"text":"And Adam gave names to all the cattle and to all the birds of the sky, and to all the wild beasts of the field, but for Adam there was not found a help like to himself.","searchKeywords":["and","adam","gave","names","all","the","cattle","birds","sky","wild","beasts","field","but","for","there","was","not","found","help","like","himself"]},{"verseId":"brenton_genesis_2_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":21,"text":"And God brought a trance upon Adam, and he slept, and he took one of his ribs, and filled up the flesh instead thereof.","searchKeywords":["and","god","brought","trance","upon","adam","slept","took","one","his","ribs","filled","the","flesh","instead","thereof"]},{"verseId":"brenton_genesis_2_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":22,"text":"And God formed the rib which he took from Adam into a woman, and brought her to Adam.","searchKeywords":["and","god","formed","the","rib","which","took","from","adam","into","woman","brought","her"]},{"verseId":"brenton_genesis_2_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":23,"text":"And Adam said, This now is bone of my bones, and flesh of my flesh; she shall be called woman, because she was taken out of her husband.","searchKeywords":["and","adam","said","this","now","bone","bones","flesh","she","shall","called","woman","because","was","taken","out","her","husband"]},{"verseId":"brenton_genesis_2_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":24,"text":"Therefore shall a man leave his father and his mother and shall cleave to his wife, and they two shall be one flesh.","searchKeywords":["therefore","shall","man","leave","his","father","and","mother","cleave","wife","they","two","one","flesh"]},{"verseId":"brenton_genesis_2_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":2,"verse":25,"text":"And the two were naked, both Adam and his wife, and were not ashamed.","searchKeywords":["and","the","two","were","naked","both","adam","his","wife","not","ashamed"]}]