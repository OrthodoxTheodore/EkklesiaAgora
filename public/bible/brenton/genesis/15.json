[{"verseId":"brenton_genesis_15_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":1,"text":"And after these things the word of the Lord came to Abram in a vision, saying, Fear not, Abram, I shield thee, thy reward shall be very great.","searchKeywords":["and","after","these","things","the","word","lord","came","abram","vision","saying","fear","not","shield","thee","thy","reward","shall","very","great"]},{"verseId":"brenton_genesis_15_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":2,"text":"And Abram said, Master Lord, what wilt thou give me? whereas I am departing without a child, but the son of Masek my home-born female slave, this Eliezer of Damascus .","searchKeywords":["and","abram","said","master","lord","what","wilt","thou","give","whereas","departing","without","child","but","the","son","masek","home","born","female","slave","this","eliezer","damascus"]},{"verseId":"brenton_genesis_15_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":3,"text":"And Abram said, since thou hast given me no seed, but my home-born shall succeed me.","searchKeywords":["and","abram","said","since","thou","hast","given","seed","but","home","born","shall","succeed"]},{"verseId":"brenton_genesis_15_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":4,"text":"And immediately there was a voice of the Lord to him, saying, This shall not be thine heir; but he that shall come out of thee shall be thine heir.","searchKeywords":["and","immediately","there","was","voice","the","lord","him","saying","this","shall","not","thine","heir","but","that","come","out","thee"]},{"verseId":"brenton_genesis_15_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":5,"text":"And he brought him out and said to him, Look up now to heaven, and count the stars, if thou shalt be able to number them fully, and he said, Thus shall thy seed be.","searchKeywords":["and","brought","him","out","said","look","now","heaven","count","the","stars","thou","shalt","able","number","them","fully","thus","shall","thy","seed"]},{"verseId":"brenton_genesis_15_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":6,"text":"And Abram believed God, and it was counted to him for righteousness.","searchKeywords":["and","abram","believed","god","was","counted","him","for","righteousness"]},{"verseId":"brenton_genesis_15_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":7,"text":"And he said to him, I am God that brought thee out of the land of the Chaldeans, so as to give thee this land to inherit.","searchKeywords":["and","said","him","god","that","brought","thee","out","the","land","chaldeans","give","this","inherit"]},{"verseId":"brenton_genesis_15_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":8,"text":"And he said, Master Lord, how shall I know that I shall inherit it?","searchKeywords":["and","said","master","lord","how","shall","know","that","inherit"]},{"verseId":"brenton_genesis_15_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":9,"text":"And he said to him, Take for me an heifer in her third year, and a she-goat in her third year, and a ram in his third year, and a dove and a pigeon.","searchKeywords":["and","said","him","take","for","heifer","her","third","year","she","goat","ram","his","dove","pigeon"]},{"verseId":"brenton_genesis_15_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":10,"text":"So he took to him all these, and divided them in the midst, and set them opposite to each other, but the birds he did not divide.","searchKeywords":["took","him","all","these","and","divided","them","the","midst","set","opposite","each","other","but","birds","did","not","divide"]},{"verseId":"brenton_genesis_15_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":11,"text":"And birds came down upon the bodies, upon the divided parts of them, and Abram sat down by them.","searchKeywords":["and","birds","came","down","upon","the","bodies","divided","parts","them","abram","sat"]},{"verseId":"brenton_genesis_15_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":12,"text":"And about sunset a trance fell upon Abram, and lo! a great gloomy terror falls upon him.","searchKeywords":["and","about","sunset","trance","fell","upon","abram","great","gloomy","terror","falls","him"]},{"verseId":"brenton_genesis_15_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":13,"text":"And it was said to Abram, Thou shalt surely know that thy seed shall be a sojourner in a land not their own, and they shall enslave them, and afflict them, and humble them four hundred years.","searchKeywords":["and","was","said","abram","thou","shalt","surely","know","that","thy","seed","shall","sojourner","land","not","their","own","they","enslave","them","afflict","humble","four","hundred","years"]},{"verseId":"brenton_genesis_15_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":14,"text":"And the nation whomsoever they shall serve I will judge; and after this, they shall come forth hither with much property.","searchKeywords":["and","the","nation","whomsoever","they","shall","serve","will","judge","after","this","come","forth","hither","with","much","property"]},{"verseId":"brenton_genesis_15_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":15,"text":"But thou shalt depart to thy fathers in peace, nourished in a good old age.","searchKeywords":["but","thou","shalt","depart","thy","fathers","peace","nourished","good","old","age"]},{"verseId":"brenton_genesis_15_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":16,"text":"And in the fourth generation they shall return hither, for the sins of the Amorites are not yet filled up, even until now.","searchKeywords":["and","the","fourth","generation","they","shall","return","hither","for","sins","amorites","are","not","yet","filled","even","until","now"]},{"verseId":"brenton_genesis_15_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":17,"text":"And when the sun was about to set, there was a flame, and behold a smoking furnace and lamps of fire, which passed between these divided pieces.","searchKeywords":["and","when","the","sun","was","about","set","there","flame","behold","smoking","furnace","lamps","fire","which","passed","between","these","divided","pieces"]},{"verseId":"brenton_genesis_15_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":18,"text":"In that day the Lord made a covenant with Abram, saying, To thy seed I will give this land, from the river of Egypt to the great river Euphrates.","searchKeywords":["that","day","the","lord","made","covenant","with","abram","saying","thy","seed","will","give","this","land","from","river","egypt","great","euphrates"]},{"verseId":"brenton_genesis_15_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":19,"text":"The Kenites, and the Kenezites, and the Kedmoneans,","searchKeywords":["the","kenites","and","kenezites","kedmoneans"]},{"verseId":"brenton_genesis_15_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":20,"text":"and the Chettites, and the Pherezites, and the Raphaim,","searchKeywords":["and","the","chettites","pherezites","raphaim"]},{"verseId":"brenton_genesis_15_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":15,"verse":21,"text":"and the Amorites, and the Chananites, and the Evites, and the Gergesites, and the Jebusites.","searchKeywords":["and","the","amorites","chananites","evites","gergesites","jebusites"]}]