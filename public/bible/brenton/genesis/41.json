[{"verseId":"brenton_genesis_41_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":1,"text":"And it came to pass after two full years that Pharao had a dream. He thought he stood upon the river.","searchKeywords":["and","came","pass","after","two","full","years","that","pharao","had","dream","thought","stood","upon","the","river"]},{"verseId":"brenton_genesis_41_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":2,"text":"And lo, there came up as it were out of the river seven cows, fair in appearance, and choice of flesh, and they fed on the sedge.","searchKeywords":["and","there","came","were","out","the","river","seven","cows","fair","appearance","choice","flesh","they","fed","sedge"]},{"verseId":"brenton_genesis_41_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":3,"text":"And other seven cows came up after these out of the river, ill-favoured and lean-fleshed, and fed by the cows on the bank of the river.","searchKeywords":["and","other","seven","cows","came","after","these","out","the","river","ill","favoured","lean","fleshed","fed","bank"]},{"verseId":"brenton_genesis_41_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":4,"text":"And the seven ill-favoured and lean cows devoured the seven well-favoured and choice-fleshed cows; and Pharao awoke.","searchKeywords":["and","the","seven","ill","favoured","lean","cows","devoured","well","choice","fleshed","pharao","awoke"]},{"verseId":"brenton_genesis_41_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":5,"text":"And he dreamed again. And, behold, seven ears came up on one stalk, choice and good.","searchKeywords":["and","dreamed","again","behold","seven","ears","came","one","stalk","choice","good"]},{"verseId":"brenton_genesis_41_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":6,"text":"And, behold, seven ears thin and blasted with the wind, grew up after them.","searchKeywords":["and","behold","seven","ears","thin","blasted","with","the","wind","grew","after","them"]},{"verseId":"brenton_genesis_41_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":7,"text":"And the seven thin ears and blasted with the wind devoured the seven choice and full ears; and Pharao awoke, and it was a dream.","searchKeywords":["and","the","seven","thin","ears","blasted","with","wind","devoured","choice","full","pharao","awoke","was","dream"]},{"verseId":"brenton_genesis_41_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":8,"text":"And it was morning, and his soul was troubled; and he sent and called all the interpreters of Egypt, and all her wise men; and Pharao related to them his dream, and there was no one to interpret it to Pharao.","searchKeywords":["and","was","morning","his","soul","troubled","sent","called","all","the","interpreters","egypt","her","wise","men","pharao","related","them","dream","there","one","interpret"]},{"verseId":"brenton_genesis_41_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":9,"text":"And the chief cupbearer spoke to Pharao, saying, I this day remember my fault:","searchKeywords":["and","the","chief","cupbearer","spoke","pharao","saying","this","day","remember","fault"]},{"verseId":"brenton_genesis_41_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":10,"text":"Pharao was angry with his servants, and put us in prison in the house of the captain of the guard, both me and the chief baker.","searchKeywords":["pharao","was","angry","with","his","servants","and","put","prison","the","house","captain","guard","both","chief","baker"]},{"verseId":"brenton_genesis_41_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":11,"text":"And we had a dream both in one night, I and he; we saw, each according to his dream.","searchKeywords":["and","had","dream","both","one","night","saw","each","according","his"]},{"verseId":"brenton_genesis_41_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":12,"text":"And there was there with us a young man, a Hebrew servant of the captain of the guard; and we related to him , and he interpreted to us.","searchKeywords":["and","there","was","with","young","man","hebrew","servant","the","captain","guard","related","him","interpreted"]},{"verseId":"brenton_genesis_41_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":13,"text":"And it came to pass, as he interpreted them to us, so also it happened, both that I was restored to my office, and that he was hanged.","searchKeywords":["and","came","pass","interpreted","them","also","happened","both","that","was","restored","office","hanged"]},{"verseId":"brenton_genesis_41_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":14,"text":"And Pharao having sent, called Joseph; and they brought him out from the prison, and shaved him, and changed his dress, and he came to Pharao.","searchKeywords":["and","pharao","having","sent","called","joseph","they","brought","him","out","from","the","prison","shaved","changed","his","dress","came"]},{"verseId":"brenton_genesis_41_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":15,"text":"And Pharao said to Joseph, I have seen a vision, and there is no one to interpret it; but I have heard say concerning thee that thou didst hear dreams and interpret them.","searchKeywords":["and","pharao","said","joseph","have","seen","vision","there","one","interpret","but","heard","say","concerning","thee","that","thou","didst","hear","dreams","them"]},{"verseId":"brenton_genesis_41_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":16,"text":"And Joseph answered Pharao and said, Without God an answer of safety shall not be given to Pharao.","searchKeywords":["and","joseph","answered","pharao","said","without","god","answer","safety","shall","not","given"]},{"verseId":"brenton_genesis_41_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":17,"text":"And Pharao spoke to Joseph, saying, In my dream methought I stood by the bank of the river;","searchKeywords":["and","pharao","spoke","joseph","saying","dream","methought","stood","the","bank","river"]},{"verseId":"brenton_genesis_41_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":18,"text":"and there came up as it were out of the river, seven cows well-favoured and choice-fleshed, and they fed on the sedge.","searchKeywords":["and","there","came","were","out","the","river","seven","cows","well","favoured","choice","fleshed","they","fed","sedge"]},{"verseId":"brenton_genesis_41_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":19,"text":"And behold seven other cows came up after them out of the river, evil and ill-favoured and lean-fleshed, such that I never saw worse in all the land of Egypt.","searchKeywords":["and","behold","seven","other","cows","came","after","them","out","the","river","evil","ill","favoured","lean","fleshed","such","that","never","saw","worse","all","land","egypt"]},{"verseId":"brenton_genesis_41_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":20,"text":"And the seven ill-favoured and thin cows ate up the seven first good and choice cows.","searchKeywords":["and","the","seven","ill","favoured","thin","cows","ate","first","good","choice"]},{"verseId":"brenton_genesis_41_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":21,"text":"And they went into their bellies; and it was not perceptible that they had gone into their bellies, and their appearance was ill-favoured, as also at the beginning; and after I awoke I slept,","searchKeywords":["and","they","went","into","their","bellies","was","not","perceptible","that","had","gone","appearance","ill","favoured","also","the","beginning","after","awoke","slept"]},{"verseId":"brenton_genesis_41_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":22,"text":"and saw again in my sleep, and as it were seven ears came up on one stem, full and good.","searchKeywords":["and","saw","again","sleep","were","seven","ears","came","one","stem","full","good"]},{"verseId":"brenton_genesis_41_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":23,"text":"And other seven ears, thin and blasted with the wind, sprang up close to them.","searchKeywords":["and","other","seven","ears","thin","blasted","with","the","wind","sprang","close","them"]},{"verseId":"brenton_genesis_41_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":24,"text":"And the seven thin and blasted ears devoured the seven fine and full ears: so I spoke to the interpreters, and there was no one to explain it to me.","searchKeywords":["and","the","seven","thin","blasted","ears","devoured","fine","full","spoke","interpreters","there","was","one","explain"]},{"verseId":"brenton_genesis_41_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":25,"text":"And Joseph said to Pharao, The dream of Pharao is one; whatever God does, he has shewn to Pharao.","searchKeywords":["and","joseph","said","pharao","the","dream","one","whatever","god","does","has","shewn"]},{"verseId":"brenton_genesis_41_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":26,"text":"The seven good cows are seven years, and the seven good ears are seven years; the dream of Pharao is one.","searchKeywords":["the","seven","good","cows","are","years","and","ears","dream","pharao","one"]},{"verseId":"brenton_genesis_41_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":27,"text":"And the seven thin kine that came up after them are seven years; and the seven thin and blasted ears are seven years; there shall be seven years of famine.","searchKeywords":["and","the","seven","thin","kine","that","came","after","them","are","years","blasted","ears","there","shall","famine"]},{"verseId":"brenton_genesis_41_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":28,"text":"And as for the word which I have told Pharao, whatsoever God intends to do, he has shewn to Pharao:","searchKeywords":["and","for","the","word","which","have","told","pharao","whatsoever","god","intends","has","shewn"]},{"verseId":"brenton_genesis_41_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":29,"text":"behold, for seven years there is coming great plenty in all the land of Egypt.","searchKeywords":["behold","for","seven","years","there","coming","great","plenty","all","the","land","egypt"]},{"verseId":"brenton_genesis_41_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":30,"text":"But there shall come seven years of famine after these, and they shall forget the plenty that shall be in all Egypt, and the famine shall consume the land.","searchKeywords":["but","there","shall","come","seven","years","famine","after","these","and","they","forget","the","plenty","that","all","egypt","consume","land"]},{"verseId":"brenton_genesis_41_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":31,"text":"And the plenty shall not be known in the land by reason of the famine that shall be after this, for it shall be very grievous.","searchKeywords":["and","the","plenty","shall","not","known","land","reason","famine","that","after","this","for","very","grievous"]},{"verseId":"brenton_genesis_41_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":32,"text":"And concerning the repetition of the dream to Pharao twice, because the saying which is from God shall be true, and God will hasten to accomplish it.","searchKeywords":["and","concerning","the","repetition","dream","pharao","twice","because","saying","which","from","god","shall","true","will","hasten","accomplish"]},{"verseId":"brenton_genesis_41_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":33,"text":"Now then, look out a wise and prudent man, and set him over the land of Egypt.","searchKeywords":["now","then","look","out","wise","and","prudent","man","set","him","over","the","land","egypt"]},{"verseId":"brenton_genesis_41_34","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":34,"text":"And let Pharao make and appoint local governors over the land; and let them take up a fifth part of all the produce of the land of Egypt for the seven years of the plenty.","searchKeywords":["and","let","pharao","make","appoint","local","governors","over","the","land","them","take","fifth","part","all","produce","egypt","for","seven","years","plenty"]},{"verseId":"brenton_genesis_41_35","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":35,"text":"And let them gather all the food of these seven good years that are coming, and let the corn be gathered under the hand of Pharao; let food be kept in the cities.","searchKeywords":["and","let","them","gather","all","the","food","these","seven","good","years","that","are","coming","corn","gathered","under","hand","pharao","kept","cities"]},{"verseId":"brenton_genesis_41_36","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":36,"text":"And the stored food shall be for the land against the seven years of famine, which shall be in the land of Egypt; and the land shall not be utterly destroyed by the famine.","searchKeywords":["and","the","stored","food","shall","for","land","against","seven","years","famine","which","egypt","not","utterly","destroyed"]},{"verseId":"brenton_genesis_41_37","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":37,"text":"And the word was pleasing in the sight of Pharao, and in the sight of all his servants.","searchKeywords":["and","the","word","was","pleasing","sight","pharao","all","his","servants"]},{"verseId":"brenton_genesis_41_38","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":38,"text":"And Pharao said to all his servants, Shall we find such a man as this, who has the Spirit of God in him?","searchKeywords":["and","pharao","said","all","his","servants","shall","find","such","man","this","who","has","the","spirit","god","him"]},{"verseId":"brenton_genesis_41_39","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":39,"text":"And Pharao said to Joseph, Since God has shewed thee all these things, there is not a wiser or more prudent man than thou.","searchKeywords":["and","pharao","said","joseph","since","god","has","shewed","thee","all","these","things","there","not","wiser","more","prudent","man","than","thou"]},{"verseId":"brenton_genesis_41_40","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":40,"text":"Thou shalt be over my house, and all my people shall be obedient to thy word; only in the throne will I excel thee.","searchKeywords":["thou","shalt","over","house","and","all","people","shall","obedient","thy","word","only","the","throne","will","excel","thee"]},{"verseId":"brenton_genesis_41_41","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":41,"text":"And Pharao said to Joseph, Behold, I set thee this day over all the land of Egypt.","searchKeywords":["and","pharao","said","joseph","behold","set","thee","this","day","over","all","the","land","egypt"]},{"verseId":"brenton_genesis_41_42","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":42,"text":"And Pharao took his ring off his hand, and put it on the hand of Joseph, and put on him a robe of fine linen, and put a necklace of gold about his neck.","searchKeywords":["and","pharao","took","his","ring","off","hand","put","the","joseph","him","robe","fine","linen","necklace","gold","about","neck"]},{"verseId":"brenton_genesis_41_43","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":43,"text":"And he mounted him on the second of his chariots, and a herald made proclamation before him; and he set him over all the land of Egypt.","searchKeywords":["and","mounted","him","the","second","his","chariots","herald","made","proclamation","before","set","over","all","land","egypt"]},{"verseId":"brenton_genesis_41_44","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":44,"text":"And Pharao said to Joseph, I am Pharao; without thee no one shall lift up his hand on all the land of Egypt.","searchKeywords":["and","pharao","said","joseph","without","thee","one","shall","lift","his","hand","all","the","land","egypt"]},{"verseId":"brenton_genesis_41_45","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":45,"text":"And Pharao called the name of Joseph, Psonthomphanech; and he gave him Aseneth, the daughter of Petephres, priest of Heliopolis, to wife.","searchKeywords":["and","pharao","called","the","name","joseph","psonthomphanech","gave","him","aseneth","daughter","petephres","priest","heliopolis","wife"]},{"verseId":"brenton_genesis_41_46","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":46,"text":"And Joseph was thirty years old when he stood before Pharao, king of Egypt. And Joseph went out from the presence of Pharao, and went through all the land of Egypt.","searchKeywords":["and","joseph","was","thirty","years","old","when","stood","before","pharao","king","egypt","went","out","from","the","presence","through","all","land"]},{"verseId":"brenton_genesis_41_47","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":47,"text":"And the land produced, in the seven years of plenty, handfuls .","searchKeywords":["and","the","land","produced","seven","years","plenty","handfuls"]},{"verseId":"brenton_genesis_41_48","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":48,"text":"And he gathered all the food of the seven years, in which was the plenty in the land of Egypt; and he laid up the food in the cities; the food of the fields of a city round about it he laid up in it.","searchKeywords":["and","gathered","all","the","food","seven","years","which","was","plenty","land","egypt","laid","cities","fields","city","round","about"]},{"verseId":"brenton_genesis_41_49","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":49,"text":"And Joseph gathered very much corn as the sand of the sea, until it could not be numbered, for there was no number .","searchKeywords":["and","joseph","gathered","very","much","corn","the","sand","sea","until","could","not","numbered","for","there","was","number"]},{"verseId":"brenton_genesis_41_50","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":50,"text":"And to Joseph were born two sons, before the seven years of famine came, which Aseneth, the daughter of Petephres, priest of Heliopolis, bore to him.","searchKeywords":["and","joseph","were","born","two","sons","before","the","seven","years","famine","came","which","aseneth","daughter","petephres","priest","heliopolis","bore","him"]},{"verseId":"brenton_genesis_41_51","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":51,"text":"And Joseph called the name of the first-born, Manasse; for God, , has made me forget all my toils, and all my father's house.","searchKeywords":["and","joseph","called","the","name","first","born","manasse","for","god","has","made","forget","all","toils","father","house"]},{"verseId":"brenton_genesis_41_52","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":52,"text":"And he called the name of the second, Ephraim; for God, , has increased me in the land of my humiliation.","searchKeywords":["and","called","the","name","second","ephraim","for","god","has","increased","land","humiliation"]},{"verseId":"brenton_genesis_41_53","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":53,"text":"And the seven years of plenty passed away, which were in the land of Egypt.","searchKeywords":["and","the","seven","years","plenty","passed","away","which","were","land","egypt"]},{"verseId":"brenton_genesis_41_54","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":54,"text":"And the seven years of famine began to come, as Joseph said; and there was a famine in all the land; but in all the land of Egypt there was bread.","searchKeywords":["and","the","seven","years","famine","began","come","joseph","said","there","was","all","land","but","egypt","bread"]},{"verseId":"brenton_genesis_41_55","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":55,"text":"And all the land of Egypt was hungry; and the people cried to Pharao for bread. And Pharao said to all the Egyptians, Go to Joseph, and do whatsoever he shall tell you.","searchKeywords":["and","all","the","land","egypt","was","hungry","people","cried","pharao","for","bread","said","egyptians","joseph","whatsoever","shall","tell","you"]},{"verseId":"brenton_genesis_41_56","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":56,"text":"And the famine was on the face of all the earth; and Joseph opened all the granaries, and sold to all the Egyptians.","searchKeywords":["and","the","famine","was","face","all","earth","joseph","opened","granaries","sold","egyptians"]},{"verseId":"brenton_genesis_41_57","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":41,"verse":57,"text":"And all countries came to Egypt to buy of Joseph, for the famine prevailed in all the earth.","searchKeywords":["and","all","countries","came","egypt","buy","joseph","for","the","famine","prevailed","earth"]}]