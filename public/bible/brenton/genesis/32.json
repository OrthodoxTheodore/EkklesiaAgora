[{"verseId":"brenton_genesis_32_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":1,"text":"And Laban rose up in the morning, and kissed his sons and his daughters, and blessed them; and Laban having turned back, departed to his place.","searchKeywords":["and","laban","rose","the","morning","kissed","his","sons","daughters","blessed","them","having","turned","back","departed","place"]},{"verseId":"brenton_genesis_32_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":2,"text":"And Jacob departed for his journey; and having looked up, he saw the host of God encamped; and the angels of God met him.","searchKeywords":["and","jacob","departed","for","his","journey","having","looked","saw","the","host","god","encamped","angels","met","him"]},{"verseId":"brenton_genesis_32_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":3,"text":"And Jacob said, when he saw them, This is the Camp of God; and he called the name of that place, Encampments.","searchKeywords":["and","jacob","said","when","saw","them","this","the","camp","god","called","name","that","place","encampments"]},{"verseId":"brenton_genesis_32_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":4,"text":"And Jacob sent messengers before him to Esau his brother to the land of Seir, to the country of Edom.","searchKeywords":["and","jacob","sent","messengers","before","him","esau","his","brother","the","land","seir","country","edom"]},{"verseId":"brenton_genesis_32_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":5,"text":"And he charged them, saying, Thus shall ye say to my lord Esau: Thus saith thy servant Jacob; I have sojourned with Laban and tarried until now.","searchKeywords":["and","charged","them","saying","thus","shall","say","lord","esau","saith","thy","servant","jacob","have","sojourned","with","laban","tarried","until","now"]},{"verseId":"brenton_genesis_32_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":6,"text":"And there were born to me oxen, and asses, and sheep, and men-servants and women-servants; and I sent to tell my lord Esau, that thy servant might find grace in thy sight.","searchKeywords":["and","there","were","born","oxen","asses","sheep","men","servants","women","sent","tell","lord","esau","that","thy","servant","might","find","grace","sight"]},{"verseId":"brenton_genesis_32_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":7,"text":"And the messengers returned to Jacob, saying, We came to thy brother Esau, and lo! he comes to meet thee, and four hundred men with him.","searchKeywords":["and","the","messengers","returned","jacob","saying","came","thy","brother","esau","comes","meet","thee","four","hundred","men","with","him"]},{"verseId":"brenton_genesis_32_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":8,"text":"And Jacob was greatly terrified, and was perplexed; and he divided the people that was with him, and the cows, and the camels, and the sheep, into two camps.","searchKeywords":["and","jacob","was","greatly","terrified","perplexed","divided","the","people","that","with","him","cows","camels","sheep","into","two","camps"]},{"verseId":"brenton_genesis_32_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":9,"text":"And Jacob said, If Esau should come to one camp, and smite it, the other camp shall be in safety.","searchKeywords":["and","jacob","said","esau","should","come","one","camp","smite","the","other","shall","safety"]},{"verseId":"brenton_genesis_32_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":10,"text":"And Jacob said, God of my father Abraam, and God of my father Isaac, O Lord, thou he that said to me, Depart quickly to the land of thy birth, and I will do thee good.","searchKeywords":["and","jacob","said","god","father","abraam","isaac","lord","thou","that","depart","quickly","the","land","thy","birth","will","thee","good"]},{"verseId":"brenton_genesis_32_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":11,"text":"Let there be to me a sufficiency of all the justice and all the truth which thou hast wrought with thy servant; for with this my staff I passed over this Jordan, and now I am become two camps.","searchKeywords":["let","there","sufficiency","all","the","justice","and","truth","which","thou","hast","wrought","with","thy","servant","for","this","staff","passed","over","jordan","now","become","two","camps"]},{"verseId":"brenton_genesis_32_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":12,"text":"Deliver me from the hand of my brother, from the hand of Esau, for I am afraid of him, lest haply he should come and smite me, and the mother upon the children.","searchKeywords":["deliver","from","the","hand","brother","esau","for","afraid","him","lest","haply","should","come","and","smite","mother","upon","children"]},{"verseId":"brenton_genesis_32_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":13,"text":"But thou saidst, I will do thee good, and will make thy seed as the sand of the sea, which shall not be numbered for multitude.","searchKeywords":["but","thou","saidst","will","thee","good","and","make","thy","seed","the","sand","sea","which","shall","not","numbered","for","multitude"]},{"verseId":"brenton_genesis_32_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":14,"text":"And he slept there that night, and took of the gifts which he carried , and sent out to Esau his brother,","searchKeywords":["and","slept","there","that","night","took","the","gifts","which","carried","sent","out","esau","his","brother"]},{"verseId":"brenton_genesis_32_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":15,"text":"two hundred she-goats, twenty he-goats, two hundred sheep, twenty rams,","searchKeywords":["two","hundred","she","goats","twenty","sheep","rams"]},{"verseId":"brenton_genesis_32_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":16,"text":"milch camels, and their foals, thirty, forty kine, ten bulls, twenty asses, and ten colts.","searchKeywords":["milch","camels","and","their","foals","thirty","forty","kine","ten","bulls","twenty","asses","colts"]},{"verseId":"brenton_genesis_32_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":17,"text":"And he gave them to his servants drove apart; and he said to his servants, Go on before me, and put a space between drove and drove.","searchKeywords":["and","gave","them","his","servants","drove","apart","said","before","put","space","between"]},{"verseId":"brenton_genesis_32_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":18,"text":"And he charged the first, saying, If Esau my brother meet thee, and he ask thee, saying, Whose art thou? and whither wouldest thou go, and whose are these possessions advancing before thee?","searchKeywords":["and","charged","the","first","saying","esau","brother","meet","thee","ask","whose","art","thou","whither","wouldest","are","these","possessions","advancing","before"]},{"verseId":"brenton_genesis_32_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":19,"text":"Thou shalt say, Thy servant Jacob's; he hath sent gifts to my lord Esau, and lo! he is behind us.","searchKeywords":["thou","shalt","say","thy","servant","jacob","hath","sent","gifts","lord","esau","and","behind"]},{"verseId":"brenton_genesis_32_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":20,"text":"And he charged the first and the second and the third, and all that went before him after these flocks, saying, Thus shall ye speak to Esau when ye find him;","searchKeywords":["and","charged","the","first","second","third","all","that","went","before","him","after","these","flocks","saying","thus","shall","speak","esau","when","find"]},{"verseId":"brenton_genesis_32_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":21,"text":"and ye shall say, Behold thy servant Jacob comes after us. For he said, I will propitiate his countenance with the gifts going before his presence, and afterwards I will behold his face, for peradventure he will accept me.","searchKeywords":["and","shall","say","behold","thy","servant","jacob","comes","after","for","said","will","propitiate","his","countenance","with","the","gifts","going","before","presence","afterwards","face","peradventure","accept"]},{"verseId":"brenton_genesis_32_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":22,"text":"So the presents went on before him, but he himself lodged that night in the camp.","searchKeywords":["the","presents","went","before","him","but","himself","lodged","that","night","camp"]},{"verseId":"brenton_genesis_32_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":23,"text":"And he rose up in that night, and took his two wives and his two servant-maids, and his eleven children, and crossed over the ford of Jaboch.","searchKeywords":["and","rose","that","night","took","his","two","wives","servant","maids","eleven","children","crossed","over","the","ford","jaboch"]},{"verseId":"brenton_genesis_32_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":24,"text":"And he took them, and passed over the torrent, and brought over all his possessions.","searchKeywords":["and","took","them","passed","over","the","torrent","brought","all","his","possessions"]},{"verseId":"brenton_genesis_32_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":25,"text":"And Jacob was left alone; and a man wrestled with him till the morning.","searchKeywords":["and","jacob","was","left","alone","man","wrestled","with","him","till","the","morning"]},{"verseId":"brenton_genesis_32_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":26,"text":"And he saw that he prevailed not against him; and he touched the broad part of his thigh, and the broad part of Jacob's thigh was benumbed in his wrestling with him.","searchKeywords":["and","saw","that","prevailed","not","against","him","touched","the","broad","part","his","thigh","jacob","was","benumbed","wrestling","with"]},{"verseId":"brenton_genesis_32_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":27,"text":"And he said to him, Let me go, for the day has dawned; but he said, I will not let thee go, except thou bless me.","searchKeywords":["and","said","him","let","for","the","day","has","dawned","but","will","not","thee","except","thou","bless"]},{"verseId":"brenton_genesis_32_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":28,"text":"And he said to him, What is thy name? and he answered, Jacob.","searchKeywords":["and","said","him","what","thy","name","answered","jacob"]},{"verseId":"brenton_genesis_32_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":29,"text":"And he said to him, Thy name shall no longer be called Jacob, but Israel shall be thy name; for thou hast prevailed with God, and shalt be mighty with men.","searchKeywords":["and","said","him","thy","name","shall","longer","called","jacob","but","israel","for","thou","hast","prevailed","with","god","shalt","mighty","men"]},{"verseId":"brenton_genesis_32_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":30,"text":"And Jacob asked and said, Tell me thy name; and he said, Wherefore dost thou ask after my name? and he blessed him there.","searchKeywords":["and","jacob","asked","said","tell","thy","name","wherefore","dost","thou","ask","after","blessed","him","there"]},{"verseId":"brenton_genesis_32_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":31,"text":"And Jacob called the name of that place, the Face of God; for, , I have seen God face to face, and my life was preserved.","searchKeywords":["and","jacob","called","the","name","that","place","face","god","for","have","seen","life","was","preserved"]},{"verseId":"brenton_genesis_32_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":32,"text":"And the sun rose upon him, when he passed the Face of God; and he halted upon his thigh.","searchKeywords":["and","the","sun","rose","upon","him","when","passed","face","god","halted","his","thigh"]},{"verseId":"brenton_genesis_32_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":32,"verse":33,"text":"Therefore the children of Israel will by no means eat of the sinew which was benumbed, which is on the broad part of the thigh, until this day, because touched the broad part of the thigh of Jacob— the sinew which was benumbed.","searchKeywords":["therefore","the","children","israel","will","means","eat","sinew","which","was","benumbed","broad","part","thigh","until","this","day","because","touched","jacob"]}]