[{"verseId":"brenton_genesis_42_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":1,"text":"And Jacob having seen that there was a sale in Egypt, said to his sons, Why are ye indolent?","searchKeywords":["and","jacob","having","seen","that","there","was","sale","egypt","said","his","sons","why","are","indolent"]},{"verseId":"brenton_genesis_42_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":2,"text":"Behold, I have heard that there is corn in Egypt; go down thither, and buy for us a little food, that we may live, and not die.","searchKeywords":["behold","have","heard","that","there","corn","egypt","down","thither","and","buy","for","little","food","may","live","not","die"]},{"verseId":"brenton_genesis_42_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":3,"text":"And the ten brethren of Joseph went down to buy corn out of Egypt.","searchKeywords":["and","the","ten","brethren","joseph","went","down","buy","corn","out","egypt"]},{"verseId":"brenton_genesis_42_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":4,"text":"But sent not Benjamin, the brother of Joseph, with his brethren; for he said, Lest, haply, disease befal him.","searchKeywords":["but","sent","not","benjamin","the","brother","joseph","with","his","brethren","for","said","lest","haply","disease","befal","him"]},{"verseId":"brenton_genesis_42_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":5,"text":"And the sons of Israel came to buy with those that came, for the famine was in the land of Chanaan.","searchKeywords":["and","the","sons","israel","came","buy","with","those","that","for","famine","was","land","chanaan"]},{"verseId":"brenton_genesis_42_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":6,"text":"And Joseph was ruler of the land; he sold to all the people of the land. And the brethren of Joseph, having come, did reverence to him, with the face to the ground.","searchKeywords":["and","joseph","was","ruler","the","land","sold","all","people","brethren","having","come","did","reverence","him","with","face","ground"]},{"verseId":"brenton_genesis_42_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":7,"text":"And when Joseph saw his brethren, he knew them, and estranged himself from them, and spoke hard words to them; and said to them, Whence are ye come? And they said, Out of the land of Chanaan, to buy food.","searchKeywords":["and","when","joseph","saw","his","brethren","knew","them","estranged","himself","from","spoke","hard","words","said","whence","are","come","they","out","the","land","chanaan","buy","food"]},{"verseId":"brenton_genesis_42_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":8,"text":"And Joseph knew his brethren, but they knew not him.","searchKeywords":["and","joseph","knew","his","brethren","but","they","not","him"]},{"verseId":"brenton_genesis_42_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":9,"text":"And Joseph remembered his dream, which he saw; and he said to them, Ye are spies; to observe the marks of the land are ye come.","searchKeywords":["and","joseph","remembered","his","dream","which","saw","said","them","are","spies","observe","the","marks","land","come"]},{"verseId":"brenton_genesis_42_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":10,"text":"But they said, Nay, Sir, we thy servants are come to buy food;","searchKeywords":["but","they","said","nay","sir","thy","servants","are","come","buy","food"]},{"verseId":"brenton_genesis_42_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":11,"text":"we are all sons of one man; we are peaceable, thy servants are not spies.","searchKeywords":["are","all","sons","one","man","peaceable","thy","servants","not","spies"]},{"verseId":"brenton_genesis_42_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":12,"text":"And he said to them, Nay, but ye are come to observe the marks of the land.","searchKeywords":["and","said","them","nay","but","are","come","observe","the","marks","land"]},{"verseId":"brenton_genesis_42_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":13,"text":"And they said, We thy servants are twelve brethren, in the land of Chanaan; and, behold, the youngest is with our father to-day, but the other one is not.","searchKeywords":["and","they","said","thy","servants","are","twelve","brethren","the","land","chanaan","behold","youngest","with","our","father","day","but","other","one","not"]},{"verseId":"brenton_genesis_42_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":14,"text":"And Joseph said to them, This is it that I spoke to you, saying, ye are spies;","searchKeywords":["and","joseph","said","them","this","that","spoke","you","saying","are","spies"]},{"verseId":"brenton_genesis_42_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":15,"text":"herein shall ye be manifested; by the health of Pharao, ye shall not depart hence, unless your younger brother come hither.","searchKeywords":["herein","shall","manifested","the","health","pharao","not","depart","hence","unless","your","younger","brother","come","hither"]},{"verseId":"brenton_genesis_42_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":16,"text":"Send one of you, and take your brother; and go ye to prison, till your words be clear, whether ye speak the truth or not; but, if not, by the health of Pharao, verily ye are spies.","searchKeywords":["send","one","you","and","take","your","brother","prison","till","words","clear","whether","speak","the","truth","not","but","health","pharao","verily","are","spies"]},{"verseId":"brenton_genesis_42_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":17,"text":"And he put them in prison three days.","searchKeywords":["and","put","them","prison","three","days"]},{"verseId":"brenton_genesis_42_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":18,"text":"And he said to them on the third day, This do, and ye shall live, for I fear God.","searchKeywords":["and","said","them","the","third","day","this","shall","live","for","fear","god"]},{"verseId":"brenton_genesis_42_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":19,"text":"If ye be peaceable, let one of your brethren be detained in prison; but go ye, and carry back the corn ye have purchased.","searchKeywords":["peaceable","let","one","your","brethren","detained","prison","but","and","carry","back","the","corn","have","purchased"]},{"verseId":"brenton_genesis_42_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":20,"text":"And bring your younger brother to me, and your words shall be believed; but, if not, ye shall die. And they did so.","searchKeywords":["and","bring","your","younger","brother","words","shall","believed","but","not","die","they","did"]},{"verseId":"brenton_genesis_42_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":21,"text":"And each said to his brother, Yes, indeed, for we are in fault concerning our brother, when we disregarded the anguish of his soul, when he besought us, and we hearkened not to him; and therefore has this affliction come upon us.","searchKeywords":["and","each","said","his","brother","yes","indeed","for","are","fault","concerning","our","when","disregarded","the","anguish","soul","besought","hearkened","not","him","therefore","has","this","affliction","come","upon"]},{"verseId":"brenton_genesis_42_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":22,"text":"And Ruben answered them, saying, Did I not speak to you, saying, Hurt not the boy, and ye heard me not? and, behold, his blood is required.","searchKeywords":["and","ruben","answered","them","saying","did","not","speak","you","hurt","the","boy","heard","behold","his","blood","required"]},{"verseId":"brenton_genesis_42_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":23,"text":"But they knew not that Joseph understood them; for there was an interpreter between them.","searchKeywords":["but","they","knew","not","that","joseph","understood","them","for","there","was","interpreter","between"]},{"verseId":"brenton_genesis_42_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":24,"text":"And Joseph turned away from them, and wept; and again he came to them, and spoke to them; and he took Symeon from them, and bound him before their eyes.","searchKeywords":["and","joseph","turned","away","from","them","wept","again","came","spoke","took","symeon","bound","him","before","their","eyes"]},{"verseId":"brenton_genesis_42_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":25,"text":"And Joseph gave orders to fill their vessels with corn, and to return their money to each into his sack, and to give them provision for the way; and it was so done to them.","searchKeywords":["and","joseph","gave","orders","fill","their","vessels","with","corn","return","money","each","into","his","sack","give","them","provision","for","the","way","was","done"]},{"verseId":"brenton_genesis_42_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":26,"text":"And having put the corn on the asses, they departed thence.","searchKeywords":["and","having","put","the","corn","asses","they","departed","thence"]},{"verseId":"brenton_genesis_42_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":27,"text":"And one having opened his sack to give his asses fodder, at the place where they rested, saw also his bundle of money, for it was on the mouth of his sack.","searchKeywords":["and","one","having","opened","his","sack","give","asses","fodder","the","place","where","they","rested","saw","also","bundle","money","for","was","mouth"]},{"verseId":"brenton_genesis_42_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":28,"text":"And he said to his brethren, My money has been restored to me, and behold this is in my sack. And their heart was wonder-struck, and they were troubled, saying one to another, What is this that God has done to us?","searchKeywords":["and","said","his","brethren","money","has","been","restored","behold","this","sack","their","heart","was","wonder","struck","they","were","troubled","saying","one","another","what","that","god","done"]},{"verseId":"brenton_genesis_42_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":29,"text":"And they came to their father, Jacob, into the land of Chanaan, and reported to him all that had happened to them, saying,","searchKeywords":["and","they","came","their","father","jacob","into","the","land","chanaan","reported","him","all","that","had","happened","them","saying"]},{"verseId":"brenton_genesis_42_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":30,"text":"The man, the lord of the land, spoke harsh words to us, and put us in prison as spies of the land.","searchKeywords":["the","man","lord","land","spoke","harsh","words","and","put","prison","spies"]},{"verseId":"brenton_genesis_42_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":31,"text":"And we said to him, We are men of peace, we are not spies.","searchKeywords":["and","said","him","are","men","peace","not","spies"]},{"verseId":"brenton_genesis_42_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":32,"text":"We are twelve brethren, sons of our father; one is not, and the youngest is with his father to-day in the land of Chanaan.","searchKeywords":["are","twelve","brethren","sons","our","father","one","not","and","the","youngest","with","his","day","land","chanaan"]},{"verseId":"brenton_genesis_42_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":33,"text":"And the man, the lord of the land, said to us, Herein shall I know that ye are peaceable; leave one brother here with me, and having taken the corn ye have purchased for your family, depart.","searchKeywords":["and","the","man","lord","land","said","herein","shall","know","that","are","peaceable","leave","one","brother","here","with","having","taken","corn","have","purchased","for","your","family","depart"]},{"verseId":"brenton_genesis_42_34","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":34,"text":"And bring to me your younger brother; then I shall know that ye are not spies, but that ye are men of peace: and I will restore you your brother, and ye shall trade in the land.","searchKeywords":["and","bring","your","younger","brother","then","shall","know","that","are","not","spies","but","men","peace","will","restore","you","trade","the","land"]},{"verseId":"brenton_genesis_42_35","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":35,"text":"And it came to pass as they were emptying their sacks, there was each man's bundle of money in his sack; and they and their father saw their bundles of money, and they were afraid.","searchKeywords":["and","came","pass","they","were","emptying","their","sacks","there","was","each","man","bundle","money","his","sack","father","saw","bundles","afraid"]},{"verseId":"brenton_genesis_42_36","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":36,"text":"And their father Jacob said to them, Ye have bereaved me. Joseph is not, Symeon is not, and will ye take Benjamin? all these things have come upon me.","searchKeywords":["and","their","father","jacob","said","them","have","bereaved","joseph","not","symeon","will","take","benjamin","all","these","things","come","upon"]},{"verseId":"brenton_genesis_42_37","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":37,"text":"And Ruben spoke to his father, saying, Slay my two sons, if I bring him not to thee; give him into my hand, and I will bring him back to thee.","searchKeywords":["and","ruben","spoke","his","father","saying","slay","two","sons","bring","him","not","thee","give","into","hand","will","back"]},{"verseId":"brenton_genesis_42_38","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":42,"verse":38,"text":"But he said, My son shall not go down with you, because his brother is dead, and he only has been left; and it shall come to pass that he is afflicted by the way by which ye go, then ye shall bring down my old age with sorrow to Hades.","searchKeywords":["but","said","son","shall","not","down","with","you","because","his","brother","dead","and","only","has","been","left","come","pass","that","afflicted","the","way","which","then","bring","old","age","sorrow","hades"]}]