[{"verseId":"brenton_genesis_49_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":1,"text":"And Jacob called his sons, and said to them, Assemble yourselves, that I may tell you what shall happen to you in the last days.","searchKeywords":["and","jacob","called","his","sons","said","them","assemble","yourselves","that","may","tell","you","what","shall","happen","the","last","days"]},{"verseId":"brenton_genesis_49_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":2,"text":"Gather yourselves together, and hear me, sons of Jacob; hear Israel, hear your father.","searchKeywords":["gather","yourselves","together","and","hear","sons","jacob","israel","your","father"]},{"verseId":"brenton_genesis_49_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":3,"text":"Ruben, thou my first-born, thou my strength, and the first of my children, hard to be endured, self-willed.","searchKeywords":["ruben","thou","first","born","strength","and","the","children","hard","endured","self","willed"]},{"verseId":"brenton_genesis_49_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":4,"text":"Thou wast insolent like water, burst not forth with violence, for thou wentest up to the bed of thy father; then thou defiledst the couch, whereupon thou wentest up.","searchKeywords":["thou","wast","insolent","like","water","burst","not","forth","with","violence","for","wentest","the","bed","thy","father","then","defiledst","couch","whereupon"]},{"verseId":"brenton_genesis_49_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":5,"text":"Symeon and Levi, brethren, accomplished the injustice of their cutting off.","searchKeywords":["symeon","and","levi","brethren","accomplished","the","injustice","their","cutting","off"]},{"verseId":"brenton_genesis_49_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":6,"text":"Let not my soul come into their counsel, and let not mine inward parts contend in their conspiracy, for in their wrath they slew men, and in their passion they houghed a bull.","searchKeywords":["let","not","soul","come","into","their","counsel","and","mine","inward","parts","contend","conspiracy","for","wrath","they","slew","men","passion","houghed","bull"]},{"verseId":"brenton_genesis_49_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":7,"text":"Cursed be their wrath, for it was wilful, and their anger, for it was cruel: I will divide them in Jacob, and scatter them in Israel.","searchKeywords":["cursed","their","wrath","for","was","wilful","and","anger","cruel","will","divide","them","jacob","scatter","israel"]},{"verseId":"brenton_genesis_49_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":8,"text":"Juda, thy brethren have praised thee, and thy hands shall be on the back of thine enemies; thy father's sons shall do thee reverence.","searchKeywords":["juda","thy","brethren","have","praised","thee","and","hands","shall","the","back","thine","enemies","father","sons","reverence"]},{"verseId":"brenton_genesis_49_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":9,"text":"Juda is a lion's whelp: from the tender plant, my son, thou art gone up, having couched thou liest as a lion, and as a whelp; who shall stir him up?","searchKeywords":["juda","lion","whelp","from","the","tender","plant","son","thou","art","gone","having","couched","liest","and","who","shall","stir","him"]},{"verseId":"brenton_genesis_49_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":10,"text":"A ruler shall not fail from Juda, nor a prince from his loins, until there come the things stored up for him; and he is the expectation of nations.","searchKeywords":["ruler","shall","not","fail","from","juda","nor","prince","his","loins","until","there","come","the","things","stored","for","him","and","expectation","nations"]},{"verseId":"brenton_genesis_49_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":11,"text":"Binding his foal to the vine, and the foal of his ass to the branch , he shall wash his robe in wine, and his garment in the blood of the grape.","searchKeywords":["binding","his","foal","the","vine","and","ass","branch","shall","wash","robe","wine","garment","blood","grape"]},{"verseId":"brenton_genesis_49_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":12,"text":"His eyes shall be more cheering than wine, and his teeth whiter than milk.","searchKeywords":["his","eyes","shall","more","cheering","than","wine","and","teeth","whiter","milk"]},{"verseId":"brenton_genesis_49_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":13,"text":"Zabulon shall dwell on the coast, and he by a haven of ships, and shall extend to Sidon.","searchKeywords":["zabulon","shall","dwell","the","coast","and","haven","ships","extend","sidon"]},{"verseId":"brenton_genesis_49_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":14,"text":"Issachar has desired that which is good; resting between the inheritances.","searchKeywords":["issachar","has","desired","that","which","good","resting","between","the","inheritances"]},{"verseId":"brenton_genesis_49_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":15,"text":"And having seen the resting place that it was good, and the land that it was fertile, he subjected his shoulder to labour, and became a husbandman.","searchKeywords":["and","having","seen","the","resting","place","that","was","good","land","fertile","subjected","his","shoulder","labour","became","husbandman"]},{"verseId":"brenton_genesis_49_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":16,"text":"Dan shall judge his people, as one tribe too in Israel.","searchKeywords":["dan","shall","judge","his","people","one","tribe","too","israel"]},{"verseId":"brenton_genesis_49_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":17,"text":"And let Dan be a serpent in the way, besetting the path, biting the heel of the horse (and the rider shall fall backward),","searchKeywords":["and","let","dan","serpent","the","way","besetting","path","biting","heel","horse","rider","shall","fall","backward"]},{"verseId":"brenton_genesis_49_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":18,"text":"waiting for the salvation of the Lord.","searchKeywords":["waiting","for","the","salvation","lord"]},{"verseId":"brenton_genesis_49_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":19,"text":"Gad, a plundering troop shall plunder him; but he shall plunder him, closely.","searchKeywords":["gad","plundering","troop","shall","plunder","him","but","closely"]},{"verseId":"brenton_genesis_49_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":20,"text":"Aser, his bread fat; and he shall yield dainties to princes.","searchKeywords":["aser","his","bread","fat","and","shall","yield","dainties","princes"]},{"verseId":"brenton_genesis_49_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":21,"text":"Nephthalim is a spreading stem, bestowing beauty on its fruit.","searchKeywords":["nephthalim","spreading","stem","bestowing","beauty","its","fruit"]},{"verseId":"brenton_genesis_49_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":22,"text":"Joseph is a son increased; my dearly loved son is increased; my youngest son, turn to me.","searchKeywords":["joseph","son","increased","dearly","loved","youngest","turn"]},{"verseId":"brenton_genesis_49_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":23,"text":"Against whom men taking evil counsel reproached , and the archers pressed hard upon him.","searchKeywords":["against","whom","men","taking","evil","counsel","reproached","and","the","archers","pressed","hard","upon","him"]},{"verseId":"brenton_genesis_49_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":24,"text":"But their bow and arrows were mightily consumed, and the sinews of their arms were slackened by the hand of the mighty one of Jacob; thence is he that strengthened Israel from the God of thy father;","searchKeywords":["but","their","bow","and","arrows","were","mightily","consumed","the","sinews","arms","slackened","hand","mighty","one","jacob","thence","that","strengthened","israel","from","god","thy","father"]},{"verseId":"brenton_genesis_49_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":25,"text":"and my God helped thee, and he blessed thee with the blessing of heaven from above, and the blessing of the earth possessing all things, because of the blessing of the breasts and of the womb,","searchKeywords":["and","god","helped","thee","blessed","with","the","blessing","heaven","from","above","earth","possessing","all","things","because","breasts","womb"]},{"verseId":"brenton_genesis_49_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":26,"text":"the blessings of thy father and thy mother—it has prevailed above the blessing of the lasting mountains, and beyond the blessings of the everlasting hills; they shall be upon the head of Joseph, and upon the head of the brothers of whom he took the lead.","searchKeywords":["the","blessings","thy","father","and","mother","has","prevailed","above","blessing","lasting","mountains","beyond","everlasting","hills","they","shall","upon","head","joseph","brothers","whom","took","lead"]},{"verseId":"brenton_genesis_49_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":27,"text":"Benjamin, as a ravening wolf, shall eat still in the morning, and at evening he gives food.","searchKeywords":["benjamin","ravening","wolf","shall","eat","still","the","morning","and","evening","gives","food"]},{"verseId":"brenton_genesis_49_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":28,"text":"All these the twelve sons of Jacob; and their father spoke these words to them, and he blessed them; he blessed each of them according to his blessing.","searchKeywords":["all","these","the","twelve","sons","jacob","and","their","father","spoke","words","them","blessed","each","according","his","blessing"]},{"verseId":"brenton_genesis_49_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":29,"text":"And he said to them, I am added to my people; ye shall bury me with my fathers in the cave, which is in the field of Ephron the Chettite,","searchKeywords":["and","said","them","added","people","shall","bury","with","fathers","the","cave","which","field","ephron","chettite"]},{"verseId":"brenton_genesis_49_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":30,"text":"in the double cave which is opposite Mambre, in the land of Chanaan, the cave which Abraam bought of Ephron the Chettite, for a possession of a sepulchre.","searchKeywords":["the","double","cave","which","opposite","mambre","land","chanaan","abraam","bought","ephron","chettite","for","possession","sepulchre"]},{"verseId":"brenton_genesis_49_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":31,"text":"There they buried Abraam and Sarrha his wife; there they buried Isaac, and Rebecca his wife; there they buried Lea;","searchKeywords":["there","they","buried","abraam","and","sarrha","his","wife","isaac","rebecca","lea"]},{"verseId":"brenton_genesis_49_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":32,"text":"in the portion of the field, and of the cave that was in it, of the sons of Chet.","searchKeywords":["the","portion","field","and","cave","that","was","sons","chet"]},{"verseId":"brenton_genesis_49_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":49,"verse":33,"text":"And Jacob ceased giving charges to his sons; and having lifted up his feet on the bed, he died, and was gathered to his people.","searchKeywords":["and","jacob","ceased","giving","charges","his","sons","having","lifted","feet","the","bed","died","was","gathered","people"]}]