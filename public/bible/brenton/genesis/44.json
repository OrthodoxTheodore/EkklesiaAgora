[{"verseId":"brenton_genesis_44_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":1,"text":"And Joseph charged the steward of his house, saying, Fill the men's sacks with food, as much as they can carry, and put the money of each in the mouth of his sack.","searchKeywords":["and","joseph","charged","the","steward","his","house","saying","fill","men","sacks","with","food","much","they","can","carry","put","money","each","mouth","sack"]},{"verseId":"brenton_genesis_44_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":2,"text":"And put my silver cup into the sack of the youngest, and the price of his corn. And it was done according to the word of Joseph, as he said.","searchKeywords":["and","put","silver","cup","into","the","sack","youngest","price","his","corn","was","done","according","word","joseph","said"]},{"verseId":"brenton_genesis_44_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":3,"text":"The morning dawned, and the men were sent away, they and their asses.","searchKeywords":["the","morning","dawned","and","men","were","sent","away","they","their","asses"]},{"verseId":"brenton_genesis_44_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":4,"text":"And when they had gone out of the city, were not far off, then Joseph said to his steward, Arise, and pursue after the men; and thou shalt overtake them, and say to them, Why have ye returned evil for good?","searchKeywords":["and","when","they","had","gone","out","the","city","were","not","far","off","then","joseph","said","his","steward","arise","pursue","after","men","thou","shalt","overtake","them","say","why","have","returned","evil","for","good"]},{"verseId":"brenton_genesis_44_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":5,"text":"Why have ye stolen my silver cup? is it not this out of which my lord drinks? and he divines augury with it; ye have accomplished evil in that which ye have done.","searchKeywords":["why","have","stolen","silver","cup","not","this","out","which","lord","drinks","and","divines","augury","with","accomplished","evil","that","done"]},{"verseId":"brenton_genesis_44_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":6,"text":"And he found them, and spoke to them according to these words.","searchKeywords":["and","found","them","spoke","according","these","words"]},{"verseId":"brenton_genesis_44_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":7,"text":"And they said to him, Why does our lord speak according to these words? far be it from thy servants to do according to this word.","searchKeywords":["and","they","said","him","why","does","our","lord","speak","according","these","words","far","from","thy","servants","this","word"]},{"verseId":"brenton_genesis_44_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":8,"text":"If we brought back to thee out of the land of Chanaan the money which we found in our sacks, how should we steal silver or gold out of the house of thy lord?","searchKeywords":["brought","back","thee","out","the","land","chanaan","money","which","found","our","sacks","how","should","steal","silver","gold","house","thy","lord"]},{"verseId":"brenton_genesis_44_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":9,"text":"With whomsoever of thy servants thou shalt find the cup, let him die; and, moreover, we will be servants to our lord.","searchKeywords":["with","whomsoever","thy","servants","thou","shalt","find","the","cup","let","him","die","and","moreover","will","our","lord"]},{"verseId":"brenton_genesis_44_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":10,"text":"And he said, Now then it shall be as ye say; with whomsoever the cup shall be found, he shall be my servant, and ye shall be clear.","searchKeywords":["and","said","now","then","shall","say","with","whomsoever","the","cup","found","servant","clear"]},{"verseId":"brenton_genesis_44_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":11,"text":"And they hasted, and took down every man his sack on the ground, and they opened every man his sack.","searchKeywords":["and","they","hasted","took","down","every","man","his","sack","the","ground","opened"]},{"verseId":"brenton_genesis_44_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":12,"text":"And he searched, beginning from the eldest, until he came to the youngest; and he found the cup in Benjamin's sack.","searchKeywords":["and","searched","beginning","from","the","eldest","until","came","youngest","found","cup","benjamin","sack"]},{"verseId":"brenton_genesis_44_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":13,"text":"And they rent their garments, and laid each man his sack on his ass, and returned to the city.","searchKeywords":["and","they","rent","their","garments","laid","each","man","his","sack","ass","returned","the","city"]},{"verseId":"brenton_genesis_44_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":14,"text":"And Judas and his brethren came in to Joseph, while he was yet there, and fell on the ground before him.","searchKeywords":["and","judas","his","brethren","came","joseph","while","was","yet","there","fell","the","ground","before","him"]},{"verseId":"brenton_genesis_44_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":15,"text":"And Joseph said to them, What is this thing that ye have done? know ye not that a man such as I can surely divine?","searchKeywords":["and","joseph","said","them","what","this","thing","that","have","done","know","not","man","such","can","surely","divine"]},{"verseId":"brenton_genesis_44_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":16,"text":"And Judas said, What shall we answer to our lord, or what shall we say, or wherein should we be justified? whereas God has discovered the unrighteousness of thy servants; behold, we are slaves to our lord, both we and he with whom the cup has been found.","searchKeywords":["and","judas","said","what","shall","answer","our","lord","say","wherein","should","justified","whereas","god","has","discovered","the","unrighteousness","thy","servants","behold","are","slaves","both","with","whom","cup","been","found"]},{"verseId":"brenton_genesis_44_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":17,"text":"And Joseph said, Far be it from me to do this thing; the man with whom the cup has been found, he shall be my servant; but do ye go up with safety to your father.","searchKeywords":["and","joseph","said","far","from","this","thing","the","man","with","whom","cup","has","been","found","shall","servant","but","safety","your","father"]},{"verseId":"brenton_genesis_44_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":18,"text":"And Judas drew near him, and said, I pray, Sir, let thy servant speak a word before thee, and be not angry with thy servant, for thou art next to Pharao.","searchKeywords":["and","judas","drew","near","him","said","pray","sir","let","thy","servant","speak","word","before","thee","not","angry","with","for","thou","art","next","pharao"]},{"verseId":"brenton_genesis_44_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":19,"text":"Sir, thou askedst thy servants, saying, Have ye a father or a brother?","searchKeywords":["sir","thou","askedst","thy","servants","saying","have","father","brother"]},{"verseId":"brenton_genesis_44_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":20,"text":"And we said to lord, We have a father, an old man, and he has a son of his old age, a young one, and his brother is dead, and he alone has been left behind to his mother, and his father loves him.","searchKeywords":["and","said","lord","have","father","old","man","has","son","his","age","young","one","brother","dead","alone","been","left","behind","mother","loves","him"]},{"verseId":"brenton_genesis_44_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":21,"text":"And thou saidst to thy servants, Bring him down to me, and I will take care of him.","searchKeywords":["and","thou","saidst","thy","servants","bring","him","down","will","take","care"]},{"verseId":"brenton_genesis_44_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":22,"text":"And we said to lord, The child will not be able to leave his father; but if he should leave his father, he will die.","searchKeywords":["and","said","lord","the","child","will","not","able","leave","his","father","but","should","die"]},{"verseId":"brenton_genesis_44_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":23,"text":"But thou saidst to thy servants, Except your younger brother come down with you, ye shall not see my face again.","searchKeywords":["but","thou","saidst","thy","servants","except","your","younger","brother","come","down","with","you","shall","not","see","face","again"]},{"verseId":"brenton_genesis_44_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":24,"text":"And it came to pass, when we went up to thy servant our father, we reported to him the words of our lord.","searchKeywords":["and","came","pass","when","went","thy","servant","our","father","reported","him","the","words","lord"]},{"verseId":"brenton_genesis_44_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":25,"text":"And our father said, Go again, and buy us a little food.","searchKeywords":["and","our","father","said","again","buy","little","food"]},{"verseId":"brenton_genesis_44_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":26,"text":"And we said, We shall not be able to go down; but if our younger brother go down with us, we will go down; for we shall not be able to see the man's face, our younger brother not being with us.","searchKeywords":["and","said","shall","not","able","down","but","our","younger","brother","with","will","for","see","the","man","face","being"]},{"verseId":"brenton_genesis_44_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":27,"text":"And thy servant our father said to us, Ye know that my wife bore me two ;","searchKeywords":["and","thy","servant","our","father","said","know","that","wife","bore","two"]},{"verseId":"brenton_genesis_44_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":28,"text":"and one is departed from me; and ye said that he was devoured of wild beasts, and I have not seen him until now.","searchKeywords":["and","one","departed","from","said","that","was","devoured","wild","beasts","have","not","seen","him","until","now"]},{"verseId":"brenton_genesis_44_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":29,"text":"If then ye take this one also from my presence, and an affliction happen to him by the way, then shall ye bring down my old age with sorrow to the grave.","searchKeywords":["then","take","this","one","also","from","presence","and","affliction","happen","him","the","way","shall","bring","down","old","age","with","sorrow","grave"]},{"verseId":"brenton_genesis_44_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":30,"text":"Now then, if I should go in to thy servant, and our father, and the boy should not be with us, (and his life depends on this life)—","searchKeywords":["now","then","should","thy","servant","and","our","father","the","boy","not","with","his","life","depends","this"]},{"verseId":"brenton_genesis_44_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":31,"text":"it shall even come to pass, when he sees the boy is not with us, he will die, and thy servants will bring down the old age of thy servant, and our father, with sorrow to the grave.","searchKeywords":["shall","even","come","pass","when","sees","the","boy","not","with","will","die","and","thy","servants","bring","down","old","age","servant","our","father","sorrow","grave"]},{"verseId":"brenton_genesis_44_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":32,"text":"For thy servant has received the boy from his father, saying, If I bring him not to thee, and place him before thee, I shall be guilty towards my father for ever.","searchKeywords":["for","thy","servant","has","received","the","boy","from","his","father","saying","bring","him","not","thee","and","place","before","shall","guilty","towards","ever"]},{"verseId":"brenton_genesis_44_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":33,"text":"Now then I will remain a servant with thee instead of the lad, a domestic of my lord; but let the lad go up with his brethren.","searchKeywords":["now","then","will","remain","servant","with","thee","instead","the","lad","domestic","lord","but","let","his","brethren"]},{"verseId":"brenton_genesis_44_34","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":44,"verse":34,"text":"For how shall I go up to my father, the lad not being with us? lest I behold the evils which will befal my father.","searchKeywords":["for","how","shall","father","the","lad","not","being","with","lest","behold","evils","which","will","befal"]}]