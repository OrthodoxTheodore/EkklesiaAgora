[{"verseId":"brenton_genesis_10_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":1,"text":"Now these the generations of the sons of Noe, Sem, Cham, Japheth; and sons were born to them after the flood.","searchKeywords":["now","these","the","generations","sons","noe","sem","cham","japheth","and","were","born","them","after","flood"]},{"verseId":"brenton_genesis_10_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":2,"text":"The sons of Japheth, Gamer, and Magog, and Madoi, and Jovan, and Elisa, and Thobel, and Mosoch, and Thiras.","searchKeywords":["the","sons","japheth","gamer","and","magog","madoi","jovan","elisa","thobel","mosoch","thiras"]},{"verseId":"brenton_genesis_10_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":3,"text":"And the sons of Gamer, Aschanaz, and Riphath, and Thorgama.","searchKeywords":["and","the","sons","gamer","aschanaz","riphath","thorgama"]},{"verseId":"brenton_genesis_10_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":4,"text":"And the sons of Jovan, Elisa, and Tharseis, Cetians, Rhodians.","searchKeywords":["and","the","sons","jovan","elisa","tharseis","cetians","rhodians"]},{"verseId":"brenton_genesis_10_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":5,"text":"From these were the islands of the Gentiles divided in their land, each according to his tongue, in their tribes and in their nations.","searchKeywords":["from","these","were","the","islands","gentiles","divided","their","land","each","according","his","tongue","tribes","and","nations"]},{"verseId":"brenton_genesis_10_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":6,"text":"And the sons of Cham, Chus, and Mesrain, Phud, and Chanaan.","searchKeywords":["and","the","sons","cham","chus","mesrain","phud","chanaan"]},{"verseId":"brenton_genesis_10_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":7,"text":"And the sons of Chus, Saba, and Evila, and Sabatha, and Rhegma, and Sabathaca. And the sons of Rhegma, Saba, and Dadan.","searchKeywords":["and","the","sons","chus","saba","evila","sabatha","rhegma","sabathaca","dadan"]},{"verseId":"brenton_genesis_10_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":8,"text":"And Chus begot Nebrod: he began to be a giant upon the earth.","searchKeywords":["and","chus","begot","nebrod","began","giant","upon","the","earth"]},{"verseId":"brenton_genesis_10_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":9,"text":"He was a giant hunter before the Lord God; therefore they say, As Nebrod the giant hunter before the Lord.","searchKeywords":["was","giant","hunter","before","the","lord","god","therefore","they","say","nebrod"]},{"verseId":"brenton_genesis_10_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":10,"text":"And the beginning of his kingdom was Babylon, and Orech, and Archad, and Chalanne, in the land of Senaar.","searchKeywords":["and","the","beginning","his","kingdom","was","babylon","orech","archad","chalanne","land","senaar"]},{"verseId":"brenton_genesis_10_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":11,"text":"Out of that land came Assur, and built Ninevi, and the city Rhooboth, and Chalach,","searchKeywords":["out","that","land","came","assur","and","built","ninevi","the","city","rhooboth","chalach"]},{"verseId":"brenton_genesis_10_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":12,"text":"and Dase between Ninevi and Chalach: this is the great city.","searchKeywords":["and","dase","between","ninevi","chalach","this","the","great","city"]},{"verseId":"brenton_genesis_10_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":13,"text":"And Mesrain begot the Ludiim, and the Nephthalim, and the Enemetiim, and the Labiim,","searchKeywords":["and","mesrain","begot","the","ludiim","nephthalim","enemetiim","labiim"]},{"verseId":"brenton_genesis_10_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":14,"text":"and the Patrosoniim, and the Chasmoniim (whence came forth Phylistiim) and the Gaphthoriim.","searchKeywords":["and","the","patrosoniim","chasmoniim","whence","came","forth","phylistiim","gaphthoriim"]},{"verseId":"brenton_genesis_10_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":15,"text":"And Chanaan begot Sidon his first-born, and the Chettite,","searchKeywords":["and","chanaan","begot","sidon","his","first","born","the","chettite"]},{"verseId":"brenton_genesis_10_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":16,"text":"and the Jebusite, and the Amorite, and the Girgashite,","searchKeywords":["and","the","jebusite","amorite","girgashite"]},{"verseId":"brenton_genesis_10_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":17,"text":"and the Evite, and the Arukite, and the Asennite,","searchKeywords":["and","the","evite","arukite","asennite"]},{"verseId":"brenton_genesis_10_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":18,"text":"and the Aradian, and the Samarean, and the Amathite; and after this the tribes of the Chananites were dispersed.","searchKeywords":["and","the","aradian","samarean","amathite","after","this","tribes","chananites","were","dispersed"]},{"verseId":"brenton_genesis_10_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":19,"text":"And the boundaries of the Chananites were from Sidon till one comes to Gerara and Gaza, till one comes to Sodom and Gomorrha, Adama and Seboim, as far as Dasa.","searchKeywords":["and","the","boundaries","chananites","were","from","sidon","till","one","comes","gerara","gaza","sodom","gomorrha","adama","seboim","far","dasa"]},{"verseId":"brenton_genesis_10_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":20,"text":"These the sons of Cham in their tribes according to their tongues, in their countries, and in their nations.","searchKeywords":["these","the","sons","cham","their","tribes","according","tongues","countries","and","nations"]},{"verseId":"brenton_genesis_10_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":21,"text":"And to Sem himself also were children born, the father of all the sons of Heber, the brother of Japheth the elder.","searchKeywords":["and","sem","himself","also","were","children","born","the","father","all","sons","heber","brother","japheth","elder"]},{"verseId":"brenton_genesis_10_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":22,"text":"Sons of Sem, Elam, and Assur, and Arphaxad, and Lud, and Aram, and Cainan.","searchKeywords":["sons","sem","elam","and","assur","arphaxad","lud","aram","cainan"]},{"verseId":"brenton_genesis_10_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":23,"text":"And sons of Aram, Uz, and Ul, and Gater, and Mosoch.","searchKeywords":["and","sons","aram","gater","mosoch"]},{"verseId":"brenton_genesis_10_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":24,"text":"And Arphaxad begot Cainan, and Cainan begot Sala. And Sala begot Heber.","searchKeywords":["and","arphaxad","begot","cainan","sala","heber"]},{"verseId":"brenton_genesis_10_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":25,"text":"And to Heber were born two sons, the name of the one, Phaleg, because in his days the earth was divided, and the name of his brother Jektan.","searchKeywords":["and","heber","were","born","two","sons","the","name","one","phaleg","because","his","days","earth","was","divided","brother","jektan"]},{"verseId":"brenton_genesis_10_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":26,"text":"And Jektan begot Elmodad, and Saleth, and Sarmoth, and Jarach,","searchKeywords":["and","jektan","begot","elmodad","saleth","sarmoth","jarach"]},{"verseId":"brenton_genesis_10_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":27,"text":"and Odorrha, and Aibel, and Decla,","searchKeywords":["and","odorrha","aibel","decla"]},{"verseId":"brenton_genesis_10_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":28,"text":"and Eval, and Abimael, and Saba,","searchKeywords":["and","eval","abimael","saba"]},{"verseId":"brenton_genesis_10_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":29,"text":"and Uphir, and Evila, and Jobab, all these were the sons of Jektan.","searchKeywords":["and","uphir","evila","jobab","all","these","were","the","sons","jektan"]},{"verseId":"brenton_genesis_10_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":30,"text":"And their dwelling was from Masse, till one comes to Saphera, a mountain of the east.","searchKeywords":["and","their","dwelling","was","from","masse","till","one","comes","saphera","mountain","the","east"]},{"verseId":"brenton_genesis_10_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":31,"text":"These were the sons of Sem in their tribes, according to their tongues, in their countries, and in their nations.","searchKeywords":["these","were","the","sons","sem","their","tribes","according","tongues","countries","and","nations"]},{"verseId":"brenton_genesis_10_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":10,"verse":32,"text":"These are the tribes of the sons of Noe, according to their generations, according to their nations: of them were the islands of the Gentiles scattered over the earth after the flood.","searchKeywords":["these","are","the","tribes","sons","noe","according","their","generations","nations","them","were","islands","gentiles","scattered","over","earth","after","flood"]}]