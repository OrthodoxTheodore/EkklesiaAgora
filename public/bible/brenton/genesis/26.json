[{"verseId":"brenton_genesis_26_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":1,"text":"And there was a famine in the land, besides the former famine, which was in the time of Abraam; and Isaac went to Abimelech the king of the Phylistines to Gerara.","searchKeywords":["and","there","was","famine","the","land","besides","former","which","time","abraam","isaac","went","abimelech","king","phylistines","gerara"]},{"verseId":"brenton_genesis_26_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":2,"text":"And the Lord appeared to him and said, Go not down to Egypt, but dwell in the land, which I shall tell thee of.","searchKeywords":["and","the","lord","appeared","him","said","not","down","egypt","but","dwell","land","which","shall","tell","thee"]},{"verseId":"brenton_genesis_26_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":3,"text":"And sojourn in this land; and I will be with thee, and bless thee, for I will give to thee and to thy seed all this land; and I will establish my oath which I swore to thy father Abraam.","searchKeywords":["and","sojourn","this","land","will","with","thee","bless","for","give","thy","seed","all","establish","oath","which","swore","father","abraam"]},{"verseId":"brenton_genesis_26_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":4,"text":"And I will multiply thy seed as the stars of heaven; and I will give to thy seed all this land, and all the nations of the earth shall be blest in thy seed.","searchKeywords":["and","will","multiply","thy","seed","the","stars","heaven","give","all","this","land","nations","earth","shall","blest"]},{"verseId":"brenton_genesis_26_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":5,"text":"Because Abraam thy father hearkened to my voice, and kept my injunctions, and my commandments, and my ordinances, and my statutes.","searchKeywords":["because","abraam","thy","father","hearkened","voice","and","kept","injunctions","commandments","ordinances","statutes"]},{"verseId":"brenton_genesis_26_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":6,"text":"And Isaac dwelt in Gerara.","searchKeywords":["and","isaac","dwelt","gerara"]},{"verseId":"brenton_genesis_26_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":7,"text":"And the men of the place questioned him concerning Rebecca his wife, and he said, She is my sister, for he feared to say, She is my wife, lest at any time the men of the place should slay him because of Rebecca, because she was fair.","searchKeywords":["and","the","men","place","questioned","him","concerning","rebecca","his","wife","said","she","sister","for","feared","say","lest","any","time","should","slay","because","was","fair"]},{"verseId":"brenton_genesis_26_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":8,"text":"And he remained there a long time, and Abimelech the king of Gerara leaned to look through the window, and saw Isaac sporting with Rebecca his wife.","searchKeywords":["and","remained","there","long","time","abimelech","the","king","gerara","leaned","look","through","window","saw","isaac","sporting","with","rebecca","his","wife"]},{"verseId":"brenton_genesis_26_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":9,"text":"And Abimelech called Isaac, and said to him, Is she then thy wife? why hast thou said, She is my sister? And Isaac said to him, , for I said, Lest at any time I die on her account.","searchKeywords":["and","abimelech","called","isaac","said","him","she","then","thy","wife","why","hast","thou","sister","for","lest","any","time","die","her","account"]},{"verseId":"brenton_genesis_26_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":10,"text":"And Abimelech said to him, Why hast thou done this to us? one of my kindred within a little had lain with thy wife, and thou wouldest have brought ignorance upon us.","searchKeywords":["and","abimelech","said","him","why","hast","thou","done","this","one","kindred","within","little","had","lain","with","thy","wife","wouldest","have","brought","ignorance","upon"]},{"verseId":"brenton_genesis_26_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":11,"text":"And Abimelech charged all his people, saying, Every man that touches this man and his wife shall be liable to death.","searchKeywords":["and","abimelech","charged","all","his","people","saying","every","man","that","touches","this","wife","shall","liable","death"]},{"verseId":"brenton_genesis_26_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":12,"text":"And Isaac sowed in that land, and he found in that year barley an hundred-fold, and the Lord blessed him.","searchKeywords":["and","isaac","sowed","that","land","found","year","barley","hundred","fold","the","lord","blessed","him"]},{"verseId":"brenton_genesis_26_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":13,"text":"And the man was exalted, and advancing he increased, till he became very great.","searchKeywords":["and","the","man","was","exalted","advancing","increased","till","became","very","great"]},{"verseId":"brenton_genesis_26_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":14,"text":"And he had cattle of sheep, and cattle of oxen, and many tilled lands, and the Phylistines envied him.","searchKeywords":["and","had","cattle","sheep","oxen","many","tilled","lands","the","phylistines","envied","him"]},{"verseId":"brenton_genesis_26_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":15,"text":"And all the wells which the servants of his father had dug in the time of his father, the Phylistines stopped them, and filled them with earth.","searchKeywords":["and","all","the","wells","which","servants","his","father","had","dug","time","phylistines","stopped","them","filled","with","earth"]},{"verseId":"brenton_genesis_26_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":16,"text":"And Abimelech said to Isaac, Depart from us, for thou art become much mightier than we.","searchKeywords":["and","abimelech","said","isaac","depart","from","for","thou","art","become","much","mightier","than"]},{"verseId":"brenton_genesis_26_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":17,"text":"And Isaac departed thence, and rested in the valley of Gerara, and dwelt there.","searchKeywords":["and","isaac","departed","thence","rested","the","valley","gerara","dwelt","there"]},{"verseId":"brenton_genesis_26_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":18,"text":"And Isaac dug again the wells of water, which the servants of his father Abraam had dug, and the Phylistines had stopped them, after the death of his father Abraam; and he gave them names, according to the names by which his father named them.","searchKeywords":["and","isaac","dug","again","the","wells","water","which","servants","his","father","abraam","had","phylistines","stopped","them","after","death","gave","names","according","named"]},{"verseId":"brenton_genesis_26_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":19,"text":"And the servants of Isaac dug in the valley of Gerara, and they found there a well of living water.","searchKeywords":["and","the","servants","isaac","dug","valley","gerara","they","found","there","well","living","water"]},{"verseId":"brenton_genesis_26_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":20,"text":"And the shepherds of Gerara strove with the shepherds of Isaac, saying that the water was theirs; and they called the name of the well, Injury, for they injured him.","searchKeywords":["and","the","shepherds","gerara","strove","with","isaac","saying","that","water","was","theirs","they","called","name","well","injury","for","injured","him"]},{"verseId":"brenton_genesis_26_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":21,"text":"And having departed thence he dug another well, and they strove also for that; and he named the name of it, Enmity.","searchKeywords":["and","having","departed","thence","dug","another","well","they","strove","also","for","that","named","the","name","enmity"]},{"verseId":"brenton_genesis_26_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":22,"text":"And he departed thence and dug another well; and they did not strive about that; and he named the name of it, Room, saying, Because now the Lord has made room for us, and has increased us upon the earth.","searchKeywords":["and","departed","thence","dug","another","well","they","did","not","strive","about","that","named","the","name","room","saying","because","now","lord","has","made","for","increased","upon","earth"]},{"verseId":"brenton_genesis_26_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":23,"text":"And he went up thence to the well of the oath.","searchKeywords":["and","went","thence","the","well","oath"]},{"verseId":"brenton_genesis_26_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":24,"text":"And the Lord appeared to him in that night, and said, I am the God of Abraam thy father; fear not, for I am with thee, and I will bless thee, and multiply thy seed for the sake of Abraam thy father.","searchKeywords":["and","the","lord","appeared","him","that","night","said","god","abraam","thy","father","fear","not","for","with","thee","will","bless","multiply","seed","sake"]},{"verseId":"brenton_genesis_26_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":25,"text":"And he built there an altar, and called on the name of the Lord, and there he pitched his tent, and there the servants of Isaac dug a well in the valley of Gerara.","searchKeywords":["and","built","there","altar","called","the","name","lord","pitched","his","tent","servants","isaac","dug","well","valley","gerara"]},{"verseId":"brenton_genesis_26_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":26,"text":"And Abimelech came to him from Gerara, and so did Ochozath his friend, and Phichol the commander-in-chief of his army.","searchKeywords":["and","abimelech","came","him","from","gerara","did","ochozath","his","friend","phichol","the","commander","chief","army"]},{"verseId":"brenton_genesis_26_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":27,"text":"And Isaac said to them, Wherefore have ye come to me? whereas ye hated me, and sent me away from you.","searchKeywords":["and","isaac","said","them","wherefore","have","come","whereas","hated","sent","away","from","you"]},{"verseId":"brenton_genesis_26_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":28,"text":"And they said, We have surely seen that the Lord was with thee, and we said, Let there be an oath between us and thee, and we will make a covenant with thee,","searchKeywords":["and","they","said","have","surely","seen","that","the","lord","was","with","thee","let","there","oath","between","will","make","covenant"]},{"verseId":"brenton_genesis_26_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":29,"text":"that thou shalt do no wrong by us, as we have not abhorred thee, and according as we have treated thee well, and have sent thee forth peaceably; and now thou art blessed of the Lord.","searchKeywords":["that","thou","shalt","wrong","have","not","abhorred","thee","and","according","treated","well","sent","forth","peaceably","now","art","blessed","the","lord"]},{"verseId":"brenton_genesis_26_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":30,"text":"And he made a feast for them, and they ate and drank.","searchKeywords":["and","made","feast","for","them","they","ate","drank"]},{"verseId":"brenton_genesis_26_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":31,"text":"And they arose in the morning, and swore each to his neighbour; and Isaac sent them forth, and they departed from him in safety.","searchKeywords":["and","they","arose","the","morning","swore","each","his","neighbour","isaac","sent","them","forth","departed","from","him","safety"]},{"verseId":"brenton_genesis_26_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":32,"text":"And it came to pass in that day, that the servants of Isaac came and told him of the well which they had dug; and they said, We have not found water.","searchKeywords":["and","came","pass","that","day","the","servants","isaac","told","him","well","which","they","had","dug","said","have","not","found","water"]},{"verseId":"brenton_genesis_26_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":33,"text":"And he called it, Oath: therefore he called the name of that city, the Well of Oath, until this day.","searchKeywords":["and","called","oath","therefore","the","name","that","city","well","until","this","day"]},{"verseId":"brenton_genesis_26_34","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":34,"text":"And Esau was forty years old; and he took to wife Judith the daughter of Beoch the Chettite, and Basemath, daughter of Helon the Chettite.","searchKeywords":["and","esau","was","forty","years","old","took","wife","judith","the","daughter","beoch","chettite","basemath","helon"]},{"verseId":"brenton_genesis_26_35","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":26,"verse":35,"text":"And they were provoking to Isaac and Rebecca.","searchKeywords":["and","they","were","provoking","isaac","rebecca"]}]