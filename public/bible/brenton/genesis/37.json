[{"verseId":"brenton_genesis_37_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":1,"text":"And Jacob dwelt in the land where his father sojourned, in the land of Chanaan.","searchKeywords":["and","jacob","dwelt","the","land","where","his","father","sojourned","chanaan"]},{"verseId":"brenton_genesis_37_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":2,"text":"And these are the generations of Jacob. And Joseph was seventeen years old, feeding the sheep of his father with his brethren, being young; with the sons of Balla, and with the sons of Zelpha, the wives of his father; and Joseph brought to Israel their father their evil reproach.","searchKeywords":["and","these","are","the","generations","jacob","joseph","was","seventeen","years","old","feeding","sheep","his","father","with","brethren","being","young","sons","balla","zelpha","wives","brought","israel","their","evil","reproach"]},{"verseId":"brenton_genesis_37_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":3,"text":"And Jacob loved Joseph more than all his sons, because he was to him the son of old age; and he made for him a coat of many colours.","searchKeywords":["and","jacob","loved","joseph","more","than","all","his","sons","because","was","him","the","son","old","age","made","for","coat","many","colours"]},{"verseId":"brenton_genesis_37_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":4,"text":"And his brethren having seen that his father loved him more than all his sons, hated him, and could not speak anything peaceable to him.","searchKeywords":["and","his","brethren","having","seen","that","father","loved","him","more","than","all","sons","hated","could","not","speak","anything","peaceable"]},{"verseId":"brenton_genesis_37_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":5,"text":"And Joseph dreamed a dream, and reported it to his brethren.","searchKeywords":["and","joseph","dreamed","dream","reported","his","brethren"]},{"verseId":"brenton_genesis_37_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":6,"text":"And he said to them, Hear this dream which I have dreamed.","searchKeywords":["and","said","them","hear","this","dream","which","have","dreamed"]},{"verseId":"brenton_genesis_37_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":7,"text":"I thought ye were binding sheaves in the middle of the field, and my sheaf stood up and was erected, and your sheaves turned round, and did obeisance to my sheaf.","searchKeywords":["thought","were","binding","sheaves","the","middle","field","and","sheaf","stood","was","erected","your","turned","round","did","obeisance"]},{"verseId":"brenton_genesis_37_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":8,"text":"And his brethren said to him, Shalt thou indeed reign over us, or shalt thou indeed be lord over us? And they hated him still more for his dreams and for his words.","searchKeywords":["and","his","brethren","said","him","shalt","thou","indeed","reign","over","lord","they","hated","still","more","for","dreams","words"]},{"verseId":"brenton_genesis_37_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":9,"text":"And he dreamed another dream, and related it to his father, and to his brethren, and said, Behold, I have dreamed another dream: as it were the sun, and the moon, and the eleven stars did me reverence.","searchKeywords":["and","dreamed","another","dream","related","his","father","brethren","said","behold","have","were","the","sun","moon","eleven","stars","did","reverence"]},{"verseId":"brenton_genesis_37_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":10,"text":"And his father rebuked him, and said to him, What is this dream which thou hast dreamed? shall indeed both I and thy mother and thy brethren come and bow before thee to the earth?","searchKeywords":["and","his","father","rebuked","him","said","what","this","dream","which","thou","hast","dreamed","shall","indeed","both","thy","mother","brethren","come","bow","before","thee","the","earth"]},{"verseId":"brenton_genesis_37_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":11,"text":"And his brethren envied him; but his father observed the saying.","searchKeywords":["and","his","brethren","envied","him","but","father","observed","the","saying"]},{"verseId":"brenton_genesis_37_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":12,"text":"And his brethren went to feed the sheep of their father to Sychem.","searchKeywords":["and","his","brethren","went","feed","the","sheep","their","father","sychem"]},{"verseId":"brenton_genesis_37_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":13,"text":"And Israel said to Joseph, Do not thy brethren feed their flock in Sychem? Come, I will send thee to them; and he said to him, Behold, I .","searchKeywords":["and","israel","said","joseph","not","thy","brethren","feed","their","flock","sychem","come","will","send","thee","them","him","behold"]},{"verseId":"brenton_genesis_37_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":14,"text":"And Israel said to him, Go and see if thy brethren and the sheep are well, and bring me word; and he sent him out of the valley of Chebron, and he came to Sychem.","searchKeywords":["and","israel","said","him","see","thy","brethren","the","sheep","are","well","bring","word","sent","out","valley","chebron","came","sychem"]},{"verseId":"brenton_genesis_37_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":15,"text":"And a man found him wandering in the field; and the man asked him, saying, What seekest thou?","searchKeywords":["and","man","found","him","wandering","the","field","asked","saying","what","seekest","thou"]},{"verseId":"brenton_genesis_37_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":16,"text":"And he said, I am seeking my brethren; tell me where they feed .","searchKeywords":["and","said","seeking","brethren","tell","where","they","feed"]},{"verseId":"brenton_genesis_37_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":17,"text":"And the man said to him, They have departed hence, for I heard them saying, Let us go to Dothaim; and Joseph went after his brethren, and found them in Dothaim.","searchKeywords":["and","the","man","said","him","they","have","departed","hence","for","heard","them","saying","let","dothaim","joseph","went","after","his","brethren","found"]},{"verseId":"brenton_genesis_37_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":18,"text":"And they spied him from a distance before he drew nigh to them, and they wickedly took counsel to slay him.","searchKeywords":["and","they","spied","him","from","distance","before","drew","nigh","them","wickedly","took","counsel","slay"]},{"verseId":"brenton_genesis_37_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":19,"text":"And each said to his brother, Behold, that dreamer comes.","searchKeywords":["and","each","said","his","brother","behold","that","dreamer","comes"]},{"verseId":"brenton_genesis_37_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":20,"text":"Now then come, let us kill him, and cast him into one of the pits; and we will say, An evil wild beast has devoured him; and we shall see what his dreams will be.","searchKeywords":["now","then","come","let","kill","him","and","cast","into","one","the","pits","will","say","evil","wild","beast","has","devoured","shall","see","what","his","dreams"]},{"verseId":"brenton_genesis_37_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":21,"text":"And Ruben having heard it, rescued him out of their hands, and said, Let us not kill him.","searchKeywords":["and","ruben","having","heard","rescued","him","out","their","hands","said","let","not","kill"]},{"verseId":"brenton_genesis_37_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":22,"text":"And Ruben said to them, Shed not blood; cast him into one of these pits in the wilderness, but do not lay hand upon him; that he might rescue him out of their hands, and restore him to his father.","searchKeywords":["and","ruben","said","them","shed","not","blood","cast","him","into","one","these","pits","the","wilderness","but","lay","hand","upon","that","might","rescue","out","their","hands","restore","his","father"]},{"verseId":"brenton_genesis_37_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":23,"text":"And it came to pass, when Joseph came to his brethren, that they stripped Joseph of his many-coloured coat that was upon him.","searchKeywords":["and","came","pass","when","joseph","his","brethren","that","they","stripped","many","coloured","coat","was","upon","him"]},{"verseId":"brenton_genesis_37_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":24,"text":"And they took him and cast him into the pit; and the pit was empty, it had not water.","searchKeywords":["and","they","took","him","cast","into","the","pit","was","empty","had","not","water"]},{"verseId":"brenton_genesis_37_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":25,"text":"And they sat down to eat bread; and having lifted up their eyes they beheld, and lo, Ismaelitish travellers came from Galaad, and their camels were heavily loaded with spices, and resin, and myrrh; and they went to bring them to Egypt.","searchKeywords":["and","they","sat","down","eat","bread","having","lifted","their","eyes","beheld","ismaelitish","travellers","came","from","galaad","camels","were","heavily","loaded","with","spices","resin","myrrh","went","bring","them","egypt"]},{"verseId":"brenton_genesis_37_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":26,"text":"And Judas said to his brethren, What profit is it if we slay our brother, and conceal his blood?","searchKeywords":["and","judas","said","his","brethren","what","profit","slay","our","brother","conceal","blood"]},{"verseId":"brenton_genesis_37_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":27,"text":"Come, let us sell him to these Ismaelites, but let not our hands be upon him, because he is our brother and our flesh; and his brethren hearkened.","searchKeywords":["come","let","sell","him","these","ismaelites","but","not","our","hands","upon","because","brother","and","flesh","his","brethren","hearkened"]},{"verseId":"brenton_genesis_37_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":28,"text":"And the men, the merchants of Madian, went by, and they drew and lifted Joseph out of the pit, and sold Joseph to the Ismaelites for twenty pieces of gold; and they brought Joseph down into Egypt.","searchKeywords":["and","the","men","merchants","madian","went","they","drew","lifted","joseph","out","pit","sold","ismaelites","for","twenty","pieces","gold","brought","down","into","egypt"]},{"verseId":"brenton_genesis_37_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":29,"text":"And Ruben returned to the pit, and sees not Joseph in the pit; and he rent his garments.","searchKeywords":["and","ruben","returned","the","pit","sees","not","joseph","rent","his","garments"]},{"verseId":"brenton_genesis_37_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":30,"text":"And he returned to his brethren and said, The boy is not; and I, whither am I yet to go?","searchKeywords":["and","returned","his","brethren","said","the","boy","not","whither","yet"]},{"verseId":"brenton_genesis_37_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":31,"text":"And having taken the coat of Joseph, they slew a kid of the goats, and stained the coat with the blood.","searchKeywords":["and","having","taken","the","coat","joseph","they","slew","kid","goats","stained","with","blood"]},{"verseId":"brenton_genesis_37_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":32,"text":"And they sent the coat of many colours; and they brought it to their father, and said, This have we found; know if it be thy son's coat or no.","searchKeywords":["and","they","sent","the","coat","many","colours","brought","their","father","said","this","have","found","know","thy","son"]},{"verseId":"brenton_genesis_37_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":33,"text":"And he recognised it, and said, It is my son's coat, an evil wild beast has devoured him; a wild beast has carried off Joseph.","searchKeywords":["and","recognised","said","son","coat","evil","wild","beast","has","devoured","him","carried","off","joseph"]},{"verseId":"brenton_genesis_37_34","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":34,"text":"And Jacob rent his clothes, and put sackcloth on his loins, and mourned for his son many days.","searchKeywords":["and","jacob","rent","his","clothes","put","sackcloth","loins","mourned","for","son","many","days"]},{"verseId":"brenton_genesis_37_35","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":35,"text":"And all his sons and his daughters gathered themselves together, and came to comfort him; but he would not be comforted, saying, I will go down to my son mourning to Hades; and his father wept for him.","searchKeywords":["and","all","his","sons","daughters","gathered","themselves","together","came","comfort","him","but","would","not","comforted","saying","will","down","son","mourning","hades","father","wept","for"]},{"verseId":"brenton_genesis_37_36","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":37,"verse":36,"text":"And the Madianites sold Joseph into Egypt; to Petephres, the eunuch of Pharao, captain of the guard.","searchKeywords":["and","the","madianites","sold","joseph","into","egypt","petephres","eunuch","pharao","captain","guard"]}]