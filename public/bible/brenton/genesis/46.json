[{"verseId":"brenton_genesis_46_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":1,"text":"And Israel departed, he and all that he had, and came to the well of the oath; and he offered sacrifice to the God of his father Isaac.","searchKeywords":["and","israel","departed","all","that","had","came","the","well","oath","offered","sacrifice","god","his","father","isaac"]},{"verseId":"brenton_genesis_46_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":2,"text":"And God spoke to Israel in a night vision, saying, Jacob, Jacob; and he said, What is it?","searchKeywords":["and","god","spoke","israel","night","vision","saying","jacob","said","what"]},{"verseId":"brenton_genesis_46_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":3,"text":"And he says to him, I am the God of thy fathers; fear not to go down into Egypt, for I will make thee there a great nation.","searchKeywords":["and","says","him","the","god","thy","fathers","fear","not","down","into","egypt","for","will","make","thee","there","great","nation"]},{"verseId":"brenton_genesis_46_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":4,"text":"And I will go down with thee into Egypt, and I will bring thee up at the end; and Joseph shall put his hands on thine eyes.","searchKeywords":["and","will","down","with","thee","into","egypt","bring","the","end","joseph","shall","put","his","hands","thine","eyes"]},{"verseId":"brenton_genesis_46_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":5,"text":"And Jacob rose up from the well of the oath; and the sons of Israel took up their father, and the baggage, and their wives on the waggons, which Joseph sent to take them.","searchKeywords":["and","jacob","rose","from","the","well","oath","sons","israel","took","their","father","baggage","wives","waggons","which","joseph","sent","take","them"]},{"verseId":"brenton_genesis_46_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":6,"text":"And they took up their goods, and all their property, which they had gotten in the land of Chanaan; they came into the land of Egypt, Jacob, and all his seed with him.","searchKeywords":["and","they","took","their","goods","all","property","which","had","gotten","the","land","chanaan","came","into","egypt","jacob","his","seed","with","him"]},{"verseId":"brenton_genesis_46_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":7,"text":"The sons, and the sons of his sons with him; daughters, and the daughters of his daughters; and he brought all his seed into Egypt.","searchKeywords":["the","sons","and","his","with","him","daughters","brought","all","seed","into","egypt"]},{"verseId":"brenton_genesis_46_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":8,"text":"And these are the names of the sons of Israel that went into Egypt with their father Jacob—Jacob and his sons. The first-born of Jacob, Ruben.","searchKeywords":["and","these","are","the","names","sons","israel","that","went","into","egypt","with","their","father","jacob","his","first","born","ruben"]},{"verseId":"brenton_genesis_46_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":9,"text":"And the sons of Ruben; Enoch, and Phallus, Asron, and Charmi.","searchKeywords":["and","the","sons","ruben","enoch","phallus","asron","charmi"]},{"verseId":"brenton_genesis_46_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":10,"text":"And the sons of Symeon; Jemuel, and Jamin, and Aod, and Achin, and Saar, and Saul, the son of a Chananitish woman.","searchKeywords":["and","the","sons","symeon","jemuel","jamin","aod","achin","saar","saul","son","chananitish","woman"]},{"verseId":"brenton_genesis_46_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":11,"text":"And the sons of Levi; Gerson, Cath, and Merari.","searchKeywords":["and","the","sons","levi","gerson","cath","merari"]},{"verseId":"brenton_genesis_46_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":12,"text":"And the sons of Judas; Er, and Aunan, and Selom, and Phares, and Zara: and Er and Aunan died in the land of Chanaan.","searchKeywords":["and","the","sons","judas","aunan","selom","phares","zara","died","land","chanaan"]},{"verseId":"brenton_genesis_46_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":13,"text":"And the sons of Phares Esron, and Jemuel. And the sons of Issachar; Thola, and Phua, and Asum, and Sambran.","searchKeywords":["and","the","sons","phares","esron","jemuel","issachar","thola","phua","asum","sambran"]},{"verseId":"brenton_genesis_46_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":14,"text":"And the sons of Zabulun, Sered, and Allon, and Achoel.","searchKeywords":["and","the","sons","zabulun","sered","allon","achoel"]},{"verseId":"brenton_genesis_46_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":15,"text":"These the sons of Lea, which she bore to Jacob in Mesopotamia of Syria, and Dina his daughter; all the souls, sons and daughters, thirty-three.","searchKeywords":["these","the","sons","lea","which","she","bore","jacob","mesopotamia","syria","and","dina","his","daughter","all","souls","daughters","thirty","three"]},{"verseId":"brenton_genesis_46_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":16,"text":"And the sons of Gad; Saphon, and Angis, and Sannis, and Thasoban, and Aedis, and Aroedis, and Areelis.","searchKeywords":["and","the","sons","gad","saphon","angis","sannis","thasoban","aedis","aroedis","areelis"]},{"verseId":"brenton_genesis_46_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":17,"text":"And the sons of Aser; Jemna, Jessua, and Jeul, and Baria, and Sara their sister. And the sons of Baria; Chobor, and Melchiil.","searchKeywords":["and","the","sons","aser","jemna","jessua","jeul","baria","sara","their","sister","chobor","melchiil"]},{"verseId":"brenton_genesis_46_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":18,"text":"These the sons of Zelpha, which Laban gave to his daughter Lea, who bore these to Jacob, sixteen souls.","searchKeywords":["these","the","sons","zelpha","which","laban","gave","his","daughter","lea","who","bore","jacob","sixteen","souls"]},{"verseId":"brenton_genesis_46_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":19,"text":"And the sons of Rachel, the wife of Jacob; Joseph, and Benjamin.","searchKeywords":["and","the","sons","rachel","wife","jacob","joseph","benjamin"]},{"verseId":"brenton_genesis_46_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":20,"text":"And there were sons born to Joseph in the land of Egypt, whom Aseneth, the daughter of Petephres, priest of Heliopolis, bore to him, Manasses and Ephraim. And there were sons born to Manasses, which the Syrian concubine bore to him, Machir. And Machir begot Galaad. And the sons of Ephraim, the brother of Manasses; Sutalaam, and Taam. And the sons of Sutalaam; Edom.","searchKeywords":["and","there","were","sons","born","joseph","the","land","egypt","whom","aseneth","daughter","petephres","priest","heliopolis","bore","him","manasses","ephraim","which","syrian","concubine","machir","begot","galaad","brother","sutalaam","taam","edom"]},{"verseId":"brenton_genesis_46_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":21,"text":"And the sons of Benjamin; Bala, and Bochor, and Asbel. And the sons of Bala were Gera, and Noeman, and Anchis, and Ros, and Mamphim. And Gera begot Arad.","searchKeywords":["and","the","sons","benjamin","bala","bochor","asbel","were","gera","noeman","anchis","ros","mamphim","begot","arad"]},{"verseId":"brenton_genesis_46_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":22,"text":"These the sons of Rachel, which she bore to Jacob; all the souls eighteen.","searchKeywords":["these","the","sons","rachel","which","she","bore","jacob","all","souls","eighteen"]},{"verseId":"brenton_genesis_46_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":23,"text":"And the sons of Dan; Asom.","searchKeywords":["and","the","sons","dan","asom"]},{"verseId":"brenton_genesis_46_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":24,"text":"And the sons of Nephthalim; Asiel, and Goni, and Issaar, and Sollem.","searchKeywords":["and","the","sons","nephthalim","asiel","goni","issaar","sollem"]},{"verseId":"brenton_genesis_46_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":25,"text":"These the sons of Balla, whom Laban gave to his daughter Rachel, who bore these to Jacob; all the souls, seven.","searchKeywords":["these","the","sons","balla","whom","laban","gave","his","daughter","rachel","who","bore","jacob","all","souls","seven"]},{"verseId":"brenton_genesis_46_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":26,"text":"And all the souls that came with Jacob into Egypt, who came out of his loins, besides the wives of the sons of Jacob, all the souls were sixty-six.","searchKeywords":["and","all","the","souls","that","came","with","jacob","into","egypt","who","out","his","loins","besides","wives","sons","were","sixty","six"]},{"verseId":"brenton_genesis_46_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":27,"text":"And the sons of Joseph, who were born to him in the land of Egypt, were nine souls; all the souls of the house of Jacob who came with Joseph into Egypt, were seventy-five souls.","searchKeywords":["and","the","sons","joseph","who","were","born","him","land","egypt","nine","souls","all","house","jacob","came","with","into","seventy","five"]},{"verseId":"brenton_genesis_46_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":28,"text":"And he sent Judas before him to Joseph, to meet him to the city of Heroes, into the land of Ramesses.","searchKeywords":["and","sent","judas","before","him","joseph","meet","the","city","heroes","into","land","ramesses"]},{"verseId":"brenton_genesis_46_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":29,"text":"And Joseph having made ready his chariots, went up to meet Israel his father, at the city of Heroes; and having appeared to him, fell on his neck, and wept with abundant weeping.","searchKeywords":["and","joseph","having","made","ready","his","chariots","went","meet","israel","father","the","city","heroes","appeared","him","fell","neck","wept","with","abundant","weeping"]},{"verseId":"brenton_genesis_46_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":30,"text":"And Israel said to Joseph, After this I will die, since I have seen thy face, for thou art yet living.","searchKeywords":["and","israel","said","joseph","after","this","will","die","since","have","seen","thy","face","for","thou","art","yet","living"]},{"verseId":"brenton_genesis_46_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":31,"text":"And Joseph said to his brethren, I will go up and tell Pharao, and will say to him, My brethren, and my father's house, who were in the land of Chanaan, are come to me.","searchKeywords":["and","joseph","said","his","brethren","will","tell","pharao","say","him","father","house","who","were","the","land","chanaan","are","come"]},{"verseId":"brenton_genesis_46_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":32,"text":"And the men are shepherds; for they have been feeders of cattle, and they have brought with them their cattle, and their kine, and all their property.","searchKeywords":["and","the","men","are","shepherds","for","they","have","been","feeders","cattle","brought","with","them","their","kine","all","property"]},{"verseId":"brenton_genesis_46_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":33,"text":"If then Pharao call you, and say to you, What is your occupation?","searchKeywords":["then","pharao","call","you","and","say","what","your","occupation"]},{"verseId":"brenton_genesis_46_34","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":46,"verse":34,"text":"Ye shall say, We thy servants are herdsmen from our youth until now, both we and our fathers: that ye may dwell in the land of Gesem of Arabia, for every shepherd is an abomination to the Egyptians.","searchKeywords":["shall","say","thy","servants","are","herdsmen","from","our","youth","until","now","both","and","fathers","that","may","dwell","the","land","gesem","arabia","for","every","shepherd","abomination","egyptians"]}]