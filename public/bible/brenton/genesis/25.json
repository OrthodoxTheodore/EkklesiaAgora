[{"verseId":"brenton_genesis_25_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":1,"text":"And Abraam again took a wife, whose name was Chettura.","searchKeywords":["and","abraam","again","took","wife","whose","name","was","chettura"]},{"verseId":"brenton_genesis_25_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":2,"text":"And she bore to him Zombran, and Jezan, and Madal, and Madiam, and Jesboc, and Soie.","searchKeywords":["and","she","bore","him","zombran","jezan","madal","madiam","jesboc","soie"]},{"verseId":"brenton_genesis_25_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":3,"text":"And Jezan begot Saba and Dedan. And the sons of Dedan were the Assurians and the Latusians, and Laomim.","searchKeywords":["and","jezan","begot","saba","dedan","the","sons","were","assurians","latusians","laomim"]},{"verseId":"brenton_genesis_25_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":4,"text":"And the sons of Madiam Gephar and Aphir, and Enoch, and Abeida, and Eldaga; all these were sons of Chettura.","searchKeywords":["and","the","sons","madiam","gephar","aphir","enoch","abeida","eldaga","all","these","were","chettura"]},{"verseId":"brenton_genesis_25_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":5,"text":"But Abraam gave all his possessions to Isaac his son.","searchKeywords":["but","abraam","gave","all","his","possessions","isaac","son"]},{"verseId":"brenton_genesis_25_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":6,"text":"But to the sons of his concubines Abraam gave gifts, and he sent them away from his son Isaac, while he was yet living, to the east into the country of the east.","searchKeywords":["but","the","sons","his","concubines","abraam","gave","gifts","and","sent","them","away","from","son","isaac","while","was","yet","living","east","into","country"]},{"verseId":"brenton_genesis_25_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":7,"text":"And these the years of the days of the life of Abraam as many as he lived, a hundred and seventy-five years.","searchKeywords":["and","these","the","years","days","life","abraam","many","lived","hundred","seventy","five"]},{"verseId":"brenton_genesis_25_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":8,"text":"And Abraam failing died in a good old age, an old man and full of days, and was added to his people.","searchKeywords":["and","abraam","failing","died","good","old","age","man","full","days","was","added","his","people"]},{"verseId":"brenton_genesis_25_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":9,"text":"And Isaac and Ismael his sons buried him in the double cave, in the field of Ephron the son of Saar the Chettite, which is over against Mambre:","searchKeywords":["and","isaac","ismael","his","sons","buried","him","the","double","cave","field","ephron","son","saar","chettite","which","over","against","mambre"]},{"verseId":"brenton_genesis_25_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":10,"text":"the field and the cave which Abraam bought of the sons of Chet; there they buried Abraam and Sarrha his wife.","searchKeywords":["the","field","and","cave","which","abraam","bought","sons","chet","there","they","buried","sarrha","his","wife"]},{"verseId":"brenton_genesis_25_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":11,"text":"And it came to pass after Abraam was dead, that God blessed Isaac his son, and Isaac dwelt by the well of the vision.","searchKeywords":["and","came","pass","after","abraam","was","dead","that","god","blessed","isaac","his","son","dwelt","the","well","vision"]},{"verseId":"brenton_genesis_25_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":12,"text":"And these the generations of Ismael the son of Abraam, whom Agar the Egyptian the hand-maid of Sarrha bore to Abraam.","searchKeywords":["and","these","the","generations","ismael","son","abraam","whom","agar","egyptian","hand","maid","sarrha","bore"]},{"verseId":"brenton_genesis_25_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":13,"text":"And these the names of the sons of Ismael, according to the names of their generations. The firstborn of Ismael, Nabaioth, and Kedar, and Nabdeel, and Massam,","searchKeywords":["and","these","the","names","sons","ismael","according","their","generations","firstborn","nabaioth","kedar","nabdeel","massam"]},{"verseId":"brenton_genesis_25_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":14,"text":"and Masma, and Duma, and Masse,","searchKeywords":["and","masma","duma","masse"]},{"verseId":"brenton_genesis_25_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":15,"text":"and Choddan, and Thæman, and Jetur, and Naphes, and Kedma.","searchKeywords":["and","choddan","man","jetur","naphes","kedma"]},{"verseId":"brenton_genesis_25_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":16,"text":"These the sons of Ismael, and these are their names in their tents and in their dwellings, twelve princes according to their nations.","searchKeywords":["these","the","sons","ismael","and","are","their","names","tents","dwellings","twelve","princes","according","nations"]},{"verseId":"brenton_genesis_25_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":17,"text":"And these the years of the life of Ismael, a hundred and thirty-seven years; and he failed and died, and was added to his fathers.","searchKeywords":["and","these","the","years","life","ismael","hundred","thirty","seven","failed","died","was","added","his","fathers"]},{"verseId":"brenton_genesis_25_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":18,"text":"And he dwelt from Evilat to Sur, which is opposite Egypt, until one comes to the Assyrians; he dwelt in the presence of all his brethren.","searchKeywords":["and","dwelt","from","evilat","sur","which","opposite","egypt","until","one","comes","the","assyrians","presence","all","his","brethren"]},{"verseId":"brenton_genesis_25_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":19,"text":"And these the generations of Isaac the son of Abraam.","searchKeywords":["and","these","the","generations","isaac","son","abraam"]},{"verseId":"brenton_genesis_25_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":20,"text":"Abraam begot Isaac. And Isaac was forty years old when he took to wife Rebecca, daughter of Bathuel the Syrian, out of Syrian Mesopotamia, sister of Laban the Syrian.","searchKeywords":["abraam","begot","isaac","and","was","forty","years","old","when","took","wife","rebecca","daughter","bathuel","the","syrian","out","mesopotamia","sister","laban"]},{"verseId":"brenton_genesis_25_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":21,"text":"And Isaac prayed the Lord concerning Rebecca his wife, because she was barren; and the Lord heard him, and his wife Rebecca conceived in her womb.","searchKeywords":["and","isaac","prayed","the","lord","concerning","rebecca","his","wife","because","she","was","barren","heard","him","conceived","her","womb"]},{"verseId":"brenton_genesis_25_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":22,"text":"And the babes leaped within her; and she said, If it will be so with me, why is this to me? And she went to enquire of the Lord.","searchKeywords":["and","the","babes","leaped","within","her","she","said","will","with","why","this","went","enquire","lord"]},{"verseId":"brenton_genesis_25_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":23,"text":"And the Lord said to her, There are two nations in thy womb, and two peoples shall be separated from thy belly, and one people shall excel the other, and the elder shall serve the younger.","searchKeywords":["and","the","lord","said","her","there","are","two","nations","thy","womb","peoples","shall","separated","from","belly","one","people","excel","other","elder","serve","younger"]},{"verseId":"brenton_genesis_25_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":24,"text":"And the days were fulfilled that she should be delivered, and she had twins in her womb.","searchKeywords":["and","the","days","were","fulfilled","that","she","should","delivered","had","twins","her","womb"]},{"verseId":"brenton_genesis_25_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":25,"text":"And the first came out red, hairy all over like a skin; and she called his name Esau.","searchKeywords":["and","the","first","came","out","red","hairy","all","over","like","skin","she","called","his","name","esau"]},{"verseId":"brenton_genesis_25_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":26,"text":"And after this came forth his brother, and his hand took hold of the heel of Esau; and she called his name Jacob. And Isaac was sixty years old when Rebecca bore them.","searchKeywords":["and","after","this","came","forth","his","brother","hand","took","hold","the","heel","esau","she","called","name","jacob","isaac","was","sixty","years","old","when","rebecca","bore","them"]},{"verseId":"brenton_genesis_25_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":27,"text":"And the lads grew, and Esau was a man skilled in hunting, dwelling in the country, and Jacob a simple man, dwelling in a house.","searchKeywords":["and","the","lads","grew","esau","was","man","skilled","hunting","dwelling","country","jacob","simple","house"]},{"verseId":"brenton_genesis_25_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":28,"text":"And Isaac loved Esau, because his venison was his food, but Rebecca loved Jacob.","searchKeywords":["and","isaac","loved","esau","because","his","venison","was","food","but","rebecca","jacob"]},{"verseId":"brenton_genesis_25_29","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":29,"text":"And Jacob cooked pottage, and Esau came from the plain, fainting.","searchKeywords":["and","jacob","cooked","pottage","esau","came","from","the","plain","fainting"]},{"verseId":"brenton_genesis_25_30","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":30,"text":"And Esau said to Jacob, Let me taste of that red pottage, because I am fainting; therefore his name was called Edom.","searchKeywords":["and","esau","said","jacob","let","taste","that","red","pottage","because","fainting","therefore","his","name","was","called","edom"]},{"verseId":"brenton_genesis_25_31","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":31,"text":"And Jacob said to Esau, Sell me this day thy birthright.","searchKeywords":["and","jacob","said","esau","sell","this","day","thy","birthright"]},{"verseId":"brenton_genesis_25_32","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":32,"text":"And Esau said, Behold, I am going to die, and for what good does this birthright to me?","searchKeywords":["and","esau","said","behold","going","die","for","what","good","does","this","birthright"]},{"verseId":"brenton_genesis_25_33","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":33,"text":"And Jacob said to him, Swear to me this day; and he swore to him; and Esau sold his birthright to Jacob.","searchKeywords":["and","jacob","said","him","swear","this","day","swore","esau","sold","his","birthright"]},{"verseId":"brenton_genesis_25_34","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":25,"verse":34,"text":"And Jacob gave bread to Esau, and pottage of lentiles; and he ate and drank, and he arose and departed; so Esau slighted his birthright.","searchKeywords":["and","jacob","gave","bread","esau","pottage","lentiles","ate","drank","arose","departed","slighted","his","birthright"]}]