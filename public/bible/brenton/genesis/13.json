[{"verseId":"brenton_genesis_13_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":1,"text":"And Abram went up out of Egypt, he and his wife, and all that he had, and Lot with him, into the wilderness.","searchKeywords":["and","abram","went","out","egypt","his","wife","all","that","had","lot","with","him","into","the","wilderness"]},{"verseId":"brenton_genesis_13_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":2,"text":"And Abram was very rich in cattle, and silver, and gold.","searchKeywords":["and","abram","was","very","rich","cattle","silver","gold"]},{"verseId":"brenton_genesis_13_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":3,"text":"And he went whence he came, into the wilderness as far as Bæthel, as far as the place where his tent was before, between Bæthel and Aggai,","searchKeywords":["and","went","whence","came","into","the","wilderness","far","thel","place","where","his","tent","was","before","between","aggai"]},{"verseId":"brenton_genesis_13_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":4,"text":"to the place of the altar, which he built there at first, and Abram there called on the name of the Lord.","searchKeywords":["the","place","altar","which","built","there","first","and","abram","called","name","lord"]},{"verseId":"brenton_genesis_13_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":5,"text":"And Lot who went out with Abram had sheep, and oxen, and tents.","searchKeywords":["and","lot","who","went","out","with","abram","had","sheep","oxen","tents"]},{"verseId":"brenton_genesis_13_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":6,"text":"And the land was not large enough for them to live together, because their possessions were great; and the land was not large enough for them to live together.","searchKeywords":["and","the","land","was","not","large","enough","for","them","live","together","because","their","possessions","were","great"]},{"verseId":"brenton_genesis_13_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":7,"text":"And there was a strife between the herdmen of Abram's cattle, and the herdmen of Lot's cattle, and the Chananites and the Pherezites then inhabited the land.","searchKeywords":["and","there","was","strife","between","the","herdmen","abram","cattle","lot","chananites","pherezites","then","inhabited","land"]},{"verseId":"brenton_genesis_13_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":8,"text":"And Abram said to Lot, Let there not be a strife between me and thee, and between my herdmen and thy herdmen, for we are brethren.","searchKeywords":["and","abram","said","lot","let","there","not","strife","between","thee","herdmen","thy","for","are","brethren"]},{"verseId":"brenton_genesis_13_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":9,"text":"Lo! is not the whole land before thee? Separate thyself from me; if thou to the left, I will go to the right, and if thou goest to the right, I will go to the left.","searchKeywords":["not","the","whole","land","before","thee","separate","thyself","from","thou","left","will","right","and","goest"]},{"verseId":"brenton_genesis_13_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":10,"text":"And Lot having lifted up his eyes, observed all the country round about Jordan, that it was all watered, before God overthrew Sodom and Gomorrha, as the garden of the Lord, and as the land of Egypt, until thou come to Zogora.","searchKeywords":["and","lot","having","lifted","his","eyes","observed","all","the","country","round","about","jordan","that","was","watered","before","god","overthrew","sodom","gomorrha","garden","lord","land","egypt","until","thou","come","zogora"]},{"verseId":"brenton_genesis_13_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":11,"text":"And Lot chose for himself all the country round Jordan, and Lot went from the east, and they were separated each from his brother. And Abram dwelt in the land of Chanaan.","searchKeywords":["and","lot","chose","for","himself","all","the","country","round","jordan","went","from","east","they","were","separated","each","his","brother","abram","dwelt","land","chanaan"]},{"verseId":"brenton_genesis_13_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":12,"text":"And Lot dwelt in a city of the neighbouring people, and pitched his tent in Sodom.","searchKeywords":["and","lot","dwelt","city","the","neighbouring","people","pitched","his","tent","sodom"]},{"verseId":"brenton_genesis_13_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":13,"text":"But the men of Sodom were evil, and exceedingly sinful before God.","searchKeywords":["but","the","men","sodom","were","evil","and","exceedingly","sinful","before","god"]},{"verseId":"brenton_genesis_13_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":14,"text":"And God said to Abram after Lot was separated from him, Look up with thine eyes, and behold from the place where thou now art northward and southward, and eastward and seaward;","searchKeywords":["and","god","said","abram","after","lot","was","separated","from","him","look","with","thine","eyes","behold","the","place","where","thou","now","art","northward","southward","eastward","seaward"]},{"verseId":"brenton_genesis_13_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":15,"text":"for all the land which thou seest, I will give it to thee and to thy seed for ever.","searchKeywords":["for","all","the","land","which","thou","seest","will","give","thee","and","thy","seed","ever"]},{"verseId":"brenton_genesis_13_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":16,"text":"And I will make thy seed like the dust of the earth; if any one is able to number the dust of the earth, then shall thy seed be numbered.","searchKeywords":["and","will","make","thy","seed","like","the","dust","earth","any","one","able","number","then","shall","numbered"]},{"verseId":"brenton_genesis_13_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":17,"text":"Arise and traverse the land, both in the length of it and in the breadth; for to thee will I give it, and to thy seed for ever.","searchKeywords":["arise","and","traverse","the","land","both","length","breadth","for","thee","will","give","thy","seed","ever"]},{"verseId":"brenton_genesis_13_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":13,"verse":18,"text":"And Abram having removed his tent, came and dwelt by the oak of Mambre, which was in Chebrom, and he there built an altar to the Lord.","searchKeywords":["and","abram","having","removed","his","tent","came","dwelt","the","oak","mambre","which","was","chebrom","there","built","altar","lord"]}]