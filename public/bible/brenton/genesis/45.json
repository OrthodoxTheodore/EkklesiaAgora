[{"verseId":"brenton_genesis_45_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":1,"text":"And Joseph could not refrain himself when all were standing by him, but said, Dismiss all from me; and no one stood near Joseph, when he made himself known to his brethren.","searchKeywords":["and","joseph","could","not","refrain","himself","when","all","were","standing","him","but","said","dismiss","from","one","stood","near","made","known","his","brethren"]},{"verseId":"brenton_genesis_45_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":2,"text":"And he uttered his voice with weeping; and all the Egyptians heard, and it was reported to the house of Pharao.","searchKeywords":["and","uttered","his","voice","with","weeping","all","the","egyptians","heard","was","reported","house","pharao"]},{"verseId":"brenton_genesis_45_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":3,"text":"And Joseph said to his brethren, I am Joseph; doth my father yet live? And his brethren could not answer him, for they were troubled.","searchKeywords":["and","joseph","said","his","brethren","doth","father","yet","live","could","not","answer","him","for","they","were","troubled"]},{"verseId":"brenton_genesis_45_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":4,"text":"And Joseph said to his brethren, Draw nigh to me; and they drew nigh; and he said, I am your brother Joseph, whom ye sold into Egypt.","searchKeywords":["and","joseph","said","his","brethren","draw","nigh","they","drew","your","brother","whom","sold","into","egypt"]},{"verseId":"brenton_genesis_45_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":5,"text":"Now then be not grieved, and let it not seem hard to you that ye sold me hither, for God sent me before you for life.","searchKeywords":["now","then","not","grieved","and","let","seem","hard","you","that","sold","hither","for","god","sent","before","life"]},{"verseId":"brenton_genesis_45_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":6,"text":"For this second year there is famine on the earth, and there are yet five years remaining, in which there is to be neither ploughing, nor mowing.","searchKeywords":["for","this","second","year","there","famine","the","earth","and","are","yet","five","years","remaining","which","neither","ploughing","nor","mowing"]},{"verseId":"brenton_genesis_45_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":7,"text":"For God sent me before you, that there might be left to you a remnant upon the earth, even to nourish a great remnant of you.","searchKeywords":["for","god","sent","before","you","that","there","might","left","remnant","upon","the","earth","even","nourish","great"]},{"verseId":"brenton_genesis_45_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":8,"text":"Now then ye did not send me hither, but God; and he hath made me as a father of Pharao, and lord of all his house, and ruler of all the land of Egypt.","searchKeywords":["now","then","did","not","send","hither","but","god","and","hath","made","father","pharao","lord","all","his","house","ruler","the","land","egypt"]},{"verseId":"brenton_genesis_45_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":9,"text":"Hasten, therefore, and go up to my father, and say to him, These things saith thy son Joseph; God has made me lord of all the land of Egypt; come down therefore to me, and tarry not.","searchKeywords":["hasten","therefore","and","father","say","him","these","things","saith","thy","son","joseph","god","has","made","lord","all","the","land","egypt","come","down","tarry","not"]},{"verseId":"brenton_genesis_45_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":10,"text":"And thou shalt dwell in the land of Gesem of Arabia; and thou shalt be near me, thou and thy sons, and thy sons' sons, thy sheep and thine oxen, and whatsoever things are thine.","searchKeywords":["and","thou","shalt","dwell","the","land","gesem","arabia","near","thy","sons","sheep","thine","oxen","whatsoever","things","are"]},{"verseId":"brenton_genesis_45_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":11,"text":"And I will nourish thee there: for the famine is yet for five years; lest thou be consumed, and thy sons, and all thy possessions.","searchKeywords":["and","will","nourish","thee","there","for","the","famine","yet","five","years","lest","thou","consumed","thy","sons","all","possessions"]},{"verseId":"brenton_genesis_45_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":12,"text":"Behold, your eyes see, and the eyes of my brother Benjamin, that it is my mouth that speaks to you.","searchKeywords":["behold","your","eyes","see","and","the","brother","benjamin","that","mouth","speaks","you"]},{"verseId":"brenton_genesis_45_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":13,"text":"Report, therefore, to my father all my glory in Egypt, and all things that ye have seen, and make haste and bring down my father hither.","searchKeywords":["report","therefore","father","all","glory","egypt","and","things","that","have","seen","make","haste","bring","down","hither"]},{"verseId":"brenton_genesis_45_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":14,"text":"And he fell on his brother Benjamin's neck, and wept on him; and Benjamin wept on his neck.","searchKeywords":["and","fell","his","brother","benjamin","neck","wept","him"]},{"verseId":"brenton_genesis_45_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":15,"text":"And he kissed all his brethren, and wept on them; and after these things his brethren spoke to him.","searchKeywords":["and","kissed","all","his","brethren","wept","them","after","these","things","spoke","him"]},{"verseId":"brenton_genesis_45_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":16,"text":"And the report was carried into the house of Pharao, saying, Joseph's brethren are come; and Pharao was glad, and his household.","searchKeywords":["and","the","report","was","carried","into","house","pharao","saying","joseph","brethren","are","come","glad","his","household"]},{"verseId":"brenton_genesis_45_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":17,"text":"And Pharao said to Joseph, Say to thy brethren, Do this; fill your waggons, and depart into the land of Chanaan.","searchKeywords":["and","pharao","said","joseph","say","thy","brethren","this","fill","your","waggons","depart","into","the","land","chanaan"]},{"verseId":"brenton_genesis_45_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":18,"text":"And take up your father, and your possessions, and come to me; and I will give you of all the goods of Egypt, and ye shall eat the marrow of the land.","searchKeywords":["and","take","your","father","possessions","come","will","give","you","all","the","goods","egypt","shall","eat","marrow","land"]},{"verseId":"brenton_genesis_45_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":19,"text":"And do thou charge them thus; that they should take for them waggons out of the land of Egypt, for your little ones, and for your wives; and take up your father, and come.","searchKeywords":["and","thou","charge","them","thus","that","they","should","take","for","waggons","out","the","land","egypt","your","little","ones","wives","father","come"]},{"verseId":"brenton_genesis_45_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":20,"text":"And be not sparing in regard to your property, for all the good of Egypt shall be yours.","searchKeywords":["and","not","sparing","regard","your","property","for","all","the","good","egypt","shall","yours"]},{"verseId":"brenton_genesis_45_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":21,"text":"And the children of Israel did so; and Joseph gave to them waggons, according to the words spoken by king Pharao; and he gave them provision for the journey.","searchKeywords":["and","the","children","israel","did","joseph","gave","them","waggons","according","words","spoken","king","pharao","provision","for","journey"]},{"verseId":"brenton_genesis_45_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":22,"text":"And he gave to them all two sets of raiment apiece; but to Benjamin he gave three hundred pieces of gold, and five changes of raiment.","searchKeywords":["and","gave","them","all","two","sets","raiment","apiece","but","benjamin","three","hundred","pieces","gold","five","changes"]},{"verseId":"brenton_genesis_45_23","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":23,"text":"And to his father he sent at the same rate, and ten asses, bearing some of all the good things of Egypt, and ten mules, bearing bread for his father for the journey.","searchKeywords":["and","his","father","sent","the","same","rate","ten","asses","bearing","some","all","good","things","egypt","mules","bread","for","journey"]},{"verseId":"brenton_genesis_45_24","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":24,"text":"And he sent away his brethren, and they went; and he said to them, Be not angry by the way.","searchKeywords":["and","sent","away","his","brethren","they","went","said","them","not","angry","the","way"]},{"verseId":"brenton_genesis_45_25","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":25,"text":"And they went up out of Egypt, and came into the land of Chanaan, to Jacob their father.","searchKeywords":["and","they","went","out","egypt","came","into","the","land","chanaan","jacob","their","father"]},{"verseId":"brenton_genesis_45_26","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":26,"text":"And they reported to him, saying, Thy son Joseph is living, and he is ruler over all the land of Egypt; and Jacob was amazed, for he did not believe them.","searchKeywords":["and","they","reported","him","saying","thy","son","joseph","living","ruler","over","all","the","land","egypt","jacob","was","amazed","for","did","not","believe","them"]},{"verseId":"brenton_genesis_45_27","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":27,"text":"But they spoke to him all the words uttered by Joseph, whatsoever he said to them; and having seen the chariots which Joseph sent to take him up, the spirit of Jacob their father revived.","searchKeywords":["but","they","spoke","him","all","the","words","uttered","joseph","whatsoever","said","them","and","having","seen","chariots","which","sent","take","spirit","jacob","their","father","revived"]},{"verseId":"brenton_genesis_45_28","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":45,"verse":28,"text":"And Israel said, It is a great thing for me if Joseph my son is yet alive, I will go and see him before I die.","searchKeywords":["and","israel","said","great","thing","for","joseph","son","yet","alive","will","see","him","before","die"]}]