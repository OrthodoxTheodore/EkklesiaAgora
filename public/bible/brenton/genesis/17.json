[{"verseId":"brenton_genesis_17_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":1,"text":"And Abram was ninety-nine years old, and the Lord appeared to Abram and said to him, I am thy God, be well-pleasing before me, and be blameless.","searchKeywords":["and","abram","was","ninety","nine","years","old","the","lord","appeared","said","him","thy","god","well","pleasing","before","blameless"]},{"verseId":"brenton_genesis_17_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":2,"text":"And I will establish my covenant between me and thee, and I will multiply thee exceedingly.","searchKeywords":["and","will","establish","covenant","between","thee","multiply","exceedingly"]},{"verseId":"brenton_genesis_17_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":3,"text":"And Abram fell upon his face, and God spoke to him, saying,","searchKeywords":["and","abram","fell","upon","his","face","god","spoke","him","saying"]},{"verseId":"brenton_genesis_17_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":4,"text":"And I, behold! my covenant with thee, and thou shalt be a father of a multitude of nations.","searchKeywords":["and","behold","covenant","with","thee","thou","shalt","father","multitude","nations"]},{"verseId":"brenton_genesis_17_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":5,"text":"And thy name shall no more be called Abram, but thy name shall be Abraam, for I have made thee a father of many nations.","searchKeywords":["and","thy","name","shall","more","called","abram","but","abraam","for","have","made","thee","father","many","nations"]},{"verseId":"brenton_genesis_17_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":6,"text":"And I will increase thee very exceedingly, and I will make nations of thee, and kings shall come out of thee.","searchKeywords":["and","will","increase","thee","very","exceedingly","make","nations","kings","shall","come","out"]},{"verseId":"brenton_genesis_17_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":7,"text":"And I will establish my covenant between thee and thy seed after thee, to their generations, for an everlasting covenant, to be thy God, and of thy seed after thee.","searchKeywords":["and","will","establish","covenant","between","thee","thy","seed","after","their","generations","for","everlasting","god"]},{"verseId":"brenton_genesis_17_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":8,"text":"And I will give to thee and to thy seed after thee the land wherein thou sojournest, even all the land of Chanaan for an everlasting possession, and I will be to them a God.","searchKeywords":["and","will","give","thee","thy","seed","after","the","land","wherein","thou","sojournest","even","all","chanaan","for","everlasting","possession","them","god"]},{"verseId":"brenton_genesis_17_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":9,"text":"And God said to Abraam, Thou also shalt fully keep my covenant, thou and thy seed after thee for their generations.","searchKeywords":["and","god","said","abraam","thou","also","shalt","fully","keep","covenant","thy","seed","after","thee","for","their","generations"]},{"verseId":"brenton_genesis_17_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":10,"text":"And this the covenant which thou shalt fully keep between me and you, and between thy seed after thee for their generations; every male of you shall be circumcised.","searchKeywords":["and","this","the","covenant","which","thou","shalt","fully","keep","between","you","thy","seed","after","thee","for","their","generations","every","male","shall","circumcised"]},{"verseId":"brenton_genesis_17_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":11,"text":"And ye shall be circumcised in the flesh of your foreskin, and it shall be for a sign of a covenant between me and you.","searchKeywords":["and","shall","circumcised","the","flesh","your","foreskin","for","sign","covenant","between","you"]},{"verseId":"brenton_genesis_17_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":12,"text":"And the child of eight days shall be circumcised by you, every male throughout your generations, and born in the house and he that is bought with money, of every son of a stranger, who is not of thy seed.","searchKeywords":["and","the","child","eight","days","shall","circumcised","you","every","male","throughout","your","generations","born","house","that","bought","with","money","son","stranger","who","not","thy","seed"]},{"verseId":"brenton_genesis_17_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":13,"text":"He that is born in thy house, and he that is bought with money shall be surely circumcised, and my covenant shall be on your flesh for an everlasting covenant.","searchKeywords":["that","born","thy","house","and","bought","with","money","shall","surely","circumcised","covenant","your","flesh","for","everlasting"]},{"verseId":"brenton_genesis_17_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":14,"text":"And the uncircumcised male, who shall not be circumcised in the flesh of his foreskin on the eighth day, that soul shall be utterly destroyed from its family, for he has broken my covenant.","searchKeywords":["and","the","uncircumcised","male","who","shall","not","circumcised","flesh","his","foreskin","eighth","day","that","soul","utterly","destroyed","from","its","family","for","has","broken","covenant"]},{"verseId":"brenton_genesis_17_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":15,"text":"And God said to Abraam, Sara thy wife—her name shall not be called Sara, Sarrha shall be her name.","searchKeywords":["and","god","said","abraam","sara","thy","wife","her","name","shall","not","called","sarrha"]},{"verseId":"brenton_genesis_17_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":16,"text":"And I will bless her, and give thee a son of her, and I will bless him, and he shall become nations, and kings of nations shall be of him.","searchKeywords":["and","will","bless","her","give","thee","son","him","shall","become","nations","kings"]},{"verseId":"brenton_genesis_17_17","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":17,"text":"And Abraam fell upon his face, and laughed; and spoke in his heart, saying, Shall there be a child to one who is a hundred years old, and shall Sarrha who is ninety years old, bear?","searchKeywords":["and","abraam","fell","upon","his","face","laughed","spoke","heart","saying","shall","there","child","one","who","hundred","years","old","sarrha","ninety","bear"]},{"verseId":"brenton_genesis_17_18","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":18,"text":"And Abraam said to God, Let this Ismael live before thee.","searchKeywords":["and","abraam","said","god","let","this","ismael","live","before","thee"]},{"verseId":"brenton_genesis_17_19","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":19,"text":"And God said to Abraam, Yea, behold, Sarrha thy wife shall bear thee a son, and thou shalt call his name Isaac; and I will establish my covenant with him, for an everlasting covenant, to be a God to him and to his seed after him.","searchKeywords":["and","god","said","abraam","yea","behold","sarrha","thy","wife","shall","bear","thee","son","thou","shalt","call","his","name","isaac","will","establish","covenant","with","him","for","everlasting","seed","after"]},{"verseId":"brenton_genesis_17_20","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":20,"text":"And concerning Ismael, behold, I have heard thee, and, behold, I have blessed him, and will increase him and multiply him exceedingly; twelve nations shall he beget, and I will make him a great nation.","searchKeywords":["and","concerning","ismael","behold","have","heard","thee","blessed","him","will","increase","multiply","exceedingly","twelve","nations","shall","beget","make","great","nation"]},{"verseId":"brenton_genesis_17_21","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":21,"text":"But I will establish my covenant with Isaac, whom Sarrha shall bear to thee at this time, in the next year.","searchKeywords":["but","will","establish","covenant","with","isaac","whom","sarrha","shall","bear","thee","this","time","the","next","year"]},{"verseId":"brenton_genesis_17_22","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":17,"verse":22,"text":"And he left off speaking with him, and God went up from Abraam.","searchKeywords":["and","left","off","speaking","with","him","god","went","from","abraam"]},{"verseId":"brenton_genesis_17_23","translatio