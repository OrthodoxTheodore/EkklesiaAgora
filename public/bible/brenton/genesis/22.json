[{"verseId":"brenton_genesis_22_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":22,"verse":1,"text":"And it came to pass after these things that God tempted Abraam, and said to him, Abraam, Abraam; and he said, Lo! I .","searchKeywords":["and","came","pass","after","these","things","that","god","tempted","abraam","said","him"]},{"verseId":"brenton_genesis_22_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":22,"verse":2,"text":"And he said, Take thy son, the beloved one, whom thou hast loved—Isaac, and go into the high land, and offer him there for a whole-burnt-offering on one of the mountains which I will tell thee of.","searchKeywords":["and","said","take","thy","son","the","beloved","one","whom","thou","hast","loved","isaac","into","high","land","offer","him","there","for","whole","burnt","offering","mountains","which","will","tell","thee"]},{"verseId":"brenton_genesis_22_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":22,"verse":3,"text":"And Abraam rose up in the morning and saddled his ass, and he took with him two servants, and Isaac his son, and having split wood for a whole-burnt-offering, he arose and departed, and came to the place of which God spoke to him,","searchKeywords":["and","abraam","rose","the","morning","saddled","his","ass","took","with","him","two","servants","isaac","son","having","split","wood","for","whole","burnt","offering","arose","departed","came","place","which","god","spoke"]},{"verseId":"brenton_genesis_22_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":22,"verse":4,"text":"on the third day; and Abraam having lifted up his eyes, saw the place afar off.","searchKeywords":["the","third","day","and","abraam","having","lifted","his","eyes","saw","place","afar","off"]},{"verseId":"brenton_genesis_22_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":22,"verse":5,"text":"And Abraam said to his servants, Sit ye here with the ass, and I and the lad will proceed thus far, and having worshipped we will return to you.","searchKeywords":["and","abraam","said","his","servants","sit","here","with","the","ass","lad","will","proceed","thus","far","having","worshipped","return","you"]},{"verseId":"brenton_genesis_22_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":22,"verse":6,"text":"And Abraam took the wood of the whole-burnt-offering, and laid it on Isaac his son, and he took into his hands both the fire and the knife, and the two went together.","searchKeywords":["and","abraam","took","the","wood","whole","burnt","offering","laid","isaac","his","son","into","hands","both","fire","knife","two","went","together"]},{"verseId":"brenton_genesis_22_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":22,"verse":7,"text":"And Isaac said to Abraam his father, Father. And he said, What is it, son? And he said, Behold the fire and the wood, where is the sheep for a whole-burnt-offering?","searchKeywords":["and","isaac","said","abraam","his","father","what","son","behold","the","fire","wood","where","sheep","for","whole","burnt","offering"]},{"verseId":"brenton_genesis_22_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":22,"verse":8,"text":"And Abraam said, God will provide himself a sheep for a whole-burnt-offering, son. And both having gone together,","searchKeywords":["and","abraam","said","god","will","provide","himself","sheep","for","whole","burnt","offering","son","both","having","gone","together"]},{"verseId":"brenton_genesis_22_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Ge