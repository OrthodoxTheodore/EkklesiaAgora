[{"verseId":"brenton_genesis_16_1","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":1,"text":"And Sara the wife of Abram bore him no children; and she had an Egyptian maid, whose name was Agar.","searchKeywords":["and","sara","the","wife","abram","bore","him","children","she","had","egyptian","maid","whose","name","was","agar"]},{"verseId":"brenton_genesis_16_2","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":2,"text":"And Sara said to Abram, Behold, the Lord has restrained me from bearing, go therefore in to my maid, that I may get children for myself through her. And Abram hearkened to the voice of Sara.","searchKeywords":["and","sara","said","abram","behold","the","lord","has","restrained","from","bearing","therefore","maid","that","may","get","children","for","myself","through","her","hearkened","voice"]},{"verseId":"brenton_genesis_16_3","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":3,"text":"So Sara the wife of Abram having taken Agar the Egyptian her handmaid, after Abram had dwelt ten years in the land of Chanaan, gave her to Abram her husband as a wife to him.","searchKeywords":["sara","the","wife","abram","having","taken","agar","egyptian","her","handmaid","after","had","dwelt","ten","years","land","chanaan","gave","husband","him"]},{"verseId":"brenton_genesis_16_4","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":4,"text":"And he went in to Agar, and she conceived, and saw that she was with child, and her mistress was dishonoured before her.","searchKeywords":["and","went","agar","she","conceived","saw","that","was","with","child","her","mistress","dishonoured","before"]},{"verseId":"brenton_genesis_16_5","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":5,"text":"And Sara said to Abram, I am injured by thee; I gave my handmaid into thy bosom, and when I saw that she was with child, I was dishonoured before her. The Lord judge between me and thee.","searchKeywords":["and","sara","said","abram","injured","thee","gave","handmaid","into","thy","bosom","when","saw","that","she","was","with","child","dishonoured","before","her","the","lord","judge","between"]},{"verseId":"brenton_genesis_16_6","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":6,"text":"And Abram said to Sara, Behold thy handmaid is in thy hands, use her as it may seem good to thee. And Sara afflicted her, and she fled from her face.","searchKeywords":["and","abram","said","sara","behold","thy","handmaid","hands","use","her","may","seem","good","thee","afflicted","she","fled","from","face"]},{"verseId":"brenton_genesis_16_7","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":7,"text":"And an angel of the Lord found her by the fountain of water in the wilderness, by the fountain in the way to Sur.","searchKeywords":["and","angel","the","lord","found","her","fountain","water","wilderness","way","sur"]},{"verseId":"brenton_genesis_16_8","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":8,"text":"And the angel of the Lord said to her, Agar, Sara's maid, whence comest thou, and whither goest thou? and she said, I am fleeing from the face of my mistress Sara.","searchKeywords":["and","the","angel","lord","said","her","agar","sara","maid","whence","comest","thou","whither","goest","she","fleeing","from","face","mistress"]},{"verseId":"brenton_genesis_16_9","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":9,"text":"And the angel of the Lord said to her, Return to thy mistress, and submit thyself under her hands.","searchKeywords":["and","the","angel","lord","said","her","return","thy","mistress","submit","thyself","under","hands"]},{"verseId":"brenton_genesis_16_10","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":10,"text":"And the angel of the Lord said to her, I will surely multiply thy seed, and it shall not be numbered for multitude.","searchKeywords":["and","the","angel","lord","said","her","will","surely","multiply","thy","seed","shall","not","numbered","for","multitude"]},{"verseId":"brenton_genesis_16_11","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":11,"text":"And the angel of the Lord said to her, Behold, thou art with child, and shalt bear a son, and shalt call his name Ismael, for the Lord hath hearkened to thy humiliation.","searchKeywords":["and","the","angel","lord","said","her","behold","thou","art","with","child","shalt","bear","son","call","his","name","ismael","for","hath","hearkened","thy","humiliation"]},{"verseId":"brenton_genesis_16_12","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":12,"text":"He shall be a wild man, his hands against all, and the hands of all against him, and he shall dwell in the presence of all his brethren.","searchKeywords":["shall","wild","man","his","hands","against","all","and","the","him","dwell","presence","brethren"]},{"verseId":"brenton_genesis_16_13","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":13,"text":"And she called the name of the Lord God who spoke to her, Thou art God who seest me; for she said, For I have openly seen him that appeared to me.","searchKeywords":["and","she","called","the","name","lord","god","who","spoke","her","thou","art","seest","for","said","have","openly","seen","him","that","appeared"]},{"verseId":"brenton_genesis_16_14","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":14,"text":"Therefore she called the well, The well of him whom I have openly seen; behold it is between Cades and Barad.","searchKeywords":["therefore","she","called","the","well","him","whom","have","openly","seen","behold","between","cades","and","barad"]},{"verseId":"brenton_genesis_16_15","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":15,"text":"And Agar bore a son to Abram; and Abram called the name of his son which Agar bore to him, Ismael.","searchKeywords":["and","agar","bore","son","abram","called","the","name","his","which","him","ismael"]},{"verseId":"brenton_genesis_16_16","translationId":"brenton","testament":"OT","bookIndex":1,"bookName":"Genesis","bookAbbrev":"genesis","chapter":16,"verse":16,"text":"And Abram was eighty-six years old, when Agar bore Ismael to Abram.","searchKeywords":["and","abram","was","eighty","six","years","old","when","agar","bore","ismael"]}]