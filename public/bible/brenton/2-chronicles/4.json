[{"verseId":"brenton_2-chronicles_4_1","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":1,"text":"And he made a brazen altar, the length of it twenty cubits, and the breadth twenty cubits, and the height ten cubits.","searchKeywords":["and","made","brazen","altar","the","length","twenty","cubits","breadth","height","ten"]},{"verseId":"brenton_2-chronicles_4_2","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":2,"text":"And he made the molten sea, in diameter ten cubits, entirely round, and the height of it five cubits, and the circumference thirty cubits.","searchKeywords":["and","made","the","molten","sea","diameter","ten","cubits","entirely","round","height","five","circumference","thirty"]},{"verseId":"brenton_2-chronicles_4_3","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":3,"text":"And beneath it the likeness of calves, they compass it round about: ten cubits compass the laver round about, they cast the calves two rows in their casting,","searchKeywords":["and","beneath","the","likeness","calves","they","compass","round","about","ten","cubits","laver","cast","two","rows","their","casting"]},{"verseId":"brenton_2-chronicles_4_4","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":4,"text":"wherein they made them twelve calves,—three looking northwards, and three westwards, and three southwards, and three eastwards: and the sea was upon them above, their hinder parts were inward.","searchKeywords":["wherein","they","made","them","twelve","calves","three","looking","northwards","and","westwards","southwards","eastwards","the","sea","was","upon","above","their","hinder","parts","were","inward"]},{"verseId":"brenton_2-chronicles_4_5","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":5,"text":"And its thickness was a hand-breadth, and its brim as the brim of a cup, graven with flowers of lilies, holding three thousand measures: and he finished .","searchKeywords":["and","its","thickness","was","hand","breadth","brim","the","cup","graven","with","flowers","lilies","holding","three","thousand","measures","finished"]},{"verseId":"brenton_2-chronicles_4_6","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":6,"text":"And he made ten lavers, and set five on the right hand, and five on the left, to wash in them the instruments of the whole-burnt-offerings, and to rinse in them; and the sea for the priests to wash in.","searchKeywords":["and","made","ten","lavers","set","five","the","right","hand","left","wash","them","instruments","whole","burnt","offerings","rinse","sea","for","priests"]},{"verseId":"brenton_2-chronicles_4_7","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":7,"text":"And he made the ten golden candlesticks according to their pattern, and he put them in the temple, five on the right hand, and five on the left.","searchKeywords":["and","made","the","ten","golden","candlesticks","according","their","pattern","put","them","temple","five","right","hand","left"]},{"verseId":"brenton_2-chronicles_4_8","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":8,"text":"And he made ten tables, and put them in the temple, five on the right hand, and five on the left: and he made a hundred golden bowls.","searchKeywords":["and","made","ten","tables","put","them","the","temple","five","right","hand","left","hundred","golden","bowls"]},{"verseId":"brenton_2-chronicles_4_9","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":9,"text":"Also he made the priests' court, and the great court, and doors to the court, and their panels overlaid with brass.","searchKeywords":["also","made","the","priests","court","and","great","doors","their","panels","overlaid","with","brass"]},{"verseId":"brenton_2-chronicles_4_10","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":10,"text":"And he set the sea at the corner of the house on the right, as it were fronting the east.","searchKeywords":["and","set","the","sea","corner","house","right","were","fronting","east"]},{"verseId":"brenton_2-chronicles_4_11","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":11,"text":"And Chiram made the fleshhooks, and the fire-pans, and the grate of the altar, and all its instruments: and Chiram finished doing all the work which he wrought for king Solomon in the house of God:","searchKeywords":["and","chiram","made","the","fleshhooks","fire","pans","grate","altar","all","its","instruments","finished","doing","work","which","wrought","for","king","solomon","house","god"]},{"verseId":"brenton_2-chronicles_4_12","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":12,"text":"two pillars, and upon them an embossed work for the chapiters on the heads of the two pillars, and two nets to cover the heads of the chapiters which are on the heads of the pillars;","searchKeywords":["two","pillars","and","upon","them","embossed","work","for","the","chapiters","heads","nets","cover","which","are"]},{"verseId":"brenton_2-chronicles_4_13","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":13,"text":"and four hundred golden bells for the two nets, and two rows of pomegranates in each net, to cover the two embossed rims of the chapiters which are upon the pillars.","searchKeywords":["and","four","hundred","golden","bells","for","the","two","nets","rows","pomegranates","each","net","cover","embossed","rims","chapiters","which","are","upon","pillars"]},{"verseId":"brenton_2-chronicles_4_14","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":14,"text":"And he made the ten bases, and he made the lavers upon the bases;","searchKeywords":["and","made","the","ten","bases","lavers","upon"]},{"verseId":"brenton_2-chronicles_4_15","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":15,"text":"and the one sea, and the twelve calves under it;","searchKeywords":["and","the","one","sea","twelve","calves","under"]},{"verseId":"brenton_2-chronicles_4_16","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":16,"text":"and the foot-baths, and the buckets, and the caldrons, and the flesh-hooks, and all their furniture (which Chiram made, and brought to king Solomon in the house of the Lord) of pure brass.","searchKeywords":["and","the","foot","baths","buckets","caldrons","flesh","hooks","all","their","furniture","which","chiram","made","brought","king","solomon","house","lord","pure","brass"]},{"verseId":"brenton_2-chronicles_4_17","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":17,"text":"In the country round about Jordan the king cast them, in the clay ground in the house of Socchoth, and between Saredatha.","searchKeywords":["the","country","round","about","jordan","king","cast","them","clay","ground","house","socchoth","and","between","saredatha"]},{"verseId":"brenton_2-chronicles_4_18","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":18,"text":"So Solomon made all these vessels in great abundance, for the quantity of brass failed not.","searchKeywords":["solomon","made","all","these","vessels","great","abundance","for","the","quantity","brass","failed","not"]},{"verseId":"brenton_2-chronicles_4_19","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":19,"text":"And Solomon made all the vessels of the house of the Lord, and the golden altar, and the tables, and upon them the loaves of shewbread;","searchKeywords":["and","solomon","made","all","the","vessels","house","lord","golden","altar","tables","upon","them","loaves","shewbread"]},{"verseId":"brenton_2-chronicles_4_20","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":20,"text":"also the candlesticks, and the lamps to give light according to the pattern, and in front of the oracle, of pure gold.","searchKeywords":["also","the","candlesticks","and","lamps","give","light","according","pattern","front","oracle","pure","gold"]},{"verseId":"brenton_2-chronicles_4_21","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":21,"text":"And their snuffers, and their lamps , and the bowls, and the censers, and the fire-pans, of pure gold.","searchKeywords":["and","their","snuffers","lamps","the","bowls","censers","fire","pans","pure","gold"]},{"verseId":"brenton_2-chronicles_4_22","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":4,"verse":22,"text":"And the inner door of the house into the holy of holies, and the inner doors of the temple of gold. So all the work which Solomon wrought for the house of the Lord was finished.","searchKeywords":["and","the","inner","door","house","into","holy","holies","doors","temple","gold","all","work","which","solomon","wrought","for","lord","was","finished"]}]