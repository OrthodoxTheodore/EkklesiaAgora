[{"verseId":"brenton_2-chronicles_15_1","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":1,"text":"And Azarias the son of Oded—upon him came the Spirit of the Lord,","searchKeywords":["and","azarias","the","son","oded","upon","him","came","spirit","lord"]},{"verseId":"brenton_2-chronicles_15_2","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":2,"text":"and he went out to meet Asa, and all Juda and Benjamin, and said, Hear me, Asa, and all Juda and Benjamin. The Lord with you, while ye are with him; and if ye seek him out, he will be found of you; but if ye forsake him, he will forsake you.","searchKeywords":["and","went","out","meet","asa","all","juda","benjamin","said","hear","the","lord","with","you","while","are","him","seek","will","found","but","forsake"]},{"verseId":"brenton_2-chronicles_15_3","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":3,"text":"And Israel a long time without the true God, and without a priest to expound , and without the law.","searchKeywords":["and","israel","long","time","without","the","true","god","priest","expound","law"]},{"verseId":"brenton_2-chronicles_15_4","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":4,"text":"But he shall turn them to the Lord God of Israel, and he will be found of them.","searchKeywords":["but","shall","turn","them","the","lord","god","israel","and","will","found"]},{"verseId":"brenton_2-chronicles_15_5","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":5,"text":"And in that time there is no peace to one going out, or to one coming in, for the terror of the Lord is upon all that inhabit the lands.","searchKeywords":["and","that","time","there","peace","one","going","out","coming","for","the","terror","lord","upon","all","inhabit","lands"]},{"verseId":"brenton_2-chronicles_15_6","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":6,"text":"And nation shall fight against nation, and city against city; for God has confounded them with every affliction.","searchKeywords":["and","nation","shall","fight","against","city","for","god","has","confounded","them","with","every","affliction"]},{"verseId":"brenton_2-chronicles_15_7","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":7,"text":"But be ye strong, and let not your hands be weakened: for there is a reward for your work.","searchKeywords":["but","strong","and","let","not","your","hands","weakened","for","there","reward","work"]},{"verseId":"brenton_2-chronicles_15_8","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":8,"text":"And when heard these words, and the prophecy of Adad the prophet, then he strengthened himself, and cast out the abominations from all the land of Juda and Benjamin, and from the cities which Jeroboam possessed, in mount Ephraim, and he renewed the altar of the Lord, which was before the temple of the Lord.","searchKeywords":["and","when","heard","these","words","the","prophecy","adad","prophet","then","strengthened","himself","cast","out","abominations","from","all","land","juda","benjamin","cities","which","jeroboam","possessed","mount","ephraim","renewed","altar","lord","was","before","temple"]},{"verseId":"brenton_2-chronicles_15_9","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":9,"text":"And he assembled Juda and Benjamin, and the strangers that dwelt with him, of Ephraim, and of Manasse, and of Symeon: for many of Israel were joined to him, when they saw that the Lord his God was with him.","searchKeywords":["and","assembled","juda","benjamin","the","strangers","that","dwelt","with","him","ephraim","manasse","symeon","for","many","israel","were","joined","when","they","saw","lord","his","god","was"]},{"verseId":"brenton_2-chronicles_15_10","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":10,"text":"And they assembled at Jerusalem in the third month, in the fifteenth year of the reign of Asa.","searchKeywords":["and","they","assembled","jerusalem","the","third","month","fifteenth","year","reign","asa"]},{"verseId":"brenton_2-chronicles_15_11","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":11,"text":"And he sacrificed to the Lord in that day of the spoils which they brought, seven hundred calves and seven thousand sheep.","searchKeywords":["and","sacrificed","the","lord","that","day","spoils","which","they","brought","seven","hundred","calves","thousand","sheep"]},{"verseId":"brenton_2-chronicles_15_12","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":12,"text":"And he entered into a covenant that they should seek the Lord God of their fathers with all their heart and with all their soul.","searchKeywords":["and","entered","into","covenant","that","they","should","seek","the","lord","god","their","fathers","with","all","heart","soul"]},{"verseId":"brenton_2-chronicles_15_13","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":13,"text":"And that whoever should not seek the Lord God of Israel, should die, whether young or old, whether man or woman.","searchKeywords":["and","that","whoever","should","not","seek","the","lord","god","israel","die","whether","young","old","man","woman"]},{"verseId":"brenton_2-chronicles_15_14","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":14,"text":"And they swore to the Lord with a loud voice, and with trumpets, and with cornets.","searchKeywords":["and","they","swore","the","lord","with","loud","voice","trumpets","cornets"]},{"verseId":"brenton_2-chronicles_15_15","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":15,"text":"And all Juda rejoiced concerning the oath: for they swore with all their heart, and they sought him with all their desires; and he was found of them: and the Lord gave them rest round about.","searchKeywords":["and","all","juda","rejoiced","concerning","the","oath","for","they","swore","with","their","heart","sought","him","desires","was","found","them","lord","gave","rest","round","about"]},{"verseId":"brenton_2-chronicles_15_16","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":16,"text":"And he removed Maacha his mother from being priestess to Astarte; and he cut down the idol, and burnt it in the brook of Kedron.","searchKeywords":["and","removed","maacha","his","mother","from","being","priestess","astarte","cut","down","the","idol","burnt","brook","kedron"]},{"verseId":"brenton_2-chronicles_15_17","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":17,"text":"Nevertheless they removed not the high places: they still existed in Israel: nevertheless the heart of Asa was perfect all his days.","searchKeywords":["nevertheless","they","removed","not","the","high","places","still","existed","israel","heart","asa","was","perfect","all","his","days"]},{"verseId":"brenton_2-chronicles_15_18","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":18,"text":"And he brought in the holy things of David his father, and the holy things of the house of God, silver, and gold, and vessels.","searchKeywords":["and","brought","the","holy","things","david","his","father","house","god","silver","gold","vessels"]},{"verseId":"brenton_2-chronicles_15_19","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":15,"verse":19,"text":"And there was no war with him until the thirty-fifth year of the reign of Asa.","searchKeywords":["and","there","was","war","with","him","until","the","thirty","fifth","year","reign","asa"]}]