[{"verseId":"brenton_2-chronicles_14_1","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":1,"text":"And he did that which was good and right in the sight of the Lord his God.","searchKeywords":["and","did","that","which","was","good","right","the","sight","lord","his","god"]},{"verseId":"brenton_2-chronicles_14_2","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":2,"text":"And he removed the altars of the strange , and the high places, and broke the pillars in pieces, and cut down the groves:","searchKeywords":["and","removed","the","altars","strange","high","places","broke","pillars","pieces","cut","down","groves"]},{"verseId":"brenton_2-chronicles_14_3","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":3,"text":"and he told Juda to seek earnestly the Lord God of their fathers, and to perform the law and the commandments.","searchKeywords":["and","told","juda","seek","earnestly","the","lord","god","their","fathers","perform","law","commandments"]},{"verseId":"brenton_2-chronicles_14_4","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":4,"text":"And he removed from all the cities of Juda the altars and the idols, and established in quietness","searchKeywords":["and","removed","from","all","the","cities","juda","altars","idols","established","quietness"]},{"verseId":"brenton_2-chronicles_14_5","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":5,"text":"fortified cities in the land of Juda; for the land was quiet, and he had no war in these years; for the Lord gave him rest.","searchKeywords":["fortified","cities","the","land","juda","for","was","quiet","and","had","war","these","years","lord","gave","him","rest"]},{"verseId":"brenton_2-chronicles_14_6","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":6,"text":"And he said to Juda, Let us fortify these cities, and make walls, and towers, and gates, and bars: we shall prevail over the land, for as we have sought out the Lord our God, he has sought out us, and has given us rest round about, and prospered us.","searchKeywords":["and","said","juda","let","fortify","these","cities","make","walls","towers","gates","bars","shall","prevail","over","the","land","for","have","sought","out","lord","our","god","has","given","rest","round","about","prospered"]},{"verseId":"brenton_2-chronicles_14_7","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":7,"text":"And Asa had a force of armed men bearing shields and spears in the land of Juda, three hundred thousand, and in the land of Benjamin two hundred and eighty thousand targeteers and archers: all these were mighty warriors.","searchKeywords":["and","asa","had","force","armed","men","bearing","shields","spears","the","land","juda","three","hundred","thousand","benjamin","two","eighty","targeteers","archers","all","these","were","mighty","warriors"]},{"verseId":"brenton_2-chronicles_14_8","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":8,"text":"And Zare the Ethiopian went out against them, with a force of a million, and three hundred chariots; and came to Maresa.","searchKeywords":["and","zare","the","ethiopian","went","out","against","them","with","force","million","three","hundred","chariots","came","maresa"]},{"verseId":"brenton_2-chronicles_14_9","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":9,"text":"And Asa went out to meet him, and set the battle in array in the valley north of Maresa.","searchKeywords":["and","asa","went","out","meet","him","set","the","battle","array","valley","north","maresa"]},{"verseId":"brenton_2-chronicles_14_10","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":10,"text":"And Asa cried to the Lord his God, and said, O Lord, it is not impossible with thee to save by many or by few: strengthen us, O Lord our God; for we trust in thee, and in thy name have we come against this great multitude. O Lord our God, let not man prevail against thee.","searchKeywords":["and","asa","cried","the","lord","his","god","said","not","impossible","with","thee","save","many","few","strengthen","our","for","trust","thy","name","have","come","against","this","great","multitude","let","man","prevail"]},{"verseId":"brenton_2-chronicles_14_11","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":11,"text":"And the Lord smote the Ethiopians before Juda; and the Ethiopians fled.","searchKeywords":["and","the","lord","smote","ethiopians","before","juda","fled"]},{"verseId":"brenton_2-chronicles_14_12","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":12,"text":"And Asa and his people pursued them to Gedor; and the Ethiopians fell, so that they could not recover themselves; for they were crushed before the Lord, and before his host; and they took many spoils.","searchKeywords":["and","asa","his","people","pursued","them","gedor","the","ethiopians","fell","that","they","could","not","recover","themselves","for","were","crushed","before","lord","host","took","many","spoils"]},{"verseId":"brenton_2-chronicles_14_13","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":13,"text":"And they destroyed their towns round about Gedor; for a terror of the Lord was upon them: and they spoiled all their cities, for they had much spoil.","searchKeywords":["and","they","destroyed","their","towns","round","about","gedor","for","terror","the","lord","was","upon","them","spoiled","all","cities","had","much","spoil"]},{"verseId":"brenton_2-chronicles_14_14","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":14,"verse":14,"text":"Also they destroyed the tents of cattle, and the Alimazons, and took many sheep and camels, and returned to Jerusalem.","searchKeywords":["also","they","destroyed","the","tents","cattle","and","alimazons","took","many","sheep","camels","returned","jerusalem"]}]