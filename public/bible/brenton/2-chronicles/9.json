[{"verseId":"brenton_2-chronicles_9_1","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":1,"text":"And the queen of Saba heard the name of Solomon, and she came to Jerusalem with a very large force, to prove Solomon with hard questions, and camels bearing spices in abundance, and gold, and precious stones: and she came to Solomon, and told him all that was in her mind.","searchKeywords":["and","the","queen","saba","heard","name","solomon","she","came","jerusalem","with","very","large","force","prove","hard","questions","camels","bearing","spices","abundance","gold","precious","stones","told","him","all","that","was","her","mind"]},{"verseId":"brenton_2-chronicles_9_2","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":2,"text":"And Solomon told her all her words; and there passed not a word from Solomon which he told her not.","searchKeywords":["and","solomon","told","her","all","words","there","passed","not","word","from","which"]},{"verseId":"brenton_2-chronicles_9_3","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":3,"text":"And the queen of Saba saw the wisdom of Solomon, and the house which he had built,","searchKeywords":["and","the","queen","saba","saw","wisdom","solomon","house","which","had","built"]},{"verseId":"brenton_2-chronicles_9_4","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":4,"text":"and the meat of the tables, and the sitting of his servants, and the standing of his ministers, and their raiment; and his cupbearers, and their apparel; and the whole-burnt-offerings which he offered up in the house of the Lord; then she was in ecstasy.","searchKeywords":["and","the","meat","tables","sitting","his","servants","standing","ministers","their","raiment","cupbearers","apparel","whole","burnt","offerings","which","offered","house","lord","then","she","was","ecstasy"]},{"verseId":"brenton_2-chronicles_9_5","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":5,"text":"And she said to the king, a true report which I heard in my land concerning thy words, and concerning thy wisdom.","searchKeywords":["and","she","said","the","king","true","report","which","heard","land","concerning","thy","words","wisdom"]},{"verseId":"brenton_2-chronicles_9_6","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":6,"text":"Yet I believed not the reports until I came, and my eyes saw: and, behold, the half of the abundance of thy wisdom was not told me: thou hast exceeded the report which I heard.","searchKeywords":["yet","believed","not","the","reports","until","came","and","eyes","saw","behold","half","abundance","thy","wisdom","was","told","thou","hast","exceeded","report","which","heard"]},{"verseId":"brenton_2-chronicles_9_7","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":7,"text":"Blessed thy men, blessed these thy servants, who stand before thee continually, and hear thy wisdom.","searchKeywords":["blessed","thy","men","these","servants","who","stand","before","thee","continually","and","hear","wisdom"]},{"verseId":"brenton_2-chronicles_9_8","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":8,"text":"Blessed be the Lord thy God, who took pleasure in thee, to set thee upon his throne for a king, to the Lord thy God: forasmuch as the Lord thy God loved Israel to establish them for ever, therefore he has set thee over them for a king to execute judgment and justice.","searchKeywords":["blessed","the","lord","thy","god","who","took","pleasure","thee","set","upon","his","throne","for","king","forasmuch","loved","israel","establish","them","ever","therefore","has","over","execute","judgment","and","justice"]},{"verseId":"brenton_2-chronicles_9_9","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":9,"text":"And she gave the king a hundred and twenty talents of gold, and spices in very great abundance, and precious stones: and there were not such spices as those which the queen of Saba gave king Solomon.","searchKeywords":["and","she","gave","the","king","hundred","twenty","talents","gold","spices","very","great","abundance","precious","stones","there","were","not","such","those","which","queen","saba","solomon"]},{"verseId":"brenton_2-chronicles_9_10","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":10,"text":"And the servants of Solomon and the servants of Chiram brought gold to Solomon out of Suphir, and pine timber, and precious stones.","searchKeywords":["and","the","servants","solomon","chiram","brought","gold","out","suphir","pine","timber","precious","stones"]},{"verseId":"brenton_2-chronicles_9_11","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":11,"text":"And the king made of the pine timber steps to the house of the Lord, and to the king's house, and harps and lutes for the singers: and such were not seen before in the land of Juda.","searchKeywords":["and","the","king","made","pine","timber","steps","house","lord","harps","lutes","for","singers","such","were","not","seen","before","land","juda"]},{"verseId":"brenton_2-chronicles_9_12","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":12,"text":"And king Solomon gave to the queen of Saba all that she requested, besides all that she brought to king Solomon: and she returned to her land.","searchKeywords":["and","king","solomon","gave","the","queen","saba","all","that","she","requested","besides","brought","returned","her","land"]},{"verseId":"brenton_2-chronicles_9_13","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":13,"text":"And the weight of the gold that was brought to Solomon in one year was six hundred and sixty-six talents of gold,","searchKeywords":["and","the","weight","gold","that","was","brought","solomon","one","year","six","hundred","sixty","talents"]},{"verseId":"brenton_2-chronicles_9_14","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":14,"text":"besides what the men who were regularly appointed and the merchants brought, and all the kings of Arabia and princes of the land: all brought gold and silver to king Solomon.","searchKeywords":["besides","what","the","men","who","were","regularly","appointed","and","merchants","brought","all","kings","arabia","princes","land","gold","silver","king","solomon"]},{"verseId":"brenton_2-chronicles_9_15","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":15,"text":"And king Solomon made two hundred shields of beaten gold: there were six hundred of pure gold to one shield.","searchKeywords":["and","king","solomon","made","two","hundred","shields","beaten","gold","there","were","six","pure","one","shield"]},{"verseId":"brenton_2-chronicles_9_16","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":16,"text":"And three hundred bucklers of beaten gold: of three hundred gold shekels went to one buckler: and the king placed them in the house of the forest of Lebanon.","searchKeywords":["and","three","hundred","bucklers","beaten","gold","shekels","went","one","buckler","the","king","placed","them","house","forest","lebanon"]},{"verseId":"brenton_2-chronicles_9_17","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":17,"text":"And the king made a great throne of ivory, and he gilded it with pure gold.","searchKeywords":["and","the","king","made","great","throne","ivory","gilded","with","pure","gold"]},{"verseId":"brenton_2-chronicles_9_18","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":18,"text":"And six steps to the throne, riveted with gold, and elbows on either side of the seat of the throne, and two lions standing by the elbows:","searchKeywords":["and","six","steps","the","throne","riveted","with","gold","elbows","either","side","seat","two","lions","standing"]},{"verseId":"brenton_2-chronicles_9_19","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":19,"text":"and twelve lions standing there on the six steps on each side. There was not the like in any kingdom.","searchKeywords":["and","twelve","lions","standing","there","the","six","steps","each","side","was","not","like","any","kingdom"]},{"verseId":"brenton_2-chronicles_9_20","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":20,"text":"And all king Solomon's vessels were of gold, and all the vessels of the house of the forest of Lebanon were covered with gold: silver was not thought anything of in the days of Solomon.","searchKeywords":["and","all","king","solomon","vessels","were","gold","the","house","forest","lebanon","covered","with","silver","was","not","thought","anything","days"]},{"verseId":"brenton_2-chronicles_9_21","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":21,"text":"For a ship went for the king to Tharsis with the servants of Chiram: once every three years came vessels from Tharsis to the king, laden with gold, and silver, and ivory, and apes.","searchKeywords":["for","ship","went","the","king","tharsis","with","servants","chiram","once","every","three","years","came","vessels","from","laden","gold","and","silver","ivory","apes"]},{"verseId":"brenton_2-chronicles_9_22","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":22,"text":"And Solomon exceeded all kings both in riches and wisdom.","searchKeywords":["and","solomon","exceeded","all","kings","both","riches","wisdom"]},{"verseId":"brenton_2-chronicles_9_23","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":23,"text":"And all the kings of the earth sought the presence of Solomon, to hear his wisdom, which God had put in his heart.","searchKeywords":["and","all","the","kings","earth","sought","presence","solomon","hear","his","wisdom","which","god","had","put","heart"]},{"verseId":"brenton_2-chronicles_9_24","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":24,"text":"And they brought every one his gifts, silver vessels and golden vessels, and raiment, myrrh and spices, horses and mules, a rate every year.","searchKeywords":["and","they","brought","every","one","his","gifts","silver","vessels","golden","raiment","myrrh","spices","horses","mules","rate","year"]},{"verseId":"brenton_2-chronicles_9_25","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":25,"text":"And Solomon had four thousand mares for chariots, and twelve thousand horsemen; and he put them in the chariot cities, and with the king in Jerusalem.","searchKeywords":["and","solomon","had","four","thousand","mares","for","chariots","twelve","horsemen","put","them","the","chariot","cities","with","king","jerusalem"]},{"verseId":"brenton_2-chronicles_9_26","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":26,"text":"And he ruled over all the kings from the river even to the land of the Philistines, and to the borders of Egypt.","searchKeywords":["and","ruled","over","all","the","kings","from","river","even","land","philistines","borders","egypt"]},{"verseId":"brenton_2-chronicles_9_27","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":27,"text":"And the king made gold and silver in Jerusalem as stones, and cedars as the sycamore trees in the plain for abundance.","searchKeywords":["and","the","king","made","gold","silver","jerusalem","stones","cedars","sycamore","trees","plain","for","abundance"]},{"verseId":"brenton_2-chronicles_9_28","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":28,"text":"And Solomon imported horses from Egypt, and from every country.","searchKeywords":["and","solomon","imported","horses","from","egypt","every","country"]},{"verseId":"brenton_2-chronicles_9_29","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":29,"text":"And the rest of the acts of Solomon, the first and the last, behold, these are written in the words of Nathan the prophet, and in the words of Achia the Selonite, and in the visions of Joel the seer concerning Jeroboam the son of Nabat.","searchKeywords":["and","the","rest","acts","solomon","first","last","behold","these","are","written","words","nathan","prophet","achia","selonite","visions","joel","seer","concerning","jeroboam","son","nabat"]},{"verseId":"brenton_2-chronicles_9_30","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":30,"text":"And Solomon reigned over all Israel forty years.","searchKeywords":["and","solomon","reigned","over","all","israel","forty","years"]},{"verseId":"brenton_2-chronicles_9_31","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":9,"verse":31,"text":"And Solomon fell asleep, and they buried him in the city of David his father: and Roboam his son reigned in his stead.","searchKeywords":["and","solomon","fell","asleep","they","buried","him","the","city","david","his","father","roboam","son","reigned","stead"]}]