[{"verseId":"brenton_2-chronicles_11_1","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":1,"text":"And Roboam came to Jerusalem; and he assembled Juda and Benjamin, a hundred and eighty thousand young men fit for war, and he waged war with Israel to recover the kingdom to Roboam.","searchKeywords":["and","roboam","came","jerusalem","assembled","juda","benjamin","hundred","eighty","thousand","young","men","fit","for","war","waged","with","israel","recover","the","kingdom"]},{"verseId":"brenton_2-chronicles_11_2","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":2,"text":"And the word of the Lord came to Samaias the man of God, saying,","searchKeywords":["and","the","word","lord","came","samaias","man","god","saying"]},{"verseId":"brenton_2-chronicles_11_3","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":3,"text":"Speak to Roboam the of Solomon, and to all Juda and Benjamin, saying,","searchKeywords":["speak","roboam","the","solomon","and","all","juda","benjamin","saying"]},{"verseId":"brenton_2-chronicles_11_4","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":4,"text":"Thus saith the Lord, Ye shall not go up, and ye shall not war against your brethren: return every one to his home; for this thing is of me. And they hearkened to the word of the Lord, and returned from going against Jeroboam.","searchKeywords":["thus","saith","the","lord","shall","not","and","war","against","your","brethren","return","every","one","his","home","for","this","thing","they","hearkened","word","returned","from","going","jeroboam"]},{"verseId":"brenton_2-chronicles_11_5","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":5,"text":"And Roboam dwelt in Jerusalem, and he built walled cities in Judæa.","searchKeywords":["and","roboam","dwelt","jerusalem","built","walled","cities","jud"]},{"verseId":"brenton_2-chronicles_11_6","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":6,"text":"And he built Bethleem, and Ætan and Thecoe,","searchKeywords":["and","built","bethleem","tan","thecoe"]},{"verseId":"brenton_2-chronicles_11_7","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":7,"text":"and Bæthsura, and Sochoth, and Odollam,","searchKeywords":["and","thsura","sochoth","odollam"]},{"verseId":"brenton_2-chronicles_11_8","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":8,"text":"and Geth, and Marisa, and Ziph,","searchKeywords":["and","geth","marisa","ziph"]},{"verseId":"brenton_2-chronicles_11_9","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":9,"text":"and Adorai, and Lachis, and Azeca,","searchKeywords":["and","adorai","lachis","azeca"]},{"verseId":"brenton_2-chronicles_11_10","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":10,"text":"and Saraa, and Ælom, and Chebron, which belongs to Juda and Benjamin, walled cities.","searchKeywords":["and","saraa","lom","chebron","which","belongs","juda","benjamin","walled","cities"]},{"verseId":"brenton_2-chronicles_11_11","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":11,"text":"And he fortified them with walls, and placed in them captains, and stores of provisions, oil and wine,","searchKeywords":["and","fortified","them","with","walls","placed","captains","stores","provisions","oil","wine"]},{"verseId":"brenton_2-chronicles_11_12","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":12,"text":"shields and spears in every several city, and he fortified them very strongly, and he had on his side Juda and Benjamin.","searchKeywords":["shields","and","spears","every","several","city","fortified","them","very","strongly","had","his","side","juda","benjamin"]},{"verseId":"brenton_2-chronicles_11_13","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":13,"text":"And the priests and the Levites who were in all Israel were gathered to him out of all the coasts.","searchKeywords":["and","the","priests","levites","who","were","all","israel","gathered","him","out","coasts"]},{"verseId":"brenton_2-chronicles_11_14","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":14,"text":"For the Levites left the tents of their possession, and went to Juda to Jerusalem, because Jeroboam and his sons had ejected them so that they should not minister to the Lord.","searchKeywords":["for","the","levites","left","tents","their","possession","and","went","juda","jerusalem","because","jeroboam","his","sons","had","ejected","them","that","they","should","not","minister","lord"]},{"verseId":"brenton_2-chronicles_11_15","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":15,"text":"And he made for himself priests of the high places, and for the idols, and for the vanities, and for the calves which Jeroboam made.","searchKeywords":["and","made","for","himself","priests","the","high","places","idols","vanities","calves","which","jeroboam"]},{"verseId":"brenton_2-chronicles_11_16","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":16,"text":"And he cast out from the tribes of Israel those who set their heart to seek the Lord God of Israel: and they came to Jerusalem, to sacrifice to the Lord God of their fathers.","searchKeywords":["and","cast","out","from","the","tribes","israel","those","who","set","their","heart","seek","lord","god","they","came","jerusalem","sacrifice","fathers"]},{"verseId":"brenton_2-chronicles_11_17","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":17,"text":"And they strengthened the kingdom of Juda; and strengthened Roboam the of Solomon for three years, for he walked three years in the ways of David and Solomon.","searchKeywords":["and","they","strengthened","the","kingdom","juda","roboam","solomon","for","three","years","walked","ways","david"]},{"verseId":"brenton_2-chronicles_11_18","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":18,"text":"And Roboam took to himself for a wife Moolath daughter of Jerimuth the son of David, and Abigaia daughter of Heliab the son of Jessæ.","searchKeywords":["and","roboam","took","himself","for","wife","moolath","daughter","jerimuth","the","son","david","abigaia","heliab","jess"]},{"verseId":"brenton_2-chronicles_11_19","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":19,"text":"And she bore him sons; Jeus, and Samoria, and Zaam.","searchKeywords":["and","she","bore","him","sons","jeus","samoria","zaam"]},{"verseId":"brenton_2-chronicles_11_20","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":20,"text":"And afterwards he took to himself Maacha the daughter of Abessalom; and she bore him Abia, and Jetthi, and Zeza, and Salemoth.","searchKeywords":["and","afterwards","took","himself","maacha","the","daughter","abessalom","she","bore","him","abia","jetthi","zeza","salemoth"]},{"verseId":"brenton_2-chronicles_11_21","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":21,"text":"And Roboam loved Maacha the daughter of Abessalom more than all his wives and all his concubines: for he had eighteen wives and sixty concubines; and he begot twenty-eight sons, and sixty daughters.","searchKeywords":["and","roboam","loved","maacha","the","daughter","abessalom","more","than","all","his","wives","concubines","for","had","eighteen","sixty","begot","twenty","eight","sons","daughters"]},{"verseId":"brenton_2-chronicles_11_22","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":22,"text":"And he made Abia the son of Maacha chief, a leader among his brethren, for he intended to make him king.","searchKeywords":["and","made","abia","the","son","maacha","chief","leader","among","his","brethren","for","intended","make","him","king"]},{"verseId":"brenton_2-chronicles_11_23","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":11,"verse":23,"text":"And he was exalted beyond all his sons in all the coasts of Juda and Benjamin, and in the strong cities; and he gave them provisions in great abundance: and he desired many wives.","searchKeywords":["and","was","exalted","beyond","all","his","sons","the","coasts","juda","benjamin","strong","cities","gave","them","provisions","great","abundance","desired","many","wives"]}]