[{"verseId":"brenton_2-chronicles_17_1","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":1,"text":"And Josaphat his son reigned in his stead, and Josaphat strengthened himself against Israel.","searchKeywords":["and","josaphat","his","son","reigned","stead","strengthened","himself","against","israel"]},{"verseId":"brenton_2-chronicles_17_2","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":2,"text":"And he put garrisons in all the strong cities of Juda, and appointed captains in all the cities of Juda, and in the cities of Ephraim, which Asa his father had taken.","searchKeywords":["and","put","garrisons","all","the","strong","cities","juda","appointed","captains","ephraim","which","asa","his","father","had","taken"]},{"verseId":"brenton_2-chronicles_17_3","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":3,"text":"And the Lord was with Josaphat, for he walked in the first ways of his father, and did not seek to idols;","searchKeywords":["and","the","lord","was","with","josaphat","for","walked","first","ways","his","father","did","not","seek","idols"]},{"verseId":"brenton_2-chronicles_17_4","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":4,"text":"but he sought to the Lord God of his father, and walked in the commandments of his father, and not according to the works of Israel.","searchKeywords":["but","sought","the","lord","god","his","father","and","walked","commandments","not","according","works","israel"]},{"verseId":"brenton_2-chronicles_17_5","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":5,"text":"And the Lord prospered the kingdom in his hand; and all Juda gave gifts to Josaphat; and he had great wealth and glory.","searchKeywords":["and","the","lord","prospered","kingdom","his","hand","all","juda","gave","gifts","josaphat","had","great","wealth","glory"]},{"verseId":"brenton_2-chronicles_17_6","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":6,"text":"And his heart was exalted in the way of the Lord; and he removed the high places and the groves from the land of Juda.","searchKeywords":["and","his","heart","was","exalted","the","way","lord","removed","high","places","groves","from","land","juda"]},{"verseId":"brenton_2-chronicles_17_7","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":7,"text":"And in the third year of his reign, he sent his chief men, and his mighty men, Abdias and Zacharias, and Nathanael, and Michaias, to teach in the cities of Juda.","searchKeywords":["and","the","third","year","his","reign","sent","chief","men","mighty","abdias","zacharias","nathanael","michaias","teach","cities","juda"]},{"verseId":"brenton_2-chronicles_17_8","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":8,"text":"And with them the Levites, Samaias, and Nathanias, and Zabdias, and Asiel, and Semiramoth, and Jonathan, and Adonias, and Tobias, and Tobadonias, Levites, and with them Elisama and Joram, the priests.","searchKeywords":["and","with","them","the","levites","samaias","nathanias","zabdias","asiel","semiramoth","jonathan","adonias","tobias","tobadonias","elisama","joram","priests"]},{"verseId":"brenton_2-chronicles_17_9","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":9,"text":"And they taught in Juda, and with them the book of the law of the Lord, and they passed through the cities of Juda, and taught the people.","searchKeywords":["and","they","taught","juda","with","them","the","book","law","lord","passed","through","cities","people"]},{"verseId":"brenton_2-chronicles_17_10","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":10,"text":"And a terror of the Lord was upon all the kingdoms of the land round about Juda, and they made no war against Josaphat.","searchKeywords":["and","terror","the","lord","was","upon","all","kingdoms","land","round","about","juda","they","made","war","against","josaphat"]},{"verseId":"brenton_2-chronicles_17_11","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":11,"text":"And of the Philistines brought to Josaphat gifts, and silver, and presents; and the Arabians brought him seven thousand seven hundred rams.","searchKeywords":["and","the","philistines","brought","josaphat","gifts","silver","presents","arabians","him","seven","thousand","hundred","rams"]},{"verseId":"brenton_2-chronicles_17_12","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":12,"text":"And Josaphat increased in greatness exceedingly, and built in Judea places of abode, and strong cities.","searchKeywords":["and","josaphat","increased","greatness","exceedingly","built","judea","places","abode","strong","cities"]},{"verseId":"brenton_2-chronicles_17_13","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":13,"text":"And he had many works in Judea: and the mighty men of war, of strength, in Jerusalem.","searchKeywords":["and","had","many","works","judea","the","mighty","men","war","strength","jerusalem"]},{"verseId":"brenton_2-chronicles_17_14","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":14,"text":"And this their number according to the houses of their fathers; even the captains of thousands in Juda , Ednas the chief, and with him mighty men of strength three hundred thousand.","searchKeywords":["and","this","their","number","according","the","houses","fathers","even","captains","thousands","juda","ednas","chief","with","him","mighty","men","strength","three","hundred","thousand"]},{"verseId":"brenton_2-chronicles_17_15","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":15,"text":"And after him, Joanan the captain, and with him two hundred and eighty thousand.","searchKeywords":["and","after","him","joanan","the","captain","with","two","hundred","eighty","thousand"]},{"verseId":"brenton_2-chronicles_17_16","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":16,"text":"And after him Amasias the of Zari, who was zealous for the Lord; and with him two hundred thousand mighty men of strength.","searchKeywords":["and","after","him","amasias","the","zari","who","was","zealous","for","lord","with","two","hundred","thousand","mighty","men","strength"]},{"verseId":"brenton_2-chronicles_17_17","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":17,"text":"And out of Benjamin a mighty man of strength, even Eliada, and with him two hundred thousand archers and targeteers.","searchKeywords":["and","out","benjamin","mighty","man","strength","even","eliada","with","him","two","hundred","thousand","archers","targeteers"]},{"verseId":"brenton_2-chronicles_17_18","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":18,"text":"And after him Jozabad, and with him a hundred and eighty thousand mighty men of war.","searchKeywords":["and","after","him","jozabad","with","hundred","eighty","thousand","mighty","men","war"]},{"verseId":"brenton_2-chronicles_17_19","translationId":"brenton","testament":"OT","bookIndex":14,"bookName":"2 Chronicles","bookAbbrev":"2-chronicles","chapter":17,"verse":19,"text":"These were the king's servants, besides those whom the king put in the strong cities in all Judea.","searchKeywords":["these","were","the","king","servants","besides","those","whom","put","strong","cities","all","judea"]}]