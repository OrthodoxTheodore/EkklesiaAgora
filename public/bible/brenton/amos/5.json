[{"verseId":"brenton_amos_5_1","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":1,"text":"Hear ye this word of the Lord, even a lamentation, which I take up against you. The house of Israel is fallen; it shall no more rise.","searchKeywords":["hear","this","word","the","lord","even","lamentation","which","take","against","you","house","israel","fallen","shall","more","rise"]},{"verseId":"brenton_amos_5_2","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":2,"text":"The virgin of Israel has fallen upon his land; there is none that shall raise her up.","searchKeywords":["the","virgin","israel","has","fallen","upon","his","land","there","none","that","shall","raise","her"]},{"verseId":"brenton_amos_5_3","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":3,"text":"Therefore thus saith the Lord God; The city out of which there went forth a thousand, there shall be left a hundred, and out of which there went forth a hundred, there shall be left ten to the house of Israel.","searchKeywords":["therefore","thus","saith","the","lord","god","city","out","which","there","went","forth","thousand","shall","left","hundred","and","ten","house","israel"]},{"verseId":"brenton_amos_5_4","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":4,"text":"Wherefore thus saith the Lord to the house of Israel, Seek ye me, and ye shall live.","searchKeywords":["wherefore","thus","saith","the","lord","house","israel","seek","and","shall","live"]},{"verseId":"brenton_amos_5_5","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":5,"text":"But seek not Bæthel, and go not in to Galgala, and cross not over to the Well of the Oath: for Galgala shall surely go into captivity, and Bæthel shall be as that which is not.","searchKeywords":["but","seek","not","thel","and","galgala","cross","over","the","well","oath","for","shall","surely","into","captivity","that","which"]},{"verseId":"brenton_amos_5_6","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":6,"text":"Seek ye the Lord, and ye shall live; lest the house of Joseph blaze as fire, and it devour him, and there shall be none to quench it for the house of Israel.","searchKeywords":["seek","the","lord","and","shall","live","lest","house","joseph","blaze","fire","devour","him","there","none","quench","for","israel"]},{"verseId":"brenton_amos_5_7","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":7,"text":"that executes judgment in the height , and he has established justice on the earth:","searchKeywords":["that","executes","judgment","the","height","and","has","established","justice","earth"]},{"verseId":"brenton_amos_5_8","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":8,"text":"who makes all things, and changes , and turns darkness into the morning, and darkens the day into night: who calls for the water of the sea, and pours it out on the face of the earth: the Lord is his name:","searchKeywords":["who","makes","all","things","and","changes","turns","darkness","into","the","morning","darkens","day","night","calls","for","water","sea","pours","out","face","earth","lord","his","name"]},{"verseId":"brenton_amos_5_9","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":9,"text":"who dispenses ruin to strength, and brings distress upon the fortress.","searchKeywords":["who","dispenses","ruin","strength","and","brings","distress","upon","the","fortress"]},{"verseId":"brenton_amos_5_10","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":10,"text":"They hated him that reproved in the gates, and abhorred holy speech.","searchKeywords":["they","hated","him","that","reproved","the","gates","and","abhorred","holy","speech"]},{"verseId":"brenton_amos_5_11","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":11,"text":"Therefore because they have smitten the poor with their fists, and ye have received of them choice gifts; ye have built polished houses, but ye shall not dwell in them; ye have planted desirable vineyards, but ye shall not drink the wine of them.","searchKeywords":["therefore","because","they","have","smitten","the","poor","with","their","fists","and","received","them","choice","gifts","built","polished","houses","but","shall","not","dwell","planted","desirable","vineyards","drink","wine"]},{"verseId":"brenton_amos_5_12","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":12,"text":"For I know your many transgressions, and your sins are great, trampling on the just, taking bribes, and turning aside the poor in the gates.","searchKeywords":["for","know","your","many","transgressions","and","sins","are","great","trampling","the","just","taking","bribes","turning","aside","poor","gates"]},{"verseId":"brenton_amos_5_13","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":13,"text":"Therefore the prudent shall be silent at that time; for it is a time of evils.","searchKeywords":["therefore","the","prudent","shall","silent","that","time","for","evils"]},{"verseId":"brenton_amos_5_14","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":14,"text":"Seek good, and not evil, that ye may live: and so the Lord God Almighty shall be with you, as ye have said,","searchKeywords":["seek","good","and","not","evil","that","may","live","the","lord","god","almighty","shall","with","you","have","said"]},{"verseId":"brenton_amos_5_15","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":15,"text":"We have hated evil, and loved good: and restore ye judgment in the gates; that the Lord God Almighty may have mercy on the remnant of Joseph.","searchKeywords":["have","hated","evil","and","loved","good","restore","judgment","the","gates","that","lord","god","almighty","may","mercy","remnant","joseph"]},{"verseId":"brenton_amos_5_16","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":16,"text":"Therefore thus saith the Lord God Almighty; In all the streets lamentations; and in all the ways shall it be said, Woe, woe! the husbandman shall be called to mourning and lamentation, and to them that are skilled in complaining.","searchKeywords":["therefore","thus","saith","the","lord","god","almighty","all","streets","lamentations","and","ways","shall","said","woe","husbandman","called","mourning","lamentation","them","that","are","skilled","complaining"]},{"verseId":"brenton_amos_5_17","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":17,"text":"And lamentation in all the ways; because I will pass through the midst of thee, saith the Lord.","searchKeywords":["and","lamentation","all","the","ways","because","will","pass","through","midst","thee","saith","lord"]},{"verseId":"brenton_amos_5_18","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":18,"text":"Woe to you that desire the day of the Lord! what is this day of the Lord to you? whereas it is darkness, and not light.","searchKeywords":["woe","you","that","desire","the","day","lord","what","this","whereas","darkness","and","not","light"]},{"verseId":"brenton_amos_5_19","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":19,"text":"As if a man should flee from the face of a lion, and a bear should meet him; and he should spring into his house, and lean his hands upon the wall, and a serpent should bite him.","searchKeywords":["man","should","flee","from","the","face","lion","and","bear","meet","him","spring","into","his","house","lean","hands","upon","wall","serpent","bite"]},{"verseId":"brenton_amos_5_20","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":20,"text":"Is not the day of the Lord darkness, and not light? and is not this gloom without brightness?","searchKeywords":["not","the","day","lord","darkness","and","light","this","gloom","without","brightness"]},{"verseId":"brenton_amos_5_21","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":21,"text":"I hate, I reject your feasts, and I will not smell meat-offerings in your general assemblies.","searchKeywords":["hate","reject","your","feasts","and","will","not","smell","meat","offerings","general","assemblies"]},{"verseId":"brenton_amos_5_22","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":22,"text":"Wherefore if ye should bring me your whole-burnt-sacrifices and meat-offerings, I will not accept : neither will I have respect to your grand peace-offerings.","searchKeywords":["wherefore","should","bring","your","whole","burnt","sacrifices","and","meat","offerings","will","not","accept","neither","have","respect","grand","peace"]},{"verseId":"brenton_amos_5_23","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":23,"text":"Remove from me the sound of thy songs, and I will not hear the music of thine instruments.","searchKeywords":["remove","from","the","sound","thy","songs","and","will","not","hear","music","thine","instruments"]},{"verseId":"brenton_amos_5_24","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":24,"text":"But let judgment roll down as water, and righteousness as an impassable torrent.","searchKeywords":["but","let","judgment","roll","down","water","and","righteousness","impassable","torrent"]},{"verseId":"brenton_amos_5_25","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":25,"text":"Have ye offered to me victims and sacrifices, O house of Israel, forty years in the wilderness?","searchKeywords":["have","offered","victims","and","sacrifices","house","israel","forty","years","the","wilderness"]},{"verseId":"brenton_amos_5_26","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":26,"text":"Yea, ye took up the tabernacle of Moloch, and the star of your god Ræphan, the images of them which ye made for yourselves.","searchKeywords":["yea","took","the","tabernacle","moloch","and","star","your","god","phan","images","them","which","made","for","yourselves"]},{"verseId":"brenton_amos_5_27","translationId":"brenton","testament":"OT","bookIndex":34,"bookName":"Amos","bookAbbrev":"amos","chapter":5,"verse":27,"text":"And I will carry you away beyond Damascus, saith the Lord, the Almighty God is his name.","searchKeywords":["and","will","carry","you","away","beyond","damascus","saith","the","lord","almighty","god","his","name"]}]