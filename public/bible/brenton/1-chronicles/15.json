[{"verseId":"brenton_1-chronicles_15_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":1,"text":"And made for himself houses in the city of David, and he prepared a place for the ark of God, and made a tent for it.","searchKeywords":["and","made","for","himself","houses","the","city","david","prepared","place","ark","god","tent"]},{"verseId":"brenton_1-chronicles_15_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":2,"text":"Then said David, It is not to bear the ark of God, but the Levites; for the Lord has chosen them to bear the ark of the Lord, and to minister to him for ever.","searchKeywords":["then","said","david","not","bear","the","ark","god","but","levites","for","lord","has","chosen","them","and","minister","him","ever"]},{"verseId":"brenton_1-chronicles_15_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":3,"text":"And David assembled all Israel at Jerusalem, to bring up the ark of the Lord to the place which he prepared for it.","searchKeywords":["and","david","assembled","all","israel","jerusalem","bring","the","ark","lord","place","which","prepared","for"]},{"verseId":"brenton_1-chronicles_15_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":4,"text":"And David gathered together the sons of Aaron the Levites.","searchKeywords":["and","david","gathered","together","the","sons","aaron","levites"]},{"verseId":"brenton_1-chronicles_15_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":5,"text":"Of the sons of Caath; Uriel the chief, and his brethren, a hundred and twenty.","searchKeywords":["the","sons","caath","uriel","chief","and","his","brethren","hundred","twenty"]},{"verseId":"brenton_1-chronicles_15_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":6,"text":"Of the sons of Merari; Asaia the chief, and his brethren, two hundred and twenty.","searchKeywords":["the","sons","merari","asaia","chief","and","his","brethren","two","hundred","twenty"]},{"verseId":"brenton_1-chronicles_15_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":7,"text":"Of the sons of Gedson; Joel the chief, and his brethren, a hundred and thirty.","searchKeywords":["the","sons","gedson","joel","chief","and","his","brethren","hundred","thirty"]},{"verseId":"brenton_1-chronicles_15_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":8,"text":"Of the sons of Elisaphat; Semei the chief, and his brethren, two hundred.","searchKeywords":["the","sons","elisaphat","semei","chief","and","his","brethren","two","hundred"]},{"verseId":"brenton_1-chronicles_15_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":9,"text":"Of the sons of Chebrom; Eliel the chief, and his brethren eighty.","searchKeywords":["the","sons","chebrom","eliel","chief","and","his","brethren","eighty"]},{"verseId":"brenton_1-chronicles_15_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":10,"text":"Of the sons of Oziel; Aminadab the chief, and his brethren a hundred and twelve.","searchKeywords":["the","sons","oziel","aminadab","chief","and","his","brethren","hundred","twelve"]},{"verseId":"brenton_1-chronicles_15_11","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":11,"text":"And David called Sadoc and Abiathar the priests, and the Levites, Uriel, Asaia, and Joel, and Semaia, and Eliel, and Aminadab,","searchKeywords":["and","david","called","sadoc","abiathar","the","priests","levites","uriel","asaia","joel","semaia","eliel","aminadab"]},{"verseId":"brenton_1-chronicles_15_12","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":12,"text":"and said to them, Ye the heads of the families of the Levites: sanctify yourselves, you and your brethren, and ye shall carry up the ark of the God of Israel, which I have prepared for it.","searchKeywords":["and","said","them","the","heads","families","levites","sanctify","yourselves","you","your","brethren","shall","carry","ark","god","israel","which","have","prepared","for"]},{"verseId":"brenton_1-chronicles_15_13","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":13,"text":"For because ye were not at the first, our God made a breach upon us, because we sought him not according to the ordinance.","searchKeywords":["for","because","were","not","the","first","our","god","made","breach","upon","sought","him","according","ordinance"]},{"verseId":"brenton_1-chronicles_15_14","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":14,"text":"So the priests and the Levites sanctified themselves, to bring up the ark of the God of Israel.","searchKeywords":["the","priests","and","levites","sanctified","themselves","bring","ark","god","israel"]},{"verseId":"brenton_1-chronicles_15_15","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":15,"text":"And the sons of the Levites took the ark of God, (as Moses commanded by the word of God according to the scripture) upon their shoulders with staves.","searchKeywords":["and","the","sons","levites","took","ark","god","moses","commanded","word","according","scripture","upon","their","shoulders","with","staves"]},{"verseId":"brenton_1-chronicles_15_16","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":16,"text":"And David said to the chiefs of the Levites, Set your brethren the singers with musical instruments, lutes, harps, and cymbals, to sound aloud with a voice of joy.","searchKeywords":["and","david","said","the","chiefs","levites","set","your","brethren","singers","with","musical","instruments","lutes","harps","cymbals","sound","aloud","voice","joy"]},{"verseId":"brenton_1-chronicles_15_17","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":17,"text":"So the Levites appointed Æman the son of Joel; Asaph the son of Barachias of his brethren; and Æthan the son of Kisæus was of the sons of Merari their brethren;","searchKeywords":["the","levites","appointed","man","son","joel","asaph","barachias","his","brethren","and","than","kis","was","sons","merari","their"]},{"verseId":"brenton_1-chronicles_15_18","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":18,"text":"and with them their brethren of the second rank, Zacharias, and Oziel, and Semiramoth, and Jeiel, and Elioel, and Eliab, and Banaia, and Maasaia, and Matthathia, and Eliphena, and Makellia, and Abdedom, and Jeiel, and Ozias, the porters.","searchKeywords":["and","with","them","their","brethren","the","second","rank","zacharias","oziel","semiramoth","jeiel","elioel","eliab","banaia","maasaia","matthathia","eliphena","makellia","abdedom","ozias","porters"]},{"verseId":"brenton_1-chronicles_15_19","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":19,"text":"And the singers, Æman, Asaph, and Æthan, with brazen cymbals to make to be heard.","searchKeywords":["and","the","singers","man","asaph","than","with","brazen","cymbals","make","heard"]},{"verseId":"brenton_1-chronicles_15_20","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":20,"text":"Zacharias, and Oziel, Semiramoth, Jeiel, Oni, Eliab, Maasæas, Banæas, with lutes, on alæmoth.","searchKeywords":["zacharias","and","oziel","semiramoth","jeiel","oni","eliab","maas","ban","with","lutes","moth"]},{"verseId":"brenton_1-chronicles_15_21","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":21,"text":"And Mattathias, and Eliphalu, and Makenia, and Abdedom, and Jeiel, and Ozias, with harps of Amasenith, to make a loud noise.","searchKeywords":["and","mattathias","eliphalu","makenia","abdedom","jeiel","ozias","with","harps","amasenith","make","loud","noise"]},{"verseId":"brenton_1-chronicles_15_22","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":22,"text":"And Chonenia chief of the Levites master of the bands, because he was skilful.","searchKeywords":["and","chonenia","chief","the","levites","master","bands","because","was","skilful"]},{"verseId":"brenton_1-chronicles_15_23","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":23,"text":"And Barachia and Elcana door-keepers of the ark.","searchKeywords":["and","barachia","elcana","door","keepers","the","ark"]},{"verseId":"brenton_1-chronicles_15_24","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":24,"text":"And Somnia, and Josaphat, and Nathanael, and Amasai, and Zacharia, and Banæa, and Eliezer, the priests, were sounding with trumpets before the ark of God: and Abdedom and Jeia door-keepers of the ark of God.","searchKeywords":["and","somnia","josaphat","nathanael","amasai","zacharia","ban","eliezer","the","priests","were","sounding","with","trumpets","before","ark","god","abdedom","jeia","door","keepers"]},{"verseId":"brenton_1-chronicles_15_25","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":25,"text":"So David, and the elders of Israel, and the captains of thousands, went to bring up the ark of the covenant from the house of Abdedom with gladness.","searchKeywords":["david","and","the","elders","israel","captains","thousands","went","bring","ark","covenant","from","house","abdedom","with","gladness"]},{"verseId":"brenton_1-chronicles_15_26","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":26,"text":"And it came to pass when God strengthened the Levites bearing the ark of the covenant of the Lord, that they sacrificed seven calves and seven rams.","searchKeywords":["and","came","pass","when","god","strengthened","the","levites","bearing","ark","covenant","lord","that","they","sacrificed","seven","calves","rams"]},{"verseId":"brenton_1-chronicles_15_27","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":27,"text":"And David girt with a fine linen robe, and all the Levites bearing the ark of the covenant of the Lord, and the singers, and Chonenias the master of the band of singers; also upon David a robe of fine linen.","searchKeywords":["and","david","girt","with","fine","linen","robe","all","the","levites","bearing","ark","covenant","lord","singers","chonenias","master","band","also","upon"]},{"verseId":"brenton_1-chronicles_15_28","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":28,"text":"And all Israel brought up the ark of the covenant of the Lord with shouting, and with the sound of a horn, and with trumpets, and with cymbals, playing loudly on lutes and harps.","searchKeywords":["and","all","israel","brought","the","ark","covenant","lord","with","shouting","sound","horn","trumpets","cymbals","playing","loudly","lutes","harps"]},{"verseId":"brenton_1-chronicles_15_29","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":15,"verse":29,"text":"And the ark of the covenant of the Lord arrived, and came to the city of David; and Melchol the daughter of Saul looked down through the window, and saw king David dancing and playing: and she despised him in her heart.","searchKeywords":["and","the","ark","covenant","lord","arrived","came","city","david","melchol","daughter","saul","looked","down","through","window","saw","king","dancing","playing","she","despised","him","her","heart"]}]