[{"verseId":"brenton_1-chronicles_27_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":1,"text":"Now the sons of Israel according to their number, heads of families, captains of thousands and captains of hundreds, and scribes ministering to the king, and for every affair of the king according to divisions, every ordinance of coming in and going out monthly, for all the months of the year, one division of them twenty-four thousand.","searchKeywords":["now","the","sons","israel","according","their","number","heads","families","captains","thousands","and","hundreds","scribes","ministering","king","for","every","affair","divisions","ordinance","coming","going","out","monthly","all","months","year","one","division","them","twenty","four","thousand"]},{"verseId":"brenton_1-chronicles_27_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":2,"text":"And over the first division of the first month Isboaz the son of Zabdiel: in his division twenty-four thousand.","searchKeywords":["and","over","the","first","division","month","isboaz","son","zabdiel","his","twenty","four","thousand"]},{"verseId":"brenton_1-chronicles_27_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":3,"text":"Of the sons of Tharez was chief of all the captains of the host for the first month.","searchKeywords":["the","sons","tharez","was","chief","all","captains","host","for","first","month"]},{"verseId":"brenton_1-chronicles_27_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":4,"text":"And over the division of the second month Dodia the son of Ecchoc, and over his division Makelloth also chief: and in his division twenty and four thousand, chief men of the host.","searchKeywords":["and","over","the","division","second","month","dodia","son","ecchoc","his","makelloth","also","chief","twenty","four","thousand","men","host"]},{"verseId":"brenton_1-chronicles_27_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":5,"text":"The third for the third month Banaias the son of Jodae the chief priest: and in his division twenty and four thousand.","searchKeywords":["the","third","for","month","banaias","son","jodae","chief","priest","and","his","division","twenty","four","thousand"]},{"verseId":"brenton_1-chronicles_27_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":6,"text":"This Banæas more mighty than the thirty, and over the thirty: and Zabad his son over his division.","searchKeywords":["this","ban","more","mighty","than","the","thirty","and","over","zabad","his","son","division"]},{"verseId":"brenton_1-chronicles_27_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":7,"text":"The fourth for the fourth month Asael the brother of Joab, and Zabadias his son, and his brethren: and in his division twenty and four thousand.","searchKeywords":["the","fourth","for","month","asael","brother","joab","and","zabadias","his","son","brethren","division","twenty","four","thousand"]},{"verseId":"brenton_1-chronicles_27_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":8,"text":"The fifth chief for the fifth month Samaoth the Jezraite: and in his division twenty and four thousand.","searchKeywords":["the","fifth","chief","for","month","samaoth","jezraite","and","his","division","twenty","four","thousand"]},{"verseId":"brenton_1-chronicles_27_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":9,"text":"The sixth for the sixth month Hoduias the son of Ekkes the Thecoite: and in his division twenty and four thousand.","searchKeywords":["the","sixth","for","month","hoduias","son","ekkes","thecoite","and","his","division","twenty","four","thousand"]},{"verseId":"brenton_1-chronicles_27_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":10,"text":"The seventh for the seventh month Chelles of Phallus of the children of Ephraim: and in his division twenty and four thousand.","searchKeywords":["the","seventh","for","month","chelles","phallus","children","ephraim","and","his","division","twenty","four","thousand"]},{"verseId":"brenton_1-chronicles_27_11","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":11,"text":"The eighth for the eighth month Sobochai the Usathite, to Zarai: and in his division twenty and four thousand.","searchKeywords":["the","eighth","for","month","sobochai","usathite","zarai","and","his","division","twenty","four","thousand"]},{"verseId":"brenton_1-chronicles_27_12","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":12,"text":"The ninth for the ninth month Abiezer of Anathoth, of the land of Benjamin: and in his division twenty and four thousand.","searchKeywords":["the","ninth","for","month","abiezer","anathoth","land","benjamin","and","his","division","twenty","four","thousand"]},{"verseId":"brenton_1-chronicles_27_13","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":13,"text":"The tenth for the tenth month Meera the Netophathite, to Zarai: and in his division twenty and four thousand.","searchKeywords":["the","tenth","for","month","meera","netophathite","zarai","and","his","division","twenty","four","thousand"]},{"verseId":"brenton_1-chronicles_27_14","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":14,"text":"The eleventh for the eleventh month Banaias of Pharathon, of the sons of Ephraim: and in his division twenty and four thousand.","searchKeywords":["the","eleventh","for","month","banaias","pharathon","sons","ephraim","and","his","division","twenty","four","thousand"]},{"verseId":"brenton_1-chronicles_27_15","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":15,"text":"The twelfth for the twelfth month Choldia the Netophathite, to Gothoniel: and in his division twenty and four thousand.","searchKeywords":["the","twelfth","for","month","choldia","netophathite","gothoniel","and","his","division","twenty","four","thousand"]},{"verseId":"brenton_1-chronicles_27_16","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":16,"text":"And over the tribes of Israel, the chief for Ruben Eliezer the son of Zechri: for Symeon, Saphatias the son of Maacha:","searchKeywords":["and","over","the","tribes","israel","chief","for","ruben","eliezer","son","zechri","symeon","saphatias","maacha"]},{"verseId":"brenton_1-chronicles_27_17","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":17,"text":"for Levi, Asabias the son of Camuel: for Aaron, Sadoc:","searchKeywords":["for","levi","asabias","the","son","camuel","aaron","sadoc"]},{"verseId":"brenton_1-chronicles_27_18","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":18,"text":"for Juda, Eliab of the brethren of David: for Issachar, Ambri the son of Michael:","searchKeywords":["for","juda","eliab","the","brethren","david","issachar","ambri","son","michael"]},{"verseId":"brenton_1-chronicles_27_19","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":19,"text":"for Zabulon, Samæas the son of Abdiu: for Nephthali, Jerimoth the son of Oziel:","searchKeywords":["for","zabulon","sam","the","son","abdiu","nephthali","jerimoth","oziel"]},{"verseId":"brenton_1-chronicles_27_20","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":20,"text":"for Ephraim, Ose the son of Ozia: for the half-tribe of Manasse, Joel the son of Phadæa:","searchKeywords":["for","ephraim","ose","the","son","ozia","half","tribe","manasse","joel","phad"]},{"verseId":"brenton_1-chronicles_27_21","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":21,"text":"for the half-tribe of Manasse in the land of Galaad, Jadai the son of Zadæas, for the sons of Benjamin, Jasiel the son of Abenner:","searchKeywords":["for","the","half","tribe","manasse","land","galaad","jadai","son","zad","sons","benjamin","jasiel","abenner"]},{"verseId":"brenton_1-chronicles_27_22","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":22,"text":"for Dan, Azariel the son of Iroab: these the chiefs of the tribes of Israel.","searchKeywords":["for","dan","azariel","the","son","iroab","these","chiefs","tribes","israel"]},{"verseId":"brenton_1-chronicles_27_23","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":23,"text":"But David took not their number from twenty years old and under: because the Lord said that he would multiply Israel as the stars of the heaven.","searchKeywords":["but","david","took","not","their","number","from","twenty","years","old","and","under","because","the","lord","said","that","would","multiply","israel","stars","heaven"]},{"verseId":"brenton_1-chronicles_27_24","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":24,"text":"And Joab the son of Saruia began to number the people, and did not finish the work, for there was hereupon wrath on Israel; and the number was not recorded in the book of the chronicles of king David.","searchKeywords":["and","joab","the","son","saruia","began","number","people","did","not","finish","work","for","there","was","hereupon","wrath","israel","recorded","book","chronicles","king","david"]},{"verseId":"brenton_1-chronicles_27_25","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":25,"text":"And over the king's treasures Asmoth the son of Odiel; and over the treasures in the country, and in the towns, and in the villages, and in the towers, Jonathan the son of Ozia.","searchKeywords":["and","over","the","king","treasures","asmoth","son","odiel","country","towns","villages","towers","jonathan","ozia"]},{"verseId":"brenton_1-chronicles_27_26","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":26,"text":"And over the husbandmen who tilled the ground Esdri the son of Chelub.","searchKeywords":["and","over","the","husbandmen","who","tilled","ground","esdri","son","chelub"]},{"verseId":"brenton_1-chronicles_27_27","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":27,"text":"And over the fields Semei of Rael; and over the treasures of wine in the fields Zabdi the son of Sephni.","searchKeywords":["and","over","the","fields","semei","rael","treasures","wine","zabdi","son","sephni"]},{"verseId":"brenton_1-chronicles_27_28","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":28,"text":"And over the oliveyards, and over the sycamores in the plain country Ballanan the Gedorite; and over the stores of oil Joas.","searchKeywords":["and","over","the","oliveyards","sycamores","plain","country","ballanan","gedorite","stores","oil","joas"]},{"verseId":"brenton_1-chronicles_27_29","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":29,"text":"And over the oxen pasturing in Saron Satrai the Saronite; and over the oxen in the valleys Sophat the son of Adli.","searchKeywords":["and","over","the","oxen","pasturing","saron","satrai","saronite","valleys","sophat","son","adli"]},{"verseId":"brenton_1-chronicles_27_30","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":30,"text":"And over the camels Abias the Ismaelite; and over the asses Jadias of Merathon.","searchKeywords":["and","over","the","camels","abias","ismaelite","asses","jadias","merathon"]},{"verseId":"brenton_1-chronicles_27_31","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":31,"text":"And over the sheep Jaziz the Agarite. All these superintendents of the substance of king David.","searchKeywords":["and","over","the","sheep","jaziz","agarite","all","these","superintendents","substance","king","david"]},{"verseId":"brenton_1-chronicles_27_32","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":32,"text":"And Jonathan, David's uncle by the father's side, a counsellor, a wise man: and Jeel the son of Achami with the king's sons.","searchKeywords":["and","jonathan","david","uncle","the","father","side","counsellor","wise","man","jeel","son","achami","with","king","sons"]},{"verseId":"brenton_1-chronicles_27_33","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":33,"text":"Achitophel the king's counsellor: and Chusi the chief friend of the king.","searchKeywords":["achitophel","the","king","counsellor","and","chusi","chief","friend"]},{"verseId":"brenton_1-chronicles_27_34","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":27,"verse":34,"text":"And after this Achitophel Jodae the son of Banæas next, and Abiathar: and Joab the king's commander-in-chief.","searchKeywords":["and","after","this","achitophel","jodae","the","son","ban","next","abiathar","joab","king","commander","chief"]}]