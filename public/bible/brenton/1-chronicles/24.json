[{"verseId":"brenton_1-chronicles_24_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":1,"text":"And the sons of Aaron in division, Nadab, and Abiud, and Eleazar, and Ithamar.","searchKeywords":["and","the","sons","aaron","division","nadab","abiud","eleazar","ithamar"]},{"verseId":"brenton_1-chronicles_24_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":2,"text":"And Nadab and Abiud died before their father, and they had no sons: so Eleazar and Ithamar the sons of Aaron ministered as priests.","searchKeywords":["and","nadab","abiud","died","before","their","father","they","had","sons","eleazar","ithamar","the","aaron","ministered","priests"]},{"verseId":"brenton_1-chronicles_24_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":3,"text":"And David distributed them, even Sadoc of the sons of Eleazar, and Achimelech of the sons of Ithamar, according to their numbering, according to their service, according to the houses of their fathers.","searchKeywords":["and","david","distributed","them","even","sadoc","the","sons","eleazar","achimelech","ithamar","according","their","numbering","service","houses","fathers"]},{"verseId":"brenton_1-chronicles_24_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":4,"text":"And there were found the sons of Eleazar more chiefs of the mighty ones, than of the sons of Ithamar: and he divided them, sixteen heads of families to the sons of Eleazar, eight according to families to the sons of Ithamar.","searchKeywords":["and","there","were","found","the","sons","eleazar","more","chiefs","mighty","ones","than","ithamar","divided","them","sixteen","heads","families","eight","according"]},{"verseId":"brenton_1-chronicles_24_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":5,"text":"And he divided them according to their lots, one with the other; for there were those who had charge of the holy things, and those who had charge of the of the Lord among the sons of Eleazar, and among the sons of Ithamar.","searchKeywords":["and","divided","them","according","their","lots","one","with","the","other","for","there","were","those","who","had","charge","holy","things","lord","among","sons","eleazar","ithamar"]},{"verseId":"brenton_1-chronicles_24_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":6,"text":"And Samaias the son of Nathanael, the scribe, of Levi, wrote them down before the king, and the princes, and Sadoc the priest, and Achimelech the son of Abiathar ; and the heads of the families of the priests and the Levites, each of a household one to Eleazar, and one to Ithamar.","searchKeywords":["and","samaias","the","son","nathanael","scribe","levi","wrote","them","down","before","king","princes","sadoc","priest","achimelech","abiathar","heads","families","priests","levites","each","household","one","eleazar","ithamar"]},{"verseId":"brenton_1-chronicles_24_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":7,"text":"And the first lot came out to Joarim, the second to Jedia,","searchKeywords":["and","the","first","lot","came","out","joarim","second","jedia"]},{"verseId":"brenton_1-chronicles_24_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":8,"text":"the third to Charib, the fourth to Seorim,","searchKeywords":["the","third","charib","fourth","seorim"]},{"verseId":"brenton_1-chronicles_24_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":9,"text":"the fifth to Melchias, the sixth to Meiamin,","searchKeywords":["the","fifth","melchias","sixth","meiamin"]},{"verseId":"brenton_1-chronicles_24_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":10,"text":"the seventh to Cos, the eighth to Abia,","searchKeywords":["the","seventh","cos","eighth","abia"]},{"verseId":"brenton_1-chronicles_24_11","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":11,"text":"the ninth to Jesus, the tenth to Sechenias,","searchKeywords":["the","ninth","jesus","tenth","sechenias"]},{"verseId":"brenton_1-chronicles_24_12","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":12,"text":"the eleventh to Eliabi, the twelfth to Jacim,","searchKeywords":["the","eleventh","eliabi","twelfth","jacim"]},{"verseId":"brenton_1-chronicles_24_13","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":13,"text":"the thirteenth to Oppha, the fourteenth to Jesbaal,","searchKeywords":["the","thirteenth","oppha","fourteenth","jesbaal"]},{"verseId":"brenton_1-chronicles_24_14","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":14,"text":"the fifteenth to Belga, the sixteenth to Emmer,","searchKeywords":["the","fifteenth","belga","sixteenth","emmer"]},{"verseId":"brenton_1-chronicles_24_15","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":24,"verse":15,"text":"the seventeenth to Chezin, the eighteenth to Aphese,","searchKeywords":["the","seventeenth","chezin","eighteenth","aphese"]},{"ver