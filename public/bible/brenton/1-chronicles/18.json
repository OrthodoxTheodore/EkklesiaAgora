[{"verseId":"brenton_1-chronicles_18_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":1,"text":"And it came to pass afterwards, that David smote the Philistines, and routed them, and took Geth and its villages out of the hand of the Philistines.","searchKeywords":["and","came","pass","afterwards","that","david","smote","the","philistines","routed","them","took","geth","its","villages","out","hand"]},{"verseId":"brenton_1-chronicles_18_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":2,"text":"And he smote Moab; and the Moabites became servants to David, tributaries.","searchKeywords":["and","smote","moab","the","moabites","became","servants","david","tributaries"]},{"verseId":"brenton_1-chronicles_18_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":3,"text":"And David smote Adraazar king of Suba of Emath, as he was going to establish power toward the river Euphrates.","searchKeywords":["and","david","smote","adraazar","king","suba","emath","was","going","establish","power","toward","the","river","euphrates"]},{"verseId":"brenton_1-chronicles_18_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":4,"text":"And David took of them a thousand chariots, and seven thousand horsemen, and twenty thousand infantry: and David houghed all the chariot , but there were reserved of them a hundred chariots.","searchKeywords":["and","david","took","them","thousand","chariots","seven","horsemen","twenty","infantry","houghed","all","the","chariot","but","there","were","reserved","hundred"]},{"verseId":"brenton_1-chronicles_18_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":5,"text":"And the Syrian came from Damascus to help Adraazar king of Suba; and David smote of the Syrian twenty and two thousand men.","searchKeywords":["and","the","syrian","came","from","damascus","help","adraazar","king","suba","david","smote","twenty","two","thousand","men"]},{"verseId":"brenton_1-chronicles_18_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":6,"text":"And David put a garrison in Syria near Damascus; and they became tributary servants to David: and the Lord delivered David wherever he went.","searchKeywords":["and","david","put","garrison","syria","near","damascus","they","became","tributary","servants","the","lord","delivered","wherever","went"]},{"verseId":"brenton_1-chronicles_18_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":7,"text":"And David took the golden collars that were on the servants of Adraazar, and brought them to Jerusalem.","searchKeywords":["and","david","took","the","golden","collars","that","were","servants","adraazar","brought","them","jerusalem"]},{"verseId":"brenton_1-chronicles_18_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":8,"text":"And David took out of Matabeth, and out of the chief cities of Adraazar very much brass: of this Solomon made the brazen sea, and the pillars, and the brazen vessels.","searchKeywords":["and","david","took","out","matabeth","the","chief","cities","adraazar","very","much","brass","this","solomon","made","brazen","sea","pillars","vessels"]},{"verseId":"brenton_1-chronicles_18_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":9,"text":"And Thoa king of Emath heard that David had smitten the whole force of Adraazar king of Suba.","searchKeywords":["and","thoa","king","emath","heard","that","david","had","smitten","the","whole","force","adraazar","suba"]},{"verseId":"brenton_1-chronicles_18_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":10,"text":"And he sent Aduram his son to king David to ask how he was, and to congratulate him because he had fought against Adraazar, and smitten him; for Thoa was the enemy of Adraazar.","searchKeywords":["and","sent","aduram","his","son","king","david","ask","how","was","congratulate","him","because","had","fought","against","adraazar","smitten","for","thoa","the","enemy"]},{"verseId":"brenton_1-chronicles_18_11","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":11,"text":"And all the golden and silver and brazen vessels, even these king David consecrated to the Lord, with the silver and the gold which he took from all the nations; from Idumæa, and Moab, and from the children of Ammon, and from the Philistines, and from Amalec.","searchKeywords":["and","all","the","golden","silver","brazen","vessels","even","these","king","david","consecrated","lord","with","gold","which","took","from","nations","idum","moab","children","ammon","philistines","amalec"]},{"verseId":"brenton_1-chronicles_18_12","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":12,"text":"And Abesa son of Saruia smote the Idumeans in the valley of Salt, eighteen thousand.","searchKeywords":["and","abesa","son","saruia","smote","the","idumeans","valley","salt","eighteen","thousand"]},{"verseId":"brenton_1-chronicles_18_13","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":13,"text":"And he put garrisons in the valley; and all the Idumæans became David's servants: and the Lord delivered David wherever he went.","searchKeywords":["and","put","garrisons","the","valley","all","idum","ans","became","david","servants","lord","delivered","wherever","went"]},{"verseId":"brenton_1-chronicles_18_14","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":14,"text":"So David reigned over all Israel; and he executed judgment and justice to all his people.","searchKeywords":["david","reigned","over","all","israel","and","executed","judgment","justice","his","people"]},{"verseId":"brenton_1-chronicles_18_15","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":15,"text":"And Joab the son of Saruia over the army, and Josaphat the son of Achilud recorder.","searchKeywords":["and","joab","the","son","saruia","over","army","josaphat","achilud","recorder"]},{"verseId":"brenton_1-chronicles_18_16","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":16,"text":"And Sadoc son of Achitob, and Achimelech son of Abiathar, the priests; and Susa the scribe;","searchKeywords":["and","sadoc","son","achitob","achimelech","abiathar","the","priests","susa","scribe"]},{"verseId":"brenton_1-chronicles_18_17","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":18,"verse":17,"text":"and Banæas the son of Jodae over the Cherethite and the Phelethite, and the sons of David were the chief deputies of the king.","searchKeywords":["and","ban","the","son","jodae","over","cherethite","phelethite","sons","david","were","chief","deputies","king"]}]