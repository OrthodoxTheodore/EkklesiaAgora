[{"verseId":"brenton_1-chronicles_14_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":1,"text":"And Chiram king of Tyre sent messengers to David, and cedar timbers, and masons, and carpenters, to build a house for him.","searchKeywords":["and","chiram","king","tyre","sent","messengers","david","cedar","timbers","masons","carpenters","build","house","for","him"]},{"verseId":"brenton_1-chronicles_14_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":2,"text":"And David knew that the Lord designed him to be king over Israel; because his kingdom was highly exalted, on account of his people Israel.","searchKeywords":["and","david","knew","that","the","lord","designed","him","king","over","israel","because","his","kingdom","was","highly","exalted","account","people"]},{"verseId":"brenton_1-chronicles_14_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":3,"text":"And David took more wives in Jerusalem: and there were born to David more sons and daughters.","searchKeywords":["and","david","took","more","wives","jerusalem","there","were","born","sons","daughters"]},{"verseId":"brenton_1-chronicles_14_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":4,"text":"And these the names of those that were born, who were to him in Jerusalem; Samaa, Sobab, Nathan, and Solomon,","searchKeywords":["and","these","the","names","those","that","were","born","who","him","jerusalem","samaa","sobab","nathan","solomon"]},{"verseId":"brenton_1-chronicles_14_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":5,"text":"and Baar, and Elisa, and Eliphaleth,","searchKeywords":["and","baar","elisa","eliphaleth"]},{"verseId":"brenton_1-chronicles_14_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":6,"text":"and Nageth, and Naphath, and Japhie,","searchKeywords":["and","nageth","naphath","japhie"]},{"verseId":"brenton_1-chronicles_14_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":7,"text":"and Elisamae, and Eliade, and Eliphala.","searchKeywords":["and","elisamae","eliade","eliphala"]},{"verseId":"brenton_1-chronicles_14_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":8,"text":"And the Philistines heard that David was anointed king over all Israel: and all the Philistines went up to seek David; and David heard , and went out to meet them.","searchKeywords":["and","the","philistines","heard","that","david","was","anointed","king","over","all","israel","went","seek","out","meet","them"]},{"verseId":"brenton_1-chronicles_14_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":9,"text":"And the Philistines came and assembled together in the giants' valley.","searchKeywords":["and","the","philistines","came","assembled","together","giants","valley"]},{"verseId":"brenton_1-chronicles_14_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":10,"text":"And David enquired of God, saying, Shall I go up against the Philistines? and wilt thou deliver them into my hand? And the Lord said to him, Go up, and I will deliver them into thy hands.","searchKeywords":["and","david","enquired","god","saying","shall","against","the","philistines","wilt","thou","deliver","them","into","hand","lord","said","him","will","thy","hands"]},{"verseId":"brenton_1-chronicles_14_11","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":11,"text":"And he went up to Baal Pharasin, and David smote them there; and David said, God has broken through enemies by my hand like a breach of water: therefore he called the name of that place, the Breach of Pharasin.","searchKeywords":["and","went","baal","pharasin","david","smote","them","there","said","god","has","broken","through","enemies","hand","like","breach","water","therefore","called","the","name","that","place"]},{"verseId":"brenton_1-chronicles_14_12","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":12,"text":"And the Philistines left their gods there; and David gave orders to burn them with fire.","searchKeywords":["and","the","philistines","left","their","gods","there","david","gave","orders","burn","them","with","fire"]},{"verseId":"brenton_1-chronicles_14_13","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":13,"text":"And the Philistines once more assembled themselves in the giants' valley.","searchKeywords":["and","the","philistines","once","more","assembled","themselves","giants","valley"]},{"verseId":"brenton_1-chronicles_14_14","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":14,"text":"And David enquired of God again; and God said to him, Thou shalt not go after them; turn away from them, and thou shalt come upon them near the pear trees.","searchKeywords":["and","david","enquired","god","again","said","him","thou","shalt","not","after","them","turn","away","from","come","upon","near","the","pear","trees"]},{"verseId":"brenton_1-chronicles_14_15","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":15,"text":"And it shall be, when thou shalt hear the sound of their tumult in the tops of the pear trees, then thou shalt go into the battle: for God has gone out before thee to smite the army of the Philistines.","searchKeywords":["and","shall","when","thou","shalt","hear","the","sound","their","tumult","tops","pear","trees","then","into","battle","for","god","has","gone","out","before","thee","smite","army","philistines"]},{"verseId":"brenton_1-chronicles_14_16","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":16,"text":"And he did as God commanded him: and he smote the army of the Philistines from Gabaon to Gazera.","searchKeywords":["and","did","god","commanded","him","smote","the","army","philistines","from","gabaon","gazera"]},{"verseId":"brenton_1-chronicles_14_17","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":14,"verse":17,"text":"And the name of David was in all the land; and the Lord put the terror of him on all the nations.","searchKeywords":["and","the","name","david","was","all","land","lord","put","terror","him","nations"]}]