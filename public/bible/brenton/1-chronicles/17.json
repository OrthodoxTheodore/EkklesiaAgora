[{"verseId":"brenton_1-chronicles_17_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":1,"text":"And it came to pass as David dwelt in his house, that David said to Nathan the prophet, Behold, I dwell in a house of cedar, but the ark of the covenant of the Lord under of skins.","searchKeywords":["and","came","pass","david","dwelt","his","house","that","said","nathan","the","prophet","behold","dwell","cedar","but","ark","covenant","lord","under","skins"]},{"verseId":"brenton_1-chronicles_17_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":2,"text":"And Nathan said to David, Do all that is in thy heart; for God with thee.","searchKeywords":["and","nathan","said","david","all","that","thy","heart","for","god","with","thee"]},{"verseId":"brenton_1-chronicles_17_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":3,"text":"And it came to pass in that night, that the word of the Lord came to Nathan, ,","searchKeywords":["and","came","pass","that","night","the","word","lord","nathan"]},{"verseId":"brenton_1-chronicles_17_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":4,"text":"Go and say to David my servant, Thus said the Lord, Thou shalt not build me a house for me to dwell in it.","searchKeywords":["and","say","david","servant","thus","said","the","lord","thou","shalt","not","build","house","for","dwell"]},{"verseId":"brenton_1-chronicles_17_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":5,"text":"For I have not dwelt in a house from the day that I brought up Israel until this day, but I have been in a tabernacle and a tent,","searchKeywords":["for","have","not","dwelt","house","from","the","day","that","brought","israel","until","this","but","been","tabernacle","and","tent"]},{"verseId":"brenton_1-chronicles_17_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":6,"text":"in all places through which I have gone with all Israel: did I ever speak to one tribe of Israel whom I commanded to feed my people, saying, that ye have not built me a house of cedar?","searchKeywords":["all","places","through","which","have","gone","with","israel","did","ever","speak","one","tribe","whom","commanded","feed","people","saying","that","not","built","house","cedar"]},{"verseId":"brenton_1-chronicles_17_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":7,"text":"And now thus shalt thou say to my servant David, Thus saith the Lord Almighty, I took thee from the sheepfold, from following the flocks, to be a ruler over my people Israel:","searchKeywords":["and","now","thus","shalt","thou","say","servant","david","saith","the","lord","almighty","took","thee","from","sheepfold","following","flocks","ruler","over","people","israel"]},{"verseId":"brenton_1-chronicles_17_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":8,"text":"and I was with thee in all places whither thou wentest, and I destroyed all thine enemies from before thee, and I made for thee a name according to the name of the great ones that are upon the earth.","searchKeywords":["and","was","with","thee","all","places","whither","thou","wentest","destroyed","thine","enemies","from","before","made","for","name","according","the","great","ones","that","are","upon","earth"]},{"verseId":"brenton_1-chronicles_17_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":9,"text":"And I will appoint a place for my people Israel, and I will plant him, and he shall dwell by himself, and shall no longer be anxious; and the son of iniquity shall no longer afflict him, as at the beginning,","searchKeywords":["and","will","appoint","place","for","people","israel","plant","him","shall","dwell","himself","longer","anxious","the","son","iniquity","afflict","beginning"]},{"verseId":"brenton_1-chronicles_17_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":10,"text":"and from the days when I appointed judges over my people Israel. Also I have humbled all thine enemies, and I will increase thee, and the Lord will build thee a house.","searchKeywords":["and","from","the","days","when","appointed","judges","over","people","israel","also","have","humbled","all","thine","enemies","will","increase","thee","lord","build","house"]},{"verseId":"brenton_1-chronicles_17_11","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":11,"text":"And it shall come to pass when thy days shall be fulfilled, and thou shalt sleep with thy fathers, that I will raise up thy seed after thee, which shall be of thy bowels, and I will establish his kingdom.","searchKeywords":["and","shall","come","pass","when","thy","days","fulfilled","thou","shalt","sleep","with","fathers","that","will","raise","seed","after","thee","which","bowels","establish","his","kingdom"]},{"verseId":"brenton_1-chronicles_17_12","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":12,"text":"He shall build me a house, and I will set up his throne for ever.","searchKeywords":["shall","build","house","and","will","set","his","throne","for","ever"]},{"verseId":"brenton_1-chronicles_17_13","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":13,"text":"I will be to him a father, and he shall be to me a son: and my mercy will I not withdraw from him, as I withdrew from them that were before thee.","searchKeywords":["will","him","father","and","shall","son","mercy","not","withdraw","from","withdrew","them","that","were","before","thee"]},{"verseId":"brenton_1-chronicles_17_14","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":14,"text":"And I will establish him in my house and in his kingdom for ever; and his throne shall be set up for ever.","searchKeywords":["and","will","establish","him","house","his","kingdom","for","ever","throne","shall","set"]},{"verseId":"brenton_1-chronicles_17_15","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":15,"text":"According to all these words, and according to all this vision, so spoke Nathan to David.","searchKeywords":["according","all","these","words","and","this","vision","spoke","nathan","david"]},{"verseId":"brenton_1-chronicles_17_16","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":16,"text":"And king David came and sat before the Lord, and said, Who am I, O Lord God? and what my house, that thou hast loved me for ever?","searchKeywords":["and","king","david","came","sat","before","the","lord","said","who","god","what","house","that","thou","hast","loved","for","ever"]},{"verseId":"brenton_1-chronicles_17_17","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":17,"text":"And these things were little in thy sight, O God: thou hast also spoken concerning the house of thy servant for a long time to come, and thou hast looked upon me as a man looks upon his fellow, and hast exalted me, O Lord God.","searchKeywords":["and","these","things","were","little","thy","sight","god","thou","hast","also","spoken","concerning","the","house","servant","for","long","time","come","looked","upon","man","looks","his","fellow","exalted","lord"]},{"verseId":"brenton_1-chronicles_17_18","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":18,"text":"What shall David do more toward thee to glorify ? and thou knowest thy servant.","searchKeywords":["what","shall","david","more","toward","thee","glorify","and","thou","knowest","thy","servant"]},{"verseId":"brenton_1-chronicles_17_19","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":19,"text":"And thou hast wrought all this greatness according to thine heart.","searchKeywords":["and","thou","hast","wrought","all","this","greatness","according","thine","heart"]},{"verseId":"brenton_1-chronicles_17_20","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":20,"text":"O Lord, there is none like thee, and there is no God beside thee, according to all things which we have heard with our ears.","searchKeywords":["lord","there","none","like","thee","and","god","beside","according","all","things","which","have","heard","with","our","ears"]},{"verseId":"brenton_1-chronicles_17_21","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":21,"text":"Neither is there another nation upon the earth as thy people Israel, whereas God led him in the way, to redeem a people for himself, to make for himself a great and glorious name, to cast out nations from before thy people, whom thou redeemedst out of Egypt.","searchKeywords":["neither","there","another","nation","upon","the","earth","thy","people","israel","whereas","god","led","him","way","redeem","for","himself","make","great","and","glorious","name","cast","out","nations","from","before","whom","thou","redeemedst","egypt"]},{"verseId":"brenton_1-chronicles_17_22","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":22,"text":"And thou hast appointed thy people Israel as a people to thyself for ever; and thou, Lord, didst become a God to them.","searchKeywords":["and","thou","hast","appointed","thy","people","israel","thyself","for","ever","lord","didst","become","god","them"]},{"verseId":"brenton_1-chronicles_17_23","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":23,"text":"And now, Lord, let the word which thou spokest to thy servant, and concerning his house, be confirmed for ever, and do thou as thou hast spoken.","searchKeywords":["and","now","lord","let","the","word","which","thou","spokest","thy","servant","concerning","his","house","confirmed","for","ever","hast","spoken"]},{"verseId":"brenton_1-chronicles_17_24","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":24,"text":"And let thy name established and magnified for ever, saying, Lord, Lord, Almighty God of Israel: and the house of thy servant David established before thee.","searchKeywords":["and","let","thy","name","established","magnified","for","ever","saying","lord","almighty","god","israel","the","house","servant","david","before","thee"]},{"verseId":"brenton_1-chronicles_17_25","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":25,"text":"For thou, O Lord my God, hast revealed to the ear of thy servant that thou wilt build him a house; therefore thy servant has found a willingness to pray before thee.","searchKeywords":["for","thou","lord","god","hast","revealed","the","ear","thy","servant","that","wilt","build","him","house","therefore","has","found","willingness","pray","before","thee"]},{"verseId":"brenton_1-chronicles_17_26","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":26,"text":"And now, Lord, thou thyself art God, and thou hast spoken these good things concerning thy servant.","searchKeywords":["and","now","lord","thou","thyself","art","god","hast","spoken","these","good","things","concerning","thy","servant"]},{"verseId":"brenton_1-chronicles_17_27","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":17,"verse":27,"text":"And now thou hast begun to bless the house of thy servant, so that it should continue for ever before thee: for thou, Lord, hast blessed , and do thou bless for ever.","searchKeywords":["and","now","thou","hast","begun","bless","the","house","thy","servant","that","should","continue","for","ever","before","thee","lord","blessed"]}]