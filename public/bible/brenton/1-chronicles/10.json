[{"verseId":"brenton_1-chronicles_10_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":1,"text":"Now the Philistines warred against Israel; and they fled from before the Philistines, and fell down slain in mount Gelbue.","searchKeywords":["now","the","philistines","warred","against","israel","and","they","fled","from","before","fell","down","slain","mount","gelbue"]},{"verseId":"brenton_1-chronicles_10_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":2,"text":"And the Philistines pursued after Saul, and after his sons; and the Philistines smote Jonathan, and Aminadab, and Melchisue, sons of Saul.","searchKeywords":["and","the","philistines","pursued","after","saul","his","sons","smote","jonathan","aminadab","melchisue"]},{"verseId":"brenton_1-chronicles_10_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":3,"text":"And the battle prevailed against Saul, and the archers hit him with bows and arrows, and they were wounded of the bows.","searchKeywords":["and","the","battle","prevailed","against","saul","archers","hit","him","with","bows","arrows","they","were","wounded"]},{"verseId":"brenton_1-chronicles_10_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":4,"text":"And Saul said to his armour-bearer, Draw thy sword, and pierce me through with it, lest these uncircumcised come and mock me. But his armour-bearer would not, for he was greatly afraid: so Saul took a sword, and fell upon it.","searchKeywords":["and","saul","said","his","armour","bearer","draw","thy","sword","pierce","through","with","lest","these","uncircumcised","come","mock","but","would","not","for","was","greatly","afraid","took","fell","upon"]},{"verseId":"brenton_1-chronicles_10_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":5,"text":"And his armour-bearer saw that Saul was dead, and he also fell upon his sword.","searchKeywords":["and","his","armour","bearer","saw","that","saul","was","dead","also","fell","upon","sword"]},{"verseId":"brenton_1-chronicles_10_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":6,"text":"So Saul died, and his three sons on that day, and all his family died at the same time.","searchKeywords":["saul","died","and","his","three","sons","that","day","all","family","the","same","time"]},{"verseId":"brenton_1-chronicles_10_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":7,"text":"And all the men of Israel that were in the valley saw that Israel fled, and that Saul and his sons were dead, and they left their cities, and fled: and the Philistines came and dwelt in them.","searchKeywords":["and","all","the","men","israel","that","were","valley","saw","fled","saul","his","sons","dead","they","left","their","cities","philistines","came","dwelt","them"]},{"verseId":"brenton_1-chronicles_10_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":8,"text":"And it came to pass on the next that the Philistines came to strip the slain, and they found Saul and his sons fallen on mount Gelbue.","searchKeywords":["and","came","pass","the","next","that","philistines","strip","slain","they","found","saul","his","sons","fallen","mount","gelbue"]},{"verseId":"brenton_1-chronicles_10_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":9,"text":"And they stripped him, and took his head, and his armour, and sent them into the land of the Philistines round about, to proclaim the glad tidings to their idols, and to the people.","searchKeywords":["and","they","stripped","him","took","his","head","armour","sent","them","into","the","land","philistines","round","about","proclaim","glad","tidings","their","idols","people"]},{"verseId":"brenton_1-chronicles_10_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":10,"text":"And they put their armour in the house of their god, and they put his head in the house of Dagon.","searchKeywords":["and","they","put","their","armour","the","house","god","his","head","dagon"]},{"verseId":"brenton_1-chronicles_10_11","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":11,"text":"And all the dwellers in Galaad heard of all that the Philistines had done to Saul and to Israel.","searchKeywords":["and","all","the","dwellers","galaad","heard","that","philistines","had","done","saul","israel"]},{"verseId":"brenton_1-chronicles_10_12","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":12,"text":"And all the mighty men rose up from Galaad, and they took the body of Saul, and the bodies of his sons, and brought them to Jabis, and buried their bones under the oak in Jabis, and fasted seven days.","searchKeywords":["and","all","the","mighty","men","rose","from","galaad","they","took","body","saul","bodies","his","sons","brought","them","jabis","buried","their","bones","under","oak","fasted","seven","days"]},{"verseId":"brenton_1-chronicles_10_13","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":13,"text":"So Saul died for his transgressions, wherein he transgressed against God, against the word of the Lord, forasmuch as he kept not, because Saul enquired of a wizard to seek , and Samuel the prophet answered him:","searchKeywords":["saul","died","for","his","transgressions","wherein","transgressed","against","god","the","word","lord","forasmuch","kept","not","because","enquired","wizard","seek","and","samuel","prophet","answered","him"]},{"verseId":"brenton_1-chronicles_10_14","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":10,"verse":14,"text":"and he sought not the Lord: so he slew him, and turned the kingdom to David the son of Jesse.","searchKeywords":["and","sought","not","the","lord","slew","him","turned","kingdom","david","son","jesse"]}]