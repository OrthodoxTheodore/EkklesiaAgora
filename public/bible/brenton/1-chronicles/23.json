[{"verseId":"brenton_1-chronicles_23_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":1,"text":"And David was old and full of days; and he made Solomon his son king over Israel in his stead.","searchKeywords":["and","david","was","old","full","days","made","solomon","his","son","king","over","israel","stead"]},{"verseId":"brenton_1-chronicles_23_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":2,"text":"And he assembled all the chief men of Israel, and the priests, and the Levites.","searchKeywords":["and","assembled","all","the","chief","men","israel","priests","levites"]},{"verseId":"brenton_1-chronicles_23_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":3,"text":"And the Levites numbered from thirty years old and upward; and their number by their polls amounted to thirty and eight thousand men.","searchKeywords":["and","the","levites","numbered","from","thirty","years","old","upward","their","number","polls","amounted","eight","thousand","men"]},{"verseId":"brenton_1-chronicles_23_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":4,"text":"Of the overseers over the works of the house of the Lord twenty-four thousand, and six thousand scribes and judges;","searchKeywords":["the","overseers","over","works","house","lord","twenty","four","thousand","and","six","scribes","judges"]},{"verseId":"brenton_1-chronicles_23_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":5,"text":"and four thousand door-keepers, and four thousand to praise the Lord with instruments which he made to praise the Lord.","searchKeywords":["and","four","thousand","door","keepers","praise","the","lord","with","instruments","which","made"]},{"verseId":"brenton_1-chronicles_23_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":6,"text":"And David divided them daily courses, for the sons of Levi, for Gedson, Caath, and Merari.","searchKeywords":["and","david","divided","them","daily","courses","for","the","sons","levi","gedson","caath","merari"]},{"verseId":"brenton_1-chronicles_23_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":7,"text":"And for Gedson, Edan, and Semei.","searchKeywords":["and","for","gedson","edan","semei"]},{"verseId":"brenton_1-chronicles_23_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":8,"text":"The sons of Edan Jeiel, the chief, and Zethan, and Joel, three.","searchKeywords":["the","sons","edan","jeiel","chief","and","zethan","joel","three"]},{"verseId":"brenton_1-chronicles_23_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":9,"text":"The sons of Semei; Salomith, Jeiel, and Dan, three: these the chiefs of the families of Edan.","searchKeywords":["the","sons","semei","salomith","jeiel","and","dan","three","these","chiefs","families","edan"]},{"verseId":"brenton_1-chronicles_23_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":10,"text":"And to the sons of Semei, Jeth, and Ziza, and Joas, and Beria: these the four sons of Semei.","searchKeywords":["and","the","sons","semei","jeth","ziza","joas","beria","these","four"]},{"verseId":"brenton_1-chronicles_23_11","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":11,"text":"And Jeth was the chief, and Ziza the second: and Joas and Beria did not multiply sons, and they became one reckoning according to the house of their father.","searchKeywords":["and","jeth","was","the","chief","ziza","second","joas","beria","did","not","multiply","sons","they","became","one","reckoning","according","house","their","father"]},{"verseId":"brenton_1-chronicles_23_12","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":12,"text":"The sons of Caath; Ambram, Isaar, Chebron, Oziel, four.","searchKeywords":["the","sons","caath","ambram","isaar","chebron","oziel","four"]},{"verseId":"brenton_1-chronicles_23_13","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":13,"text":"The sons of Ambram; Aaron and Moses: and Aaron was appointed for the consecration of the most holy things, he and his sons for ever, to burn incense before the Lord, to minister and bless in his name for ever.","searchKeywords":["the","sons","ambram","aaron","and","moses","was","appointed","for","consecration","most","holy","things","his","ever","burn","incense","before","lord","minister","bless","name"]},{"verseId":"brenton_1-chronicles_23_14","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":14,"text":"And Moses the man of God, his sons were reckoned to the tribe of Levi.","searchKeywords":["and","moses","the","man","god","his","sons","were","reckoned","tribe","levi"]},{"verseId":"brenton_1-chronicles_23_15","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":15,"text":"The sons of Moses; Gersam, and Eliezer.","searchKeywords":["the","sons","moses","gersam","and","eliezer"]},{"verseId":"brenton_1-chronicles_23_16","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":16,"text":"The sons of Gersam; Subael the chief.","searchKeywords":["the","sons","gersam","subael","chief"]},{"verseId":"brenton_1-chronicles_23_17","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":17,"text":"And the sons of Eliezer were, Rabia the chief: and Eliezer had no other sons; but the sons of Rabia were very greatly multiplied.","searchKeywords":["and","the","sons","eliezer","were","rabia","chief","had","other","but","very","greatly","multiplied"]},{"verseId":"brenton_1-chronicles_23_18","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":18,"text":"The sons of Isaar; Salomoth the chief.","searchKeywords":["the","sons","isaar","salomoth","chief"]},{"verseId":"brenton_1-chronicles_23_19","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":19,"text":"The sons of Chebron; Jeria the chief, Amaria the second, Jeziel the third, Jekemias the fourth.","searchKeywords":["the","sons","chebron","jeria","chief","amaria","second","jeziel","third","jekemias","fourth"]},{"verseId":"brenton_1-chronicles_23_20","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":20,"text":"The sons of Oziel; Micha the chief, and Isia the second.","searchKeywords":["the","sons","oziel","micha","chief","and","isia","second"]},{"verseId":"brenton_1-chronicles_23_21","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":21,"text":"The sons of Merari; Mooli, and Musi: the sons of Mooli; Eleazar, and Kis.","searchKeywords":["the","sons","merari","mooli","and","musi","eleazar","kis"]},{"verseId":"brenton_1-chronicles_23_22","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":22,"text":"And Eleazar died, and he had no sons, but daughters: and the sons of Kis, their brethren, took them.","searchKeywords":["and","eleazar","died","had","sons","but","daughters","the","kis","their","brethren","took","them"]},{"verseId":"brenton_1-chronicles_23_23","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":23,"text":"The sons of Musi; Mooli, and Eder, and Jarimoth, three.","searchKeywords":["the","sons","musi","mooli","and","eder","jarimoth","three"]},{"verseId":"brenton_1-chronicles_23_24","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":24,"text":"These the sons of Levi according to the houses of their fathers; chiefs of their families according to their numbering, according to the number of their names, according to their polls, doing the works of service of the house of the Lord, from twenty years old and upward.","searchKeywords":["these","the","sons","levi","according","houses","their","fathers","chiefs","families","numbering","number","names","polls","doing","works","service","house","lord","from","twenty","years","old","and","upward"]},{"verseId":"brenton_1-chronicles_23_25","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":25,"text":"For David said, The Lord God of Israel has given rest to his people, and has taken up his abode in Jerusalem for ever.","searchKeywords":["for","david","said","the","lord","god","israel","has","given","rest","his","people","and","taken","abode","jerusalem","ever"]},{"verseId":"brenton_1-chronicles_23_26","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":26,"text":"And the Levites bore not the tabernacle, and all the vessels of it for its service.","searchKeywords":["and","the","levites","bore","not","tabernacle","all","vessels","for","its","service"]},{"verseId":"brenton_1-chronicles_23_27","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":27,"text":"For by the last words of David was the number of the Levites from twenty years old and upward.","searchKeywords":["for","the","last","words","david","was","number","levites","from","twenty","years","old","and","upward"]},{"verseId":"brenton_1-chronicles_23_28","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":28,"text":"For he appointed them to wait on Aaron, to minister in the house of the Lord, over the courts, and over the chambers, and over the purification of all the holy things, and over the works of the service of the house of God;","searchKeywords":["for","appointed","them","wait","aaron","minister","the","house","lord","over","courts","and","chambers","purification","all","holy","things","works","service","god"]},{"verseId":"brenton_1-chronicles_23_29","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":29,"text":"and for the shew-bread, and for the fine flour of the meat-offering, and for the unleavened cakes, and for the fried cake, and for the dough, and for every measure;","searchKeywords":["and","for","the","shew","bread","fine","flour","meat","offering","unleavened","cakes","fried","cake","dough","every","measure"]},{"verseId":"brenton_1-chronicles_23_30","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":30,"text":"and to stand in the morning to praise and give thanks to the Lord, and so in the evening;","searchKeywords":["and","stand","the","morning","praise","give","thanks","lord","evening"]},{"verseId":"brenton_1-chronicles_23_31","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":31,"text":"and over all the whole-burnt-offerings that were offered up to the Lord on the sabbaths, and at the new moons, and at the feasts, by number, according to the order to them, continually before the Lord.","searchKeywords":["and","over","all","the","whole","burnt","offerings","that","were","offered","lord","sabbaths","new","moons","feasts","number","according","order","them","continually","before"]},{"verseId":"brenton_1-chronicles_23_32","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":23,"verse":32,"text":"And they are to keep the charge of the tabernacle of witness, and the charge of the holy place, and the charges of the sons of Aaron their brethren, to minister in the house of the Lord.","searchKeywords":["and","they","are","keep","the","charge","tabernacle","witness","holy","place","charges","sons","aaron","their","brethren","minister","house","lord"]}]