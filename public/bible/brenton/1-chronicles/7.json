[{"verseId":"brenton_1-chronicles_7_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":1,"text":"And to the sons of Issachar, Thola, and Phua, and Jasub, and Semeron, four.","searchKeywords":["and","the","sons","issachar","thola","phua","jasub","semeron","four"]},{"verseId":"brenton_1-chronicles_7_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":2,"text":"And the sons of Thola; Ozi, Raphaia, and Jeriel, and Jamai, and Jemasan, and Samuel, chiefs of their fathers' houses Thola, men of might according to their generations; their number in the days of David twenty and two thousand and six hundred.","searchKeywords":["and","the","sons","thola","ozi","raphaia","jeriel","jamai","jemasan","samuel","chiefs","their","fathers","houses","men","might","according","generations","number","days","david","twenty","two","thousand","six","hundred"]},{"verseId":"brenton_1-chronicles_7_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":3,"text":"And the sons of Ozi; Jezraia: and the sons of Jezraia; Michael, Abdiu, and Joel, and Jesia, five, all rulers.","searchKeywords":["and","the","sons","ozi","jezraia","michael","abdiu","joel","jesia","five","all","rulers"]},{"verseId":"brenton_1-chronicles_7_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":4,"text":"And with them, according to their generations, according to the houses of their families, mighty to set in array for war, thirty and six thousand, for they had multiplied wives and children.","searchKeywords":["and","with","them","according","their","generations","the","houses","families","mighty","set","array","for","war","thirty","six","thousand","they","had","multiplied","wives","children"]},{"verseId":"brenton_1-chronicles_7_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":5,"text":"And their brethren among all the families of Issachar, also mighty men, eighty-seven thousand— the number of them all.","searchKeywords":["and","their","brethren","among","all","the","families","issachar","also","mighty","men","eighty","seven","thousand","number","them"]},{"verseId":"brenton_1-chronicles_7_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":6,"text":"The sons of Benjamin; Bale, and Bachir, and Jediel, three.","searchKeywords":["the","sons","benjamin","bale","and","bachir","jediel","three"]},{"verseId":"brenton_1-chronicles_7_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":7,"text":"And the sons of Bale; Esebon, and Ozi, and Oziel, and Jerimuth, and Uri, five; heads of houses of families, mighty men; and their number twenty and two thousand and thirty-four.","searchKeywords":["and","the","sons","bale","esebon","ozi","oziel","jerimuth","uri","five","heads","houses","families","mighty","men","their","number","twenty","two","thousand","thirty","four"]},{"verseId":"brenton_1-chronicles_7_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":8,"text":"And the sons of Bachir; Zemira, and Joas, and Eliezer, and Elithenan, and Amaria, and Jerimuth, and Abiud, and Anathoth, and Eleemeth: all these the sons of Bachir.","searchKeywords":["and","the","sons","bachir","zemira","joas","eliezer","elithenan","amaria","jerimuth","abiud","anathoth","eleemeth","all","these"]},{"verseId":"brenton_1-chronicles_7_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":9,"text":"And their number according to their generations, ( chiefs of their fathers' houses, men of might), twenty thousand and two hundred.","searchKeywords":["and","their","number","according","generations","chiefs","fathers","houses","men","might","twenty","thousand","two","hundred"]},{"verseId":"brenton_1-chronicles_7_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":10,"text":"And the sons of Jediel; Balaan: and the sons of Balaan; Jaüs, and Benjamin, and Aoth, and Chanana, and Zæthan, and Tharsi, and Achisaar.","searchKeywords":["and","the","sons","jediel","balaan","benjamin","aoth","chanana","than","tharsi","achisaar"]},{"verseId":"brenton_1-chronicles_7_11","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":11,"text":"All these the sons of Jediel, chiefs of their families, men of might, seventeen thousand and two hundred, going forth to war with might.","searchKeywords":["all","these","the","sons","jediel","chiefs","their","families","men","might","seventeen","thousand","and","two","hundred","going","forth","war","with"]},{"verseId":"brenton_1-chronicles_7_12","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":12,"text":"And Sapphin, and Apphin, and the sons of Or, Asom, whose son Aor.","searchKeywords":["and","sapphin","apphin","the","sons","asom","whose","son","aor"]},{"verseId":"brenton_1-chronicles_7_13","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":13,"text":"The sons of Nephthali; Jasiel, Goni, and Aser, and Sellum, his sons, Balam his son.","searchKeywords":["the","sons","nephthali","jasiel","goni","and","aser","sellum","his","balam","son"]},{"verseId":"brenton_1-chronicles_7_14","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":14,"text":"The sons of Manasse; Esriel, whom his Syrian concubine bore; and she bore to him also Machir the father of Galaad.","searchKeywords":["the","sons","manasse","esriel","whom","his","syrian","concubine","bore","and","she","him","also","machir","father","galaad"]},{"verseId":"brenton_1-chronicles_7_15","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":15,"text":"And Machir took a wife for Apphin and Sapphin, and his sister's name was Moöcha; and the name of the second was Sapphaad; and to Sapphaad were born daughters.","searchKeywords":["and","machir","took","wife","for","apphin","sapphin","his","sister","name","was","cha","the","second","sapphaad","were","born","daughters"]},{"verseId":"brenton_1-chronicles_7_16","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":16,"text":"And Moöcha the wife of Machir bore a son, and called his name Phares; and his brother's name Surus; his sons Ulam, and Rocom.","searchKeywords":["and","cha","the","wife","machir","bore","son","called","his","name","phares","brother","surus","sons","ulam","rocom"]},{"verseId":"brenton_1-chronicles_7_17","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":17,"text":"And the sons of Ulam; Badam. These the sons of Galaad, the son of Machir, the son of Manasse.","searchKeywords":["and","the","sons","ulam","badam","these","galaad","son","machir","manasse"]},{"verseId":"brenton_1-chronicles_7_18","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":18,"text":"And his sister Malecheth bore Isud, and Abiezer, and Maela.","searchKeywords":["and","his","sister","malecheth","bore","isud","abiezer","maela"]},{"verseId":"brenton_1-chronicles_7_19","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":19,"text":"And the sons of Semira were, Aim, and Sychem, and Lakim, and Anian.","searchKeywords":["and","the","sons","semira","were","aim","sychem","lakim","anian"]},{"verseId":"brenton_1-chronicles_7_20","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":20,"text":"And the sons of Ephraim; Sothalath, and Barad his son, and Thaath his son, Elada his son, Saath his son,","searchKeywords":["and","the","sons","ephraim","sothalath","barad","his","son","thaath","elada","saath"]},{"verseId":"brenton_1-chronicles_7_21","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":21,"text":"and Zabad his son, Sothele his son, and Azer, and Elead: and the men of Geth who were born in the land slew them, because they went down to take their cattle.","searchKeywords":["and","zabad","his","son","sothele","azer","elead","the","men","geth","who","were","born","land","slew","them","because","they","went","down","take","their","cattle"]},{"verseId":"brenton_1-chronicles_7_22","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":22,"text":"And their father Ephraim mourned many days, and his brethren came to comfort him.","searchKeywords":["and","their","father","ephraim","mourned","many","days","his","brethren","came","comfort","him"]},{"verseId":"brenton_1-chronicles_7_23","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":23,"text":"And he went in to his wife, and she conceived, and bore a son, and he called his name Beria, because, , He was afflicted in my house.","searchKeywords":["and","went","his","wife","she","conceived","bore","son","called","name","beria","because","was","afflicted","house"]},{"verseId":"brenton_1-chronicles_7_24","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":24,"text":"And his daughter Saraa, and he was among them that were left, and he built Bæthoron the upper and the lower. And the descendants of Ozan Seera,","searchKeywords":["and","his","daughter","saraa","was","among","them","that","were","left","built","thoron","the","upper","lower","descendants","ozan","seera"]},{"verseId":"brenton_1-chronicles_7_25","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":25,"text":"and Raphe his son, Saraph and Thalees his sons, Thaen his son.","searchKeywords":["and","raphe","his","son","saraph","thalees","sons","thaen"]},{"verseId":"brenton_1-chronicles_7_26","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":26,"text":"To Laadan his son son Amiud, his son Helisamai, son","searchKeywords":["laadan","his","son","amiud","helisamai"]},{"verseId":"brenton_1-chronicles_7_27","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":27,"text":"Nun, son Jesue, his sons.","searchKeywords":["nun","son","jesue","his","sons"]},{"verseId":"brenton_1-chronicles_7_28","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":28,"text":"And their possession and their dwelling Bæthel and her towns, to the east Noaran, westward Gazer and her towns, and Sychem and her towns, as far as Gaza and her towns.","searchKeywords":["and","their","possession","dwelling","thel","her","towns","the","east","noaran","westward","gazer","sychem","far","gaza"]},{"verseId":"brenton_1-chronicles_7_29","