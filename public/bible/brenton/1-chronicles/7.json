":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":34,"text":"And the sons of Semmer; Achir, and Rooga, and Jaba, and Aram.","searchKeywords":["and","the","sons","semmer","achir","rooga","jaba","aram"]},{"verseId":"brenton_1-chronicles_7_35","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":35,"text":"And the sons of Elam his brother; Sopha, and Imana, and Selles, and Amal.","searchKeywords":["and","the","sons","elam","his","brother","sopha","imana","selles","amal"]},{"verseId":"brenton_1-chronicles_7_36","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":36,"text":"The sons of Sopha; Sue, and Arnaphar, and Suda, and Barin, and Imran,","searchKeywords":["the","sons","sopha","sue","and","arnaphar","suda","barin","imran"]},{"verseId":"brenton_1-chronicles_7_37","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":37,"text":"and Basan, and Oa, and Sama, and Salisa, and Jethra, and Beëra.","searchKeywords":["and","basan","sama","salisa","jethra"]},{"verseId":"brenton_1-chronicles_7_38","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":38,"text":"And the sons of Jether, Jephina, and Phaspha, and Ara.","searchKeywords":["and","the","sons","jether","jephina","phaspha","ara"]},{"verseId":"brenton_1-chronicles_7_39","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7,"verse":39,"text":"And the sons of Ola; Orech, Aniel, and Rasia.","searchKeywords":["and","the","sons","ola","orech","aniel","rasia"]},{"verseId":"brenton_1-chronicles_7_40","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":7