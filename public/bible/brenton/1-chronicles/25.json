[{"verseId":"brenton_1-chronicles_25_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":25,"verse":1,"text":"And king David and the captains of the host appointed to their services the sons of Asaph, and of Æman, and of Idithun, prophesiers with harps, and lutes, and cymbals: and their number was according to their polls serving in their ministrations.","searchKeywords":["and","king","david","the","captains","host","appointed","their","services","sons","asaph","man","idithun","prophesiers","with","harps","lutes","cymbals","number","was","according","polls","serving","ministrations"]},{"verseId":"brenton_1-chronicles_25_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":25,"verse":2,"text":"The sons of Asaph; Sacchur, Joseph, and Nathanias, and Erael: the sons of Asaph next the king.","searchKeywords":["the","sons","asaph","sacchur","joseph","and","nathanias","erael","next","king"]},{"verseId":"brenton_1-chronicles_25_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":25,"verse":3,"text":"To Idithun the sons of Idithun, Godolias, and Suri, and Iseas, and Asabias, and Matthathias, six after their father Idithun, sounding loudly on the harp thanksgiving and praise to the Lord.","searchKeywords":["idithun","the","sons","godolias","and","suri","iseas","asabias","matthathias","six","after","their","father","sounding","loudly","harp","thanksgiving","praise","lord"]},{"verseId":"brenton_1-chronicles_25_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":25,"verse":4,"text":"To Æman the sons of Æman, Bukias, and Matthanias, and Oziel, and Subael, and Jerimoth, and Ananias, and Anan, and Heliatha, and Godollathi, and Rometthiezer, and Jesbasaca, and Mallithi, and Otheri, and Meazoth.","