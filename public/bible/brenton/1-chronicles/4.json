[{"verseId":"brenton_1-chronicles_4_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":1,"text":"And the sons of Juda; Phares, Esrom, and Charmi, and Or, Subal,","searchKeywords":["and","the","sons","juda","phares","esrom","charmi","subal"]},{"verseId":"brenton_1-chronicles_4_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":2,"text":"and Rada his son; and Subal begot Jeth; and Jeth begot Achimai, and Laad: these the generations of the Arathites.","searchKeywords":["and","rada","his","son","subal","begot","jeth","achimai","laad","these","the","generations","arathites"]},{"verseId":"brenton_1-chronicles_4_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":3,"text":"And these the sons of Ætam; Jezrael and Jesman, and Jebdas: and their sister's name Eselebbon.","searchKeywords":["and","these","the","sons","tam","jezrael","jesman","jebdas","their","sister","name","eselebbon"]},{"verseId":"brenton_1-chronicles_4_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":4,"text":"And Phanuel the father of Gedor, and Jazer the father of Osan: these the sons of Or, the first-born of Ephratha, the father of Bæthalaen.","searchKeywords":["and","phanuel","the","father","gedor","jazer","osan","these","sons","first","born","ephratha","thalaen"]},{"verseId":"brenton_1-chronicles_4_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":5,"text":"And Asur the father of Thecoe had two wives, Aoda and Thoada.","searchKeywords":["and","asur","the","father","thecoe","had","two","wives","aoda","thoada"]},{"verseId":"brenton_1-chronicles_4_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":6,"text":"And Aoda bore to him Ochaia, and Ephal, and Thæman, and Aasther: all these the sons of Aoda.","searchKeywords":["and","aoda","bore","him","ochaia","ephal","man","aasther","all","these","the","sons"]},{"verseId":"brenton_1-chronicles_4_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":7,"text":"And the sons of Thoada; Sereth, and Saar, and Esthanam.","searchKeywords":["and","the","sons","thoada","sereth","saar","esthanam"]},{"verseId":"brenton_1-chronicles_4_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":8,"text":"And Coe begot Enob, and Sabatha, and the progeny of the brother of Rechab, the son of Jarin.","searchKeywords":["and","coe","begot","enob","sabatha","the","progeny","brother","rechab","son","jarin"]},{"verseId":"brenton_1-chronicles_4_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":9,"text":"And Igabes was more famous than his brethren; and his mother called his name Igabes, saying, I have born as a sorrowful one.","searchKeywords":["and","igabes","was","more","famous","than","his","brethren","mother","called","name","saying","have","born","sorrowful","one"]},{"verseId":"brenton_1-chronicles_4_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":10,"text":"And Igabes called on the God of Israel, saying, O that thou wouldest indeed bless me, and enlarge my coasts, and that thy hand might be with me, and that thou wouldest make me know that thou wilt not grieve me! And God granted him all that he asked.","searchKeywords":["and","igabes","called","the","god","israel","saying","that","thou","wouldest","indeed","bless","enlarge","coasts","thy","hand","might","with","make","know","wilt","not","grieve","granted","him","all","asked"]},{"verseId":"brenton_1-chronicles_4_11","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":11,"text":"And Chaleb the father of Ascha begot Machir; he the father of Assathon.","searchKeywords":["and","chaleb","the","father","ascha","begot","machir","assathon"]},{"verseId":"brenton_1-chronicles_4_12","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":12,"text":"He begot Bathraias, and Besseë, and Thæman the founder of the city of Naas the brother of Eselom the Kenezite: these the men of Rechab.","searchKeywords":["begot","bathraias","and","besse","man","the","founder","city","naas","brother","eselom","kenezite","these","men","rechab"]},{"verseId":"brenton_1-chronicles_4_13","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":13,"text":"And the sons of Kenez; Gothoniel, and Saraia: and the sons of Gothoniel; Athath.","searchKeywords":["and","the","sons","kenez","gothoniel","saraia","athath"]},{"verseId":"brenton_1-chronicles_4_14","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":14,"text":"And Manathi begot Gophera: and Saraia begot Jobab, the father of Ageaddair, for they were artificers.","searchKeywords":["and","manathi","begot","gophera","saraia","jobab","the","father","ageaddair","for","they","were","artificers"]},{"verseId":"brenton_1-chronicles_4_15","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":15,"text":"And the sons of Chaleb the son of Jephonne; Er, Ada, and Noom: and the sons of Ada, Kenez.","searchKeywords":["and","the","sons","chaleb","son","jephonne","ada","noom","kenez"]},{"verseId":"brenton_1-chronicles_4_16","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":16,"text":"And the sons of Aleel, Zib, and Zepha, and Thiria, and Eserel.","searchKeywords":["and","the","sons","aleel","zib","zepha","thiria","eserel"]},{"verseId":"brenton_1-chronicles_4_17","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":17,"text":"And the sons of Esri; Jether, Morad, and Apher, and Jamon: and Jether begot Maron, and Semei, and Jesba the father of Esthæmon.","searchKeywords":["and","the","sons","esri","jether","morad","apher","jamon","begot","maron","semei","jesba","father","esth","mon"]},{"verseId":"brenton_1-chronicles_4_18","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":18,"text":"And his wife, that Adia, bore Jared the father of Gedor, and Aber the father of Sochon, and Chetiel the father of Zamon: and these the sons of Betthia the daughter of Pharao, whom Mored took.","searchKeywords":["and","his","wife","that","adia","bore","jared","the","father","gedor","aber","sochon","chetiel","zamon","these","sons","betthia","daughter","pharao","whom","mored","took"]},{"verseId":"brenton_1-chronicles_4_19","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":19,"text":"And the sons of the wife of Iduia the sister of Nachaim the father of Keila; Garmi, and Esthæmon the Nochathite.","searchKeywords":["and","the","sons","wife","iduia","sister","nachaim","father","keila","garmi","esth","mon","nochathite"]},{"verseId":"brenton_1-chronicles_4_20","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":20,"text":"And the sons of Semon; Amnon, and Ana the son of Phana, and Inon: and the sons of Sei, Zoan, and the sons of Zoab.","searchKeywords":["and","the","sons","semon","amnon","ana","son","phana","inon","sei","zoan","zoab"]},{"verseId":"brenton_1-chronicles_4_21","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":21,"text":"The sons of Selom the son of Juda; Er the father of Lechab, and Laada the father of Marisa, and the offspring of the family of Ephrathabac the house of Esoba.","searchKeywords":["the","sons","selom","son","juda","father","lechab","and","laada","marisa","offspring","family","ephrathabac","house","esoba"]},{"verseId":"brenton_1-chronicles_4_22","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":22,"text":"And Joakim, and the men of Chozeba, and Joas, and Saraph, who dwelt in Moab, and he changed their names to Abederin and Athukiim.","searchKeywords":["and","joakim","the","men","chozeba","joas","saraph","who","dwelt","moab","changed","their","names","abederin","athukiim"]},{"verseId":"brenton_1-chronicles_4_23","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":23,"text":"These the potters who dwelt in Ataim and Gadira with the king: they grew strong in his kingdom, and dwelt there.","searchKeywords":["these","the","potters","who","dwelt","ataim","and","gadira","with","king","they","grew","strong","his","kingdom","there"]},{"verseId":"brenton_1-chronicles_4_24","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":24,"text":"The sons of Semeon; Namuel, and Jamin, Jarib, Zares, Saul:","searchKeywords":["the","sons","semeon","namuel","and","jamin","jarib","zares","saul"]},{"verseId":"brenton_1-chronicles_4_25","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":25,"text":"Salem his son, Mabasam his son, Masma his son:","searchKeywords":["salem","his","son","mabasam","masma"]},{"verseId":"brenton_1-chronicles_4_26","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":26,"text":"Amuel his son, Sabud his son, Zacchur his son, Semei his son.","searchKeywords":["amuel","his","son","sabud","zacchur","semei"]},{"verseId":"brenton_1-chronicles_4_27","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":27,"text":"Semei sixteen sons, and six daughters; and his brethren had not many sons, neither did all their families multiply as the sons of Juda.","searchKeywords":["semei","sixteen","sons","and","six","daughters","his","brethren","had","not","many","neither","did","all","their","families","multiply","the","juda"]},{"verseId":"brenton_1-chronicles_4_28","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":28,"text":"And they dwelt in Bersabee, and Molada, and in Esersual,","searchKeywords":["and","they","dwelt","bersabee","molada","esersual"]},{"verseId":"brenton_1-chronicles_4_29","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":29,"text":"and in Balaa, and in Æsem, and in Tholad,","searchKeywords":["and","balaa","sem","tholad"]},{"verseId":"brenton_1-chronicles_4_30","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":30,"text":"and in Bathuel, and in Herma, and in Sikelag,","searchKeywords":["and","bathuel","herma","sikelag"]},{"verseId":"brenton_1-chronicles_4_31","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":31,"text":"and in Bæthmarimoth, and Hemisuseosin, and the house of Baruseorim: these their cities until king David.","searchKeywords":["and","thmarimoth","hemisuseosin","the","house","baruseorim","these","their","cities","until","king","david"]},{"verseId":"brenton_1-chronicles_4_32","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":32,"text":"And their villages Ætan, and En, Remnon, and Thocca, and Æsar, five cities.","searchKeywords":["and","their","villages","tan","remnon","thocca","sar","five","cities"]},{"verseId":"brenton_1-chronicles_4_33","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":33,"text":"And all their villages round about these cities, as far as Baal: this their possession, and their distribution.","searchKeywords":["and","all","their","villages","round","about","these","cities","far","baal","this","possession","distribution"]},{"verseId":"brenton_1-chronicles_4_34","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":34,"text":"And Mosobab, and Jemoloch, and Josia the son of Amasia;","searchKeywords":["and","mosobab","jemoloch","josia","the","son","amasia"]},{"verseId":"brenton_1-chronicles_4_35","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":35,"text":"and Joel, and Jeu the son of Asabia, the son of Sarau, the son of Asiel;","searchKeywords":["and","joel","jeu","the","son","asabia","sarau","asiel"]},{"verseId":"brenton_1-chronicles_4_36","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":36,"text":"and Elionai, and Jocaba, and Jasuia, and Asaia, and Jediel, and Ismael, and Banaias;","searchKeywords":["and","elionai","jocaba","jasuia","asaia","jediel","ismael","banaias"]},{"verseId":"brenton_1-chronicles_4_37","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":37,"text":"and Zuza the son of Saphai, the son of Alon, the son of Jedia, the son of Semri, the son of Samaias.","searchKeywords":["and","zuza","the","son","saphai","alon","jedia","semri","samaias"]},{"verseId":"brenton_1-chronicles_4_38","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":38,"text":"These went by the names of princes in their families, and they increased abundantly in their fathers' households.","searchKeywords":["these","went","the","names","princes","their","families","and","they","increased","abundantly","fathers","households"]},{"verseId":"brenton_1-chronicles_4_39","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":39,"text":"And they went till they came to Gerara, to the east of Gai, to seek pasture for their cattle.","searchKeywords":["and","they","went","till","came","gerara","the","east","gai","seek","pasture","for","their","cattle"]},{"verseId":"brenton_1-chronicles_4_40","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":40,"text":"And they found abundant and good pastures, and the land before them wide, and peace and quietness; for some of the children of Cham who dwelt there before.","searchKeywords":["and","they","found","abundant","good","pastures","the","land","before","them","wide","peace","quietness","for","some","children","cham","who","dwelt","there"]},{"verseId":"brenton_1-chronicles_4_41","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":41,"text":"And these who are written by name came in the days of Ezekias king of Juda, and they smote the people's houses, and the Minæans whom they found there, and utterly destroyed them until this day: and they dwelt in their place, because pasture there for their cattle.","searchKeywords":["and","these","who","are","written","name","came","the","days","ezekias","king","juda","they","smote","people","houses","min","ans","whom","found","there","utterly","destroyed","them","until","this","day","dwelt","their","place","because","pasture","for","cattle"]},{"verseId":"brenton_1-chronicles_4_42","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":42,"text":"And some of them, of the sons of Symeon, went to mount Seir, five hundred men; and Phalaettia, and Noadia, and Raphaia, and Oziel, sons of Jesi, their rulers.","searchKeywords":["and","some","them","the","sons","symeon","went","mount","seir","five","hundred","men","phalaettia","noadia","raphaia","oziel","jesi","their","rulers"]},{"verseId":"brenton_1-chronicles_4_43","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":4,"verse":43,"text":"And they smote the remnant that were left of Amalec, until this day.","searchKeywords":["and","they","smote","the","remnant","that","were","left","amalec","until","this","day"]}]