[{"verseId":"brenton_1-chronicles_13_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":1,"text":"And David took counsel with the captains of thousands and captains of hundreds, every commander.","searchKeywords":["and","david","took","counsel","with","the","captains","thousands","hundreds","every","commander"]},{"verseId":"brenton_1-chronicles_13_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":2,"text":"And David said to the whole congregation of Israel, If it good to you, and it should be prospered by the Lord our God, let us send to our brethren that are left in all the land of Israel, and let the priests the Levites who are with them in the cities of their possession , and let them be gathered to us.","searchKeywords":["and","david","said","the","whole","congregation","israel","good","you","should","prospered","lord","our","god","let","send","brethren","that","are","left","all","land","priests","levites","who","with","them","cities","their","possession","gathered"]},{"verseId":"brenton_1-chronicles_13_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":3,"text":"And let us bring over to us the ark of our God; for men have not enquired it since the days of Saul.","searchKeywords":["and","let","bring","over","the","ark","our","god","for","men","have","not","enquired","since","days","saul"]},{"verseId":"brenton_1-chronicles_13_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":4,"text":"And all the congregation said that they would do thus; for the saying was right in the eyes of all the people.","searchKeywords":["and","all","the","congregation","said","that","they","would","thus","for","saying","was","right","eyes","people"]},{"verseId":"brenton_1-chronicles_13_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":5,"text":"So David assembled all Israel, from the borders of Egypt even to the entering in of Hemath, to bring in the ark of God from the city of Jarim.","searchKeywords":["david","assembled","all","israel","from","the","borders","egypt","even","entering","hemath","bring","ark","god","city","jarim"]},{"verseId":"brenton_1-chronicles_13_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":6,"text":"And David brought it up: and all Israel went up to the city of David, which belonged to Juda, to bring up thence the ark of the Lord God who sits between the cherubim, whose name is called .","searchKeywords":["and","david","brought","all","israel","went","the","city","which","belonged","juda","bring","thence","ark","lord","god","who","sits","between","cherubim","whose","name","called"]},{"verseId":"brenton_1-chronicles_13_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":7,"text":"And they set the ark of God on a new waggon out of the house of Aminadab: and Oza and his brethren drove the waggon.","searchKeywords":["and","they","set","the","ark","god","new","waggon","out","house","aminadab","oza","his","brethren","drove"]},{"verseId":"brenton_1-chronicles_13_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":8,"text":"And David and all Israel playing before the Lord with all their might, and together with singers, and with harps, and with lutes, with timbrels, and with cymbals, and with trumpets.","searchKeywords":["and","david","all","israel","playing","before","the","lord","with","their","might","together","singers","harps","lutes","timbrels","cymbals","trumpets"]},{"verseId":"brenton_1-chronicles_13_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":9,"text":"And they came as far as the threshing-floor: and Oza put forth his hand to hold the ark, because the bullock moved it from .","searchKeywords":["and","they","came","far","the","threshing","floor","oza","put","forth","his","hand","hold","ark","because","bullock","moved","from"]},{"verseId":"brenton_1-chronicles_13_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":10,"text":"And the Lord was very angry with Oza, and smote him there, because of his stretching forth his hand upon the ark: and he died there before God.","searchKeywords":["and","the","lord","was","very","angry","with","oza","smote","him","there","because","his","stretching","forth","hand","upon","ark","died","before","god"]},{"verseId":"brenton_1-chronicles_13_11","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":11,"text":"And David was dispirited, because the Lord made a breach on Oza: and he called that place the Breach of Oza until this day.","searchKeywords":["and","david","was","dispirited","because","the","lord","made","breach","oza","called","that","place","until","this","day"]},{"verseId":"brenton_1-chronicles_13_12","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":12,"text":"And David feared God that day, saying, How shall I bring the ark of God in to myself?","searchKeywords":["and","david","feared","god","that","day","saying","how","shall","bring","the","ark","myself"]},{"verseId":"brenton_1-chronicles_13_13","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":13,"text":"So David brought not the ark home to himself into the city of David, but he turned it aside into the house of Abeddara the Gethite.","searchKeywords":["david","brought","not","the","ark","home","himself","into","city","but","turned","aside","house","abeddara","gethite"]},{"verseId":"brenton_1-chronicles_13_14","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":13,"verse":14,"text":"And the ark of God abode in the house of Abeddara three months: and God blessed Abeddara and all that he had.","searchKeywords":["and","the","ark","god","abode","house","abeddara","three","months","blessed","all","that","had"]}]