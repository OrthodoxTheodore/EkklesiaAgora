[{"verseId":"brenton_1-chronicles_9_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":9,"verse":1,"text":"And all Israel, their enrolment: and these written down in the book of the kings of Israel and Juda, with the that were carried away to Babylon for their transgressions.","searchKeywords":["and","all","israel","their","enrolment","these","written","down","the","book","kings","juda","with","that","were","carried","away","babylon","for","transgressions"]},{"verseId":"brenton_1-chronicles_9_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":9,"verse":2,"text":"And they that dwelt before in their possessions in the cities of Israel, the priests, the Levites, and the appointed ones.","searchKeywords":["and","they","that","dwelt","before","their","possessions","the","cities","israel","priests","levites","appointed","ones"]},{"verseId":"brenton_1-chronicles_9_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":9,"verse":3,"text":"And there dwelt in Jerusalem some of the children of Juda, and of the children of Benjamin, and of the children of Ephraim, and Manasse.","searchKeywords":["and","there","dwelt","jerusalem","some","the","children","juda","benjamin","ephraim","manasse"]},{"verseId":"brenton_1-chronicles_9_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":9,"verse":4,"text":"And Gnothi, and the son of Samiud, the son of Amri, the son of Ambraim, the son of Buni, son of the sons of Phares, the son of Juda.","searchKeywords":["and","gnothi","the","son","samiud","amri","ambraim","buni","sons","phares","juda"]},{"verseId":"brenton_1-chronicles_9_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":9,"verse":5,"text":"And of the Selonites; Asaia his first-born, and his sons.","searchKeywords":["and","the","selonites","asaia","his","first","born","sons"]},{"verseId":"brenton_1-chronicles_9_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":9,"verse":6,"text":"Of the sons of Zara; Jeel, and their brethren, six hundred and ninety.","searchKeywords":["the","sons","zara","jeel","and","their","brethren","six","hundred","ninety"]},{"verseId":"brenton_1-chronicles_9_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":9,"verse":7,"text":"And of the sons of Benjamin; Salom, son of Mosollam, son of Odouia, son of Asinu.","searchKeywords":["and","the","sons","benjamin","salom","son","mosollam","odouia","asinu"]},{"verseId":"brenton_1-chronicles_9_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":9,"verse":8,"text":"And Jemnaa son of Jeroboam, and Elo: these the sons of Ozi the son of Machir: and Mosollam, son of Saphatia, son of Raguel, son of Jemnai;","searchKeywords":["and","jemnaa","son","jeroboam","elo","these","the","sons","ozi","machir","mosollam","saphatia","raguel","jemnai"]},{"verseId":"brenton_1-chronicles_9_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":9,"verse":9,"text":"and their brethren according to their generations, nine hundred and fifty-six, all the men heads of families according to the houses of their fathers.","searchKeywords":["and","their","brethren","according","generations","nine","hundred","fifty","six","all","the","men","heads","families","houses","fathers"]},{"verseId":"brenton_1-chronicles_9_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":9,"verse":10,"text":"And of the priest