[{"verseId":"brenton_1-chronicles_16_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":1,"text":"So they brought in the ark of God, and set it in the midst of the tabernacle which David pitched for it; and they offered whole-burnt-offerings and peace-offerings before God.","searchKeywords":["they","brought","the","ark","god","and","set","midst","tabernacle","which","david","pitched","for","offered","whole","burnt","offerings","peace","before"]},{"verseId":"brenton_1-chronicles_16_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":2,"text":"And David finished offering up whole-burnt-offerings and peace-offerings, and blessed the people in the name of the Lord.","searchKeywords":["and","david","finished","offering","whole","burnt","offerings","peace","blessed","the","people","name","lord"]},{"verseId":"brenton_1-chronicles_16_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":3,"text":"And he divided to every man of Israel (both men and women), to man one baker's loaf, and a cake.","searchKeywords":["and","divided","every","man","israel","both","men","women","one","baker","loaf","cake"]},{"verseId":"brenton_1-chronicles_16_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":4,"text":"And he appointed before the ark of the covenant of the Lord, Levites to minister lift up the voice, and to give thanks and praise the Lord God of Israel:","searchKeywords":["and","appointed","before","the","ark","covenant","lord","levites","minister","lift","voice","give","thanks","praise","god","israel"]},{"verseId":"brenton_1-chronicles_16_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":5,"text":"Asaph the chief, and next to him Zacharias, Jeiel, Semiramoth, and Jeiel, Mattathias, Eliab, and Banæas, and Abdedom: and Jeiel sounding with musical instruments, lutes harps, and Asaph with cymbals:","searchKeywords":["asaph","the","chief","and","next","him","zacharias","jeiel","semiramoth","mattathias","eliab","ban","abdedom","sounding","with","musical","instruments","lutes","harps","cymbals"]},{"verseId":"brenton_1-chronicles_16_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":6,"text":"and Banæas and Oziel the priests continually with trumpets before the ark of the covenant of God in that day.","searchKeywords":["and","ban","oziel","the","priests","continually","with","trumpets","before","ark","covenant","god","that","day"]},{"verseId":"brenton_1-chronicles_16_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":7,"text":"Then David first gave orders to praise the Lord by the hand of Asaph and his brethren.","searchKeywords":["then","david","first","gave","orders","praise","the","lord","hand","asaph","and","his","brethren"]},{"verseId":"brenton_1-chronicles_16_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":8,"text":"Song. Give thanks to the Lord, call upon him by his name, make known his designs among the people.","searchKeywords":["song","give","thanks","the","lord","call","upon","him","his","name","make","known","designs","among","people"]},{"verseId":"brenton_1-chronicles_16_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":9,"text":"Sing to him, and sing hymns to him, relate to all his wonderful deeds, which the Lord has wrought.","searchKeywords":["sing","him","and","hymns","relate","all","his","wonderful","deeds","which","the","lord","has","wrought"]},{"verseId":"brenton_1-chronicles_16_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":10,"text":"Praise his holy name, the heart that seeks his pleasure shall rejoice.","searchKeywords":["praise","his","holy","name","the","heart","that","seeks","pleasure","shall","rejoice"]},{"verseId":"brenton_1-chronicles_16_11","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":11,"text":"Seek the Lord and be strong, seek his face continually.","searchKeywords":["seek","the","lord","and","strong","his","face","continually"]},{"verseId":"brenton_1-chronicles_16_12","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":12,"text":"Remember his wonderful works which he has wrought, his wonders, and the judgments of his mouth;","searchKeywords":["remember","his","wonderful","works","which","has","wrought","wonders","and","the","judgments","mouth"]},{"verseId":"brenton_1-chronicles_16_13","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":13,"text":"seed of Israel his servants, seed of Jacob his chosen ones.","searchKeywords":["seed","israel","his","servants","jacob","chosen","ones"]},{"verseId":"brenton_1-chronicles_16_14","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":14,"text":"He the Lord our God; his judgments in all the earth.","searchKeywords":["the","lord","our","god","his","judgments","all","earth"]},{"verseId":"brenton_1-chronicles_16_15","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":15,"text":"Let us remember his covenant for ever, his word which he commanded to a thousand generations,","searchKeywords":["let","remember","his","covenant","for","ever","word","which","commanded","thousand","generations"]},{"verseId":"brenton_1-chronicles_16_16","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":16,"text":"which he covenanted with Abraham, and his oath to Isaac.","searchKeywords":["which","covenanted","with","abraham","and","his","oath","isaac"]},{"verseId":"brenton_1-chronicles_16_17","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":17,"text":"He confirmed it to Jacob for an ordinance, to Israel an everlasting covenant,","searchKeywords":["confirmed","jacob","for","ordinance","israel","everlasting","covenant"]},{"verseId":"brenton_1-chronicles_16_18","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":18,"text":"saying, To thee will I give the land of Chanaan, the line of your inheritance:","searchKeywords":["saying","thee","will","give","the","land","chanaan","line","your","inheritance"]},{"verseId":"brenton_1-chronicles_16_19","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":19,"text":"when they were few in number, when they were but little, and dwelt as strangers in it;","searchKeywords":["when","they","were","few","number","but","little","and","dwelt","strangers"]},{"verseId":"brenton_1-chronicles_16_20","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":20,"text":"and went from nation to nation, and from one kingdom to another people.","searchKeywords":["and","went","from","nation","one","kingdom","another","people"]},{"verseId":"brenton_1-chronicles_16_21","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":21,"text":"He suffered not a man to oppress them, and he reproved kings for their sakes,","searchKeywords":["suffered","not","man","oppress","them","and","reproved","kings","for","their","sakes"]},{"verseId":"brenton_1-chronicles_16_22","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":22,"text":"saying, Touch not my anointed ones, and deal not wrongfully with my prophets.","searchKeywords":["saying","touch","not","anointed","ones","and","deal","wrongfully","with","prophets"]},{"verseId":"brenton_1-chronicles_16_23","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":23,"text":"Sing ye to the Lord, all the earth; proclaim his salvation from day to day.","searchKeywords":["sing","the","lord","all","earth","proclaim","his","salvation","from","day"]},{"verseId":"brenton_1-chronicles_16_25","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":25,"text":"great, and greatly to be praised: he to be feared above all gods.","searchKeywords":["great","and","greatly","praised","feared","above","all","gods"]},{"verseId":"brenton_1-chronicles_16_26","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":26,"text":"idols; but our God made the heavens.","searchKeywords":["idols","but","our","god","made","the","heavens"]},{"verseId":"brenton_1-chronicles_16_27","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":27,"text":"in his presence; strength and rejoicing in his place.","searchKeywords":["his","presence","strength","and","rejoicing","place"]},{"verseId":"brenton_1-chronicles_16_29","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":29,"text":"to his name: take gifts and offer before him; and worship the Lord in his holy courts.","searchKeywords":["his","name","take","gifts","and","offer","before","him","worship","the","lord","holy","courts"]},{"verseId":"brenton_1-chronicles_16_34","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":34,"text":"good, for his mercy for ever.","searchKeywords":["good","for","his","mercy","ever"]},{"verseId":"brenton_1-chronicles_16_36","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":36,"text":"the Lord God of Israel from everlasting and to everlasting:","searchKeywords":["the","lord","god","israel","from","everlasting","and"]},{"verseId":"brenton_1-chronicles_16_38","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":38,"text":"sixty and eight; and Abdedom the son of Idithun, and Osa, to be door-keepers.","searchKeywords":["sixty","and","eight","abdedom","the","son","idithun","osa","door","keepers"]},{"verseId":"brenton_1-chronicles_16_39","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":39,"text":"Sadoc the priest, and his brethren the priests, before the tabernacle of the Lord in the high place in Gabaon,","searchKeywords":["sadoc","the","priest","and","his","brethren","priests","before","tabernacle","lord","high","place","gabaon"]},{"verseId":"brenton_1-chronicles_16_41","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":41,"text":"Æman and Idithun, and the rest chosen out by name to praise the Lord, for his mercy for ever.","searchKeywords":["man","and","idithun","the","rest","chosen","out","name","praise","lord","for","his","mercy","ever"]},{"verseId":"brenton_1-chronicles_16_42","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":16,"verse":42,"text":"trumpets and cymbals to sound aloud, and musical instruments for the songs of God: and the sons of Idithun at the gate.","searchKeywords":["trumpets","and","cymbals","sound","aloud","musical","instruments","for","the","songs","god","sons","idithun","gate"]}]