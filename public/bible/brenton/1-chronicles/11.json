[{"verseId":"brenton_1-chronicles_11_1","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":1,"text":"And all Israel came to David in Chebron, saying, Behold, we thy bones and thy flesh.","searchKeywords":["and","all","israel","came","david","chebron","saying","behold","thy","bones","flesh"]},{"verseId":"brenton_1-chronicles_11_2","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":2,"text":"And heretofore when Saul was king, thou wast he that led Israel in and out, and the Lord of Israel said to thee, Thou shalt feed my people Israel, and thou shalt be for a ruler over Israel.","searchKeywords":["and","heretofore","when","saul","was","king","thou","wast","that","led","israel","out","the","lord","said","thee","shalt","feed","people","for","ruler","over"]},{"verseId":"brenton_1-chronicles_11_3","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":3,"text":"And all the elders of Israel came to the king to Chebron; and king David made a covenant with them in Chebron before the Lord: and they anointed David to be king over Israel, according to the word of the Lord by Samuel.","searchKeywords":["and","all","the","elders","israel","came","king","chebron","david","made","covenant","with","them","before","lord","they","anointed","over","according","word","samuel"]},{"verseId":"brenton_1-chronicles_11_4","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":4,"text":"And the king and his men went to Jerusalem, this Jebus; and there the Jebusites the inhabitants of the land said to David,","searchKeywords":["and","the","king","his","men","went","jerusalem","this","jebus","there","jebusites","inhabitants","land","said","david"]},{"verseId":"brenton_1-chronicles_11_5","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":5,"text":"Thou shalt not enter in hither. But he took the strong hold of Sion: this the city of David.","searchKeywords":["thou","shalt","not","enter","hither","but","took","the","strong","hold","sion","this","city","david"]},{"verseId":"brenton_1-chronicles_11_6","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":6,"text":"And David said, Whoever first smites the Jebusite, even he shall be chief and captain. And Joab the son of Saruia went up first, and became chief.","searchKeywords":["and","david","said","whoever","first","smites","the","jebusite","even","shall","chief","captain","joab","son","saruia","went","became"]},{"verseId":"brenton_1-chronicles_11_7","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":7,"text":"And David dwelt in the strong hold; therefore he called it the city of David.","searchKeywords":["and","david","dwelt","the","strong","hold","therefore","called","city"]},{"verseId":"brenton_1-chronicles_11_8","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":8,"text":"And he fortified the city round about.","searchKeywords":["and","fortified","the","city","round","about"]},{"verseId":"brenton_1-chronicles_11_9","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":9,"text":"And David continued to increase, and the Lord Almighty with him.","searchKeywords":["and","david","continued","increase","the","lord","almighty","with","him"]},{"verseId":"brenton_1-chronicles_11_10","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":10,"text":"And these the chiefs of the mighty men, whom David had, who strengthened with him in his kingdom, with all Israel, to make him king, according to the word of the Lord concerning Israel.","searchKeywords":["and","these","the","chiefs","mighty","men","whom","david","had","who","strengthened","with","him","his","kingdom","all","israel","make","king","according","word","lord","concerning"]},{"verseId":"brenton_1-chronicles_11_11","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":11,"text":"And this the list of the mighty of David; Jesebada, son of Achaman, first of the thirty: he drew his sword once against three hundred whom he slew at one time.","searchKeywords":["and","this","the","list","mighty","david","jesebada","son","achaman","first","thirty","drew","his","sword","once","against","three","hundred","whom","slew","one","time"]},{"verseId":"brenton_1-chronicles_11_12","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":12,"text":"And after him Eleazar son of Dodai, the Achochite: he was among the three mighty men.","searchKeywords":["and","after","him","eleazar","son","dodai","the","achochite","was","among","three","mighty","men"]},{"verseId":"brenton_1-chronicles_11_13","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":13,"text":"He was with David in Phasodamin, and the Philistines were gathered there to battle, and a portion of the field full of barley; and the people fled before the Philistines.","searchKeywords":["was","with","david","phasodamin","and","the","philistines","were","gathered","there","battle","portion","field","full","barley","people","fled","before"]},{"verseId":"brenton_1-chronicles_11_14","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":14,"text":"And he stood in the midst of the portion, and rescued it, and smote the Philistines; and the Lord wrought a great deliverance.","searchKeywords":["and","stood","the","midst","portion","rescued","smote","philistines","lord","wrought","great","deliverance"]},{"verseId":"brenton_1-chronicles_11_15","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":15,"text":"And three of the thirty chiefs went down to the rock to David, to the cave of Odollam, and the camp of the Philistines in the giants' valley.","searchKeywords":["and","three","the","thirty","chiefs","went","down","rock","david","cave","odollam","camp","philistines","giants","valley"]},{"verseId":"brenton_1-chronicles_11_16","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":16,"text":"And David then in the hold, and the garrison of the Philistines then in Bethleem.","searchKeywords":["and","david","then","the","hold","garrison","philistines","bethleem"]},{"verseId":"brenton_1-chronicles_11_17","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":17,"text":"And David longed, and said, Who will give me water to drink of the well of Bethleem, that is in the gate?","searchKeywords":["and","david","longed","said","who","will","give","water","drink","the","well","bethleem","that","gate"]},{"verseId":"brenton_1-chronicles_11_18","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":18,"text":"And the three broke through the camp of the Philistines, and they drew water out of the well that was in Bethleem, which was in the gate, and they took it, and came to David: but David would not drink it, and poured it out to the Lord, and said,","searchKeywords":["and","the","three","broke","through","camp","philistines","they","drew","water","out","well","that","was","bethleem","which","gate","took","came","david","but","would","not","drink","poured","lord","said"]},{"verseId":"brenton_1-chronicles_11_19","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":19,"text":"God forbid that I should do this thing: shall I drink the blood of these men with their lives? for with their lives they brought it. So he would not drink it. These things did the three mighty .","searchKeywords":["god","forbid","that","should","this","thing","shall","drink","the","blood","these","men","with","their","lives","for","they","brought","would","not","things","did","three","mighty"]},{"verseId":"brenton_1-chronicles_11_20","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":20,"text":"And Abisa the brother of Joab, he was chief of three: he drew his sword against three hundred slain at one time, and he had a name among the three.","searchKeywords":["and","abisa","the","brother","joab","was","chief","three","drew","his","sword","against","hundred","slain","one","time","had","name","among"]},{"verseId":"brenton_1-chronicles_11_21","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":21,"text":"He was more famous than the two of the three, and he was chief them; yet he reached not to the three.","searchKeywords":["was","more","famous","than","the","two","three","and","chief","them","yet","reached","not"]},{"verseId":"brenton_1-chronicles_11_22","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":22,"text":"And Banaia the son of Jodae was the son of a mighty man: many his acts for Cabasael: he smote two lion-like men of Moab, and he went down and smote a lion in a pit on a snowy day.","searchKeywords":["and","banaia","the","son","jodae","was","mighty","man","many","his","acts","for","cabasael","smote","two","lion","like","men","moab","went","down","pit","snowy","day"]},{"verseId":"brenton_1-chronicles_11_23","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":23,"text":"And he smote an Egyptian, a wonderful man five cubits ; and in the hand of the Egyptian a spear like a weavers' beam; and Banaia went down to him with a staff, and took the spear out of the Egyptian's hand, and slew him with his own spear.","searchKeywords":["and","smote","egyptian","wonderful","man","five","cubits","the","hand","spear","like","weavers","beam","banaia","went","down","him","with","staff","took","out","slew","his","own"]},{"verseId":"brenton_1-chronicles_11_24","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":24,"text":"These things did Banaia son of Jodae, and his name among the three mighties.","searchKeywords":["these","things","did","banaia","son","jodae","and","his","name","among","the","three","mighties"]},{"verseId":"brenton_1-chronicles_11_25","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":25,"text":"He was distinguished beyond the thirty, yet he reached not to the three: and David set him over his family.","searchKeywords":["was","distinguished","beyond","the","thirty","yet","reached","not","three","and","david","set","him","over","his","family"]},{"verseId":"brenton_1-chronicles_11_26","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":26,"text":"And the mighty of the forces , Asael the brother of Joab, Eleanan the son of Dodoe of Bethleem,","searchKeywords":["and","the","mighty","forces","asael","brother","joab","eleanan","son","dodoe","bethleem"]},{"verseId":"brenton_1-chronicles_11_27","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":27,"text":"Samaoth the Arorite, Chelles the Phelonite,","searchKeywords":["samaoth","the","arorite","chelles","phelonite"]},{"verseId":"brenton_1-chronicles_11_28","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":28,"text":"Ora the son of Ekkis the Thecoite, Abiezer the Anathothite,","searchKeywords":["ora","the","son","ekkis","thecoite","abiezer","anathothite"]},{"verseId":"brenton_1-chronicles_11_29","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":29,"text":"Sobochai the Usathite, Eli the Achonite,","searchKeywords":["sobochai","the","usathite","eli","achonite"]},{"verseId":"brenton_1-chronicles_11_30","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":30,"text":"Marai the Netophathite, Chthaod the son of Nooza the Netophathite,","searchKeywords":["marai","the","netophathite","chthaod","son","nooza"]},{"verseId":"brenton_1-chronicles_11_31","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":31,"text":"Airi the son of Rebie of the hill of Benjamin, Banaias the Pharathonite,","searchKeywords":["airi","the","son","rebie","hill","benjamin","banaias","pharathonite"]},{"verseId":"brenton_1-chronicles_11_32","translationId":"brenton","testament":"OT","bookIndex":13,"bookName":"1 Chronicles","bookAbbrev":"1-chronicles","chapter":11,"verse":32,"text":"Uri of Nachali Gaas, Abiel the Garabæthite,","searchKeywords":["uri","nachali","gaas","abiel","the","garab","thite"]},{"verseId":"brenton_1-chronicles_11_33","tran