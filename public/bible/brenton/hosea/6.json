[{"verseId":"brenton_hosea_6_1","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":6,"verse":1,"text":"Let us go, and return to the Lord our God; for he has torn, and will heal us; he will smite, and bind us up.","searchKeywords":["let","and","return","the","lord","our","god","for","has","torn","will","heal","smite","bind"]},{"verseId":"brenton_hosea_6_2","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":6,"verse":2,"text":"After two days he will heal us: in the third day we shall arise, and live before him, and shall know :","searchKeywords":["after","two","days","will","heal","the","third","day","shall","arise","and","live","before","him","know"]},{"verseId":"brenton_hosea_6_3","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":6,"verse":3,"text":"let us follow on to know the Lord: we shall find him ready as the morning, and he will come to us as the early and latter rain to the earth.","searchKeywords":["let","follow","know","the","lord","shall","find","him","ready","morning","and","will","come","early","latter","rain","earth"]},{"verseId":"brenton_hosea_6_4","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":6,"verse":4,"text":"What shall I do unto thee, Ephraim? What shall I do to thee, Juda? whereas your mercy is as a morning cloud, and as the early dew that goes away.","searchKeywords":["what","shall","unto","thee","ephraim","juda","whereas","your","mercy","morning","cloud","and","the","early","dew","that","goes","away"]},{"verseId":"brenton_hosea_6_5","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":6,"verse":5,"text":"Therefore have I mown down your prophets; I have slain them with the word of my mouth: and my judgment shall go forth as the light.","searchKeywords":["therefore","have","mown","down","your","prophets","slain","them","with","the","word","mouth","and","judgment","shall","forth","light"]},{"verseId":"brenton_hosea_6_6","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":6,"verse":6,"text":"For I will mercy rather than sacrifice, and the knowledge of God rather than whole-burnt-offerings.","searchKeywords":["for","will","mercy","rather","than","sacrifice","and","the","knowledge","god","whole","burnt","offerings"]},{"verseId":"brenton_hosea_6_7","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":6,"verse":7,"text":"But they are as a man transgressing a covenant:","searchKeywords":["but","they","are","man","transgressing","covenant"]},{"verseId":"brenton_hosea_6_8","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":6,"verse":8,"text":"there the city Galaad despised me, working vanity, troubling water.","searchKeywords":["there","the","city","galaad","despised","working","vanity","troubling","water"]},{"verseId":"brenton_hosea_6_9","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":6,"verse":9,"text":"And thy strength of a robber: the priests have hid the way, they have murdered Sicima; for they have wrought iniquity in the house of Israel.","searchKeywords":["and","thy","strength","robber","the","priests","have","hid","way","they","murdered","sicima","for","wrought","iniquity","house","israel"]},{"verseId":"brenton_hosea_6_10","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":6,"verse":10,"text":"I have seen horrible there, the fornication of Ephraim: Israel and Juda are defiled;","searchKeywords":["have","seen","horrible","there","the","fornication","ephraim","israel","and","juda","are","defiled"]},{"verseId":"brenton_hosea_6_11","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":6,"verse":11,"text":"begin to gather grapes for thyself, when I turn the captivity of my people.","searchKeywords":["begin","gather","grapes","for","thyself","when","turn","the","captivity","people"]}]