[{"verseId":"brenton_hosea_5_1","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":1,"text":"Hear these things, ye priests; and attend, O house of Israel; and hearken, O house of the king; for the controversy is with you, because ye have been a snare in Scopia, and as a net spread on Itabyrium,","searchKeywords":["hear","these","things","priests","and","attend","house","israel","hearken","the","king","for","controversy","with","you","because","have","been","snare","scopia","net","spread","itabyrium"]},{"verseId":"brenton_hosea_5_2","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":2,"text":"which they that hunt the prey have fixed: but I will correct you.","searchKeywords":["which","they","that","hunt","the","prey","have","fixed","but","will","correct","you"]},{"verseId":"brenton_hosea_5_3","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":3,"text":"I know Ephraim, and Israel is not far from me: for now Ephraim has gone grievously a-whoring, Israel is defiled.","searchKeywords":["know","ephraim","and","israel","not","far","from","for","now","has","gone","grievously","whoring","defiled"]},{"verseId":"brenton_hosea_5_4","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":4,"text":"They have not framed their counsels to return to their God, for the spirit of fornication is in them, and they have not known the Lord.","searchKeywords":["they","have","not","framed","their","counsels","return","god","for","the","spirit","fornication","them","and","known","lord"]},{"verseId":"brenton_hosea_5_5","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":5,"text":"And the pride of Israel shall be brought low before his face; and Israel and Ephraim shall fall in their iniquities; and Judas also shall fall with them.","searchKeywords":["and","the","pride","israel","shall","brought","low","before","his","face","ephraim","fall","their","iniquities","judas","also","with","them"]},{"verseId":"brenton_hosea_5_6","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":6,"text":"They shall go with sheep and calves diligently to seek the Lord; but they shall not find him, for he has withdrawn himself from them.","searchKeywords":["they","shall","with","sheep","and","calves","diligently","seek","the","lord","but","not","find","him","for","has","withdrawn","himself","from","them"]},{"verseId":"brenton_hosea_5_7","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":7,"text":"For they have forsaken the Lord; for strange children have been born to them: now shall the cankerworm devour them and their heritages.","searchKeywords":["for","they","have","forsaken","the","lord","strange","children","been","born","them","now","shall","cankerworm","devour","and","their","heritages"]},{"verseId":"brenton_hosea_5_8","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":8,"text":"Blow ye the trumpet on the hills, sound aloud on the heights: proclaim in the house of On, Benjamin is amazed.","searchKeywords":["blow","the","trumpet","hills","sound","aloud","heights","proclaim","house","benjamin","amazed"]},{"verseId":"brenton_hosea_5_9","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":9,"text":"Ephraim has come to nought in the days of reproof: in the tribes of Israel I have shown faithful .","searchKeywords":["ephraim","has","come","nought","the","days","reproof","tribes","israel","have","shown","faithful"]},{"verseId":"brenton_hosea_5_10","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":10,"text":"The princes of Juda became as they that removed the bounds: I will pour out upon them my fury as water.","searchKeywords":["the","princes","juda","became","they","that","removed","bounds","will","pour","out","upon","them","fury","water"]},{"verseId":"brenton_hosea_5_11","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":11,"text":"Ephraim altogether prevailed against his adversary, he trod judgment under foot, for he began to go after vanities.","searchKeywords":["ephraim","altogether","prevailed","against","his","adversary","trod","judgment","under","foot","for","began","after","vanities"]},{"verseId":"brenton_hosea_5_12","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":12,"text":"Therefore I as consternation to Ephraim, and as a goad to the house of Juda.","searchKeywords":["therefore","consternation","ephraim","and","goad","the","house","juda"]},{"verseId":"brenton_hosea_5_13","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":13,"text":"And Ephraim saw his disease, and Judas his pain; then Ephraim went to the Assyrians, and sent ambassadors to king Jarim: but he could not heal you, and your pain shall in nowise cease from you.","searchKeywords":["and","ephraim","saw","his","disease","judas","pain","then","went","the","assyrians","sent","ambassadors","king","jarim","but","could","not","heal","you","your","shall","nowise","cease","from"]},{"verseId":"brenton_hosea_5_14","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":14,"text":"Wherefore I am as a panther to Ephraim, and as a lion to the house of Juda: and I will tear, and go away; and I will take, and there shall be none to deliver.","searchKeywords":["wherefore","panther","ephraim","and","lion","the","house","juda","will","tear","away","take","there","shall","none","deliver"]},{"verseId":"brenton_hosea_5_15","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":5,"verse":15,"text":"I will go and return to my place, until they are brought to nought, and shall they seek my face.","searchKeywords":["will","and","return","place","until","they","are","brought","nought","shall","seek","face"]}]