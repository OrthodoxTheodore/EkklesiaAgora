[{"verseId":"brenton_hosea_12_1","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":1,"text":"Ephraim has compassed me with falsehood, and the house of Israel and Juda with ungodliness: now God knows them, and they shall be called God's holy people.","searchKeywords":["ephraim","has","compassed","with","falsehood","and","the","house","israel","juda","ungodliness","now","god","knows","them","they","shall","called","holy","people"]},{"verseId":"brenton_hosea_12_2","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":2,"text":"But Ephraim is an evil spirit, he has chased the east wind all the day: he has multiplied empty and vain things, and made a covenant with the Assyrians, and oil has gone in the way of traffic into Egypt.","searchKeywords":["but","ephraim","evil","spirit","has","chased","the","east","wind","all","day","multiplied","empty","and","vain","things","made","covenant","with","assyrians","oil","gone","way","traffic","into","egypt"]},{"verseId":"brenton_hosea_12_3","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":3,"text":"And the Lord a controversy with Juda, in order to punish Jacob: according to his ways and according to his practices will he recompense him.","searchKeywords":["and","the","lord","controversy","with","juda","order","punish","jacob","according","his","ways","practices","will","recompense","him"]},{"verseId":"brenton_hosea_12_4","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":4,"text":"He took his brother by the heel in the womb, and in his labours he had power with God.","searchKeywords":["took","his","brother","the","heel","womb","and","labours","had","power","with","god"]},{"verseId":"brenton_hosea_12_5","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":5,"text":"And he prevailed with the angel and was strong: they wept, and intreated me: they found me in the house of On, and there was spoken to them.","searchKeywords":["and","prevailed","with","the","angel","was","strong","they","wept","intreated","found","house","there","spoken","them"]},{"verseId":"brenton_hosea_12_6","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":6,"text":"But the Lord God Almighty shall be his memorial.","searchKeywords":["but","the","lord","god","almighty","shall","his","memorial"]},{"verseId":"brenton_hosea_12_7","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":7,"text":"Thou therefore shalt return to thy God: keep thou mercy and judgment, and draw nigh to thy God continually.","searchKeywords":["thou","therefore","shalt","return","thy","god","keep","mercy","and","judgment","draw","nigh","continually"]},{"verseId":"brenton_hosea_12_8","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":8,"text":"Chanaan, in his hand is a balance of unrighteousness: he has loved to tyrannise.","searchKeywords":["chanaan","his","hand","balance","unrighteousness","has","loved","tyrannise"]},{"verseId":"brenton_hosea_12_9","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":9,"text":"And Ephraim said, Nevertheless I am rich, I have found refreshment to myself. None of his labours shall be found to him, by reason of the sins which he has committed.","searchKeywords":["and","ephraim","said","nevertheless","rich","have","found","refreshment","myself","none","his","labours","shall","him","reason","the","sins","which","has","committed"]},{"verseId":"brenton_hosea_12_10","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":10,"text":"But I the Lord thy God brought thee up out of the land of Egypt: I will yet cause thee to dwell in tabernacles, according to the days of the feast.","searchKeywords":["but","the","lord","thy","god","brought","thee","out","land","egypt","will","yet","cause","dwell","tabernacles","according","days","feast"]},{"verseId":"brenton_hosea_12_11","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":11,"text":"And I will speak to the prophets, and I have multiplied visions, and by the means of the prophets I was represented.","searchKeywords":["and","will","speak","the","prophets","have","multiplied","visions","means","was","represented"]},{"verseId":"brenton_hosea_12_12","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":12,"text":"If Galaad exists not, then the chiefs in Galaad when they sacrificed were false, and their altars were as heaps on the ground of the field.","searchKeywords":["galaad","exists","not","then","the","chiefs","when","they","sacrificed","were","false","and","their","altars","heaps","ground","field"]},{"verseId":"brenton_hosea_12_13","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":13,"text":"And Jacob retreated into the plain of Syria, and Israel served for a wife, and waited for a wife.","searchKeywords":["and","jacob","retreated","into","the","plain","syria","israel","served","for","wife","waited"]},{"verseId":"brenton_hosea_12_14","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":14,"text":"And the Lord brought Israel out of the land of Egypt by a prophet, and by a prophet was he preserved.","searchKeywords":["and","the","lord","brought","israel","out","land","egypt","prophet","was","preserved"]},{"verseId":"brenton_hosea_12_15","translationId":"brenton","testament":"OT","bookIndex":33,"bookName":"Hosea","bookAbbrev":"hosea","chapter":12,"verse":15,"text":"Ephraim was angry and excited, therefore his blood shall be poured out upon him, and the Lord shall recompense to him his reproach.","searchKeywords":["ephraim","was","angry","and","excited","therefore","his","blood","shall","poured","out","upon","him","the","lord","recompense","reproach"]}]