rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Avatars: owner can write, anyone can read
    match /avatars/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // Banners: owner can write, anyone can read
    match /banners/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // Post images: owner can write, anyone can read
    match /posts/{uid}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    // Videos: owner can upload video files, anyone can read
    match /videos/{uid}/{videoId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid
        && request.resource.contentType.matches('video/.*');
    }
    // Thumbnails: authenticated user can upload, anyone can read
    match /thumbnails/{videoId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Channel assets (logos, banners): authenticated user can upload, anyone can read
    match /channels/{channelId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
